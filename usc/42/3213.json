{"tag":"section","attrib":{"id":"idbc79736c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3213"},"text":null,"children":[{"tag":"num","attrib":{"value":"3213"},"text":"§ 3213.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc79736d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3213/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2000-07-01"},"text":"July 1, 2000","children":[],"tail":", and July 1 of each year thereafter, the Secretary shall submit to Congress a comprehensive and detailed annual report on the activities of the Secretary under this chapter during the most recently completed fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc79736e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3213/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report required under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc79736f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3213/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a list of all grant recipients by State, including the projected private sector dollar to Federal dollar investment ratio for each grant recipient;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc797370-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3213/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include a discussion of any private sector leveraging goal with respect to grants awarded to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc797371-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3213/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rural areas and urban economically distressed areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc797372-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3213/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" highly distressed areas;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc797373-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3213/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the completion of a project, include the realized private sector dollar to Federal dollar investment ratio for the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc797374-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3213/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc797375-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3213/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a list of all of the grants provided by the Economic Development Administration for projects located in, or that primarily benefit, rural areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc797376-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3213/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation of the process used to determine how each project referred to in subparagraph (A) would benefit a rural area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc797377-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3213/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a certification that each project referred to in subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc797378-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3213/b/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is located in a rural area; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc797379-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3213/b/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will primarily benefit a rural area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc79737a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3213/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional reporting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As part of the annual report to Congress of the Economic Development Administration, the Secretary shall include a report on project completions and close outs for construction awards that includes the following information on individual construction projects:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc79737b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3213/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The award date of the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc79737c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3213/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The completion date of the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc79737d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3213/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The close out date of the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc79737e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3213/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total amount of the project, including non-Federal cost share and funding from other sources, including a breakdown by source.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc79737f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3213/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of jobs anticipated to be created or retained as a result of the investment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc797380-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3213/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than the date of the submission of the report under subsection (c), the Secretary shall make the report under subsection (c) publicly available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc797381-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3213/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional reporting requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To ensure that projects are meeting expected timelines, not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", the Secretary shall submit to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a report that, at a minimum—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc797382-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3213/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes an analysis of Economic Development Administration construction project timeline estimates and actual project durations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc797383-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3213/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the frequency with which project timelines are delayed and the sources of those delays, including cases in which a project scope or schedule requires an award amendment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc797384-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tVI/s603"},"text":"Pub. L. 89–136, title VI, § 603","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/tI/s102/a"},"text":"Pub. L. 105–393, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3614"},"text":"112 Stat. 3614","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/373/tVI/s601"},"text":"Pub. L. 108–373, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-27"},"text":"Oct. 27, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1769"},"text":"118 Stat. 1769","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dB/tII/s2230"},"text":"Pub. L. 118–272, div. B, title II, § 2230","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3196"},"text":"138 Stat. 3196","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc797385-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc797386-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc797387-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3213, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tVII/s703"},"text":"Pub. L. 89–136, title VII, § 703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-08-26"},"text":"Aug. 26, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/572"},"text":"79 Stat. 572","children":[],"tail":", set forth savings provisions, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/s102/b/3"},"text":"Pub. L. 105–393, § 102(b)(3)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/s603"},"text":"section 603 of Pub. L. 89–136","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3203"},"text":"section 3203 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/s102/a"},"text":"Pub. L. 105–393, § 102(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc797388-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2230/1/A/i"},"text":"Pub. L. 118–272, § 2230(1)(A)(i)","children":[],"tail":", inserted “areas” after “rural”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2230/1/A/ii"},"text":"Pub. L. 118–272, § 2230(1)(A)(ii)","children":[],"tail":"–(C), added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2230/2"},"text":"Pub. L. 118–272, § 2230(2)","children":[],"tail":", added subsecs. (c) to (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/373"},"text":"Pub. L. 108–373","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc797389-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbc79738a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1999-02-11"},"text":"Feb. 11, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/s105"},"text":"section 105 of Pub. L. 105–393","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3121"},"text":"section 3121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
