{"tag":"section","attrib":{"id":"idbaa3a1d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"1396w–4"},"text":"§ 1396w–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State option to provide coordinated care through a health home for individuals with chronic conditions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbaa3a1d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396a/a/1"},"text":"section 1396a(a)(1) of this title","children":[],"tail":" (relating to statewideness), "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396a/a/10/B"},"text":"section 1396a(a)(10)(B) of this title","children":[],"tail":" (relating to comparability), and any other provision of this subchapter for which the Secretary determines it is necessary to waive in order to implement this section, beginning "},{"tag":"date","attrib":{"date":"2011-01-01"},"text":"January 1, 2011","children":[],"tail":", a State, at its option as a State plan amendment, may provide for medical assistance under this subchapter to eligible individuals with chronic conditions who select a designated provider (as described under subsection (h)(5)), a team of health care professionals (as described under subsection (h)(6)) operating with such a provider, or a health team (as described under subsection (h)(7)) as the individual’s health home for purposes of providing the individual with health home services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaa3a1d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health home qualification standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish standards for qualification as a designated provider for the purpose of being eligible to be a health home for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaa3a1d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaa3a1d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State shall provide a designated provider, a team of health care professionals operating with such a provider, or a health team with payments for the provision of health home services to each eligible individual with chronic conditions that selects such provider, team of health care professionals, or health team as the individual’s health home. Payments made to a designated provider, a team of health care professionals operating with such a provider, or a health team for such services shall be treated as medical assistance for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396b/a"},"text":"section 1396b(a) of this title","children":[],"tail":", except that, subject to paragraph (4), during the first 8 fiscal year quarters that the State plan amendment is in effect, the Federal medical assistance percentage applicable to such payments shall be equal to 90 percent."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaa3a1d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Methodology","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaa3a1d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The State shall specify in the State plan amendment the methodology the State will use for determining payment for the provision of health home services. Such methodology for determining payment—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbaa3a1d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be tiered to reflect, with respect to each eligible individual with chronic conditions provided such services by a designated provider, a team of health care professionals operating with such a provider, or a health team, as well as the severity or number of each such individual’s chronic conditions or the specific capabilities of the provider, team of health care professionals, or health team; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaa3a1d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be established consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396a/a/30/A"},"text":"section 1396a(a)(30)(A) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaa3a1da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternate models of payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The methodology for determining payment for provision of health home services under this section shall not be limited to a per-member per-month basis and may provide (as proposed by the State and subject to approval by the Secretary) for alternate models of payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaa3a1db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Planning grants","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaa3a1dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning ","children":[{"tag":"date","attrib":{"date":"2011-01-01"},"text":"January 1, 2011","children":[],"tail":", the Secretary may award planning grants to States for purposes of developing a State plan amendment under this section. A planning grant awarded to a State under this paragraph shall remain available until expended."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaa3a1dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State contribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State awarded a planning grant shall contribute an amount equal to the State percentage determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396d/b"},"text":"section 1396d(b) of this title","children":[],"tail":" (without regard to "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/s5001"},"text":"section 5001 of Public Law 111–5","children":[],"tail":") for each fiscal year for which the grant is awarded."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaa3a1de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total amount of payments made to States under this paragraph shall not exceed $25,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaa3a1df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule relating to substance use disorder health homes","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaa3a1e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a State with an SUD-focused State plan amendment approved by the Secretary on or after ","children":[{"tag":"date","attrib":{"date":"2018-10-01"},"text":"October 1, 2018","children":[],"tail":", the Secretary may, at the request of the State, extend the application of the Federal medical assistance percentage described in paragraph (1) to payments for the provision of health home services to SUD-eligible individuals under such State plan amendment, in addition to the first 8 fiscal year quarters the State plan amendment is in effect, for the subsequent 2 fiscal year quarters that the State plan amendment is in effect. Nothing in this section shall be construed as prohibiting a State with a State plan amendment that is approved under this section and that is not an SUD-focused State plan amendment from additionally having approved on or after such date an SUD-focused State plan amendment under this section, including for purposes of application of this paragraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaa3a1e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a State with an SUD-focused State plan amendment for which the application of the Federal medical assistance percentage has been extended under subparagraph (A), such State shall, at the end of the period of such State plan amendment, submit to the Secretary a report on the following, with respect to SUD-eligible individuals provided health home services under such State plan amendment:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbaa3a1e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/c/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The quality of health care provided to such individuals, with a focus on outcomes relevant to the recovery of each such individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaa3a1e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/c/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The access of such individuals to health care.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaa3a1e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/c/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total expenditures of such individuals for health care.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of this subparagraph, the Secretary shall specify all applicable measures for determining quality, access, and expenditures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaa3a1e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Best practices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2020-10-01"},"text":"October 1, 2020","children":[],"tail":", the Secretary shall make publicly available on the internet website of the Centers for Medicare & Medicaid Services best practices for designing and implementing an SUD-focused State plan amendment, based on the experiences of States that have State plan amendments approved under this section that include SUD-eligible individuals."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaa3a1e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this paragraph:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbaa3a1e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/c/4/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SUD-eligible individuals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “SUD-eligible individual” means, with respect to a State, an individual who satisfies all of the following:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbaa3a1e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/c/4/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The individual is an eligible individual with chronic conditions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbaa3a1e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/c/4/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The individual is an individual with a substance use disorder.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbaa3a1ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/c/4/D/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The individual has not previously received health home services under any other State plan amendment approved for the State under this section by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaa3a1eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/c/4/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SUD-focused State plan amendment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “SUD-focused State plan amendment” means a State plan amendment under this section that is designed to provide health home services primarily to SUD-eligible individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaa3a1ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hospital referrals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State shall include in the State plan amendment a requirement for hospitals that are participating providers under the State plan or a waiver of such plan to establish procedures for referring any eligible individuals with chronic conditions who seek or need treatment in a hospital emergency department to designated providers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaa3a1ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State shall consult and coordinate, as appropriate, with the Substance Abuse and Mental Health Services Administration in addressing issues regarding the prevention and treatment of mental illness and substance abuse among eligible individuals with chronic conditions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaa3a1ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State shall include in the State plan amendment—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaa3a1ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a methodology for tracking avoidable hospital readmissions and calculating savings that result from improved chronic care coordination and management under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaa3a1f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a proposal for use of health information technology in providing health home services under this section and improving service delivery and coordination across the care continuum (including the use of wireless patient technology to improve coordination and management of care and patient adherence to recommendations made by their provider).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaa3a1f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on quality measures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition for receiving payment for health home services provided to an eligible individual with chronic conditions, a designated provider shall report to the State, in accordance with such requirements as the Secretary shall specify, on all applicable measures for determining the quality of such services. When appropriate and feasible, a designated provider shall use health information technology in providing the State with such information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaa3a1f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaa3a1f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible individual with chronic conditions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaa3a1f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subparagraph (B), the term “eligible individual with chronic conditions” means an individual who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbaa3a1f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/h/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is eligible for medical assistance under the State plan or under a waiver of such plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaa3a1f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/h/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has at least—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbaa3a1f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/h/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 chronic conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbaa3a1f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/h/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 chronic condition and is at risk of having a second chronic condition; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbaa3a1f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/h/1/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 serious and persistent mental health condition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaa3a1fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this paragraph shall prevent the Secretary from establishing higher levels as to the number or severity of chronic or mental health conditions for purposes of determining eligibility for receipt of health home services under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaa3a1fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chronic condition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “chronic condition” has the meaning given that term by the Secretary and shall include, but is not limited to, the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaa3a1fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A mental health condition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaa3a1fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Substance use disorder.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaa3a1fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Asthma.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaa3a1ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/h/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Diabetes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaa3a200-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/h/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Heart disease.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaa3a201-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/h/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Being overweight, as evidenced by having a Body Mass Index (BMI) over 25.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaa3a202-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health home","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “health home” means a designated provider (including a provider that operates in coordination with a team of health care professionals) or a health team selected by an eligible individual with chronic conditions to provide health home services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaa3a203-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health home services","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaa3a204-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/h/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “health home services” means comprehensive and timely high-quality services described in subparagraph (B) that are provided by a designated provider, a team of health care professionals operating with such a provider, or a health team.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaa3a205-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/h/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The services described in this subparagraph are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbaa3a206-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/h/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comprehensive care management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaa3a207-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/h/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" care coordination and health promotion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaa3a208-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/h/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comprehensive transitional care, including appropriate follow-up, from inpatient to other settings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaa3a209-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/h/4/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" patient and family support (including authorized representatives);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaa3a20a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/h/4/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" referral to community and social support services, if relevant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaa3a20b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/h/4/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use of health information technology to link services, as feasible and appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaa3a20c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/h/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designated provider","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “designated provider” means a physician, clinical practice or clinical group practice, rural clinic, community health center, community mental health center, home health agency, or any other entity or provider (including pediatricians, gynecologists, and obstetricians) that is determined by the State and approved by the Secretary to be qualified to be a health home for eligible individuals with chronic conditions on the basis of documentation evidencing that the physician, practice, or clinic—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaa3a20d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/h/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the systems and infrastructure in place to provide health home services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaa3a20e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/h/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfies the qualification standards established by the Secretary under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaa3a20f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/h/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Team of health care professionals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “team of health care professionals” means a team of health professionals (as described in the State plan amendment) that may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaa3a210-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/h/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include physicians and other professionals, such as a nurse care coordinator, nutritionist, social worker, behavioral health professional, or any professionals deemed appropriate by the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaa3a211-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/h/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be free standing, virtual, or based at a hospital, community health center, community mental health center, rural clinic, clinical practice or clinical group practice, academic health center, or any entity deemed appropriate by the State and approved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaa3a212-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396w–4/h/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health team","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “health team” has the meaning given such term for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s256a–1"},"text":"section 256a–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbaa3a213-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XIX, § 1945, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tII/s2703/a"},"text":"Pub. L. 111–148, title II, § 2703(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/319"},"text":"124 Stat. 319","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/271/tI/s1006/a"},"text":"Pub. L. 115–271, title I, § 1006(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3913"},"text":"132 Stat. 3913","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbaa3a214-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbaa3a215-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbaa3a216-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/s5001"},"text":"Section 5001 of Public Law 111–5","children":[],"tail":", referred to in subsec. (c)(3)(B), is "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/s5001"},"text":"section 5001 of Pub. L. 111–5","children":[],"tail":", div. B, title V, "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/496"},"text":"123 Stat. 496","children":[],"tail":", which was formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396d"},"text":"section 1396d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbaa3a217-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s1006/a/1"},"text":"Pub. L. 115–271, § 1006(a)(1)","children":[],"tail":", inserted “subject to paragraph (4),” after “except that,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s1006/a/2"},"text":"Pub. L. 115–271, § 1006(a)(2)","children":[],"tail":", added par. (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbaa3a218-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbaa3a219-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Survey and Interim Report","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tII/s2703/b/2"},"text":"Pub. L. 111–148, title II, § 2703(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/322"},"text":"124 Stat. 322","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/148/tII/s2703/b/2"},"text":"\n","children":[{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2014-01-01"},"text":"January 1, 2014","children":[],"tail":", the Secretary of Health and Human Services shall survey States that have elected the option under section 1945 of the Social Security Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396w–4"},"text":"42 U.S.C. 1396w–4","children":[],"tail":"] (as added by subsection (a)) and report to Congress on the nature, extent, and use of such option, particularly as it pertains to—"}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hospital admission rates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chronic disease management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordination of care for individuals with chronic conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"“(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessment of program implementation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"“(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" processes and lessons learned (as described in subparagraph (B));","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"“(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessment of quality improvements and clinical outcomes under such option; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"“(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimates of cost savings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation reporting","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A State that has elected the option under section 1945 of the Social Security Act (as added by subsection (a)) shall report to the Secretary, as necessary, on processes that have been developed and lessons learned regarding provision of coordinated care through a health home for Medicaid beneficiaries with chronic conditions under such option.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
