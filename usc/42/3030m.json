{"tag":"section","attrib":{"id":"idbc58094f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030m"},"text":null,"children":[{"tag":"num","attrib":{"value":"3030m"},"text":"§ 3030m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc580950-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030m/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary shall carry out a program for making grants to States under State plans approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3027"},"text":"section 3027 of this title","children":[],"tail":" to provide evidence-based disease prevention and health promotion services and information at multipurpose senior centers, at congregate meal sites, through home delivered meals programs, or at other appropriate sites. In carrying out such program, the Assistant Secretary shall provide technical assistance on the delivery of evidence-based disease prevention and health promotion services in different settings and for different populations, and consult with the Directors of the Centers for Disease Control and Prevention and the National Institute on Aging."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc580951-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030m/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community organizations and agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary shall, to the extent possible, assure that services provided by other community organizations and agencies are used to carry out the provisions of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc580952-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030m/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improving indoor air quality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary shall work in consultation with qualified experts to provide information on methods of improving indoor air quality in buildings where older individuals congregate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc580953-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tIII/s361"},"text":"Pub. L. 89–73, title III, § 361","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/175/tI/s143/c"},"text":"Pub. L. 100–175, title I, § 143(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-11-29"},"text":"Nov. 29, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/947"},"text":"101 Stat. 947","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/375/tIII/s319/a"},"text":"Pub. L. 102–375, title III, § 319(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"Sept. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1241"},"text":"106 Stat. 1241","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/171"},"text":"Pub. L. 103–171","children":[],"tail":", §§ 2(13), 3(a)(13), "},{"tag":"date","attrib":{"date":"1993-12-02"},"text":"Dec. 2, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1989"},"text":"107 Stat. 1989","children":[],"tail":", 1990; "},{"tag":"ref","attrib":{"href":"/us/pl/109/365/tIII/s319"},"text":"Pub. L. 109–365, title III, § 319","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2551"},"text":"120 Stat. 2551","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/144/s4/j/2"},"text":"Pub. L. 114–144, § 4(j)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-04-19"},"text":"Apr. 19, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/340"},"text":"130 Stat. 340","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/131/tI/s117/b"},"text":"Pub. L. 116–131, title I, § 117(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-25"},"text":"Mar. 25, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/246"},"text":"134 Stat. 246","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc580954-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc580955-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc580956-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/131"},"text":"Pub. L. 116–131","children":[],"tail":" inserted “provide technical assistance on the delivery of evidence-based disease prevention and health promotion services in different settings and for different populations, and” before “consult”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/144"},"text":"Pub. L. 114–144","children":[],"tail":" inserted “evidence-based” after “to provide”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/365"},"text":"Pub. L. 109–365","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/171"},"text":"Pub. L. 103–171","children":[],"tail":", §§ 2(13), 3(a)(13), substituted “Assistant Secretary” for “Commissioner” in two places and inserted “and Prevention” after “Control”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/171/s3/a/13"},"text":"Pub. L. 103–171, § 3(a)(13)","children":[],"tail":", substituted “Assistant Secretary” for “Commissioner”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/375/s319/a/1"},"text":"Pub. L. 102–375, § 319(a)(1)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “The Commissioner shall carry out a program for making grants to States under State plans approved under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3027"},"text":"section 3027 of this title","children":[],"tail":" for periodic preventive health services to be provided at senior centers or alternative sites as appropriate.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/375/s319/a/2"},"text":"Pub. L. 102–375, § 319(a)(2)","children":[],"tail":", (3), redesignated subsec. (c) as (b) and struck out former subsec. (b) which read as follows: “Preventive health services under this part may not include services eligible for reimbursement under Medicare.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc580957-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbc580958-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1987-10-01"},"text":"Oct. 1, 1987","children":[],"tail":", except not applicable with respect to any area plan submitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3026/a"},"text":"section 3026(a) of this title","children":[],"tail":" or any State plan submitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3027/a"},"text":"section 3027(a) of this title","children":[],"tail":" and approved for any fiscal year beginning before "},{"tag":"date","attrib":{"date":"1987-11-29"},"text":"Nov. 29, 1987","children":[],"tail":", see section 701(a), (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/100/175"},"text":"Pub. L. 100–175","children":[],"tail":", set out as an Effective Date of 1987 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
