{"tag":"section","attrib":{"id":"idbf1c3141-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10242"},"text":null,"children":[{"tag":"num","attrib":{"value":"10242"},"text":"§ 10242.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Nuclear Waste Negotiator","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf1c3142-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10242/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the Office of the Nuclear Waste Negotiator that shall be an independent establishment in the executive branch.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf1c3143-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10242/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nuclear Waste Negotiator","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf1c3144-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10242/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office shall be headed by a Nuclear Waste Negotiator who shall be appointed by the President, by and with the advice and consent of the Senate. The Negotiator shall hold office at the pleasure of the President, and shall be compensated at the rate provided for level III of the Executive Schedule in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf1c3145-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10242/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Negotiator shall attempt to find a State or Indian tribe willing to host a repository or monitored retrievable storage facility at a technically qualified site on reasonable terms and shall negotiate with any State or Indian tribe which expresses an interest in hosting a repository or monitored retrievable storage facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf1c3146-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/425/tIV/s402"},"text":"Pub. L. 97–425, title IV, § 402","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/d/tIII"},"text":"Pub. L. 100–202, § 101(d) [title III]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-104"},"text":"101 Stat. 1329–104","children":[],"tail":", 1329–121; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tV/s5041"},"text":"Pub. L. 100–203, title V, § 5041","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-243"},"text":"101 Stat. 1330–243","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/507/s1"},"text":"Pub. L. 100–507, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-18"},"text":"Oct. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2541"},"text":"102 Stat. 2541","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf1c3147-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf1c3148-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf1c3149-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" added identical sections."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf1c314a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/507"},"text":"Pub. L. 100–507","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “There is established within the Executive Office of the President the Office of the Nuclear Waste Negotiator.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
