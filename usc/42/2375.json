{"tag":"section","attrib":{"id":"idbc21418e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2375"},"text":null,"children":[{"tag":"num","attrib":{"value":"2375"},"text":"§ 2375.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gift of utility to city; charges and terms for utilities transferred to other transferees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Commission may give the utility to the city incorporated at the community; and must charge in selling the utility to any other transferee: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That at Los Alamos, utilities may be given to the county or other local governmental entity. The charges and terms for the transfer of any utility may be established by advertising and competitive bid, or by negotiated sale or other transfer at such prices, terms, and conditions as the Commission shall determine to be fair and equitable."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc21418f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-08-04/ch543"},"text":"Aug. 4, 1955, ch. 543","children":[],"tail":", ch. 7, § 75, "},{"tag":"ref","attrib":{"href":"/us/stat/69/480"},"text":"69 Stat. 480","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/719/s21"},"text":"Pub. L. 87–719, § 21","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-28"},"text":"Sept. 28, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/666"},"text":"76 Stat. 666","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc214190-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc214191-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc214192-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1962—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/719"},"text":"Pub. L. 87–719","children":[],"tail":" inserted “: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That at Los Alamos, utilities may be given to the county or other local governmental entity” after “transferee”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc214193-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbc214194-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Atomic Energy Commission abolished and functions transferred by sections 5814 and 5841 of this title. See also Transfer of Functions notes set out under those sections.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
