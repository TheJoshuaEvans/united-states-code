{"tag":"section","attrib":{"id":"idb5c720a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290kk"},"text":null,"children":[{"tag":"num","attrib":{"value":"290kk"},"text":"§ 290kk.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability to designated programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5c720a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290kk/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designated programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (b), this part applies to discretionary and formula grant programs administered by the Substance Abuse and Mental Health Services Administration that make awards of financial assistance to public or private entities for the purpose of carrying out activities to prevent or treat substance abuse (in this part referred to as a “designated program”). Designated programs include the program under subpart II of part B of subchapter XVII (relating to formula grants to the States).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5c720a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290kk/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This part does not apply to any award of financial assistance under a designated program for a purpose other than the purpose specified in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5c720a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290kk/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part (and subject to subsection (b)):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5c720a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290kk/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “designated program” has the meaning given such term in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5c720a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290kk/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “financial assistance” means a grant, cooperative agreement, or contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5c720a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290kk/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “program beneficiary” means an individual who receives program services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5c720a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290kk/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “program participant” means a public or private entity that has received financial assistance under a designated program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5c720aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290kk/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “program services” means treatment for substance abuse, or preventive services regarding such abuse, provided pursuant to an award of financial assistance under a designated program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5c720ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290kk/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “religious organization” means a nonprofit religious organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5c720ac-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 596, formerly § 581, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tI/s144"},"text":"Pub. L. 106–554, § 1(a)(7) [title I, § 144]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–619; renumbered § 596, "},{"tag":"ref","attrib":{"href":"/us/pl/119/44/tI/s107/a/2"},"text":"Pub. L. 119–44, title I, § 107(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-01"},"text":"Dec. 1, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/674"},"text":"139 Stat. 674","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
