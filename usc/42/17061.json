{"tag":"section","attrib":{"id":"idc0227dbd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061"},"text":null,"children":[{"tag":"num","attrib":{"value":"17061"},"text":"§ 17061.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this title: ","children":[{"tag":"ref","attrib":{"idref":"fn004240"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004240"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0227dbe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Administrator of General Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227dbf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Advisory Committee” means the Green Building Advisory Committee established under section 484.","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227dc0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commercial Director” means the individual appointed to the position established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17081"},"text":"section 17081 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227dc1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consortium","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Consortium” means the High-Performance Green Building Partnership Consortium created in response to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17092/c/1"},"text":"section 17092(c)(1) of this title","children":[],"tail":" to represent the private sector in a public-private partnership to promote high-performance green buildings and zero-net-energy commercial buildings."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227dc2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-effective lighting technology","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0227dc3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “cost-effective lighting technology” means a lighting technology that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0227dc4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will result in substantial operational cost savings by ensuring an installed consumption of not more than 1 watt per square foot; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0227dc5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is contained in a list under—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc0227dc6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/5/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8259b"},"text":"section 8259b of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc0227dc7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/5/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal acquisition regulation 23–203; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc0227dc8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/5/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is at least as energy-conserving as required by other provisions of this Act, including the requirements of this title ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" and title III "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" which shall be applicable to the extent that they would achieve greater energy savings than provided under clause (i) or this clause."},{"tag":"ref","attrib":{"idref":"fn004241"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004241"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Does not fit with cl. (ii) introductory provision."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227dc9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “cost-effective lighting technology” includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0227dca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lamps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0227dcb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ballasts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0227dcc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/5/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" luminaires;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0227dcd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/5/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lighting controls;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0227dce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/5/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" daylighting; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0227dcf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/5/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" early use of other highly cost-effective lighting technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227dd0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-effective technologies and practices","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “cost-effective technologies and practices” means a technology or practice that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0227dd1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will result in substantial operational cost savings by reducing electricity or fossil fuel consumption, water, or other utility costs, including use of geothermal heat pumps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227dd2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complies with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8259b"},"text":"section 8259b of this title","children":[],"tail":" and Federal acquisition regulation 23–203; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227dd3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is at least as energy and water conserving as required under this title,","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" including sections 431 through 435, and title V,"},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" including sections 511 through 525, which shall be applicable to the extent that they are more stringent or require greater energy or water savings than required by this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227dd4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal Director” means the individual appointed to the position established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17092/a"},"text":"section 17092(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227dd5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal facility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal facility” means any building that is constructed, renovated, leased, or purchased in part or in whole for use by the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227dd6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operational cost savings","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0227dd7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “operational cost savings” means a reduction in end-use operational costs through the application of cost-effective technologies and practices or geothermal heat pumps, including a reduction in electricity consumption relative to consumption by the same customer or at the same facility in a given year, as defined in guidelines promulgated by the Administrator pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7628/b"},"text":"section 7628(b) of this title","children":[],"tail":", that achieves cost savings sufficient to pay the incremental additional costs of using cost-effective technologies and practices including geothermal heat pumps by not later than the later of the date established under sections 431 through 434,"},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" or—"}],"tail":null},{"tag":"clause","attrib":{"id":"idc0227dd8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/9/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for cost-effective technologies and practices, the date that is 5 years after the date of installation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0227dd9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/9/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for geothermal heat pumps, as soon as practical after the date of installation of the applicable geothermal heat pump.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227dda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “operational cost savings” includes savings achieved at a facility as a result of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0227ddb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/9/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the installation or use of cost-effective technologies and practices; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0227ddc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/9/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the planting of vegetation that shades the facility and reduces the heating, cooling, or lighting needs of the facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227ddd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “operational cost savings” does not include savings from measures that would likely be adopted in the absence of cost-effective technology and practices programs, as determined by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227dde-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geothermal heat pump","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “geothermal heat pump” means any heating or air conditioning technology that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0227ddf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses the ground or ground water as a thermal energy source to heat, or as a thermal energy sink to cool, a building; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227de0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the requirements of the Energy Star program of the Environmental Protection Agency applicable to geothermal heat pumps on the date of purchase of the technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227de1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" GSA facility","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0227de2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “GSA facility” means any building, structure, or facility, in whole or in part (including the associated support systems of the building, structure, or facility) that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0227de3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/11/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is constructed (including facilities constructed for lease), renovated, or purchased, in whole or in part, by the Administrator for use by the Federal Government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0227de4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/11/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is leased, in whole or in part, by the Administrator for use by the Federal Government—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc0227de5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/11/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in subclause (II), for a term of not less than 5 years; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc0227de6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/11/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a term of less than 5 years, if the Administrator determines that use of cost-effective technologies and practices would result in the payback of expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227de7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “GSA facility” includes any group of buildings, structures, or facilities described in subparagraph (A) (including the associated energy-consuming support systems of the buildings, structures, and facilities).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227de8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/11/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may exempt from the definition of “GSA facility” under this paragraph a building, structure, or facility that meets the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8253/c"},"text":"section 8253(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227de9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High-performance building","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “high-performance building” means a building that integrates and optimizes on a life cycle basis all major high performance attributes, including energy conservation, environment, safety, security, durability, accessibility, cost-benefit, productivity, sustainability, functionality, and operational considerations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227dea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High-performance green building","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “high-performance green building” means a high-performance building that, during its life-cycle, as compared with similar buildings (as measured by Commercial Buildings Energy Consumption Survey or Residential Energy Consumption Survey data from the Energy Information Agency)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0227deb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduces energy, water, and material resource use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227dec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improves indoor environmental quality, including reducing indoor pollution, improving thermal comfort, and improving lighting and acoustic environments that affect occupant health and productivity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227ded-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/13/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduces negative impacts on the environment throughout the life-cycle of the building, including air and water pollution and waste generation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227dee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/13/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increases the use of environmentally preferable products, including biobased, recycled content, and nontoxic products with lower life-cycle impacts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227def-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/13/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increases reuse and recycling opportunities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227df0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/13/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrates systems in the building;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227df1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/13/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduces the environmental and energy impacts of transportation through building location and site design that support a full range of transportation choices for users of the building; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227df2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/13/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" considers indoor and outdoor effects of the building on human health and the environment, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0227df3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/13/H/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improvements in worker productivity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0227df4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/13/H/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the life-cycle impacts of building materials and operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0227df5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/13/H/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other factors that the Federal Director or the Commercial Director consider to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227df6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Life-cycle","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “life-cycle”, with respect to a high-performance green building, means all stages of the useful life of the building (including components, equipment, systems, and controls of the building) beginning at conception of a high-performance green building project and continuing through site selection, design, construction, landscaping, commissioning, operation, maintenance, renovation, deconstruction or demolition, removal, and recycling of the high-performance green building.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227df7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Life-cycle assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “life-cycle assessment” means a comprehensive system approach for measuring the environmental performance of a product or service over the life of the product or service, beginning at raw materials acquisition and continuing through manufacturing, transportation, installation, use, reuse, and end-of-life waste management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227df8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Life-cycle costing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “life-cycle costing”, with respect to a high-performance green building, means a technique of economic evaluation that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0227df9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/16/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sums, over a given study period, the costs of initial investment (less resale value), replacements, operations (including energy use), and maintenance and repair of an investment decision; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227dfa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/16/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is expressed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0227dfb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/16/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in present value terms, in the case of a study period equivalent to the longest useful life of the building, determined by taking into consideration the typical life of such a building in the area in which the building is to be located; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0227dfc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/16/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in annual value terms, in the case of any other study period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227dfd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Commercial High-Performance Green Buildings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Office of Commercial High-Performance Green Buildings” means the Office of Commercial High-Performance Green Buildings established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17081/a"},"text":"section 17081(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227dfe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Federal High-Performance Green Buildings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Office of Federal High-Performance Green Buildings” means the Office of Federal High-Performance Green Buildings established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17092/a"},"text":"section 17092(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227dff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Practices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “practices” means design, financing, permitting, construction, commissioning, operation and maintenance, and other practices that contribute to achieving zero-net-energy buildings or facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227e00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Zero-net-energy commercial building","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “zero-net-energy commercial building” means a commercial building that is designed, constructed, and operated to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0227e01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/20/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require a greatly reduced quantity of energy to operate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227e02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/20/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet the balance of energy needs from sources of energy that do not produce greenhouse gases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227e03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/20/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" therefore result in no net emissions of greenhouse gases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227e04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17061/20/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be economically viable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0227e05-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIV/s401"},"text":"Pub. L. 110–140, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1596"},"text":"121 Stat. 1596","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0227e06-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc0227e07-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc0227e08-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in text, is title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1596"},"text":"121 Stat. 1596","children":[],"tail":", which enacted this subchapter, part C (§ 6341 et seq.) of subchapter III of chapter 77 of this title, sections 6371h–1 and 7628 of this title, and subchapter V (§ 2695 et seq.) of chapter 53 of Title 15, Commerce and Trade, amended sections 6832, 6834, 6862, 6872, 8253, 8254, and 12709 of this title, and enacted provisions set out as notes under sections 6834 and 6872 of this title. For complete classification of title IV to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 484, referred to in par. (2), probably should be a reference to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s494"},"text":"section 494 of Pub. L. 110–140","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s17123"},"text":"section 17123 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This Act, referred to in par. (5)(A)(ii)(III), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1492"},"text":"121 Stat. 1492","children":[],"tail":", known as the Energy Independence and Security Act of 2007, which enacted this chapter and enacted and amended numerous other sections and notes in the Code. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s17001"},"text":"section 17001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Title III, referred to in par. (5)(A)(ii)(III), is title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1549"},"text":"121 Stat. 1549","children":[],"tail":", which enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s3313"},"text":"section 3313 of Title 40","children":[],"tail":", Public Buildings, Property, and Works, amended sections 6291 to 6295, 6297, 6302, 6304, 6311, 6313 to 6316, 15821, and 16191 of this title and sections 3307, 3310, and 3314 to 3316 of Title 40, and enacted provisions set out as notes under sections 6291, 6294, 6295, and 6313 of this title. For complete classification of title III to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sections 431 through 435, referred to in pars. (6)(C) and 9(A), are sections 431 to 435 of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":". Sections 431 to 434 amended sections 6832, 6834, and 8253 of this title and enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6834"},"text":"section 6834 of this title","children":[],"tail":". Section 435 enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s17091"},"text":"section 17091 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Title V, referred to in par. (6)(C), is title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1655"},"text":"121 Stat. 1655","children":[],"tail":", which enacted subchapter IV (§ 17131 et seq.) of this chapter, part D (§ 8279) of subchapter III of chapter 91 of this title, and sections 1824, 2162a, and 2169 of Title 2, The Congress, amended sections 6325, 6834, 8256, 8258, 8259b, 8287, and 8287c of this title, "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s2162"},"text":"section 2162 of Title 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2913"},"text":"section 2913 of Title 10","children":[],"tail":", Armed Forces, "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3203"},"text":"section 3203 of Title 15","children":[],"tail":", Commerce and Trade, and "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s2621"},"text":"section 2621 of Title 16","children":[],"tail":", Conservation, and enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8259b"},"text":"section 8259b of this title","children":[],"tail":". For complete classification of title V to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sections 511 through 525, referred to in par. (6)(C), are sections 511 to 525 of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":", which enacted part A (§ 17131) of subchapter IV of this chapter and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s17141"},"text":"section 17141 of this title","children":[],"tail":", amended sections 6834, 8256, 8258, 8259b, 8287, and 8287c of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2913"},"text":"section 2913 of Title 10","children":[],"tail":", Armed Forces, and enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8259b"},"text":"section 8259b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc0227e09-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc0227e0a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
