{"tag":"section","attrib":{"id":"idbe518e42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7553"},"text":null,"children":[{"tag":"num","attrib":{"value":"7553"},"text":"§ 7553.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on production of engines requiring leaded gasoline","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Administrator shall promulgate regulations applicable to motor vehicle engines and nonroad engines manufactured after model year 1992 that prohibit the manufacture, sale, or introduction into commerce of any engine that requires leaded gasoline.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbe518e43-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title II, § 218, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/549/tII/s226"},"text":"Pub. L. 101–549, title II, § 226","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2505"},"text":"104 Stat. 2505","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
