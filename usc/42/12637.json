{"tag":"section","attrib":{"id":"idbf852cf1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12637"},"text":null,"children":[{"tag":"num","attrib":{"value":"12637"},"text":"§ 12637.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonduplication and nondisplacement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf852cf2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12637/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonduplication","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf852cf3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12637/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assistance provided under the national service laws shall be used only for a program that does not duplicate, and is in addition to, an activity otherwise available in the locality of such program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf852cf4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12637/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private nonprofit entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assistance made available under the national service laws shall not be provided to a private nonprofit entity to conduct activities that are the same or substantially equivalent to activities provided by a State or local government agency that such entity resides in, unless the requirements of subsection (b) are met.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf852cf5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12637/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondisplacement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf852cf6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12637/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An employer shall not displace an employee, position, or volunteer (other than a participant under the national service laws), including partial displacement such as reduction in hours, wages, or employment benefits, as a result of the use by such employer of a participant in a program receiving assistance under the national service laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf852cf7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12637/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service opportunities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A service opportunity shall not be created under the national service laws that will infringe in any manner on the promotional opportunity of an employed individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf852cf8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12637/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on services","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf852cf9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12637/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duplication of services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A participant in a program receiving assistance under the national service laws shall not perform any services or duties or engage in activities that would otherwise be performed by an employee as part of the assigned duties of such employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf852cfa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12637/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplantation of hiring","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A participant in any program receiving assistance under the national service laws shall not perform any services or duties, or engage in activities, that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf852cfb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12637/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will supplant the hiring of employed workers; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf852cfc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12637/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are services, duties, or activities with respect to which an individual has recall rights pursuant to a collective bargaining agreement or applicable personnel procedures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf852cfd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12637/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties formerly performed by another employee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A participant in any program receiving assistance under the national service laws shall not perform services or duties that have been performed by or were assigned to any—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf852cfe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12637/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" presently employed worker;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf852cff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12637/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employee who recently resigned or was discharged;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf852d00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12637/b/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" employee who—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbf852d01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12637/b/3/C/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is subject to a reduction in force; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf852d02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12637/b/3/C/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has recall rights pursuant to a collective bargaining agreement or applicable personnel procedures;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf852d03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12637/b/3/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employee who is on leave (terminal, temporary, vacation, emergency, or sick); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf852d04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12637/b/3/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employee who is on strike or who is being locked out.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf852d05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12637/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Labor market information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Labor shall make available to the Corporation and to any program agency under this subchapter such labor market information as is appropriate for use in carrying out the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf852d06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12637/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Allowances, earnings, and payments to individuals participating in programs that receive assistance under this subchapter shall not be considered to be income for the purposes of determining eligibility for and the amount of income transfer and in-kind aid furnished under any Federal or federally assisted program based on need, other than as provided under the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s301"},"text":"42 U.S.C. 301","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf852d07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12637/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards of conduct","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Programs that receive assistance under this subchapter shall establish and stringently enforce standards of conduct at the program site to promote proper moral and disciplinary conditions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf852d08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12637/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parental involvement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf852d09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12637/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Programs that receive assistance under the national service laws shall consult with the parents or legal guardians of children in developing and operating programs that include and serve children.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf852d0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12637/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parental permission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Programs that receive assistance under the national service laws shall, before transporting minor children, provide the children’s parents with the reason for the transportation and obtain the parents’ written permission for such transportation, consistent with State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf852d0b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s177"},"text":"Pub. L. 101–610, title I, § 177","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3163"},"text":"104 Stat. 3163","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s117"},"text":"Pub. L. 103–82, title I, § 117","children":[],"tail":", title IV, § 402(b)(1), "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/864"},"text":"107 Stat. 864","children":[],"tail":", 918; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/f/tVIII/s405/d/42/A"},"text":"Pub. L. 105–277, div. A, § 101(f) [title VIII, § 405(d)(42)(A)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-337"},"text":"112 Stat. 2681–337","children":[],"tail":", 2681–427; "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1605"},"text":"Pub. L. 111–13, title I, § 1605","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1530"},"text":"123 Stat. 1530","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf852d0c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf852d0d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf852d0e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":", which is classified generally to chapter 7 (§ 301 et seq.) of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf852d0f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1605/1"},"text":"Pub. L. 111–13, § 1605(1)","children":[],"tail":", substituted “under the national service laws” for “under this subchapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1605/1"},"text":"Pub. L. 111–13, § 1605(1)","children":[],"tail":", (2), substituted “employee, position, or volunteer (other than a participant under the national service laws)” for “employee or position” and “under the national service laws” for “under this subchapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1605/1"},"text":"Pub. L. 111–13, § 1605(1)","children":[],"tail":", substituted “under the national service laws” for “under this subchapter” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1605/3"},"text":"Pub. L. 111–13, § 1605(3)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" amended heading and text of subsec. (d) generally. Prior to amendment, text read as follows: “Section 142(b) of the Job Training Partnership Act shall apply to the projects conducted under this subchapter as such projects were conducted under the Job Training Partnership Act.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (b)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s117/1"},"text":"Pub. L. 103–82, § 117(1)","children":[],"tail":", amended heading and text of subpar. (B) generally. Prior to amendment, text read as follows: “A participant in any program receiving assistance under this subchapter shall not perform any services or duties or engage in activities that will supplant the hiring of employed workers.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(C)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s117/2"},"text":"Pub. L. 103–82, § 117(2)","children":[],"tail":", amended cl. (iii) generally. Prior to amendment, cl. (iii) read as follows: “employee who is subject to a reduction in force;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s402/b/1"},"text":"Pub. L. 103–82, § 402(b)(1)","children":[],"tail":", substituted “Corporation” for “Commission”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf852d10-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf852d11-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13"},"text":"Pub. L. 111–13","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s6101/a"},"text":"section 6101(a) of Pub. L. 111–13","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf852d12-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s117"},"text":"section 117 of Pub. L. 103–82","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1993-10-01"},"text":"Oct. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s123"},"text":"section 123 of Pub. L. 103–82","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1701"},"text":"section 1701 of Title 16","children":[],"tail":", Conservation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s402/b/1"},"text":"section 402(b)(1) of Pub. L. 103–82","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1993-10-01"},"text":"Oct. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s406/a"},"text":"section 406(a) of Pub. L. 103–82","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5061"},"text":"section 5061 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
