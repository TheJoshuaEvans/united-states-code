{"tag":"section","attrib":{"id":"idb685dc50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–20"},"text":null,"children":[{"tag":"num","attrib":{"value":"300cc–20"},"text":"§ 300cc–20.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional authority with respect to research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb685dc51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–20/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data collection with respect to national prevalence","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb685dc52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–20/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary, acting through the Director of the Centers for Disease Control and Prevention, may, through representative sampling and other appropriate methodologies, provide for the continuous collection of data on the incidence in the United States of cases of acquired immune deficiency syndrome and of cases of infection with the etiologic agent for such syndrome. The Secretary may carry out the program of data collection directly or through cooperative agreements and contracts with public and nonprofit private entities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb685dc53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–20/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall encourage each State to enter into a cooperative agreement or contract under paragraph (1) with the Secretary in order to facilitate the prompt collection of the most recent accurate data on the incidence of cases described in such paragraph.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb685dc54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–20/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall ensure that data collected under paragraph (1) includes data on the demographic characteristics of the population of individuals with cases described in paragraph (1), including data on specific subpopulations at risk of infection with the etiologic agent for acquired immune deficiency syndrome.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb685dc55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–20/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out this subsection, the Secretary shall, for the purpose of assuring the utility of data collected under this section, request entities with expertise in the methodologies of data collection to provide, as soon as is practicable, assistance to the Secretary and to the States with respect to the development and utilization of uniform methodologies of data collection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb685dc56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–20/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall provide for the dissemination of data collected pursuant to this subsection. In carrying out this paragraph, the Secretary may publish such data as frequently as the Secretary determines to be appropriate with respect to the protection of the public health. The Secretary shall publish such data not less than once each year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb685dc57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–20/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Epidemiological and demographic data","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb685dc58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–20/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary, acting through the Director of the Centers for Disease Control and Prevention, shall develop an epidemiological data base and shall provide for long-term studies for the purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb685dc59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–20/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collecting information on the demographic characteristics of the population of individuals infected with the etiologic agent for acquired immune deficiency syndrome and the natural history of such infection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb685dc5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–20/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing models demonstrating the long-term domestic and international patterns of the transmission of such etiologic agent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb685dc5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–20/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may carry out paragraph (1) directly or through grants to, or cooperative agreeements ","children":[{"tag":"ref","attrib":{"idref":"fn002414"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002414"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" or contracts with, public and nonprofit private entities, including Federal agencies."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb685dc5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–20/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Long-term research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make grants to public and nonprofit private entities for the purpose of assisting grantees in conducting long-term research into treatments for acquired immune deficiency syndrome developed from knowledge of the genetic nature of the etiologic agent for such syndrome.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb685dc5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–20/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Social sciences research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director of the National Institute of Mental Health, may make grants to public and nonprofit private entities for the purpose of assisting grantees in conducting scientific research into the psychological and social sciences as such sciences relate to acquired immune deficiency syndrome.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb685dc5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–20/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb685dc5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–20/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of carrying out this section, there are authorized to be appropriated such sums as may be necessary for each fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb685dc60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–20/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts appropriated pursuant to paragraph (1) to carry out subsection (c) shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb685dc61-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXIII, § 2320, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tII/s201/4"},"text":"Pub. L. 100–607, title II, § 201(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3074"},"text":"102 Stat. 3074","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tII/s2617/d"},"text":"Pub. L. 100–690, title II, § 2617(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4240"},"text":"102 Stat. 4240","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/531/tIII/s312/d/20"},"text":"Pub. L. 102–531, title III, § 312(d)(20)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3505"},"text":"106 Stat. 3505","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXVIII/s1811/5"},"text":"Pub. L. 103–43, title XVIII, § 1811(5)","children":[],"tail":", (6), "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/200"},"text":"107 Stat. 200","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb685dc62-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb685dc63-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb685dc64-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43/s1811/5"},"text":"Pub. L. 103–43, § 1811(5)","children":[],"tail":", inserted “and the natural history of such infection” after “syndrome”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43/s1811/6"},"text":"Pub. L. 103–43, § 1811(6)","children":[],"tail":", substituted “fiscal year” for “of the fiscal years 1989 through 1991”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsecs. (a)(1), (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/531"},"text":"Pub. L. 102–531","children":[],"tail":" substituted “Centers for Disease Control and Prevention” for “Centers for Disease Control”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" substituted “subsection” for “section”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb685dc65-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb685dc66-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" effective immediately after enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/100/607"},"text":"Pub. L. 100–607","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/s2600"},"text":"section 2600 of Pub. L. 100–690","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s242m"},"text":"section 242m of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
