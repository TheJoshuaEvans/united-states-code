{"tag":"section","attrib":{"id":"idc029aa80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17131"},"text":null,"children":[{"tag":"num","attrib":{"value":"17131"},"text":"§ 17131.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training Federal contracting officers to negotiate energy efficiency contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc029aa81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17131/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall create and administer in the Federal Energy Management Program a training program to educate Federal contract negotiation and contract management personnel so that the contract officers are prepared to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc029aa82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17131/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" negotiate energy savings performance contracts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029aa83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17131/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conclude effective and timely contracts for energy efficiency services with all companies offering energy efficiency services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029aa84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17131/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review Federal contracts for all products and services for the potential energy efficiency opportunities and implications of the contracts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc029aa85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17131/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schedule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", the Secretary shall plan, staff, announce, and begin training under the Federal Energy Management Program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc029aa86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17131/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel to be trained","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Personnel appropriate to receive training under the Federal Energy Management Program shall be selected by and sent for the training from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc029aa87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17131/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029aa88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17131/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Veterans Affairs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029aa89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17131/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029aa8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17131/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the General Services Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029aa8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17131/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Housing and Urban Development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029aa8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17131/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Postal Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029aa8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17131/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all other Federal agencies and departments that enter contracts for buildings, building services, electricity and electricity services, natural gas and natural gas services, heating and air conditioning services, building fuel purchases, and other types of procurement or service contracts determined by the Secretary, in carrying out the Federal Energy Management Program, to offer the potential for energy savings and greenhouse gas emission reductions if negotiated with taking into account those goals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc029aa8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17131/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trainers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Training under the Federal Energy Management Program may be conducted by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc029aa8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17131/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attorneys or contract officers with experience in negotiating and managing contracts described in subsection (c)(7) from any agency, except that the Secretary shall reimburse the related salaries and expenses of the attorneys or contract officers from amounts made available for carrying out this section to the extent the attorneys or contract officers are not employees of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029aa90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17131/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private experts hired by the Secretary for the purposes of this section, except that the Secretary may not hire experts who are simultaneously employed by any company under contract to provide energy efficiency services to the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc029aa91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17131/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary to carry out this section $750,000 for each of fiscal years 2008 through 2012.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc029aa92-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tV/s517"},"text":"Pub. L. 110–140, title V, § 517","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1659"},"text":"121 Stat. 1659","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc029aa93-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc029aa94-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc029aa95-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
