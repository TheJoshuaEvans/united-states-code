{"tag":"section","attrib":{"id":"idbfdfcfb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15092"},"text":null,"children":[{"tag":"num","attrib":{"value":"15092"},"text":"§ 15092.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rule","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfdfcfb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15092/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfdfcfb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15092/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child with a disability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “child with a disability” means an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfdfcfb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15092/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a significant physical or mental impairment, as defined pursuant to State policy to the extent that such policy is established without regard to type of disability; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdfcfba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15092/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an infant or a young child from birth through age 8 and has a substantial developmental delay or specific congenital or acquired condition that presents a high probability of resulting in a disability if services are not provided to the infant or child.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfcfbb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15092/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Family","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfdfcfbc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15092/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), for purposes of the application of this subchapter in a State, the term “family” has the meaning given the term by the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdfcfbd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15092/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term does not include an employee who, acting in a paid employment capacity, provides services to a child with a disability in an out-of-home setting such as a hospital, nursing home, personal care home, board and care home, group home, or other facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfcfbe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15092/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Family support for families of children with disabilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “family support for families of children with disabilities” means supports, resources, services, and other assistance provided to families of children with disabilities pursuant to State policy that are designed to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfdfcfbf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15092/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support families in the efforts of such families to raise their children with disabilities in the home;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdfcfc0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15092/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthen the role of the family as primary caregiver for such children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdfcfc1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15092/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent involuntary out-of-the-home placement of such children and maintain family unity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdfcfc2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15092/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reunite families with children with disabilities who have been placed out of the home, whenever possible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfcfc3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15092/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfcfc4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15092/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the 50 States of the United States, the District of Columbia, the Commonwealth of Puerto Rico, the United States Virgin Islands, Guam, American Samoa, and the Commonwealth of the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfcfc5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15092/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Systems change activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “systems change activities” means efforts that result in laws, regulations, policies, practices, or organizational structures—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfdfcfc6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15092/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that are family-centered and family-directed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdfcfc7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15092/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that facilitate and increase access to, provision of, and funding for, family support services for families of children with disabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdfcfc8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15092/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that otherwise accomplish the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdfcfc9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15092/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"References in this subchapter to a child with a disability shall be considered to include references to an individual who is not younger than age 18 who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfdfcfca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15092/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a significant impairment described in subsection (a)(1)(A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfcfcb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15092/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is residing with and receiving assistance from a family member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfdfcfcc-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/402/tII/s203"},"text":"Pub. L. 106–402, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1729"},"text":"114 Stat. 1729","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
