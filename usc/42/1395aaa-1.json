{"tag":"section","attrib":{"id":"idba03dfa2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1395aaa–1"},"text":"§ 1395aaa–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quality and efficiency measurement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idba03dfa3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multi-stakeholder group input into selection of quality and efficiency measures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a pre-rulemaking process under which the following steps occur with respect to the selection of quality and efficiency measures described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395aaa/b/7/B"},"text":"section 1395aaa(b)(7)(B) of this title","children":[],"tail":":"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idba03dfa4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Input","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395aaa/b/7"},"text":"section 1395aaa(b)(7) of this title","children":[],"tail":", the entity with a contract under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395aaa"},"text":"section 1395aaa of this title","children":[],"tail":" shall convene multi-stakeholder groups to provide input to the Secretary on the selection of quality and efficiency measures described in subparagraph (B) of such paragraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba03dfa5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability of measures considered for selection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than December 1 of each year (beginning with 2011), the Secretary shall make available to the public a list of quality and efficiency measures described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395aaa/b/7/B"},"text":"section 1395aaa(b)(7)(B) of this title","children":[],"tail":" that the Secretary is considering under this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba03dfa6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmission of multi-stakeholder input","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395aaa/b/8"},"text":"section 1395aaa(b)(8) of this title","children":[],"tail":", not later than February 1 of each year (beginning with 2012), the entity shall transmit to the Secretary the input of multi-stakeholder groups described in paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba03dfa7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of multi-stakeholder input","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall take into consideration the input from multi-stakeholder groups described in paragraph (1) in selecting quality and efficiency measures described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395aaa/b/7/B"},"text":"section 1395aaa(b)(7)(B) of this title","children":[],"tail":" that have been endorsed by the entity with a contract under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395aaa"},"text":"section 1395aaa of this title","children":[],"tail":" and measures that have not been endorsed by such entity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba03dfa8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rationale for use of quality and efficiency measures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall publish in the Federal Register the rationale for the use of any quality and efficiency measure described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395aaa/b/7/B"},"text":"section 1395aaa(b)(7)(B) of this title","children":[],"tail":" that has not been endorsed by the entity with a contract under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395aaa"},"text":"section 1395aaa of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba03dfa9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment of impact","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2012-03-01"},"text":"March 1, 2012","children":[],"tail":", and at least once every three years thereafter, the Secretary shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idba03dfaa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct an assessment of the quality and efficiency impact of the use of endorsed measures described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395aaa/b/7/B"},"text":"section 1395aaa(b)(7)(B) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idba03dfab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make such assessment available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba03dfac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process for dissemination of measures used by the Secretary","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idba03dfad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a process for disseminating quality and efficiency measures used by the Secretary. Such process shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idba03dfae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The incorporation of such measures, where applicable, in workforce programs, training curricula, and any other means of dissemination determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idba03dfaf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The dissemination of such quality and efficiency measures through the national strategy developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s280j"},"text":"section 280j of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba03dfb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing methods","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent practicable, the Secretary shall utilize and expand existing dissemination methods in disseminating quality and efficiency measures under the process established under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba03dfb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of quality and efficiency measures used by the Secretary","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idba03dfb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idba03dfb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" periodically (but in no case less often than once every 3 years) review quality and efficiency measures described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395aaa/b/7/B"},"text":"section 1395aaa(b)(7)(B) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idba03dfb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to each such measure, determine whether to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idba03dfb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain the use of such measure; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idba03dfb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" phase out such measure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba03dfb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting the review under paragraph (1), the Secretary shall take steps to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idba03dfb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek to avoid duplication of measures used; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idba03dfb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into consideration current innovative methodologies and strategies for quality and efficiency improvement practices in the delivery of health care services that represent best practices for such quality and efficiency improvement and measures endorsed by the entity with a contract under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395aaa"},"text":"section 1395aaa of this title","children":[],"tail":" since the previous review by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba03dfba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall preclude a State from using the quality and efficiency measures identified under sections 1320b–9a and 1320b–9b of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba03dfbb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of quality and efficiency measures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the Center for Medicare & Medicaid Services shall through contracts develop quality and efficiency measures (as determined appropriate by the Administrator) for use under this chapter. In developing such measures, the Administrator shall consult with the Director of the Agency for Healthcare Research and Quality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba03dfbc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hospital acquired conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, to the extent practicable, publicly report on measures for hospital-acquired conditions that are currently utilized by the Centers for Medicare & Medicaid Services for the adjustment of the amount of payment to hospitals based on rates of hospital-acquired infections.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba03dfbd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical expert panel review of opioid and opioid use disorder quality measures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idba03dfbe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2018-10-24"},"text":"October 24, 2018","children":[],"tail":", the Secretary shall establish a technical expert panel for purposes of reviewing quality measures relating to opioids and opioid use disorders, including care, prevention, diagnosis, health outcomes, and treatment furnished to individuals with opioid use disorders. The Secretary may use the entity with a contract under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395aaa/a"},"text":"section 1395aaa(a) of this title","children":[],"tail":" and amend such contract as necessary to provide for the establishment of such technical expert panel."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba03dfbf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and assessment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date the technical expert panel described in paragraph (1) is established (and periodically thereafter as the Secretary determines appropriate), the technical expert panel shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idba03dfc0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review quality measures that relate to opioids and opioid use disorders, including existing measures and those under development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idba03dfc1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify gaps in areas of quality measurement that relate to opioids and opioid use disorders, and identify measure development priorities for such measure gaps; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idba03dfc2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations to the Secretary on quality measures with respect to opioids and opioid use disorders for purposes of improving care, prevention, diagnosis, health outcomes, and treatment, including recommendations for revisions of such measures, need for development of new measures, and recommendations for including such measures in the Merit-Based Incentive Payment System under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–4/q"},"text":"section 1395w–4(q) of this title","children":[],"tail":", the alternative payment models under section 1395"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(z)(3)(C) of this title, the shared savings program under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395jjj"},"text":"section 1395jjj of this title","children":[],"tail":", the quality reporting requirements for inpatient hospitals under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395ww/b/3/B/viii"},"text":"section 1395ww(b)(3)(B)(viii) of this title","children":[],"tail":", and the hospital value-based purchasing program under section 1395ww("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":") of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba03dfc3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of measures by Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idba03dfc4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using opioid and opioid use disorder measures (including measures used under the Merit-Based Incentive Payment System under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–4/q"},"text":"section 1395w–4(q) of this title","children":[],"tail":", measures recommended under paragraph (2)(C), and other such measures identified by the Secretary) in alternative payment models under section 1395"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(z)(3)(C) of this title and in the shared savings program under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395jjj"},"text":"section 1395jjj of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idba03dfc5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using opioid measures described in subparagraph (A), as applicable, in the quality reporting requirements for inpatient hospitals under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395ww/b/3/B/viii"},"text":"section 1395ww(b)(3)(B)(viii) of this title","children":[],"tail":", and in the hospital value-based purchasing program under section 1395ww("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":") of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba03dfc6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization of measure development","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prioritize for measure development the gaps in quality measures identified under paragraph (2)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba03dfc7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization of measure endorsement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idba03dfc8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395aaa–1/g/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the period beginning on ","children":[{"tag":"date","attrib":{"date":"2018-10-24"},"text":"October 24, 2018","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2023-12-31"},"text":"December 31, 2023","children":[],"tail":", shall prioritize the endorsement of measures relating to opioids and opioid use disorders by the entity with a contract under subsection (a) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395aaa"},"text":"section 1395aaa of this title","children":[],"tail":" in connection with endorsement of measures described in subsection (b)(2) of such section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id