{"tag":"section","attrib":{"id":"idbf6d5e5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12401"},"text":null,"children":[{"tag":"num","attrib":{"value":"12401"},"text":"§ 12401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finding, purposes, and definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf6d5e5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12401/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Congress finds that it is in the national interest to accelerate efforts to develop a domestic capability to economically produce hydrogen in quantities that will make a significant contribution toward reducing the Nation’s dependence on conventional fuels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf6d5e5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12401/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf6d5e60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12401/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to direct the Secretary of Energy to conduct a research, development, and demonstration program leading to the production, storage, transport, and use of hydrogen for industrial, residential, transportation, and utility applications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6d5e61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12401/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to direct the Secretary to develop a technology assessment and information transfer program among the Federal agencies and aerospace, transportation, energy, and other entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6d5e62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12401/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop renewable energy resources as a primary source of energy for the production of hydrogen.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf6d5e63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12401/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this chapter, the term:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf6d5e64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12401/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “critical technology” (or “critical technical issue”) means a technology (or issue) that, in the opinion of the Secretary, requires understanding and development in order to take the next needed step in the development of hydrogen as an economic fuel or storage medium;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6d5e65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12401/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Department” means the Department of Energy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6d5e66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12401/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of Energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf6d5e67-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/566/s102"},"text":"Pub. L. 101–566, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2797"},"text":"104 Stat. 2797","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/271/tI/s101"},"text":"Pub. L. 104–271, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3304"},"text":"110 Stat. 3304","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf6d5e68-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf6d5e69-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf6d5e6a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/271/s101/a"},"text":"Pub. L. 104–271, § 101(a)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “to direct the Secretary to prepare a comprehensive 5-year comprehensive program management plan that will identify and resolve critical technical issues necessary for the realization of a domestic capability to produce, distribute, and use hydrogen economically within the shortest time practicable;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/271/s101/b"},"text":"Pub. L. 104–271, § 101(b)","children":[],"tail":", added par. (2) and redesignated former par. (2) as (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf6d5e6b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbf6d5e6c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/271/s1"},"text":"Pub. L. 104–271, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3304"},"text":"110 Stat. 3304","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/271/s1"},"text":"“This Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7238"},"text":"section 7238 of this title","children":[],"tail":", amending this section and sections 12402 to 12405, 12407, 12408, and 13436 of this title, and enacting provisions set out as notes under sections 7238, 12403, and 13436 of this title] may be cited as the ‘Hydrogen Future Act of 1996’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idbf6d5e6d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/566/tI/s101"},"text":"Pub. L. 101–566, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2797"},"text":"104 Stat. 2797","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/566/tI/s101"},"text":"“This Act [enacting this chapter] may be referred to as the ‘Spark M. Matsunaga Hydrogen Research, Development, and Demonstration Act of 1990’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
