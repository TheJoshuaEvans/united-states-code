{"tag":"section","attrib":{"id":"idbe815208-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8235"},"text":null,"children":[{"tag":"num","attrib":{"value":"8235"},"text":"§ 8235.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Residential building” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As used in this part, the term “residential building” means any building used as a residence which is not a new building to which final standards under sections 6833(a) and 6834 ","children":[{"tag":"ref","attrib":{"idref":"fn003818"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003818"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title apply and which has a system for heating, cooling, or both."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbe815209-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/619/tII/s261"},"text":"Pub. L. 95–619, title II, § 261","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/294/tV/s562"},"text":"Pub. L. 96–294, title V, § 562","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/746"},"text":"94 Stat. 746","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe81520a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe81520b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbe81520c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6834"},"text":"Section 6834 of this title","children":[],"tail":", referred to in text, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tX/s1041/b"},"text":"Pub. L. 97–35, title X, § 1041(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/621"},"text":"95 Stat. 621","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbe81520d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbe81520e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Statement of Purpose","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/294/tV/s561"},"text":"Pub. L. 96–294, title V, § 561","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/746"},"text":"94 Stat. 746","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/294/tV/s561"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“It is the purpose of this subtitle [subtitle C (§§ 561–563) of title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/294"},"text":"Pub. L. 96–294","children":[],"tail":", enacting this part]—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish a program under which the Secretary of Energy may provide assistance to State and local governments to encourage up to four demonstration programs that make energy conservation measures available without charge to residential property owners and tenants under a plan designed to maximize the energy savings available in residential buildings in designated areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to demonstrate through such program prototype residential energy efficiency plans under which State and local governments, State regulatory authorities, and public utilities may participate in a cooperative manner with public or private entities to install energy conservation measures in the greatest possible number of residential buildings within their respective jurisdictions or service areas.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
