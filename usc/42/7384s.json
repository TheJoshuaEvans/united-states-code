{"tag":"section","attrib":{"id":"idbe0c6f91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384s"},"text":null,"children":[{"tag":"num","attrib":{"value":"7384s"},"text":"§ 7384s.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation and benefits to be provided","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe0c6f92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384s/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation provided","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe0c6f93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384s/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), a covered employee, or the survivor of that covered employee if the employee is deceased, shall receive compensation for the disability or death of that employee from that employee’s occupational illness in the amount of $150,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe0c6f94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384s/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A covered employee shall, to the extent that employee’s occupational illness is established beryllium sensitivity, receive beryllium sensitivity monitoring under subsection (c) in lieu of compensation under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0c6f95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384s/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A covered employee shall receive medical benefits under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7384t"},"text":"section 7384t of this title","children":[],"tail":" for that employee’s occupational illness."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0c6f96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384s/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Beryllium sensitivity monitoring","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual receiving beryllium sensitivity monitoring under this subsection shall receive the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe0c6f97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384s/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A thorough medical examination to confirm the nature and extent of the individual’s established beryllium sensitivity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe0c6f98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384s/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Regular medical examinations thereafter to determine whether that individual has developed established chronic beryllium disease.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0c6f99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384s/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment from compensation fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The compensation provided under this section, when authorized or approved by the President, shall be paid from the compensation fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7384e"},"text":"section 7384e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0c6f9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384s/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments in the case of deceased persons","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe0c6f9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384s/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of a covered employee who is deceased at the time of payment of compensation under this section, whether or not the death is the result of the covered employee’s occupational illness, such payment may be made only as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe0c6f9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384s/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the covered employee is survived by a spouse who is living at the time of payment, such payment shall be made to such surviving spouse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe0c6f9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384s/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If there is no surviving spouse described in subparagraph (A), such payment shall be made in equal shares to all children of the covered employee who are living at the time of payment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe0c6f9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384s/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If there is no surviving spouse described in subparagraph (A) and if there are no children described in subparagraph (B), such payment shall be made in equal shares to the parents of the covered employee who are living at the time of payment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe0c6f9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384s/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If there is no surviving spouse described in subparagraph (A), and if there are no children described in subparagraph (B) or parents described in subparagraph (C), such payment shall be made in equal shares to all grandchildren of the covered employee who are living at the time of payment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe0c6fa0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384s/e/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If there is no surviving spouse described in subparagraph (A), and if there are no children described in subparagraph (B), parents described in subparagraph (C), or grandchildren described in subparagraph (D), then such payment shall be made in equal shares to the grandparents of the covered employee who are living at the time of payment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe0c6fa1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384s/e/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding the other provisions of this paragraph, if there is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbe0c6fa2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384s/e/1/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a surviving spouse described in subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe0c6fa3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384s/e/1/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least one child of the covered employee who is living and a minor at the time of payment and who is not a recognized natural child or adopted child of such surviving spouse,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then half of such payment shall be made to such surviving spouse, and the other half of such payment shall be made in equal shares to each child of the covered employee who is living and a minor at the time of payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe0c6fa4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384s/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a covered employee eligible for payment dies before filing a claim under this subchapter, a survivor of that employee who may receive payment under paragraph (1) may file a claim for such payment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe0c6fa5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384s/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe0c6fa6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384s/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the “spouse” of an individual is a wife or husband of that individual who was married to that individual for at least one year immediately before the death of that individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe0c6fa7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384s/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a “child” includes a recognized natural child, a stepchild who lived with an individual in a regular parent-child relationship, and an adopted child;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe0c6fa8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384s/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a “parent” includes fathers and mothers through adoption;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe0c6fa9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384s/e/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a “grandchild” of an individual is a child of a child of that individual; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe0c6faa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384s/e/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a “grandparent” of an individual is a parent of a parent of that individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0c6fab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384s/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall take effect on ","children":[{"tag":"date","attrib":{"date":"2001-07-31"},"text":"July 31, 2001","children":[],"tail":", unless Congress otherwise provides in an Act enacted before that date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe0c6fac-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dC/tXXXVI/s3628"},"text":"Pub. L. 106–398, § 1 [div. C, title XXXVI, § 3628]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–506; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dC/tXXXI/s3151/a/4/A"},"text":"Pub. L. 107–107, div. C, title XXXI, § 3151(a)(4)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1372"},"text":"115 Stat. 1372","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe0c6fad-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe0c6fae-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe0c6faf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" amended heading and text of subsec. (e) generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) Subject to the provisions of this section, if a covered employee dies before the effective date specified in subsection (f) of this section, whether or not the death is a result of that employee’s occupational illness, a survivor of that employee may, on behalf of that survivor and any other survivors of that employee, receive the compensation provided for under this section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) The right to receive compensation under this section shall be afforded to survivors in the same order of precedence as that set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8109"},"text":"section 8109 of title 5","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbe0c6fb0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbe0c6fb1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2001 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2001-07-01"},"text":"July 1, 2001","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/s3151/a/4/D"},"text":"section 3151(a)(4)(D) of Pub. L. 107–107","children":[],"tail":", set out as a note under section 7384"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
