{"tag":"section","attrib":{"id":"idbe695ccb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671d"},"text":null,"children":[{"tag":"num","attrib":{"value":"7671d"},"text":"§ 7671d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Phase-out of production and consumption of class II substances","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe695ccc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction of use of class II substances","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Effective ","children":[{"tag":"date","attrib":{"date":"2015-01-01"},"text":"January 1, 2015","children":[],"tail":", it shall be unlawful for any person to introduce into interstate commerce or use any class II substance unless such substance—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe695ccd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been used, recovered, and recycled;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe695cce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is used and entirely consumed (except for trace quantities) in the production of other chemicals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe695ccf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671d/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is used as a refrigerant in appliances manufactured prior to ","children":[{"tag":"date","attrib":{"date":"2020-01-01"},"text":"January 1, 2020","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe695cd0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671d/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is listed as acceptable for use as a fire suppression agent for nonresidential applications in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7671k/c"},"text":"section 7671k(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"As used in this subsection, the term “refrigerant” means any class II substance used for heat transfer in a refrigerating system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe695cd1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Production phase-out","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe695cd2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Effective ","children":[{"tag":"date","attrib":{"date":"2015-01-01"},"text":"January 1, 2015","children":[],"tail":", it shall be unlawful for any person to produce any class II substance in an annual quantity greater than the quantity of such substance produced by such person during the baseline year."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe695cd3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Effective ","children":[{"tag":"date","attrib":{"date":"2030-01-01"},"text":"January 1, 2030","children":[],"tail":", it shall be unlawful for any person to produce any class II substance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe695cd4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations regarding production and consumption of class II substances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"By ","children":[{"tag":"date","attrib":{"date":"1999-12-31"},"text":"December 31, 1999","children":[],"tail":", the Administrator shall promulgate regulations phasing out the production, and restricting the use, of class II substances in accordance with this section, subject to any acceleration of the phase-out of production under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7671e"},"text":"section 7671e of this title","children":[],"tail":". The Administrator shall also promulgate regulations to insure that the consumption of class II substances in the United States is phased out and terminated in accordance with the same schedule (subject to the same exceptions and other provisions) as is applicable to the phase-out and termination of production of class II substances under this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe695cd5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe695cd6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical devices","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe695cd7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671d/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the termination of production required under subsection (b)(2) and the restriction on use referred to in subsection (a), the Administrator, after notice and opportunity for public comment, shall, to the extent such action is consistent with the Montreal Protocol, authorize the production and use of limited quantities of class II substances solely for purposes of use in medical devices if such authorization is determined by the Commissioner, in consultation with the Administrator, to be necessary for use in medical devices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe695cd8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671d/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cap on exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under no circumstances may the authority set forth in subparagraph (A) be applied to authorize any person to produce a class II substance in annual quantities greater than 10 percent of that produced by such person during the baseline year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe695cd9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Developing countries","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe695cda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671d/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the provisions of subsection (a) or (b), the Administrator, after notice and opportunity for public comment, may authorize the production of limited quantities of a class II substance in excess of the quantities otherwise permitted under such provisions solely for export to and use in developing countries that are Parties to the Montreal Protocol, as determined by the Administrator. Any production authorized under this subsection shall be solely for purposes of satisfying the basic domestic needs of such countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe695cdb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671d/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cap on exception","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbe695cdc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671d/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under no circumstances may the authority set forth in subparagraph (A) be applied to authorize any person to produce a class II substance in any year following the effective date of subsection (b)(1) and before the year 2030 in annual quantities greater than 110 percent of the quantity of such substance produced by such person during the baseline year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe695cdd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671d/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under no circumstances may the authority set forth in subparagraph (A) be applied to authorize any person to produce a class II substance in the year 2030, or any year thereafter, in an annual quantity greater than 15 percent of the quantity of such substance produced by such person during the baseline year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe695cde-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671d/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each exception authorized under this paragraph shall terminate no later than ","children":[{"tag":"date","attrib":{"date":"2040-01-01"},"text":"January 1, 2040","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe695cdf-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title VI, § 605, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/549/tVI/s602/a"},"text":"Pub. L. 101–549, title VI, § 602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2658"},"text":"104 Stat. 2658","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tIII/s320"},"text":"Pub. L. 112–81, div. A, title III, § 320","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1361"},"text":"125 Stat. 1361","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe695ce0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe695ce1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe695ce2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" added par. (4)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
