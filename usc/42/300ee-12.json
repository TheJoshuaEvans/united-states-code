{"tag":"section","attrib":{"id":"idb68a96cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–12"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ee–12"},"text":"§ 300ee–12.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions with respect to carrying out purpose of grants","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A State may expend payments received under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–11/a"},"text":"section 300ee–11(a) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb68a96cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–12/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop, establish, and conduct public information activities relating to the prevention and diagnosis of acquired immune deficiency syndrome for those populations or communities in the State in which there are a significant number of individuals at risk of infection with the etiologic agent for such syndrome;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68a96cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–12/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop, establish, and conduct such public information activities for the general public relating to the prevention and diagnosis of such syndrome;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68a96ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–12/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop, establish, and conduct activities to reduce risks relating to such syndrome, including research into the prevention of such syndrome;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68a96cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–12/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct demonstration projects for the prevention of such syndrome;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68a96d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–12/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide technical assistance to public entities, to nonprofit private entities concerned with such syndrome, to schools, and to employers, for the purpose of developing information programs relating to such syndrome;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68a96d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–12/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to education and training programs for the prevention of such syndrome, to conduct such programs for health professionals (including allied health professionals), public safety workers (including emergency response employees), teachers, school administrators, and other appropriate education personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68a96d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–12/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct appropriate programs for educating school-aged children with respect to such syndrome, after consulting with local school boards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68a96d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–12/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make available to physicians and dentists in the State information with respect to acquired immune deficiency syndrome, including measures for the prevention of exposure to, and the transmission of, the etiologic agent for such syndrome (which information is updated not less than annually with the most recently available scientific date ","children":[{"tag":"ref","attrib":{"idref":"fn002417"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002417"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “data”."}],"tail":" relating to such syndrome);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68a96d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–12/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out the initial implementation of recommendations contained in the guidelines and the model curriculum developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–2"},"text":"section 300ee–2 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68a96d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–12/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make grants to public entities, and to nonprofit private entities concerned with acquired immune deficiency syndrome, for the purpose of the development, establishment, and expansion of programs for education directed toward individuals at increased risk of infection with the etiologic agent for such syndrome and activities to reduce the risks of exposure to such etiologic agent, with preference to programs directed toward populations in which there is significant evidence of such infection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb68a96d6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXV, formerly title XV, § 2502, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tII/s221"},"text":"Pub. L. 100–607, title II, § 221","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3094"},"text":"102 Stat. 3094","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tII/s2619/b"},"text":"Pub. L. 100–690, title II, § 2619(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4242"},"text":"102 Stat. 4242","children":[],"tail":"; renumbered title XXV, "},{"tag":"ref","attrib":{"href":"/us/pl/101/93/s5/e/1"},"text":"Pub. L. 101–93, § 5(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-16"},"text":"Aug. 16, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/612"},"text":"103 Stat. 612","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb68a96d7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb68a96d8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","att