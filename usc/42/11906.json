{"tag":"section","attrib":{"id":"idbf5a4c63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11906"},"text":null,"children":[{"tag":"num","attrib":{"value":"11906"},"text":"§ 11906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf5a4c64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11906/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grantee reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require grantees under this subchapter to provide periodic reports that include the obligation and expenditure of grant funds, the progress made by the grantee in implementing the plan described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11904/a"},"text":"section 11904(a) of this title","children":[],"tail":", and any change in the incidence of drug-related crime in projects assisted under this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf5a4c65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11906/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" HUD reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall submit a report to the Congress not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"1998-10-21"},"text":"October 21, 1998","children":[],"tail":", describing the system used to distribute funding to grantees under this section, which shall include descriptions of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf5a4c66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11906/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the methodology used to distribute amounts made available under this subchapter among public housing agencies, including provisions used to provide for renewals of ongoing programs funded under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5a4c67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11906/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actions taken by the Secretary to ensure that amounts made available under this subchapter are not used to fund baseline local government services, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11907/b"},"text":"section 11907(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf5a4c68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11906/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of funding awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall cause to be published in the Federal Register notice of all grant awards made pursuant to this subchapter, which shall identify the grantees and the amount of the grants. Such notice shall be published not less frequently than annually.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf5a4c69-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tV/s5127"},"text":"Pub. L. 100–690, title V, § 5127","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/tV/s586/g"},"text":"Pub. L. 105–276, title V, § 586(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2649"},"text":"112 Stat. 2649","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf5a4c6a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf5a4c6b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf5a4c6c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 11906, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tV/s5127"},"text":"Pub. L. 100–690, title V, § 5127","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4303"},"text":"102 Stat. 4303","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/tV/s581/a"},"text":"Pub. L. 101–625, title V, § 581(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4248"},"text":"104 Stat. 4248","children":[],"tail":", related to implementation of this subchapter, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/tV"},"text":"Pub. L. 105–276, title V","children":[],"tail":", §§ 503, 586(g), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2521"},"text":"112 Stat. 2521","children":[],"tail":", 2649, effective and applicable beginning upon "},{"tag":"date","attrib":{"date":"1999-10-01"},"text":"Oct. 1, 1999","children":[],"tail":", except as otherwise provided, with provision that Secretary may implement the repeal before such date, except to extent otherwise provided, and with savings provision."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf5a4c6d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf5a4c6e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective and applicable beginning upon ","children":[{"tag":"date","attrib":{"date":"1999-10-01"},"text":"Oct. 1, 1999","children":[],"tail":", except as otherwise provided, with provision that Secretary may implement section before such date, except to extent otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/s503"},"text":"section 503 of Pub. L. 105–276","children":[],"tail":", set out as an Effective Date of 1998 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437"},"text":"section 1437 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
