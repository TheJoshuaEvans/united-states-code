{"tag":"section","attrib":{"id":"idc02c1b89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17157"},"text":null,"children":[{"tag":"num","attrib":{"value":"17157"},"text":"§ 17157.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and evaluation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc02c1b8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17157/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may review and evaluate the performance of any eligible entity that receives a grant under the program, including by conducting an audit, as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02c1b8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17157/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may withhold from an eligible entity any portion of a grant to be provided to the eligible entity under the program if the Secretary determines that the eligible entity has failed to achieve compliance with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc02c1b8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17157/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any applicable guideline or regulation of the Secretary relating to the program, including the misuse or misappropriation of funds provided under the program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1b8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17157/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the energy efficiency and conservation strategy of the eligible entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc02c1b8e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tV/s547"},"text":"Pub. L. 110–140, title V, § 547","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1674"},"text":"121 Stat. 1674","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc02c1b8f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc02c1b90-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc02c1b91-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
