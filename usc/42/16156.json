{"tag":"section","attrib":{"id":"idbff52cf9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16156"},"text":null,"children":[{"tag":"num","attrib":{"value":"16156"},"text":"§ 16156.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical Advisory Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbff52cfa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16156/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Hydrogen Technical and Fuel Cell Advisory Committee is established to advise the Secretary on the programs and activities under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff52cfb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16156/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff52cfc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16156/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Technical Advisory Committee shall be comprised of not fewer than 12 nor more than 25 members. The members shall be appointed by the Secretary to represent domestic industry, academia, professional societies, government agencies, Federal laboratories, previous advisory panels, and financial, environmental, and other appropriate organizations based on the Department’s assessment of the technical and other qualifications of Technical Advisory Committee members and the needs of the Technical Advisory Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52cfd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16156/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term of a member of the Technical Advisory Committee shall not be more than 3 years. The Secretary may appoint members of the Technical Advisory Committee in a manner that allows the terms of the members serving at any time to expire at spaced intervals so as to ensure continuity in the functioning of the Technical Advisory Committee. A member of the Technical Advisory Committee whose term is expiring may be reappointed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52cfe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16156/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Technical Advisory Committee shall have a chairperson, who shall be elected by the members from among their number.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff52cff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16156/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Technical Advisory Committee shall review and make recommendations to the Secretary on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff52d00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16156/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implementation of programs and activities under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16156/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the safety, economical, and environmental consequences of technologies for the production, distribution, delivery, storage, or use of hydrogen energy and fuel cells; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16156/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16153"},"text":"section 16153 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff52d03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16156/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Response","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff52d04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16156/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of recommendations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall consider, but need not adopt, any recommendations of the Technical Advisory Committee under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16156/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biennial report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall transmit a biennial report to Congress describing any recommendations made by the Technical Advisory Committee since the previous report. The report shall include a description of how the Secretary has implemented or plans to implement the recommendations, or an explanation of the reasons that a recommendation will not be implemented. The report shall be transmitted along with the President’s budget proposal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff52d06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16156/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide resources necessary in the judgment of the Secretary for the Technical Advisory Committee to carry out its responsibilities under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff52d07-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVIII/s807"},"text":"Pub. L. 109–58, title VIII, § 807","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/849"},"text":"119 Stat. 849","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
