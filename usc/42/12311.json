{"tag":"section","attrib":{"id":"idbf687cac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12311"},"text":null,"children":[{"tag":"num","attrib":{"value":"12311"},"text":"§ 12311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Administration on Children, Youth, and Families","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf687cad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12311/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Department of Health and Human Services an Administration on Children, Youth, and Families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf687cae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12311/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commissioner","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf687caf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12311/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf687cb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12311/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administration on Children, Youth, and Families, as established under subsection (a), shall be headed by a Commissioner on Children, Youth, and Families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf687cb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12311/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf687cb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12311/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President, by and with the advice and consent of the Senate, shall appoint the Commissioner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf687cb3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/501/tIX/s915"},"text":"Pub. L. 101–501, title IX, § 915","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-03"},"text":"Nov. 3, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1263"},"text":"104 Stat. 1263","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf687cb4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf687cb5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf687cb6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","a