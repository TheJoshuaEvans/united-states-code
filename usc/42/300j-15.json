{"tag":"section","attrib":{"id":"idb647e945-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–15"},"text":null,"children":[{"tag":"num","attrib":{"value":"300j–15"},"text":"§ 300j–15.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water conservation plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb647e946-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–15/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"1996-08-06"},"text":"August 6, 1996","children":[],"tail":", the Administrator shall publish in the Federal Register guidelines for water conservation plans for public water systems serving fewer than 3,300 persons, public water systems serving between 3,300 and 10,000 persons, and public water systems serving more than 10,000 persons, taking into consideration such factors as water availability and climate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb647e947-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–15/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loans or grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 1 year after publication of the guidelines under subsection (a), a State exercising primary enforcement responsibility for public water systems may require a public water system, as a condition of receiving a loan or grant from a State loan fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300j–12"},"text":"section 300j–12 of this title","children":[],"tail":", to submit with its application for such loan or grant a water conservation plan consistent with such guidelines."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb647e948-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIV, § 1455, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/182/tI/s134"},"text":"Pub. L. 104–182, title I, § 134","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-06"},"text":"Aug. 6, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1679"},"text":"110 Stat. 1679","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
