{"tag":"section","attrib":{"id":"idbd0f996a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5141"},"text":null,"children":[{"tag":"num","attrib":{"value":"5141"},"text":"§ 5141.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of administrative conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any Federal agency charged with the administration of a Federal assistance program may, if so requested by the applicant State or local authorities, modify or waive, for a major disaster, such administrative conditions for assistance as would otherwise prevent the giving of assistance under such programs if the inability to meet such conditions is a result of the major disaster.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd0f996b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tIII/s301"},"text":"Pub. L. 93–288, title III, § 301","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/707/tI/s105/a/2"},"text":"Pub. L. 100–707, title I, § 105(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4691"},"text":"102 Stat. 4691","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd0f996c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd0f996d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbd0f996e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5141, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tIII/s301"},"text":"Pub. L. 93–288, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/146"},"text":"88 Stat. 146","children":[],"tail":", set out procedure for determination of existence of emergency or major disaster, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/100/707/s105/a/2"},"text":"Pub. L. 100–707, § 105(a)(2)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
