{"tag":"section","attrib":{"id":"idbf3b2c46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11261"},"text":null,"children":[{"tag":"num","attrib":{"value":"11261"},"text":"§ 11261.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf3b2c47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11261/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Agency for Healthcare Research and Quality shall conduct, or make grants for the conduct of, research relevant to appropriate services for individuals with Alzheimer’s disease and related dementias and for their families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf3b2c48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11261/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research subjects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Agency for Healthcare Research and Quality shall ensure that research conducted under subsection (a) shall include research—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf3b2c49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11261/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" concerning improving the organization, delivery, and financing of services for individuals with Alzheimer’s disease and related dementias and for their families, including research on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf3b2c4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11261/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the design, staffing, and operation of special care units for the individuals in institutional settings, as well as individuals in institutional settings,","children":[{"tag":"ref","attrib":{"idref":"fn003991"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003991"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The words “as well as individuals in institutional settings,” probably should not appear."}],"tail":" as well as individuals in home care, day care, and respite care; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf3b2c4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11261/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the exploration and enhancement of services such as home care, day care, and respite care, that provide alternatives to institutional care;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf3b2c4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11261/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" concerning the costs incurred by individuals with Alzheimer’s disease and related dementias and by their families in obtaining services, particularly services that are essential to the individuals and that are not generally required by other patients under long-term care programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf3d9c4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11261/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" concerning the costs, cost-effectiveness, and effectiveness of various interventions to provide services for individuals with Alzheimer’s disease and related dementias and for their families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf3d9c4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11261/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducted in consultation with the Director of the National Institute on Aging and the Commissioner of the Administration on Aging, concerning the role of physicians in caring for persons with Alzheimer’s disease and related dementias and for their families, including the role of a physician in connecting such persons with appropriate health care and supportive services, including those supported through State and area agencies on aging designated under section 3025(a)(1) and (2)(A) of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf3d9c4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11261/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducted in consultation with the Director of the National Institute on Aging and the Commissioner of the Administration on Aging, concerning legal and ethical issues, including issues associated with special care units, facing individuals with Alzheimer’s disease and related dementias and facing their families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf3d9c50-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/660/tIX/s934"},"text":"Pub. L. 99–660, title IX, § 934","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/507/s7/b/1/B"},"text":"Pub. L. 102–507, § 7(b)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3285"},"text":"106 Stat. 3285","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/129/s2/b/2"},"text":"Pub. L. 106–129, § 2(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-06"},"text":"Dec. 6, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1670"},"text":"113 Stat. 1670","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf3d9c51-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf3d9c52-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf3d9c53-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 11261, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/660/tIX/s934"},"text":"Pub. L. 99–660, title IX, § 934","children":[],"tail":", formerly § 947, "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3811"},"text":"100 Stat. 3811","children":[],"tail":"; renumbered § 934, "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tI/s142/c/2/B"},"text":"Pub. L. 100–607, title I, § 142(c)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3057"},"text":"102 Stat. 3057","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/54/s13/q/14/B"},"text":"Pub. L. 102–54, § 13(q)(14)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-06-13"},"text":"June 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/282"},"text":"105 Stat. 282","children":[],"tail":", related to research relevant to appropriate services for individuals with Alzheimer’s disease and related dementias, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/507/s7/b/1/B"},"text":"Pub. L. 102–507, § 7(b)(1)(B)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf3d9c54-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/129"},"text":"Pub. L. 106–129","children":[],"tail":" substituted “Director of the Agency for Healthcare Research and Quality” for “Administrator of the Agency for Health Care Policy and Research”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
