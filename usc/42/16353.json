{"tag":"section","attrib":{"id":"idc00d221f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16353"},"text":null,"children":[{"tag":"num","attrib":{"value":"16353"},"text":"§ 16353.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Merit review of proposals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc00d2220-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16353/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Awards of funds authorized under this Act or an amendment made by this Act shall be made only after an impartial review of the scientific and technical merit of the proposals for the awards has been carried out by or for the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00f6b11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16353/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Competitive awards under this Act shall involve competitions open to all qualified entities within one or more of the following categories:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00f6b12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16353/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Institutions of higher education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6b13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16353/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" National Laboratories.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6b14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16353/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nonprofit and for-profit private entities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6b15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16353/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and local governments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6b16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16353/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Consortia of entities described in paragraphs (1) through (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00f6b17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16353/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of Congress that research, development, demonstration, and commercial application activities carried out by the Department should be awarded using competitive procedures, to the maximum extent practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc00f6b18-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s989"},"text":"Pub. L. 109–58, title IX, § 989","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/911"},"text":"119 Stat. 911","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc00f6b19-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc00f6b1a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc00f6b1b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsecs. (a) and (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/594"},"text":"119 Stat. 594","children":[],"tail":", known as the Energy Policy Act of 2005, which enacted this chapter and enacted, amended, and repealed numerous other sections and notes in the Code. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s15801"},"text":"section 15801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
