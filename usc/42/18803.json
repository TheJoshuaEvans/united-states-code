{"tag":"section","attrib":{"id":"idc06c7f8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18803"},"text":null,"children":[{"tag":"num","attrib":{"value":"18803"},"text":"§ 18803.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial building energy consumption information sharing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc06c7f8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18803/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06c7f8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18803/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Administrator of the Energy Information Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c7f90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18803/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Agreement” means the agreement entered into under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c7f91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18803/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survey","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Survey” means the Commercial Building Energy Consumption Survey.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06c7f92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18803/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of Agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Administrator and the Administrator of the Environmental Protection Agency shall sign, and submit to Congress, an information sharing agreement relating to commercial building energy consumption data."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06c7f93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18803/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content of Agreement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Agreement shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06c7f94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18803/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide, to the extent permitted by law, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06c7f95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18803/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator shall have access to building-specific data in the Portfolio Manager database of the Environmental Protection Agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c7f96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18803/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Environmental Protection Agency shall have access to building-specific data collected by the Survey;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c7f97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18803/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the manner in which the Administrator shall use the data described in paragraph (1) and subsection (d);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c7f98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18803/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" describe and compare—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06c7f99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18803/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the methodologies that the Energy Information Administration, the Environmental Protection Agency, and State and local government managers use to maximize the quality, reliability, and integrity of data collected through the Survey, the Portfolio Manager database of the Environmental Protection Agency, and State and local building energy disclosure laws (including regulations), respectively, and the manner in which those methodologies can be improved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c7f9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18803/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consistencies and variations in data for the same buildings captured in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06c7f9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18803/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc06c7f9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18803/c/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 2018 Survey cycle; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06c7f9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18803/c/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each subsequent Survey cycle; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06c7f9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18803/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Portfolio Manager database of the Environmental Protection Agency; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c7f9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18803/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consider whether, and the methods by which, the Administrator may collect and publish new iterations of Survey data every 3 years—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06c7fa0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18803/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using the Survey processes of the Administrator; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c7fa1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18803/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as supplemented by information in the Portfolio Manager database of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06c7fa2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18803/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The data referred in subsection (c)(2) includes data that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06c7fa3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18803/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is collected through the Portfolio Manager database of the Environmental Protection Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c7fa4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18803/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is required to be publicly available on the internet under State and local government building energy disclosure laws (including regulations); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c7fa5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18803/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes information on private sector buildings that are not less than 250,000 square feet.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06c7fa6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18803/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the agreement, the Administrator and the Administrator of the Environmental Protection Agency shall protect information in accordance with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06c7fa7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18803/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b/4"},"text":"section 552(b)(4) of title 5","children":[],"tail":" (commonly known as the “Freedom of Information Act”);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c7fa8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18803/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subchapter III of chapter 35 of title 44; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c7fa9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18803/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other applicable law (including regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc06c7faa-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tV/s40514"},"text":"Pub. L. 117–58, div. D, title V, § 40514","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1061"},"text":"135 Stat. 1061","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc06c7fab-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc06c7fac-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc06c7fad-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
