{"tag":"section","attrib":{"id":"idc035923e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17354"},"text":null,"children":[{"tag":"num","attrib":{"value":"17354"},"text":"§ 17354.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc035923f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17354/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2008-03-31"},"text":"March 31, 2008","children":[],"tail":", and each March 31 thereafter, the Foundation shall submit to the appropriate congressional committees a report on the implementation of this part during the prior fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0359240-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17354/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report required by subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0359241-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17354/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total financial resources available to the Foundation during the year, including appropriated funds, the value and source of any gifts or donations accepted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17355/a/6"},"text":"section 17355(a)(6) of this title","children":[],"tail":", and any other resources;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0359242-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17354/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the Board’s policy priorities for the year and the basis upon which competitive grant proposals were solicited and awarded to nongovernmental institutions and other organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0359243-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17354/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of grants made to nongovernmental institutions and other organizations that includes the identity of the institutional recipient, the dollar amount, and the results of the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0359244-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17354/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the total administrative and operating expenses of the Foundation for the year, as well as specific information on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0359245-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17354/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of Foundation employees and the cost of compensation for Board members, Foundation employees, and personal service contractors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0359246-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17354/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" costs associated with securing the use of real property for carrying out the functions of the Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0359247-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17354/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" total travel expenses incurred by Board members and Foundation employees in connection with Foundation activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0359248-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17354/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" total representational expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0359249-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIX/s924"},"text":"Pub. L. 110–140, title IX, § 924","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1736"},"text":"121 Stat. 1736","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc035924a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc035924b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc035924c-3a70-11f1-ae07-e4213316b5