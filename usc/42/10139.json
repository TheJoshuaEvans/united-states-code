{"tag":"section","attrib":{"id":"idbf12bb75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10139"},"text":null,"children":[{"tag":"num","attrib":{"value":"10139"},"text":"§ 10139.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review of agency actions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf12bb76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10139/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction of United States courts of appeals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf12bb77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10139/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except for review in the Supreme Court of the United States, the United States courts of appeals shall have original and exclusive jurisdiction over any civil action—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf12bb78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10139/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for review of any final decision or action of the Secretary, the President, or the Commission under this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf12bb79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10139/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alleging the failure of the Secretary, the President, or the Commission to make any decision, or take any action, required under this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf12bb7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10139/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" challenging the constitutionality of any decision made, or action taken, under any provision of this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf12bb7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10139/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for review of any environmental impact statement prepared pursuant to the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.) with respect to any action under this part, or as required under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10155/c/1"},"text":"section 10155(c)(1) of this title","children":[],"tail":", or alleging a failure to prepare such statement with respect to any such action;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf12bb7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10139/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for review of any environmental assessment prepared under section 10132(b)(1) or 10155(c)(2) of this title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf12bb7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10139/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for review of any research and development activity under subchapter II.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf12bb7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10139/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The venue of any proceeding under this section shall be in the judicial circuit in which the petitioner involved resides or has its principal office, or in the United States Court of Appeals for the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf12bb7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10139/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn003936"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003936"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No subsec. (b) has been enacted."}],"tail":" Deadline for commencing action"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A civil action for judicial review described under subsection (a)(1) may be brought not later than the 180th day after the date of the decision or action or failure to act involved, as the case may be, except that if a party shows that he did not know of the decision or action complained of (or of the failure to act), and that a reasonable person acting under the circumstances would not have known, such party may bring a civil action not later than the 180th day after the date such party acquired actual or constructive knowledge of such decision, action, or failure to act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf12bb80-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/425/tI/s119"},"text":"Pub. L. 97–425, title I, § 119","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-07"},"text":"Jan. 7, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2227"},"text":"96 Stat. 2227","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf12bb81-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf12bb82-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf12bb83-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsec. (a)(1)(D), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
