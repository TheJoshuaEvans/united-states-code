{"tag":"section","attrib":{"id":"idbdeb047b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991e"},"text":null,"children":[{"tag":"num","attrib":{"value":"6991e"},"text":"§ 6991e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdeb047c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance orders","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdeb047d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), whenever on the basis of any information, the Administrator determines that any person is in violation of any requirement of this subchapter, the Administrator may issue an order requiring compliance within a reasonable specified time period or the Administrator may commence a civil action in the United States district court in which the violation occurred for appropriate relief, including a temporary or permanent injunction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdeb047e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a violation of any requirement of this subchapter where such violation occurs in a State with a program approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6991c"},"text":"section 6991c of this title","children":[],"tail":", the Administrator shall give notice to the State in which such violation has occurred prior to issuing an order or commencing a civil action under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdeb047f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a violator fails to comply with an order under this subsection within the time specified in the order, he shall be liable for a civil penalty of not more than $25,000 for each day of continued noncompliance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdeb0480-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any order issued under this section shall become final unless, no later than thirty days after the order is served, the person or persons named therein request a public hearing. Upon such request the Administrator shall promptly conduct a public hearing. In connection with any proceeding under this section the Administrator may issue subpoenas for the attendance and testimony of witnesses and the production of relevant papers, books, and documents, and may promulgate rules for discovery procedures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdeb0481-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any order issued under this section shall state with reasonable specificity the nature of the violation, specify a reasonable time for compliance, and assess a penalty, if any, which the Administrator determines is reasonable taking into account the seriousness of the violation and any good faith efforts to comply with the applicable requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdeb0482-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdeb0483-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991e/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any owner who knowingly fails to notify or submits false information pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6991a/a"},"text":"section 6991a(a) of this title","children":[],"tail":" shall be subject to a civil penalty not to exceed $10,000 for each tank for which notification is not given or false information is submitted."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdeb0484-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991e/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any owner or operator of an underground storage tank who fails to comply with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdeb0485-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991e/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any requirement or standard promulgated by the Administrator under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6991b"},"text":"section 6991b of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdeb0486-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991e/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any requirement or standard of a State program approved pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6991c"},"text":"section 6991c of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdeb0487-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991e/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6991b/g"},"text":"section 6991b(g) of this title","children":[],"tail":" (entitled “Interim Prohibition”); or "},{"tag":"ref","attrib":{"idref":"fn003547"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003547"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “or” probably should not appear."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdeb0488-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991e/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn003548"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003548"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Two subpars. (D) have been enacted."}],"tail":" the requirements established in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6991b/i"},"text":"section 6991b(i) of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"idref":"fn003549"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003549"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. The comma probably should be a semicolon."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdeb0489-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991e/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" the training requirements established by States pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6991i"},"text":"section 6991i of this title","children":[],"tail":" (relating to operator training); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdeb048a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991e/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the delivery prohibition requirement established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6991k"},"text":"section 6991k of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be subject to a civil penalty not to exceed $10,000 for each tank for each day of violation. Any person making or accepting a delivery or deposit of a regulated substance to an underground storage tank at an ineligible facility in violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6991k"},"text":"section 6991k of this title","children":[],"tail":" shall also be subject to the same civil penalty for each day of such violation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdeb048b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incentive for performance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Both of the following may be taken into account in determining the terms of a civil penalty under subsection (d):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdeb048c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991e/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The compliance history of an owner or operator in accordance with this subchapter or a program approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6991c"},"text":"section 6991c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdeb048d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991e/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other factor the Administrator considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdeb048e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/272/tII/s9006"},"text":"Pub. L. 89–272, title II, § 9006","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/616/tVI/s601/a"},"text":"Pub. L. 98–616, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3285"},"text":"98 Stat. 3285","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXV"},"text":"Pub. L. 109–58, title XV","children":[],"tail":", §§ 1524(c), 1526(d), 1527(b), 1530(d), "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1096"},"text":"119 Stat. 1096","children":[],"tail":", 1098, 1099, 1104.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdeb048f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdeb0490-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbdeb0491-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s1527/b/2"},"text":"Pub. L. 109–58, § 1527(b)(2)","children":[],"tail":", inserted at end “Any person making or accepting a delivery or deposit of a regulated substance to an underground storage tank at an ineligible facility in violation of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6991k"},"text":"section 6991k of this title","children":[],"tail":" shall also be subject to the same civil penalty for each day of such violation.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s1530/d/1"},"text":"Pub. L. 109–58, § 1530(d)(1)","children":[],"tail":", which directed amendment of subpar. (B) by striking out “or” at end, could not be executed because “or” did not appear subsequent to amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/s1524/c/1"},"text":"Pub. L. 109–58, § 1524(c)(1)","children":[],"tail":". See below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s1524/c/1"},"text":"Pub. L. 109–58, § 1524(c)(1)","children":[],"tail":", struck out “or” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s1530/d/2"},"text":"Pub. L. 109–58, § 1530(d)(2)","children":[],"tail":", inserted “; or” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s1530/d/3"},"text":"Pub. L. 109–58, § 1530(d)(3)","children":[],"tail":", added subpar. (D) relating to requirements established in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6991b/i"},"text":"section 6991b(i) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s1524/c/2"},"text":"Pub. L. 109–58, § 1524(c)(2)","children":[],"tail":", added subpar. (D) relating to training requirements established by States pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6991i"},"text":"section 6991i of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s1527/b/1"},"text":"Pub. L. 109–58, § 1527(b)(1)","children":[],"tail":", added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s1526/d"},"text":"Pub. L. 109–58, § 1526(d)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbdeb0492-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbdeb0493-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s1530/d"},"text":"section 1530(d) of Pub. L. 109–58","children":[],"tail":" effective 18 months after "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/s1530/b"},"text":"section 1530(b) of Pub. L. 109–58","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6991b"},"text":"section 6991b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
