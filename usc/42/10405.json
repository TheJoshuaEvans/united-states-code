{"tag":"section","attrib":{"id":"idbf2818d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10405"},"text":null,"children":[{"tag":"num","attrib":{"value":"10405"},"text":"§ 10405.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotment of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf2818d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10405/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the sums appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10403"},"text":"section 10403 of this title","children":[],"tail":" and available for grants to States under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10406/a"},"text":"section 10406(a) of this title","children":[],"tail":" for any fiscal year—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf2818d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10405/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Guam, American Samoa, the United States Virgin Islands, and the Commonwealth of the Northern Mariana Islands shall each be allotted not less than ⅛ of 1 percent of the amounts available for grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10406/a"},"text":"section 10406(a) of this title","children":[],"tail":" for the fiscal year for which the allotment is made; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2818d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10405/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each State shall be allotted for a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10406/a"},"text":"section 10406(a) of this title","children":[],"tail":", $600,000, with the remaining funds to be allotted to each State in an amount that bears the same ratio to such remaining funds as the population of such State bears to the population of all States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2818d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10405/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Population","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of this section, the population of each State, and the total population of all the States, shall be determined by the Secretary on the basis of the most recent census data available to the Secretary, and the Secretary shall use for such purpose, if available, the annual interim current census data produced by the Secretary of Commerce pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t13/s181"},"text":"section 181 of title 13","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2818d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10405/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ratable reduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the sums appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10403"},"text":"section 10403 of this title","children":[],"tail":" for any fiscal year and available for grants to States under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10406/a"},"text":"section 10406(a) of this title","children":[],"tail":" are not sufficient to pay in full the total amounts that all States are entitled to receive under subsection (a) for such fiscal year, then the maximum amounts that all States are entitled to receive under subsection (a) for such fiscal year shall be ratably reduced. In the event that additional funds become available for making such grants for any fiscal year during which the preceding sentence is applicable, such reduced amounts shall be increased on the same basis as they were reduced."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2818d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10405/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallotment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, at the end of the sixth month of any fiscal year for which sums are appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10403"},"text":"section 10403 of this title","children":[],"tail":", the amount allotted to a State has not been made available to such State in a grant under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10406/a"},"text":"section 10406(a) of this title","children":[],"tail":" because of the failure of such State to meet the requirements for such a grant, then the Secretary shall reallot such amount to States that meet such requirements."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2818d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10405/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continued availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All funds allotted to a State for a fiscal year under this section, and made available to such State in a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10406/a"},"text":"section 10406(a) of this title","children":[],"tail":", shall remain available for obligation by the State until the end of the following fiscal year. All such funds that are not obligated by the State by the end of the following fiscal year shall be made available to the Secretary for discretionary activities under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10414"},"text":"section 10414 of this title","children":[],"tail":". Such funds shall remain available for obligation, and for expenditure by a recipient of the funds under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10414"},"text":"section 10414 of this title","children":[],"tail":", for not more than 1 year from the date on which the funds are made available to the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2818d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10405/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In subsection (a)(2), the term “State” does not include any jurisdiction specified in subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf2818d9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/457/tIII/s305"},"text":"Pub. L. 98–457, title III, § 305","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/320/tII/s201"},"text":"Pub. L. 111–320, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-20"},"text":"Dec. 20, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3488"},"text":"124 Stat. 3488","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf2818da-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf2818db-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf2818dc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 10405, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/457/tIII/s306"},"text":"Pub. L. 98–457, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-09"},"text":"Oct. 9, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1760"},"text":"98 Stat. 1760","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/295/tIII/s314"},"text":"Pub. L. 102–295, title III, § 314","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-05-28"},"text":"May 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/204"},"text":"106 Stat. 204","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/36/tIV/s403"},"text":"Pub. L. 108–36, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-06-25"},"text":"June 25, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/825"},"text":"117 Stat. 825","children":[],"tail":", related to evaluation of the effectiveness of the programs administered and operated pursuant to this chapter, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/111/320"},"text":"Pub. L. 111–320","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10404/c"},"text":"section 10404(c) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/457/s305"},"text":"section 305 of Pub. L. 98–457","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10404"},"text":"section 10404 of this title","children":[],"tail":" prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/111/320"},"text":"Pub. L. 111–320","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
