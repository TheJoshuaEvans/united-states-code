{"tag":"section","attrib":{"id":"idbcdffdbf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4767"},"text":null,"children":[{"tag":"num","attrib":{"value":"4767"},"text":"§ 4767.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of grants","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Whenever the Office, after giving reasonable notice and opportunity for hearing to the State or general local government concerned, finds—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcdffdc0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4767/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that a program or project has been so changed that it no longer complies with the provisions of this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcdffdc1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4767/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that in the operation of the program or project there is a failure to comply substantially with any such provision;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Office shall notify the State or general local government of its findings and no further payments may be made to such government by the Office until it is satisfied that such noncompliance has been, or will promptly be, corrected. However, the Office may authorize the continuance of payments to those projects approved under this chapter which are not involved in the noncompliance.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcdffdc2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/648/tV/s507"},"text":"Pub. L. 91–648, title V, § 507","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-05"},"text":"Jan. 5, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1928"},"text":"84 Stat. 1928","children":[],"tail":"; 1978 Reorg. Plan No. 2, § 102, eff. "},{"tag":"date","attrib":{"date":"1979-01-01"},"text":"Jan. 1, 1979","children":[],"tail":", 43 F.R. 36037, "},{"tag":"ref","attrib":{"href":"/us/stat/92/3783"},"text":"92 Stat. 3783","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcdffdc3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcdffdc4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbcdffdc5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, means the provisions of subchapters I, II, III, and IV of this chapter. See ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4761"},"text":"section 4761 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbcdffdc6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbcdffdc7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Office”, meaning Office of Personnel Management, substituted in text for “Commission”, meaning Civil Service Commission, pursuant to Reorg. Plan No. 2 of 1978, § 102, 43 F.R. 36037, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/92/3783"},"text":"92 Stat. 3783","children":[],"tail":", set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1101"},"text":"section 1101 of Title 5","children":[],"tail":", Government Organization and Employees, which transferred functions vested by statute in Civil Service Commission and Chairman thereof to Director of Office of Personnel Management (except as otherwise specified), effective "},{"tag":"date","attrib":{"date":"1979-01-01"},"text":"Jan. 1, 1979","children":[],"tail":", as provided by section 1–102 of Ex. Ord. No. 12107, "},{"tag":"date","attrib":{"date":"1978-12-28"},"text":"Dec. 28, 1978","children":[],"tail":", 44 F.R. 1055, set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1101"},"text":"section 1101 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
