{"tag":"section","attrib":{"id":"idbe05438e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7372"},"text":null,"children":[{"tag":"num","attrib":{"value":"7372"},"text":"§ 7372.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Secretary” and “renewable energy resource” defined","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe05438f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7372/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Secretary” means the Secretary of Energy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe054390-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7372/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “renewable energy resource” means any energy resource which has recently originated in the sun, including direct and indirect solar radiation and intermediate solar energy forms such as wind, ocean thermal gradients, ocean currents and waves, hydropower, photovoltaic energy, products of photosynthetic processes, organic wastes, and others.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe054391-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/294/tIV/s403"},"text":"Pub. L. 96–294, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/716"},"text":"94 Stat. 716","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe054392-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe054393-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbe054394-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in text, was in the original “this title”, meaning title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/294"},"text":"Pub. L. 96–294","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/715"},"text":"94 Stat. 715","children":[],"tail":", known as the Renewable Energy Resources Act of 1980, which enacted this subchapter, amended sections 8255, 8271, and 8274 to 8276 of this title and sections 2705 and 2708 of Title 16, Conservation, and enacted a provision set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s2701"},"text":"section 2701 of Title 16","children":[],"tail":". For complete classification of title IV to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7371"},"text":"section 7371 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
