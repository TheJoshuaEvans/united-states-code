{"tag":"section","attrib":{"id":"idbfdd5f60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15065"},"text":null,"children":[{"tag":"num","attrib":{"value":"15065"},"text":"§ 15065.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In this part, the term “State” means each of the several States of the United States, the District of Columbia, the Commonwealth of Puerto Rico, the United States Virgin Islands, and Guam.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbfdd5f61-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/402/tI/s155"},"text":"Pub. L. 106–402, title I, § 155","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1725"},"text":"114 Stat. 1725","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
