{"tag":"section","attrib":{"id":"idbd716878-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6234"},"text":null,"children":[{"tag":"num","attrib":{"value":"6234"},"text":"§ 6234.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategic Petroleum Reserve","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd716879-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6234/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Strategic Petroleum Reserve for the storage of up to 1 billion barrels of petroleum products shall be created pursuant to this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd71687a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6234/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in accordance with this part, shall exercise authority over the development, operation, and maintenance of the Reserve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd71687b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6234/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" to (e) Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/469/tI/s103/7/C"},"text":"Pub. L. 106–469, title I, § 103(7)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2030"},"text":"114 Stat. 2030","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd71687c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6234/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of drawdown and distribution; requests for funds for storage","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd71687d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6234/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The drawdown and distribution of petroleum products from the Strategic Petroleum Reserve is authorized only under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6241"},"text":"section 6241 of this title","children":[],"tail":", and drawdown and distribution of petroleum products for purposes other than those described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6241"},"text":"section 6241 of this title","children":[],"tail":" shall be prohibited."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd71687e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6234/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the Secretary’s annual budget submission, the Secretary shall request funds for acquisition, transportation, and injection of petroleum products for storage in the Reserve. If no requests for funds are made, the Secretary shall provide a written explanation of the reason therefore.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd71687f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tI/s154"},"text":"Pub. L. 94–163, title I, § 154","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-22"},"text":"Dec. 22, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/882"},"text":"89 Stat. 882","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/619/tVI/s691/b/2"},"text":"Pub. L. 95–619, title VI, § 691(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3288"},"text":"92 Stat. 3288","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXIV/s1402"},"text":"Pub. L. 102–486, title XIV, § 1402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2994"},"text":"106 Stat. 2994","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/177/s1/6"},"text":"Pub. L. 105–177, § 1(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-01"},"text":"June 1, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/106"},"text":"112 Stat. 106","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/469/tI/s103/7"},"text":"Pub. L. 106–469, title I, § 103(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2030"},"text":"114 Stat. 2030","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd716880-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd716881-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd716882-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/469/s103/7/A"},"text":"Pub. L. 106–469, § 103(7)(A)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, subsec. (a) provided for the creation of a Strategic Petroleum Reserve of up to 1 billion barrels of petroleum products and required that the Reserve contain not less than 150 million barrels of petroleum products by the end of the 3-year period beginning on "},{"tag":"date","attrib":{"date":"1975-12-22"},"text":"Dec. 22, 1975","children":[],"tail":", and that the President take actions to enlarge the Reserve to 1,000,000,000 barrels as rapidly as possible beginning "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/469/s103/7/B"},"text":"Pub. L. 106–469, § 103(7)(B)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “The Secretary, not later than "},{"tag":"date","attrib":{"date":"1976-12-15"},"text":"December 15, 1976","children":[],"tail":", shall prepare and transmit to the Congress, in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6421"},"text":"section 6421 of this title","children":[],"tail":", a Strategic Petroleum Reserve Plan. Such Plan shall comply with the provisions of this section and shall detail the Secretary’s proposals for designing, constructing, and filling the storage and related facilities of the Reserve.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/469/s103/7/C"},"text":"Pub. L. 106–469, § 103(7)(C)","children":[],"tail":", struck out subsecs. (c) to (e) which related to the levels of crude oil to be stored, plan objectives, and plan provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/177"},"text":"Pub. L. 105–177","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486"},"text":"Pub. L. 102–486","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsecs. (b), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/619"},"text":"Pub. L. 95–619","children":[],"tail":" substituted “Secretary” and “Secretary’s” for “Administrator” and “Administrator’s”, respectively, meaning Administrator of the Federal Energy Administration, wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd716883-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd716884-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Strategic Petroleum Reserve Drawdown Plan","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/229/s4/c"},"text":"Pub. L. 97–229, § 4(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-08-03"},"text":"Aug. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/252"},"text":"96 Stat. 252","children":[],"tail":", required the President to transmit to Congress, on or before "},{"tag":"date","attrib":{"date":"1982-12-01"},"text":"Dec. 1, 1982","children":[],"tail":", and as an amendment to the Strategic Petroleum Reserve Plan, a drawdown plan for the Strategic Petroleum Reserve consistent with the requirements of this section, to take effect on the date of transmittal and not be subject to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6239/e"},"text":"section 6239(e) of this title","children":[],"tail":" relating to Congressional review."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
