{"tag":"section","attrib":{"id":"idc0227e7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17071"},"text":null,"children":[{"tag":"num","attrib":{"value":"17071"},"text":"§ 17071.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy Code improvements applicable to manufactured housing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0227e7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17071/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of standards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0227e7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17071/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 4 years after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", the Secretary shall by regulation establish standards for energy efficiency in manufactured housing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227e80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17071/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice, comment, and consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Standards described in paragraph (1) shall be established after—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0227e81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17071/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notice and an opportunity for comment by manufacturers of manufactured housing and other interested parties; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227e82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17071/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consultation with the Secretary of Housing and Urban Development, who may seek further counsel from the Manufactured Housing Consensus Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0227e83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17071/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0227e84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17071/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International Energy Conservation Code","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The energy conservation standards established under this section shall be based on the most recent version of the International Energy Conservation Code (including supplements), except in cases in which the Secretary finds that the code ","children":[{"tag":"ref","attrib":{"idref":"fn004243"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004243"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Code”."}],"tail":" is not cost-effective, or a more stringent standard would be more cost-effective, based on the impact of the code "},{"tag":"ref","attrib":{"idref":"fn004243"},"text":"1","children":[],"tail":" on the purchase price of manufactured housing and on total life-cycle construction and operating costs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227e85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17071/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The energy conservation standards established under this section may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0227e86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17071/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into consideration the design and factory construction techniques of manufactured homes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227e87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17071/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be based on the climate zones established by the Department of Housing and Urban Development rather than the climate zones under the International Energy Conservation Code; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227e88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17071/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for alternative practices that result in net estimated energy consumption equal to or less than the specified standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227e89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17071/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updating","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The energy conservation standards established under this section shall be updated not later than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0227e8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17071/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 year after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227e8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17071/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 year after any revision to the International Energy Conservation Code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0227e8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17071/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any manufacturer of manufactured housing that violates a provision of the regulations under subsection (a) is liable to the United States for a civil penalty in an amount not exceeding 1 percent of the manufacturer’s retail list price of the manufactured housing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0227e8d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIV/s413"},"text":"Pub. L. 110–140, title IV, § 413","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1601"},"text":"121 Stat. 1601","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0227e8e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc0227e8f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc0227e90-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
