{"tag":"section","attrib":{"id":"idc0334764-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17281"},"text":null,"children":[{"tag":"num","attrib":{"value":"17281"},"text":"§ 17281.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National media campaign","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0334765-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17281/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Assistant Secretary for Energy Efficiency and Renewable Energy (referred to in this section as the “Secretary”), shall develop and conduct a national media campaign—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0334766-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17281/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase energy efficiency throughout the economy of the United States during the 10-year period beginning on ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0334767-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17281/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote the national security benefits associated with increased energy efficiency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0334768-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17281/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to decrease oil consumption in the United States during the 10-year period beginning on ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0334769-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17281/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract with entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out subsection (a) directly or through—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc033476a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17281/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" competitively bid contracts with 1 or more nationally recognized media firms for the development and distribution of monthly television, radio, and newspaper public service announcements; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc033476b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17281/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collective agreements with 1 or more nationally recognized institutes, businesses, or nonprofit organizations for the funding, development, and distribution of monthly television, radio, and newspaper public service announcements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc033476c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17281/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc033476d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17281/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts made available to carry out this section shall be used for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc033476e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17281/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" advertising costs, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc033476f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17281/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase of media time and space;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0334770-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17281/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creative and talent costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0334771-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17281/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" testing and evaluation of advertising; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0334772-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17281/c/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluation of the effectiveness of the media campaign; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0334773-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17281/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administrative costs, including operational and management expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0334774-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17281/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Secretary shall allocate not less than 85 percent of funds made available under subsection (e) for each fiscal year for the advertising functions specified under paragraph (1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0334775-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17281/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall annually submit to Congress a report that describes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0334776-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17281/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the strategy of the national media campaign and whether specific objectives of the campaign were accomplished, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0334777-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17281/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determinations concerning the rate of change of energy consumption, in both absolute and per capita terms; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0334778-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17281/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation that enables consideration of whether the media campaign contributed to reduction of energy consumption;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0334779-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17281/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" steps taken to ensure that the national media campaign operates in an effective and efficient manner consistent with the overall strategy and focus of the campaign;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc033477a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17281/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plans to purchase advertising time and space;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc033477b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17281/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" policies and practices implemented to ensure that Federal funds are used responsibly to purchase advertising time and space and eliminate the potential for waste, fraud, and abuse; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc033477c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17281/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all contracts or cooperative agreements entered into with a corporation, partnership, or individual working on behalf of the national media campaign.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc033477d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17281/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc033477e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17281/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $5,000,000 for each of fiscal years 2008 through 2012.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc033477f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17281/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decreased oil consumption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall use not less than 50 percent of the amount that is made available under this section for each fiscal year to develop and conduct a national media campaign to decrease oil consumption in the United States over the next decade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0334780-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tVIII/s801"},"text":"Pub. L. 110–140, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1716"},"text":"121 Stat. 1716","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0334781-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc0334782-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc0334783-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
