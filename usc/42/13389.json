{"tag":"section","attrib":{"id":"idbfc0d652-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389"},"text":null,"children":[{"tag":"num","attrib":{"value":"13389"},"text":"§ 13389.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Greenhouse gas intensity reducing strategies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfc0d653-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc0d654-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Advisory Committee” means the Climate Change Technology Advisory Committee established under subsection (f)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d655-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carbon sequestration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “carbon sequestration” means the capture of carbon dioxide through terrestrial, geological, biological, or other means, which prevents the release of carbon dioxide into the atmosphere.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d656-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Committee” means the Committee on Climate Change Technology established under subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d657-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Developing country","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “developing country” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13387/m"},"text":"section 13387(m) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d658-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Greenhouse gas","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “greenhouse gas” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfc0d659-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carbon dioxide;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d65a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methane;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d65b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nitrous oxide;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d65c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/a/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hydrofluorocarbons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d65d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/a/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perfluorocarbons; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d65e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/a/5/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sulfur hexafluoride.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d65f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Greenhouse gas intensity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “greenhouse gas intensity” means the ratio of greenhouse gas emissions to economic output.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d660-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Laboratory","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “National Laboratory” has the meaning given the term in section 15801(3) ","children":[{"tag":"ref","attrib":{"idref":"fn004168"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004168"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc0d661-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Committee on Climate Change Technology","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc0d662-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the President shall establish a Committee on Climate Change Technology to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfc0d663-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrate current Federal climate reports; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d664-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate Federal climate change technology activities and programs carried out in furtherance of the strategy developed under subsection (c)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d665-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall be composed of at least 7 members, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfc0d666-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary, who shall chair the Committee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d667-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d668-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chairman of the Council on Environmental Quality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d669-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d66a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Environmental Protection Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d66b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d66c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Office of Science and Technology Policy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d66d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other representatives as may be determined by the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d66e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Committee shall provide such personnel as are necessary to enable the Committee to perform its duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc0d66f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National climate change technology policy","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc0d670-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Committee shall, based on applicable Federal climate reports, submit to the Secretary and the President a national strategy to promote the deployment and commercialization of greenhouse gas intensity reducing technologies and practices developed through research and development programs conducted by the National Laboratories, other Federal research facilities, institutions of higher education, and the private sector."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d671-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfc0d672-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the time of submission of the strategy to the President under paragraph (1), also make the strategy available to the public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d673-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" update the strategy every 5 years, or more frequently as the Committee determines to be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc0d674-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Climate Change Technology Program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the date on which the Committee is established under subsection (b)(1), the Secretary, in consultation with the Committee, shall establish within the Department of Energy the Climate Change Technology Program to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc0d675-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist the Committee in the interagency coordination of climate change technology research, development, demonstration, and deployment to reduce greenhouse gas intensity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d676-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out the programs authorized under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc0d677-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technology inventory","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc0d678-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct and make public an inventory and evaluation of greenhouse gas intensity reducing technologies that have been developed, or are under development, by the National Laboratories, other Federal research facilities, institutions of higher education, and the private sector to determine which technologies are suitable for commercialization and deployment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d679-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after the completion of the inventory under paragraph (1), the Secretary shall submit to Congress a report that includes the results of the completed inventory and any recommendations of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d67a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall use the results of the inventory as guidance in the commercialization and deployment of greenhouse gas intensity reducing technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d67b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updated inventory","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfc0d67c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" periodically update the inventory under paragraph (1), including when determined necessary by the Committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d67d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make the updated inventory available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc0d67e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Climate Change Technology Advisory Committee","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc0d67f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Committee, may establish under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7234"},"text":"section 7234 of this title","children":[],"tail":" a Climate Change Technology Advisory Committee to identify statutory, regulatory, economic, and other barriers to the commercialization and deployment of greenhouse gas intensity reducing technologies and practices in the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d680-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Committee shall be composed of the following members, to be appointed by the Secretary, in consultation with the Committee:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfc0d681-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 representative shall be appointed from each National Laboratory.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d682-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 members shall be representatives of energy-producing trade organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d683-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 members shall represent energy-intensive trade organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d684-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 members shall represent groups that represent end-use energy and other consumers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d685-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/f/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 members shall be employees of the Federal Government who are experts in energy technology, intellectual property, and tax.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d686-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/f/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 members shall be representatives of institutions of higher education with expertise in energy technology development that are recommended by the National Academy of Engineering.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d687-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", and annually thereafter, the Advisory Committee shall submit to the Committee a report that describes—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfc0d688-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the findings of the Advisory Committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d689-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations of the Advisory Committee for the removal or reduction of barriers to commercialization, deployment, and increasing the use of greenhouse gas intensity reducing technologies and practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc0d68a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Greenhouse gas intensity reducing technology deployment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc0d68b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Based on the strategy developed under subsection (c)(1), the technology inventory conducted under subsection (e)(1), the greenhouse gas intensity reducing technology study report submitted under subsection (e)(2), and reports under subsection (f)(3), if any, the Committee shall develop recommendations that would provide for the removal of domestic barriers to the commercialization and deployment of greenhouse gas intensity reducing technologies and practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d68c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the recommendations under paragraph (1), the Committee shall consider in the aggregate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfc0d68d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost-effectiveness of the technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d68e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fiscal and regulatory barriers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d68f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" statutory and other barriers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d690-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/g/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intellectual property issues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d691-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing recommendations under paragraph (1), the Committee may identify the need for climate change technology demonstration projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d692-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Committee shall submit to the President and Congress a report that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfc0d693-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/g/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies, based on the report submitted under subsection (f)(3), any barriers to, and commercial risks associated with, the deployment of greenhouse gas intensity reducing technologies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d694-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/g/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a plan for carrying out demonstration projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d695-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfc0d696-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/g/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the time of submission of the report to Congress under paragraph (4), also make the report available to the public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d697-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/g/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" update the report every 5 years, or more frequently as the Committee determines to be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc0d698-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures for calculating, monitoring, and analyzing greenhouse gas intensity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in collaboration with the Committee and the National Institute of Standards and Technology, and after public notice and opportunity for comment, shall develop standards and best practices for calculating, monitoring, and analyzing greenhouse gas intensity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc0d699-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc0d69a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, subject to the availability of appropriations, support demonstration projects that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfc0d69b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/i/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the reduction of the greenhouse gas intensity to levels below that which would be achieved by technologies being used in the United States as of ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d69c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/i/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maximize the potential return on Federal investment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d69d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/i/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate distinct roles in public-private partnerships;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d69e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/i/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produce a large-scale reduction of greenhouse gas intensity if commercialization occurred; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d69f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/i/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support a diversified portfolio to mitigate the uncertainty associated with a single technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d6a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In supporting a demonstration project under this subsection, the Secretary shall require cost-sharing in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16352"},"text":"section 16352 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d6a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc0d6a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13389/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative research and development agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out greenhouse gas intensity reduction research and technology deployment activities under this subtitle,","children":[{"tag":"ref","attrib":{"idref":"fn004169"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004169"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. See References in Text note below."}],"tail":" the Secretary may enter into cooperative research and development agreements under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3710a"},"text":"section 3710a of title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfc0d6a3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXVI/s1610"},"text":"Pub. L. 102–486, title XVI, § 1610","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXVI/s1601"},"text":"Pub. L. 109–58, title XVI, § 1601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1109"},"text":"119 Stat. 1109","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfc0d6a4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfc0d6a5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfc0d6a6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15801/3"},"text":"Section 15801(3) of this title","children":[],"tail":", referred to in subsec. (a)(7), was in the original “section 3(3) of the Energy Policy Act of 2005” and was translated as meaning section 2(3) of that Act to reflect the probable intent of Congress, because the Energy Policy Act of 2005 does not contain a section 3 and section 2(3) defines “National Laboratory”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This subtitle, referred to in subsec. (j), appearing in the original, is unidentifiable because title XVI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486"},"text":"Pub. L. 102–486","children":[],"tail":", of which this section is a part, does not contain subtitles."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
