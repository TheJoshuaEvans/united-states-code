{"tag":"section","attrib":{"id":"idb602c9a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24"},"text":null,"children":[{"tag":"num","attrib":{"value":"299b–24"},"text":"§ 299b–24.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Patient safety organization certification and listing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb602c9a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb602c9a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial certification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity that seeks to be a patient safety organization shall submit an initial certification to the Secretary that the entity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb602c9a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has policies and procedures in place to perform each of the patient safety activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s299b–21/5"},"text":"section 299b–21(5) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb602c9a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon being listed under subsection (d), will comply with the criteria described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb602c9a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent certifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity that is a patient safety organization shall submit every 3 years after the date of its initial listing under subsection (d) a subsequent certification to the Secretary that the entity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb602c9a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is performing each of the patient safety activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s299b–21/5"},"text":"section 299b–21(5) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb602c9aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is complying with the criteria described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb602c9ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb602c9ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following are criteria for the initial and subsequent certification of an entity as a patient safety organization:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb602c9ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The mission and primary activity of the entity are to conduct activities that are to improve patient safety and the quality of health care delivery.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb602c9ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The entity has appropriately qualified staff (whether directly or through contract), including licensed or certified medical professionals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb602c9af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The entity, within each 24-month period that begins after the date of the initial listing under subsection (d), has bona fide contracts, each of a reasonable period of time, with more than 1 provider for the purpose of receiving and reviewing patient safety work product.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb602c9b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The entity is not, and is not a component of, a health insurance issuer (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–91/b/2"},"text":"section 300gg–91(b)(2) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb602c9b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The entity shall fully disclose—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb602c9b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/b/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any financial, reporting, or contractual relationship between the entity and any provider that contracts with the entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb602c9b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/b/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if applicable, the fact that the entity is not managed, controlled, and operated independently from any provider that contracts with the entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb602c9b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the extent practical and appropriate, the entity collects patient safety work product from providers in a standardized manner that permits valid comparisons of similar cases among similar providers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb602c9b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The utilization of patient safety work product for the purpose of providing direct feedback and assistance to providers to effectively minimize patient risk.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb602c9b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional criteria for component organizations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If an entity that seeks to be a patient safety organization is a component of another organization, the following are additional criteria for the initial and subsequent certification of the entity as a patient safety organization:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb602c9b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The entity maintains patient safety work product separately from the rest of the organization, and establishes appropriate security measures to maintain the confidentiality of the patient safety work product.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb602c9b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The entity does not make an unauthorized disclosure under this part of patient safety work product to the rest of the organization in breach of confidentiality.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb602c9b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The mission of the entity does not create a conflict of interest with the rest of the organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb602c9ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of certification","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb602c9bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb602c9bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the submission by an entity of an initial certification under subsection (a)(1), the Secretary shall determine if the certification meets the requirements of subparagraphs (A) and (B) of such subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb602c9bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the submission by an entity of a subsequent certification under subsection (a)(2), the Secretary shall review the certification with respect to requirements of subparagraphs (A) and (B) of such subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb602c9be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of acceptance or non-acceptance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb602c9bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity’s initial certification meets requirements referred to in paragraph (1)(A), the Secretary shall notify the entity of the acceptance of such certification; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb602c9c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity’s initial certification does not meet such requirements, the Secretary shall notify the entity that such certification is not accepted and the reasons therefor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb602c9c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosures regarding relationship to providers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall consider any disclosures under subsection (b)(1)(E) by an entity and shall make public findings on whether the entity can fairly and accurately perform the patient safety activities of a patient safety organization. The Secretary shall take those findings into consideration in determining whether to accept the entity’s initial certification and any subsequent certification submitted under subsection (a) and, based on those findings, may deny, condition, or revoke acceptance of the entity’s certification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb602c9c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Listing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall compile and maintain a listing of entities with respect to which there is an acceptance of a certification pursuant to subsection (c)(2)(A) that has not been revoked under subsection (e) or voluntarily relinquished.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb602c9c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revocation of acceptance of certification","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb602c9c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, after notice of deficiency, an opportunity for a hearing, and a reasonable opportunity for correction, the Secretary determines that a patient safety organization does not meet the certification requirements under subsection (a)(2), including subparagraphs (A) and (B) of such subsection, the Secretary shall revoke the Secretary’s acceptance of the certification of such organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb602c9c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplying confirmation of notification to providers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 15 days of a revocation under paragraph (1), a patient safety organization shall submit to the Secretary a confirmation that the organization has taken all reasonable actions to notify each provider whose patient safety work product is collected or analyzed by the organization of such revocation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb602c9c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of decision","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary revokes the certification of an organization under paragraph (1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb602c9c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remove the organization from the listing maintained under subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb602c9c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish notice of the revocation in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb602c9c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status of data after removal from listing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb602c9ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to the privilege and confidentiality protections described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s299b–22"},"text":"section 299b–22 of this title","children":[],"tail":", data submitted to an entity within 30 days after the entity is removed from the listing under subsection (e)(3)(A) shall have the same status as data submitted while the entity was still listed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb602c9cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection to continue to apply","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the privilege and confidentiality protections described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s299b–22"},"text":"section 299b–22 of this title","children":[],"tail":" applied to patient safety work product while an entity was listed, or to data described in paragraph (1), such protections shall continue to apply to such work product or data after the entity is removed from the listing under subsection (e)(3)(A)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb602c9cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of work product and data","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary removes a patient safety organization from the listing as provided for in subsection (e)(3)(A), with respect to the patient safety work product or data described in subsection (f)(1) that the patient safety organization received from another entity, such former patient safety organization shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb602c9cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the approval of the other entity and a patient safety organization, transfer such work product or data to such patient safety organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb602c9ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" return such work product or data to the entity that submitted the work product or data; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb602c9cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if returning such work product or data to such entity is not practicable, destroy such work product or data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb602c9d0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IX, § 924, as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/41/s2/a/5"},"text":"Pub. L. 109–41, § 2(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-07-29"},"text":"July 29, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/431"},"text":"119 Stat. 431","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb602c9d1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb602c9d2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb602c9d3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 924 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was renumbered section 944 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s299c–3"},"text":"section 299c–3 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 924 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s299c–3"},"text":"section 299c–3 of this title","children":[],"tail":" prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/106/129"},"text":"Pub. L. 106–129","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
