{"tag":"section","attrib":{"id":"idbd0ade1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5132"},"text":null,"children":[{"tag":"num","attrib":{"value":"5132"},"text":"§ 5132.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disaster warnings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd0ade1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5132/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Readiness of Federal agencies to issue warnings to State and local officials","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall insure that all appropriate Federal agencies are prepared to issue warnings of disasters to State and local officials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0ade1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5132/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance to State and local governments for effective warnings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall direct appropriate Federal agencies to provide technical assistance to State and local governments to insure that timely and effective disaster warning is provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0ade20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5132/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Warnings to governmental authorities and public endangered by disaster","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President is authorized to utilize or to make available to Federal, State, and local agencies the facilities of the civil defense communications system established and maintained pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5196/c"},"text":"section 5196(c) of this title","children":[],"tail":" or any other Federal communications system for the purpose of providing warning to governmental authorities and the civilian population in areas endangered by disasters."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0ade21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5132/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements with commercial communications systems for use of facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President is authorized to enter into agreements with the officers or agents of any private or commercial communications systems who volunteer the use of their systems on a reimbursable or nonreimbursable basis for the purpose of providing warning to governmental authorities and the civilian population endangered by disasters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd0ade22-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tII/s202"},"text":"Pub. L. 93–288, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/145"},"text":"88 Stat. 145","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dC/tXXXIV/s3412/b/1"},"text":"Pub. L. 103–337, div. C, title XXXIV, § 3412(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3111"},"text":"108 Stat. 3111","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd0ade23-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd0ade24-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd0ade25-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5196/c"},"text":"section 5196(c) of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2281/c"},"text":"section 2281(c) of title 50","children":[],"tail":", Appendix,”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
