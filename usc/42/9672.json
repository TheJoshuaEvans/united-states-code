{"tag":"section","attrib":{"id":"idbed983a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9672"},"text":null,"children":[{"tag":"num","attrib":{"value":"9672"},"text":"§ 9672.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State laws; scope of subchapter","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbed983a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9672/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to affect either the tort law or the law governing the interpretation of insurance contracts of any State. The definitions of pollution liability and pollution liability insurance under any State law shall not be applied for the purposes of this subchapter, including recognition or qualification of risk retention groups or purchasing groups.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbed983a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9672/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of subchapter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority to offer or to provide insurance under this subchapter shall be limited to coverage of pollution liability risks and this subchapter does not authorize a risk retention group or purchasing group to provide coverage of any other line of insurance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbed983a7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/510/tIV/s402"},"text":"Pub. L. 96–510, title IV, § 402","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/499/tII/s210/a"},"text":"Pub. L. 99–499, title II, § 210(a)","children":[],"tail":", formerly § 210, "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1716"},"text":"100 Stat. 1716","children":[],"tail":"; renumbered § 210(a), "},{"tag":"ref","attrib":{"href":"/us/pl/99/563/s11/c/1"},"text":"Pub. L. 99–563, § 11(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3177"},"text":"100 Stat. 3177","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
