{"tag":"section","attrib":{"id":"idb4852a89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239"},"text":null,"children":[{"tag":"num","attrib":{"value":"239"},"text":"§ 239.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4852a8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4852a8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered countermeasure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered countermeasure” means a covered countermeasure as specified in a Declaration made pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s233/p"},"text":"section 233(p) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4852a8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered individual","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered individual” means an individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4852a8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is a health care worker, law enforcement officer, firefighter, security personnel, emergency medical personnel, other public safety personnel, or support personnel for such occupational specialities ","children":[{"tag":"ref","attrib":{"idref":"fn002020"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002020"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “specialties”."}],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4852a8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is or will be functioning in a role identified in a State, local, or Department of Health and Human Services smallpox emergency response plan (as defined in paragraph (7)) approved by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4852a8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has volunteered and been selected to be a member of a smallpox emergency response plan described in subparagraph (B) prior to the time at which the Secretary publicly announces that an active case of smallpox has been identified either within or outside of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4852a90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to whom a smallpox vaccine is administered pursuant to such approved plan during the effective period of the Declaration (including the portion of such period before ","children":[{"tag":"date","attrib":{"date":"2003-04-30"},"text":"April 30, 2003","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4852a91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered injury","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered injury” means an injury, disability, illness, condition, or death (other than a minor injury such as minor scarring or minor local reaction) determined, pursuant to the procedures established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s239a"},"text":"section 239a of this title","children":[],"tail":", to have been sustained by an individual as the direct result of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4852a92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administration to the individual of a covered countermeasure during the effective period of the Declaration; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4852a93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" accidental vaccinia inoculation of the individual in circumstances in which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4852a94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vaccinia is contracted during the effective period of the Declaration or within 30 days after the end of such period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4852a95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" smallpox vaccine has not been administered to the individual; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4852a96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual has been in contact with an individual who is (or who was accidentally inoculated by) a covered individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4852a97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Declaration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Declaration” means the Declaration Regarding Administration of Smallpox Countermeasures issued by the Secretary on ","children":[{"tag":"date","attrib":{"date":"2003-01-24"},"text":"January 24, 2003","children":[],"tail":", and published in the Federal Register on "},{"tag":"date","attrib":{"date":"2003-01-28"},"text":"January 28, 2003","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4879a98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective period of the Declaration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “effective period of the Declaration” means the effective period specified in the Declaration, unless extended by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4879a99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible individual","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible individual” means an individual who is (as determined in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s239a"},"text":"section 239a of this title","children":[],"tail":")—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4879a9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a covered individual who sustains a covered injury in the manner described in paragraph (3)(A); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4879a9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual who sustains a covered injury in the manner described in paragraph (3)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4879a9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Smallpox emergency response plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “smallpox emergency response plan” or “plan” means a response plan detailing actions to be taken in preparation for a possible smallpox-related emergency during the period prior to the identification of an active case of smallpox either within or outside the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4879a9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that a State, local, or Department of Health and Human Services plan to vaccinate individuals that is approved by the Secretary establishes procedures to ensure, consistent with the Declaration and any applicable guidelines of the Centers for Disease Control and Prevention, that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4879a9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" potential participants are educated with respect to contraindications, the voluntary nature of the program, and the availability of potential benefits and compensation under this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4879a9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is voluntary screening provided to potential participants that can identify health conditions relevant to contraindications; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4879aa0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is appropriate post-inoculation medical surveillance that includes an evaluation of adverse health effects that may reasonably appear to be due to such vaccine and prompt referral of, or the provision of appropriate information to, any individual requiring health care as a result of such adverse health event.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4879aa1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title II, § 261, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/20/s2"},"text":"Pub. L. 108–20, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-04-30"},"text":"Apr. 30, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/638"},"text":"117 Stat. 638","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
