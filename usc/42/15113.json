{"tag":"section","attrib":{"id":"idbfdfd024-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15113"},"text":null,"children":[{"tag":"num","attrib":{"value":"15113"},"text":"§ 15113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reaching up scholarship program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfdfd025-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15113/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award grants to eligible entities, on a competitive basis, to enable the entities to carry out scholarship programs by providing vouchers for postsecondary education to direct support workers who assist individuals with developmental disabilities residing in diverse settings. The Secretary shall award the grants to pay for the Federal share of the cost of providing the vouchers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdfd026-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15113/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under this section, an entity shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfdfd027-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15113/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfd028-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15113/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfd029-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15113/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a consortium of such institutions or agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdfd02a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15113/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under this section, an eligible entity shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require, including a description of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfdfd02b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15113/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the basis for awarding the vouchers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfd02c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15113/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of individuals to receive the vouchers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfd02d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15113/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of funds that will be made available by the eligible entity to pay for the non-Federal share of the cost of providing the vouchers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdfd02e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15113/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding a grant under this section for a scholarship program, the Secretary shall give priority to an entity submitting an application that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfdfd02f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15113/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" specifies that individuals who receive vouchers through the program will be individuals—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfdfd030-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15113/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who are direct support workers who assist individuals with developmental disabilities residing in diverse settings, while pursuing postsecondary education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdfd031-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15113/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each of whom verifies, prior to receiving the voucher, that the worker has completed 250 hours as a direct support worker in the past 90 days;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfd032-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15113/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" states that the vouchers that will be provided through the program will be in amounts of not more than $2,000 per year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfd033-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15113/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides an assurance that the eligible entity (or another specified entity that is not a voucher recipient) will contribute the non-Federal share of the cost of providing the vouchers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfd034-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15113/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets such other conditions as the Secretary may specify.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdfd035-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15113/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of providing the vouchers shall be not more than 80 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfdfd036-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/402/tIII/s303"},"text":"Pub. L. 106–402, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1735"},"text":"114 Stat. 1735","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
