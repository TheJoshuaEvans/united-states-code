{"tag":"section","attrib":{"id":"idbf046470-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9875"},"text":null,"children":[{"tag":"num","attrib":{"value":"9875"},"text":"§ 9875.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application and description of activities; requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf046471-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9875/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf046472-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9875/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to receive an allotment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9872"},"text":"section 9872 of this title","children":[],"tail":", each State shall submit an application to the Secretary. Each such application shall be in such form and submitted by such date as the Secretary shall require."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf046473-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9875/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each application required under paragraph (1) for an allotment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9872"},"text":"section 9872 of this title","children":[],"tail":" shall contain assurances that the State will meet the requirements of subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf046474-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9875/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As part of the annual application required by subsection (a), the chief executive officer of each State shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf046475-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9875/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certify that the State agrees to use the funds allotted to it under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9872"},"text":"section 9872 of this title","children":[],"tail":" in accordance with the requirements of this subchapter; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf046476-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9875/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certify that the State agrees that Federal funds made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9873"},"text":"section 9873 of this title","children":[],"tail":" for any period will be so used as to supplement and increase the level of State, local, and other non-Federal funds that would in the absence of such Federal funds be made available for the programs and activities for which funds are provided under that section and will in no event supplant such State, local, and other non-Federal funds."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The Secretary may not prescribe for a State the manner of compliance with the requirements of this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf046477-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9875/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Description; intended use of payments; comments; revision","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf046478-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9875/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The chief executive officer of a State shall, as part of the application required by subsection (a), also prepare and furnish the Secretary (in accordance with such form as the Secretary shall provide) with a description of the intended use of the payments the State will receive under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9873"},"text":"section 9873 of this title","children":[],"tail":", including information on the programs and activities to be supported. The description shall be made public within the State in such manner as to facilitate comment from any person (including any Federal or other public agency) during development of the description and after its transmittal. The description shall be revised (consistent with this section) until "},{"tag":"date","attrib":{"date":"1991-09-30"},"text":"September 30, 1991","children":[],"tail":", as may be necessary to reflect substantial changes in the programs and activities assisted by the State under this subchapter, and any revision shall be subject to the requirements of the preceding sentence."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf046479-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9875/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The chief executive officer of each State shall include in such a description of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf04647a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9875/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of children who participated in before and after school child care programs assisted under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf04647b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9875/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the characteristics of the children so served including age levels, handicapped condition, income level of families in such programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf04647c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9875/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the salary level and benefits paid to employees in such child care programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf04647d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9875/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of clients served in resource and referral systems assisted under this subchapter, and the types of assistance they requested.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf04647e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9875/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to Public Health Service Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except where inconsistent with the provisions of this subchapter, the provisions of section 1903(b) [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300w–2/b"},"text":"42 U.S.C. 300w–2(b)","children":[],"tail":"], paragraphs (1) through (5) of section 1906(a) "},{"tag":"ref","attrib":{"idref":"fn003916"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003916"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300w–5/a"},"text":"42 U.S.C. 300w–5(a)","children":[],"tail":"], and sections 1906(b), 1907, 1908, and 1909 ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300w–5/b"},"text":"42 U.S.C. 300w–5(b)","children":[],"tail":", 300w–6, 300w–7, 300w–8] of the Public Health Service Act shall apply to this subchapter in the same manner as such provisions apply to part A of title XIX of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300w"},"text":"42 U.S.C. 300w","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf04647f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s670E"},"text":"Pub. L. 97–35, title VI, § 670E","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/558/tI/s109"},"text":"Pub. L. 98–558, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2882"},"text":"98 Stat. 2882","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/501/tIII"},"text":"Pub. L. 101–501, title III","children":[],"tail":", §§ 304, 305(b), "},{"tag":"date","attrib":{"date":"1990-11-03"},"text":"Nov. 3, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1249"},"text":"104 Stat. 1249","children":[],"tail":", 1250.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf046480-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf046481-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf046482-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Public Health Service Act, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"act July 1, 1944, ch. 373","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/682"},"text":"58 Stat. 682","children":[],"tail":". Part A of title XIX of the Public Health Service Act is classified generally to part A (§ 300w et seq.) of subchapter XVII of chapter 6A of this title. Section 1906(a) of the Act, which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300w–5/a"},"text":"section 300w–5(a) of this title","children":[],"tail":", was amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/102/531/tI/s104/a"},"text":"Pub. L. 102–531, title I, § 104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3473"},"text":"106 Stat. 3473","children":[],"tail":", and, as so amended, consists of pars. (1) to (4) rather than pars. (1) to (5). For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf046483-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/501/s305/b"},"text":"Pub. L. 101–501, § 305(b)","children":[],"tail":", which directed that “until "},{"tag":"date","attrib":{"date":"1987-09-30"},"text":"September 30, 1987","children":[],"tail":",” be struck out, could not be executed, because of the intervening amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/101/501/s304"},"text":"Pub. L. 101–501, § 304","children":[],"tail":", see below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/501/s304"},"text":"Pub. L. 101–501, § 304","children":[],"tail":", designated existing provisions as par. (1), substituted “"},{"tag":"date","attrib":{"date":"1991-09-30"},"text":"September 30, 1991","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1987-09-30"},"text":"September 30, 1987","children":[],"tail":"”, and added par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf046484-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf046485-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/501"},"text":"Pub. L. 101–501","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1990-10-01"},"text":"Oct. 1, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/501/s1001/a"},"text":"section 1001(a) of Pub. L. 101–501","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8621"},"text":"section 8621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
