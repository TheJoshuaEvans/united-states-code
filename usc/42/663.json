{"tag":"section","attrib":{"id":"idb7c07f06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s663"},"text":null,"children":[{"tag":"num","attrib":{"value":"663"},"text":"§ 663.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of Federal Parent Locator Service in connection with enforcement or determination of child custody in cases of parental kidnaping of child","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7c07f07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s663/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements with States for use of Federal Parent Locator Service","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall enter into an agreement with every State under which the services of the Federal Parent Locator Service established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s653"},"text":"section 653 of this title","children":[],"tail":" shall be made available to each State for the purpose of determining the whereabouts of any parent or child when such information is to be used to locate such parent or child for the purpose of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7c07f08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s663/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enforcing any State or Federal law with respect to the unlawful taking or restraint of a child; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7c07f09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s663/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making or enforcing a child custody or visitation determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7c07f0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s663/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requests from authorized persons for information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An agreement entered into under subsection (a) shall provide that the State agency described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s654"},"text":"section 654 of this title","children":[],"tail":" will, under procedures prescribed by the Secretary in regulations, receive and transmit to the Secretary requests from authorized persons for information as to (or useful in determining) the whereabouts of any parent or child when such information is to be used to locate such parent or child for the purpose of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7c07f0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s663/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enforcing any State or Federal law with respect to the unlawful taking or restraint of a child; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7c07f0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s663/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making or enforcing a child custody or visitation determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7c07f0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s663/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information which may be disclosed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Information authorized to be provided by the Secretary under subsection (a), (b), (e), or (f) shall be subject to the same conditions with respect to disclosure as information authorized to be provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s653"},"text":"section 653 of this title","children":[],"tail":", and a request for information by the Secretary under this section shall be considered to be a request for information under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s653"},"text":"section 653 of this title","children":[],"tail":" which is authorized to be provided under such section. Only information as to the most recent address and place of employment of any parent or child shall be provided under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7c07f0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s663/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Custody or visitation determination” and “authorized person” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7c07f0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s663/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “custody or visitation determination” means a judgment, decree, or other order of a court providing for the custody or visitation of a child, and includes permanent and temporary orders, and initial orders and modification;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7c07f10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s663/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “authorized person” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7c07f11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s663/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any agent or attorney of any State having an agreement under this section, who has the duty or authority under the law of such State to enforce a child custody or visitation determination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7c07f12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s663/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any court having jurisdiction to make or enforce such a child custody or visitation determination, or any agent of such court; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7c07f13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s663/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any agent or attorney of the United States, or of a State having an agreement under this section, who has the duty or authority to investigate, enforce, or bring a prosecution with respect to the unlawful taking or restraint of a child.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7c07f14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s663/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement on use of Federal Parent Locator Service with United States Central Authority under Convention on the Civil Aspects of International Child Abduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall enter into an agreement with the Central Authority designated by the President in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9006"},"text":"section 9006 of title 22","children":[],"tail":", under which the services of the Federal Parent Locator Service established under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s653"},"text":"section 653 of this title","children":[],"tail":" shall be made available to such Central Authority upon its request for the purpose of locating any parent or child on behalf of an applicant to such Central Authority within the meaning of "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s9002/1"},"text":"section 9002(1) of title 22","children":[],"tail":". The Federal Parent Locator Service shall charge no fees for services requested pursuant to this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7c07f15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s663/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement to assist in locating missing children under Federal Parent Locator Service","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall enter into an agreement with the Attorney General of the United States, under which the services of the Federal Parent Locator Service established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s653"},"text":"section 653 of this title","children":[],"tail":" shall be made available to the Office of Juvenile Justice and Delinquency Prevention upon its request to locate any parent or child on behalf of such Office for the purpose of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7c07f16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s663/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enforcing any State or Federal law with respect to the unlawful taking or restraint of a child, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7c07f17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s663/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making or enforcing a child custody or visitation determination.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The Federal Parent Locator Service shall charge no fees for services requested pursuant to this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7c07f18-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title IV, § 463, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/611/s9/b"},"text":"Pub. L. 96–611, § 9(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-28"},"text":"Dec. 28, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3572"},"text":"94 Stat. 3572","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/300/s11"},"text":"Pub. L. 100–300, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-29"},"text":"Apr. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/441"},"text":"102 Stat. 441","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/432/tII/s214/a"},"text":"Pub. L. 103–432, title II, § 214(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4461"},"text":"108 Stat. 4461","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/tIII"},"text":"Pub. L. 104–193, title III","children":[],"tail":", §§ 316(e)(1), 395(d)(1)(G), "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2215"},"text":"110 Stat. 2215","children":[],"tail":", 2259; "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tV/s5534/b"},"text":"Pub. L. 105–33, title V, § 5534(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/629"},"text":"111 Stat. 629","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7c07f19-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7c07f1a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7c07f1b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5534/b/1/A"},"text":"Pub. L. 105–33, § 5534(b)(1)(A)","children":[],"tail":", (5), in introductory provisions, substituted “every State” for “any State which is able and willing to do so,” and “each State” for “such State” and struck out “noncustodial” before “parent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5534/b/1/B"},"text":"Pub. L. 105–33, § 5534(b)(1)(B)","children":[],"tail":", inserted “or visitation” after “custody”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5534/b/5"},"text":"Pub. L. 105–33, § 5534(b)(5)","children":[],"tail":", struck out “noncustodial” before “parent or child when” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5534/b/2"},"text":"Pub. L. 105–33, § 5534(b)(2)","children":[],"tail":", inserted “or visitation” after “custody”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5534/b/5"},"text":"Pub. L. 105–33, § 5534(b)(5)","children":[],"tail":", struck out “noncustodial” before “parent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5534/b/3/A"},"text":"Pub. L. 105–33, § 5534(b)(3)(A)","children":[],"tail":", inserted “or visitation” before “determination”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(A), (B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5534/b/3/B"},"text":"Pub. L. 105–33, § 5534(b)(3)(B)","children":[],"tail":", inserted “or visitation” after “custody”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5534/b/4"},"text":"Pub. L. 105–33, § 5534(b)(4)","children":[],"tail":", inserted “or visitation” after “custody”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":", §§ 316(e)(1), 395(d)(1)(G), inserted “Federal” before “Parent Locator Service” and substituted “noncustodial parent” for “absent parent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/s395/d/1/G"},"text":"Pub. L. 104–193, § 395(d)(1)(G)","children":[],"tail":", substituted “noncustodial parent” for “absent parent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/s316/e/1"},"text":"Pub. L. 104–193, § 316(e)(1)","children":[],"tail":", inserted “Federal” before “Parent Locator Service” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/432/s214/b"},"text":"Pub. L. 103–432, § 214(b)","children":[],"tail":", substituted “subsection (a), (b), (e), or (f)” for “subsection (a), (b), or (e)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/432/s214/a"},"text":"Pub. L. 103–432, § 214(a)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/300/s11/1"},"text":"Pub. L. 100–300, § 11(1)","children":[],"tail":", substituted “under subsection (a)” for “under this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/300/s11/2"},"text":"Pub. L. 100–300, § 11(2)","children":[],"tail":", substituted “under subsection (a), (b), or (e)” for “under this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/300/s11/3"},"text":"Pub. L. 100–300, § 11(3)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb7c07f1c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb7c07f1d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33"},"text":"Pub. L. 105–33","children":[],"tail":" effective as if included in the enactment of title III of the Personal Responsibility and Work Opportunity Reconciliation Act of 1996, "},{"tag":"ref","attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5557"},"text":"section 5557 of Pub. L. 105–33","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s608"},"text":"section 608 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb7c07f1e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":", see section 395(a)–(c) of "},{"tag":"ref","attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s654"},"text":"section 654 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb7c07f1f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/432/tII/s214/c"},"text":"Pub. L. 103–432, title II, § 214(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4461"},"text":"108 Stat. 4461","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/432/tII/s214/c"},"text":"“The amendments made by this section [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1995-10-01"},"text":"October 1, 1995","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb7c07f20-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/611/s9/d"},"text":"Pub. L. 96–611, § 9(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-28"},"text":"Dec. 28, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3573"},"text":"94 Stat. 3573","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/611/s9/d"},"text":"“No agreement entered into under section 463 of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s663"},"text":"42 U.S.C. 663","children":[],"tail":"] shall become effective before the date on which "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1738A"},"text":"section 1738A of title 28","children":[],"tail":", United States Code (as added by this title [probably should be “as added by section 8(a) of this Act”]) becomes effective.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
