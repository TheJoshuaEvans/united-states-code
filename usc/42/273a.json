{"tag":"section","attrib":{"id":"idb520316b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s273a"},"text":null,"children":[{"tag":"num","attrib":{"value":"273a"},"text":"§ 273a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National living donor mechanisms","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may establish and maintain mechanisms to evaluate the long-term effects associated with living organ donations by individuals who have served as living donors.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb520316c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 371A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/216/s7"},"text":"Pub. L. 108–216, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-04-05"},"text":"Apr. 5, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/589"},"text":"118 Stat. 589","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
