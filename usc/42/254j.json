101/992"},"text":"101 Stat. 992","children":[],"tail":", and repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/100/713/tI/s104/b/1"},"text":"Pub. L. 100–713, title I, § 104(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4787"},"text":"102 Stat. 4787","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb4f52aa5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"Section 1013 of title 5","children":[],"tail":"” for “Section 14 of the Federal Advisory Committee Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" struck out at end “Members may not be reappointed to the Council.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/183"},"text":"Pub. L. 103–183","children":[],"tail":" inserted “compensation at a rate fixed by the Secretary (but not to exceed” before “the daily equivalent” and substituted “Schedule);” for “Schedule;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/414"},"text":"Pub. L. 97–414","children":[],"tail":" inserted “(other than "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s254r"},"text":"section 254r of this title","children":[],"tail":")” after “carrying out this subpart”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/s2707/a"},"text":"Pub. L. 97–35, § 2707(a)","children":[],"tail":", amended subsec. (a) generally, striking out pars. (1) to (5) respecting required status and background of members appointed by the Secretary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/s2707/b"},"text":"Pub. L. 97–35, § 2707(b)","children":[],"tail":", inserted “not” before “be reappointed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/32"},"text":"Pub. L. 96–32","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703/b"},"text":"section 5703(b) of title 5","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb4f52aa6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb4f52aa7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Advisory Committees","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/641/s6"},"text":"Pub. L. 93–641, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2275"},"text":"88 Stat. 2275","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s217a"},"text":"section 217a of this title","children":[],"tail":", provided that an advisory committee established pursuant to the Public Health Service Act shall terminate at such time as may be specifically prescribed by an Act of Congress enacted after "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb4f52aa8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References in Other Laws to GS–16, 17, or 18 Pay Rates","children":[],"tail":null},{"tag":"p","attrib":{},"text":"References in laws to the rates of pay for GS–16, 17, or 18, or to maximum rates of pay under the General Schedule, to be considered references to rates payable under specified sections of Title 5, Government Organization and Employees, see section 529 [title I, § 101(c)(1)] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":", set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
