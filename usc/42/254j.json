{"tag":"section","attrib":{"id":"idb4f52a9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254j"},"text":null,"children":[{"tag":"num","attrib":{"value":"254j"},"text":"§ 254j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Advisory Council on National Health Service Corps","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4f52a9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; appointment of members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a council to be known as the National Advisory Council on the National Health Service Corps (hereinafter in this section referred to as the “Council”). The Council shall be composed of not more than 15 members appointed by the Secretary. The Council shall consult with, advise, and make recommendations to, the Secretary with respect to his responsibilities in carrying out this subpart (other than section 254r ","children":[{"tag":"ref","attrib":{"idref":"fn002085"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002085"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title), and shall review and comment upon regulations promulgated by the Secretary under this subpart."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f52a9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of members; compensation; expenses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4f52a9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254j/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Council shall be appointed for a term of three years, except that any member appointed to fill a vacancy occurring prior to the expiration of the term for which the member’s predecessor was appointed shall be appointed for the remainder of such term. No member shall be removed, except for cause.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f52a9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254j/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Council (other than members who are officers or employees of the United States), while attending meetings or conferences thereof or otherwise serving on the business of the Council, shall be entitled to receive for each day (including traveltime) in which they are so serving compensation at a rate fixed by the Secretary (but not to exceed the daily equivalent of the annual rate of basic pay in effect for grade GS–18 of the General Schedule); and while so serving away from their homes or regular places of business all members may be allowed travel expenses, including per diem in lieu of subsistence, as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":" for persons in the Government Service employed intermittently."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f52aa0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254j/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"Section 1013 of title 5","children":[],"tail":" shall not apply with respect to the Council."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4f52aa1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 337, as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/484/tIV/s407/b/3"},"text":"Pub. L. 94–484, title IV, § 407(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2277"},"text":"90 Stat. 2277","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/32/s7/g"},"text":"Pub. L. 96–32, § 7(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-10"},"text":"July 10, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/84"},"text":"93 Stat. 84","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXVII/s2707"},"text":"Pub. L. 97–35, title XXVII, § 2707","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/907"},"text":"95 Stat. 907","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/414/s8/f"},"text":"Pub. L. 97–414, § 8(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-04"},"text":"Jan. 4, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2061"},"text":"96 Stat. 2061","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/183/tVII/s706/b"},"text":"Pub. L. 103–183, title VII, § 706(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-14"},"text":"Dec. 14, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"hre