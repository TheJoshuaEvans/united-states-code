{"tag":"section","attrib":{"id":"idb5f4716a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296m"},"text":null,"children":[{"tag":"num","attrib":{"value":"296m"},"text":"§ 296m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Workforce diversity grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5f4716b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296m/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5f4716c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296m/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002292"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002292"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No par. (2) has been enacted."}],"tail":" Authority"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award grants to and enter into contracts with eligible entities to meet the costs of special projects to increase nursing education opportunities for individuals who are from disadvantaged backgrounds (including racial and ethnic minorities underrepresented among registered nurses) by providing student scholarships or stipends, stipends for diploma or associate degree nurses to enter a bridge or degree completion program, student scholarships or stipends for accelerated nursing degree programs, pre-entry preparation, advanced education preparation, and retention activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5f4716d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296m/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out subsection (a), the Secretary shall take into consideration the recommendations of the National Advisory Council on Nurse Education and Practice and consult with nursing associations including the National Coalition of Ethnic Minority Nurse Associations, American ","children":[{"tag":"ref","attrib":{"idref":"fn002293"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002293"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be preceded by “the”."}],"tail":" Nurses Association, the National League for Nursing, the American Association of Colleges of Nursing, the National Black Nurses Association, the National Association of Hispanic Nurses, the Association of Asian American and Pacific Islander Nurses, the Native American Indian and Alaskan Nurses Association, and the National Council of State Boards of Nursing, and other organizations determined appropriate by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5f4716e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296m/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required information and conditions for award recipients","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5f4716f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296m/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Recipients of awards under this section may be required, where requested, to report to the Secretary concerning the annual admission, retention, and graduation rates for individuals from disadvantaged backgrounds and ethnic and racial minorities in the school or schools involved in the projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5f47170-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296m/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Falling rates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any of the rates reported under paragraph (1) fall below the average of the two previous years, the grant or contract recipient shall provide the Secretary with plans for immediately improving such rates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5f47171-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296m/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ineligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A recipient described in paragraph (2) shall be ineligible for continued funding under this section if the plan of the recipient fails to improve the rates within the 1-year period beginning on the date such plan is implemented.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5f47172-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VIII, § 821, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/392/tI/s123/4"},"text":"Pub. L. 105–392, title I, § 123(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3568"},"text":"112 Stat. 3568","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tV/s5404"},"text":"Pub. L. 111–148, title V, § 5404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/649"},"text":"124 Stat. 649","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5f47173-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5f47174-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5f47175-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 296m, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tVIII/s822"},"text":"act July 1, 1944, ch. 373, title VIII, § 822","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/63/tIX/s931/a"},"text":"Pub. L. 94–63, title IX, § 931(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-07-29"},"text":"July 29, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/361"},"text":"89 Stat. 361","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/83/tIII/s307"},"text":"Pub. L. 95–83, title III, § 307","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(5)(A), "},{"