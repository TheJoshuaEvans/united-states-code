href":"/us/stat/103/614"},"text":"103 Stat. 614","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/597/tIV/s401/b"},"text":"Pub. L. 101–597, title IV, § 401(b)[(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3035"},"text":"104 Stat. 3035","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/408/tII/s204"},"text":"Pub. L. 102–408, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-13"},"text":"Oct. 13, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2072"},"text":"106 Stat. 2072","children":[],"tail":", authorized grants and contracts for nurse practitioner and nurse midwife programs, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/392/tI/s123/1"},"text":"Pub. L. 105–392, title I, § 123(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3562"},"text":"112 Stat. 3562","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 821 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to section 296"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/392"},"text":"Pub. L. 105–392","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5f47176-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s5404/1"},"text":"Pub. L. 111–148, § 5404(1)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, and substituted “stipends for diploma or associate degree nurses to enter a bridge or degree completion program, student scholarships or stipends for accelerated nursing degree programs, pre-entry preparation, advanced education preparation, and retention activities” for “pre-entry preparation, and retention activities”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s5404/2"},"text":"Pub. L. 111–148, § 5404(2)","children":[],"tail":", substituted “National Advisory Council on Nurse Education and Practice and consult with nursing associations including the National Coalition of Ethnic Minority Nurse Associations,” for “First, Second and Third Invitational Congresses for Minority Nurse Leaders on ‘Caring for the Emerging Majority,’ in 1992, 1993 and 1997, and consult with nursing associations including the” and inserted “, and other organizations determined appropriate by the Secretary” before period at end."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
