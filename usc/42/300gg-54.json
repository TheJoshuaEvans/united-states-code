{"tag":"section","attrib":{"id":"idb6b7e95a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–54"},"text":null,"children":[{"tag":"num","attrib":{"value":"300gg–54"},"text":"§ 300gg–54.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coverage of dependent students on medically necessary leave of absence","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of section 2707 ","children":[{"tag":"ref","attrib":{"idref":"fn002480"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002480"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall apply to health insurance coverage offered by a health insurance issuer in the individual market in the same manner as they apply to health insurance coverage offered by a health insurance issuer in connection with a group health plan in the small or large group market."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb6b7e95b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVII, § 2753, as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/381/s2/b/2"},"text":"Pub. L. 110–381, § 2(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-09"},"text":"Oct. 9, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4084"},"text":"122 Stat. 4084","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6b7e95c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6b7e95d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes"