{"tag":"section","attrib":{"id":"idb5895376-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s288–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"288–2"},"text":"§ 288–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extramural loan repayment program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5895377-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s288–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Institutes of Health shall, as appropriate and based on workforce and scientific priorities, carry out a program through the subcategories listed in subsection (b)(1) (or modified subcategories as provided for in subsection (b)(2)), of entering into contracts with qualified health professionals under which such health professionals agree to conduct research in consideration of the Federal Government agreeing to repay, for each year of such research, not more than $50,000 of the principal and interest of the educational loans of such health professionals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5897a88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s288–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subcategories of research","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5897a89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s288–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program under subsection (a), the Director of the National Institutes of Health—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5897a8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s288–2/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall continue to focus on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5897a8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s288–2/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contraception or infertility research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5897a8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s288–2/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pediatric research, including pediatric pharmacological research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5897a8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s288–2/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minority health disparities research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5897a8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s288–2/b/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clinical research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5897a8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s288–2/b/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clinical research conducted by appropriately qualified health professional ","children":[{"tag":"ref","attrib":{"idref":"fn002211"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002211"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “professionals”."}],"tail":" who are from disadvantaged backgrounds; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5897a90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s288–2/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may focus on an area of emerging scientific or workforce need.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5897a91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s288–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elimination or establishment of subcategories","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Institutes of Health may eliminate one or more subcategories provided for in paragraph (1) due to changes in workforce or scientific needs related to biomedical research. The Director may establish other subcategory areas based on workforce and scientific priorities if the total number of subcategories does not exceed the number of subcategories listed in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5897a92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s288–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Institutes of Health may not enter into a contract with a health professional pursuant to subsection (a) unless such professional has a substantial amount of education loans relative to income (as determined pursuant to guidelines issued by the Director).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5897a93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s288–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of certain provisions regarding obligated service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of sections 254","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–1, 254m, and 254"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title shall, except as inconsistent with subsection (a) of this section, apply to the program established in subsection (a) to the same extent and in the same manner as such provisions apply to the National Health Service Corps Loan Repayment Program established in subpart III of part D of subchapter II."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5897a94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s288–2/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts available for carrying out this section shall remain available until the expiration of the second fiscal year beginning after the fiscal year for which the amounts were made available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb589a1a5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 487B, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tX/s1002"},"text":"Pub. L. 103–43, title X, § 1002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/166"},"text":"107 Stat. 166","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/392/tIV/s410/b"},"text":"Pub. L. 105–392, title IV, § 410(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3589"},"text":"112 Stat. 3589","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/154/s1/b/8"},"text":"Pub. L. 110–154, § 1(b)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-21"},"text":"Dec. 21, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1827"},"text":"121 Stat. 1827","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tII/s2022/b"},"text":"Pub. L. 114–255, div. A, title II, § 2022(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1053"},"text":"130 Stat. 1053","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb589a1a6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb589a1a7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb589a1a8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s2022/b/1"},"text":"Pub. L. 114–255, § 2022(b)(1)","children":[],"tail":", amended section catchline generally. Prior to amendment, catchline read as follows: “Loan repayment program for research with respect to contraception and infertility”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s2022/b/2"},"text":"Pub. L. 114–255, § 2022(b)(2)","children":[],"tail":", inserted heading and, in text, substituted “The Director of the National Institutes of Health shall, as appropriate and based on workforce and scientific priorities, carry out a program through the subcategories listed in subsection (b)(1) (or modified subcategories as provided for in subsection (b)(2)),” for “The Secretary, in consultation with the Director of the Eunice Kennedy Shriver National Institute of Child Health and Human Development, shall establish a program” and “research, not more than $50,000” for “service, not more than $35,000” and struck out “(including graduate students)” after “qualified health professionals” and “with respect to contraception, or with respect to infertility,” after “conduct research”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s2022/b/4"},"text":"Pub. L. 114–255, § 2022(b)(4)","children":[],"tail":", added subsecs. (b) and (c). Former subsecs. (b) and (c) redesignated (d) and (e), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s2022/3"},"text":"Pub. L. 114–255, § 2022(3)","children":[],"tail":", (5), redesignated subsec. (b) as (d) and inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s2002/3"},"text":"Pub. L. 114–255, § 2002(3)","children":[],"tail":", (6), redesignated subsec. (c) as (e) and inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/154"},"text":"Pub. L. 110–154","children":[],"tail":", which directed substitution of “Eunice Kennedy Shriver National Institute of Child Health and Human Development” for “National Institute on Child Health and Human Development”, was executed by making the substitution for “National Institute of Child Health and Human Development” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/392"},"text":"Pub. L. 105–392","children":[],"tail":" substituted “$35,000” for “$20,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
