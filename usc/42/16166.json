{"tag":"section","attrib":{"id":"idbff79e1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16166"},"text":null,"children":[{"tag":"num","attrib":{"value":"16166"},"text":"§ 16166.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clean hydrogen production qualifications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbff79e20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16166/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Secretary, in consultation with the Administrator of the Environmental Protection Agency and after taking into account input from industry and other stakeholders, as determined by the Secretary, shall develop an initial standard for the carbon intensity of clean hydrogen production that shall apply to activities carried out under this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff79e21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16166/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff79e22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16166/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The standard developed under subsection (a) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff79e23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16166/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support clean hydrogen production from each source described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16154/e/2"},"text":"section 16154(e)(2) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79e24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16166/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" define the term “clean hydrogen” to mean hydrogen produced with a carbon intensity equal to or less than 2 kilograms of carbon dioxide-equivalent produced at the site of production per kilogram of hydrogen produced; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79e25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16166/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into consideration technological and economic feasibility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79e26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16166/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than the date that is 5 years after the date on which the Secretary develops the standard under subsection (a), the Secretary, in consultation with the Administrator of the Environmental Protection Agency and after taking into account input from industry and other stakeholders, as determined by the Secretary, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff79e27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16166/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine whether the definition of clean hydrogen required under paragraph (1)(B) should be adjusted below the standard described in that paragraph; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79e28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16166/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary determines the adjustment described in subparagraph (A) is appropriate, carry out the adjustment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff79e29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16166/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The standard developed under subsection (a) shall apply to clean hydrogen production from renewable, fossil fuel with carbon capture, utilization, and sequestration technologies, nuclear, and other fuel sources using any applicable production technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff79e2a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVIII/s822"},"text":"Pub. L. 109–58, title VIII, § 822","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tIII/s40315/a"},"text":"Pub. L. 117–58, div. D, title III, § 40315(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1015"},"text":"135 Stat. 1015","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbff79e2b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbff79e2c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbff79e2d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s40315/a"},"text":"Section 40315(a) of Pub. L. 117–58","children":[],"tail":", which directed the amendment of the Energy Policy Act of 2005 by adding this section at the end, was executed by adding this section at the end of title VIII of the Act, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbff79e2e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbff79e2f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
