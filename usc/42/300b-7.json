{"tag":"section","attrib":{"id":"idb60eb05d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"300b–7"},"text":"§ 300b–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tourette Syndrome","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb60eb05e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–7/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop and implement outreach programs to educate the public, health care providers, educators and community based organizations about the etiology, symptoms, diagnosis and treatment of Tourette Syndrome, with a particular emphasis on children with Tourette Syndrome. Such programs may be carried out by the Secretary directly and through awards of grants or contracts to public or nonprofit private entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb60eb05f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–7/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities under subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb60eb060-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–7/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the production and translation of educational materials, including public service announcements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb60eb061-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–7/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of training material for health care providers, educators and community based organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb60eb062-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–7/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outreach efforts directed at the misdiagnosis and underdiagnosis of Tourette Syndrome in children and in minority groups.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb60eb063-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–7/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this section, there are authorized to be appropriated such sums as may be necessary for each of the fiscal years 2001 through 2005.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb60eb064-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XI, § 1108, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dA/tXXIII/s2301"},"text":"Pub. L. 106–310, div. A, title XXIII, § 2301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1157"},"text":"114 Stat. 1157","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
