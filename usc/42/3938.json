{"tag":"section","attrib":{"id":"idbc9f987d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3938"},"text":null,"children":[{"tag":"num","attrib":{"value":"3938"},"text":"§ 3938.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report of corporation; audit of accounts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc9f987e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3938/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc9f987f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3938/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The corporation shall submit an annual report to the President for transmittal to the Congress within six months after the end of its fiscal year. The report shall include a comprehensive and detailed report of the operations, activities, and financial condition of the corporation and the partnership under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc9f9880-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3938/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The report shall contain a description of the activities undertaken under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3936/a/4"},"text":"section 3936(a)(4) of this title","children":[],"tail":", and shall specify, as a percentage of equity and in dollars, the extent of the corporation’s and the partnership’s investment in housing for the benefit of families and individuals of low or moderate income, the extent of the corporation’s and the partnership’s investment in other housing, and the extent of the corporation’s and the partnership’s activities which are undertaken under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3936/a/4"},"text":"section 3936(a)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc9f9881-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3938/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The accounts of the corporation and of the partnership shall be audited annually in accordance with generally accepted auditing standards by independent certified public accountants or independent licensed public accountants certified or licensed by a regulatory authority of a State or other political subdivision of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc9f9882-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/448/tIX/s908"},"text":"Pub. L. 90–448, title IX, § 908","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-01"},"text":"Aug. 1, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/550"},"text":"82 Stat. 550","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/479/tI/s104/c/3"},"text":"Pub. L. 98–479, title I, § 104(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-17"},"text":"Oct. 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2225"},"text":"98 Stat. 2225","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc9f9883-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc9f9884-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc9f9885-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/479"},"text":"Pub. L. 98–479","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc9f9886-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbc9f9887-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions in subsec. (a) of this section relating to transmittal of annual report to Congress, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance, and item 2 on page 182 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
