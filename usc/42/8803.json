{"tag":"section","attrib":{"id":"idbea2945d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8803"},"text":null,"children":[{"tag":"num","attrib":{"value":"8803"},"text":"§ 8803.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbea2945e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8803/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent provided in advance in appropriation Acts, for the two year period beginning ","children":[{"tag":"date","attrib":{"date":"1980-10-01"},"text":"October 1, 1980","children":[],"tail":", there is authorized to be appropriated and transferred $1,170,000,000 from the Energy Security Reserve established in the Treasury of the United States under title II of the Act entitled “An Act making appropriations for the Department of the Interior and related agencies for the fiscal year ending "},{"tag":"date","attrib":{"date":"1980-09-30"},"text":"September 30, 1980","children":[],"tail":", and for other purposes” ("},{"tag":"ref","attrib":{"href":"/us/pl/96/126"},"text":"Public Law 96–126","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/93/970"},"text":"93 Stat. 970","children":[],"tail":") and made available for obligation by such Act only to the extent provided in advance in appropriation Acts, as follows:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbea2945f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8803/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $460,000,000 to the Secretary of Agriculture for carrying out activities under subchapter I, except of the amount of the financial assistance provided by the Secretary of Agriculture under subchapter I, up to one-third shall be for small-scale biomass energy projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea29460-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8803/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $460,000,000 to the Secretary of Energy for carrying out biomass energy activities under subchapter I, of which at least $500,000,000 ","children":[{"tag":"ref","attrib":{"idref":"fn003850"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003850"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. "},{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" decreased appropriation to $460,000,000 from $600,000,000 without amending sum of $500,000,000."}],"tail":" shall be available to the Office of Alcohol Fuels for carrying out its activities, and any amount not made available to the Office of Alcohol Fuels shall be available to the Secretary to carry out the purposes of subchapter I under available authorities of the Secretary, including authorities under subchapter I; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea29461-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8803/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $250,000,000 shall be available to the Secretary of Energy for carrying out activities under subchapter II.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbea29462-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8803/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds until expended","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available under subsection (a) shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbea29463-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8803/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations respecting amount of appropriations remaining available","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbea29464-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8803/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of determining the amount of such appropriations which remain available for purposes of this chapter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbea29465-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8803/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" loans shall be counted at the initial face value of the loan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbea29466-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8803/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" loan guarantees shall be counted at the initial face value of such loan guarantee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbea29467-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8803/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" price guarantees and purchase agreements shall be counted at the value determined by the Secretary concerned as of the date of each such contract based upon the Secretary’s determination of the maximum potential liability of the United States under the contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbea29468-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8803/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any increase in the liability of the United States pursuant to any amendment or other modification to a contract for a loan, loan guarantee, price guarantee, or purchase agreement, shall be counted to the extent of such increase.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea29469-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8803/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Determinations under paragraph (1) shall be made in accordance with generally accepted accounting principles, consistently applied.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea2946a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8803/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If more than one form of financial assistance is to be provided to any one project, the obligations and commitments thereunder shall be counted at the maximum potential exposure of the United States on such project at any time during the life of such project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea2946b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8803/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any commitment to provide financial assistance shall be treated the same as such assistance for purposes of this subsection; except that any such commitment which is nullified or voided for any reason shall not be considered for purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbea2946c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8803/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial assistance provided only to extent advanced in appropriation Acts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Financial assistance may be provided under this chapter only to the extent provided in advance in appropriation Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbea2946d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/294/tII/s204"},"text":"Pub. L. 96–294, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/685"},"text":"94 Stat. 685","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tX"},"text":"Pub. L. 97–35, title X","children":[],"tail":", §§ 1061–1063, "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/622"},"text":"95 Stat. 622","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbea2946e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbea2946f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbea29470-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Energy Security Reserve established in the Treasury of the United States under title II of the Act entitled “An Act making appropriations for the Department of the Interior and related agencies for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1980-09-30"},"text":"September 30, 1980","children":[],"tail":", and for other purposes” ("},{"tag":"ref","attrib":{"href":"/us/pl/96/126"},"text":"Public Law 96–126","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/93/970"},"text":"93 Stat. 970","children":[],"tail":"), referred to in subsec. (a), was established by "},{"tag":"ref","attrib":{"href":"/us/pl/96/126/tII/s201"},"text":"Pub. L. 96–126, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-11-27"},"text":"Nov. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/970"},"text":"93 Stat. 970","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5915"},"text":"section 5915 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (c)(1) and (d), was in the original “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/294"},"text":"Pub. L. 96–294","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/683"},"text":"94 Stat. 683","children":[],"tail":", known as the Biomass Energy and Alcohol Fuels Act of 1980, which is classified principally to this chapter. For complete classification of title II to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8801"},"text":"section 8801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbea29471-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1981—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/s1063"},"text":"Pub. L. 97–35, § 1063","children":[],"tail":", substituted “$1,170,000,000” for “$1,450,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/s1061"},"text":"Pub. L. 97–35, § 1061","children":[],"tail":", substituted “$460,000,000” for “$600,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/s1062"},"text":"Pub. L. 97–35, § 1062","children":[],"tail":", substituted “$460,000,000” for “$600,000,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbea29472-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbea29473-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s1038"},"text":"section 1038 of Pub. L. 97–35","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6240"},"text":"section 6240 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
