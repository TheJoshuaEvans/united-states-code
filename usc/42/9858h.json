{"tag":"section","attrib":{"id":"idbeffa8e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858h"},"text":null,"children":[{"tag":"num","attrib":{"value":"9858h"},"text":"§ 9858h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbeffa8e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations, a State that has an application approved by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9858c/d"},"text":"section 9858c(d) of this title","children":[],"tail":" shall be entitled to a payment under this section for each fiscal year in an amount equal to its allotment under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9858m"},"text":"section 9858m of this title","children":[],"tail":" for such fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbeffa8e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Method of payment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbeffa8e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the Secretary may make payments to a State in installments, and in advance or by way of reimbursement, with necessary adjustments on account of overpayments or underpayments, as the Secretary may determine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeffa8e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make such payments in a manner that prevents the State from complying with the requirement specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9858c/c/3"},"text":"section 9858c(c)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbeffa8e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858h/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Spending of funds by State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payments to a State from the allotment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9858m"},"text":"section 9858m of this title","children":[],"tail":" for any fiscal year may be obligated by the State in that fiscal year or in the succeeding fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbeffa8e8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s658J"},"text":"Pub. L. 97–35, title VI, § 658J","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tV/s5082/2"},"text":"Pub. L. 101–508, title V, § 5082(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990"