{"tag":"section","attrib":{"id":"idbff52d70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161a"},"text":null,"children":[{"tag":"num","attrib":{"value":"16161a"},"text":"§ 16161a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional clean hydrogen hubs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbff52d71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of regional clean hydrogen hub","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “regional clean hydrogen hub” means a network of clean hydrogen producers, potential clean hydrogen consumers, and connective infrastructure located in close proximity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff52d72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a program to support the development of at least 4 regional clean hydrogen hubs that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff52d73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrably aid the achievement of the clean hydrogen production standard developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16166/a"},"text":"section 16166(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate the production, processing, delivery, storage, and end-use of clean hydrogen; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" can be developed into a national clean hydrogen network to facilitate a clean hydrogen economy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff52d76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of regional clean hydrogen hubs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff52d77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solicitation of proposals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Secretary shall solicit proposals for regional clean hydrogen hubs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of hubs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after the deadline for the submission of proposals under paragraph (1), the Secretary shall select at least 4 regional clean hydrogen hubs to be developed under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall select regional clean hydrogen hubs under paragraph (2) using the following criteria:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff52d7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Feedstock diversity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the maximum extent practicable—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff52d7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161a/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 1 regional clean hydrogen hub shall demonstrate the production of clean hydrogen from fossil fuels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff52d7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161a/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 1 regional clean hydrogen hub shall demonstrate the production of clean hydrogen from renewable energy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff52d7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161a/c/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 1 regional clean hydrogen hub shall demonstrate the production of clean hydrogen from nuclear energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff52d7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" End-use diversity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the maximum extent practicable—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff52d7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161a/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 1 regional clean hydrogen hub shall demonstrate the end-use of clean hydrogen in the electric power generation sector;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff52d80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161a/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 1 regional clean hydrogen hub shall demonstrate the end-use of clean hydrogen in the industrial sector;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff52d81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161a/c/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 1 regional clean hydrogen hub shall demonstrate the end-use of clean hydrogen in the residential and commercial heating sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff52d82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161a/c/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 1 regional clean hydrogen hub shall demonstrate the end-use of clean hydrogen in the transportation sector.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff52d83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161a/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographic diversity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the maximum extent practicable, each regional clean hydrogen hub—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff52d84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161a/c/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be located in a different region of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff52d85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161a/c/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall use energy resources that are abundant in that region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff52d86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161a/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hubs in natural gas-producing regions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent practicable, at least 2 regional clean hydrogen hubs shall be located in the regions of the United States with the greatest natural gas resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff52d87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161a/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall give priority to regional clean hydrogen hubs that are likely to create opportunities for skilled training and long-term employment to the greatest number of residents of the region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff52d88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161a/c/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may take into consideration other criteria that, in the judgment of the Secretary, are necessary or appropriate to carry out this subchapter ","children":[{"tag":"ref","attrib":{"idref":"fn004212"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004212"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a period."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding of regional clean hydrogen hubs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make grants to each regional clean hydrogen hub selected under paragraph (2) to accelerate commercialization of, and demonstrate the production, processing, delivery, storage, and end-use of, clean hydrogen.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff52d8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary to carry out this section $8,000,000,000 for the period of fiscal years 2022 through 2026.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff52d8b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVIII/s813"},"text":"Pub. L. 109–58, title VIII, § 813","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tIII/s40314/2"},"text":"Pub. L. 117–58, div. D, title III, § 40314(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1008"},"text":"135 Stat. 1008","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbff52d8c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbff52d8d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbff52d8e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s813"},"text":"section 813 of Pub. L. 109–58","children":[],"tail":" was renumbered section 818 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s16162"},"text":"section 16162 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbff52d8f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbff52d90-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
