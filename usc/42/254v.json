{"tag":"section","attrib":{"id":"idb4fec785-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254v"},"text":null,"children":[{"tag":"num","attrib":{"value":"254v"},"text":"§ 254v.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clarification regarding service in schools and other community-based settings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4fec786-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254v/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schools and community-based settings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An entity to which a participant in the Scholarship Program or the Loan Repayment Program (referred to in this section as a “participant”) is assigned under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254f"},"text":"section 254f of this title","children":[],"tail":" may direct such participant to provide service as a behavioral or mental health professional at a school or other community-based setting located in a health professional shortage area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fec787-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254v/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obligated service","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4fec788-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254v/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any service described in subsection (a) that a participant provides may count towards such participant’s completion of any obligated service requirements under the Scholarship Program or the Loan Repayment Program, subject to any limitation imposed under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fec789-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254v/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may impose a limitation on the number of hours of service described in subsection (a) that a participant may credit towards completing obligated service requirements, provided that the limitation allows a member to credit service described in subsection (a) for not less than 50 percent of the total hours required to complete such obligated service requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fec78a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254v/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authorization under subsection (a) shall be notwithstanding any other provision of this subpart or subpart II.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4fec78b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 338N, as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/271/tVII/s7072"},"text":"Pub. L. 115–271, title VII, § 7072","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4030"},"text":"132 Stat. 4030","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
