{"tag":"section","attrib":{"id":"idb5ce4c3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s291m"},"text":null,"children":[{"tag":"num","attrib":{"value":"291m"},"text":"§ 291m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State control of operations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as otherwise specifically provided, nothing in this subchapter shall be construed as conferring on any Federal officer or employee the right to exercise any supervision or control over the administration, personnel, maintenance, or operation of any facility with respect to which any funds have been or may be expended under this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb5ce4c3f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VI, § 643, formerly § 623, as added "},{"tag":"ref","attrib":{"href":"/us/pl/88/443/s3/a"},"text":"Pub. L. 88–443, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-08-18"},"text":"Aug. 18, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/458"},"text":"78 Stat. 458","children":[],"tail":", and renumbered § 643, "},{"tag":"ref","attrib":{"href":"/us/pl/91/296/tII/s201"},"text":"Pub. L. 91–296, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-30"},"text":"June 30, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/344"},"text":"84 Stat. 344","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5ce4c40-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5ce4c41-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"chi