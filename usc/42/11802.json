{"tag":"section","attrib":{"id":"idbf57db3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11802"},"text":null,"children":[{"tag":"num","attrib":{"value":"11802"},"text":"§ 11802.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application for grants and contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf57db3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11802/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any agency, organization, institution, or individual desiring to receive a grant, or to enter into a contract, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11801"},"text":"section 11801 of this title","children":[],"tail":" shall submit to the Secretary an application at such time, in such manner, and containing or accompanied by such information as the Secretary may require by rule."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf57db3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11802/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each application for assistance under this subchapter shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf57db3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11802/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth a project or activity for carrying out one or more of the purposes specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11801"},"text":"section 11801 of this title","children":[],"tail":" and specifically identify each such purpose such project or activity is designed to carry out,"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf57db40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11802/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that such project or activity shall be administered by or under the supervision of the applicant,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf57db41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11802/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the proper and efficient administration of such project or activity,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf57db42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11802/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for regular evaluation of the operation of such project or activity,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf57db43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11802/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that regular reports on such project or activity shall be submitted to the Secretary, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf57db44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11802/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide such fiscal control and fund accounting procedures as may be necessary to ensure prudent use, proper disbursement, and accurate accounting of funds received under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf57db45-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tIII/s3502"},"text":"Pub. L. 100–690, title III, § 3502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4254"},"text":"102 Stat. 4254","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
