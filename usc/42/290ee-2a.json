{"tag":"section","attrib":{"id":"idb5bd83b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2a"},"text":null,"children":[{"tag":"num","attrib":{"value":"290ee–2a"},"text":"§ 290ee–2a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peer support technical assistance center","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5bd83b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Assistant Secretary, shall establish or operate a National Peer-Run Training and Technical Assistance Center for Addiction Recovery Support (referred to in this section as the “Center”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bd83b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Center established under subsection (a) shall provide technical assistance and support to recovery community organizations and peer support networks, including such assistance and support related to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5bd83b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" training on identifying—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5bd83b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" signs of substance use disorder;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5bd83b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resources to assist individuals with a substance use disorder, or resources for families of an individual with a substance use disorder; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5bd83ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2a/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" best practices for the delivery of recovery support services;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bd83bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of translation services, interpretation, or other such services for clients with limited English speaking proficiency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bff3bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data collection to support research, including for translational research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bff3bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" capacity building, such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5bff3be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2a/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" professional development of peer support specialists; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5bff3bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2a/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making recovery support services available in nonclinical settings; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bff3c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluation and improvement, as necessary, of the effectiveness of such services provided by recovery community organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bff3c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Best practices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Center established under subsection (a) shall periodically issue best practices for use by recovery community organizations and peer support networks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bff3c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional Centers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5bff3c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may establish one regional technical assistance center (referred to in this subsection as the “Regional Center”), with existing resources, to assist the Center in carrying out activities described in subsection (b) within the geographic region of such Regional Center in a manner that is tailored to the needs of such region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bff3c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 4 years after ","children":[{"tag":"date","attrib":{"date":"2025-12-01"},"text":"December 1, 2025","children":[],"tail":", the Secretary shall evaluate the activities of the Regional Center and submit to the Committee on Health, Education, Labor, and Pensions of the Senate and the Committee on Energy and Commerce of the House of Representatives a report on the findings of such evaluation, including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5bff3c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the distinct roles and responsibilities of the Regional Center and the Center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5bff3c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" available information relating to the outcomes of the Regional Center under this subsection, such as any impact on the operations and efficiency of the Center relating to requests for technical assistance and support within the region of such Regional Center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5bff3c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2a/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any gaps or areas of duplication relating to the activities of the Regional Center and the Center within such region; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5bff3c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2a/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations relating to the modification, expansion, or termination of the Regional Center under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bff3c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall terminate on ","children":[{"tag":"date","attrib":{"date":"2030-09-30"},"text":"September 30, 2030","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bff3ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery community organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “recovery community organization” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290ee–2"},"text":"section 290ee–2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bff3cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–2a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $2,000,000 for each of fiscal years 2026 through 2030.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5bff3cc-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 547A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/271/tVII/s7152"},"text":"Pub. L. 115–271, title VII, § 7152","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4058"},"text":"132 Stat. 4058","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/44/tIII/s302"},"text":"Pub. L. 119–44, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-01"},"text":"Dec. 1, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/684"},"text":"139 Stat. 684","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5bff3cd-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5bff3ce-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5bff3cf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/44/s302/1"},"text":"Pub. L. 119–44, § 302(1)","children":[],"tail":", substituted “building, such as—” for “building; and” and added subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/44/s302/3"},"text":"Pub. L. 119–44, § 302(3)","children":[],"tail":", added subsec. (d). Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/44/s302/2"},"text":"Pub. L. 119–44, § 302(2)","children":[],"tail":", redesignated subsec. (d) as (e). Former subsec. (e) redesignated (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/44/s302/2"},"text":"Pub. L. 119–44, § 302(2)","children":[],"tail":", (4), redesignated subsec. (e) as (f) and substituted “$2,000,000 for each of fiscal years 2026 through 2030” for “$1,000,000 for each of fiscal years 2019 through 2023”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
