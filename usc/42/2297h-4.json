{"tag":"section","attrib":{"id":"idbc1a15e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297h–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"2297h–4"},"text":"§ 2297h–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers to private corporation","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Concurrent with privatization, the Corporation shall transfer to the private corporation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc1a15e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297h–4/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lease of the gaseous diffusion plants in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2297h–5"},"text":"section 2297h–5 of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc1a15e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297h–4/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all personal property and inventories of the Corporation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc1a15e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297h–4/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all contracts, agreements, and leases under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2297h–6/a"},"text":"section 2297h–6(a) of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc1a15ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297h–4/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Corporation’s right to purchase power from the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2297h–6/b"},"text":"section 2297h–6(b) of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc1a15eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297h–4/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such funds in accounts of the Corporation held by the Treasury or on deposit with any bank or other financial institution as approved by the Secretary of the Treasury, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc1a15ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297h–4/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all of the Corporation’s records, including all of the papers and other documentary materials, regardless of physical form or characteristics, made or received by the Corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc1a15ed-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134/tIII/s3106"},"text":"Pub. L. 104–134, title III, § 3106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1321-338"},"text":"110 Stat. 1321–338","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc1a15ee-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc1a15ef-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbc1a15f0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the USEC Privatization Act and also as part of the Omnibus Consolidated Rescissions and Appropriations Act of 1996, and not as part of the Atomic Energy Act of 1954 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
