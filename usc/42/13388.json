{"tag":"section","attrib":{"id":"idbfc0d64c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13388"},"text":null,"children":[{"tag":"num","attrib":{"value":"13388"},"text":"§ 13388.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Global Climate Change Response Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfc0d64d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13388/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury, in consultation with the Secretary of State, shall establish a Global Climate Change Response Fund to act as a mechanism for United States contributions to assist global efforts in mitigating and adapting to global climate change.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc0d64e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13388/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on deposits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No deposits shall be made to the Global Climate Change Response Fund until the United States has ratified the United Nations Framework Convention on Climate Change.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc0d64f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13388/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Moneys deposited into the Fund shall be used by the President, to the extent authorized and appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2222"},"text":"section 2222 of title 22","children":[],"tail":", solely for contributions to a financial mechanism negotiated pursuant to the United Nations Framework Convention on Climate Change, including all protocols or agreements related thereto."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc0d650-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13388/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated for deposit in the Fund to carry out the purposes of this section, $50,000,000 for fiscal year 1994 and such sums as may be necessary for fiscal years 1995 and 1996.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfc0d651-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXVI/s1609"},"text":"Pub. L. 102–486, title XVI, § 1609","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3007"},"text":"106 Stat. 3007","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
