{"tag":"section","attrib":{"id":"idbed98396-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9671"},"text":null,"children":[{"tag":"num","attrib":{"value":"9671"},"text":"§ 9671.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbed98397-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9671/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insurance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “insurance” means primary insurance, excess insurance, reinsurance, surplus lines insurance, and any other arrangement for shifting and distributing risk which is determined to be insurance under applicable State or Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed98398-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9671/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pollution liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “pollution liability” means liability for injuries arising from the release of hazardous substances or pollutants or contaminants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed98399-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9671/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Risk retention group","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “risk retention group” means any corporation or other limited liability association taxable as a corporation, or as an insurance company, formed under the laws of any State—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbed9839a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9671/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose primary activity consists of assuming and spreading all, or any portion, of the pollution liability of its group members;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbed9839b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9671/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is organized for the primary purpose of conducting the activity described under subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbed9839c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9671/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is chartered or licensed as an insurance company and authorized to engage in the business of insurance under the laws of any State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbed9839d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9671/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which does not exclude any person from membership in the group solely to provide for members of such a group a competitive advantage over such a person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed9839e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9671/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchasing group","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “purchasing group” means any group of persons which has as one of its purposes the purchase of pollution liability insurance on a group basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed9839f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9671/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means any State of the United States, the District of Columbia, the Commonwealth of Puerto Rico, Guam, American Samoa, the Virgin Islands, the Commonwealth of the Northern Marianas, and any other territory or possession over which the United States has jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbed983a0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/510/tIV/s401"},"text":"Pub. L. 96–510, title IV, § 401","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/499/tII/s210/a"},"text":"Pub. L. 99–499, title II, § 210(a)","children":[],"tail":", formerly § 210, "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1716"},"text":"100 Stat. 1716","children":[],"tail":"; renumbered § 210(a), "},{"tag":"ref","attrib":{"href":"/us/pl/99/563/s11/c/1"},"text":"Pub. L. 99–563, § 11(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3177"},"text":"100 Stat. 3177","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbed983a1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbed983a2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbed983a3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"State Powers and Authorities Under Risk Retention Amendments of 1986","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/499/tII/s210/b"},"text":"Pub. L. 99–499, title II, § 210(b)","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/99/563/s11/c/1"},"text":"Pub. L. 99–563, § 11(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3177"},"text":"100 Stat. 3177","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/563/s11/c/1"},"text":"“For purposes of subsection (a) of this section [enacting this subchapter], the powers and authorities of States addressed by the Risk Retention Amendments of 1986 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/563"},"text":"Pub. L. 99–563","children":[],"tail":", see Short Title of 1986 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3901"},"text":"section 3901 of Title 15","children":[],"tail":", Commerce and Trade] are in addition to those of this Act [see Short Title of 1986 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9601"},"text":"section 9601 of this title","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
