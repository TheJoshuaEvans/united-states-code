{"tag":"section","attrib":{"id":"idba123717-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395mmm"},"text":null,"children":[{"tag":"num","attrib":{"value":"1395mmm"},"text":"§ 1395mmm.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limiting Medicare coverage of certain individuals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idba123718-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395mmm/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (b), an individual may be entitled to, or enrolled for, benefits under this subchapter only if the individual is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idba123719-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395mmm/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a citizen or national of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba12371a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395mmm/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an alien who is lawfully admitted for permanent residence under the Immigration and Nationality Act;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba12371b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395mmm/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an alien who has been granted the status of Cuban and Haitian entrant, as defined in section 501(e) of the Refugee Education Assistance Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/422"},"text":"Public Law 96–422","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba12371c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395mmm/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual who lawfully resides in the United States in accordance with a Compact of Free Association referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1612/b/2/G"},"text":"section 1612(b)(2)(G) of title 8","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba12371d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395mmm/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to individuals currently entitled to or enrolled for benefits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idba12371e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395mmm/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an individual who is entitled to, or enrolled for, benefits under this subchapter as of ","children":[{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", subsection (a) shall apply beginning on the date that is 18 months after "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba12371f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395mmm/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review by Commissioner of Social Security","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idba123720-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395mmm/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", the Commissioner of Social Security shall complete a review of individuals entitled to, or enrolled for, benefits under this subchapter as of "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", for purposes of identifying individuals not described in any of paragraphs (1) through (4) of subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idba123721-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395mmm/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner of Social Security shall notify each individual identified under the review conducted under subparagraph (A) that such individual’s entitlement to, or enrollment for, benefits under this subchapter will be terminated as of the date that is 18 months after ","children":[{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":". Such notification shall be made as soon as practicable after such identification and in a manner designed to ensure such individual’s comprehension of such notification."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idba123722-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XVIII, § 1899C, as added "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s71201"},"text":"Pub. L. 119–21, title VII, § 71201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/319"},"text":"139 Stat. 319","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idba123723-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idba123724-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idba123725-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Immigration and Nationality Act, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"act June 27, 1952, ch. 477","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/163"},"text":"66 Stat. 163","children":[],"tail":", which is classified principally to chapter 12 (§ 1101 et seq.) of Title 8, Aliens and Nationality. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of Title 8","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 501(e) of the Refugee Education Assistance Act of 1980, referred to in subsec. (a)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/422/s501/e"},"text":"section 501(e) of Pub. L. 96–422","children":[],"tail":", which is set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1522"},"text":"section 1522 of Title 8","children":[],"tail":", Aliens and Nationality."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
