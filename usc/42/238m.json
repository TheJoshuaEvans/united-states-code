{"tag":"section","attrib":{"id":"idb4852a22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s238m"},"text":null,"children":[{"tag":"num","attrib":{"value":"238m"},"text":"§ 238m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of fiscal agents","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4852a23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s238m/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracting authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may enter into contracts with fiscal agents—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4852a24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s238m/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4852a25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s238m/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine the amounts payable to persons who, on behalf of the Indian Health Service, furnish health services to eligible Indians,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4852a26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s238m/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine the amounts payable to persons who, on behalf of the Public Health Service, furnish health services to individuals pursuant to section 247d or 249 of this title,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4852a27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s238m/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to receive, disburse, and account for funds in making payments described in paragraph (1),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4852a28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s238m/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make such audits of records as may be necessary to assure that these payments are proper, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4852a29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s238m/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to perform such additional functions as may be necessary to carry out the functions described in paragraphs (1) through (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4852a2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s238m/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracting prerequisites","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4852a2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s238m/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Contracts under subsection (a) may be entered into without regard to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s6101"},"text":"section 6101 of title 41","children":[],"tail":" or any other provision of law requiring competition."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4852a2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s238m/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No such contract shall be entered into with an entity unless the Secretary finds that the entity will perform its obligations under the contract efficiently and effectively and will meet such requirements as to financial responsibility, legal authority, and other matters as he finds pertinent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4852a2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s238m/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advances under contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A contract under subsection (a) may provide for advances of funds to enable entities to make payments under the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4852a2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s238m/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable statutory provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsections (d) and (e) ","children":[{"tag":"ref","attrib":{"idref":"fn002018"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002018"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395u"},"text":"section 1395u of this title","children":[],"tail":" shall apply to contracts with entities under subsection (a) in the same manner as they apply to contracts with carriers under that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4852a2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s238m/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Fiscal agent” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “fiscal agent” means a carrier described in section 1395u(f)(1) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title and includes, with respect to contracts under subsection (a)(1)(A), an Indian tribe or tribal organization acting under contract with the Secretary under the Indian Self-Determination Act ("},{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Public Law 93–638","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5321"},"text":"25 U.S.C. 5321","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4852a30-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title II, § 244, formerly title XXI, § 2116, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tXVII/s17003"},"text":"Pub. L. 99–272, title XVII, § 17003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/359"},"text":"100 Stat. 359","children":[],"tail":"; renumbered title XXIII, § 2316, "},{"tag":"ref","attrib":{"href":"/us/pl/99/660/tIII/s311/a"},"text":"Pub. L. 99–660, title III, § 311(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3755"},"text":"100 Stat. 3755