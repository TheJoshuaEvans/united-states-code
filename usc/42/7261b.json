{"tag":"section","attrib":{"id":"idbdfe175a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7261b"},"text":null,"children":[{"tag":"num","attrib":{"value":"7261b"},"text":"§ 7261b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technology transfer to small businesses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdfe175b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7261b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Energy shall establish a program to facilitate and encourage the transfer of technology to small businesses and shall issue guidelines relating to the program not later than ","children":[{"tag":"date","attrib":{"date":"1993-05-01"},"text":"May 1, 1993","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdfe175c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7261b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of this section, the term “small business” means a business concern that meets the applicable size standards prescribed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s632/a"},"text":"section 632(a) of title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdfe175d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dC/tXXXI/s3135/b"},"text":"Pub. L. 102–484, div. C, title XXXI, § 3135(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2641"},"text":"106 Stat. 2641","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdfe175e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdfe175f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbdfe1760-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Defense Authorization Act for Fiscal Year 1993, and not as part of the Department of Energy Organization Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
