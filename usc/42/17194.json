{"tag":"section","attrib":{"id":"idc02c1c12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194"},"text":null,"children":[{"tag":"num","attrib":{"value":"17194"},"text":"§ 17194.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhanced geothermal systems research and development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc02c1c13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall support a program of research, development, demonstration, and commercial application for enhanced geothermal systems, including the programs described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02c1c14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhanced geothermal systems technologies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In collaboration with industry partners, institutions of higher education, and the national laboratories, the Secretary shall support a program of research, development, demonstration, and commercial application of the technologies to achieve higher efficiency and lower cost enhanced geothermal systems, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc02c1c15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reservoir stimulation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1c16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" drilled, non-stimulated (e.g. closed-loop) reservoir technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1c17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reservoir characterization, monitoring, and modeling and understanding of the surface area and volume of fractures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1c18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stress and fracture mapping including real time monitoring and modeling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1c19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tracer development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1c1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three and four-dimensional seismic imaging and tomography;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1c1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" well placement and orientation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1c1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" long-term reservoir management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1c1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" drilling technologies, methods, and tools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1c1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improved exploration tools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1c1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" zonal isolation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1c20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" understanding induced seismicity risks from reservoir engineering and stimulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02c1c21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Frontier observatory for research in geothermal energy","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc02c1c22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall support the establishment and construction of up to 3 field research sites, which shall each be known as a “Frontier Observatory for Research in Geothermal Energy” or “FORGE” site to develop, test, and enhance techniques and tools for enhanced geothermal energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1c23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02c1c24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide financial assistance in support of research and development projects focused on advanced monitoring technologies, new technologies and approaches for implementing multi-zone stimulations, nonstimulation techniques, and dynamic reservoir modeling that incorporates all available high-fidelity characterization data; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1c25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek opportunities to coordinate efforts and share information with domestic and international partners engaged in research and development of geothermal systems and related technology, including coordination between FORGE sites.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1c26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Site selection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the FORGE sites referred to in paragraph (1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02c1c27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider applications through a competitive, merit-reviewed process, from National Laboratories, multi-institutional collaborations, institutes of higher education and other appropriate entities best suited to provide national leadership on geothermal related issues and perform the duties enumerated under this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1c28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prioritize existing field sites and facilities with capabilities relevant to the duties enumerated under this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1c29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the mission need for and potential location of subsequent FORGE sites following the completion of construction and one year of operation of two FORGE sites; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1c2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure geologic diversity among FORGE sites when developing subsequent sites, to the maximum extent practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1c2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing forge sites","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A FORGE site already in existence on ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", may continue to receive support."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1c2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Site operation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02c1c2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"FORGE sites selected under paragraph (3) shall operate for an initial term of not more than 7 years after the date on which site operation begins.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1c2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance metrics","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish performance metrics for each FORGE site supported under this paragraph, which may be used by the Secretary to determine whether a FORGE site should continue to receive funding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1c2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional terms","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02c1c30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At the end of an operational term described in subparagraph (B), a FORGE site may—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc02c1c31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/c/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be transferred to other public or private entities for further enhanced geothermal testing; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc02c1c32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/c/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to appropriations and a merit review by the Secretary, operate for an additional term of not more than 7 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1c33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operational term described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An operational term referred to in subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc02c1c34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/c/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an existing FORGE site, is the existing operational term; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc02c1c35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/c/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of new FORGE sites selected under paragraph (3), is the initial term under paragraph (5)(A) or an additional term under subparagraph (A)(ii) of this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1c36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02c1c37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/c/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Out of funds authorized to be appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17202"},"text":"section 17202 of this title","children":[],"tail":", there shall be made available to the Secretary to carry out the FORGE activities under this paragraph—"}],"tail":null},{"tag":"clause","attrib":{"id":"idc02c1c38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/c/7/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $45,000,000 for fiscal year 2021;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc02c1c39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/c/7/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $55,000,000 for fiscal year 2022;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc02c1c3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/c/7/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $65,000,000 for fiscal year 2023;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc02c1c3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/c/7/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $70,000,000 for fiscal year 2024; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc02c1c3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/c/7/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $70,000,000 for fiscal year 2025.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1c3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/c/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this subsection, the Secretary shall consider the balance between funds dedicated to construction and operations and research activities to reflect the state of site development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02c1c3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhanced geothermal systems demonstrations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc02c1c3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning on ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary, in collaboration with industry partners, institutions of higher education, and the national laboratories, shall support an initiative for demonstration of enhanced geothermal systems for power production or direct use."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1c40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02c1c41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under the initiative described in paragraph (1), 4 demonstration projects shall be carried out in locations that are potentially commercially viable for enhanced geothermal systems development, while also considering environmental impacts to the maximum extent practicable, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1c42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Demonstration projects under subparagraph (A) shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc02c1c43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" collectively demonstrate—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc02c1c44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/d/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" different geologic settings, such as hot sedimentary aquifers, layered geologic systems, supercritical systems, and basement rock systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc02c1c45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/d/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a variety of development techniques, including open hole and cased hole completions, differing well orientations, and stimulation and nonstimulation mechanisms; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc02c1c46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, use existing sites where subsurface characterization or geothermal energy integration analysis has been conducted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1c47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eastern demonstration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not fewer than 1 of the demonstration projects carried out under subparagraph (A) shall be located an area east of the Mississippi River that is suitable for enhanced geothermal demonstration for power, heat, or a combination of power and heat.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1c48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Milestone-based demonstration projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may carry out demonstration projects under this subsection as a milestone-based demonstration project under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7256c"},"text":"section 7256c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1c49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17194/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Out of funds authorized to be appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17202"},"text":"section 17202 of this title","children":[],"tail":", there shall be made available to the Secretary to carry out the demonstration activities under this subsection $21,000,000 for each of fiscal years 2021 through 2025."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc02c1c4a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tVI/s615"},"text":"Pub. L. 110–140, title VI, § 615","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1680"},"text":"121 Stat. 1680","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tIII/s3002/d"},"text":"Pub. L. 116–260, div. Z, title III, § 3002(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2489"},"text":"134 Stat. 2489","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc02c1c4b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc02c1c4c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc02c1c4d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", referred to in subsecs. (c)(4) and (d)(1), was in the original “the date of enactment of this Act” and “he date of enactment of this section”, respectively, and were translated as meaning the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc02c1c4e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" amended section generally. Prior to amendment, section related to enhanced geothermal systems research and development."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc02c1c4f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc02c1c50-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
