{"tag":"section","attrib":{"id":"idbfee27f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962"},"text":null,"children":[{"tag":"num","attrib":{"value":"15962"},"text":"§ 15962.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project criteria","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfee27f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive assistance under this part, a project shall advance efficiency, environmental performance, and cost competitiveness well beyond the level of technologies that are in commercial service or have been demonstrated on a scale that the Secretary determines is sufficient to demonstrate that commercial service is viable as of ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee27f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical criteria for clean coal power initiative","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfee27f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gasification projects","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfee27f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In allocating the funds made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15961/a"},"text":"section 15961(a) of this title","children":[],"tail":", the Secretary shall ensure that at least 70 percent of the funds are used only to fund projects on coal-based gasification technologies, including—"}],"tail":null},{"tag":"clause","attrib":{"id":"idbfee27f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gasification combined cycle;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfee27f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gasification fuel cells and turbine combined cycle;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfee27fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gasification coproduction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfee27fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hybrid gasification and combustion; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfee27fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other advanced coal based technologies capable of producing a concentrated stream of carbon dioxide.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfee27fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical milestones","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfee27fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic determination","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbfee27ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall periodically set technical milestones specifying the emission and thermal efficiency levels that coal gasification projects under this part shall be designed, and reasonably expected, to achieve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbfee2800-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prescriptive milestones","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The technical milestones shall become more prescriptive during the period of the clean coal power initiative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfee2801-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 2020 goals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish the periodic milestones so as to achieve by the year 2020 coal gasification projects able—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbfee2802-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"item","attrib":{"id":"idbfee2803-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/1/B/ii/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to remove at least 99 percent of sulfur dioxide; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idbfee2804-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/1/B/ii/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to emit not more than 0.04 pound SO","children":[{"tag":"sub","attrib":{},"text":"2","children":[],"tail":" per million Btu, based on a 30-day average;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbfee2805-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to emit not more than .05 lbs of NO","children":[{"tag":"sub","attrib":{},"text":"x","children":[],"tail":" per million Btu;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbfee2806-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/1/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to achieve at least 95 percent reductions in mercury emissions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbfee2807-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/1/B/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to achieve a thermal efficiency of at least—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idbfee2808-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/1/B/ii/IV/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent for coal of more than 9,000 Btu;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idbfee2809-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/1/B/ii/IV/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 48 percent for coal of 7,000 to 9,000 Btu; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idbfee280a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/1/B/ii/IV/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 46 percent for coal of less than 7,000 Btu.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee280b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other projects","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfee280c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that up to 30 percent of the funds made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15961/a"},"text":"section 15961(a) of this title","children":[],"tail":" are used to fund projects other than those described in paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfee280d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical milestones","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfee280e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic determination","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbfee280f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall periodically establish technical milestones specifying the emission and thermal efficiency levels that projects funded under this paragraph shall be designed, and reasonably expected, to achieve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbfee2810-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prescriptive milestones","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The technical milestones shall become more prescriptive during the period of the clean coal power initiative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfee2811-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 2020 goals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall set the periodic milestones so as to achieve by the year 2020 projects able—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbfee2812-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to remove at least 97 percent of sulfur dioxide;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbfee2813-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to emit no more than .08 lbs of NO","children":[{"tag":"sub","attrib":{},"text":"x","children":[],"tail":" per million Btu;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbfee2814-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/2/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to achieve at least 90 percent reductions in mercury emissions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbfee2815-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/2/B/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to achieve a thermal efficiency of at least—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idbfee2816-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/2/B/ii/IV/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 43 percent for coal of more than 9,000 Btu;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idbfee2817-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/2/B/ii/IV/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 41 percent for coal of 7,000 to 9,000 Btu; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idbfee2818-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/2/B/ii/IV/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 39 percent for coal of less than 7,000 Btu.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee2819-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before setting the technical milestones under paragraphs (1)(B) and (2)(B), the Secretary shall consult with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfee281a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Environmental Protection Agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfee281b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" interested entities, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfee281c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coal producers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfee281d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" industries using coal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfee281e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organizations that promote coal or advanced coal technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfee281f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfee2820-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organizations representing workers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfee2821-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/3/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organizations representing consumers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee2822-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing units","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of projects at units in existence on ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", in lieu of the thermal efficiency requirements described in paragraphs (1)(B)(ii)(IV) and (2)(B)(ii)(IV), the milestones shall be designed to achieve an overall thermal design efficiency improvement, compared to the efficiency of the unit as operated, of not less than—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfee2823-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 7 percent for coal of more than 9,000 Btu;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfee2824-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 6 percent for coal of 7,000 to 9,000 Btu; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfee2825-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4 percent for coal of less than 7,000 Btu.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee2826-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfee2827-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elevation of site","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In evaluating project proposals to achieve thermal efficiency levels established under paragraphs (1)(B)(i) and (2)(B)(i) and in determining progress towards thermal efficiency milestones under paragraphs (1)(B)(ii)(IV), (2)(B)(ii)(IV), and (4), the Secretary shall take into account and make adjustments for the elevation of the site at which a project is proposed to be constructed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfee2828-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of milestones","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In applying the thermal efficiency milestones under paragraphs (1)(B)(ii)(IV), (2)(B)(ii)(IV), and (4) to projects that separate and capture at least 50 percent of the potential emissions of carbon dioxide by a facility, the energy used for separation and capture of carbon dioxide shall not be counted in calculating the thermal efficiency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfee2829-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permitted uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary may give priority to projects that include, as part of the project—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfee282a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/5/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the separation or capture of carbon dioxide; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfee282b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/b/5/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reduction of the demand for natural gas if deployed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee282c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall not provide financial assistance under this part for a project unless the recipient documents to the satisfaction of the Secretary that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfee282d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recipient is financially responsible;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee282e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recipient will provide sufficient information to the Secretary to enable the Secretary to ensure that the funds are spent efficiently and effectively; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee282f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a market exists for the technology being demonstrated or applied, as evidenced by statements of interest in writing from potential purchasers of the technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee2830-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide financial assistance to projects that, as determined by the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfee2831-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet the requirements of subsections (a), (b), and (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee2832-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" are likely—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfee2833-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to achieve overall cost reductions in the use of coal to generate useful forms of energy or chemical feedstocks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfee2834-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve the competitiveness of coal among various forms of energy in order to maintain a diversity of fuel choices in the United States to meet electricity generation requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfee2835-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to demonstrate methods and equipment that are applicable to 25 percent of the electricity generating facilities, using various types of coal, that use coal as the primary feedstock as of ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee2836-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this part, the Secretary shall require cost sharing in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16352"},"text":"section 16352 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee2837-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scheduled completion of selected projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfee2838-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In selecting a project for financial assistance under this section, the Secretary shall establish a reasonable period of time during which the owner or operator of the project shall complete the construction or demonstration phase of the project, as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee2839-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Condition of financial assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require as a condition of receipt of any financial assistance under this part that the recipient of the assistance enter into an agreement with the Secretary not to request an extension of the time period established for the project by the Secretary under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee283a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of time period","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfee283b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), the Secretary may extend the time period established under paragraph (1) if the Secretary determines, in the sole discretion of the Secretary, that the owner or operator of the project cannot complete the construction or demonstration phase of the project within the time period due to circumstances beyond the control of the owner or operator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfee283c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not extend a time period under subparagraph (A) by more than 4 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee283d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fee title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may vest fee title or other property interests acquired under cost-share clean coal power initiative agreements under this part in any entity, including the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee283e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data protection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For a period not exceeding 5 years after completion of the operations phase of a cooperative agreement, the Secretary may provide appropriate protections (including exemptions from subchapter II of chapter 5 of title 5) against the dissemination of information that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfee283f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" results from demonstration activities carried out under the clean coal power initiative program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee2840-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would be a trade secret or commercial or financial information that is privileged or confidential if the information had been obtained from and first produced by a non-Federal party participating in a clean coal power initiative project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee2841-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No technology, or level of emission reduction, solely by reason of the use of the technology, or the achievement of the emission reduction, by 1 or more facilities receiving assistance under this Act, shall be considered to be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfee2842-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequately demonstrated for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7411"},"text":"section 7411 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee2843-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achievable for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7479"},"text":"section 7479 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee2844-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15962/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achievable in practice for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7501"},"text":"section 7501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfee2845-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIV/s402"},"text":"Pub. L. 109–58, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/750"},"text":"119 Stat. 750","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tVI/s653"},"text":"Pub. L. 110–140, title VI, § 653","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1695"},"text":"121 Stat. 1695","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfee2846-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfee2847-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfee2848-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (i), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/594"},"text":"119 Stat. 594","children":[],"tail":", known as the Energy Policy Act of 2005, which enacted this chapter and enacted, amended, and repealed numerous other sections and notes in the Code. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s15801"},"text":"section 15801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbfee2849-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (b)(1)(B)(ii)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":" added subcl. (I) and struck out former subcl. (I) which read as follows: “to remove at least 99 percent of sulfur dioxide;”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbfee284a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbfee284b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":" effective on the date that is 1 day after "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
