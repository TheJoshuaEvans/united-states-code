{"tag":"section","attrib":{"id":"idba60f3b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396h"},"text":null,"children":[{"tag":"num","attrib":{"value":"1396h"},"text":"§ 1396h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State false claims act requirements for increased State share of recoveries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idba60f3b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396d/b"},"text":"section 1396d(b) of this title","children":[],"tail":", if a State has in effect a law relating to false or fraudulent claims that meets the requirements of subsection (b), the Federal medical assistance percentage with respect to any amounts recovered under a State action brought under such law, shall be decreased by 10 percentage points."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba60f3b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a), the requirements of this subsection are that the Inspector General of the Department of Health and Human Services, in consultation with the Attorney General, determines that the State has in effect a law that meets the following requirements:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idba60f3b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The law establishes liability to the State for false or fraudulent claims described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3729"},"text":"section 3729 of title 31","children":[],"tail":" with respect to any expenditure described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396b/a"},"text":"section 1396b(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba60f3b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The law contains provisions that are at least as effective in rewarding and facilitating qui tam actions for false or fraudulent claims as those described in sections 3730 through 3732 of title 31.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba60f3b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396h/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The law contains a requirement for filing an action under seal for 60 days with review by the State Attorney General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idba60f3ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396h/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The law contains a civil penalty that is not less than the amount of the civil penalty authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3729"},"text":"section 3729 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba60f3bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396h/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deemed compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State that, as of ","children":[{"tag":"date","attrib":{"date":"2007-01-01"},"text":"January 1, 2007","children":[],"tail":", has a law in effect that meets the requirements of subsection (b) shall be deemed to be in compliance with such requirements for so long as the law continues to meet such requirements."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idba60f3bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396h/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No preclusion of broader laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed as prohibiting a State that has in effect a law that establishes liability to the State for false or fraudulent claims described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3729"},"text":"section 3729 of title 31","children":[],"tail":", with respect to programs in addition to the State program under this subchapter, or with respect to expenditures in addition to expenditures described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396b/a"},"text":"section 1396b(a) of this title","children":[],"tail":", from being considered to be in compliance with the requirements of subsection (a) so long as the law meets such requirements."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idba60f3bd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XIX, § 1909, as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/171/tVI/s6031/a"},"text":"Pub. L. 109–171, title VI, § 6031(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-02-08"},"text":"Feb. 8, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/72"},"text":"120 Stat. 72","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idba60f3be-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idba60f3bf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idba60f3c0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1396h, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531/tXIX/s1909"},"text":"act Aug. 14, 1935, ch. 531, title XIX, § 1909","children":[],"tail":", as added and amended "},{"tag":"date","attrib":{"date":"1972-10-30"},"text":"Oct. 30, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/92/603/tII"},"text":"Pub. L. 92–603, title II","children":[],"tail":", §§ 242(c), 278(b)(9), "},{"tag":"ref","attrib":{"href":"/us/stat/86/1419"},"text":"86 Stat. 1419","children":[],"tail":", 1454; "},{"tag":"date","attrib":{"date":"1977-10-25"},"text":"Oct. 25, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/95/142/s4/b"},"text":"Pub. L. 95–142, § 4(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1181"},"text":"91 Stat. 1181","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1980-12-05"},"text":"Dec. 5, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"