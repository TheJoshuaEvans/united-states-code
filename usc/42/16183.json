{"tag":"section","attrib":{"id":"idbff79e53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183"},"text":null,"children":[{"tag":"num","attrib":{"value":"16183"},"text":"§ 16183.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy and water for sustainability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbff79e54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nexus of energy and water for sustainability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff79e55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff79e56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Department” means the Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79e57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy-water nexus","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “energy-water nexus” means the links between—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff79e58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the water needed to produce fuels, electricity, and other forms of energy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff79e59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the energy needed to transport, reclaim, and treat water and wastewater.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79e5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency RD&D Coordination Committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Interagency RD&D Coordination Committee” means the Interagency RD&D Coordination Committee on the Nexus of Energy and Water for Sustainability (or the “NEWS RD&D Committee”) established under paragraph (3)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79e5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nexus of Energy and Water Sustainability RD&D Office; NEWS RD&D Office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Nexus of Energy and Water Sustainability RD&D Office” or the “NEWS RD&D Office” means an office located at the Department and managed in cooperation with the Department of the Interior pursuant to an agreement between the 2 agencies to carry out leadership and administrative functions for the Interagency RD&D Coordination Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79e5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" RD&D","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “RD&D” means research, development, and demonstration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79e5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79e5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Recognizing States’ primacy over allocation and administration of water resources (except in specific instances where preempted under Federal law) and the siting of energy infrastructure within State boundaries on non-Federal lands, it is the national policy that the Federal government, in all energy-water nexus management activities, shall maximize coordination and consultation among Federal agencies and with State and local governments, and disseminate information to the public in the most effective manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79e5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency RD&D Coordination Committee","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff79e60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary and the Secretary of the Interior shall establish the joint NEWS RD&D Office and Interagency RD&D Coordination Committee on the Nexus of Energy and Water for Sustainability (or the “NEWS RD&D Committee”) to carry out the duties described in subparagraph (C)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79e61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff79e62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the Secretary of the Interior shall jointly manage the NEWS RD&D Office and serve as co-chairs of the Interagency RD&D Coordination Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff79e63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership; staffing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Membership and staffing shall be determined by the co-chairs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79e64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Interagency RD&D Coordination Committee shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff79e65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as a forum for developing common Federal goals and plans on energy-water nexus RD&D activities, in coordination with the National Science and Technology Council;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff79e66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", and biennially thereafter, issue a strategic plan on energy-water nexus RD&D activities, priorities, and objectives pursuant to subparagraph (D), which shall be developed in consultation with relevant State and local governments;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff79e67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" convene and promote coordination of RD&D activities of relevant Federal departments and agencies on energy-water nexus;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff79e68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/3/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbff79e69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/3/C/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate and develop capabilities and methodologies related to RD&D activities for data collection, data communication protocols (including models and modeling results), data management, and dissemination of validated data and results related to energy-water nexus RD&D activities to requesting Federal departments and agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbff79e6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/3/C/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" promote information exchange between Federal departments and agencies—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idbff79e6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/3/C/iv/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify and document Federal and non-Federal RD&D programs and funding opportunities that support basic and applied RD&D proposals to advance energy-water nexus related science and technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idbff79e6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/3/C/iv/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to leverage existing RD&D programs by encouraging joint solicitations, block grants, and matching programs with non-Federal entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idbff79e6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/3/C/iv/II/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify opportunities for domestic and international public-private partnerships, innovative financing mechanisms, and information and data exchange with respect to RD&D activities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff79e6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/3/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify ways to leverage existing RD&D programs, including programs at the State and local level;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff79e6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/3/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make publicly available the results of RD&D activities on the energy water nexus;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff79e70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/3/C/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with regard to RD&D programs, recommend improvements and best practices for the collection and dissemination of federal water use data and the use of monitoring networks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff79e71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/3/C/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" promote coordination on RD&D with non-Federal interests by—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbff79e72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/3/C/viii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consulting with representatives of research and academic institutions, State, local, and Tribal governments, public utility commissions, and industry, who have expertise in technologies, technological innovations, or practices relating to the energy-water nexus; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbff79e73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/3/C/viii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considering conducting technical workshops.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79e74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategic plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the strategic plan pursuant to (C)(ii), the Interagency RD&D Coordination Committee shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff79e75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent possible, avoid duplication with other Federal RD&D programs, and projects, including with those of the National Laboratories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff79e76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consider inclusion of specific research, development and demonstration needs, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbff79e77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/3/D/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" innovative practices, technologies and other advancements improving water efficiency, treatment, recovery, or reuse associated with energy generation, including cooling, and fuel production;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbff79e78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/3/D/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" innovative practices, technologies and other advancements associated with energy use in water collection, supply, delivery, distribution, treatment, or reuse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbff79e79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/3/D/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" innovative practices, technologies and other advancements associated with generation or production of energy from water or wastewater systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbff79e7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/3/D/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modeling and systems analysis related to energy-water nexus; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff79e7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/3/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit the plan to the Committee on Energy and Natural Resources of the Senate and the Committees on Science, Space, and Technology, Energy and Commerce, and Natural Resources of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79e7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules of construction","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff79e7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/3/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this section grants to the Interagency RD&D Coordination Committee the authority to promulgate regulations or set standards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff79e7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/3/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, nothing in this section shall be construed to require State, Tribal, or local governments to take any action that may result in an increased financial burden to such governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79e7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing the strategic plan described in subparagraph (C)(ii), the Secretary shall consult and coordinate with a diverse group of representatives from research and academic institutions, industry, public utility commissions, and State and local governments who have expertise in technologies and practices relating to the energy-water nexus.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79e80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review; report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At the end of the 5-year period beginning on the date on which the Interagency RD&D Coordination Committee and NEWS RD&D Office are established, the NEWS RD&D Office shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff79e81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/3/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the activities, relevance, and effectiveness of the Interagency RD&D Coordination Committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff79e82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/3/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit to the Committee on Energy and Natural Resources of the Senate and the Committees on Science, Space, and Technology, Energy and Commerce, and Natural Resources of the House of Representatives a report that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbff79e83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/3/G/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the results of the review conducted under clause (i); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbff79e84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/3/G/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a recommendation on whether the Interagency RD&D Coordination Committee should continue.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79e85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crosscut budget","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after the President submits the budget of the United States Government under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":", the co-chairs of the Interagency RD&D Coordination Committee (acting through the NEWS RD&D Office) shall submit to the Committee on Energy and Natural Resources of the Senate and the Committees on Science, Space, and Technology, Energy and Commerce, and Natural Resources of the House of Representatives, an interagency budget crosscut report that displays at the program-, project-, and activity-level for each of the Federal agencies that carry out or support (including through grants, contracts, interagency and intraagency transfers, and multiyear and no-year funds) basic and applied RD&D activities to advance the energy-water nexus related science and technologies, including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff79e86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the budget proposed in the budget request of the President for the upcoming fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79e87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expenditures and obligations for the prior fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79e88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimated expenditures and obligations for the current fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79e89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff79e8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority provided to the NEWS RD&D Office and NEWS RD&D Committee under this subsection shall terminate on the date that is 7 years after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79e8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The termination of authority under subparagraph (A) shall not affect ongoing interagency planning, coordination, or other RD&D activities relating to the energy-water nexus.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff79e8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integrating energy and water research","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall integrate the following considerations into energy RD&D programs and projects of the Department by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff79e8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" advancing RD&D for energy and energy efficiency technologies and practices that meet the objectives of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff79e8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimizing freshwater withdrawal and consumption;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79e8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing water use efficiency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79e90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilizing nontraditional water sources;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79e91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considering the effects climate variability may have on water supplies and quality for energy generation and fuel production; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79e92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving understanding of the energy-water nexus (as defined in subsection (a)(1)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff79e93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16183/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide for such additional RD&D activities as appropriate to integrate the considerations described in subsection (b) into the RD&D activities of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff79e94-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tI/s1010"},"text":"Pub. L. 116–260, div. Z, title I, § 1010","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2438"},"text":"134 Stat. 2438","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbff79e95-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbff79e96-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbff79e97-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy Act of 2020, and not as part of the Energy Policy Act of 2005 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
