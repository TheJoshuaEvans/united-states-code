{"tag":"section","attrib":{"id":"idbaad3f51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"1397m–2"},"text":"§ 1397m–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Long-term care ombudsman program grants and training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbaad3f52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to support the long-term care ombudsman program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaad3f53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make grants to eligible entities with relevant expertise and experience in abuse and neglect in long-term care facilities or long-term care ombudsman programs and responsibilities, for the purpose of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaad3f54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m–2/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the capacity of State long-term care ombudsman programs to respond to and resolve complaints about abuse and neglect;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaad3f55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m–2/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting pilot programs with State long-term care ombudsman offices or local ombudsman entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaad3f56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m–2/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing support for such State long-term care ombudsman programs and such pilot programs (such as through the establishment of a national long-term care ombudsman resource center).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaad3f57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaad3f58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m–2/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2011, $5,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaad3f59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m–2/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2012, $7,500,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaad3f5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m–2/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each of fiscal years 2013 and 2014, $10,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaad3f5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ombudsman training programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaad3f5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish programs to provide and improve ombudsman training with respect to elder abuse, neglect, and exploitation for national organizations and State long-term care ombudsman programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaad3f5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this subsection, for each of fiscal years 2011 through 2014, $10,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbaad3f5e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XX, § 2043, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tVI/s6703/a/1/C"},"text":"Pub. L. 111–148, title VI, § 6703(a)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/796"},"text":"124 Stat. 796","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
