{"tag":"section","attrib":{"id":"idbf17774d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10191"},"text":null,"children":[{"tag":"num","attrib":{"value":"10191"},"text":"§ 10191.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf17774e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10191/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide direction to the Secretary with respect to the disposal of high-level radioactive waste and spent nuclear fuel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf17774f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10191/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to authorize the Secretary, pursuant to this subchapter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf177750-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10191/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide for the construction, operation, and maintenance of a deep geologic test and evaluation facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf177751-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10191/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide for a focused and integrated high-level radioactive waste and spent nuclear fuel research and development program, including the development of a test and evaluation facility to carry out research and provide an integrated demonstration of the technology for deep geologic disposal of high-level radioactive waste, and the development of the facilities to demonstrate dry storage of spent nuclear fuel; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf177752-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10191/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide for an improved cooperative role between the Federal Government and States, affected Indian tribes, and units of general local government in the siting of a test and evaluation facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf177753-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/425/tII/s211"},"text":"Pub. L. 97–425, title II, § 211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-07"},"text":"Jan. 7, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2245"},"text":"96 Stat. 2245","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
