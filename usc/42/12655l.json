{"tag":"section","attrib":{"id":"idbf9385ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655l"},"text":null,"children":[{"tag":"num","attrib":{"value":"12655l"},"text":"§ 12655l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Living allowance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf9385ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655l/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full-time service","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf9385ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655l/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Living allowance required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (3), each participant in a full-time youth corps program that receives assistance under this division shall receive a living allowance in an amount equal to or greater than the average annual subsistence allowance provided to VISTA volunteers under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4955"},"text":"section 4955 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9385af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655l/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the annual living allowance provided under paragraph (1) that may be paid using assistance provided under this division, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12571"},"text":"section 12571 of this title","children":[],"tail":", and any other Federal funds shall not exceed 85 percent of the total average annual subsistence allowance provided to VISTA volunteers under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4955"},"text":"section 4955 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9385b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655l/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum living allowance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total amount of an annual living allowance that may be provided to a participant in a full-time youth corps program that receives assistance under this division shall not exceed 200 percent of the average annual subsistence allowance provided to VISTA volunteers under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4955"},"text":"section 4955 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9385b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655l/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver or reduction of living allowance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corporation may waive or reduce the requirement of paragraph (1) with respect to such national service program if such program demonstrates that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf9385b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655l/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such requirement is inconsistent with the objectives of the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf9385b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655l/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the living allowance that will be provided to each full-time participant is sufficient to meet the necessary costs of living (including food, housing, and transportation) in the area in which the program is located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9385b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655l/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirement of paragraph (1) shall not apply to any program that was in existence on ","children":[{"tag":"date","attrib":{"date":"1993-09-21"},"text":"September 21, 1993","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf9385b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655l/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction in existing program benefits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf9385b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655l/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to require a program in existence on ","children":[{"tag":"date","attrib":{"date":"1990-11-16"},"text":"November 16, 1990","children":[],"tail":", to decrease any stipends, salaries, or living allowances provided to participants under such program so long as the amount of any such stipends, salaries, or living allowances that is in excess of the levels provided for in this section are paid from non-Federal sources."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9385b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655l/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fair Labor Standards Act of 1938","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of the Fair Labor Standards Act of 1938 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s201"},"text":"29 U.S.C. 201","children":[],"tail":" et seq.], residential youth corps programs under this division will be considered an organized camp."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf9385b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655l/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health insurance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the living allowance provided under subsection (a), program agencies are encouraged to provide health insurance to each participant in a full-time youth corps program who does not otherwise have access to health insurance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf9385b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655l/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilities, services, and supplies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf9385ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655l/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program agency may deduct, from amounts provided under subsection (a) to a participant, a reasonable portion of the costs of the rates for any room and board that is provided for such participant at a residential facility. Such deducted funds shall be deposited into rollover accounts that shall be used solely to defray the costs of room and board for participants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9385bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655l/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program agency shall establish the amount of the deductions and rates under paragraph (1) after evaluating the costs of providing such room and board to the participant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9385bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655l/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of program agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A program agency may provide facilities, quarters, and board and shall provide limited and emergency medical care, transportation from administrative facilities to work sites, accommodations for individuals with disabilities, and other appropriate services, supplies, and equipment to each participant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9385bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655l/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other Federal agencies","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf9385be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655l/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation may provide services, facilities, supplies, and equipment, including any surplus food and equipment available from other Federal programs, to any program agency carrying out projects under this division.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf9385bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655l/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary of Defense","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever possible, the Corporation shall make arrangements with the Secretary of Defense to have logistical support provided by a military installation near the work site, including the provision of temporary tent centers where needed, and other supplies and equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9385c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655l/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health and safety standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation and program agencies shall establish standards and enforcement procedures concerning the health and safety of participants for all projects, consistent with Federal, State, and local health and safety standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf9385c1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s199K"},"text":"Pub. L. 101–610, title I, § 199K","children":[],"tail":", formerly § 133, "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3147"},"text":"104 Stat. 3147","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/10/s5/6"},"text":"Pub. L. 102–10, § 5(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-03-12"},"text":"Mar. 12, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/30"},"text":"105 Stat. 30","children":[],"tail":"; renumbered § 199M, renumbered § 199K, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s101/a"},"text":"Pub. L. 103–82, title I, § 101(a)","children":[],"tail":", (d), (e)(1), (8)(B), "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/788"},"text":"107 Stat. 788","children":[],"tail":", 814–816.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf9385c2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf9385c3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf9385c4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Fair Labor Standards Act of 1938, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch676"},"text":"act June 25, 1938, ch. 676","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1060"},"text":"52 Stat. 1060","children":[],"tail":", which is classified principally to chapter 8 (§ 201 et seq.) of Title 29, Labor. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s201"},"text":"section 201 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf9385c5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12553"},"text":"section 12553 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s101/a"},"text":"Pub. L. 103–82, § 101(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf9385c6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s101/d"},"text":"Pub. L. 103–82, § 101(d)","children":[],"tail":", added pars. (1) to (5) and struck out former pars. (1) and (2) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—From assistance provided under this part, each participant in a full-time youth corps program that receives assistance under this part shall receive a living allowance of not more than an amount equal to 100 percent of the poverty line for a family of two (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9902/2"},"text":"section 9902(2) of this title","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Non-federal sources","children":[],"tail":".—Notwithstanding paragraph (1), a program agency may provide participants with additional amounts that are made available from non-Federal sources.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4)(A), (B), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s101/e/1"},"text":"Pub. L. 103–82, § 101(e)(1)","children":[],"tail":", substituted “Corporation” for “Commission”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/10"},"text":"Pub. L. 102–10","children":[],"tail":" substituted “subsection (a)” for “subsections (a) and (c)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf9385c7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf9385c8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82"},"text":"Pub. L. 103–82","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1993-10-01"},"text":"Oct. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s123"},"text":"section 123 of Pub. L. 103–82","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1701"},"text":"section 1701 of Title 16","children":[],"tail":", Conservation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
