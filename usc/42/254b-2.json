{"tag":"section","attrib":{"id":"idb4e487ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254b–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"254b–2"},"text":"§ 254b–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community health centers and the National Health Service Corps Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4e487ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254b–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the purpose of this section to establish a Community Health Center Fund (referred to in this section as the “CHC Fund”), to be administered through the Office of the Secretary of the Department of Health and Human Services to provide for expanded and sustained national investment in community health centers under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254b"},"text":"section 254b of this title","children":[],"tail":" and the National Health Service Corps."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e487ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254b–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is authorized to be appropriated, and there is appropriated, out of any monies in the Treasury not otherwise appropriated, to the CHC Fund—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4e487ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254b–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to be transferred to the Secretary of Health and Human Services to provide enhanced funding for the community health center program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254b"},"text":"section 254b of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4e487f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254b–2/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000,000,000 for fiscal year 2011;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e487f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254b–2/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,200,000,000 for fiscal year 2012;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e487f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254b–2/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,500,000,000 for fiscal year 2013;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e487f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254b–2/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,200,000,000 for fiscal year 2014;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e487f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254b–2/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $3,600,000,000 for each of fiscal years 2015 through 2017;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"