attrib":{},"text":" $349,736,600 for fiscal year 2025;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e48806-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254b–2/b/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $350,000,000 for fiscal year 2026; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e48807-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254b–2/b/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $88,219,178 for the period beginning on ","children":[{"tag":"date","attrib":{"date":"2026-10-01"},"text":"October 1, 2026","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2026-12-31"},"text":"December 31, 2026","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e48808-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254b–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated, and there is appropriated, out of any monies in the Treasury not otherwise appropriated, $1,500,000,000 to be available for fiscal years 2011 through 2015 to be used by the Secretary of Health and Human Services for the construction and renovation of community health centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e48809-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254b–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services shall transfer amounts in the CHC Fund to accounts within the Department of Health and Human Services to increase funding, over the fiscal year 2008 level, for community health centers and the National Health Service Corps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e4880a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254b–2/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts appropriated under subsections (b) and (c) shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4e4880b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10503"},"text":"Pub. L. 111–148, title X, § 10503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1004"},"text":"124 Stat. 1004","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/152/tII/s2303"},"text":"Pub. L. 111–152, title II, § 2303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-30"},"text":"Mar. 30, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1083"},"text":"124 Stat. 1083","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/10/tII/s221/a"},"text":"Pub. L. 114–10, title II, § 221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-04-16"},"text":"Apr. 16, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat