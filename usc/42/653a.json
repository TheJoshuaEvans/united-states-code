{"tag":"section","attrib":{"id":"idb7b227a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a"},"text":null,"children":[{"tag":"num","attrib":{"value":"653a"},"text":"§ 653a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State Directory of New Hires","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7b227a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7b227aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7b227ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement for States that have no directory","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), not later than ","children":[{"tag":"date","attrib":{"date":"1997-10-01"},"text":"October 1, 1997","children":[],"tail":", each State shall establish an automated directory (to be known as the “State Directory of New Hires”) which shall contain information supplied in accordance with subsection (b) by employers on each newly hired employee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7b227ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" States with new hire reporting law in existence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State which has a new hire reporting law in existence on ","children":[{"tag":"date","attrib":{"date":"1996-08-22"},"text":"August 22, 1996","children":[],"tail":", may continue to operate under the State law, but the State must meet the requirements of subsection (g)(2) not later than "},{"tag":"date","attrib":{"date":"1997-10-01"},"text":"October 1, 1997","children":[],"tail":", and the requirements of this section (other than subsection (g)(2)) not later than "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"October 1, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b227ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7b227ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “employee”—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7b227af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means an individual who is an employee within the meaning of chapter 24 of the Internal Revenue Code of 1986; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7b227b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include an employee of a Federal or State agency performing intelligence or counterintelligence functions, if the head of such agency has determined that reporting pursuant to paragraph (1) with respect to the employee could endanger the safety of the employee or compromise an ongoing investigation or intelligence mission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7b227b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employer","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7b227b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “employer” has the meaning given such term in section 3401(d) of the Internal Revenue Code of 1986 and includes any governmental entity and any labor organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7b227b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Labor organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “labor organization” shall have the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s152/5"},"text":"section 152(5) of title 29","children":[],"tail":", and includes any entity (also known as a “hiring hall”) which is used by the organization and an employer to carry out requirements described in "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s158/f/3"},"text":"section 158(f)(3) of title 29","children":[],"tail":" of an agreement between the organization and the employer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7b227b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Newly hired employee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “newly hired employee” means an employee who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7b227b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not previously been employed by the employer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7b227b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was previously employed by the employer but has been separated from such prior employment for at least 60 consecutive days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7b227b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employer information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7b227b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7b227b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraphs (B) and (C), each employer shall furnish to the Directory of New Hires of the State in which a newly hired employee works, a report that contains the name, address, and social security number of the employee, the date services for remuneration were first performed by the employee, and the name and address of, and identifying number assigned under section 6109 of the Internal Revenue Code of 1986 to, the employer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7b227ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multistate employers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An employer that has employees who are employed in 2 or more States and that transmits reports magnetically or electronically may comply with subparagraph (A) by designating 1 State in which such employer has employees to which the employer will transmit the report described in subparagraph (A), and transmitting such report to such State. Any employer that transmits reports pursuant to this subparagraph shall notify the Secretary in writing as to which State such employer designates for the purpose of sending reports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7b227bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Government employers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any department, agency, or instrumentality of the United States shall comply with subparagraph (A) by transmitting the report described in subparagraph (A) to the National Directory of New Hires established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s653"},"text":"section 653 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b227bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing of report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State may provide the time within which the report required by paragraph (1) shall be made with respect to an employee, but such report shall be made—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7b227bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 20 days after the date the employer hires the employee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7b227be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an employer transmitting reports magnetically or electronically, by 2 monthly transmissions (if necessary) not less than 12 days nor more than 16 days apart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7b227bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting format and method","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each report required by subsection (b) shall, to the extent practicable, be made on a W–4 form or, at the option of the employer, an equivalent form, and may be transmitted by 1st class mail, magnetically, or electronically.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7b227c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil money penalties on noncomplying employers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The State shall have the option to set a State civil money penalty which shall not exceed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7b227c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $25 per failure to meet the requirements of this section with respect to a newly hired employee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b227c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $500 if, under State law, the failure is the result of a conspiracy between the employer and the employee to not supply the required report or to supply a false or incomplete report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7b227c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entry of employer information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Information shall be entered into the data base maintained by the State Directory of New Hires within 5 business days of receipt from an employer pursuant to subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7b227c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information comparisons","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7b227c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1998-05-01"},"text":"May 1, 1998","children":[],"tail":", an agency designated by the State shall, directly or by contract, conduct automated comparisons of the social security numbers reported by employers pursuant to subsection (b) and the social security numbers appearing in the records of the State case registry for cases being enforced under the State plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b227c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of match","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When an information comparison conducted under paragraph (1) reveals a match with respect to the social security number of an individual required to provide support under a support order, the State Directory of New Hires shall provide the agency administering the State plan approved under this part of the appropriate State with the name, address, and social security number of the employee to whom the social security number is assigned, and the name and address of, and identifying number assigned under section 6109 of the Internal Revenue Code of 1986 to, the employer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7b227c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmission of information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7b227c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmission of wage withholding notices to employers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 2 business days after the date information regarding a newly hired employee is entered into the State Directory of New Hires, the State agency enforcing the employee’s child support obligation shall transmit a notice to the employer of the employee directing the employer to withhold from the income of the employee an amount equal to the monthly (or other periodic) child support obligation (including any past due support obligation) of the employee, unless the employee’s income is not subject to withholding pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s666/b/3"},"text":"section 666(b)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b227c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmissions to the National Directory of New Hires","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7b227ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New hire information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 3 business days after the date information regarding a newly hired employee is entered into the State Directory of New Hires, the State Directory of New Hires shall furnish the information to the National Directory of New Hires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7b227cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wage and unemployment compensation information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State Directory of New Hires shall, on a quarterly basis, furnish to the National Directory of New Hires information concerning the wages and unemployment compensation paid to individuals, by such dates, in such format, and containing such information as the Secretary of Health and Human Services shall specify in regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b227cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Business day” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this subsection, the term “business day” means a day on which State offices are open for regular business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7b227cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other uses of new hire information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7b227ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location of child support obligors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The agency administering the State plan approved under this part shall use information received pursuant to subsection (f)(2) to locate individuals for purposes of establishing paternity and establishing, modifying, and enforcing child support obligations, and may disclose such information to any agent of the agency that is under contract with the agency to carry out such purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b227cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Verification of eligibility for certain programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State agency responsible for administering a program specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320b–7/b"},"text":"section 1320b–7(b) of this title","children":[],"tail":" shall have access to information reported by employers pursuant to subsection (b) of this section for purposes of verifying eligibility for the program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b227d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of employment security and workers’ compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"State agencies operating employment security and workers’ compensation programs shall have access to information reported by employers pursuant to subsection (b) for the purposes of administering such programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b497d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s653a/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Veteran employment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretaries of Labor and of Veterans Affairs shall have access to information reported by employers pursuant to subsection (b) of this section for purposes of tracking employment of veterans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7b497d2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title IV, § 453A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/tIII/s313/b"},"text":"Pub. L. 104–193, title III, § 313(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2209"},"text":"110 Stat. 2209","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tV/s5533"},"text":"Pub. L. 105–33, title V, § 5533","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/627"},"text":"111 Stat. 627","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/291/tVIII/s802/a"},"text":"Pub. L. 111–291, title VIII, § 802(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2010-12-08"},"text":"Dec. 8, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3157"},"text":"124 Stat. 3157","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/40/tII/s253/a"},"text":"Pub. L. 112–40, title II, § 253(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-10-21"},"text":"Oct. 21, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/422"},"text":"125 Stat. 422","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/315/tIV/s4301"},"text":"Pub. L. 116–315, title IV, § 4301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/5016"},"text":"134 Stat. 5016","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7b497d3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7b497d4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb7b497d5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Internal Revenue Code of 1986, referred to in subsecs. (a)(2), (b)(1)(A), and (f)(2), is classified generally to Title 26, Internal Revenue Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7b497d6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (h)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315"},"text":"Pub. L. 116–315","children":[],"tail":" added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/40"},"text":"Pub. L. 112–40","children":[],"tail":" added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/291/s802/a"},"text":"Pub. L. 111–291, § 802(a)","children":[],"tail":", inserted “the date services for remuneration were first performed by the employee,” after “of the employee,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/291/s802/b"},"text":"Pub. L. 111–291, § 802(b)","children":[],"tail":", inserted “, to the extent practicable,” after “Each report required by subsection (b) shall”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5533/1"},"text":"Pub. L. 105–33, § 5533(1)","children":[],"tail":", substituted “shall not exceed” for “shall be less than” in introductory provisions and “$25 per failure to meet the requirements of this section with respect to a newly hired employee” for “$25” in par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5533/2"},"text":"Pub. L. 105–33, § 5533(2)","children":[],"tail":", substituted “information” for “extracts of the reports required under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s503/a/6"},"text":"section 503(a)(6) of this title","children":[],"tail":" to be made to the Secretary of Labor”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb7b497d7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb7b497d8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/40/tII/s253/b"},"text":"Pub. L. 112–40, title II, § 253(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-10-21"},"text":"Oct. 21, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/422"},"text":"125 Stat. 422","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/40/tII/s253/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to paragraph (2), the amendments made by this section [amending this section] shall take effect 6 months after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2011-10-21"},"text":"Oct. 21, 2011","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance transition period","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary of Health and Human Services determines that State legislation (other than legislation appropriating funds) is required in order for a State plan under part D of title IV of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s651"},"text":"42 U.S.C. 651","children":[],"tail":" et seq.] to meet the additional requirement imposed by the amendment made by subsection (a) [amending this section], the plan shall not be regarded as failing to meet such requirement before the first day of the second calendar quarter beginning after the close of the first regular session of the State legislature that begins after the effective date of such amendment. If the State has a 2-year legislative session, each year of the session is deemed to be a separate regular session of the State legislature.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb7b497d9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/291/tVIII/s802/c"},"text":"Pub. L. 111–291, title VIII, § 802(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-08"},"text":"Dec. 8, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3157"},"text":"124 Stat. 3157","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/291/tVIII/s802/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to paragraph (2), the amendments made by this section [amending this section] shall take effect 6 months after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2010-12-08"},"text":"Dec. 8, 2010","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance transition period","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary of Health and Human Services determines that State legislation (other than legislation appropriating funds) is required in order for a State plan under part D of title IV of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s651"},"text":"42 U.S.C. 651","children":[],"tail":" et seq.] to meet the additional requirements imposed by the amendment made by subsection (a), the plan shall not be regarded as failing to meet such requirements before the first day of the second calendar quarter beginning after the close of the first regular session of the State legislature that begins after the effective date of such amendment. If the State has a 2-year legislative session, each year of the session is deemed to be a separate regular session of the State legislature.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb7b497da-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33"},"text":"Pub. L. 105–33","children":[],"tail":" effective as if included in the enactment of title III of the Personal Responsibility and Work Opportunity Reconciliation Act of 1996, "},{"tag":"ref","attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5557"},"text":"section 5557 of Pub. L. 105–33","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s608"},"text":"section 608 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb7b497db-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of section, see section 395(a)–(c) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":", set out as an Effective Date of 1996 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s654"},"text":"section 654 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
