ore the effective date under section 503(a) of the Quality Housing and Work Responsibility Act of 1998);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0ee71f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modernization assistance under section 1437","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title (as in effect before the effective date under section 503(a) of the Quality Housing and Work Responsibility Act of 1998);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0ee720-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb–2/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance for the certificate and voucher programs under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f"},"text":"section 1437f of this title","children":[],"tail":" (as in effect before the effective date under section 503(a) of the Quality Housing and Work Responsibility Act of 1998);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0ee721-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb–2/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance from the Operating Fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437g/e"},"text":"section 1437g(e) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0ee722-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb–2/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance from the Ca