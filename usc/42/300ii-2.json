{"tag":"section","attrib":{"id":"idb6d22809-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ii–2"},"text":"§ 300ii–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National lifespan respite resource center","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6d2280a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award a grant or cooperative agreement to a public or private nonprofit entity to establish a National Resource Center on Lifespan Respite Care (referred to in this section as the “center”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6d2280b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes of the center","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The center shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6d2280c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain a national database on lifespan respite care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6d2280d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide training and technical assistance to State, community, and nonprofit respite care programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6d2280e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–2/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide information, referral, and educational programs to the public on lifespan respite care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6d2280f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXIX, § 2903, as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/442/s2"},"text":"Pub. L. 109–442, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-21"},"text":"Dec. 21, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3295"},"text":"120 Stat. 3295","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
