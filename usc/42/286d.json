{"tag":"section","attrib":{"id":"idb581d9ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286d"},"text":null,"children":[{"tag":"num","attrib":{"value":"286d"},"text":"§ 286d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Information Center","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb581d9bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Library an entity to be known as the National Information Center on Health Services Research and Health Care Technology (in this section referred to as the “Center”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb581d9bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of the Center is the collection, storage, analysis, retrieval, and dissemination of information on health services research, clinical practice guidelines, and on health care technology, including the assessment of such technology. Such purpose includes developing and maintaining data bases and developing and implementing methods of carrying out such purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb581d9bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electronic, convenient format; criteria for inclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Center shall ensure that information under subsection (b) concerning clinical practice guidelines is collected and maintained electronically and in a convenient format. Such Director shall develop and publish criteria for the inclusion of practice guidelines and technology assessments in the information center database.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb581d9be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with Director of the Agency for Healthcare Research and Quality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Center, shall coordinate the activities carried out under this section through the Center with related activities of the Director of the Agency for Healthcare Research and Quality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb581d9bf-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 478A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXIV/s1421"},"text":"Pub. L. 103–43, title XIV, § 1421","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/171"},"text":"107 Stat. 171","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/129/s2/b/2"},"text":"Pub. L. 106–129, § 2(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-06"},"text":"Dec. 6, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1670"},"text":"113 Stat. 1670","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb581d9c0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb581d9c1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb581d9c2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/129"},"text":"Pub. L. 106–129","children":[],"tail":" substituted “Director of the Agency for Healthcare Research and Quality” for “Administrator for Health Care Policy and Research”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb581d9c3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb581d9c4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43/s1422/b"},"text":"Pub. L. 103–43, § 1422(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/172"},"text":"107 Stat. 172","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/43/s1422/b"},"text":"“The amendments made by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/410/s3"},"text":"section 3 of Public Law 102–410","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/106/2094"},"text":"106 Stat. 2094","children":[],"tail":") [amending "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s299a–1"},"text":"section 299a–1 of this title","children":[],"tail":"], by section 1421 of this Act [enacting this section], and by subsection (a) of this section [amending "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s299a–1"},"text":"section 299a–1 of this title","children":[],"tail":"] may not be construed as terminating the information center on health care technologies and health care technology assessment established under section 904 of the Public Health Service Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s299a–2"},"text":"42 U.S.C. 299a–2","children":[],"tail":"], as in effect on the day before the date of the enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/102/410"},"text":"Public Law 102–410","children":[],"tail":" ["},{"tag":"date","attrib":{"date":"1992-10-13"},"text":"Oct. 13, 1992","children":[],"tail":"]. Such center shall be considered to be the center established in section 478A of the Public Health Service Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s286d"},"text":"42 U.S.C. 286d","children":[],"tail":"], as added by section 1421 of this Act, and shall be subject to the provisions of such section 478A.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
