{"tag":"section","attrib":{"id":"idbcdffd8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4763"},"text":null,"children":[{"tag":"num","attrib":{"value":"4763"},"text":"§ 4763.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General administrative provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcdffd8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4763/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration by Office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Unless otherwise specifically provided, the Office shall administer this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcdffd8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4763/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advice and assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office shall furnish such advice and assistance to State and local governments as may be necessary to carry out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcdffd8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4763/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations and standards; contracts: modification, covenants, conditions, and provisions; utilization of other agencies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the performance of, and with respect to, the functions, powers, and duties vested in it by this chapter, the Office may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcdffd8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4763/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue such standards and regulations as may be necessary to carry out the purposes of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcdffd90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4763/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consent to the modification of any contract entered into pursuant to this chapter, such consent being subject to any specific limitations of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcdffd91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4763/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include in any contract made pursuant to this chapter such covenants, conditions, or provisions as it deems necessary to assure that the purposes of this chapter will be achieved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcdffd92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4763/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilize the services and facilities of any Federal agency, any State or local government, and any other public or nonprofit agency or institution, on a reimbursable basis or otherwise, in accordance with agreements between the Office and the head thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcdffd93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4763/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information: collection and availability; research and evaluation; administration report; coordination of Federal programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the performance of, and with respect to the functions, powers, and duties vested in it by this chapter, the Office—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcdffd94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4763/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may collect information from time to time with respect to State and local government training programs and personnel administration improvement programs and projects under this chapter, and make such information available to interested groups, organizations, or agencies, public or private;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcdffd95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4763/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may conduct such research and make such evaluation as needed for the efficient administration of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcdffd96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4763/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include in its annual report a report of the administration of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcdffd97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4763/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall make such arrangements as may be necessary to avoid duplication of programs providing for training and to insure consistent administration of the related Federal training activities, with particular regard to title I of the Higher Education Act of 1965 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"20 U.S.C. 1001","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcdffd98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4763/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this chapter are not a limitation on existing authorities under other statutes but are in addition to any such authorities, unless otherwise specifically provided in this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcdffd99-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/648/tV/s503"},"text":"Pub. L. 91–648, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-05"},"text":"Jan. 5, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1926"},"text":"84 Stat. 1926","children":[],"tail":"; 1978 Reorg. Plan No. 2, § 102, eff. "},{"tag":"date","attrib":{"date":"1979-01-01"},"text":"Jan. 1, 1979","children":[],"tail":", 43 F.R. 36037, "},{"tag":"ref","attrib":{"href":"/us/stat/92/3783"},"text":"92 Stat. 3783","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcdffd9a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcdffd9b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbcdffd9c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, means the provisions of subchapters I, II, III, and IV of this chapter. See ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4761"},"text":"section 4761 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Higher Education Act of 1965, referred to in subsec. (d)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329"},"text":"Pub. L. 89–329","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-11-08"},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1219"},"text":"79 Stat. 1219","children":[],"tail":". Title I of the Higher Education Act of 1965 is classified generally to subchapter I (§ 1001 et seq.) of chapter 28 of Title 20, Education. Title I as originally enacted by "},{"tag":"ref","attrib":{"href":"/us/pl/89/329"},"text":"Pub. L. 89–329","children":[],"tail":" related to community service and continuing education programs. Title I was amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/96/374"},"text":"Pub. L. 96–374","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/99/498"},"text":"Pub. L. 99–498","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Pub. L. 102–325","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", and now contains general provisions. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of Title 20","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbcdffd9d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbcdffd9e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Office”, meaning Office of Personnel Management, substituted for “Commission”, meaning Civil Service Commission, in subsecs. (a) to (d) pursuant to Reorg. Plan No. 2 of 1978, § 102, 43 F.R. 36037, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/92/3783"},"text":"92 Stat. 3783","children":[],"tail":", set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1101"},"text":"section 1101 of Title 5","children":[],"tail":", Government Organization and Employees, which transferred functions vested by statute in Civil Service Commission and Chairman thereof to Director of Office of Personnel Management (except as otherwise specified), effective "},{"tag":"date","attrib":{"date":"1979-01-01"},"text":"Jan. 1, 1979","children":[],"tail":", as provided by section 1–102 of Ex. Ord. No. 12107, "},{"tag":"date","attrib":{"date":"1978-12-28"},"text":"Dec. 28, 1978","children":[],"tail":", 44 F.R. 1055, set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1101"},"text":"section 1101 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
