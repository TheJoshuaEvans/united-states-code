{"tag":"section","attrib":{"id":"idb64ca33b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19c"},"text":null,"children":[{"tag":"num","attrib":{"value":"300j–19c"},"text":"§ 300j–19c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study on intractable water systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb64ca33c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of intractable water system","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “intractable water system” means a community water system or a noncommunity water system—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb64ca33d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that serves fewer than 1,000 individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca33e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the owner or operator of which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb64ca33f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19c/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is unable or unwilling to provide safe and adequate service to those individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb64ca340-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19c/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has abandoned or effectively abandoned the community water system or noncommunity water system, as applicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb64ca341-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19c/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has defaulted on a financial obligation relating to the community water system or noncommunity water system, as applicable; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb64ca342-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19c/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fails to maintain the facilities of the community water system or noncommunity water system, as applicable, in a manner so as to prevent a potential public health hazard; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca343-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that is, as of ","children":[{"tag":"date","attrib":{"date":"2018-10-23"},"text":"October 23, 2018","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb64ca344-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19c/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in significant noncompliance with this chapter or any regulation promulgated pursuant to this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb64ca345-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19c/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" listed as having a history of significant noncompliance with this subchapter pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300g–9/b/1"},"text":"section 300g–9(b)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb64ca346-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study required","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb64ca347-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2018-10-23"},"text":"October 23, 2018","children":[],"tail":", the Administrator, in consultation with the Secretary of Agriculture and the Secretary of Health and Human Services, shall complete a study that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb64ca348-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19c/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies intractable water systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb64ca349-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19c/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes barriers to delivery of potable water to individuals served by an intractable water system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca34a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2018-10-23"},"text":"October 23, 2018","children":[],"tail":", the Administrator shall submit to Congress a report describing findings and recommendations based on the study under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb64ca34b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIV, § 1459C, as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/270/tII/s2003"},"text":"Pub. L. 115–270, title II, § 2003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3841"},"text":"132 Stat. 3841","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
