{"tag":"section","attrib":{"id":"idbd4db3b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5401"},"text":null,"children":[{"tag":"num","attrib":{"value":"5401"},"text":"§ 5401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd4db3b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5401/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd4db3b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5401/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manufactured housing plays a vital role in meeting the housing needs of the Nation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd4db3b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5401/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manufactured homes provide a significant resource for affordable homeownership and rental housing accessible to all Americans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd4db3b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5401/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd4db3ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5401/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to protect the quality, durability, safety, and affordability of manufactured homes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd4db3bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5401/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate the availability of affordable manufactured homes and to increase homeownership for all Americans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd4db3bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5401/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide for the establishment of practical, uniform, and, to the extent possible, performance-based Federal construction standards for manufactured homes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd4db3bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5401/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage innovative and cost-effective construction techniques for manufactured homes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd4db3be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5401/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to protect residents of manufactured homes with respect to personal injuries and the amount of insurance costs and property damages in manufactured housing, consistent with the other purposes of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd4db3bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5401/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish a balanced consensus process for the development, revision, and interpretation of Federal construction and safety standards for manufactured homes and related regulations for the enforcement of such standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd4db3c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5401/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure uniform and effective enforcement of Federal construction and safety standards for manufactured homes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd4db3c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5401/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that the public interest in, and need for, affordable manufactured housing is duly considered in all determinations relating to the Federal standards and their enforcement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd4db3c2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/383/tVI/s602"},"text":"Pub. L. 93–383, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/700"},"text":"88 Stat. 700","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/399/tIII/s308/c/4"},"text":"Pub. L. 96–399, title III, § 308(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-08"},"text":"Oct. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1641"},"text":"94 Stat. 1641","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIII/s339B/c"},"text":"Pub. L. 97–35, title III, § 339B(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/417"},"text":"95 Stat. 417","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/tVI/s602"},"text":"Pub. L. 106–569, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2997"},"text":"114 Stat. 2997","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd4db3c3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd4db3c4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd4db3c5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569"},"text":"Pub. L. 106–569","children":[],"tail":" amended section catchline and text generally. Prior to amendment, text read as follows: “The Congress declares that the purposes of this chapter are to reduce the number of personal injuries and deaths and the amount of insurance costs and property damage resulting from manufactured home accidents and to improve the quality and durability of manufactured homes. Therefore, the Congress determines that it is necessary to establish Federal construction and safety standards for manufactured homes and to authorize manufactured home safety research and development.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/399"},"text":"Pub. L. 96–399","children":[],"tail":" substituted “manufactured home” for “mobile home” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd4db3c6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd4db3c7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569/tVI/s612"},"text":"Pub. L. 106–569, title VI, § 612","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/3012"},"text":"114 Stat. 3012","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/569/tVI/s612"},"text":"“The amendments made by this title [see Short Title of 2000 Amendment note below] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":"], except that the amendments shall have no effect on any order or interpretative bulletin that is issued under the National Manufactured Housing Construction and Safety Standards Act of 1974 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5401"},"text":"42 U.S.C. 5401","children":[],"tail":" et seq.) and published as a proposed rule pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":", United States Code, on or before that date of the enactment.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbd4db3c8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/383/tVI/s627"},"text":"Pub. L. 93–383, title VI, § 627","children":[],"tail":", formerly § 628, "},{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/714"},"text":"88 Stat. 714","children":[],"tail":", renumbered § 627, "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/tVI/s611/2"},"text":"Pub. L. 106–569, title VI, § 611(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/3012"},"text":"114 Stat. 3012","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/569/tVI/s611/2"},"text":"“The provisions of this title [enacting this chapter and provisions set out as a note under this section] shall take effect upon the expiration of 180 days following the date of enactment of this title [","children":[{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbd4db3c9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569/tVI/s601/a"},"text":"Pub. L. 106–569, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2997"},"text":"114 Stat. 2997","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/569/tVI/s601/a"},"text":"“This title [amending this section and sections 5402 to 5404, 5406, 5407, 5409, 5412 to 5415, 5419, 5422, and 5426 of this title, repealing ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5425"},"text":"section 5425 of this title","children":[],"tail":", and enacting and amending provisions set out as notes under this section] may be cited as the ‘Manufactured Housing Improvement Act of 2000’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idbd4db3ca-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/383/tVI/s601"},"text":"Pub. L. 93–383, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/700"},"text":"88 Stat. 700","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/96/399/tIII/s308/c/5"},"text":"Pub. L. 96–399, title III, § 308(c)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-08"},"text":"Oct. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1641"},"text":"94 Stat. 1641","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/399/tIII/s308/c/5"},"text":"“This title [enacting this chapter and provisions set out as a note under this section] may be cited as the ‘National Manufactured Housing Construction and Safety Standards Act of 1974’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"idbd4db3cb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569/tVI/s613"},"text":"Pub. L. 106–569, title VI, § 613","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/3012"},"text":"114 Stat. 3012","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/569/tVI/s613"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standards and Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal manufactured home construction and safety standards (as such term is defined in section 603 of the National Manufactured Housing Construction and Safety Standards Act of 1974 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5402"},"text":"42 U.S.C. 5402","children":[],"tail":"]) and all regulations pertaining thereto in effect on the day before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":"] shall apply until the effective date of a standard or regulation modifying or superseding the existing standard or regulation that is promulgated under subsection (a) or (b) of section 604 of the National Manufactured Housing Construction and Safety Standards Act of 1974, as amended by this title ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5403/a"},"text":"42 U.S.C. 5403(a)","children":[],"tail":", (b)]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any contract awarded pursuant to a Request for Proposal issued before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":"] shall remain in effect until the earlier of—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expiration of the 2-year period beginning on the date of the enactment of this Act; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expiration of the contract term.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
