{"tag":"section","attrib":{"id":"idb6cfde4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–31"},"text":null,"children":[{"tag":"num","attrib":{"value":"300hh–31"},"text":"§ 300hh–31.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Epidemiology-laboratory capacity grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6cfde4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–31/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of appropriations, the Secretary, acting through the Director of the Centers for Disease Control and Prevention, shall establish an Epidemiology and Laboratory Capacity Grant Program to award grants to State health departments as well as local health departments and tribal jurisdictions that meet such criteria as the Director determines appropriate. Academic centers that assist State and eligible local and tribal health departments may also be eligible for funding under this section as the Director determines appropriate. Grants shall be awarded under this section to assist public health agencies in improving surveillance for, and response to, infectious diseases and other conditions of public health importance by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6cfde4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–31/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthening epidemiologic capacity to identify and monitor the occurrence of infectious diseases, including mosquito and other vector-borne diseases, and other conditions of public health importance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cfde4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–31/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancing laboratory practice as well as systems to report test orders and results electronically;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cfde4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–31/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving information systems including developing and maintaining an information exchange using national guidelines and complying with capacities and functions determined by an advisory council established and appointed by the Director; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cfde50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–31/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and implementing prevention and control strategies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6cfde51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–31/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this section $190,000,000 for each of fiscal years 2019 through 2023, of which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6cfde52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–31/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than $95,000,000 shall be made available each such fiscal year for activities under paragraphs (1) and (4) of subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cfde53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–31/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than $60,000,000 shall be made available each such fiscal year for activities under subsection (a)(3); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cfde54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–31/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than $32,000,000 shall be made available each such fiscal year for activities under subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6cfde55-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVIII, § 2821, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIV/s4304"},"text":"Pub. L. 111–148, title IV, § 4304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/584"},"text":"124 Stat. 584","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/22/tVI/s607/b"},"text":"Pub. L. 116–22, title VI, § 607(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-06-24"},"text":"June 24, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/960"},"text":"133 Stat. 960","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6cfde56-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6cfde57-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6cfde58-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/22/s607/b/1"},"text":"Pub. L. 116–22, § 607(b)(1)","children":[],"tail":", inserted “, including mosquito and other vector-borne diseases,” after “infectious diseases”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/22/s607/b/2"},"text":"Pub. L. 116–22, § 607(b)(2)","children":[],"tail":", substituted “2019 through 2023” for “2010 through 2013” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
