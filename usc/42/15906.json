{"tag":"section","attrib":{"id":"idbfe6fbf5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15906"},"text":null,"children":[{"tag":"num","attrib":{"value":"15906"},"text":"§ 15906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" North Slope Science Initiative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfe6fbf6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15906/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe6fbf7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15906/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior shall establish a long-term initiative to be known as the “North Slope Science Initiative” (referred to in this section as the “Initiative”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe6fbf8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15906/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of the Initiative shall be to implement efforts to coordinate collection of scientific data that will provide a better understanding of the terrestrial, aquatic, and marine ecosystems of the North Slope of Alaska.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe6fbf9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15906/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Objectives","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To ensure that the Initiative is conducted through a comprehensive science strategy and implementation plan, the Initiative shall, at a minimum—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe6fbfa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15906/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and prioritize information needs for inventory, monitoring, and research activities to address the individual and cumulative effects of past, ongoing, and anticipated development activities and environmental change on the North Slope;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe6fbfb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15906/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop an understanding of information needs for regulatory and land management agencies, local governments, and the public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe6fbfc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15906/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" focus on prioritization of pressing natural resource management and ecosystem information needs, coordination, and cooperation among agencies and organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe6fbfd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15906/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate ongoing and future inventory, monitoring, and research activities to minimize duplication of effort, share financial resources and expertise, and assure the collection of quality information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe6fbfe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15906/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify priority needs not addressed by agency science programs in effect on ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", and develop a funding strategy to meet those needs;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe6fbff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15906/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a consistent approach to high caliber science, including inventory, monitoring, and research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe6fc00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15906/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" maintain and improve public and agency access to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe6fc01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15906/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accumulated and ongoing research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe6fc02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15906/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contemporary and traditional local knowledge; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe6fc03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15906/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure through appropriate peer review that the science conducted by participating agencies and organizations is of the highest technical quality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe6fc04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15906/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe6fc05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15906/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To ensure comprehensive collection of scientific data, in carrying out the Initiative, the Secretary shall consult and coordinate with Federal, State, and local agencies that have responsibilities for land and resource management across the North Slope.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe6fc06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15906/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall enter into cooperative agreements with the State of Alaska, the North Slope Borough, the Arctic Slope Regional Corporation, and other Federal agencies as appropriate to coordinate efforts, share resources, and fund projects under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe6fc07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15906/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Science technical advisory panel","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe6fc08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15906/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Initiative shall include a panel to provide advice on proposed inventory, monitoring, and research functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe6fc09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15906/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The panel described in paragraph (1) shall consist of a representative group of not more than 15 scientists and technical experts from diverse professions and interests, including the oil and gas industry, subsistence users, Native Alaskan entities, conservation organizations, wildlife management organizations, and academia, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe6fc0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15906/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", and each year thereafter, the Secretary shall publish a report that describes the studies and findings of the Initiative."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe6fc0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15906/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfe6fc0c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIII/s348"},"text":"Pub. L. 109–58, title III, § 348","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/708"},"text":"119 Stat. 708","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
