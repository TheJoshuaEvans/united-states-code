{"tag":"section","attrib":{"id":"idbea04ad5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8629"},"text":null,"children":[{"tag":"num","attrib":{"value":"8629"},"text":"§ 8629.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Studies and reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbea04ad6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8629/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary, after consultation with the Secretary of Energy, shall provide for the collection of data, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbea04ad7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8629/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information concerning home energy consumption;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea04ad8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8629/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount, cost and type of fuels used for households eligible for assistance under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea04ad9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8629/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type of fuel used by various income groups;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea04ada-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8629/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and income levels of households assisted by this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea04adb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8629/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of households which received such assistance and include one or more individuals who are 60 years or older or disabled or include young children; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea04adc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8629/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information which the Secretary determines to be reasonably necessary to carry out the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Nothing in this subsection may be construed to require the Secretary to collect data which has been collected and made available to the Secretary by any other agency of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbea04add-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8629/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall, no later than June 30 of each fiscal year, submit a report to the Congress containing a detailed compilation of the data under subsection (a) with respect to the prior fiscal year, and a report that describes for the prior fiscal year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbea04ade-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8629/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manner in which States carry out the requirements of clauses (2), (5), (8), and (15) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8624/b"},"text":"section 8624(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea04adf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8629/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of each State’s program on recipient and eligible households.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbea04ae0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXVI/s2610"},"text":"Pub. L. 97–35, title XXVI, § 2610","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/902"},"text":"95 Stat. 902","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/558/tVI/s607"},"text":"Pub. L. 98–558, title VI, § 607","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2893"},"text":"98 Stat. 2893","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/425/tV/s506"},"text":"Pub. L. 99–425, title V, § 506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-09-30"},"text":"Sept. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/976"},"text":"100 Stat. 976","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/252/tIII/s311/c/7"},"text":"Pub. L. 103–252, title III, § 311(c)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-05-18"},"text":"May 18, 1994","children":[],"tail":"