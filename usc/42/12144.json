{"tag":"section","attrib":{"id":"idbf61517c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12144"},"text":null,"children":[{"tag":"num","attrib":{"value":"12144"},"text":"§ 12144.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public entity operating a demand responsive system","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If a public entity operates a demand responsive system, it shall be considered discrimination, for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12132"},"text":"section 12132 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s794"},"text":"section 794 of title 29","children":[],"tail":", for such entity to purchase or lease a new vehicle for use on such system, for which a solicitation is made after the 30th day following "},{"tag":"date","attrib":{"date":"1990-07-26"},"text":"July 26, 1990","children":[],"tail":", that is not readily accessible to and usable by individuals with disabilities, including individuals who use wheelchairs, unless such system, when viewed in its entirety, provides a level of service to such individuals equivalent to the level of service such system provides to individuals without disabilities."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbf61517d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/336/tII/s224"},"text":"Pub. L. 101–336, title II, § 224","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-07-26"},"text":"July 26, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/342"},"text":"104 Stat. 342","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf61517e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf61517f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf615180-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1990-07-26"},"text":"July 26, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/336/s231/b"},"text":"section 231(b) of Pub. L. 101–336","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12141"},"text":"section 12141 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
