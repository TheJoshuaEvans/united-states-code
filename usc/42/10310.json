{"tag":"section","attrib":{"id":"idbf2113a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10310"},"text":null,"children":[{"tag":"num","attrib":{"value":"10310"},"text":"§ 10310.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Produced water research and development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf2113a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10310/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As soon as possible after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary of Energy (in this section referred to as the “Secretary”) shall establish a research and development program on produced water to develop—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf2113a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10310/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" new technologies and practices to reduce the environmental impact; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2113a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10310/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" opportunities for reprocessing of produced water at natural gas or oil development sites.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2113a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10310/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program established under subsection (a), the Secretary shall give priority to projects that develop and bring to market—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf2113a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10310/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effective systems for on-site management or repurposing of produced water; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2113a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10310/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" new technologies or approaches to reduce the environmental impact of produced water on local water sources and the environment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2113a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10310/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conduct of program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program established under subsection (a), the Secretary shall carry out science-based research and development activities to pursue—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf2113a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10310/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improved efficiency, technologies, and techniques for produced water recycling stations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2113a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10310/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alternative approaches to treating, reusing, storing, or decontaminating produced water.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2113aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10310/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $10,000,000 for each of fiscal years 2021 through 2025.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf2113ab-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tIV/s4008"},"text":"Pub. L. 116–260, div. Z, title IV, § 4008","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2546"},"text":"134 Stat. 2546","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf2113ac-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf2113ad-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf2113ae-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy Act of 2020, and not as part of the Water Resources Research Act of 1984 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
