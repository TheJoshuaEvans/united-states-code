{"tag":"section","attrib":{"id":"idb6d95325-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–16"},"text":null,"children":[{"tag":"num","attrib":{"value":"300jj–16"},"text":"§ 300jj–16.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary application and use of adopted standards and implementation specifications by private entities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6d95326-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–16/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided under section 13112 of the HITECH Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17902"},"text":"42 U.S.C. 17902","children":[],"tail":"], nothing in such Act or in the amendments made by such Act shall be construed—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6d95327-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–16/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to require a private entity to adopt or comply with a standard or implementation specification adopted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300jj–14"},"text":"section 300jj–14 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6d95328-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–16/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide a Federal agency authority, other than the authority such agency may have under other provisions of law, to require a private entity to comply with such a standard or implementation specification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6d95329-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–16/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this part shall be construed to require that a private entity that enters into a contract with the Federal Government apply or use the standards and implementation specifications adopted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300jj–14"},"text":"section 300jj–14 of this title","children":[],"tail":" with respect to activities not related to the contract."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6d9532a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXX, § 3006, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/dA/tXIII/s13101"},"text":"Pub. L. 111–5, div. A, title XIII, § 13101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/241"},"text":"123 Stat. 241","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6d9532b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6d9532c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb6d9532d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The HITECH Act, referred to in subsec. (a), is title XIII of div. A and title IV of div. B of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/226"},"text":"123 Stat. 226","children":[],"tail":", 467, also known as the Health Information Technology for Economic and Clinical Health Act. For complete classification of this Act to the Code, see Short Title of 2009 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
