{"tag":"section","attrib":{"id":"idbc666078-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l"},"text":null,"children":[{"tag":"num","attrib":{"value":"3056l"},"text":"§ 3056l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive requirements relating to grant awards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc666079-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc66607a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial approval of grant applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the funds available for national grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3056d/d"},"text":"section 3056d(d) of this title","children":[],"tail":", the Secretary shall award grants under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3056/b"},"text":"section 3056(b) of this title","children":[],"tail":" to eligible applicants, through a competitive process that emphasizes meeting performance requirements, to carry out projects under this subchapter for a period of 4 years, except as provided in paragraph (2). The Secretary may not conduct a grant competition under this subchapter until the day described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3056k/e"},"text":"section 3056k(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc66607b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of approval based on performance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the recipient of a grant made under paragraph (1) meets the expected levels of performance described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3056k/d/2/A"},"text":"section 3056k(d)(2)(A) of this title","children":[],"tail":" for each year of such 4-year period with respect to a project, the Secretary may award a grant under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3056/b"},"text":"section 3056(b) of this title","children":[],"tail":" to such recipient to continue such project beyond such 4-year period for 1 additional year without regard to such process."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc66607c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible applicants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An applicant shall be eligible to receive a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3056/b"},"text":"section 3056(b) of this title","children":[],"tail":" in accordance with subsections (a), (c), and (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc66607d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a)(1), the Secretary shall select the eligible applicants to receive grants based on the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc66607e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The applicant’s ability to administer a project that serves the greatest number of eligible individuals, giving particular consideration to individuals with greatest economic need, individuals with greatest social need, and individuals described in subsection (a)(3)(B)(ii) or (b)(2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3056p"},"text":"section 3056p of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc66607f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The applicant’s ability to administer a project that provides employment for eligible individuals in the communities in which such individuals reside, or in nearby communities, that will contribute to the general welfare of the communities involved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc666080-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The applicant’s ability to administer a project that moves eligible individuals into unsubsidized employment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc666081-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The applicant’s prior performance, if any, in meeting core measures of performance under this subchapter and the applicant’s ability to address core indicators of performance under this subchapter and under other Federal or State programs in the case of an applicant that has not previously received a grant under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc666082-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The applicant’s ability to move individuals with multiple barriers to employment, including individuals described in subsection (a)(3)(B)(ii) or (b)(2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3056p"},"text":"section 3056p of this title","children":[],"tail":", into unsubsidized employment."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc666083-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The applicant’s ability to coordinate activities with other organizations at the State and local level.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc666084-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The applicant’s plan for fiscal management of the project to be administered with funds received in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc666085-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The applicant’s ability to administer a project that provides community service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc666086-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The applicant’s ability to minimize disruption in services for participants and in community services provided.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc666087-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any additional criteria that the Secretary considers to be appropriate in order to minimize disruption in services for participants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc666088-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibility tests","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc666089-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before final selection of a grantee, the Secretary shall conduct a review of available records to assess the applicant’s overall responsibility to administer Federal funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc66608a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As part of the review described in paragraph (1), the Secretary may consider any information, including the applicant’s history with regard to the management of other grants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc66608b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to satisfy test","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The failure to satisfy a responsibility test with respect to any 1 factor that is listed in paragraph (4), excluding those listed in subparagraphs (A) and (B) of such paragraph, does not establish that the applicant is not responsible unless such failure is substantial or persists for 2 or more consecutive years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc66608c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Test","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The responsibility tests include review of the following factors:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc66608d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Unsuccessful efforts by the applicant to recover debts, after 3 demand letters have been sent, that are established by final agency action, or a failure to comply with an approved repayment plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc66608e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Established fraud or criminal activity of a significant nature within the organization or agency involved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc66608f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Serious administrative deficiencies identified by the Secretary, such as failure to maintain a financial management system as required by Federal rules or regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc666090-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/d/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Willful obstruction of the audit process.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc666091-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/d/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Failure to provide services to participants for a current or recent grant or to meet applicable core measures of performance or address applicable indicators of performance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc666092-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/d/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Failure to correct deficiencies brought to the grantee’s attention in writing as a result of monitoring activities, reviews, assessments, or other activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc666093-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/d/4/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Failure to return a grant closeout package or outstanding advances within 90 days of the grant expiration date or receipt of the closeout package, whichever is later, unless an extension has been requested and granted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc666094-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/d/4/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Failure to submit required reports.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc666095-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/d/4/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Failure to properly report and dispose of Government property as instructed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc666096-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/d/4/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Failure to have maintained effective cash management or cost controls resulting in excess cash on hand.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc666097-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/d/4/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Failure to ensure that a subrecipient complies with its Office of Management and Budget Circular A–133 audit requirements specified at section 667.200(b) of title 20, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc666098-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/d/4/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Failure to audit a subrecipient within the required period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc666099-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/d/4/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Final disallowed costs in excess of 5 percent of the grant or contract award if, in the judgment of the grant officer, the disallowances are egregious.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc66609a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/d/4/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Failure to establish a mechanism to resolve a subrecipient’s audit in a timely fashion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc66609b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Applicants that are determined to be not responsible shall not be selected as grantees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc66609c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disallowed costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Interest on disallowed costs shall accrue in accordance with the Debt Collection Improvement Act of 1996, including the amendments made by that Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc66609d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grantees serving individuals with barriers to employment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc66609e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “individuals with barriers to employment” means minority individuals, Indian individuals, individuals with greatest economic need, eligible individuals who have been incarcerated or are under supervision following release from prison or jail, and individuals described in subsection (a)(3)(B)(ii) or (b)(2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3056p"},"text":"section 3056p of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc66609f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In areas where a substantial population of individuals with barriers to employment exists, a grantee that receives a national grant in accordance with this section shall, in selecting subgrantees, give special consideration to organizations (including former recipients of such national grants) with demonstrated expertise in serving individuals with barriers to employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc6660a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056l/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minority-serving grantees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not promulgate rules or regulations affecting grantees in areas where a substantial population of minority individuals exists, that would significantly compromise the ability of the grantees to serve their targeted population of minority older individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc6660a1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tV/s514"},"text":"Pub. L. 89–73, title V, § 514","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/365/tV/s501"},"text":"Pub. L. 109–365, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2584"},"text":"120 Stat. 2584","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/144/s6/e"},"text":"Pub. L. 114–144, § 6(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-04-19"},"text":"Apr. 19, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/346"},"text":"130 Stat. 346","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/131/tIV/s401/a/2"},"text":"Pub. L. 116–131, title IV, § 401(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-25"},"text":"Mar. 25, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/266"},"text":"134 Stat. 266","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc6660a2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc6660a3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbc6660a4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Debt Collection Improvement Act of 1996, referred to in subsec. (d)(6), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134/tIII/s31001"},"text":"section 31001 of title III of Pub. L. 104–134","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1321-358"},"text":"110 Stat. 1321–358","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1996 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3701"},"text":"secti