{"tag":"section","attrib":{"id":"idbcd6608d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4602"},"text":null,"children":[{"tag":"num","attrib":{"value":"4602"},"text":"§ 4602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect upon property acquisition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcd6608e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4602/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4651"},"text":"section 4651 of this title","children":[],"tail":" create no rights or liabilities and shall not affect the validity of any property acquisitions by purchase or condemnation."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcd6608f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4602/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this chapter shall be construed as creating in any condemnation proceedings brought under the power of eminent domain, any element of value or of damage not in existence immediately prior to ","children":[{"tag":"date","attrib":{"date":"1971-01-02"},"text":"January 2, 1971","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcd66090-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/646/tI/s102"},"text":"Pub. L. 91–646, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-02"},"text":"Jan. 2, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1895"},"text":"84 Stat. 1895","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcd66091-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcd66092-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbcd66093-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/646"},"text":"Pub. L. 91–646","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-02"},"text":"Jan. 2, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1894"},"text":"84 Stat. 1894","children":[],"tail":", known as the Uniform Relocation Assistance and Real Property Acquisition Policies Act of 1970, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4601"},"text":"section 4601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
