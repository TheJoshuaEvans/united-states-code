{"tag":"section","attrib":{"id":"idbe375010-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7508"},"text":null,"children":[{"tag":"num","attrib":{"value":"7508"},"text":"§ 7508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance documents","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Administrator shall issue guidance documents under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7408"},"text":"section 7408 of this title","children":[],"tail":" for purposes of assisting States in implementing requirements of this part respecting the lowest achievable emission rate. Such a document shall be published not later than nine months after "},{"tag":"date","attrib":{"date":"1977-08-07"},"text":"August 7, 1977","children":[],"tail":", and shall be revised at least every two years thereafter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbe375011-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title I, § 178, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/95/tI/s129/b"},"text":"Pub. L. 95–95, title I, § 129(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-07"},"text":"Aug. 7, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/750"},"text":"91 Stat. 750","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
