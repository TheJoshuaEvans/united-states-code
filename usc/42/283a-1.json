{"tag":"section","attrib":{"id":"idb556f91b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283a–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"283a–1"},"text":"§ 283a–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reporting to prevent fraud and abuse","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb556f91c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283a–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Whistleblower complaints","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb556f91d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283a–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On an annual basis, the Director of NIH shall submit to the Inspector General of the Department of Health and Human Services, the Secretary, the Committee on Energy and Commerce and the Committee on Appropriations of the House of Representatives, and the Committee on Health, Education, Labor, and Pensions and the Committee on Appropriations of the Senate a report summarizing the activities of the National Institutes of Health relating to whistleblower complaints.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb556f91e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283a–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each whistleblower complaint pending during the year for which a report is submitted under this subsection, the report shall identify the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb556f91f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283a–1/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each agency of the National Institutes of Health involved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb556f920-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283a–1/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The status of the complaint.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb556f921-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283a–1/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The resolution of the complaint to date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb556f922-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283a–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The first report under subsection (a) shall be submitted not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2007-01-15"},"text":"January 15, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb556f923-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 403B, as added "},{"tag":"ref","attrib":{"href":"/us/pl/10