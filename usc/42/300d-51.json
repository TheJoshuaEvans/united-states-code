{"tag":"section","attrib":{"id":"idb6182629-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–51"},"text":null,"children":[{"tag":"num","attrib":{"value":"300d–51"},"text":"§ 300d–51.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Residency training programs in emergency medicine","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb618262a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–51/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make grants to public and nonprofit private entities for the purpose of planning and developing approved residency training programs in emergency medicine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb618262b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–51/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification and referral of domestic violence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make a grant under subsection (a) only if the applicant involved agrees that the training programs under subsection (a) will provide education and training in identifying and referring cases of domestic violence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb618262c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–51/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this section, there is authorized to be appropriated $400,000 for each of the fiscal years 2008 though 2012.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb618262d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XII, § 1251, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/408/tIII/s304"},"text":"Pub. L. 102–408, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-13"},"text":"Oct. 13, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2084"},"text":"106 Stat. 2084","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/23/s13"},"text":"Pub. L. 110–23, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-05-03"},"text":"May 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/98"},"text":"121 Stat. 98","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb618262e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb618262f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6182630-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/23"},"text":"Pub. L. 110–23","children":[],"tail":" amended section generally. Prior to amendment, section related to residency training programs in emergency medicine and authorized appropriations for fiscal years 1993 through 1995."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
