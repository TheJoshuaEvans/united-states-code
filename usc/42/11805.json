{"tag":"section","attrib":{"id":"idbf57db52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11805"},"text":null,"children":[{"tag":"num","attrib":{"value":"11805"},"text":"§ 11805.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"To carry out this subchapter, there are authorized to be appropriated $16,000,000 for fiscal year 1992 and such sums as may be necessary for fiscal years 1993 and 1994.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbf57db53-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tIII/s3505"},"text":"Pub. L. 100–690, title III, § 3505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4255"},"text":"102 Stat. 4255","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/132/s1/b"},"text":"Pub. L. 102–132, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-18"},"text":"Oct. 18, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/630"},"text":"105 Stat. 630","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf57db54-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf57db55-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf57db56-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—