{"tag":"section","attrib":{"id":"idbc369d84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2996g"},"text":null,"children":[{"tag":"num","attrib":{"value":"2996g"},"text":"§ 2996g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records and reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc369d85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2996g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to require reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation is authorized to require such reports as it deems necessary from any grantee, contractor, or person or entity receiving financial assistance under this subchapter regarding activities carried out pursuant to this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc369d86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2996g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to require recordkeeping; access to records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation is authorized to prescribe the keeping of records with respect to funds provided by grant or contract and shall have access to such records at all reasonable times for the purpose of insuring compliance with the grant or contract or the terms and conditions upon which financial assistance was provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc369d87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2996g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report to President and Congress; contents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall publish an annual report which shall be filed by the Corporation with the President and the Congress. Such report shall include a description of services provided pursuant to section 2996f(a)(2)(C)(i) and (ii) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc369d88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2996g/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Copies and retention of reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Copies of all reports pertinent to the evaluation, inspection, or monitoring of any grantee, contractor, or person or entity receiving financial assistance under this subchapter shall be submitted on a timely basis to such grantee, contractor, or person or entity, and shall be maintained in the principal office of the Corporation for a period of at least five years subsequent to such evaluation, inspection, or monitoring. Such reports shall be available for public inspection during regular business hours, and copies shall be furnished, upon request, to interested parties upon payment of such reasonable fees as the Corporation may establish.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc369d89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2996g/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication in Federal Register of rules, regulations, guidelines and instructions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall afford notice and reasonable opportunity for comment to interested parties prior to issuing rules, regulations, and guidelines, and it shall publish in the Federal Register at least 30 days prior to their effective date all its rules, regulations, guidelines, and instructions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc369d8a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/452/tX/s1008"},"text":"Pub. L. 88–452, title X, § 1008","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/355/s2"},"text":"Pub. L. 93–355, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-07-25"},"text":"July 25, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/386"},"text":"88 Stat. 386","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/222/s9/b/2"},"text":"Pub. L. 95–222, § 9(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-12-28"},"text":"Dec. 28, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1621"},"text":"91 Stat. 1621","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc369d8b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc369d8c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc369d8d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1977—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/222"},"text":"Pub. L. 95–222","children":[],"tail":" inserted provisions setting forth required contents of annual report."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc369d8e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbc369d8f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1977 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/222"},"text":"Pub. L. 95–222","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1977-12-28"},"text":"Dec. 28, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/222/s17/b"},"text":"section 17(b) of Pub. L. 95–222","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2996"},"text":"section 2996 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbc369d90-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions in subsec. (c) of this section relating to filing annual report with Congress, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance, and item 2 on page 202 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
