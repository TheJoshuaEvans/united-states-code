{"tag":"section","attrib":{"id":"idb615dcac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–21"},"text":null,"children":[{"tag":"num","attrib":{"value":"300d–21"},"text":"§ 300d–21.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance and provision by Secretary of supplies and services in lieu of grant funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb615dcad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–21/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, without charge to a State receiving payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–11/a"},"text":"section 300d–11(a) of this title","children":[],"tail":", provide to the State (or to any public or nonprofit private entity designated by the State) technical assistance with respect to the planning, development, and operation of any program carried out pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–11/b"},"text":"section 300d–11(b) of this title","children":[],"tail":". The Secretary may provide such technical assistance directly, through contract, or through grants."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb615dcae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–21/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision by Secretary of supplies and services in lieu of grant funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb615dcaf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–21/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the request of a State receiving payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–11/a"},"text":"section 300d–11(a) of this title","children":[],"tail":", the Secretary may, subject to paragraph (2), provide supplies, equipment, and services for the purpose of aiding the State in carrying out "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–11/b"},"text":"section 300d–11(b) of this title","children":[],"tail":" and, for such purpose, may detail to the State any officer or employee of the Department of Health and Human Services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb615dcb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–21/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction in payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to a request described in paragraph (1), the Secretary shall reduce the amount of payments to the State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–11/a"},"text":"section 300d–11(a) of this title","children":[],"tail":" by an amount equal to the costs of detailing personnel and the fair market value of any supplies, equipment, or services provided by the Secretary. The Secretary shall, for the payment of expenses incurred in complying with such request, expend the amounts withheld."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb615dcb1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XII, § 1221, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/590/s3"},"text":"Pub. L. 101–590, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2926"},"text":"104 Stat. 2926","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb615dcb2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb615dcb3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb615dcb4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 300d–21, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tXII/s1221"},"text":"act July 1, 1944, ch. 373, title XII, § 1221","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/94/573/s14/3"},"text":"Pub. L. 94–573, § 14(3)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2718"},"text":"90 Stat. 2718","children":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1979-12-12"},"text":"Dec. 12, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/96/142/tI/s107/a"},"text":"Pub. L. 96–142, title I, § 107(a)","children":[],"tail":"–(c), "},{"tag":"ref","attrib":{"href":"/us/stat/93/1069"},"text":"93 Stat. 1069","children":[],"tail":", related to programs for burn, trauma, and poison injuries, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIX/s902/d/1"},"text":"Pub. L. 97–35, title IX, § 902(d)(1)","children":[],"tail":", (h), "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/560"},"text":"95 Stat. 560","children":[],"tail":", 561, effective "},{"tag":"date","attrib":{"date":"1981-10-01"},"text":"Oct. 1, 1981","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
