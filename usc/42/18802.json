{"tag":"section","attrib":{"id":"idc06c7f7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18802"},"text":null,"children":[{"tag":"num","attrib":{"value":"18802"},"text":"§ 18802.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Career skills training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc06c7f7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18802/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “eligible entity” means a nonprofit partnership that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06c7f80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18802/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes the equal participation of industry, including public or private employers, and labor organizations, including joint labor-management training programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c7f81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18802/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include workforce investment boards, community-based organizations, qualified service and conservation corps, educational institutions, small businesses, cooperatives, State and local veterans agencies, and veterans service organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c7f82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18802/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" demonstrates—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06c7f83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18802/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" experience in implementing and operating worker skills training and education programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c7f84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18802/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability to identify and involve in training programs carried out under this section, target populations of individuals who would benefit from training and be actively involved in activities relating to energy efficiency and renewable energy industries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c7f85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18802/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability to help individuals achieve economic self-sufficiency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06c7f86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18802/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grants to eligible entities to pay the Federal share of associated career skills training programs under which students concurrently receive classroom instruction and on-the-job training for the purpose of obtaining an industry-related certification to install energy efficient buildings technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06c7f87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18802/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of carrying out a career skills training program described in subsection (b) shall be 50 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06c7f88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18802/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary to carry out this section $10,000,000 for fiscal year 2022, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc06c7f89-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tV/s40513"},"text":"Pub. L. 117–58, div. D, title V, § 40513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1060"},"text":"135 Stat. 1060","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc06c7f8a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc06c7f8b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc06c7f8c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
