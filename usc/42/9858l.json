{"tag":"section","attrib":{"id":"idbeffa945-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858l"},"text":null,"children":[{"tag":"num","attrib":{"value":"9858l"},"text":"§ 9858l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondiscrimination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbeffa946-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858l/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Religious nondiscrimination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbeffa947-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858l/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbeffa948-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858l/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), nothing in this section shall be construed to modify or affect the provisions of any other Federal law or regulation that relates to discrimination in employment on the basis of religion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbeffa949-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858l/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A sectarian organization may require that employees adhere to the religious tenets and teachings of such organization, and such organization may require that employees adhere to rules forbidding the use of drugs or alcohol.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeffa94a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858l/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discrimination against child","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbeffa94b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858l/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A child care provider (other than a family child care provider) that receives assistance under this subchapter shall not discriminate against any child on the basis of religion in providing child care services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbeffa94c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858l/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-funded child care slots","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall prohibit a child care provider from selecting children for child care slots that are not funded directly with assistance provided under this subchapter because such children or their family members participate on a regular basis in other activities of the organization that owns or operates such provider.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeffa94d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858l/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment in general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbeffa94e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858l/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A child care provider that receives assistance under this subchapter shall not discriminate in employment on the basis of the religion of the prospective employee if such employee’s primary responsibility is or will be working directly with children in the provision of child care services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbeffa94f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858l/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified applicants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If two or more prospective employees are qualified for any position with a child care provider receiving assistance under this subchapter, nothing in this section shall prohibit such child care provider from employing a prospective employee who is already participating on a regular basis in other activities of the organization that owns or operates such provider.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbeffa950-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858l/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Present employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This paragraph shall not apply to employees of child care providers receiving assistance under this subchapter if such employees are employed with the provider on ","children":[{"tag":"date","attrib":{"date":"1990-11-05"},"text":"November 5, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeffa951-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858l/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment and admission practices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraphs (1)(B), (2), and (3), if assistance provided under this subchapter, and any other Federal or State program, amounts to 80 percent or more of the operating budget of a child care provider that receives such assistance, the Secretary shall not permit such provider to receive any further assistance under this subchapter unless the grant or contract relating to the financial assistance, or the employment and admissions policies of the provider, specifically provides that no person with responsibilities in the operation of the child care program, project, or activity of the provider will discriminate against any individual in employment, if such employee’s primary responsibility is or will be working directly with children in the provision of child care, or admissions because of the religion of such individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbeffa952-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858l/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on State law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to supersede or modify any provision of a State constitution or State law that prohibits the expenditure of public funds in or by sectarian institutions, except that no provision of a State constitution or State law shall be construed to prohibit the expenditure in or by sectarian institutions of any Federal funds provided under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbeffa953-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s658N"},"text":"Pub. L. 97–35, title VI, § 658N","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tV/s5082/2"},"text":"Pub. L. 101–508, title V, § 5082(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-245"},"text":"104 Stat. 1388–245","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/401/s3/a"},"text":"Pub. L. 102–401, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-07"},"text":"Oct. 7, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1959"},"text":"106 Stat. 1959","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/586/s8/c/1"},"text":"Pub. L. 102–586, § 8(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5036"},"text":"106 Stat. 5036","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbeffa954-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbeffa955-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbeffa956-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/401"},"text":"Pub. L. 102–401","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/102/586"},"text":"Pub. L. 102–586","children":[],"tail":" made identical technical corrections to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/s5082/2"},"text":"Pub. L. 101–508, § 5082(2)","children":[],"tail":", which added this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
