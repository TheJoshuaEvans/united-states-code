{"tag":"section","attrib":{"id":"idbff2e343-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16106"},"text":null,"children":[{"tag":"num","attrib":{"value":"16106"},"text":"§ 16106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ultra-efficient engine technology for aircraft","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbff2e344-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ultra-efficient engine technology partnership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall enter into a cooperative agreement with the National Aeronautics and Space Administration for the development of ultra-efficient engine technology for aircraft.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff2e345-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance objective","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish the following performance objectives for the program set forth in subsection (a):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff2e346-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16106/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A fuel efficiency increase of at least 10 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e347-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16106/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A reduction in the impact of landing and takeoff nitrogen oxides emissions on local air quality of 70 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e348-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16106/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Exploring advanced concepts, alternate propulsion, and power configurations, including hybrid fuel cell powered systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e349-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16106/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Exploring the use of alternate fuel in conventional or nonconventional turbine-based systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff2e34a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16106/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary for carrying out this section $50,000,000 for each of the fiscal years 2006, 2007, 2008, 2009, and 2010.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff2e34b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVII/s758"},"text":"Pub. L. 109–58, title VII, § 758","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/833"},"text":"119 Stat. 833","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
