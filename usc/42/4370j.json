{"tag":"section","attrib":{"id":"idbcccea0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370j"},"text":null,"children":[{"tag":"num","attrib":{"value":"4370j"},"text":"§ 4370j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Municipal Ombudsman","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcccea0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Office of the Administrator an Office of the Municipal Ombudsman, to be headed by a Municipal Ombudsman.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcccea0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The duties of the Municipal Ombudsman shall include the provision of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcccea0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370j/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical assistance to municipalities seeking to comply with the Federal Water Pollution Control Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251"},"text":"33 U.S.C. 1251","children":[],"tail":" et seq.]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcccea10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370j/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information to the Administrator to help the Administrator ensure that agency policies are implemented by all offices of the Environmental Protection Agency, including regional offices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcccea11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370j/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Municipal Ombudsman shall work with appropriate offices at the headquarters and regional offices of the Environmental Protection Agency to ensure that a municipality seeking assistance is provided information regarding—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcccea12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370j/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" available Federal financial assistance for which the municipality is eligible;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcccea13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370j/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" flexibility available under the Federal Water Pollution Control Act; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcccea14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370j/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the opportunity to develop an integrated plan under section 402(s) of the Federal Water Pollution Control Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1342/s"},"text":"33 U.S.C. 1342(s)","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcccea15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370j/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information sharing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Municipal Ombudsman shall publish on the website of the Environmental Protection Agency—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcccea16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370j/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" general information relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcccea17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370j/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the technical assistance referred to in subsection (b)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcccea18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370j/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the financial assistance referred to in subsection (c)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcccea19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370j/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the flexibility referred to in subsection (c)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcccea1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370j/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any resources developed by the Administrator related to integrated plans under section 402(s) of the Federal Water Pollution Control Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1342/s"},"text":"33 U.S.C. 1342(s)","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcccea1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370j/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of each permit, order, or judicial consent decree that implements or incorporates such an integrated plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcccea1c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/436/s4"},"text":"Pub. L. 115–436, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5560"},"text":"132 Stat. 5560","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcccea1d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcccea1e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbcccea1f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Water Pollution Control Act, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"act June 30, 1948, ch. 758","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/92/500/s2"},"text":"Pub. L. 92–500, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-18"},"text":"Oct. 18, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/816"},"text":"86 Stat. 816","children":[],"tail":", which is classified generally to chapter 26 (§ 1251 et seq.) of Title 33, Navigation and Navigable Waters. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251"},"text":"section 1251 of Title 33","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbcccea20-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Infrastructure Improvement Act, and not as part of the National Environmental Policy Act of 1969 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcccea21-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbcccea22-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/436/s2"},"text":"Pub. L. 115–436, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5558"},"text":"132 Stat. 5558","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/436/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this Act [see Short Title of 2019 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251"},"text":"section 1251 of Title 33","children":[],"tail":", Navigation and Navigable Waters]:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrator","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Administrator’ means the Administrator of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Municipality","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘municipality’ has the meaning given that term in section 502 of the Federal Water Pollution Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1362"},"text":"33 U.S.C. 1362","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
