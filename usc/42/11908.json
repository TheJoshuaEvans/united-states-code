{"tag":"section","attrib":{"id":"idbf5a4c7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11908"},"text":null,"children":[{"tag":"num","attrib":{"value":"11908"},"text":"§ 11908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf5a4c7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11908/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this subchapter $310,000,000 for fiscal year 1999, and such sums as may be necessary for fiscal years 2000, 2001, 2002, and 2003.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf5a4c7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11908/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Set-aside for federally assisted low-income housing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of any amounts made available in any fiscal year to carry out this subchapter not more than 6.25 percent shall be available for grants for federally assisted low-income housing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf5a4c7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11908/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Set-aside for technical assistance and program oversight","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of any amounts appropriated in any fiscal year to carry out this subchapter, amounts shall be available to the extent provided in appropriations Acts to provide training, technical assistance, contract expertise, program oversight, program assessment, execution, and other assistance for or on behalf of public housing agencies, recipients of assistance under the Native American Housing Assistance and Self-Determination Act of 1996 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4101"},"text":"25 U.S.C. 4101","children":[],"tail":" et seq.], resident organizations, and officials and employees of the Department (including training and the cost of necessary travel for participants in such training, by or to officials and employees of the Department and of public housing agencies, and to residents and to other eligible grantees). Assistance and other activities carried out using amounts made available under this subsection may be provided directly or indirectly by grants, contracts, or cooperative agreements."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf5a4c80-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tV/s5129"},"text":"Pub. L. 100–690, title V, § 5129","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/tV/s586/g"},"text":"Pub. L. 105–276, title V, § 586(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2650"},"text":"112 Stat. 2650","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf5a4c81-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf5a4c82-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial No