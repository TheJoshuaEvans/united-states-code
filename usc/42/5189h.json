ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Individual assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd206227-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/c/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Mitigation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd206228-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/c/2/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Administrative.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd206229-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/c/2/D/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd20622a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/c/2/D/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other relevant category (including emergency measures and disaster resources) delineated by disaster.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd20622b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The date on which funds appropriated will be exhausted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd20622c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd20622d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 10 days after the first day of each month, the Administrator of the Federal Emergency Management Agency shall publish on the website of the Federal Emergency Management Agency the specifics of each contract in excess of $1,000,000 that the Federal Emergency Management Agency enters into, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd20622e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the party;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd20622f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date the contract was awarded;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd206230-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount and scope of the contract;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd206231-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the contract was awarded through a competitive bidding process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd206232-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if no competitive bidding process was used, the reason why competitive bidding was not used; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd206233-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authority used to bypass the competitive bidding process.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The information shall be delineated by disaster, if applicable, and specify the damage category code, if applicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd206234-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 10 days after the last day of the fiscal year, the Administrator of the Federal Emergency Management Agency shall provide a report to the appropriate committees of Congress summarizing the following information for the preceding fiscal year:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd206235-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of contracts awarded without competitive bidding.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd206236-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The reasons why a competitive bidding process was not used.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd206237-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total amount of contracts awarded with no competitive bidding.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd206238-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The damage category codes, if applicable, for contracts awarded without competitive bidding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd206239-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of public assistance recipient and subrecipient contracts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd20623a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2018-10-05"},"text":"October 5, 2018","children":[],"tail":", the Administrator of the Federal Emergency Management Agency shall initiate and maintain an effort to collect and store information, prior to the project closeout phase on any contract entered into by a public assistance recipient or subrecipient that through the base award, available options, or any subsequent modifications has an estimated value of more than $1,000,000 and is funded through section 5165b, 5170b, 5170c, 5172, 5173, 5189f, or 5192 of this title, including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd20623b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disaster number, project worksheet number, and the category of work associated with each contract;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd20623c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of each party;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd20623d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date the contract was awarded;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd20623e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the contract;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd20623f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/e/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the scope of the contract;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd206240-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/e/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period of performance for the contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd206241-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/e/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the contract was awarded through a competitive bidding process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd206242-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of information collected","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the Federal Emergency Management Agency shall make the information collected and stored under paragraph (1) available to the Inspector General of the Department of Homeland Security, the Government Accountability Office, and appropriate committees of Congress, upon request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd206243-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 365 days after ","children":[{"tag":"date","attrib":{"date":"2018-10-05"},"text":"October 5, 2018","children":[],"tail":", the Administrator of the Federal Emergency Management Agency shall submit a report to the Committee on Homeland Security and Governmental Affairs of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives on the efforts of the Federal Emergency Management Agency to collect the information described in paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd206244-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tIV/s430"},"text":"Pub. L. 93–288, title IV, § 430","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dD/s1224"},"text":"Pub. L. 115–254, div. D, § 1224","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3455"},"text":"132 Stat. 3455","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd206245-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd206246-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbd206247-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Enactment of section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" applicable to each major disaster and emergency declared by the President on or after "},{"tag":"date","attrib":{"date":"2017-08-01"},"text":"Aug. 1, 2017","children":[],"tail":", and authorities provided under div. D of "},{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" applicable to each major disaster and emergency declared by the President on or after "},{"tag":"date","attrib":{"date":"2016-01-01"},"text":"Jan. 1, 2016","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1202"},"text":"section 1202 of Pub. L. 115–254","children":[],"tail":", set out as an Effective Date of 2018 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
