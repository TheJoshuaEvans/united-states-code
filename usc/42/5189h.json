,"attrib":{},"text":" the State, county, and applicant name;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd206201-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the applicant is a private nonprofit organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd206202-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the damage category code;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd206203-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the Federal share obligated; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd206204-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of the award.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd206205-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mission assignments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd206206-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 5 days after the issuance of a mission assignment or mission assignment task order, the Administrator of the Federal Emergency Management Agency shall publish on the website of the Federal Emergency Management Agency any mission assignment or mission assignment task order to another Federal department or agency regarding a major disaster in excess of $1,000,000, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd206207-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the impacted State or Indian Tribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd206208-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disaster declaration for such State or Indian Tribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd206209-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the assigned agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd20620a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the assistance requested;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd20620b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the disaster;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd20620c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total cost estimate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd20620d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount obligated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd20620e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State or Indian tribal government cost share, if applicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd20620f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authority under which the mission assignment or mission assignment task order was directed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd206210-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/b/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if applicable, the date a State or Indian Tribe requested the mission assignment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd206211-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recording changes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 10 days after the last day of each month until a mission assignment or mission assignment task order described in paragraph (1) is completed and closed out, the Administrator of the Federal Emergency Management Agency shall update any changes to the total cost estimate and the amount obligated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd206212-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disaster relief monthly report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 10 days after the first day of each month, the Administrator of the Federal Emergency Management Agency shall publish on the website of the Federal Emergency Management Agency reports, including a specific description of the methodology and the source data used in developing such reports, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd206213-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an estimate of the amounts for the fiscal year covered by the President’s most recent budget pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":" including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd206214-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the unobligated balance of funds to be carried over from the prior fiscal year to the budget year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd206215-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the unobligated balance of funds to be carried over from the budget year to the budget year plus 1;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd206216-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of obligations for noncatastrophic events for the budget year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd206217-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of obligations for the budget year for catastrophic events delineated by event and by State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd206218-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount that has been previously obligated or will be required for catastrophic events delineated by event and by State for all prior years, the current fiscal year, the budget year, and each fiscal year thereafter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd206219-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of previously obligated funds that will be recovered for the budget year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd20621a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount that will be required for obligations for emergencies, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5122/1"},"text":"section 5122(1) of this title","children":[],"tail":", major disasters, as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5122/2"},"text":"section 5122(2) of this title","children":[],"tail":", fire management assistance grants, as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5187"},"text":"section 5187 of this title","children":[],"tail":", surge activities, and disaster readiness and support activities; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd20621b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/c/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount required for activities not covered under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s901/b/2/D/iii"},"text":"section 901(b)(2)(D)(iii) of title 2","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd20621c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189h/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":