{"tag":"section","attrib":{"id":"idb5e15f08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294i"},"text":null,"children":[{"tag":"num","attrib":{"value":"294i"},"text":"§ 294i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program for education and training in pain care","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5e15f09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make awards of grants, cooperative agreements, and contracts to health professions schools, hospices, tribal health programs (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1603"},"text":"section 1603 of title 25","children":[],"tail":"), and other public and nonprofit private entities for the development and implementation of programs to provide education and training to health care professionals in pain care."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e15f0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain topics","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity receiving an award under this section shall develop a comprehensive education and training plan that includes information and education on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5e15f0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294i/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recognized means for assessing, diagnosing, preventing, treating, and managing pain and related signs and symptoms, including non-addictive medical products and non-pharmacologic treatments and the medically appropriate use of controlled substances;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e15f0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294i/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applicable Federal, State, and local laws, regulations, rules, and policies on controlled substances, including opioids;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e15f0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294i/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interdisciplinary approaches to the delivery of pain care, including delivery through specialized centers providing comprehensive pain care treatment expertise, integrated, evidence-based pain management, and, as appropriate, non-pharmacotherapy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e15f0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294i/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cultural, linguistic, literacy, geographic, and other barriers to care in underserved populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e15f0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294i/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recent findings, developments, and advancements in pain care research and the provision of pain care, which may include non-addictive medical products and non-pharmacologic treatments intended to treat pain; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e15f10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294i/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the dangers of opioid abuse and misuse, detection of early warning signs of opioid use disorders (which may include best practices related to screening for opioid use disorders, training on screening, brief intervention, and referral to treatment), and safe disposal options for prescription medications (including such options provided by law enforcement or other innovative deactivation mechanisms).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e15f11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294i/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation of programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall (directly or through grants or contracts) provide for the evaluation of programs implemented under subsection (a) in order to determine the effect of such programs on knowledge and practice of pain care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e15f12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294i/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pain care defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section the term “pain care” means the assessment, diagnosis, prevention, treatment, or management of acute or chronic pain regardless of causation or body location.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e15f13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294i/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section, such sums as may be necessary for each of the fiscal years 2019 through 2023. Amounts appropriated under this subsection shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5e15f14-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VII, § 759, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIV/s4305/c"},"text":"Pub. L. 111–148, title IV, § 4305(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/586"},"text":"124 Stat. 586","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/271/tVII/s7073/a"},"text":"Pub. L. 115–271, title VII, § 7073(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4031"},"text":"132 Stat. 4031","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5e15f15-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5e15f16-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5e15f17-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 294i, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tVII/s771"},"text":"act July 1, 1944, ch. 373, title VII, § 771","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/408/tI/s102"},"text":"Pub. L. 102–408, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-13"},"text":"Oct. 13, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2049"},"text":"106 Stat. 2049","children":[],"tail":", authorized grants to educational entities offering programs in health administration, hospital administration, or health policy analysis and planning, prior to the general amendment of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/105/392"},"text":"Pub. L. 105–392","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 294i, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tVII/s736"},"text":"act July 1, 1944, ch. 373, title VII, § 736","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/94/484/tIV/s401/b/3"},"text":"Pub. L. 94–484, title IV, § 401(b)(3)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2265"},"text":"90 Stat. 2265","children":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1977-08-01"},"text":"Aug. 1, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/95/83/tIII/s307/d"},"text":"Pub. L. 95–83, title III, § 307(d)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/390"},"text":"91 Stat. 390","children":[],"tail":", related to participation by Federal credit unions in Federal, State, and private student loan insurance programs, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/102/408"},"text":"Pub. L. 102–408","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s292k"},"text":"section 292k of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 759 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s294aa"},"text":"section 294aa of this title","children":[],"tail":" prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/102/408"},"text":"Pub. L. 102–408","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5e15f18-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s7073/a/1"},"text":"Pub. L. 115–271, § 7073(a)(1)","children":[],"tail":", substituted “hospices, tribal health programs (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1603"},"text":"section 1603 of title 25","children":[],"tail":"), and other public and nonprofit private entities” for “hospices, and other public and private entities”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s7073/a/2/A"},"text":"Pub. L. 115–271, § 7073(a)(2)(A)","children":[],"tail":", substituted “entity receiving an award under this section shall develop a comprehensive education and training plan that includes” for “award may be made under subsection (a) only if the applicant for the award agrees that the program carried out with the award will include” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s7073/a/2/B"},"text":"Pub. L. 115–271, § 7073(a)(2)(B)","children":[],"tail":", inserted “preventing,” after “diagnosing,” and “non-addictive medical products and non-pharmacologic treatments and” after “including”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s7073/a/2/C"},"text":"Pub. L. 115–271, § 7073(a)(2)(C)","children":[],"tail":", inserted “Federal, State, and local” after “applicable” and substituted “opioids” for “the degree to which misconceptions and concerns regarding such laws, regulations, rules, and policies, or the enforcement thereof, may create barriers to patient access to appropriate and effective pain care”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s7073/a/2/D"},"text":"Pub. L. 115–271, § 7073(a)(2)(D)","children":[],"tail":", inserted “, integrated, evidence-based pain management, and, as appropriate, non-pharmacotherapy” before semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s7073/a/2/E"},"text":"Pub. L. 115–271, § 7073(a)(2)(E)","children":[],"tail":", (F), added pars. (5) and (6) and struck out former par. (5) which read as follows: “recent findings, developments, and improvements in the provision of pain care.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s7073/a/3"},"text":"Pub. L. 115–271, § 7073(a)(3)","children":[],"tail":", inserted “prevention,” after “diagnosis,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s7073/a/4"},"text":"Pub. L. 115–271, § 7073(a)(4)","children":[],"tail":", substituted “2019 through 2023” for “2010 through 2012”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5e15f19-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb5e15f1a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Emergency Department Alternatives to Opioids Demonstration Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/tVII/s7091"},"text":"Pub. L. 115–271, title VII, § 7091","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4035"},"text":"132 Stat. 4035","children":[],"tail":", which related to emergency department alternatives to opioids demonstration program, was editorially reclassified as "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s294i–1"},"text":"section 294i–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
