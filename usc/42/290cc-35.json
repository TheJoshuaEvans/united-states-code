{"tag":"section","attrib":{"id":"idb5b8c882-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–35"},"text":null,"children":[{"tag":"num","attrib":{"value":"290cc–35"},"text":"§ 290cc–35.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5b8c883-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–35/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this part, there is authorized to be appropriated $64,635,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b8c884-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–35/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of insufficient appropriations for minimum allotments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5b8c885-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–35/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the amounts made available under subsection (a) for a fiscal year are insufficient for providing each State with an allotment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–21"},"text":"section 290cc–21 of this title","children":[],"tail":" of not less than the applicable amount under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–24/a/1"},"text":"section 290cc–24(a)(1) of this title","children":[],"tail":", the Secretary shall, from such amounts as are made available under such subsection, make grants to the States for providing to eligible homeless individuals the services specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–22/b"},"text":"section 290cc–22(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b8c886-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–35/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) may not be construed to require the Secretary to make a grant under such paragraph to each State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5b8c887-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 535, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/77/tVI/s611/3"},"text":"Pub. L. 100–77, title VI, § 611(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-07-22"},"text":"July 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/523"},"text":"101 Stat. 523","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tVIII/s811/a"},"text":"Pub. L. 100–607, title VIII, § 811(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3169"},"text":"102 Stat. 3169","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/628/tVI/s611/a"},"text":"Pub. L. 100–628, title VI, § 611(a)","children