{"tag":"section","attrib":{"id":"idbd0f999c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5148"},"text":null,"children":[{"tag":"num","attrib":{"value":"5148"},"text":"§ 5148.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonliability of Federal Government","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Federal Government shall not be liable for any claim based upon the exercise or performance of or the failure to exercise or perform a discretionary function or duty on the part of a Federal agency or an employee of the Federal Government in carrying out the provisions of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd0f999d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tIII/s305"},"text":"Pub. L. 93–288, title III, § 305","children":[],"tail":", formerly § 308, "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/149"},"text":"88 Stat. 149","children":[],"tail":"; renumbered § 305, "},{"tag":"ref","attrib":{"href":"/us/pl/100/707/tI/s105/d"},"text":"Pub. L. 100–707, title I, § 105(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4691"},"text":"102 Stat. 4691","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd0f999e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd0f999f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd0f