{"tag":"section","attrib":{"id":"idbdf4a216-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7144e"},"text":null,"children":[{"tag":"num","attrib":{"value":"7144e"},"text":"§ 7144e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Indian Energy Policy and Programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdf4a217-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7144e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Department an Office of Indian Energy Policy and Programs (referred to in this section as the “Office”). The Office shall be headed by a Director, who shall be appointed by the Secretary and compensated at a rate equal to that of level IV of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdf4a218-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7144e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Director","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director, in accordance with Federal policies promoting Indian self-determination and the purposes of this chapter, shall provide, direct, foster, coordinate, and implement energy planning, education, management, conservation, and delivery programs of the Department that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdf4a219-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7144e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote Indian tribal energy development, efficiency, and use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdf4a21a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7144e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce or stabilize energy costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdf4a21b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7144e/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance and strengthen Indian tribal energy and economic infrastructure relating to natural resource development and electrification; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdf4a21c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7144e/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bring electrical power and service to Indian land and the homes of tribal members located on Indian lands or acquired, constructed, or improved (in whole or in part) with Federal funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdf4a21d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/91/tII/s217"},"text":"Pub. L. 95–91, title II, § 217","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tV/s502/a"},"text":"Pub. L. 109–58, title V, § 502(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/763"},"text":"119 Stat. 763","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdf4a21e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdf4a21f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbdf4a220-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/91"},"text":"Pub. L. 95–91","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-04"},"text":"Aug. 4, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/565"},"text":"91 Stat. 565","children":[],"tail":", known as the Department of Energy Organization Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7101"},"text":"section 7101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
