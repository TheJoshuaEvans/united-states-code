{"tag":"section","attrib":{"id":"idc027607c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113"},"text":null,"children":[{"tag":"num","attrib":{"value":"17113"},"text":"§ 17113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Industrial emissions reduction technology development program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc027607d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc027607e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Director” means the Director of the Office of Science and Technology Policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc027607f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0276080-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a scientist or other individual with knowledge and expertise in emissions reduction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276081-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276082-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nongovernmental organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276083-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a National Laboratory;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276084-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a private entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276085-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a partnership or consortium of 2 or more entities described in subparagraphs (B) through (E).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0276086-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emissions reduction","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0276087-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “emissions reduction” means the reduction, to the maximum extent practicable, of net nonwater greenhouse gas emissions to the atmosphere by energy services and industrial processes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276088-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “emissions reduction” does not include the elimination of carbon embodied in the principal products of industrial manufacturing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0276089-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “program” means the program established under subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc027608a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Critical material or mineral","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “critical material or mineral” means a material or mineral that serves an essential function in the manufacturing of a product and has a high risk of a supply disruption, such that a shortage of such a material or mineral would have significant consequences for United States economic or national security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc027608b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Industrial emissions reduction technology development program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc027608c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary, in consultation with the Director, the heads of relevant Federal agencies, National Laboratories, industry, and institutions of higher education, shall establish a crosscutting industrial emissions reduction technology development program of research, development, demonstration, and commercial application to advance innovative technologies that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc027608d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the technological and economic competitiveness of industry and manufacturing in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc027608e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the viability and competitiveness of United States industrial technology exports; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc027608f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achieve emissions reduction in nonpower industrial sectors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0276090-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0276091-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with each relevant office in the Department and any other Federal agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276092-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate and collaborate with the Industrial Technology Innovation Advisory Committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17115"},"text":"section 17115 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276093-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate and seek to avoid duplication with the Future of Industry ","children":[{"tag":"ref","attrib":{"idref":"fn004250"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004250"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" program established under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s17111"},"text":"section 17111 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0276094-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leverage of existing resources","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program, the Secretary shall leverage, to the maximum extent practicable—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0276095-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing resources and programs of the Department and other relevant Federal agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276096-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public-private partnerships.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0276097-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Focus areas","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program shall focus on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0276098-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" industrial production processes, including technologies and processes that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0276099-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achieve emissions reduction in high emissions industrial materials production processes, including production processes for iron, steel, steel mill products, aluminum, cement, concrete, glass, pulp, paper, and industrial ceramics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc027609a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" achieve emissions reduction in medium- and high-temperature heat generation, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc027609b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through electrification of heating processes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc027609c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through renewable heat generation technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc027609d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through combined heat and power; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc027609e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/c/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by switching to alternative fuels, including hydrogen and nuclear energy;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc027609f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achieve emissions reduction in chemical production processes, including by incorporating, if appropriate and practicable, principles, practices, and methodologies of sustainable chemistry and engineering;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02760a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" leverage smart manufacturing technologies and principles, digital manufacturing technologies, and advanced data analytics to develop advanced technologies and practices in information, automation, monitoring, computation, sensing, modeling, and networking to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc02760a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/c/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" model and simulate manufacturing production lines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc02760a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/c/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor and communicate production line status;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc02760a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/c/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manage and optimize energy productivity and cost throughout production; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc02760a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/c/1/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" model, simulate, and optimize the energy efficiency of manufacturing processes;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02760a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" leverage the principles of sustainable manufacturing to minimize the potential negative environmental impacts of manufacturing while conserving energy and resources, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc02760a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/c/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by designing products that enable reuse, refurbishment, remanufacturing, and recycling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc02760a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/c/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by minimizing waste from industrial processes, including through the reuse of waste as other resources in other industrial processes for mutual benefit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc02760a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/c/1/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by increasing resource efficiency; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02760a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the energy efficiency of industrial processes;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02760aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" alternative materials that produce fewer emissions during production and result in fewer emissions during use, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02760ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" high-performance lightweight materials; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02760ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substitutions for critical materials and minerals;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02760ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of net-zero emissions liquid and gaseous fuels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02760ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emissions reduction in shipping, aviation, and long distance transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02760af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carbon capture technologies for industrial processes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02760b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other technologies that achieve net-zero emissions in nonpower industrial sectors, as determined by the Secretary, in consultation with the Director; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02760b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" high-performance computing to develop advanced materials and manufacturing processes contributing to the focus areas described in paragraphs (1) through (6), including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02760b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/c/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modeling, simulation, and optimization of the design of energy efficient and sustainable products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02760b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/c/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of digital prototyping and additive manufacturing to enhance product design.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02760b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporation of sustainable chemistry and engineering principles, practices, and methodologies, as the Secretary determines appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02760b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other research or technology areas identified in the Strategic Plan authorized in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17114"},"text":"section 17114 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02760b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants, contracts, cooperative agreements, and demonstration projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc02760b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the program, the Secretary shall award grants on a competitive basis to eligible entities for projects that the Secretary determines would best achieve the goals of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02760b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts and cooperative agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the program, the Secretary may enter into contracts and cooperative agreements with eligible entities and Federal agencies for projects that the Secretary determines would further the purposes of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02760b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In supporting technologies developed under this section, the Secretary shall fund demonstration projects that test and validate technologies described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02760ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An entity seeking funding or a contract or agreement under this subsection shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02760bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding funds under this section, the Secretary shall require cost sharing in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16352"},"text":"section 16352 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02760bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Secretary to carry out the demonstration projects authorized in subsection (d)(3)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc02760bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for fiscal year 2021;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02760be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $80,000,000 for fiscal year 2022;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02760bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000,000 for fiscal year 2023;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02760c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $150,000,000 for fiscal year 2024; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02760c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $150,000,000 for fiscal year 2025.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02760c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out the activities authorized in this section in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18631"},"text":"section 18631 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc02760c3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIV/s454"},"text":"Pub. L. 110–140, title IV, § 454","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tVI/s6003/a"},"text":"Pub. L. 116–260, div. Z, title VI, § 6003(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2553"},"text":"134 Stat. 2553","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tV/s40521/a/2"},"text":"Pub. L. 117–58, div. D, title V, § 40521(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1062"},"text":"135 Stat. 1062","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc02760c4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc02760c5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc02760c6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" substituted “Future of Industry” for “energy-intensive industries”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc02760c7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc02760c8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc02760c9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Purpose","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tVI/s6001"},"text":"Pub. L. 116–260, div. Z, title VI, § 6001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2552"},"text":"134 Stat. 2552","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/260/dZ/tVI/s6001"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The purpose of this title [enacting this section and sections 17114 to 17115a of this title and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6351"},"text":"section 6351 of this title","children":[],"tail":"] and the amendments made by this title is to encourage the development and evaluation of innovative technologies aimed at increasing—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the technological and economic competitiveness of industry and manufacturing in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the emissions reduction of nonpower industrial sectors.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
