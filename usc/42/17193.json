{"tag":"section","attrib":{"id":"idc02c1bf3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17193"},"text":null,"children":[{"tag":"num","attrib":{"value":"17193"},"text":"§ 17193.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General geothermal systems research and development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc02c1bf4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17193/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsurface components and systems","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall support a program of research, development, demonstration, and commercial application of components and systems capable of withstanding geothermal environments and necessary to develop, produce, and monitor geothermal reservoirs and produce geothermal energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02c1bf5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17193/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental impacts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc02c1bf6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17193/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support a program of research, development, demonstration, and commercial application of technologies and practices designed to mitigate or preclude potential adverse environmental impacts of geothermal energy development, production or use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1bf7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17193/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support a research program to identify potential environmental impacts, including induced seismicity, and environmental benefits of geothermal energy development, production, and use, and ensure that the program described in paragraph (1) addresses such impacts, including water use and effects on groundwater and local hydrology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1bf8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17193/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support a program of research to compare the potential environmental impacts and environmental benefits identified as part of the development, production, and use of geothermal energy with the potential emission reductions of greenhouse gases gained by geothermal energy development, production, and use; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1bf9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17193/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in carrying out this section, the Secretary shall,","children":[{"tag":"ref","attrib":{"idref":"fn004263"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004263"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The words “The Secretary shall” appear in introductory provisions."}],"tail":" to the maximum extent practicable, consult with relevant federal agencies, including the Environmental Protection Agency."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02c1bfa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17193/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservoir thermal energy storage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall support a program of research, development, and demonstration of reservoir thermal energy storage, emphasizing cost-effective improvements through deep direct use engineering, design, and systems research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02c1bfb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17193/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oil and gas technology transfer initiative","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc02c1bfc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17193/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall support an initiative among the Office of Fossil Energy, the Office of Energy Efficiency and Renewable Energy, and the private sector to research, develop, and demonstrate relevant advanced technologies and operation techniques used in the oil and gas sector for use in geothermal energy development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1bfd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17193/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out paragraph (1), the Secretary shall prioritize technologies with the greatest potential to significantly increase the use and lower the cost of geothermal energy in the United States, including the cost and speed of geothermal drilling surface technologies, large- and small-scale drilling, and well construction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02c1bfe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17193/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coproduction of geothermal energy and minerals production research and development initiative","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc02c1bff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17193/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out a research and development initiative under which the Secretary shall provide financial assistance to demonstrate the coproduction of critical minerals from geothermal resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1c00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17193/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An award made under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02c1c01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17193/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the cost effectiveness of removing minerals from geothermal brines as part of the coproduction process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1c02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17193/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase recovery rates of the targeted mineral commodity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1c03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17193/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" decrease water use and other environmental impacts, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1c04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17193/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate a path to commercial viability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02c1c05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17193/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Flexible operations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall support a research initiative on flexible operation of geothermal power plants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02c1c06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17193/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integrated energy systems","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall identify opportunities for joint research, development, and demonstration programs between geothermal systems and other energy generation or storage systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02c1c07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17193/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drilling data repository","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc02c1c08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17193/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, in consultation with the Secretary of the Interior, establish and operate a voluntary, industry-wide repository of geothermal drilling information to lower the cost of future geothermal drilling.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1c09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17193/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repository","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02c1c0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17193/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out paragraph (1), the Secretary shall collaborate with countries utilizing a significant amount of geothermal energy, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1c0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17193/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The repository established under paragraph (1) shall be integrated with the National Geothermal Data System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc02c1c0c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tVI/s614"},"text":"Pub. L. 110–140, title VI, § 614","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1680"},"text":"121 Stat. 1680","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tIII/s3002/c"},"text":"Pub. L. 116–260, div. Z, title III, § 3002(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2488"},"text":"134 Stat. 2488","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc02c1c0d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc02c1c0e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc02c1c0f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" amended section generally. Prior to amendment, section related to general geothermal systems research and development."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc02c1c10-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc02c1c11-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
