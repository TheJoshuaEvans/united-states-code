{"tag":"section","attrib":{"id":"idc07ad78b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108"},"text":null,"children":[{"tag":"num","attrib":{"value":"19108"},"text":"§ 19108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional Innovation Engines","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc07ad78c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From amounts made available to the Directorate, the Director shall make awards to eligible entities for the planning, establishment, and support of Regional Innovation Engines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07ad78d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of the Regional Innovation Engines shall be to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc07ad78e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advance multidisciplinary, collaborative, use-inspired and translational research, technology development, in key technology focus areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07ad78f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address regional, national, societal, or geostrategic challenges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07ad790-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leverage the expertise of multi-disciplinary and multi-sector partners, including partners from private industry, nonprofit organizations, and civil society organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07ad791-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the development of scientific, innovation, entrepreneurial, and STEM educational capacity within the region of the Regional Innovation Engine to grow and sustain regional innovation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07ad792-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds awarded under this section may be used by a Regional Innovation Engine to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc07ad793-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct use-inspired and translational research and technology development to advance innovation in at least one of the key technology focus areas and to help solve a compelling regional, national, societal, or geostrategic challenge;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07ad794-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" further the development, adoption, and commercialization of innovations in key technology focus areas, including through support for proof-of-concept development, and through partnership with other Federal agencies and Federal laboratories, industry, including startup companies, labor organizations, civil society organizations, and State, territorial, local, and Tribal governments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07ad795-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and manage, or facilitate access to, test beds and instrumentation, which may include fabrication facilities and cyberinfrastructure, to advance the development, integration, and demonstration of new, innovative technologies, including hardware or software;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07ad796-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish traineeship programs for graduate students who pursue degrees and research related to the key technology focus areas leading to a masters or doctorate degree by providing funding and other assistance, and opportunities for research experiences in government or industry related to the students’ studies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07ad797-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage in outreach and engagement in the region to broaden participation in the activities of the Regional Innovation Engine; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07ad798-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reimburse, in part or in whole, the cost of instrumentation, technology transfer, and commercialization activities, including patenting and licensing, and for operations and staff, as the Director determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07ad799-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection process","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making awards under this part, the Director shall consider, in addition to the scientific and technical merit of the proposal, the extent to which the activities and locations proposed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc07ad79a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the potential to create an innovation ecosystem, or enhance existing ecosystems and contribute to job creation in a region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07ad79b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate a capacity to engage and partner with multiple types of institutions of higher education, industry, labor, nonprofit organizations, civil society organizations, other Federal agencies, Federal laboratories, State, local, and Tribal governments, and other appropriate organizations, including to inform research directions and account for ethical, societal, safety, and security implications relevant to the potential applications of the research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07ad79c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate a capacity to broaden participation of populations historically underrepresented in STEM in the activities of the Regional Innovation Engine; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07ad79d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate a plan and capability to prevent the inappropriate use or dissemination of the research and technology, including research results, data, and intellectual property, as appropriate and consistent with the requirements of the relevant award.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07ad79e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc07ad79f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of this section, an “eligible entity” means an institution of higher education, a nonprofit organization, a private sector entity, or a consortium thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07ad7a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for an award under this section an eligible entity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc07ad7a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall include in its proposal partnership with 1 or more institution that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc07ad7a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a historically Black college or university;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc07ad7a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Tribal College or University;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc07ad7a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/e/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a minority-serving institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc07ad7a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/e/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an EPSCoR institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc07ad7a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/e/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an emerging research institution; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc07ad7a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/e/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a community college;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc07ad7a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may include partnership with 1 or more—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc07ad7a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" additional entities described in paragraph (2)(A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc07ad7aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" industry entities, including startups, small businesses, and public-private partnerships;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc07ad7ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/e/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" economic development organizations or venture development organizations, as such terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3722a/a"},"text":"section 3722a(a) of title 15","children":[],"tail":", as added by section 10621 of this division;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc07ad7ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/e/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" National Laboratories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc07ad7ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/e/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal laboratories, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3703"},"text":"section 3703 of title 15","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc07ad7ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/e/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal research facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc07ad7af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/e/2/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" labor organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc07ad7b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/e/2/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entities described in paragraph (1) or (2) from allied or partner countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc07ad7b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/e/2/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other entities to be vital to the success of the program, as determined by the Director;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc07ad7b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/e/2/B/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" binational research and development foundations and funds, excluding those affiliated with foreign entities of concern, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s19221"},"text":"section 19221 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc07ad7b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/e/2/B/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Engineer Research and Development Center laboratories of the Army Corps of Engineers; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc07ad7b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall include as part of its proposal a plan for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc07ad7b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/e/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing a sustained partnership that is jointly developed and managed, draws from the capacities of each institution, and is mutually beneficial; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc07ad7b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/e/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" documents governance and management plans, financial contributions from non-Federal sources, and plans for ownership and use of any intellectual property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07ad7b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promoting partnerships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making awards under this section, the Director shall encourage applicants for a Regional Innovation Engine that include multiple regional partners as described in subsection (e)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07ad7b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographic distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making awards under this section, the Director shall take into consideration the extent to which the proposals expand the geographic distribution of the Regional Innovation Engines, including by giving special consideration to rural-serving institutions of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07ad7b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resource availability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall ensure that any eligible entity receiving an award under this section shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc07ad7ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/e/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide information on relevant currently existing resources available to the proposing team from all internal and external sources, including all partner organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc07ad7bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/e/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include letters of collaboration from partner organizations that include information on resource contributions committed by such partners.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07ad7bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaboration with regional technology hubs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Regional Innovation Engine established under this section may collaborate and participate in, as appropriate, the activities of any regional technology hub designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3722a"},"text":"section 3722a of title 15","children":[],"tail":", as added by section 10621."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07ad7bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc07ad7be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An award under this section shall be for an initial period of 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07ad7bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An established Regional Innovation Engine may apply for, and the Director may award, extended funding for periods of 5 years on a merit-reviewed basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07ad7c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive, merit-review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making awards under this section, the Director shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc07ad7c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use a competitive, merit review process that includes peer review by a diverse group of individuals with relevant expertise from both the private and public sectors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07ad7c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure the focus areas of the Regional Innovation Engines do not substantially and unnecessarily duplicate the efforts of any other Regional Innovation Engine or any other similar effort at another Federal agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07ad7c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19108/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaboration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making awards under this section, the Director may collaborate with Federal departments and agencies whose missions contribute to or are affected by the technology focus area of the institute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc07ad7c4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tIII/s10388"},"text":"Pub. L. 117–167, div. B, title III, § 10388","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1581"},"text":"136 Stat. 1581","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc07ad7c5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc07ad7c6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc07ad7c7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 10621 of this division and section 10621, referred to in subsecs. (e)(2)(B)(iii) and (f), mean ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/s10621"},"text":"section 10621 of div. B of Pub. L. 117–167","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
