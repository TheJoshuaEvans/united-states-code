xt","id":"idbbc42d14-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1219"},"text":"Section 1219 of title 2","children":[],"tail":", referred to in text, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/104/331/s5/a"},"text":"Pub. L. 104–331, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4072"},"text":"110 Stat. 4072","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbbc42d15-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Government Employee Rights Act of 1991, and not as part of the Civil Rights Act of 1964, title VII of which comprises this subchapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1202"},"text":"section 1202 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbbc42d16-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1"},"text":"Pub. L. 104–1","children":[],"tail":" amended section generally. Prior to amendment, text read as follows: “All personnel actions affecting employees of the Senate shall be made free from any discrimination based on—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) race, color, religion, sex, or national origin, within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e–16"},"text":"section 2000e–16 of this title","children":[],"tail":";"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) age, within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s633a"},"text":"section 633a of title 29","children":[],"tail":"; or"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) handicap or disability, within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s791"},"text":"section 791 of title 29","children":[],"tail":" and sections 12112 to 12114 of this title.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbbc42d17-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbbc42d18-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1991-11-21"},"text":"Nov. 21, 1991","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/102/166/s402"},"text":"section 402 of Pub. L. 102–166","children":[],"tail":", set out as an Effective Date of 1991 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1981"},"text":"section 1981 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
