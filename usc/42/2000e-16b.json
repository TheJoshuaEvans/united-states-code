b":{},"text":" age, within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s633a"},"text":"section 633a of title 29","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbc42d0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000e–16b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disability, within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s791"},"text":"section 791 of title 29","children":[],"tail":" and sections 12112 to 12114 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbc42d0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000e–16b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remedies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The remedies referred to in sections 1219(a)(1) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of title 2 and 2000e–16c(a) of this title—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbc42d0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000e–16b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include, in the case of a determination that a violation of subsection (a)(1) or (a)(3) has occurred, such remedies as would be appropriate if awarded under sections 2000e–5(g), 2000e–5(k), and 2000e–16(d) of this title, and such compensatory damages as would be appropriate if awarded under section 1981 or sections 1981a(a) and 1981a(b)(2) of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbc42d0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000e–16b/b/2"},"text":null,"childr