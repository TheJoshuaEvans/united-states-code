{"tag":"section","attrib":{"id":"idb5d7c1d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293b"},"text":null,"children":[{"tag":"num","attrib":{"value":"293b"},"text":"§ 293b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan repayments and fellowships regarding faculty positions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5d7c1d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan repayments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5d7c1d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program of entering into contracts with individuals described in paragraph (2) under which the individuals agree to serve as members of the faculties of schools described in paragraph (3) in consideration of the Federal Government agreeing to pay, for each year of such service, not more than $30,000 of the principal and interest of the educational loans of such individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5d7c1d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible individuals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The individuals referred to in paragraph (1) are individuals from disadvantaged backgrounds who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5d7c1d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293b/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a degree in medicine, osteopathic medicine, dentistry, nursing, or another health profession;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5d7c1d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293b/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are enrolled in an approved graduate training program in medicine, osteopathic medicine, dentistry, nursing, or other health profession; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5d7c1da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293b/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" are enrolled as full-time students—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5d7c1db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293b/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in an accredited (as determined by the Secretary) school described in paragraph (3); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5d7c1dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293b/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the final year of a course of a study or program, offered by such institution and approved by the Secretary, leading to a degree from such a school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5d7c1dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible health professions schools","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The schools described in this paragraph are schools of medicine, nursing (as schools of nursing are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s296"},"text":"section 296 of this title","children":[],"tail":"), osteopathic medicine, dentistry, pharmacy, allied health, podiatric medicine, optometry, veterinary medicine, or public health, schools offering physician assistant education programs, or schools offering graduate programs in behavioral and mental health."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5d7c1de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements regarding faculty positions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not enter into a contract under paragraph (1) unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5d7c1df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293b/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual involved has entered into a contract with a school described in paragraph (3) to serve as a member of the faculty of the school for not less than 2 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5d7c1e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293b/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the contract referred to in subparagraph (A) provides that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5d7c1e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293b/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the school will, for each year for which the individual will serve as a member of the faculty under the contract with the school, make payments of the principal and interest due on the educational loans of the individual for such year in an amount equal to the amount of such payments made by the Secretary for the year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5d7c1e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293b/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the payments made by the school pursuant to clause (i) on behalf of the individual will be in addition to the pay that the individual would otherwise receive for serving as a member of such faculty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5d7c1e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293b/a/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the school, in making a determination of the amount of compensation to be provided by the school to the individual for serving as a member of the faculty, will make the determination without regard to the amount of payments made (or to be made) to the individual by the Federal Government under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5d7c1e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293b/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of certain provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of sections 254m, 254p, and 254q–1 of this title shall apply to the program established in paragraph (1) to the same extent and in the same manner as such provisions apply to the National Health Service Corps Loan Repayment Program established in subpart III of part D of subchapter II, including the applicability of provisions regarding reimbursements for increased tax liability and regarding bankruptcy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5d7c1e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293b/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver regarding school contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may waive the requirement established in paragraph (4)(B) if the Secretary determines that the requirement will impose an undue financial hardship on the school involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5d7c1e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fellowships","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5d7c1e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make grants to and enter into contracts with eligible entities to assist such entities in increasing the number of underrepresented minority individuals who are members of the faculty of such schools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5d7c1e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant or contract under this subsection, an entity shall provide an assurance, in the application submitted by the entity, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5d7c1e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts received under such a grant or contract will be used to award a fellowship to an individual only if the individual meets the requirements of paragraphs (3) and (4); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5d7c1ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" each fellowship awarded pursuant to the grant or contract will include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5d7c1eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293b/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a stipend in an amount not exceeding 50 percent of the regular salary of a similar faculty member for not to exceed 3 years of training; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5d7c1ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293b/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an allowance for other expenses, such as travel to professional meetings and costs related to specialized training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5d7c1ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant or contract under paragraph (1), an applicant shall demonstrate to the Secretary that such applicant has or will have the ability to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5d7c1ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293b/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify, recruit and select underrepresented minority individuals who have the potential for teaching, administration, or conducting research at a health professions institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5d7c1ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293b/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide such individuals with the skills necessary to enable them to secure a tenured faculty position at such institution, which may include training with respect to pedagogical skills, program administration, the design and conduct of research, grants writing, and the preparation of articles suitable for publication in peer reviewed journals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5d7c1f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293b/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide services designed to assist such individuals in their preparation for an academic career, including the provision of counselors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5d7c1f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293b/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide health services to rural or medically underserved populations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5d7c1f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant or contract under paragraph (1) an applicant shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5d7c1f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293b/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an assurance that such applicant will make available (directly through cash donations) $1 for every $1 of Federal funds received under this section for the fellowship;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5d7c1f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293b/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an assurance that institutional support will be provided for the individual for the second and third years at a level that is equal to the total amount of institutional funds provided in the year in which the grant or contract was awarded;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5d7c1f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293b/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an assurance that the individual that will receive the fellowship will be a member of the faculty of the applicant school; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5d7c1f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293b/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an assurance that the individual that will receive the fellowship will have, at a minimum, appropriate advanced preparation (such as a master’s or doctoral degree) and special skills necessary to enable such individual to teach and practice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5d7c1f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293b/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “underrepresented minority individuals” means individuals who are members of racial or ethnic minority groups that are underrepresented in the health professions including nursing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5d7c1f8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VII, § 738, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/392/tI/s101/a"},"text":"Pub. L. 105–392, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3532"},"text":"112 Stat. 3532","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tV/s5402/a"},"text":"Pub. L. 111–148, title V, § 5402(a)","children":[],"tail":", title X, § 10501(d), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/644"},"text":"124 Stat. 644","children":[],"tail":", 995.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5d7c1f9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5d7c1fa-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb5d7c1fb-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subpart III of part D of subchapter II, referred to in subsec. (a)(5), is classified to section 254","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" et seq. of this title."}]