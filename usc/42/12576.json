{"tag":"section","attrib":{"id":"idbf7945f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12576"},"text":null,"children":[{"tag":"num","attrib":{"value":"12576"},"text":"§ 12576.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other special assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf7945f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12576/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support for State Commissions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf7945fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12576/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From amounts appropriated for a fiscal year pursuant to the authorization of appropriation in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12681/a/5"},"text":"section 12681(a)(5) of this title","children":[],"tail":", the Corporation may make a grant in an amount between $250,000 and $1,000,000 to a State to assist the State to establish or operate the State Commission on National and Community Service required to be established by the State under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12638"},"text":"section 12638 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7945fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12576/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making a grant to a State under this subsection, the Corporation shall require the State to agree to provide matching funds from non-Federal sources of not less than $1 for every $1 provided by the Corporation through the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7945fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12576/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding paragraph (2), the Chief Executive Officer may permit a State that demonstrates hardship or a new State Commission to meet alternative matching requirements for such a grant as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf7945fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12576/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First $100,000","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the first $100,000 of grant funds provided by the Corporation, the State involved shall not be required to provide matching funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7945fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12576/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts greater than $100,000","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For grant amounts of more than $100,000 and not more than $250,000 provided by the Corporation, the State shall agree to provide matching funds from non-Federal sources of not less than $1 for every $2 provided by the Corporation, in excess of $100,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7945ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12576/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts greater than $250,000","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For grant amounts of more than $250,000 provided by the Corporation, the State shall agree to provide matching funds from non-Federal sources of not less than $1 for every $1 provided by the Corporation, in excess of $250,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf794600-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12576/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disaster service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation may undertake activities, including activities carried out through part A of title I of the Domestic Volunteer Service Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4951"},"text":"42 U.S.C. 4951","children":[],"tail":" et seq.), to involve programs that receive assistance under the national service laws in disaster relief efforts, and to support, including through mission assignments under the Robert T. Stafford Disaster Relief and Emergency Assistance Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"42 U.S.C. 5121","children":[],"tail":" et seq.), nonprofit organizations and public agencies responding to the needs of communities experiencing disasters."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf794601-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12576/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Challenge grants for national service programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf794602-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12576/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation may make challenge grants under this subsection to programs supported under the national service laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf794603-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12576/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corporation shall develop criteria for the selection of recipients of challenge grants under this subsection, so as to make the grants widely available to a variety of programs that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf794604-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12576/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are high-quality national service programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf794605-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12576/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are carried out by entities with demonstrated experience in establishing and implementing projects that provide benefits to participants and communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf794606-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12576/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A challenge grant under this subsection may provide, for an initial 3-year grant period, not more than $1 of assistance under this subsection for each $1 in cash raised from private sources by the program supported under the national service laws in excess of amounts required to be provided by the program to satisfy matching funds requirements. After an initial 3-year grant period, a grant under this subsection may provide not more than $1 of assistance under this subsection for each $2 in cash raised from private sources by the program in excess of amounts required to be provided by the program to satisfy matching funds requirements. The Corporation may permit the use of local or State funds under this paragraph in lieu of cash raised from private sources if the Corporation determines that such use would be equitable due to a lack of available private funds at the local level. The Corporation shall establish a ceiling on the amount of assistance that may be provided to a national service program under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf794607-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s126"},"text":"Pub. L. 101–610, title I, § 126","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s101/b"},"text":"Pub. L. 103–82, title I, § 101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/795"},"text":"107 Stat. 795","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1305"},"text":"Pub. L. 111–13, title I, § 1305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1500"},"text":"123 Stat. 1500","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf794608-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf794609-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf79460a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Domestic Volunteer Service Act of 1973, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/113"},"text":"Pub. L. 93–113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-10-01"},"text":"Oct. 1, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/394"},"text":"87 Stat. 394","children":[],"tail":". Part A of title I of the Act is classified generally to part A (§ 4951 et seq.) of subchapter I of chapter 66 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Robert T. Stafford Disaster Relief and Emergency Assistance Act, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288"},"text":"Pub. L. 93–288","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/143"},"text":"88 Stat. 143","children":[],"tail":", which is classified principally to chapter 68 (§ 5121 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf79460b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 12576 to 12580, which related to national and community service, were omitted in the general amendment of subtitle D of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610"},"text":"Pub. L. 101–610","children":[],"tail":" [former part D of this subchapter] by "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s102/a"},"text":"Pub. L. 103–82, § 102(a)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 12576, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s146"},"text":"Pub. L. 101–610, title I, § 146","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3153"},"text":"104 Stat. 3153","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/10/s6/b"},"text":"Pub. L. 102–10, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-03-12"},"text":"Mar. 12, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/31"},"text":"105 Stat. 31","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tXV/s1557"},"text":"Pub. L. 102–325, title XV, § 1557","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/841"},"text":"106 Stat. 841","children":[],"tail":", related to post-service benefits."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/s126"},"text":"section 126 of Pub. L. 101–610","children":[],"tail":" was renumbered section 199F and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12655e"},"text":"section 12655e of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 12577, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s147"},"text":"Pub. L. 101–610, title I, § 147","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3154"},"text":"104 Stat. 3154","children":[],"tail":", related to living allowances for participants."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 12578, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s148"},"text":"Pub. L. 101–610, title I, § 148","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3155"},"text":"104 Stat. 3155","children":[],"tail":", related to training of participants."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 12579, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s149"},"text":"Pub. L. 101–610, title I, § 149","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3156"},"text":"104 Stat. 3156","children":[],"tail":", related to cooperation between public and private entities."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 12580, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s150"},"text":"Pub. L. 101–610, title I, § 150","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3156"},"text":"104 Stat. 3156","children":[],"tail":", related to in-service education benefits."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf79460c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1305/1/A"},"text":"Pub. L. 111–13, § 1305(1)(A)","children":[],"tail":", substituted “$250,000 and $1,000,000” for “$125,000 and $750,000” and “12681(a)(5)” for “12681(a)(4)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1305/1/B"},"text":"Pub. L. 111–13, § 1305(1)(B)","children":[],"tail":", added pars. (2) and (3) and struck out former par. (2). Text of former par. (2) read as follows: “Notwithstanding the amounts specified in paragraph (1), the amount of a grant that may be provided to a State Commission under this subsection, together with other Federal funds available to establish or operate the State Commission, may not exceed—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) 85 percent of the total cost to establish or operate the State Commission for the first year for which the State Commission receives assistance under this subsection; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) such smaller percentage of such cost as the Corporation may establish for the second, third, and fourth years of such assistance in order to ensure that the Federal share does not exceed 50 percent of such costs for the fifth year, and any subsequent year, for which the State Commission receives assistance under this subsection.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1305/2"},"text":"Pub. L. 111–13, § 1305(2)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b). Prior to amendment, text read as follows: “The Corporation may undertake activities, including activities carried out through part A of title I of the Domestic Volunteer Service Act of 1973 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4951"},"text":"42 U.S.C. 4951","children":[],"tail":" et seq.), to involve in disaster relief efforts youth corps programs described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12572/a/2"},"text":"section 12572(a)(2) of this title","children":[],"tail":" and other programs that receive assistance under the national service laws.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1305/3/A"},"text":"Pub. L. 111–13, § 1305(3)(A)","children":[],"tail":", substituted “to programs supported under the national service laws” for “to national service programs that receive assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12571"},"text":"section 12571 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1305/3/B"},"text":"Pub. L. 111–13, § 1305(3)(B)","children":[],"tail":", added par. (3) and struck out former par. (3). Prior to amendment, text read as follows: “A challenge grant under this subsection may provide not more than $1 of assistance under this subsection for each $1 in cash raised by the national service program from private sources in excess of amounts required to be provided by the program to satisfy matching funds requirements under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12571/e"},"text":"section 12571(e) of this title","children":[],"tail":". The Corporation shall establish a ceiling on the amount of assistance that may be provided to a national service program under this subsection.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf79460d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf79460e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13"},"text":"Pub. L. 111–13","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s6101/a"},"text":"section 6101(a) of Pub. L. 111–13","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf79460f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1993-10-01"},"text":"Oct. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s123"},"text":"section 123 of Pub. L. 103–82","children":[],"tail":", set out as an Effective Date of 1993 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1701"},"text":"section 1701 of Title 16","children":[],"tail":", Conservation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
