{"tag":"section","attrib":{"id":"idbd206256-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5192"},"text":null,"children":[{"tag":"num","attrib":{"value":"5192"},"text":"§ 5192.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal emergency assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd206257-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5192/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any emergency, the President may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd206258-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5192/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct any Federal agency, with or without reimbursement, to utilize its authorities and the resources granted to it under Federal law (including personnel, equipment, supplies, facilities, and managerial, technical and advisory services) in support of State and local emergency assistance efforts to save lives, protect property and public health and safety, and lessen or avert the threat of a catastrophe, including precautionary evacuations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd206259-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5192/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate all disaster relief assistance (including voluntary assistance) provided by Federal agencies, private organizations, and State and local governments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd20625a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5192/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide technical and advisory assistance to affected State and local governments for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd20625b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5192/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the performance of essential community services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd20625c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5192/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issuance of warnings of risks or hazards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd20625d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5192/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public health and safety information, including dissemination of such information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd20625e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5192/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provision of health and safety measures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd20625f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5192/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" management, control, and reduction of immediate threats to public health and safety;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd206260-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5192/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide emergency assistance through Federal agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd206261-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5192/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remove debris in accordance with the terms and conditions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5173"},"text":"section 5173 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd206262-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5192/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide assistance in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5174"},"text":"section 5174 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5183"},"text":"section 5183 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd206263-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5192/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist State and local governments in the distribution of medicine, food, and other consumable supplies, and emergency assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd206264-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5192/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide accelerated Federal assistance and Federal support where necessary to save lives, prevent human suffering, or mitigate severe damage, which may be provided in the absence of a specific request and in which case the President—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd206265-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5192/a/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall, to the fullest extent practicable, promptly notify and coordinate with a State in which such assistance or support is provided; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd206266-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5192/a/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not, in notifying and coordinating with a State under subparagraph (A), delay or impede the rapid deployment, use, and distribution of critical resources to victims of an emergency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd206267-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5192/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever the Federal assistance provided under subsection (a) with respect to an emergency is inadequate, the President may also provide assistance with respect to efforts to save lives, protect property and public health and safety, and lessen or avert the threat of a catastrophe, including precautionary evacuations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd206268-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5192/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall promulgate and maintain guidelines to assist Governors in requesting the declaration of an emergency in advance of a natural or man-made disaster (including for the purpose of seeking assistance with special needs and other evacuation efforts) under this section by defining the types of assistance available to affected States and the circumstances under which such requests are likely to be approved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd206269-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tV/s502"},"text":"Pub. L. 93–288, title V, § 502","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/707/tI/s107/a"},"text":"Pub. L. 100–707, title I, § 107(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4706"},"text":"102 Stat. 4706","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/390/tII/s206/b"},"text":"Pub. L. 106–390, title II, § 206(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1570"},"text":"114 Stat. 1570","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s681/b"},"text":"Pub. L. 109–295, title VI, § 681(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1444"},"text":"120 Stat. 1444","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dG/tLXXIII/s7321/a"},"text":"Pub. L. 117–263, div. G, title LXXIII, § 7321(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3691"},"text":"136 Stat. 3691","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd20626a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd20626b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd20626c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" inserted “and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5183"},"text":"section 5183 of this title","children":[],"tail":"” after “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5174"},"text":"section 5174 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/s681/b/1/A"},"text":"Pub. L. 109–295, § 681(b)(1)(A)","children":[],"tail":", inserted “, including precautionary evacuations” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/s681/b/1/B"},"text":"Pub. L. 109–295, § 681(b)(1)(B)","children":[],"tail":"–(D), added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/s681/b/2"},"text":"Pub. L. 109–295, § 681(b)(2)","children":[],"tail":", inserted “, including precautionary evacuations” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/s681/b/3"},"text":"Pub. L. 109–295, § 681(b)(3)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/390"},"text":"Pub. L. 106–390","children":[],"tail":" struck out “temporary housing” after “provide”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd20626d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd20626e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dG/tLXXIII/s7321/b"},"text":"Pub. L. 117–263, div. G, title LXXIII, § 7321(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3691"},"text":"136 Stat. 3691","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dG/tLXXIII/s7321/b"},"text":"“The amendment made by subsection (a) [amending this section] shall only apply to amounts appropriated on or after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd20626f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/390"},"text":"Pub. L. 106–390","children":[],"tail":" effective 18 months after "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/390/s206/d"},"text":"section 206(d) of Pub. L. 106–390","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5174"},"text":"section 5174 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
