{"tag":"section","attrib":{"id":"idbc1ed069-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2306"},"text":null,"children":[{"tag":"num","attrib":{"value":"2306"},"text":"§ 2306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualification to purchase","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No officer or employee of the Commission or of any other Federal agency (including officers and members of the Armed Forces) shall be disqualified from purchasing any property or exercising any right or privilege under this chapter, but no such officer or employee shall make any determination as to his own eligibility or priority, or as to valuation, price, or terms of sale and financing of property sold to him.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc1ed06a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-08-04/ch543"},"text":"Aug. 4, 1955, ch. 543","children":[],"tail":", ch. 11, § 112, "},{"tag":"ref","attrib":{"href":"/us/stat/69/483"},"text":"69 Stat. 483","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc1ed06b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc1ed06c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbc1ed06d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Atomic Energy Commission abolished and functions transferred by sections 5814 and 5841 of this title. See also Transfer of Functions notes set out under those sections.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
