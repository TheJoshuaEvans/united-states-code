{"tag":"section","attrib":{"id":"idbc7247aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3143"},"text":null,"children":[{"tag":"num","attrib":{"value":"3143"},"text":"§ 3143.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for planning and grants for administrative expenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc7247ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3143/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the application of an eligible recipient, the Secretary may make grants to pay the costs of economic development planning and the administrative expenses of organizations that carry out the planning.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc7247ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3143/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Planning process","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Planning assisted under this subchapter shall be a continuous process involving public officials and private citizens in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc7247ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3143/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyzing local economies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7247ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3143/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" defining economic development goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7247af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3143/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determining project opportunities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7247b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3143/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" formulating and implementing an economic development program that includes systematic efforts to reduce unemployment and increase incomes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc7247b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3143/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of planning assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Planning assistance under this subchapter shall be used in conjunction with any other available Federal planning assistance to ensure adequate and effective planning and economical use of funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc7247b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3143/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Administrative expenses that may be paid with a grant under this section include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc7247b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3143/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expenses related to carrying out the planning process described in subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7247b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3143/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expenses related to project predevelopment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7247b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3143/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expenses related to updating economic development plans to align with other applicable State, regional, or local planning efforts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7247b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3143/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" expenses related to hiring professional staff to assist communities in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc7247b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3143/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" project predevelopment and implementing projects and priorities included in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc7247b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3143/d/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comprehensive economic development strategy; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc7247b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3143/d/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an economic development planning grant;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc7247ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3143/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying and using other Federal, State, and Tribal economic development programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc7247bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3143/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leveraging private and philanthropic investment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc7247bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3143/d/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preparing economic recovery plans in response to disasters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc7247bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3143/d/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carrying out economic development and predevelopment activities in accordance with professional economic development best practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc7247be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3143/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State plans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc7247bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3143/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any State plan developed with assistance under this section shall be developed, to the maximum extent practicable, cooperatively by the State, political subdivisions of the State, and the economic development districts located wholly or partially in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7247c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3143/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive economic development strategy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of receipt of assistance for a State plan under this subsection, the State shall have or develop a comprehensive economic development strategy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7247c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3143/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before providing assistance for a State plan under this section, the Secretary shall consider the extent to which the State will consider local and economic development district plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7247c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3143/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive planning process","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any overall State economic development planning assisted under this section shall be a part of a comprehensive planning process that shall consider the provision of public works to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc7247c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3143/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote economic development and opportunity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc7247c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3143/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foster effective transportation access;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc7247c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3143/e/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance and protect the environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc7247c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3143/e/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist in carrying out the workforce investment strategy of a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc7247c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3143/e/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the use of technology in economic development, including access to high-speed telecommunications (including broadband);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc7247c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3143/e/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address and mitigate economic impacts of extreme weather; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc7247c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3143/e/4/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" balance resources through the sound management of physical development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7247ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3143/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State that receives assistance for the development of a plan under this subsection shall submit to the Secretary an annual report on the planning process assisted under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc7247cb-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tII/s203"},"text":"Pub. L. 89–136, title II, § 203","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/tI/s102/a"},"text":"Pub. L. 105–393, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3602"},"text":"112 Stat. 3602","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/373/tII/s201"},"text":"Pub. L. 108–373, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-27"},"text":"Oct. 27, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1759"},"text":"118 Stat. 1759","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dB/tII/s2214"},"text":"Pub. L. 118–272, div. B, title II, § 2214","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3180"},"text":"138 Stat. 3180","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc7247cc-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc7247cd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc7247ce-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3143, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tII/s203"},"text":"Pub. L. 89–136, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-08-26"},"text":"Aug. 26, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/558"},"text":"79 Stat. 558","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/273/s2/25"},"text":"Pub. L. 94–273, § 2(25)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-21"},"text":"Apr. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/376"},"text":"90 Stat. 376","children":[],"tail":", directed deposit of funds into Economic Development Revolving Fund, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/s102/a"},"text":"Pub. L. 105–393, § 102(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc7247cf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2214/1"},"text":"Pub. L. 118–272, § 2214(1)","children":[],"tail":", (2), added subsec. (d) and redesignated former subsec. (d) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(4)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2214/3/A"},"text":"Pub. L. 118–272, § 2214(3)(A)","children":[],"tail":", substituted “(including broadband);” for “; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(4)(F), (G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2214/3/B"},"text":"Pub. L. 118–272, § 2214(3)(B)","children":[],"tail":", (C), added subpar. (F) and redesignated former subpar. (F) as (G)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/373/s201/1"},"text":"Pub. L. 108–373, § 201(1)","children":[],"tail":", inserted “, to the maximum extent practicable,” after “shall be developed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/373/s201/2"},"text":"Pub. L. 108–373, § 201(2)","children":[],"tail":", added par. (3) and struck out heading and text of former par. (3). Text read as follows: “On completion of a State plan developed with assistance under this section, the State shall—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) certify to the Secretary that, in the development of the State plan, local and economic development district plans were considered and, to the maximum extent practicable, the State plan is consistent with the local and economic development district plans; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) identify any inconsistencies between the State plan and the local and economic development district plans and provide a justification for each inconsistency.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4)(D) to (F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/373/s201/3"},"text":"Pub. L. 108–373, § 201(3)","children":[],"tail":", added subpars. (D) and (E) and redesignated former subpar. (D) as (F)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc7247d0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbc7247d1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1999-02-11"},"text":"Feb. 11, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/s105"},"text":"section 105 of Pub. L. 105–393","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3121"},"text":"section 3121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
