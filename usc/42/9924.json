{"tag":"section","attrib":{"id":"idbf0b8f77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9924"},"text":null,"children":[{"tag":"num","attrib":{"value":"9924"},"text":"§ 9924.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" References","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any reference in any provision of law to the poverty line set forth in section 624 or 625 of the Economic Opportunity Act of 1964 shall be construed to be a reference to the poverty line defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9902"},"text":"section 9902 of this title","children":[],"tail":". Except as otherwise provided, any reference in any provision of law to any community action agency designated under title II of the Economic Opportunity Act of 1964 shall be construed to be a reference to an entity eligible to receive funds under the community services block grant program."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbf0b8f78-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s683"},"text":"Pub. L. 97–35, title VI, § 683","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/285/tII/s201"},"text":"Pub. L. 105–285, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"Oct. 27, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2755"},"text":"112 Stat. 2755","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf0b8f79-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf0b8f7a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf0b8f7b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Economic Opportunity Act of 1964, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/452"},"text":"Pub. L. 88–452","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-08-20"},"text":"Aug. 20, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/508"},"text":"78 Stat. 508","children":[],"tail":". Title II of the Act was classified generally to subchapter II (§ 2781 et seq.) of chapter 34 of this title prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s683/a"},"text":"Pub. L. 97–35, title VI, § 683(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/519"},"text":"95 Stat. 519","children":[],"tail":". Section 625 of the Act, which was subsequently renumbered section 624 of the Act and related to the poverty line, was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2971d"},"text":"section 2971d of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s683/a"},"text":"section 683(a) of Pub. L. 97–35","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf0b8f7c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/s683"},"text":"section 683 of Pub. L. 97–35","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9911"},"text":"section 9911 of this title","children":[],"tail":", prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/285"},"text":"Pub. L. 105–285","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/s683"},"text":"section 683 of Pub. L. 97–35","children":[],"tail":" was renumbered section 684, and was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9912"},"text":"section 9912 of this title","children":[],"tail":", prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/285"},"text":"Pub. L. 105–285","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
