{"tag":"section","attrib":{"id":"idbaa85cf9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397"},"text":null,"children":[{"tag":"num","attrib":{"value":"1397"},"text":"§ 1397.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes of division; authorization of appropriations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of consolidating Federal assistance to States for social services into a single grant, increasing State flexibility in using social service grants, and encouraging each State, as far as practicable under the conditions in that State, to furnish services directed at the goals of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaa85cfa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achieving or maintaining economic self-support to prevent, reduce, or eliminate dependency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaa85cfb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achieving or maintaining self-sufficiency, including reduction or prevention of dependency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaa85cfc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preventing or remedying neglect, abuse, or exploitation of children and adults unable to protect their own interests, or preserving, rehabilitating or reuniting families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaa85cfd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preventing or reducing inappropriate institutional care by providing for community-based care, home-based care, or other forms of less intensive care; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaa85cfe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" securing referral or admission for institutional care when other forms of care are not appropriate, or providing services to individuals in institutions,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"there are authorized to be appropriated for each fiscal year such sums as may be necessary to carry out the purposes of this division.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbaa85cff-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XX, § 2001, as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXIII/s2352/a"},"text":"Pub. L. 97–35, title XXIII, § 2352(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/867"},"text":"95 Stat. 867","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tVI/s6703/d/1"},"text":"Pub. L. 111–148, title VI, § 6703(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/803"},"text":"124 Stat. 803","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbaa85d00-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbaa85d01-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbaa85d02-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1397, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531/tXX/s2001"},"text":"act Aug. 14, 1935, ch. 531, title XX, § 2001","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/93/647/s2"},"text":"Pub. L. 93–647, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2337"},"text":"88 Stat. 2337","children":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1980-06-17"},"text":"June 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/96/272/tII/s207/b"},"text":"Pub. L. 96–272, title II, § 207(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/526"},"text":"94 Stat. 526","children":[],"tail":", authorized appropriations to carry out former provisions of this subchapter, prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s2352/a"},"text":"section 2352(a) of Pub. L. 97–35","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbaa85d03-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s6703/d/1/B"},"text":"Pub. L. 111–148, § 6703(d)(1)(B)","children":[],"tail":", which directed substitution of “this division” for “this subchapter” wherever appearing in subtitle 1 of title XX of act "},{"tag":"date","attrib":{"date":"1935-08-14"},"text":"Aug. 14, 1935","children":[],"tail":", was executed to the concluding provisions of this section, which is in subtitle A of title XX of act "},{"tag":"date","attrib":{"date":"1935-08-14"},"text":"Aug. 14, 1935","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s6703/d/1/A"},"text":"Pub. L. 111–148, § 6703(d)(1)(A)","children":[],"tail":", substituted “division” for “subchapter” in section catchline."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbaa85d04-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbaa85d05-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXIII/s2354"},"text":"Pub. L. 97–35, title XXIII, § 2354","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/874"},"text":"95 Stat. 874","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/35/tXXIII/s2354"},"text":"“Except as otherwise explicitly provided, the provisions of this subtitle [subtitle C (§§ 2351–2355) of title XXIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":", see Short Title of 1981 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of this title","children":[],"tail":"] and the repeals and amendments made by this subtitle, shall become effective on "},{"tag":"date","attrib":{"date":"1981-10-01"},"text":"October 1, 1981","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbaa85d06-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study of State Social Service Programs; Report to Congress","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXIII/s2355"},"text":"Pub. L. 97–35, title XXIII, § 2355","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/874"},"text":"95 Stat. 874","children":[],"tail":", required Secretary of Health and Human Services to conduct a study to identify criteria and mechanisms which may be useful for States in assessing effectiveness and efficiency of State social service programs carried out with funds made available under this subchapter, such study to include consideration of Federal incentive payments as an option in rewarding States having high performance social service programs, and to report results of such study to Congress within one year after "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
