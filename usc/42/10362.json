{"tag":"section","attrib":{"id":"idbf235dda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362"},"text":null,"children":[{"tag":"num","attrib":{"value":"10362"},"text":"§ 10362.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf235ddb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Administrator of the National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf235ddc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Committee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Advisory Committee” means the National Advisory Committee on Water Information established—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf235ddd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under the Office of Management and Budget Circular 92–01; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf235dde-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coordinate water data collection activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf235ddf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “assessment program” means the water availability and use assessment program established by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10368/a"},"text":"section 10368(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf235de0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Climate division","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “climate division” means 1 of the 359 divisions in the United States that represents 2 or more regions located within a State that are as climatically homogeneous as possible, as determined by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf235de1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commissioner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commissioner” means the Commissioner of Reclamation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf235de2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Director” means the Director of the United States Geological Survey.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf235de3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible applicant","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible applicant” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf235de4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any State, Indian tribe, irrigation district, or water district;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf235de5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any State, regional, or local authority, the members of which include 1 or more organizations with water or power delivery authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf235de6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other organization with water or power delivery authority; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf235de7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any nonprofit conservation organization, if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf235de8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/7/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nonprofit conservation organization is acting in partnership with and with the agreement of an entity described in subparagraph (A), (B), or (C); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf235de9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/7/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an application for a project to improve the condition of a natural feature or nature-based feature on Federal land, the entities described in subparagraph (A), (B), or (C) from the applicable service area have been notified of the project application and there is no written objection to the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf235dea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Power Marketing Administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Federal Power Marketing Administration” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf235deb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bonneville Power Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf235dec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Southeastern Power Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf235ded-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Southwestern Power Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf235dee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/8/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Western Area Power Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf235def-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hydrologic accounting unit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “hydrologic accounting unit” means 1 of the 352 river basin hydrologic accounting units used by the United States Geological Survey.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf235df0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian tribe” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf235df1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Major aquifer system","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “major aquifer system” means a groundwater system that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf235df2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identified as a significant groundwater system by the Director; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf235df3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" included in the Groundwater Atlas of the United States, published by the United States Geological Survey.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf235df4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Major reclamation river basin","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf235df5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “major reclamation river basin” means each major river system (including tributaries)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf235df6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/12/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is located in a service area of the Bureau of Reclamation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf235df7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/12/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at which is located a federally authorized project of the Bureau of Reclamation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf235df8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “major reclamation river basin” includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf235df9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/12/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Colorado River;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf235dfa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/12/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Columbia River;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf235dfb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/12/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Klamath River;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf235dfc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/12/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Missouri River;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf235dfd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/12/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Rio Grande;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf235dfe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/12/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Sacramento River;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf235dff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/12/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the San Joaquin River; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf235e00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/12/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Truckee River.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf235e01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Natural feature","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “natural feature” means a feature that is created through the action of physical, geological, biological, and chemical processes over time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf235e02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nature-based feature","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “nature-based feature” means a feature that is created by human design, engineering, and construction to provide a means to reduce water supply and demand imbalances or drought or flood risk by acting in concert with natural processes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf235e03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal participant","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “non-Federal participant” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf235e04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/15/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State, regional, or local authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf235e05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/15/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribe or tribal organization; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf235e06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/15/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other qualifying entity, such as a water conservation district, water conservancy district, or rural water district or association, or a nongovernmental organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf235e07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Panel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “panel” means the climate change and water intragovernmental panel established by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10366/a"},"text":"section 10366(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf235e08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “program” means the regional integrated sciences and assessments program—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf235e09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/17/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" established by the Administrator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf235e0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/17/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is comprised of 8 regional programs that use advances in integrated climate sciences to assist decisionmaking processes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf235e0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf235e0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/18/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), the term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf235e0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/18/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Secretary” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf235e0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/18/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of sections 10363, 10364, and 10369 of this title, the Secretary of the Interior (acting through the Commissioner); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf235e0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/18/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of sections 10367 and 10368 of this title, the Secretary of the Interior (acting through the Director).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf235e10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10362/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “service area” means any area that encompasses a watershed that contains a federally authorized reclamation project that is located in any State or area described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s391"},"text":"section 391 of title 43","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf235e11-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tIX/s9502"},"text":"Pub. L. 111–11, title IX, § 9502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1330"},"