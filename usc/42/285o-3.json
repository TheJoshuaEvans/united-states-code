{"tag":"section","attrib":{"id":"idb57aade8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285o–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"285o–3"},"text":"§ 285o–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office on AIDS","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Director of the Institute shall establish within the Institute an Office on AIDS. The Office shall be responsible for the coordination of research and determining the direction of the Institute with respect to AIDS research related to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb57aade9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285o–3/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" primary prevention of the spread of HIV, including transmission via drug abuse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57aadea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285o–3/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" drug abuse services research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57aadeb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285o–3/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other matters determined appropriate by the Director.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb57aadec-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 464O, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tI/s123/b"},"text":"Pub. L. 102–321, title I, § 123(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/362"},"text":"106 Stat. 362","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb57aaded-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb57aadee-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb57aadef-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1992-10-01"},"text":"Oct. 1, 1992","children":[],"tail":", with provision for programs providing financial assistance, see section 801(c), (d) of "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":", set out as an Effective Date of 1992 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s236"},"text":"section 236 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb57aadf0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study by National Academy of Sciences","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/321/s706"},"text":"Section 706 of Pub. L. 102–321","children":[],"tail":" directed Secretary of Health and Human Services to contract for a study or studies relating to programs that provide both sterile hypodermic needles and bleach to individuals in order to reduce the risk of contracting acquired immune deficiency syndrome or related conditions, in order to determine extent to which such programs promote the abuse of drugs or otherwise altered any behaviors constituting a substantial risk of contracting AIDS or hepatitus, or of transmitting such conditions, and further directed Secretary to ensure that a report is submitted to Congress on the results of this study not later than 18 months after "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
