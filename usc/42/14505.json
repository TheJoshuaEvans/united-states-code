{"tag":"section","attrib":{"id":"idbfd177b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14505"},"text":null,"children":[{"tag":"num","attrib":{"value":"14505"},"text":"§ 14505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfd177b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14505/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Economic loss","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “economic loss” means any pecuniary loss resulting from harm (including the loss of earnings or other benefits related to employment, medical expense loss, replacement services loss, loss due to death, burial costs, and loss of business or employment opportunities) to the extent recovery for such loss is allowed under applicable State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd177b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14505/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Harm","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “harm” includes physical, nonphysical, economic, and noneconomic losses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd177b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14505/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noneconomic losses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “noneconomic losses” means losses for physical and emotional pain, suffering, inconvenience, physical impairment, mental anguish, disfigurement, loss of enjoyment of life, loss of society and companionship, loss of consortium (other than loss of domestic service), hedonic damages, injury to reputation and all other nonpecuniary losses of any kind or nature.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd177b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14505/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonprofit organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “nonprofit organization” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfd177b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14505/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any organization which is described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":" and exempt from tax under section 501(a) of such title and which does not practice any action which constitutes a hate crime referred to in subsection (b)(1) of the first section of the Hate Crime Statistics Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t28/s534"},"text":"28 U.S.C. 534","children":[],"tail":" note); "},{"tag":"ref","attrib":{"idref":"fn004187"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004187"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfd177ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14505/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any not-for-profit organization which is organized and conducted for public benefit and operated primarily for charitable, civic, educational, religious, welfare, or health purposes and which does not practice any action which constitutes a hate crime referred to in subsection (b)(1) of the first section of the Hate Crime Statistics Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s534"},"text":"28 U.S.C. 534","children":[],"tail":" note)."},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd177bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14505/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the several States, the District of Columbia, the Commonwealth of Puerto Rico, the Virgin Islands, Guam, American Samoa, the Northern Mariana Islands, any other territory or possession of the United States, or any political subdivision of any such State, territory, or possession.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd177bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14505/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Volunteer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “volunteer” means an individual performing services for a nonprofit organization or a governmental entity who does not receive—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfd177bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14505/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compensation (other than reasonable reimbursement or allowance for expenses actually incurred); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfd177be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14505/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other thing of value in lieu of compensation,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"in excess of $500 per year, and such term includes a volunteer serving as a director, officer, trustee, or direct service volunteer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfd177bf-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/19/s6"},"text":"Pub. L. 105–19, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-06-18"},"text":"June 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/221"},"text":"111 Stat. 221","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfd177c0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfd177c1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfd177c2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The first section of the Hate Crime Statistics Act, referred to in par. (4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/275/s1"},"text":"Pub. L. 101–275, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-04-23"},"text":"Apr. 23, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/140"},"text":"104 Stat. 140","children":[],"tail":", which was set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s534"},"text":"section 534 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure, prior to editorial reclassification as "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s41305"},"text":"section 41305 of Title 34","children":[],"tail":", Crime Control and Law Enforcement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
