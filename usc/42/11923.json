{"tag":"section","attrib":{"id":"idbf5a4c95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11923"},"text":null,"children":[{"tag":"num","attrib":{"value":"11923"},"text":"§ 11923.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional training program on drug abuse in public housing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf5a4c96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11923/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a regional training program for the training of public housing officials, to better prepare and educate the officials to confront the widespread abuse of controlled substances in the communities in which the officials work.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf5a4c97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11923/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The regional training program established under subsection (a) shall be conducted within 12 months after ","children":[{"tag":"date","attrib":{"date":"1988-11-18"},"text":"November 18, 1988","children":[],"tail":", by a national training unit established by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf5a4c98-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tV/s5144"},"text":"Pub. L. 100–690, title V, § 5144","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4303"},"text":"102 Stat. 4303","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
