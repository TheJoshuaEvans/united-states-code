{"tag":"section","attrib":{"id":"idb63e4c32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–3a"},"text":null,"children":[{"tag":"num","attrib":{"value":"300j–3a"},"text":"§ 300j–3a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to public sector agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb63e4c33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–3a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance for development and demonstration projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator of the Environmental Protection Agency shall offer grants to public sector agencies for the purposes of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb63e4c34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–3a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting in the development and demonstration (including construction) of any proj­ect which will demonstrate a new or improved method, approach, or technology for providing a dependably safe supply of drinking water to the public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb63e4c35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–3a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting in the development and demonstration (including construction) of any proj­ect which will investigate and demonstrate health and conservation implications involved in the reclamation, recycling, and reuse of wastewaters for drinking and agricultural use or the processes and methods for the preparation of safe and acceptable drinking water.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb63e4c36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–3a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants made by the Administrator under this section shall be subject to the following limitations:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb63e4c37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–3a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Grants under this section shall not exceed 66⅔ per centum of the total cost of construction of any facility and 75 per centum of any other costs, as determined by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb63e4c38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–3a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Grants under this section shall not be made for any project involving the construction or modification of any facilities for any public water system in a State unless such project has been approved by the State agency charged with the responsibility for safety of drinking water (or if there is no such agency in a State, by the State health authority).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb63e4c39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–3a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Grants under this section shall not be made for any project unless the Administrator determines, after consultation, that such project will serve a useful purpose relating to the development and demonstration of new or improved techniques, methods, or technologies for the provision of safe water to the public for drinking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb63e4c3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–3a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated for the purposes of this section $25,000,000 for fiscal year 1978.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb63e4c3b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/155/s5"},"text":"Pub. L. 95–155, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-11-08"},"text":"Nov. 8, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1258"},"text":"91 Stat. 1258","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/477/s7/a/1"},"text":"Pub. L. 95–477, § 7(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-18"},"text":"Oct. 18, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1511"},"text":"92 Stat. 1511","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb63e4c3c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb63e4c3d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb63e4c3e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Environmental Research, Development, and Demonstration Authorization Act of 1978, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb63e4c3f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/477"},"text":"Pub. L. 95–477","children":[],"tail":" inserted “agricultural use or” after “drinking and”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb63e4c40-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb63e4c41-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/477/s7/a/2"},"text":"Pub. L. 95–477, § 7(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-18"},"text":"Oct. 18, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1511"},"text":"92 Stat. 1511","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/477/s7/a/2"},"text":"“This subsection [amending this section] shall become effective ","children":[{"tag":"date","attrib":{"date":"1978-10-01"},"text":"October 1, 1978","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
