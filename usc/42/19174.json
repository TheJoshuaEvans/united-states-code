{"tag":"section","attrib":{"id":"idc081dcc9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19174"},"text":null,"children":[{"tag":"num","attrib":{"value":"19174"},"text":"§ 19174.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NIST engagement with rural communities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc081dcca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19174/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prize competition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3719"},"text":"section 3719 of title 15","children":[],"tail":", the Secretary of Commerce shall carry out a program to award prizes competitively to stimulate research and development of creative technologies to support the deployment of affordable and reliable broadband connectivity in rural communities, including unserved rural communities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc081dccb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19174/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan for deployment in rural communities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each proposal submitted pursuant to subsection (a) shall include a proposed plan for deployment of the technology that is the subject of such proposal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc081dccc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19174/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prize amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the program under subsection (a), the Secretary may award not more than a total of $5,000,000 to one or more winners of the prize competition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc081dccd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19174/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after the date on which a prize is awarded under the prize competition, the Secretary shall submit to the relevant committees of Congress a report that describes the winning proposal of the prize competition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc081dcce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19174/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the program under this section, the Secretary shall consult with the Federal Communications Commission and the heads of relevant departments and agencies of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc081dccf-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tV/s10516"},"text":"Pub. L. 117–167, div. B, title V, § 10516","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1619"},"text":"136 Stat. 1619","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
