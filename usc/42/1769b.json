{"tag":"section","attrib":{"id":"idbb67403b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1769b"},"text":"§ 1769b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Defense overseas dependents’ schools","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb67403c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of program; availability of payments and commodities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of obtaining Federal payments and commodities in conjunction with the provision of lunches to students attending Department of Defense dependents’ schools which are located outside the United States, its territories or possessions, the Secretary of Agriculture shall make available to the Department of Defense, from funds appropriated for such purpose, the same payments and commodities as are provided to States for schools participating in the National School Lunch Program in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb67403d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of program; eligibility determinations and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense shall administer lunch programs authorized by this section and shall determine eligibility for free and reduced price lunches under the criteria published by the Secretary of Agriculture, except that the Secretary of Defense shall prescribe regulations governing computation of income eligibility standards for families of students participating in the National School Lunch Program under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb67403e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nutritional standards for meals; noncompliance with standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense shall be required to offer meals meeting nutritional standards prescribed by the Secretary of Agriculture; however, the Secretary of Defense may authorize deviations from Department of Agriculture prescribed meal patterns, fluid milk requirements, and nutritional standards for nondairy beverages when local conditions preclude strict compliance or when such compliance is impracticable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb67403f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds are hereby authorized to be appropriated for any fiscal year in such amounts as may be necessary for the administrative expenses of the Department of Defense under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb674040-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance for administration of program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture shall provide the Secretary of Defense with the technical assistance in the administration of the school lunch programs authorized by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb674041-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-06-04/ch281/s20"},"text":"June 4, 1946, ch. 281, § 20","children":[],"tail":", formerly § 22, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/561/tXIV/s1408/a"},"text":"Pub. L. 95–561, title XIV, § 1408(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-01"},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2368"},"text":"92 Stat. 2368","children":[],"tail":"; renumbered § 20 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/500/tIII"},"text":"Pub. L. 99–500, title III","children":[],"tail":", §§ 328(a), 371(c)(1), "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1783-362"},"text":"100 Stat. 1783–362","children":[],"tail":", 1783–368, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/tIII"},"text":"Pub. L. 99–591, title III","children":[],"tail":", §§ 328(a), 371(c)(1), "},{"tag":"date","attrib":{"date":"1986-10-30"},"text":"Oct. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341-365"},"text":"100 Stat. 3341–365","children":[],"tail":", 3341–372; renumbered § 20 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/661/dD/tII/s4208/a"},"text":"Pub. L. 99–661, div. D, title II, § 4208(a)","children":[],"tail":", title V, § 4501(c)(1), "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","chi