6-04"},"text":"June 4, 1946","children":[],"tail":", was renumbered section 18 of act "},{"tag":"date","attrib":{"date":"1946-06-04"},"text":"June 4, 1946","children":[],"tail":", and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1769"},"text":"section 1769 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb674046-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2026—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/69"},"text":"Pub. L. 119–69","children":[],"tail":" substituted “patterns, fluid milk requirements, and nutritional standards for nondairy beverages” for “patterns and fluid milk requirements”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/147"},"text":"Pub. L. 101–147","children":[],"tail":" substituted “reduced price” for “reduced-price”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500"},"text":"Pub. L. 99–500","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s328/a"},"text":"Pub. L. 99–591, § 328(a)","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/99/661/s4208/a"},"text":"Pub. L. 99–661, § 4208(a)","children":[],"tail":", amended subsec. (d) identically, striking out “and for payment of the difference between the value of commodities and payments received from the Secretary of Agriculture and (1) the full cost of each lunch for each student eligible for a free lunch, and (2) the full cost of each lunch, less any amounts required by law or regulation to be paid by each student eligible for a reduced-price lunch” after “this section”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb674047-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbb674048-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1978-10-01"},"text":"Oct. 1, 1978","children":[],"tail":" and no provision herein to be construed as impairing or preventing the taking effect of any other Act providing for the transfer of functions described herein to an executive department having responsibility for education, see "},{"tag":"ref","attrib":{"href":"/us/pl/95/561/s1415"},"text":"section 1415 of Pub. L. 95–561","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s921"},"text":"section 921 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
