ces and preceding “old-age insurance”, and inserted “or section 402(c)” after “section 402(b)” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/21/s304/b"},"text":"Pub. L. 98–21, § 304(b)","children":[],"tail":", substituted “surviving spouse” for “widow” and “surviving spouse’s” for “widow’s” wherever appearing, substituted “the” for “her” after “determining” and “The amount of”, and inserted “or section 402(f)” after “section 402(e)” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/21/s304/b/1"},"text":"Pub. L. 98–21, § 304(b)(1)","children":[],"tail":", (2), (4), substituted “surviving spouse” for “widow” wherever appearing and “surviving spouse’s” for “widow’s”, and inserted “or section 402(f)” after “section 402(e)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/233/s2/b/1"},"text":"Pub. L. 93–233, § 2(b)(1)","children":[],"tail":", substituted “the larger of $64.40 or the amount most recently established in lieu thereof under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s415/i"},"text":"section 415(i) of this title","children":[],"tail":"” for “$58.00” and “the larger of $32.20 or the amount most recently established in lieu thereof under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s415/i"},"text":"section 415(i) of this title","children":[],"tail":"” for “$29.00”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/233/s2/b/1"},"text":"Pub. L. 93–233, § 2(b)(1)","children":[],"tail":", substituted “the larger of $64.40 or the amount most recently established in lieu thereof under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s415/i"},"text":"section 415(i) of this title","children":[],"tail":"” for “$58.00”."}],"tail":"\n"},{"tag":"p","attrib":{},"text"