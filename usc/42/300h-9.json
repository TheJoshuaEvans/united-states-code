{"tag":"section","attrib":{"id":"idb6399114-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300h–9"},"text":null,"children":[{"tag":"num","attrib":{"value":"300h–9"},"text":"§ 300h–9.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secure geologic storage permitting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6399115-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300h–9/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6399116-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300h–9/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Administrator of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6399117-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300h–9/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Class VI well","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Class VI well” means a well described in section 144.6(f) of title 40, Code of Federal Regulations (or successor regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6399118-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300h–9/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations for geologic sequestration permitting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Administrator for the permitting of Class VI wells by the Administrator for the injection of carbon dioxide for the purpose of geologic sequestration in accordance with the requirements of the Safe Drinking Water Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300f"},"text":"42 U.S.C. 300f","children":[],"tail":" et seq.) and the final rule of the Administrator entitled “Federal Requirements Under the Underground Injection Control (UIC) Program for Carbon Dioxide (CO2) Geologic Sequestration (GS) Wells” (75 Fed. Reg. 77230 ("},{"tag":"date","attrib":{"date":"2010-12-10"},"text":"December 10, 2010","children":[],"tail":")), $5,000,000 for each of fiscal years 2022 through 2026."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6399119-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300h–9/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State permitting program grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb639911a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300h–9/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall award grants to States that, pursuant to section 1422 of the Safe Drinking Water Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300h–1"},"text":"42 U.S.C. 300h–1","children":[],"tail":"), receive the approval of the Administrator for a State underground injection control program for permitting Class VI wells for the injection of carbon dioxide."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb639911b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300h–9/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State that receives a grant under paragraph (1) shall use the amounts received under the grant to defray the expenses of the State related to the establishment and operation of a State underground injection control program described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb639911c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300h–9/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Administrator to carry out this subsection $50,000,000 for the period of fiscal years 2022 through 2026.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb639911d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tIII/s40306"},"text":"Pub. L. 117–58, div. D, title III, § 40306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1002"},"text":"135 Stat. 1002","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb639911e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb639911f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb6399120-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Safe Drinking Water Act, referred to in subsec. (b), is title XIV of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1974-12-16"},"text":"Dec. 16, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/93/523/s2/a"},"text":"Pub. L. 93–523, § 2(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1660"},"text":"88 Stat. 1660","children":[],"tail":", which is classified generally to subchapter XII (§ 300f et seq.) of chapter 6A of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb6399121-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Infrastructure Investment and Jobs Act, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb6399122-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb6399123-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
