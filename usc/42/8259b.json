{"tag":"section","attrib":{"id":"idbe8ac75a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259b"},"text":null,"children":[{"tag":"num","attrib":{"value":"8259b"},"text":"§ 8259b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal procurement of energy efficient products","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe8ac75b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe8ac75c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “agency” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7902/a"},"text":"section 7902(a) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8ac75d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy Star product","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Energy Star product” means a product that is rated for energy efficiency under an Energy Star program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8ac75e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy Star program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Energy Star program” means the program established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6294a"},"text":"section 6294a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8ac75f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" FEMP designated product","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “FEMP designated product” means a product that is designated under the Federal Energy Management Program of the Department of Energy as being among the highest 25 percent of equivalent products for energy efficiency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8ac760-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259b/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Product","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “product” does not include any energy consuming product or system designed or procured for combat or combat-related missions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe8ac761-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procurement of energy efficient products","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe8ac762-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To meet the requirements of an agency for an energy consuming product in a product category covered by the Energy Star program or the Federal Energy Management Program for designated products, the head of the agency shall, except as provided in paragraph (2), procure—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe8ac763-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Energy Star product; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe8ac764-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a FEMP designated product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8ac765-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of an agency is not required to procure an Energy Star product or FEMP designated product under paragraph (1) if the head of the agency finds in writing that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe8ac766-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Energy Star product or FEMP designated product is not cost-effective over the life of the product taking energy cost savings into account; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe8ac767-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no Energy Star product or FEMP designated product is reasonably available that meets the functional requirements of the agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8ac768-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procurement planning","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The head of an agency shall incorporate into the specifications for all procurements involving energy consuming products and systems, including guide specifications, project specifications, and construction, renovation, and services contracts that include provision of energy consuming products and systems, and into the factors for the evaluation of offers received for the procurement, criteria for energy efficiency that are consistent with the criteria used for rating Energy Star products and for rating FEMP designated products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe8ac769-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Listing of energy efficient products in Federal catalogs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Energy Star products and FEMP designated products shall be clearly identified and prominently displayed in any inventory or listing of products by the General Services Administration or the Defense Logistics Agency. The General Services Administration or the Defense Logistics Agency shall list in their catalogues, represent as available, and supply only Energy Star products or FEMP designated products for all product categories covered by the Energy Star program or the Federal Energy Management Program, except in cases in which the head of the agency ordering a product specifies in writing that no Energy Star product or FEMP designated product is available to meet the buyer’s functional requirements, or that no Energy Star product or FEMP designated product is cost-effective for the intended application over the life of the product, taking energy cost savings into account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe8ac76a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific products","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe8ac76b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of electric motors of 1 to 500 horsepower, agencies shall select only premium efficient motors that meet a standard designated by the Secretary. The Secretary shall designate such a standard not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", after considering the recommendations of associated electric motor manufacturers and energy efficiency groups."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8ac76c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" All Federal agencies are encouraged to take actions to maximize the efficiency of air conditioning and refrigeration equipment, including appropriate cleaning and maintenance, including the use of any system treatment or additive that will reduce the electricity consumed by air conditioning and refrigeration equipment. Any such treatment or additive must be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe8ac76d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259b/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determined by the Secretary to be effective in increasing the efficiency of air conditioning and refrigeration equipment without having an adverse impact on air conditioning performance (including cooling capacity) or equipment useful life;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe8ac76e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259b/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determined by the Administrator of the Environmental Protection Agency to be environmentally safe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe8ac76f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259b/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shown to increase seasonal energy efficiency ratio (SEER) or energy efficiency ratio (EER) when tested by the National Institute of Standards and Technology according to Department of Energy test procedures without causing any adverse impact on the system, system components, the refrigerant or lubricant, or other materials in the system.","children":[{"tag":"p","attrib":{},"text":"Results of testing described in subparagraph (C) shall be published in the Federal Register for public review and comment. For purposes of this section, a hardware device or primary refrigerant shall not be considered an additive.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe8ac770-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federally-procured appliances with standby power","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe8ac771-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of eligible product","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “eligible product” means a commercially available, off-the-shelf product that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe8ac772-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259b/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbe8ac773-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259b/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses external standby power devices; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe8ac774-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259b/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains an internal standby power function; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe8ac775-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259b/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is included on the list compiled under paragraph (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8ac776-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal purchasing requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (3), if an agency purchases an eligible product, the agency shall purchase—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe8ac777-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259b/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an eligible product that uses not more than 1 watt in the standby power consuming mode of the eligible product; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe8ac778-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259b/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if an eligible product described in subparagraph (A) is not available, the eligible product with the lowest available standby power wattage in the standby power consuming mode of the eligible product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8ac779-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259b/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirements of paragraph (2) shall apply to a purchase by an agency only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe8ac77a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259b/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the lower-wattage eligible product is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbe8ac77b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259b/e/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lifecycle cost-effective; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe8ac77c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259b/e/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" practicable; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe8ac77d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259b/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the utility and performance of the eligible product is not compromised by the lower wattage requirement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8ac77e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259b/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible products","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Secretary of Defense, the Administrator of the Environmental Protection Agency, and the Administrator of General Services, shall compile a publicly accessible list of cost-effective eligible products that shall be subject to the purchasing requirements of paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe8ac77f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Secretary shall issue guidelines to carry out this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe8ac780-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/619/tV/s553"},"text":"Pub. L. 95–619, title V, § 553","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tI/s104/a"},"text":"Pub. L. 109–58, title I, § 104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/609"},"text":"119 Stat. 609","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tV"},"text":"Pub. L. 110–140, title V","children":[],"tail":", §§ 524, 525(a), "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1662"},"text":"121 Stat. 1662","children":[],"tail":", 1663.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe8ac781-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe8ac782-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe8ac783-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s525/a/1"},"text":"Pub. L. 110–140, § 525(a)(1)","children":[],"tail":", inserted “in a product category covered by the Energy Star program or the Federal Energy Management Program for designated products” after “energy consuming product” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s525/a/2"},"text":"Pub. L. 110–140, § 525(a)(2)","children":[],"tail":", in second sentence, inserted “list in their catalogues, represent as available, and” after “shall” and substituted “in which the head of the agency” for “where the agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s524"},"text":"Pub. L. 110–140, § 524","children":[],"tail":", added subsec. (e) and redesignated former subsec. (e) as (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbe8ac784-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbe8ac785-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":" effective on the date that is 1 day after "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbe8ac786-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Catalogue Listing Deadline","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tV/s525/b"},"text":"Pub. L. 110–140, title V, § 525(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1663"},"text":"121 Stat. 1663","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/140/tV/s525/b"},"text":"“Not later than 9 months after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":"], the General Services Administration and the Defense Logistics Agency shall ensure that the requirement established by the amendment made by subsection (a)(2)(A) [amending this section] has been fully complied with.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
