{"tag":"section","attrib":{"id":"idb685dc84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–40a"},"text":null,"children":[{"tag":"num","attrib":{"value":"300cc–40a"},"text":"§ 300cc–40a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Microbicide research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb685dc85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–40a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal strategic plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Office shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb685dc86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–40a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expedite the implementation of the Federal strategic plans required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s283/a"},"text":"section 283(a) of this title","children":[],"tail":" regarding the conduct and support of research on, and development of, a microbicide to prevent the transmission of the human immunodeficiency virus; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb685dc87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–40a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and, as appropriate, revise such plan to prioritize funding and activities relative to their scientific urgency and potential market readiness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb685dc88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–40a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In implementing, reviewing, and prioritizing elements of the plan described in subsection (a), the Director of the Office shall consult, as appropriate, with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb685dc89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–40a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of other Federal agencies involved in microbicide research, including the Coordinator of United States Government Activities to Combat HIV/AIDS Globally, the Director of the Centers for Disease Control and Prevention, and the Administrator of the United States Agency for International Development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb685dc8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–40a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the microbicide research and development community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb685dc8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–40a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health advocates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb685dc8c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXIII, § 2351A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/293/tII/s203/b"},"text":"Pub. L. 110–293, title II, § 203(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2940"},"text":"122 Stat. 2940","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb685dc8d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb685dc8e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb685dc8f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 300cc–40a, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tXXIII/s2352"},"text":"act July 1, 1944, ch. 373, title XXIII, § 2352","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXVIII/s1801/a/3"},"text":"Pub. L. 103–43, title XVIII, § 1801(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/193"},"text":"107 Stat. 193","children":[],"tail":", which required the establishment of an advisory council and coordinating committees, was transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300cc–40b"},"text":"section 300cc–40b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb685dc90-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb685dc91-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Sense of Congress","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/293/tII/s203/a"},"text":"Pub. L. 110–293, title II, § 203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2940"},"text":"122 Stat. 2940","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/293/tII/s203/a"},"text":"“Congress recognizes the need and urgency to expand the range of interventions for preventing the transmission of human immunodeficiency virus (HIV), including nonvaccine prevention methods that can be controlled by women.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
