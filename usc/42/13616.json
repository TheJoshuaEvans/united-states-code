{"tag":"section","attrib":{"id":"idbfca4bc0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13616"},"text":null,"children":[{"tag":"num","attrib":{"value":"13616"},"text":"§ 13616.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of evictions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any tenant who, except for reservation of a percentage of the units of a project pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13612"},"text":"section 13612 of this title","children":[],"tail":" or any preference for occupancy established pursuant to this subchapter, is lawfully residing in a dwelling unit in a covered section 8 housing project, may not be evicted or otherwise required to vacate such unit because of the reservation or preferences or because of any action taken by the Secretary of Housing and Urban Development or the owner of the project pursuant to this subchapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbfca4bc1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tVI/s656"},"text":"Pub. L. 102–550, title VI, § 656","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3824"},"text":"106 Stat. 3824","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfca4bc2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfca4bc3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfca4bc4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Covered section 8 housing, referred to in text, is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13619"},"text":"section 13619 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
