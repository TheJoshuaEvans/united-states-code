{"tag":"section","attrib":{"id":"idbf93855a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655e"},"text":null,"children":[{"tag":"num","attrib":{"value":"12655e"},"text":"§ 12655e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public lands or Indian lands","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf93855b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive assistance through a grant provided under this division, a program shall carry out activities on public lands or Indian lands, or result in a public benefit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf93855c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In reviewing applications submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12655b"},"text":"section 12655b of this title","children":[],"tail":" that propose programs or projects to be carried out on public lands or Indian lands, the Corporation shall consult with the Secretary of the Interior."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf93855d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consistency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A program carried out with assistance provided under this division for conservation, rehabilitation, or improvement of any public lands or Indian lands shall be consistent with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf93855e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions of law and policies relating to the management and administration of such lands, and all other applicable provisions of law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf93855f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all management, operational, and other plans and documents that govern the administration of such lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf938560-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation by other conservation programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any land or water conservation program (or any related program) administered in any State under the authority of any Federal program is encouraged to use services available under this part ","children":[{"tag":"ref","attrib":{"idref":"fn004094"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004094"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" to carry out its program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf938561-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s199F"},"text":"Pub. L. 101–610, title I, § 199F","children":[],"tail":", formerly § 126, "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3144"},"text":"104 Stat. 3144","children":[],"tail":"; renumbered § 199F and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s101/a"},"text":"Pub. L. 103–82, title I, § 101(a)","children":[],"tail":", (e)(1), (6), "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/788"},"text":"107 Stat. 788","children":[],"tail":", 815, 816.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf938562-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf938563-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf938564-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This part, referred to in subsec. (d), is unidentifiable in the original because subtitle I (§§ 199 to 199O) of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610"},"text":"Pub. L. 101–610","children":[],"tail":" does not contain parts."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf938565-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attr