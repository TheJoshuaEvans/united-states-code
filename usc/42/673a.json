{"tag":"section","attrib":{"id":"idb7d84c57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s673a"},"text":null,"children":[{"tag":"num","attrib":{"value":"673a"},"text":"§ 673a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interstate compacts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services shall take all possible steps to encourage and assist the various States to enter into interstate compacts (which are hereby approved by the Congress) under which the interests of any adopted child with respect to whom an adoption assistance agreement has been entered into by a State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s673"},"text":"section 673 of this title","children":[],"tail":" will be adequately protected, on a reasonable and equitable basis which is approved by the Secretary, if and when the child and his or her adoptive parent (or parents) move to another State."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb7d84c58-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/272/tI/s101/a/4/B"},"text":"Pub. L. 96–272, title I, § 101(a)(4)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-17"},"text":"June 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/512"},"text":"94 Stat. 512","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7d84c59-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7d84c5a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb7d84c5b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Adoption Assistance and Child Welfare Act of 1980, and not as part of the Social Security Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb7d84c5c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb7d84c5d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary of Health and Human Services” substituted in text for “Secretary of Health, Education, and Welfare” pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/s509/b"},"text":"section 509(b) of Pub. L. 96–88","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3508/b"},"text":"section 3508(b) of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
