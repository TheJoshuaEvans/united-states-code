{"tag":"section","attrib":{"id":"idbf498392-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386d"},"text":null,"children":[{"tag":"num","attrib":{"value":"11386d"},"text":"§ 11386d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf498393-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A collaborative applicant in a geographic area in which funds are awarded under this part shall specify contributions from any source other than a grant awarded under this part, including renewal funding of projects assisted under parts C, D, and F of this subchapter as in effect before the effective date under section 1503 of the Homeless Emergency Assistance and Rapid Transition to Housing Act of 2009, that shall be made available in the geographic area in an amount equal to not less than 25 percent of the funds provided to recipients in the geographic area, except that grants for leasing shall not be subject to any match requirement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf498394-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on in-kind match","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The cash value of services provided to the residents or clients of a project sponsor by an entity other than the project sponsor may count toward the contributions in subsection (a) only when documented by a memorandum of understanding between the project sponsor and the other entity that such services will be provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf498395-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Countable activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The contributions required under subsection (a) may consist of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf498396-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funding for any eligible activity described under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11383"},"text":"section 11383 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf498397-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to subsection (b), in-kind provision of services of any eligible activity described under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11383"},"text":"section 11383 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf498398-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77/tIV/s430"},"text":"Pub. L. 100–77, title IV, § 430","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/22/dB/tIII/s1305/3"},"text":"Pub. L. 111–22, div. B, title III, § 1305(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-20"},"text":"May 20, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1695"},"text":"123 Stat. 1695","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf498399-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf49839a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf49839b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 1503 of the Homeless Emergency Assistance and Rapid Transition to Housing Act of 2009, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/22/s1503"},"text":"section 1503 of Pub. L. 111–22","children":[],"tail":", which is set out as an Effective Date of 2009 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11302"},"text":"section 11302 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf49839c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf49839d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the earlier of 18 months after ","children":[{"tag":"date","attrib":{"date":"2009-05-20"},"text":"May 20, 2009","children":[],"tail":", or 3 months after publication of certain final regulations by Secretary of Housing and Urban Development, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/22/s1503"},"text":"section 1503 of Pub. L. 111–22","children":[],"tail":", set out as an Effective Date of 2009 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11302"},"text":"section 11302 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
