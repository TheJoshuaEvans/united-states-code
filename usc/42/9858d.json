{"tag":"section","attrib":{"id":"idbefd382a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858d"},"text":null,"children":[{"tag":"num","attrib":{"value":"9858d"},"text":"§ 9858d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on State allotments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbefd382b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No entitlement to contract or grant","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subchapter shall be construed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbefd382c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to entitle any child care provider or recipient of a child care certificate to any contract, grant or benefit; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbefd382d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to limit the right of any State to impose additional limitations or conditions on contracts or grants funded under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbefd382e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction of facilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbefd382f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9858m/c/6"},"text":"section 9858m(c)(6) of this title","children":[],"tail":", no funds made available under this subchapter shall be expended for the purchase or improvement of land, or for the purchase, construction, or permanent improvement (other than minor remodeling) of any building or facility."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbefd3830-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sectarian agency or organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a sectarian agency or organization, no funds made available under this subchapter may be used for the purposes described in paragraph (1) except to the extent that renovation or repair is necessary to bring the facility of such agency or organization into compliance with health and safety requirements referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9858c/c/2/I"},"text":"section 9858c(c)(2)(I) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbefd3831-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s658F"},"text":"Pub. L. 97–35, title VI, § 658F","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tV/s5082/2"},"text":"Pub. L. 101–508, title V, § 5082(2)","children":[],"tail":", "},{"