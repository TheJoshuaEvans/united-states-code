{"tag":"section","attrib":{"id":"idbd1df09f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189d"},"text":null,"children":[{"tag":"num","attrib":{"value":"5189d"},"text":"§ 5189d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Case management services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd1df0a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may provide case management services, including financial assistance, to State or local government agencies or qualified private organizations to provide such services, to victims of major disasters to identify and address unmet needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd1df0a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State, local government agency, or qualified private organization providing professional counseling services described in subsection (a) shall ensure that any individual providing case management services to victims of a major disaster as authorized under subsection (a), including individuals working for nonprofit partners and recovery organizations, is appropriately trained to address impacts from major disasters in communities, and to individuals, with socio-economically disadvantaged backgrounds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd1df0a2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tIV/s426"},"text":"Pub. L. 93–288, title IV, § 426","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s689f"},"text":"Pub. L. 109–295, title VI, § 689f","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1453"},"text":"120 Stat. 1453","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/251/s8/a"},"text":"Pub. L. 117–251, § 8(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-20"},"text":"Dec. 20, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2357"},"text":"136 Stat. 2357","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd1df0a3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd1df0a4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd1df0a5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/251"},"text":"Pub. L. 117–251","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd1df0a6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd1df0a7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/251/s8/b"},"text":"Pub. L. 117–251, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-20"},"text":"Dec. 20, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2357"},"text":"136 Stat. 2357","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/251/s8/b"},"text":"“The amendments made by this section [amending this section] shall apply with respect to amounts appropriated on or after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-20"},"text":"Dec. 20, 2022","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
