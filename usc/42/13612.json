{"tag":"section","attrib":{"id":"idbfca4ba5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13612"},"text":null,"children":[{"tag":"num","attrib":{"value":"13612"},"text":"§ 13612.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of units for disabled families","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfca4ba6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13612/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, for any project for which an owner gives preference in occupancy to elderly families pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13611"},"text":"section 13611 of this title","children":[],"tail":", such owner shall (subject to sections 13613, 13614, and 13615 of this title) reserve units in the project for occupancy only by disabled families who are not elderly or near-elderly families (and who have applied for occupancy in the housing) in the number determined under subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfca4ba7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13612/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number of units","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each owner required to reserve units in a project for occupancy under subsection (a) shall reserve a number of units in the project that is not less than the lesser of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfca4ba8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13612/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the number of units equivalent to the higher of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfca4ba9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13612/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage of units in the project that were occupied by such disabled families upon ","children":[{"tag":"date","attrib":{"date":"1992-10-28"},"text":"October 28, 1992","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfca4baa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13612/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage of units in the project that were occupied by such families upon ","children":[{"tag":"date","attrib":{"date":"1992-01-01"},"text":"January 1, 1992","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfca4bab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13612/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 percent of the number of units in the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfca4bac-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tVI/s652"},"text":"Pub. L. 102–550, title VI, § 652","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3823"},"text":"106 Stat. 3823","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
