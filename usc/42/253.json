{"tag":"section","attrib":{"id":"idb4dd5c86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s253"},"text":null,"children":[{"tag":"num","attrib":{"value":"253"},"text":"§ 253.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical services to Coast Guard, National Oceanic and Atmospheric Administration, and Public Health Service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4dd5c87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s253/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons entitled to medical services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to regulations of the President—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4dd5c88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s253/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commissioned officers, chief warrant officers, warrant officers, cadets, and enlisted personnel of the Regular Coast Guard on active duty, including those on shore duty and those on detached duty; and Regular, and temporary members of the United States Coast Guard Reserve when on active duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4dd5c89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s253/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commissioned officers, ships’ officers, and members of the crews of vessels of the National Oceanic and Atmospheric Administration on active duty, including those on shore duty and those on detached duty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4dd5c8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s253/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commissioned officers of the Regular or Reserve Corps ","children":[{"tag":"ref","attrib":{"idref":"fn002074"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002074"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Change of Name note below."}],"tail":" of the Public Health Service on active duty;"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be entitled to medical, surgical, and dental treatment and hospitalization by the Service. The Surgeon General may detail commissioned officers for duty aboard vessels of the Coast Guard or the National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4dd5c8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s253/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health care for involuntarily separated officers and dependents","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4dd5c8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s253/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may provide health care for an officer of the Regular or Reserve Corps ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" involuntarily separated from the Service, and for any dependent of such officer, if—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4dd5c8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s253/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the officer or dependent was receiving health care at the expense of the Service at the time of separation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4dd5c8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s253/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary finds that the officer or dependent is unable to obtain appropriate insurance for the conditions for which the officer or dependent was receiving health care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4dd5c8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s253/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Health care may be provided under paragraph (1) for a period of not more than one year from the date of separation of the officer from the Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4dd5c90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s253/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examination of personnel of Service assigned to Coast Guard or National Oceanic and Atmospheric Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Service shall provide all services referred to in subsection (a) required by the Coast Guard or National Oceanic and Atmospheric Administration and shall perform all duties prescribed by statute in connection with the examinations to determine physical or mental condition for purposes of appointment, enlistment, and reenlistment, promotion and retirement, and officers of the Service assigned to duty on Coast Guard or National Oceanic and Atmospheric Administration vessels may extend aid to the crews of American vessels engaged in deep-sea fishing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4dd5c91-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 326, "},{"tag":"ref","attrib":{"href":"/us/stat/58/697"},"text":"58 Stat. 697","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-06-07/ch374/s306/3"},"text":"June 7, 1956, ch. 374, § 306(3)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/254"},"text":"70 Stat. 254","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/415/s5/d"},"text":"Pub. L. 86–415, § 5(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-04-08"},"text":"Apr. 8, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/34"},"text":"74 Stat. 34","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/71/s2"},"text":"Pub. L. 88–71, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-07-19"},"text":"July 19, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/83"},"text":"77 Stat. 83","children":[],"tail":"; 1965 Reorg. Plan No. 2, eff. "},{"tag":"date","attrib":{"date":"1965-07-13"},"text":"July 13, 1965","children":[],"tail":", 30 F.R. 8819, "},{"tag":"ref","attrib":{"href":"/us/stat/79/1318"},"text":"79 Stat. 1318","children":[],"tail":"; 1970 Reorg. Plan No. 4, eff. "},{"tag":"date","attrib":{"date":"1970-10-03"},"text":"Oct. 3, 1970","children":[],"tail":", 35 F.R. 15627, "},{"tag":"ref","attrib":{"href":"/us/stat/84/2090"},"text":"84 Stat. 2090","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/117/s5"},"text":"Pub. L. 99–117, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-10-07"},"text":"Oct. 7, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/492"},"text":"99 Stat. 492","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4dd5c92-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4dd5c93-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb4dd5c94-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1985—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/117"},"text":"Pub. L. 99–117","children":[],"tail":" added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1963—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/71/s2/a"},"text":"Pub. L. 88–71, § 2(a)","children":[],"tail":", repealed subsec. (b) which provided for treatment of dependents of personnel. See "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s253a/b"},"text":"section 253a(b) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/71/s2/b"},"text":"Pub. L. 88–71, § 2(b)","children":[],"tail":", inserted “or Coast and Geodetic Survey” after “Coast Guard” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/415"},"text":"Pub. L. 86–415","children":[],"tail":" struck out provisions which authorized medical, surgical, and dental care and hospitalization for retired personnel of Coast Guard, Coast and Geodetic Survey, and Public Health Service."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1956—Subsec. (b). Act ","children":[{"tag":"date","attrib":{"date":"1956-06-07"},"text":"June 7, 1956","children":[],"tail":", repealed subsec. (b) except insofar as it related to dependent members of families of ships’ officers and members of crews of vessels of Coast and Geodetic Survey."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb4dd5c95-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb4dd5c96-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to Reserve Corps of the Public Health Service deemed to be a reference to the Ready Reserve Corps, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s204/c/3"},"text":"section 204(c)(3) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary of Health and Human Services” substituted for “Secretary of Health, Education, and Welfare” in subsec. (b) pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/s509/b"},"text":"section 509(b) of Pub. L. 96–88","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3508/b"},"text":"section 3508(b) of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb4dd5c97-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1956 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by act ","children":[{"tag":"date","attrib":{"date":"1956-06-07"},"text":"June 7, 1956","children":[],"tail":", effective six months after "},{"tag":"date","attrib":{"date":"1956-06-07"},"text":"June 7, 1956","children":[],"tail":", see section 307 of act "},{"tag":"date","attrib":{"date":"1956-06-07"},"text":"June 7, 1956","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idb4dd5c98-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of authorities, functions, personnel, and assets of the Coast Guard, including the authorities and functions of the Secretary of Transportation relating thereto, to the Department of Homeland Security, and for treatment of related references, see sections 468(b), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idb4dd5c99-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb4dd5c9a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Coast and Geodetic Survey consolidated with Weather Bureau to form a new agency in Department of Commerce to be known as Environmental Science Services Administration, and commissioned officers of Survey transferred to ESSA, by Reorg. Plan No. 2 of 1965, eff. ","children":[{"tag":"date","attrib":{"date":"1965-07-13"},"text":"July 13, 1965","children":[],"tail":", 30 F.R. 8819, "},{"tag":"ref","attrib":{"href":"/us/stat/79/1318"},"text":"79 Stat. 1318","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees. Reorg. Plan No. 4 of 1970, eff. "},{"tag":"date","attrib":{"date":"1970-10-03"},"text":"Oct. 3, 1970","children":[],"tail":", 35 F.R. 15627, "},{"tag":"ref","attrib":{"href":"/us/stat/84/2090"},"text":"84 Stat. 2090","children":[],"tail":", abolished Environmental Science Services Administration, established National Oceanic and Atmospheric Administration, and redesignated Commissioned Officer Corps of ESSA as Commissioned Officer Corps of NOAA. For further details, see Transfer of Functions note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s851"},"text":"section 851 of Title 33","children":[],"tail":", Navigation and Navigable Waters."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idb4dd5c9b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of Public Health Service, Surgeon General of Public Health Service, and all other officers and employees of Public Health Service, and functions of all agencies of or in Public Health Service transferred to Secretary of Health, Education, and Welfare by Reorg. Plan No. 3 of 1966, eff. ","children":[{"tag":"date","attrib":{"date":"1966-06-25"},"text":"June 25, 1966","children":[],"tail":", 31 F.R. 8855 "},{"tag":"ref","attrib":{"href":"/us/stat/80/1610"},"text":"80 Stat. 1610","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s202"},"text":"section 202 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
