{"tag":"section","attrib":{"id":"idbe09ff55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384o"},"text":null,"children":[{"tag":"num","attrib":{"value":"7384o"},"text":"§ 7384o.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Board on Radiation and Worker Health","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe09ff56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384o/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe09ff57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384o/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2000-10-30"},"text":"October 30, 2000","children":[],"tail":", the President shall establish and appoint an Advisory Board on Radiation and Worker Health (in this section referred to as the “Board”)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe09ff58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384o/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President shall make appointments to the Board in consultation with organizations with expertise on worker health issues in order to ensure that the membership of the Board reflects a balance of scientific, medical, and worker perspectives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe09ff59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384o/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President shall designate a Chair for the Board from among its members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe09ff5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384o/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall advise the President on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe09ff5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384o/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of guidelines under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7384n/c"},"text":"section 7384n(c) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe09ff5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384o/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the scientific validity and quality of dose estimation and reconstruction efforts being performed for purposes of the compensation program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe09ff5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384o/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other matters related to radiation and worker health in Department of Energy facilities as the President considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0c6f5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384o/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe0c6f5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384o/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President shall appoint a staff to facilitate the work of the Board. The staff shall be headed by a Director who shall be appointed under subchapter VIII of chapter 33 of title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe0c6f60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384o/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President may accept as staff of the Board personnel on detail from other Federal agencies. The detail of personnel under this paragraph may be on a nonreimbursable basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0c6f61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384o/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Board, other than full-time employees of the United States, while attending meetings of the Board or while otherwise serving at the request of the President, while serving away from their homes or regular places of business, shall be allowed travel and meal expenses, including per diem in lieu of subsistence, as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":" for individuals in the Government serving without pay."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0c6f62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384o/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security clearances","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe0c6f63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384o/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Energy shall ensure that the members and staff of the Board, and the contractors performing work in support of the Board, are afforded the opportunity to apply for a security clearance for any matter for which such a clearance is appropriate. The Secretary should, not later than 180 days after receiving a completed application, make a determination whether or not the individual concerned is eligible for the clearance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe0c6f64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384o/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2007 and each fiscal year thereafter, the Secretary of Energy shall include in the budget justification materials submitted to Congress in support of the Department of Energy budget for that fiscal year (as submitted with the budget of the President under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":") a report specifying the number of applications for security clearances under this subsection, the number of such applications granted, and the number of such applications denied."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0c6f65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384o/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy shall, in accordance with law, provide to the Board and the contractors of the Board access to any information that the Board considers relevant to carry out its responsibilities under this subchapter, including information such as Restricted Data (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2014/y"},"text":"section 2014(y) of this title","children":[],"tail":") and information covered by the Privacy Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"5 U.S.C. 552a","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe0c6f66-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dC/tXXXVI/s3624"},"text":"Pub. L. 106–398, § 1 [div. C, title XXXVI, § 3624]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–504; "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dC/tXXXI/s3166/a"},"text":"Pub. L. 108–375, div. C, title XXXI, § 3166(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2188"},"text":"118 Stat. 2188","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe0c6f67-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe0c6f68-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbe0c6f69-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Privacy Act, referred to in subsec. (f), is probably a reference to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":", Government Organization and Employees. See Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe0c6f6a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" added subsecs. (e) and (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbe0c6f6b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbe0c6f6c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Advisory Boards","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Advisory boards established after ","children":[{"tag":"date","attrib":{"date":"1973-01-05"},"text":"Jan. 5, 1973","children":[],"tail":", to terminate not later than the expiration of the 2-year period beginning on the date of their establishment, unless, in the case of a board established by the President or an officer of the Federal Government, such board is renewed by appropriate action prior to the expiration of such 2-year period, or in the case of a board established by Congress, its duration is otherwise provided by law. See sections 1001(2) and 1013 of Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
