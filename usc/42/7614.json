{"tag":"section","attrib":{"id":"idbe5b0431-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7614"},"text":null,"children":[{"tag":"num","attrib":{"value":"7614"},"text":"§ 7614.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Labor standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Administrator shall take such action as may be necessary to insure that all laborers and mechanics employed by contractors or subcontractors on projects assisted under this chapter shall be paid wages at rates not less than those prevailing for the same type of work on similar construction in the locality as determined by the Secretary of Labor, in accordance with sections 3141–3144, 3146, and 3147 of title 40. The Secretary of Labor shall have, with respect to the labor standards specified in this subsection,","children":[{"tag":"ref","attrib":{"idref":"fn003713"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003713"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section,”."}],"tail":" the authority and functions set forth in Reorganization Plan Numbered 14 of 1950 (15 F.R. 3176; "},{"tag":"ref","attrib":{"href":"/us/stat/64/1267"},"text":"64 Stat. 1267","children":[],"tail":") and "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s3145"},"text":"section 3145 of title 40","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbe5b0432-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title III, § 314, formerly § 307, as added "},{"tag":"ref","attrib":{"href":"/us/pl/90/148/s2"},"text":"Pub. L. 90–148, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-11-21"},"text":"Nov. 21, 1967","children":[],"tail":", "},