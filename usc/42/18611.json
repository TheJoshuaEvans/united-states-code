{"tag":"section","attrib":{"id":"idc0596d02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18611"},"text":null,"children":[{"tag":"num","attrib":{"value":"18611"},"text":"§ 18611.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress on accelerating energy innovation","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0596d03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18611/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" although important progress has been made in cost reduction and deployment of clean energy technologies, accelerating clean energy innovation will help meet critical competitiveness, energy security, and environmental goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0596d04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18611/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" accelerating the pace of clean energy innovation in the United States calls for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0596d05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18611/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting existing research and development programs at the Department and the world-class National Laboratories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0596d06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18611/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exploring and developing new pathways for innovators, investors, and decision-makers to leverage the resources of the Department for addressing the challenges and comparative strengths of geographic regions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0596d07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18611/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recognizing the financial constraints of the Department, regularly reviewing clean energy programs to ensure that taxpayer investments are maximized;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0596d08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18611/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the energy supply, demand, policies, markets, and resource options of the United States vary by geographic region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0596d09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18611/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a regional approach to innovation can bridge the gaps between local talent, institutions, and industries to identify opportunities and convert United States investment into domestic companies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0596d0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18611/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Congress, the Secretary, and energy industry participants should advance efforts that promote international, domestic, and regional cooperation on the research and development of energy innovations that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0596d0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18611/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide clean, affordable, and reliable energy for everyone;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0596d0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18611/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote economic growth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0596d0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18611/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are critical for energy security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0596d0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18611/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are sustainable without government support.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0596d0f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/246/tI/s103"},"text":"Pub. L. 115–246, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-28"},"text":"Sept. 28, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3131"},"text":"132 Stat. 3131","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
