{"tag":"section","attrib":{"id":"idbf5c95da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005"},"text":null,"children":[{"tag":"num","attrib":{"value":"12005"},"text":"§ 12005.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration and commercial application projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf5c95db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this section is to direct the Secretary to further the commercialization of renewable energy and energy efficiency technologies through a five-year program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf5c95dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration and commercial application projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf5c95dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf5c95de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall solicit proposals for demonstration and commercial application projects for renewable energy and energy efficiency technologies pursuant to subsection (c). Such projects may include projects for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf5c95df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the production and sale of electricity, thermal energy, or other forms of energy using a renewable energy technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf5c95e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing the efficiency of energy use; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf5c95e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improvements in, or expansion of, facilities for the manufacture of renewable energy or energy efficiency technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf5c95e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each project selected under this section shall include at least one for-profit business. Activities supported under this section shall be performed in the United States. Each project under this section shall require the manufacture and reproduction substantially within the United States for commercial sale of any invention or product that may result from the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5c95e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forms of financial assistance","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf5c95e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In supporting projects selected under subsection (c), the Secretary may choose from among the forms of agreements described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13541"},"text":"section 13541 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf5c95e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In supporting projects selected under subsection (c), the Secretary may also enter into agreements with private lenders to pay a portion of the interest on loans made for such projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5c95e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Cost sharing for projects under this section shall be conducted according to the procedures described in section 13542(b) and (c) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5c95e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Committee","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf5c95e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall establish an Advisory Committee on Demonstration and Commercial Application of Renewable Energy and Energy Efficiency Technologies (in this chapter referred to as the “Advisory Committee”) to advise the Secretary on the development of the solicitation and evaluation criteria for projects under this section, and on otherwise carrying out his responsibilities under this section. The Secretary shall appoint members to the Advisory Committee, including at least one member representing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf5c95e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf5c95ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Laboratories of the Department of Energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf5c95eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/b/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Solar Energy Research Institute;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf5c95ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/b/4/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Electric Power Research Institute;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf5c95ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/b/4/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Gas Research Institute;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf5c95ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/b/4/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Institute of Building Sciences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf5c95ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/b/4/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Institute of Standards and Technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf5c95f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/b/4/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" associations of firms in the major renewable energy manufacturing industries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf5c95f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/b/4/A/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" associations of firms in the major energy efficiency manufacturing industries.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Nothing in this subparagraph shall be construed to require the Secretary to reestablish the Advisory Committee in place under this subsection as of ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", or to perform again any duties performed by such advisory committee before "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf5c95f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the Advisory Committee shall provide the Secretary with a report assessing the implementation of the program under this section, including specific recommendations for improvements or changes to the program and solicitation process. The Secretary shall transmit such report and, if any, the Secretary’s recommendations to the Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf5c95f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf5c95f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solicitation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf5c95f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 9 months after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the Secretary shall solicit proposals for projects under this section. The Secretary may make additional solicitations for proposals if the Secretary determines that such solicitations are necessary to carry out this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf5c95f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A solicitation for proposals under this paragraph shall establish a closing date for receipt of proposals. The Secretary may, if necessary, extend the closing date for receipt of proposals for a period not to exceed 90 days.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf5c95f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each solicitation under this paragraph shall include a description of the criteria, developed by the Secretary, according to which proposals will be evaluated. In developing such criteria, the Secretary shall consider—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf5c95f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need for Federal involvement to commercialize the technology or speed commercialization of the technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf5c95f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential for the technology to have significant market penetration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf5c95fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/c/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential energy efficiency gains or energy supply contributions of the technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf5c95fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/c/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" potential environmental improvements associated with the technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf5c95fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/c/1/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the export potential of the technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf5c95fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/c/1/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the likelihood that the proposal is technically sufficient to achieve the objective of the solicitation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf5c95fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/c/1/C/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the degree to which non-Federal financial participation is involved in the proposal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf5c95ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/c/1/C/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the business and financial history of the proposer or proposers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf5c9600-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/c/1/C/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other factor the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5c9601-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project technologies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Projects under this section may include the following technologies:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf5c9602-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Conversion of cellulosic biomass to liquid fuels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf5c9603-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ethanol and ethanol byproduct processes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf5c9604-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Direct combustion or gasification of biomass.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf5c9605-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Biofuels energy systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf5c9606-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Photovoltaics, including utility scale and remote applications.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf5c9607-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Solar thermal, including solar water heating.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf5c9608-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Wind energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf5c9609-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/c/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" High temperature and low temperature geothermal energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf5c960a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/c/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fuel cells, including transportation and stationary applications.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf5c960b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/c/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nondefense high-temperature superconducting electricity technology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf5c960c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/c/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Source reduction technology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf5c960d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/c/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Factory-made housing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf5c960e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12005/c/2/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"t