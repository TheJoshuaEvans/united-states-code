{"tag":"section","attrib":{"id":"idc0596ce9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18501"},"text":null,"children":[{"tag":"num","attrib":{"value":"18501"},"text":"§ 18501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of payments from State eugenics compensation programs from consideration in determining eligibility for, or the amount of, Federal public benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0596cea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, payments made under a State eugenics compensation program shall not be considered as income or resources in determining eligibility for, or the amount of, any Federal public benefit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0596ceb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0596cec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18501/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal public benefit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Federal public benefit” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0596ced-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18501/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any grant, contract, loan, professional license, or commercial license provided by an agency of the United States or by appropriated funds of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0596cee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18501/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any retirement, welfare, health, disability, public or assisted housing, postsecondary education, food assistance, unemployment benefit, or any other similar benefit for which payments or assistance are provided to an individual, household, or family eligibility unit by an agency of the United States or by appropriated funds of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0596cef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18501/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State eugenics compensation program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State eugenics compensation program” means a program established by State law that is intended to compensate individuals who were sterilized under the authority of the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0596cf0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/241/s2"},"text":"Pub. L. 114–241, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-10-07"},"text":"Oct. 7, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/976"},"text":"130 Stat. 976","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0596cf1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc0596cf2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idc0596cf3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/241/s1"},"text":"Pub. L. 114–241, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-10-07"},"text":"Oct. 7, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/976"},"text":"130 Stat. 976","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/241/s1"},"text":"“This Act [enacting this chapter] may be cited as the ‘Treatment of Certain Payments in Eugenics Compensation Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
