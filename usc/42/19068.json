{"tag":"section","attrib":{"id":"idc0786694-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19068"},"text":null,"children":[{"tag":"num","attrib":{"value":"19068"},"text":"§ 19068.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advancing IoT for Precision Agriculture Capabilities Act","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0786695-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19068/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section may be cited as the “Advancing IoT for Precision Agriculture Act of 2021”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0786696-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19068/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the purpose of this section to promote scientific research and development opportunities for connected technologies that advance precision agriculture capabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0786697-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19068/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foundation directive on agricultural sensor research","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making awards under the sensor systems and networked systems programs of the Foundation, the Director shall include in consideration of portfolio balance research and development on sensor connectivity in environments of intermittent connectivity and intermittent computation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0786698-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19068/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve the reliable use of advance sensing systems in rural and agricultural areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0786699-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19068/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that considers—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc078669a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19068/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct gateway access for locally stored data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc078669b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19068/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attenuation of signal transmission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc078669c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19068/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" loss of signal transmission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc078669d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19068/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at-scale performance for wireless power.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc078669e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19068/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc078669f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19068/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" GAO review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", the Comptroller General of the United States shall provide—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc07866a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19068/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a technology assessment of precision agriculture technologies, such as the existing use of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc07866a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19068/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sensors, scanners, radio-frequency identification, and related technologies that can monitor soil properties, irrigation conditions, and plant physiology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc07866a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19068/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sensors, scanners, radio-frequency identification, and related technologies that can monitor livestock activity and health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc07866a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19068/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" network connectivity and wireless communications that can securely support digital agriculture technologies in rural and remote areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc07866a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19068/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aerial imagery generated by satellites or unmanned aerial vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc07866a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19068/e/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ground-based robotics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc07866a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19068/e/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" control systems design and connectivity, such as smart irrigation control systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc07866a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19068/e/1/G"},"text":null,"childre