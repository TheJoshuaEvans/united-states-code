{"tag":"section","attrib":{"id":"idbfee2904-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16021"},"text":null,"children":[{"tag":"num","attrib":{"value":"16021"},"text":"§ 16021.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project establishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfee2905-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16021/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a project to be known as the “Next Generation Nuclear Plant Project” (referred to in this part as the “Project”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee2906-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16021/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Project shall consist of the research, development, design, construction, and operation of a prototype plant, including a nuclear reactor that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfee2907-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16021/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is based on research and development activities supported by the Generation IV Nuclear Energy Systems Initiative under section 16272(c) ","children":[{"tag":"ref","attrib":{"idref":"fn004202"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004202"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee2908-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16021/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be used—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfee2909-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16021/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to generate electricity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfee290a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16021/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to produce hydrogen; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfee290b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16021/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" both to generate electricity and to produce hydrogen.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfee290c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVI/s641"},"text":"Pub. L. 109–58, title VI, § 641","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/794"},"text":"119 Stat. 794","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/248/s2/b/2"},"text":"Pub. L. 115–248, § 2(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-28"},"text":"Sept. 28, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3155"},"text":"132 Stat. 3155","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfee290d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfee290e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfee290f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16272"},"text":"Section 16272 of this title","children":[],"tail":", referred to in subsec. (b)(1), was amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tII/s2003/a"},"text":"Pub. L. 116–260, div. Z, title II, § 2003(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2459"},"text":"134 Stat. 2459","children":[],"tail":" and, as amended, "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s16272/c"},"text":"section 16272(c) of this title","children":[],"tail":" no longer refers to the Generation IV Nuclear Energy Systems Initiative."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbfee2910-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/248"},"text":"Pub. L. 115–248","children":[],"tail":" substituted “section 16272(c)” for “section 16272(d)”, which had been an 