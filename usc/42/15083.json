{"tag":"section","attrib":{"id":"idbfdd5f91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15083"},"text":null,"children":[{"tag":"num","attrib":{"value":"15083"},"text":"§ 15083.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfdd5f92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15083/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out the projects specified in this section $16,000,000 for fiscal year 2001, and such sums as may be necessary for each of fiscal years 2002 through 2007.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdd5f93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15083/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfdd5f94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15083/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants, contracts, and agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the amount appropriated under subsection (a) for each fiscal year shall be used to award grants, or enter into contracts, cooperative agreements, or other agreements, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15082"},"text":"section 15082 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdd5f95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15083/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 1 percent of the amount appropriated under subsection (a) for each fiscal year may be used to provide for the administrative costs (other than compensation of Federal employees) of the Administration on Developmental Disabilities for administering this part and parts B, C, and D, including monitoring the performance of and providing technical assistance to, entities that receive funds under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdd5f96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15083/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance for Councils and Centers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfdd5f97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15083/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each covered year, the Secretary shall expend, to provide technical assistance for entities funded under part B or D, an amount from funds appropriated under subsection (a) that is not less than the amount the Secretary expended on technical assistance for entities funded under that part (or a corresponding provision) in the previous fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdd5f98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15083/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered year","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “covered year” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfdd5f99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15083/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an expenditure for entities funded under part B, a fiscal year for which the amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15029/a"},"text":"section 15029(a) of this title","children":[],"tail":" is less than $76,000,000; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdd5f9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15083/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an expenditure for entities funded under part D, a fiscal year prior to the first fiscal year for which the amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15066/a/1"},"text":"section 15066(a)(1) of this title","children":[],"tail":" is not less than $20,000,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdd5f9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15083/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" References","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"References in this subsection to part D shall not be considered to include ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15063/c/4"},"text":"section 15063(c)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdd5f9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15083/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance on electronic information sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to any funds reserved under subsection (c), the Secretary shall reserve $100,000 from the amount appropriated under subsection (a) for each fiscal year to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15063/c/4"},"text":"section 15063(c)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdd5f9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15083/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For any fiscal year for which the amount appropriated under subsection (a) is not less than $10,000,000, not more than 50 percent of such amount shall be used for activities carried out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15081/2/A"},"text":"section 15081(2)(A) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfdd5f9e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/402/tI/s163"},"text":"Pub. L. 106–402, title I, § 163","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1727"},"text":"114 Stat. 1727","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
