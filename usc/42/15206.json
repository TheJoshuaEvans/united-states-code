{"tag":"section","attrib":{"id":"idbfdfd095-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15206"},"text":null,"children":[{"tag":"num","attrib":{"value":"15206"},"text":"§ 15206.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Medal of Valor Office","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is established within the Department of Justice a National Medal of Valor Office. The Office shall provide staff support to the Board to establish criteria and procedures for the submission of recommendations of nominees for the Medal of Valor and for the final design of the Medal of Valor.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbfdfd096-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/12/s7"},"text":"Pub. L. 107–12, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-05-30"},"text":"May 30, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/22"},"text":"115 Stat. 22","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
