{"tag":"section","attrib":{"id":"idb61d0819-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–81"},"text":null,"children":[{"tag":"num","attrib":{"value":"300d–81"},"text":"§ 300d–81.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb61d081a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–81/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To promote universal access to trauma care services provided by trauma centers and trauma-related physician specialties, the Secretary shall provide funding to States to enable such States to award grants to eligible entities for the purposes described in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb61d081b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–81/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awarding of grants by States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State may award grants to eligible entities within the State for the purposes described in subparagraph (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb61d081c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–81/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb61d081d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–81/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under subsection (b) an entity shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb61d081e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–81/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb61d081f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–81/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public or nonprofit trauma center or consortium thereof that meets that ","children":[{"tag":"ref","attrib":{"idref":"fn002333"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002333"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “the”."}],"tail":" requirements of paragraphs (1), (2), and (5) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–41/b"},"text":"section 300d–41(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb61d0820-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–81/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a safety net public or nonprofit trauma center that meets the requirements of paragraphs (1) through (5) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–41/b"},"text":"section 300d–41(b) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb61d0821-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–81/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a hospital in an underserved area (as defined by the State) that seeks to establish new trauma services; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb61d0822-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–81/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the State an application at such time, in such manner, and containing such information as the State may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb61d0823-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–81/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State shall use at least 40 percent of the amount available to the State under this part for a fiscal year to award grants to safety net trauma centers described in paragraph (1)(A)(ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb61d0824-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–81/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The recipient of a grant under subsection (b) shall carry out 1 or more of the following activities consistent with subsection (b):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb61d0825-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–81/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing trauma centers with funding to support physician compensation in trauma-related physician specialties where shortages exist in the region involved, with priority provided to safety net trauma centers described in subsection (c)(1)(A)(ii).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb61d0826-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–81/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing for individual safety net trauma center fiscal stability and costs related to having service that is available 24 hours a day, 7 days a week, with priority provided to safety net trauma centers described in subsection (c)(1)(A)(ii) located in urban, border, and rural areas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb61d0827-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–81/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reducing trauma center overcrowding at specific trauma centers related to throughput of trauma patients.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb61d0828-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–81/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establishing new trauma services in underserved areas as defined by the State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb61d0829-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–81/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Enhancing collaboration between trauma centers and other hospitals and emergency medical services personnel related to trauma service availability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb61d082a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–81/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Making capital improvements to enhance access and expedite trauma care, including providing helipads and associated safety infrastructure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb61d082b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–81/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Enhancing trauma surge capacity at specific trauma centers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb61d082c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–81/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ensuring expedient receipt of trauma patients transported by ground or air to the appropriate trauma center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb61d082d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–81/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Enhancing interstate trauma center collaboration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb61d082e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–81/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb61d082f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–81/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State may use not more than 20 percent of the amount available to the State under this part for a fiscal year for administrative costs associated with awarding grants and related costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb61d0830-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–81/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of effort","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not provide funding to a State under this part unless the State agrees that such funds will be used to supplement and not supplant State funding otherwise available for the activities and costs described in this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb61d0831-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–81/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following shall apply with respect to grants provided in this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb61d0832-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–81/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Less than $10,000,000","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the amount of appropriations for this part in a fiscal year is less than $10,000,000, the Secretary shall divide such funding evenly among only those States that have 1 or more trauma centers eligible for funding under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–41/b/3/A"},"text":"section 300d–41(b)(3)(A) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb61d0833-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–81/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Less than $20,000,000","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the amount of appropriations in a fiscal year is less than $20,000,000, the Secretary shall divide such funding evenly among only those States that have 1 or more trauma centers eligible for funding under subparagraphs (A) and (B) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–41/b/3"},"text":"section 300d–41(b)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb61d0834-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–81/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Less than $30,000,000","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the amount of appropriations for this part in a fiscal year is less than $30,000,000, the Secretary shall divide such funding evenly among only those States that have 1 or more trauma centers eligible for funding under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–41/b/3"},"text":"section 300d–41(b)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb61d0835-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–81/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" $30,000,000 or more","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the amount of appropriations for this part in a fiscal year is $30,000,000 or more, the Secretary shall divide such funding evenly among all States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb61d0836-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XII, § 1281, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIII/s3505/b"},"text":"Pub. L. 111–148, title III, § 3505(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/525"},"text":"124 Stat. 525","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
