{"tag":"section","attrib":{"id":"idb57d1f51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285q"},"text":null,"children":[{"tag":"num","attrib":{"value":"285q"},"text":"§ 285q.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of Institute","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The general purpose of the National Institute of Nursing Research (in this subpart referred to as the “Institute”) is the conduct and support of, and dissemination of information respecting, basic and clinical nursing research, training, and other programs in patient care research.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb57d1f52-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 464V, formerly § 483, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/158/s2"},"text":"Pub. L. 99–158, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-20"},"text":"Nov. 20, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/867"},"text":"99 Stat. 867","children":[],"tail":"; renumbered § 464V and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXV/s1511/a/1"},"text":"Pub. L. 103–43, title XV, § 1511(a)(1)","children":[],"tail":", (b)(2), "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/178"},"text":"107 Stat. 178","children":[],"tail":", 179.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb57d1f53-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb57d1f54-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb57d1f55-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s287c"},"text":"section 287c of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/103/43"},"text":"Pub. L. 103–43","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb57d1f56-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43/s1511/a/1"},"text":"Pub. L. 103–43, § 1511(a)(1)","children":[],"tail":" substituted “Institute” for “Center” in section catchline and “National Institute of Nursing Research (in this subpart referred to as the ‘Institute’)” for “National Center for Nursing Research (hereafter in this subpart referred to as the ‘Center’)” in text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb57d1f57-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb57d1f58-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study on Adequacy of Number of Nurses","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43/s1512"},"text":"Section 1512 of Pub. L. 103–43","children":[],"tail":" directed Secretary of Health and Human Services, acting through Director of National Institute of Nursing Research, to enter into a contract with a public or nonprofit private entity to conduct a study for purpose of determining whether and to what extent there is a need for an increase in the number of nurses in hospitals and nursing homes in order to promote the quality of patient care and reduce the incidence among nurses of work-related injuries and stress and to complete such study and submit a report to Congress not later than 18 months after "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
