{"tag":"section","attrib":{"id":"idbba0781d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1887"},"text":null,"children":[{"tag":"num","attrib":{"value":"1887"},"text":"§ 1887.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indemnification of grantees, contractors, and subcontractors under ocean drilling program; approvals and certifications by Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Foundation is on and after ","children":[{"tag":"date","attrib":{"date":"1985-11-25"},"text":"November 25, 1985","children":[],"tail":", authorized to indemnify grantees, contractors, and subcontractors associated with the ocean drilling program under the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3861"},"text":"section 3861 of title 10","children":[],"tail":", with all approvals and certifications required thereby made by the Director of the National Science Foundation."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbba0781e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/160/tII/s201"},"text":"Pub. L. 99–160, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-25"},"text":"Nov. 25, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/922"},"text":"99 Stat. 922","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1702/j/3"},"text":"Pub. L. 117–81, div. A, title XVII, § 1702(j)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2159"},"text":"135 Stat. 2159","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbba0781f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbba