{"tag":"section","attrib":{"id":"idbe2dda9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7428"},"text":null,"children":[{"tag":"num","attrib":{"value":"7428"},"text":"§ 7428.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State boards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe2dda9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7428/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn003622"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003622"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Section enacted without a subsec. (b)."}],"tail":" Not later than the date one year after "},{"tag":"date","attrib":{"date":"1977-08-07"},"text":"August 7, 1977","children":[],"tail":", each applicable implementation plan shall contain requirements that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe2dda9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7428/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any board or body which approves permits or enforcement orders under this chapter shall have at least a majority of members who represent the public interest and do not derive any significant portion of their income from persons subject to permits or enforcement orders under this chapter, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe2dda9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7428/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any potential conflicts of interest by members of such board or body or the head of an executive agency with similar powers be adequately disclosed.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"A State may adopt any requirements respecting conflicts of interest for such boards or bodies or heads of executive agencies, or any other entities which are more stringent than the requirements of paragraph (1) and (2), and the Administrator shall approve any such more stringent requirements submitted as part of an implementation plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe2dda9f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title I, § 128, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/95/tI/s125"},"text":"Pub. L. 95–95, title I, § 125","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-07"},"text":"Aug. 7, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/725"},"text":"91 Stat. 725","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe2ddaa0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbe2ddaa1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbe2ddaa2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1977-08-07"},"text":"Aug. 7, 1977","children":[],"tail":", except as otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/95/95/s406/d"},"text":"section 406(d) of Pub. L. 95–95","children":[],"tail":", set out as an Effective Date of 1977 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7401"},"text":"section 7401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
