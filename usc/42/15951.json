{"tag":"section","attrib":{"id":"idbfebb6ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15951"},"text":null,"children":[{"tag":"num","attrib":{"value":"15951"},"text":"§ 15951.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfebb6cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15951/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfebb6d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15951/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it serves the national interest to increase petroleum refining capacity for gasoline, heating oil, diesel fuel, jet fuel, kerosene, and petrochemical feedstocks wherever located within the United States, to bring more supply to the markets for the use of the American people;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfebb6d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15951/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States demand for refined petroleum products currently exceeds the country’s petroleum refining capacity to produce such products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfebb6d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15951/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this excess demand has been met with increased imports;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfebb6d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15951/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" due to lack of capacity, refined petroleum product imports are expected to grow from 7.9 percent to 10.7 percent of total refined product by 2025;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfebb6d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15951/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refiners are still subject to significant environmental and other regulations and face several new requirements under the Clean Air Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7401"},"text":"42 U.S.C. 7401","children":[],"tail":" et seq.) over the next decade; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfebb6d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15951/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" better coordination of Federal and State regulatory reviews may help facilitate siting and construction of new refineries to meet the demand in the United States for refined products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfebb6d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15951/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfebb6d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15951/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Administrator of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfebb6d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15951/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “State” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfebb6d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15951/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfebb6da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15951/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commonwealth of Puerto Rico; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfebb6db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15951/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfebb6dc-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIII/s391"},"text":"Pub. L. 109–58, title III, § 391","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/748"},"text":"119 Stat. 748","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfebb6dd-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfebb6de-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfebb6df-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Clean Air Act, referred to in subsec. (a)(5), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"act July 14, 1955, ch. 360","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/322"},"text":"69 Stat. 322","children":[],"tail":", which is classified generally to chapter 85 (§ 7401 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7401"},"text":"section 7401 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
