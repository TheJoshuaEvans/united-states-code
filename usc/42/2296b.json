{"tag":"section","attrib":{"id":"idbc17a4ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2296b"},"text":"§ 2296b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overfeed program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc17a4cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uranium purchases","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent permitted by sound business practice, the Corporation shall purchase uranium in accordance with subsection (b) and overfeed it into the enrichment process to reduce the amount of power required to produce the enriched uranium ordered by enrichment services customers, taking into account costs associated with depleted tailings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc17a4d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of domestic uranium","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Uranium purchased by the Corporation for purposes of this section shall be of domestic origin and purchased from domestic uranium producers to the extent permitted under the multilateral trade agreements (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3501/4"},"text":"section 3501(4) of title 19","children":[],"tail":") and the USMCA (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4502"},"text":"section 4502 of title 19","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc17a4d1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tX/s1011"},"text":"Pub. L. 102–486, title X, § 1011","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2948"},"text":"106 Stat. 2948","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/36/tI/s1002/g/1"},"text":"Pub. L. 106–36, title I, § 1002(g)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-06-25"},"text":"June 25, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/133"},"text":"113 Stat. 133","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dO/tVI/s602/e"},"text":"Pub. L. 116–260, div. O, title VI, § 602(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2153"},"text":"134 Stat. 2153","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc17a4d2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc17a4d3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbc17a4d4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy Policy Act of 1992, and not as part of the Atomic Energy Act of 1954 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc17a4d5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" substituted “USMCA (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4502"},"text":"section 4502 of title 19","children":[],"tail":")” for “North American Free Trade Agreement”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/36"},"text":"Pub. L. 106–36","children":[],"tail":" substituted “multilateral trade agreements (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3501/4"},"text":"section 3501(4) of title 19","children":[],"tail":") and the North American Free Trade Agreement” for “General Agreement on Tariffs and Trade and the United States-Canada Free Trade Agreement”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc17a4d6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbc17a4d7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2020-07-01"},"text":"July 1, 2020","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dO/s602/g"},"text":"section 602(g) of div. O of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2578b"},"text":"section 2578b of Title 19","children":[],"tail":", Customs Duties."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
