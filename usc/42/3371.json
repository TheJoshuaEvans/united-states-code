{"tag":"section","attrib":{"id":"idbc7e2dbd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3371"},"text":null,"children":[{"tag":"num","attrib":{"value":"3371"},"text":"§ 3371.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance for housing in Alaska","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc7e2dbe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3371/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loans and grants; authorization; purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Housing and Urban Development (hereinafter referred to as the “Secretary”) may make loans and grants on the basis of need to the regional native housing authorities duly constituted under the laws of the State of Alaska for the purpose of providing planning assistance, housing rehabilitation, and maintaining an adequate administrative structure in conjunction with the provision of housing and related facilities for Alaska residents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc7e2dbf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3371/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants under this section shall not exceed 75 per centum of the aggregate cost of the housing and related facilities to be constructed under an approved program, except that the Secretary may make a grant in excess of such limitation in any case, after consultation with State officials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc7e2dc0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3371/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated not to exceed $10,000,000 to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc7e2dc1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/754/tX/s1004"},"text":"Pub. L. 89–754, title X, § 1004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-03"},"text":"Nov. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1284"},"text":"80 Stat. 1284","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/152/tII/s220"},"text":"Pub. L. 91–152, title II, § 220","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-24"},"text":"Dec. 24, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/390"},"text":"83 Stat. 390","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/557/tIX/s904"},"text":"Pub. L. 95–557, title IX, § 904","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-31"},"text":"Oct. 31, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2125"},"text":"92 Stat. 2125","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc7e2dc2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc7e2dc3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc7e2dc4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/557/s904/a"},"text":"Pub. L. 95–557, § 904(a)","children":[],"tail":", revised subsec. (a) generally to require that the Department of Housing and Urban Development make loans and grants, on the basis of need, to regional Alaska Native housing authorities for certain planning, administrative, and other expenses in conjunction with the provision of housing and related facilities for Alaska residents."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/557/s904/b"},"text":"Pub. L. 95–557, § 904(b)","children":[],"tail":", inserted “except that the Secretary may make a grant in excess of such limitation in any case, after consultation with State officials”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/152"},"text":"Pub. L. 91–152","children":[],"tail":" substituted “$10,875” for “$7,500”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
