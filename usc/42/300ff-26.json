{"tag":"section","attrib":{"id":"idb696a53c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–26"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ff–26"},"text":"§ 300ff–26.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of treatments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb696a53d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–26/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State shall use a portion of the amounts provided under a grant awarded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–21"},"text":"section 300ff–21 of this title","children":[],"tail":" to establish a program under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–22/b/3/B"},"text":"section 300ff–22(b)(3)(B) of this title","children":[],"tail":" to provide therapeutics to treat HIV/AIDS or prevent the serious deterioration of health arising from HIV/AIDS in eligible individuals, including measures for the prevention and treatment of opportunistic infections."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb696a53e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–26/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible individual","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive assistance from a State under this section an individual shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb696a53f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–26/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a medical diagnosis of HIV/AIDS; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb696a540-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–26/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a low-income individual, as defined by the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb696a541-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–26/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section the State shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb696a542-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–26/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the therapeutics included on the list of classes of core antiretroviral therapeutics established by the Secretary under subsection (e) are, at a minimum, the treatments provided by the State pursuant to this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb696a543-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–26/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide assistance for the purchase of treatments determined to be eligible under paragraph (1), and the provision of such ancillary devices that are essential to administer such treatments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb696a544-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–26/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide outreach to individuals with HIV/AIDS, and as appropriate to the families of such individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb696a545-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–26/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate access to treatments for such individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb696a546-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–26/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" document the progress made in making therapeutics described in subsection (a) available to individuals eligible for assistance under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb696a547-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–26/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage, support, and enhance adherence to and compliance with treatment regimens, including related medical monitoring.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Of the amount reserved by a State for a fiscal year for use under this section, the State may not use more than 5 percent to carry out services under paragraph (6), except that the percentage applicable with respect to such paragraph is 10 percent if the State demonstrates to the Secretary that such additional services are essential and in no way diminish access to the therapeutics described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb696a548-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–26/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Secretary shall review the current status of State drug reimbursement programs established under section 300ff–22(2) ","children":[{"tag":"ref","attrib":{"idref":"fn002429"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002429"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title and assess barriers to the expanded availability of the treatments described in subsection (a). The Secretary shall also examine the extent to which States coordinate with other grantees under this subchapter to reduce barriers to the expanded availability of the treatments described in subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb696a549-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–26/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" List of classes of core antiretroviral therapeutics","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (c)(1), the Secretary shall develop and maintain a list of classes of core antiretroviral therapeutics, which list shall be based on the therapeutics included in the guidelines of the Secretary known as the Clinical Practice Guidelines for Use of HIV/AIDS Drugs, relating to drugs needed to manage symptoms associated with HIV. The preceding sentence does not affect the authority of the Secretary to modify such Guidelines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb696a54a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–26/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of health insurance and plans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb696a54b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–26/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out subsection (a), a State may expend a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–21"},"text":"section 300ff–21 of this title","children":[],"tail":" to provide the therapeutics described in such subsection by paying on behalf of individuals with HIV/AIDS the costs of purchasing or maintaining health insurance or plans whose coverage includes a full range of such therapeutics and appropriate primary care services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb696a54c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–26/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority established in paragraph (1) applies only to the extent that, for the fiscal year involved, the costs of the health insurance or plans to be purchased or maintained under such paragraph do not exceed the costs of otherwise providing therapeutics described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb696a54d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–26/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drug rebate program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State shall ensure that any drug rebates received on drugs purchased from funds provided pursuant to this section are applied to activities supported under this subpart, with priority given to activities described under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb696a54e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVI, § 2616, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/381/tII/s201"},"text":"Pub. L. 101–381, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/590"},"text":"104 Stat. 590","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/146/s3/c/3"},"text":"Pub. L. 104–146, § 3(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-20"},"text":"May 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1355"},"text":"110 Stat. 1355","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/345/tII/s204"},"text":"Pub. L. 106–345, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-20"},"text":"Oct. 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1332"},"text":"114 Stat. 1332","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/tII"},"text":"Pub. L. 109–415, title II","children":[],"tail":", §§ 201(c)(4), 202, 204(a), title VII, §§ 702(3), 703, "},{"tag":"date","attrib":{"date":"2006-12-19"},"text":"Dec. 19, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2788"},"text":"120 Stat. 2788","children":[],"tail":", 2796, 2820; "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"Pub. L. 111–87, § 2(a)(1)","children":[],"tail":", (3)(A), "},{"tag":"date","attrib":{"date":"2009-10-30"},"text":"Oct. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2885"},"text":"123 Stat. 2885","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb696a54f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb696a550-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb696a551-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–22"},"text":"Section 300ff–22 of this title","children":[],"tail":", referred to in subsec. (d), was amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/tII/s201/a"},"text":"Pub. L. 109–415, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-19"},"text":"Dec. 19, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2785"},"text":"120 Stat. 2785","children":[],"tail":", and, as so amended, does not contain a par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb696a552-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87"},"text":"Pub. L. 111–87","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"Pub. L. 109–415, § 703","children":[],"tail":", and revived the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":". See 2006 Amendment note and Effective Date of 2009 Amendment; Revival of Section note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"Pub. L. 109–415, § 703","children":[],"tail":", which directed repeal of this section effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", was itself repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"Pub. L. 111–87, § 2(a)(1)","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s702/3"},"text":"Pub. L. 109–415, § 702(3)","children":[],"tail":", substituted “HIV/AIDS” for “HIV disease” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s204/a"},"text":"Pub. L. 109–415, § 204(a)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–21"},"text":"section 300ff–21 of this title","children":[],"tail":"” for “this part”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s201/c/4"},"text":"Pub. L. 109–415, § 201(c)(4)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–22/b/3/B"},"text":"section 300ff–22(b)(3)(B) of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–22/a/5"},"text":"section 300ff–22(a)(5) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s702/3"},"text":"Pub. L. 109–415, § 702(3)","children":[],"tail":", substituted “HIV/AIDS” for “HIV disease”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s202/a/1"},"text":"Pub. L. 109–415, § 202(a)(1)","children":[],"tail":", added par. (1) and struck out former par. (1) which read as follows: “determine, in accordance with guidelines issued by the Secretary, which treatments are eligible to be included under the program established under this section;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s702/3"},"text":"Pub. L. 109–415, § 702(3)","children":[],"tail":", substituted “HIV/AIDS” for “HIV disease”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s202/a/3"},"text":"Pub. L. 109–415, § 202(a)(3)","children":[],"tail":", added subsec. (e). Former subsec. (e) redesignated (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s202/a/2"},"text":"Pub. L. 109–415, § 202(a)(2)","children":[],"tail":", redesignated subsec. (e) as (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s702/3"},"text":"Pub. L. 109–415, § 702(3)","children":[],"tail":", substituted “HIV/AIDS” for “HIV disease”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s204/a"},"text":"Pub. L. 109–415, § 204(a)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–21"},"text":"section 300ff–21 of this title","children":[],"tail":"” for “this part”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s202/b"},"text":"Pub. L. 109–415, § 202(b)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/345/s204/a"},"text":"Pub. L. 106–345, § 204(a)","children":[],"tail":", added par. (6) and concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/345/s204/b"},"text":"Pub. L. 106–345, § 204(b)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/146/s3/c/3/A"},"text":"Pub. L. 104–146, § 3(c)(3)(A)","children":[],"tail":", substituted “shall use a portion of the amounts” for “may use amounts” and “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–22/a/5"},"text":"section 300ff–22(a)(5) of this title","children":[],"tail":" to provide therapeutics to treat HIV disease” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–22/a/4"},"text":"section 300ff–22(a)(4) of this title","children":[],"tail":" to provide treatments that have been determined to prolong life” and inserted before period “, including measures for the prevention and treatment of opportunistic infections”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/146/s3/c/3/B"},"text":"Pub. L. 104–146, § 3(c)(3)(B)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/146/s3/c/3/C"},"text":"Pub. L. 104–146, § 3(c)(3)(C)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb696a553-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb696a554-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment; Revival of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions that repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"section 2(a)(1) of Pub. L. 111–87","children":[],"tail":" of "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"section 703 of Pub. L. 109–415","children":[],"tail":" be effective "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", and that the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", be revived, see section 2(a)(2), (3)(A) of "},{"tag":"ref","attrib":{"href":"/us/pl/111/87"},"text":"Pub. L. 111–87","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–11"},"text":"section 300ff–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb696a555-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/146"},"text":"Pub. L. 104–146","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/146/s13"},"text":"section 13 of Pub. L. 104–146","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–11"},"text":"section 300ff–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
