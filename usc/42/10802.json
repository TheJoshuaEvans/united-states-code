{"tag":"section","attrib":{"id":"idbf2f44bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10802"},"text":null,"children":[{"tag":"num","attrib":{"value":"10802"},"text":"§ 10802.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf2f44c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10802/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “abuse” means any act or failure to act by an employee of a facility rendering care or treatment which was performed, or which was failed to be performed, knowingly, recklessly, or intentionally, and which caused, or may have caused, injury or death to a ","children":[{"tag":"ref","attrib":{"idref":"fn003971"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003971"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “an”."}],"tail":" individual with mental illness, and includes acts such as—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf2f44c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10802/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rape or sexual assault of a ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" individual with mental illness;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2f44c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10802/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the striking of a ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" individual with mental illness;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2f44c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10802/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of excessive force when placing a ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" individual with mental illness in bodily restraints; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2f44c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10802/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of bodily or chemical restraints on a ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" individual with mental illness which is not in compliance with Federal and State laws and regulations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2f44c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10802/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “eligible system” means the system established in a State to protect and advocate the rights of persons with developmental disabilities under subtitle C of the Developmental Disabilities Assistance and Bill of Rights Act of 2000 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15041"},"text":"42 U.S.C. 15041","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2f44c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10802/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “facilities” may include, but need not be limited to, hospitals, nursing homes, community facilities for individuals with mental illness, board and care homes, homeless shelters, and jails and prisons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2f44c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10802/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “individual with mental illness” means, except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10804/d"},"text":"section 10804(d) of this title","children":[],"tail":", an individual—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf2f44c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10802/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has a significant mental illness or emotional impairment, as determined by a mental health professional qualified under the laws and regulations of the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2f44c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10802/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf2f44ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10802/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbf2f44cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10802/4/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is an inpatient or resident in a facility rendering care or treatment, even if the whereabouts of such inpatient or resident are unknown;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf2f44cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10802/4/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is in the process of being admitted to a facility rendering care or treatment, including persons being transported to such a facility; or”; ","children":[{"tag":"ref","attrib":{"idref":"fn003972"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003972"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf2f44cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10802/4/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is involuntarily confined in a municipal detention facility for reasons other than serving a sentence resulting from conviction for a criminal offense; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf2f44ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10802/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who satisfies the requirements of subparagraph (A) and lives in a community setting, including their own home.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2f44cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10802/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “neglect” means a negligent act or omission by any individual responsible for providing services in a facility rendering care or treatment which caused or may have caused injury or death to a ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" individual with mental illness or which placed a "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" individual with mental illness at risk of injury or death, and includes an act or omission such as the failure to establish or carry out an appropriate individual program plan or treatment plan for a "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" individual with mental illness, the failure to provide adequate nutrition, clothing, or health care to a "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" individual with mental illness, or the failure to provide a safe environment for a "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" individual with mental illness, including the failure to maintain adequate numbers of appropriately trained staff."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2f44d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10802/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2f44d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10802/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State” means each of the several States, the District of Columbia, the Commonwealth of Puerto Rico, Guam, the Commonwealth of the Northern Mariana Islands, American Samoa, the Virgin Islands, and the Trust Territory of the Pacific Islands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2f44d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10802/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “American Indian consortium” means a consortium established under part C of the Developmental Disabilities Assistance and Bill of Rights Act ","children":[{"tag":"ref","attrib":{"idref":"fn003973"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003973"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" See References in Text note below."}],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6042"},"text":"42 U.S.C. 6042","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf2f44d3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/319/tI/s102"},"text":"Pub. L. 99–319, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-05-23"},"text":"May 23, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/478"},"text":"100 Stat. 478","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/509/s3"},"text":"Pub. L. 100–509, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-20"},"text":"Oct. 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2543"},"text":"102 Stat. 2543","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/173"},"text":"Pub. L. 102–173","children":[],"tail":", §§ 4, 10(1), "},{"tag":"date","attrib":{"date":"1991-11-27"},"text":"Nov. 27, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1217"},"text":"105 Stat. 1217","children":[],"tail":", 1219; "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dB/tXXXII/s3206/b"},"text":"Pub. L. 106–310, div. B, title XXXII, § 3206(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1194"},"text":"114 Stat. 1194","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/402/tIV/s401/b/13/A"},"text":"Pub. L. 106–402, title IV, § 401(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1739"},"text":"114 Stat. 1739","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf2f44d4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf2f44d5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf2f44d6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Developmental Disabilities Assistance and Bill of Rights Act of 2000, referred to in par. (2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/402"},"text":"Pub. L. 106–402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1677"},"text":"114 Stat. 1677","children":[],"tail":". Subtitle C of the Act probably means subtitle C of title I of the Act, which is classified generally to part C (§ 15041 et seq.) of subchapter I of chapter 144 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s15001"},"text":"section 15001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Developmental Disabilities Assistance and Bill of Rights Act, referred to in par. (8), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/164"},"text":"Pub. L. 88–164","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/98/527/s2"},"text":"Pub. L. 98–527, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2662"},"text":"98 Stat. 2662","children":[],"tail":", which was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/106/402/tIV/s401/a"},"text":"Pub. L. 106–402, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1737"},"text":"114 Stat. 1737","children":[],"tail":". Part C of the Act was classified generally to subchapter III (§ 6041 et seq.) of chapter 75 of this title. Provisions similar to former part C of the Act are contained in subtitle C of title I of the Developmental Disabilities Assistance and Bill of Rights Act of 2000, "},{"tag":"ref","attrib":{"href":"/us/pl/106/402"},"text":"Pub. L. 106–402","children":[],"tail":", which is classified generally to part C (§ 15041 et seq.) of subchapter I of chapter 144 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf2f44d7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/402"},"text":"Pub. L. 106–402","children":[],"tail":" substituted “subtitle C of the Developmental Disabilities Assistance and Bill of Rights Act of 2000” for “part C of the Developmental Disabilities Assistance and Bill of Rights Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310/s3206/b/1/A"},"text":"Pub. L. 106–310, § 3206(b)(1)(A)","children":[],"tail":", inserted “, except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10804/d"},"text":"section 10804(d) of this title","children":[],"tail":",” after “means” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310/s3206/b/1/B"},"text":"Pub. L. 106–310, § 3206(b)(1)(B)","children":[],"tail":", designated existing provisions as cl. (i), redesignated former cls. (i) to (iii) as subcls. (I) to (III), respectively, of cl. (i), and added cl. (ii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310/s3206/b/2"},"text":"Pub. L. 106–310, § 3206(b)(2)","children":[],"tail":", added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/173/s10/1"},"text":"Pub. L. 102–173, § 10(1)","children":[],"tail":", substituted “individual with mental illness” for “mentally ill individual” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (3) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/173"},"text":"Pub. L. 102–173","children":[],"tail":" added par. (3), redesignated former pars. (3) to (6) as (4) to (7), respectively, and substituted “individual with mental illness” for “mentally ill individual” wherever appearing in pars. (4) and (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/509/s3/1"},"text":"Pub. L. 100–509, § 3(1)","children":[],"tail":", inserted “or death” after “caused, injury”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/509/s3/2"},"text":"Pub. L. 100–509, § 3(2)","children":[],"tail":", designated existing provisions as cl. (i), substituted “, even if the whereabouts of such inpatient or resident are unknown;” for period at end, and added cls. (ii) and (iii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/509/s3/3"},"text":"Pub. L. 100–509, § 3(3)","children":[],"tail":", inserted “or death” after “injury” in two places and inserted before period at end “, including the failure to maintain adequate numbers of appropriately trained staff”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbf2f44d8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbf2f44d9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Termination of Trust Territory of the Pacific Islands","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For termination of Trust Territory of the Pacific Islands, see note set out preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"section 1681 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
