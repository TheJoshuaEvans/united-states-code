{"tag":"section","attrib":{"id":"idbf687c6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12211"},"text":null,"children":[{"tag":"num","attrib":{"value":"12211"},"text":"§ 12211.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf687c6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12211/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Homosexuality and bisexuality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of the definition of “disability” in section 12102(2) ","children":[{"tag":"ref","attrib":{"idref":"fn004039"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004039"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, homosexuality and bisexuality are not impairments and as such are not disabilities under this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf687c70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12211/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under this chapter, the term “disability” shall not include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf687c71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12211/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transvestism, transsexualism, pedophilia, exhibitionism, voyeurism, gender identity disorders not resulting from physical impairments, or other sexual behavior disorders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf687c72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12211/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compulsive gambling, kleptomania, or pyromania; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf687c73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12211/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" psychoactive substance use disorders resulting from current illegal use of drugs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf687c74-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/336/tV/s512"},"text":"Pub. L. 101–336, title V, § 512","children":[],"tail":", formerly § 511, "},{"tag":"date","attrib":{"date":"1990-07-26"},"text":"July 26, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/376"},"text":"104 Stat. 376","children":[],"tail":"; renumbered § 512, "},{"tag":"ref","attrib":{"href":"/us/pl/110/325/s6/a/2"},"text":"Pub. L. 110–325, § 6(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-09-25"},"text":"Sept. 25, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3558"},"text":"122 Stat. 3558","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf687c75-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf687c76-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail"