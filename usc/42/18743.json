{"tag":"section","attrib":{"id":"idc0655507-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743"},"text":null,"children":[{"tag":"num","attrib":{"value":"18743"},"text":"§ 18743.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Critical minerals mining and recycling research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0655508-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0655509-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Critical mineral","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “critical mineral” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1606/a"},"text":"section 1606(a) of title 30","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc065550a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Critical minerals and metals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “critical minerals and metals” includes any host mineral of a critical mineral.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc065550b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Director” means the Director of the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc065550c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" End-to-end","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “end-to-end”, with respect to the integration of mining or life cycle of minerals, means the integrated approach of, or the lifecycle determined by, examining the research and developmental process from the mining of the raw minerals to its processing into useful materials, its integration into components and devices, the utilization of such devices in the end-use application to satisfy certain performance metrics, and the recycling or disposal of such devices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc065550d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign entity of concern","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “foreign entity of concern” means a foreign entity that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc065550e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designated as a foreign terrorist organization by the Secretary of State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1189/a"},"text":"section 1189(a) of title 8","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc065550f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" included on the list of specially designated nationals and blocked persons maintained by the Office of Foreign Assets Control of the Department of the Treasury (commonly known as the SDN list);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0655510-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned by, controlled by, or subject to the jurisdiction or direction of a government of a foreign country that is a covered nation (as defined in section 2533c(d) ","children":[{"tag":"ref","attrib":{"idref":"fn004370"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004370"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 10);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0655511-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/a/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" alleged by the Attorney General to have been involved in activities for which a conviction was obtained under—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0655512-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/a/5/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 37 of title 18 (commonly known as the “Espionage Act”);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0655513-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/a/5/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 951 or 1030 of title 18;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0655514-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/a/5/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 90 of title 18 (commonly known as the “Economic Espionage Act of 1996)”;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0655515-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/a/5/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Arms Export Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2751"},"text":"22 U.S.C. 2751","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0655516-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/a/5/D/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 224, 225, 226, 227, or 236 of the Atomic Energy Act of 1954 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2274"},"text":"42 U.S.C. 2274","children":[],"tail":", 2275, 2276, 2277, and "},{"tag":"ref","attrib":{"idref":"fn004371"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004371"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “or”."}],"tail":" 2284);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0655517-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/a/5/D/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Export Control Reform Act of 2018 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4801"},"text":"50 U.S.C. 4801","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0655518-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/a/5/D/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the International Emergency Economic Powers Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0655519-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/a/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determined by the Secretary of Commerce, in consultation with the Secretary of Defense and the Director of National Intelligence, to be engaged in unauthorized conduct that is detrimental to the national security or foreign policy of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc065551a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foundation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Foundation” means the National Science Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc065551b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institution of higher education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “institution of higher education” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc065551c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Laboratory","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “National Laboratory” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15801"},"text":"section 15801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc065551d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recycling","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “recycling” means the process of collecting and processing spent materials and devices and turning the materials and devices into raw materials or components that can be reused either partially or completely.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc065551e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secondary recovery","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “secondary recovery” means the recovery of critical minerals and metals from discarded end-use products or from waste products produced during the metal refining and manufacturing process, including from mine waste piles, acid mine drainage sludge, or byproducts produced through legacy mining and metallurgy activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc065551f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Critical minerals mining and recycling research and development","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0655520-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to support supply chain resiliency, the Secretary, in coordination with the Director, shall issue awards, on a competitive basis, to eligible entities described in paragraph (2) to support basic research that will accelerate innovation to advance critical minerals mining, recycling, and reclamation strategies and technologies for the purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0655521-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making better use of domestic resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0655522-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eliminating national reliance on minerals and mineral materials that are subject to supply disruptions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0655523-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Entities eligible to receive an award under paragraph (1) are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0655524-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Institutions of higher education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0655525-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" National Laboratories.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0655526-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nonprofit organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0655527-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Consortia of entities described in subparagraphs (A) through (C), including consortia that collaborate with private industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0655528-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities funded by an award under this section may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0655529-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" advancing mining research and development activities to develop new mapping and mining technologies and techniques, including advanced critical mineral extraction and production—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc065552a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve existing, or to develop new, supply chains of critical minerals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc065552b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to yield more efficient, economical, and environmentally benign mining practices;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc065552c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advancing critical mineral processing research activities to improve separation, alloying, manufacturing, or recycling techniques and technologies that can decrease the energy intensity, waste, potential environmental impact, and costs of those activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc065552d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advancing research and development of critical minerals mining and recycling technologies that take into account the potential end-uses and disposal of critical minerals, in order to improve end-to-end integration of mining and technological applications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc065552e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting long-term earth observation of reclaimed mine sites, including the study of the evolution of microbial diversity at those sites;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc065552f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examining the application of artificial intelligence for geological exploration of critical minerals, including what size and diversity of data sets would be required;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0655530-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examining the application of machine learning for detection and sorting of critical minerals, including what size and diversity of data sets would be required;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0655531-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/b/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting detailed isotope studies of critical minerals and the development of more refined geologic models; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0655532-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/b/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing training and research opportunities to undergraduate and graduate students to prepare the next generation of mining engineers and researchers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc067c433-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Critical minerals interagency subcommittee","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc067c434-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to support supply chain resiliency, the Critical Minerals Subcommittee of the National Science and Technology Council (referred to in this subsection as the “Subcommittee”) shall coordinate Federal science and technology efforts to ensure secure and reliable supplies of critical minerals to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c435-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the Subcommittee shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc067c436-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to advise and assist the National Science and Technology Council, including the Committee on Homeland and National Security of the National Science and Technology Council, on United States policies, procedures, and plans relating to critical minerals, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc067c437-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal research, development, and deployment efforts to optimize methods for extractions, concentration, separation, and purification of conventional, secondary, and unconventional sources of critical minerals, including research that prioritizes end-to-end integration of mining and recycling techniques and the end-use target for critical minerals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc067c438-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efficient use and reuse of critical minerals, including recycling technologies for critical minerals and the reclamation of critical minerals from components, such as spent batteries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc067c439-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" addressing the technology transitions between research or lab-scale mining and recycling and commercialization of these technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc067c43a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/c/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the critical minerals workforce of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc067c43b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/c/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States private industry investments in innovation and technology transfer from federally funded science and technology;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c43c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify emerging opportunities, stimulate international cooperation, and foster the development of secure and reliable supply chains of critical minerals, including activities relating to the reuse of critical minerals via recycling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c43d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure the transparency of information and data related to critical minerals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c43e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide recommendations on coordination and collaboration among the research, development, and deployment programs and activities of Federal agencies to promote a secure and reliable supply of critical minerals necessary to maintain national security, economic well-being, and industrial production.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c43f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out paragraphs (1) and (2), the Subcommittee may, taking into account the findings and recommendations of relevant advisory committees—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc067c440-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide recommendations on how Federal agencies may improve the topographic, geologic, and geophysical mapping of the United States and improve the discoverability, accessibility, and usability of the resulting and existing data, to the extent permitted by law and subject to appropriate limitation for purposes of privacy and security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c441-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the progress toward developing critical minerals recycling and reprocessing technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c442-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the end-to-end lifecycle of critical minerals, including for mining, usage, recycling, and end-use material and technology requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c443-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examine, and provide recommendations for, options for accessing and developing critical minerals through investment and trade with allies and partners of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c444-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate and provide recommendations to incentivize the development and use of advances in science and technology in the private industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c445-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/c/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assess the need for, and make recommendations to address, the challenges the United States critical minerals supply chain workforce faces, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc067c446-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/c/3/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aging and retiring personnel and faculty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc067c447-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/c/3/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public perceptions about the nature of mining and mineral processing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc067c448-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/c/3/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign competition for United States talent;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c449-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/c/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop, and update as necessary, a strategic plan to guide Federal programs and activities to enhance—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc067c44a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/c/3/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scientific and technical capabilities across critical mineral supply chains, including a roadmap that identifies key research and development needs and coordinates ongoing activities for source diversification, more efficient use, recycling, and substitution for critical minerals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc067c44b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/c/3/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cross-cutting mining science, data science techniques, materials science, manufacturing science and engineering, computational modeling, and environmental health and safety research and development; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c44c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/c/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report to the appropriate committees of Congress on activities and findings under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c44d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory responsibilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out paragraphs (1) and (2), the Subcommittee shall, taking into account the findings and recommendations of relevant advisory committees, identify and evaluate Federal policies and regulations that restrict the mining of critical minerals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc067c44e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program for processing of critical minerals and development of critical minerals and metals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc067c44f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the Director, the Secretary of the Interior, and the Secretary of Commerce, shall establish a grant program to finance pilot projects for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc067c450-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the processing or recycling of critical minerals in the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c451-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of critical minerals and metals in the United States ","children":[{"tag":"ref","attrib":{"idref":"fn004372"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004372"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. Probably should be followed by a period."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c452-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on grant awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant awarded under paragraph (1) may not exceed $10,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c453-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Economic viability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under paragraph (1), the Secretary shall give priority to projects that the Secretary determines are likely to be economically viable over the long term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c454-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secondary recovery","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under paragraph (1), the Secretary shall seek to award not less than 30 percent of the total amount of grants awarded during the fiscal year for projects relating to secondary recovery of critical minerals and metals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c455-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Domestic priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants for the development of critical minerals and metals under paragraph (1)(B), the Secretary shall prioritize pilot projects that will process the critical minerals and metals domestically.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c456-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on processing by foreign entity of concern","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under paragraph (1), the Secretary shall ensure that pilot projects do not export for processing any critical minerals and metals to a foreign entity of concern.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c457-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18743/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary to carry out the grant program established under paragraph (1) $100,000,000 for each of fiscal years 2021 through 2024.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc067c458-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tII/s40210"},"text":"Pub. L. 117–58, div. D, title II, § 40210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/978"},"text":"135 Stat. 978","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc067c459-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc067c45a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc067c45b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2533c/d"},"text":"Section 2533c(d) of title 10","children":[],"tail":", referred to subsec. (a)(5)(C), was renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4872/d"},"text":"section 4872(d) of title 10","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1870/d/2"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1870(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4286"},"text":"134 Stat. 4286","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/t/2/B"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(t)(2)(B)","childr