{"tag":"section","attrib":{"id":"idbfb00cd0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13104"},"text":null,"children":[{"tag":"num","attrib":{"value":"13104"},"text":"§ 13104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to States for State technical assistance programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfb00cd1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall make matching grants to States for programs to promote the use of source reduction techniques by businesses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfb00cd2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"When evaluating the requests for grants under this section, the Administrator shall consider, among other things, whether the proposed State program would accomplish the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfb00cd3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13104/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Make specific technical assistance available to businesses seeking information about source reduction opportunities, including funding for experts to provide onsite technical advice to business ","children":[{"tag":"ref","attrib":{"idref":"fn004146"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004146"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “businesses”."}],"tail":" seeking assistance and to assist in the development of source reduction plans."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb00cd4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13104/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Target assistance to businesses for whom lack of information is an impediment to source reduction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb00cd5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13104/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provide training in source reduction techniques. Such training may be provided through local engineering schools or any other appropriate means.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfb00cd6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Federal funds used in any State program under this section shall provide no more than 50 per centum of the funds made available to a State in each year of that State’s participation in the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfb00cd7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13104/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effectiveness","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall establish appropriate means for measuring the effectiveness of the State grants made under this section in promoting the use of source reduction techniques by businesses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfb00cd8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13104/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"States receiving grants under this section shall make information generated under the grants available to the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfb00cd9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/tVI/s6605"},"text":"Pub. L. 101–508, title VI, § 6605","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-323"},"text":"104 Stat. 1388–323","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
