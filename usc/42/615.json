{"tag":"section","attrib":{"id":"idb79577df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s615"},"text":null,"children":[{"tag":"num","attrib":{"value":"615"},"text":"§ 615.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waivers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb79577e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s615/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of waivers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb79577e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s615/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waivers in effect on ","children":[{"tag":"date","attrib":{"date":"1996-08-22"},"text":"August 22, 1996","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb79577e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s615/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), if any waiver granted to a State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1315"},"text":"section 1315 of this title","children":[],"tail":" or otherwise which relates to the provision of assistance under a State plan under this part (as in effect on "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"September 30, 1996","children":[],"tail":") is in effect as of "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"August 22, 1996","children":[],"tail":", the amendments made by the Personal Responsibility and Work Opportunity Reconciliation Act of 1996 (other than by section 103(c) of the Personal Responsibility and Work Opportunity Reconciliation Act of 1996) shall not apply with respect to the State before the expiration (determined without regard to any extensions) of the waiver to the extent such amendments are inconsistent with the waiver."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb79577e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s615/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financing limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, beginning with fiscal year 1996, a State operating under a waiver described in subparagraph (A) shall be entitled to payment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s603"},"text":"section 603 of this title","children":[],"tail":" for the fiscal year, in lieu of any other payment provided for in the waiver."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79577e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s615/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waivers granted subsequently","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb79577e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s615/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), if any waiver granted to a State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1315"},"text":"section 1315 of this title","children":[],"tail":" or otherwise which relates to the provision of assistance under a State plan under this part (as in effect on "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"September 30, 1996","children":[],"tail":") is submitted to the Secretary before "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"August 22, 1996","children":[],"tail":", and approved by the Secretary on or before "},{"tag":"date","attrib":{"date":"1997-07-01"},"text":"July 1, 1997","children":[],"tail":", and the State demonstrates to the satisfaction of the Secretary that the waiver will not result in Federal expenditures under subchapter IV of this chapter (as in effect without regard to the amendments made by the Personal Responsibility and Work Opportunity Reconciliation Act of 1996) that are greater than would occur in the absence of the waiver, the amendments made by the Personal Responsibility and Work Opportunity Reconciliation Act of 1996 (other than by section 103(c) of the Personal Responsibility and Work Opportunity Reconciliation Act of 1996) shall not apply with respect to the State before the expiration (determined without regard to any extensions) of the waiver to the extent the amendments made by the Personal Responsibility and Work Opportunity Reconciliation Act of 1996 are inconsistent with the waiver."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb79577e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s615/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No effect on new work requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subparagraph (A), a waiver granted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1315"},"text":"section 1315 of this title","children":[],"tail":" or otherwise which relates to the provision of assistance under a State program funded under this part (as in effect on "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"September 30, 1996","children":[],"tail":") shall not affect the applicability of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s607"},"text":"section 607 of this title","children":[],"tail":" to the State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb79577e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s615/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State option to terminate waiver","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb79577e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s615/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State may terminate a waiver described in subsection (a) before the expiration of the waiver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79577e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s615/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State which terminates a waiver under paragraph (1) shall submit a report to the Secretary summarizing the waiver and any available information concerning the result or effect of the waiver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79577ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s615/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hold harmless provision","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb79577eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s615/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, a State that, not later than the date described in subparagraph (B) of this paragraph, submits a written request to terminate a waiver described in subsection (a) shall be held harmless for accrued cost neutrality liabilities incurred under the waiver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb79577ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s615/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Date described","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The date described in this subparagraph is 90 days following the adjournment of the first regular session of the State legislature that begins after ","children":[{"tag":"date","attrib":{"date":"1996-08-22"},"text":"August 22, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb79577ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s615/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretarial encouragement of current waivers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall encourage any State operating a waiver described in subsection (a) to continue the waiver and to evaluate, using random sampling and other characteristics of accepted scientific evaluations, the result or effect of the waiver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb79577ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s615/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of individual waivers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State may elect to continue 1 or more individual waivers described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb79577ef-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title IV, § 415, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/tI/s103/a/1"},"text":"Pub. L. 104–193, title I, § 103(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2157"},"text":"110 Stat. 2157","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tV/s5514/c"},"text":"Pub. L. 105–33, title V, § 5514(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/620"},"text":"111 Stat. 620","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb79577f0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb79577f