{"tag":"section","attrib":{"id":"idbfee285a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15971"},"text":null,"children":[{"tag":"num","attrib":{"value":"15971"},"text":"§ 15971.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integrated coal/renewable energy system","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfee285b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15971/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of appropriations, the Secretary may provide loan guarantees for a project to produce energy from coal of less than 7,000 Btu/lb. using appropriate advanced integrated gasification combined cycle technology, including repowering of existing facilities, that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfee285c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15971/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is combined with wind and other renewable sources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee285d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15971/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimizes and offers the potential to sequester carbon dioxide emissions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee285e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15971/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides a ready source of hydrogen for near-site fuel cell demonstrations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee285f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15971/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The facility—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfee2860-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15971/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be built in stages;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee2861-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15971/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall have a combined output of at least 200 megawatts at successively more competitive rates; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee2862-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15971/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be located in the Upper Great Plains.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee2863-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15971/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Technical criteria described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15962/b"},"text":"section 15962(b) of this title","children":[],"tail":" shall apply to the facility."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee2864-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15971/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment tax credits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfee2865-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15971/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The loan guarantees provided under this section do not preclude the facility from receiving an allocation for investment tax credits under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s48A"},"text":"section 48A of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee2866-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15971/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Use of the investment tax credit described in paragraph (1) does not prohibit the use of other clean coal program funding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfee2867-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIV/s411"},"text":"Pub. L. 109–58, title IV, § 411","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/754"},"text":"119 Stat. 754","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
