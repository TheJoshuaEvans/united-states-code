{"tag":"section","attrib":{"id":"idbe518e39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7552"},"text":null,"children":[{"tag":"num","attrib":{"value":"7552"},"text":"§ 7552.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Motor vehicle compliance program fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe518e3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7552/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fee collection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s9701"},"text":"section 9701 of title 31","children":[],"tail":", the Administrator may promulgate (and from time to time revise) regulations establishing fees to recover all reasonable costs to the Administrator associated with—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe518e3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7552/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" new vehicle or engine certification under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7525/a"},"text":"section 7525(a) of this title","children":[],"tail":" or part C,"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe518e3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7552/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" new vehicle or engine compliance monitoring and testing under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7525/b"},"text":"section 7525(b) of this title","children":[],"tail":" or part C, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe518e3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7552/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in-use vehicle or engine compliance monitoring and testing under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7541/c"},"text":"section 7541(c) of this title","children":[],"tail":" or part C."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The Administrator may establish for all foreign and domestic manufacturers a fee schedule based on such factors as the Administrator finds appropriate and equitable and nondiscriminatory, including the number of vehicles or engines produced under a certificate of conformity. In the case of heavy-duty engine and vehicle manufacturers, such fees shall not exceed a reasonable amount to recover an appropriate portion of such reasonable costs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe518e3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7552/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special Treasury fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any fees collected under this section shall be deposited in a special fund in the United States Treasury for licensing and other services which thereafter shall be available for appropriation, to remain available until expended, to carry out the Agency’s activities for which the fees were collected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe518e3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7552/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on fund use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Moneys in the special fund referred to in subsection (b) shall not be used until after the first fiscal year commencing after the first July 1 when fees are paid into the fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe518e40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7552/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator’s testing authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall be construed to limit the Administrator’s authority to require manufacturer or confirmatory testing as provided in this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe518e41-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title II, § 217, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/549/tII/s225"},"text":"Pub. L. 101–549, title II, § 225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2504"},"text":"104 Stat. 2504","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
