{"tag":"section","attrib":{"id":"idbfca4bb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13614"},"text":null,"children":[{"tag":"num","attrib":{"value":"13614"},"text":"§ 13614.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General availability of units","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If an owner of a covered section 8 housing project in which disabled families who are near-elderly families are given a preference for occupancy pursuant to subsection (a) or (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13613"},"text":"section 13613 of this title","children":[],"tail":" determines (in accordance with regulations established by the Secretary) that there are an insufficient number of such families to fill all the units in the project for which the preference is applicable, the owner shall make such units generally available for occupancy by families who have applied, and are eligible, for occupancy in the housing, without regard to the preferences established pursuant to this subchapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbfca4bb5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tVI/s654"},"text":"Pub. L. 102–550, title VI, § 654","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3824"},"text":"106 Stat. 3824","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfca4bb6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfca4bb7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tai