{"tag":"section","attrib":{"id":"idbc74b8ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3154a"},"text":"§ 3154a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance awards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc74b8bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make a performance award in connection with a grant made, on or after ","children":[{"tag":"date","attrib":{"date":"2004-10-27"},"text":"October 27, 2004","children":[],"tail":", to an eligible recipient for a project under section 3141 or 3149 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc74b8bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance measures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc74b8bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall promulgate regulations to establish performance measures for making performance awards under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b8be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In promulgating regulations under paragraph (1), the Secretary shall consider the inclusion of performance measures that assess—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc74b8bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the recipient meets or exceeds scheduling goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc74b8c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the recipient meets or exceeds job creation goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc74b8c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154a/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts of private sector capital investments leveraged; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc74b8c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154a/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other factors as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc74b8c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of awards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc74b8c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall base the amount of a performance award made under subsection (a) in connection with a grant on the extent to which a recipient meets or exceeds performance measures established in connection with the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b8c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of a performance award may not exceed 10 percent of the amount of the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc74b8c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A recipient of a performance award under subsection (a) may use the award for any eligible purpose under this chapter, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3212"},"text":"section 3212 of this title","children":[],"tail":" and such regulations as the Secretary may promulgate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc74b8c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3144"},"text":"section 3144 of this title","children":[],"tail":", the funds of a performance award may be used to pay up to 100 percent of the cost of an eligible project or activity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc74b8c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment in meeting non-Federal share requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of meeting the non-Federal share requirements under this, or any other, Act the funds of a performance award shall be treated as funds from a non-Federal source.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc74b8c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making performance awards under subsection (a), the Secretary shall establish such terms and conditions as the Secretary considers to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc74b8ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall use any amounts made available for economic development assistance programs to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc74b8cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154a/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall include information regarding performance awards made under this section in the annual report required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3213"},"text":"section 3213 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc74b8cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154a/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review by Comptroller General","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc74b8cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154a/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller General shall regularly review the implementation of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b8ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154a/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2004-10-27"},"text":"October 27, 2004","children":[],"tail":", the Comptroller General shall submit to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a report on the findings of the Comptroller on implementation of this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc74b8cf-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tII/s215"},"text":"Pub. L. 89–136, title II, § 215","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/373/tII/s210/a"},"text":"Pub. L. 108–373, title II, § 210(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-27"},"text":"Oct. 27, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1764"},"text":"118 Stat. 1764","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
