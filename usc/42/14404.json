{"tag":"section","attrib":{"id":"idbfcf0745-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14404"},"text":null,"children":[{"tag":"num","attrib":{"value":"14404"},"text":"§ 14404.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction on use of Federal funds by advocacy programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfcf0746-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14404/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14402/b"},"text":"section 14402(b) of this title","children":[],"tail":" (relating to construction and treatment of certain services), no funds appropriated by Congress may be used to assist in, to support, or to fund any activity or service which has a purpose of assisting in, or to bring suit or provide any other form of legal assistance for the purpose of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfcf0747-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14404/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" securing or funding any item, benefit, program, or service furnished for the purpose of causing, or the purpose of assisting in causing, the suicide, euthanasia, or mercy killing of any individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfcf0748-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14404/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compelling any person, institution, governmental entity ","children":[{"tag":"ref","attrib":{"idref":"fn004184"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004184"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “or governmental entity”."}],"tail":" to provide or fund any item, benefit, program, or service for such purpose; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfcf0749-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14404/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" asserting or advocating a legal right to cause, or to assist in causing, the suicide, euthanasia, or mercy killing of any individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfcf074a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14404/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" List of programs to which restrictions apply","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfcf074b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14404/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) applies to funds appropriated under or to carry out the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfcf074c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14404/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection and advocacy systems under the Developmental Disabilities Assistance and Bill of Rights Act of 2000","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","at