{"tag":"section","attrib":{"id":"idb6b0bc87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–23"},"text":null,"children":[{"tag":"num","attrib":{"value":"300gg–23"},"text":"§ 300gg–23.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preemption; State flexibility; construction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6b0bc88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–23/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continued applicability of State law with respect to health insurance issuers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6b0bc89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–23/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2) and except as provided in subsection (b), this part, part D, and part C insofar as it relates to this part or part D shall not be construed to supersede any provision of State law which establishes, implements, or continues in effect any standard or requirement solely relating to health insurance issuers in connection with individual or group health insurance coverage except to the extent that such standard or requirement prevents the application of a requirement of this part or part D.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6b0bc8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–23/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continued preemption with respect to group health plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this part or part D shall be construed to affect or modify the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1144"},"text":"section 1144 of title 29","children":[],"tail":" with respect to group health plans."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6b0bc8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–23/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules in case of portability requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6b0bc8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–23/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the provisions of this part relating to health insurance coverage offered by a health insurance issuer supersede any provision of State law which establishes, implements, or continues in effect a standard or requirement applicable to imposition of a preexisting condition exclusion specifically governed by section 701 ","children":[{"tag":"ref","attrib":{"idref":"fn002468"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002468"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" which differs from the standards or requirements specified in such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6b0bc8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–23/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Only in relation to health insurance coverage offered by a health insurance issuer, the provisions of this part do not supersede any provision of State law to the extent that such provision—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6b0bc8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–23/b/2/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substitutes for the reference to “6-month period” in section 2701(a)(1) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" a reference to any shorter period of time;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6b0bc8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–23/b/2/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substitutes for the reference to “12 months” and “18 months” in section 2701(a)(2) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" a reference to any shorter period of time;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6b0bc90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–23/b/2/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substitutes for the references to “63” days in sections 2701(c)(2)(A) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" and 2701(d)(4)(A) "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" a reference to any greater number of days;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6b0bc91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–23/b/2/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substitutes for the reference to “30-day period” in sections 2701(b)(2) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" and 2701(d)(1) "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" a reference to any greater period;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6b0bc92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–23/b/2/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibits the imposition of any preexisting condition exclusion in cases not described in section 2701(d) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" or expands the exceptions described in such section;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6b0bc93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–23/b/2/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires special enrollment periods in addition to those required under section 2701(f) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6b0bc94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–23/b/2/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduces the maximum period permitted in an affiliation period under section 2701(g)(1)(B) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6b0bc95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–23/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this part (other than section 2704) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" or part D shall be construed as requiring a group health plan or health insurance coverage to provide specific benefits under the terms of such plan or coverage."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6b0bc96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–23/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6b0bc97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–23/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State law” includes all laws, decisions, rules, regulations, or other State action having the effect of law, of any State. A law of the United States applicable only to the District of Columbia shall be treated as a State law rather than a law of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6b0bc98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–23/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” includes a State (including the Northern Mariana Islands), any political subdivisions of a State or such Islands, or any agency or instrumentality of either.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6b0bc99-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVII, § 2724, formerly § 2723, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/191/tI/s102/a"},"text":"Pub. L. 104–191, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1971"},"text":"110 Stat. 1971","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/204/tVI/s604/b/2"},"text":"Pub. L. 104–204, title VI, § 604(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-26"},"text":"Sept. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2941"},"text":"110 Stat. 2941","children":[],"tail":"; renumbered § 2737, renumbered § 2724, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI"},"text":"Pub. L. 111–148, title I","children":[],"tail":", §§ 1001(4), 1563(c)(14), formerly § 1562(c)(14), title X, § 10107(b)(1), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/130"},"text":"124 Stat. 130","children":[],"tail":", 269, 911; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dBB/tI/s102/a/3/D"},"text":"Pub. L. 116–260, div. BB, title I, § 102(a)(3)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2772"},"text":"134 Stat. 2772","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6b0bc9a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6b0bc9b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb6b0bc9c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 2701, referred to in subsec. (b), is a reference to section 2701 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":". Section 2701, which was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg"},"text":"section 300gg of this title","children":[],"tail":", was renumbered section 2704, effective for plan years beginning on or after "},{"tag":"date","attrib":{"date":"2014-01-01"},"text":"Jan. 1, 2014","children":[],"tail":", with certain exceptions, and amended, by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI"},"text":"Pub. L. 111–148, title I","children":[],"tail":", §§ 1201(2), 1563(c)(1), formerly § 1562(c)(1), title X, § 10107(b)(1), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/154"},"text":"124 Stat. 154","children":[],"tail":", 264, 911, and was transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–3"},"text":"section 300gg–3 of this title","children":[],"tail":". A new section 2701 of act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", related to fair health insurance premiums, was added, effective for plan years beginning on or after "},{"tag":"date","attrib":{"date":"2014-01-01"},"text":"Jan. 1, 2014","children":[],"tail":", and amended, by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1201/4"},"text":"Pub. L. 111–148, title I, § 1201(4)","children":[],"tail":", title X, § 10103(a), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/155"},"text":"124 Stat. 155","children":[],"tail":", 892, and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg"},"text":"section 300gg of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 701, referred to in subsec. (b)(1), probably means “section 2701” of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":". See note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 2704, referred to in subsec. (c), is a reference to section 2704 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":". Section 2704, which was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–4"},"text":"section 300gg–4 of this title","children":[],"tail":", was renumbered section 2725, and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI"},"text":"Pub. L. 111–148, title I","children":[],"tail":", §§ 1001(2), 1563(c)(3), formerly § 1562(c)(3), title X, § 10107(b)(1), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/130"},"text":"124 Stat. 130","children":[],"tail":", 265, 911, and was transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–25"},"text":"section 300gg–25 of this title","children":[],"tail":". A new section 2704 of act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", related to prohibition of preexisting condition exclusions or other discrimination based on health status, was added, effective for plan years beginning on or after "},{"tag":"date","attrib":{"date":"2014-01-01"},"text":"Jan. 1, 2014","children":[],"tail":", with certain exceptions, and amended, by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI"},"text":"Pub. L. 111–148, title I","children":[],"tail":", §§ 1201(2), 1563(c)(1), formerly § 1562(c)(1), title X, § 10107(b)(1), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/154"},"text":"124 Stat. 154","children":[],"tail":", 264, 911, and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–3"},"text":"section 300gg–3 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6b0bc9d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s102/a/3/D/i"},"text":"Pub. L. 116–260, § 102(a)(3)(D)(i)","children":[],"tail":", substituted “this part, part D, and part C insofar as it relates to this part or part D” for “this part and part C insofar as it relates to this part” and inserted “or part D” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s102/a/3/D/ii"},"text":"Pub. L. 116–260, § 102(a)(3)(D)(ii)","children":[],"tail":", inserted “or part D” after “this part”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s102/a/3/D/iii"},"text":"Pub. L. 116–260, § 102(a)(3)(D)(iii)","children":[],"tail":", inserted “or part D” after “this part (other than section 2704)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s1563/c/14/A"},"text":"Pub. L. 111–148, § 1563(c)(14)(A)","children":[],"tail":", formerly § 1562(c)(14)(A), as renumbered by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10107/b/1"},"text":"Pub. L. 111–148, § 10107(b)(1)","children":[],"tail":", inserted “individual or” before “group health insurance”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/204"},"text":"Pub. L. 104–204","children":[],"tail":" inserted “(other than section 2704)” after “part”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb6b0bc9e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb6b0bc9f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" applicable with respect to plan years beginning on or after "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dBB/s102/e"},"text":"section 102(e) of div. BB of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8902"},"text":"section 8902 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb6b0bca0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/204"},"text":"Pub. L. 104–204","children":[],"tail":" applicable with respect to group health plans for plan years beginning on or after "},{"tag":"date","attrib":{"date":"1998-01-01"},"text":"Jan. 1, 1998","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/204/s604/c"},"text":"section 604(c) of Pub. L. 104–204","children":[],"tail":" set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–25"},"text":"section 300gg–25 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb6b0bca1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to group health plans, and health insurance coverage offered in connection with group health plans, for plan years beginning after ","children":[{"tag":"date","attrib":{"date":"1997-06-30"},"text":"June 30, 1997","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/191/s102/c"},"text":"section 102(c) of Pub. L. 104–191","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg"},"text":"section 300gg of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
