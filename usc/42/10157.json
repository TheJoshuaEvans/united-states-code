{"tag":"section","attrib":{"id":"idbf150624-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10157"},"text":null,"children":[{"tag":"num","attrib":{"value":"10157"},"text":"§ 10157.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf150625-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10157/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf150626-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10157/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn003943"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003943"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No subsec. (b) has been enacted."}],"tail":" Transportation of spent nuclear fuel under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10156/a"},"text":"section 10156(a) of this title","children":[],"tail":" shall be subject to licensing and regulation by the Commission and by the Secretary of Transportation as provided for transportation of commercial spent nuclear fuel under existing law."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf150627-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10157/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary, in providing for the transportation of spent nuclear fuel under this chapter, shall utilize by contract private industry to the fullest extent possible in each aspect of such transportation. The Secretary shall use direct Federal services for such transportation only upon a determination of the Secretary of Transportation, in consultation with the Secretary, that private industry is unable or unwilling to provide such transportation services at reasonable cost.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf150628-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/425/tI/s137"},"text":"Pub. L. 97–425, title I, § 137","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-07"},"text":"Jan. 7, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2241"},"text":"96 Stat. 2241","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
