{"tag":"section","attrib":{"id":"idc00ab0cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298c"},"text":null,"children":[{"tag":"num","attrib":{"value":"16298c"},"text":"§ 16298c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Energy Technology Laboratory reforms","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc00ab0cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special hiring authority for scientific, engineering, and project management personnel","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00ab0ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the National Energy Technology Laboratory (referred to in this section as the “Director”) may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00ab0cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298c/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" make appointments to positions in the National Energy Technology Laboratory to assist in meeting a specific project or research need, without regard to civil service laws, of individuals who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc00ab0d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298c/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have an advanced scientific or engineering background; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00ab0d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298c/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a business background and can assist in specific technology-to-market needs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab0d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298c/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fix the basic pay of any employee appointed under subparagraph (A) at a rate not to exceed level II of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of title 5","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab0d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298c/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" pay any employee appointed under subparagraph (A) payments in addition to the basic pay fixed under subparagraph (B), subject to the condition that the total amount of additional payments paid to an employee under this subparagraph for any 12-month period shall not exceed the least of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc00ab0d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298c/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $25,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00ab0d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298c/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount equal to 25 percent of the annual rate of basic pay of that employee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00ab0d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298c/a/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the limitation that is applicable for a calendar year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5307/a/1"},"text":"section 5307(a)(1) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab0d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00ab0d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298c/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term of any employee appointed under paragraph (1)(A) shall not exceed 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab0d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298c/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full-time employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 10 full-time employees appointed under paragraph (1)(A) may be employed at the National Energy Technology Laboratory at any given time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00ab0da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Laboratory-directed research and development","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00ab0db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning in fiscal year 2021, the National Energy Technology Laboratory shall be eligible for laboratory-directed research and development funding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab0dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of funding","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00ab0dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298c/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each fiscal year, of funds made available to the National Energy Technology Laboratory, the Secretary may deposit an amount, not to exceed the rate made available to the National Laboratories for laboratory-directed research and development, in a special fund account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab0de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298c/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts in the account under subparagraph (A) shall only be available for laboratory-directed research and development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab0df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298c/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The account under subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc00ab0e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298c/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be administered by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00ab0e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298c/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be available without fiscal year limitation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00ab0e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298c/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be subject to appropriation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab0e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall carry out laboratory-directed research and development activities at the National Energy Technology Laboratory consistent with Department of Energy Order 413.2C, dated ","children":[{"tag":"date","attrib":{"date":"2018-08-02"},"text":"August 2, 2018","children":[],"tail":" (or a successor order)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab0e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298c/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report on use of authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Annually, the Secretary shall submit to the Committee on Energy and Natural Resources of the Senate and the Committee on Science, Space, and Technology of the House of Representatives a report on the use of the authority provided under this subsection during the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00ab0e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Laboratory operations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall delegate human resources operations of the National Energy Technology Laboratory to the Director to assist in carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00ab0e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary shall submit to the Committee on Energy and Natural Resources of the Senate and the Committee on Science, Space, and Technology of the House of Representatives a report assessing the management and research activities of the National Energy Technology Laboratory, which shall include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00ab0e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the quality of science and research at the National Energy Technology Laboratory, relative to similar work at other National Laboratories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab0e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of the effectiveness of authorities provided in subsections (a) and (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab0e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298c/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for policy changes within the Department and legislative changes to provide the National Energy Technology Laboratory with the necessary tools and resources to advance the research mission of the National Energy Technology Laboratory.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc00ab0ea-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s969C"},"text":"Pub. L. 109–58, title IX, § 969C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tIV/s4006/a"},"text":"Pub. L. 116–260, div. Z, title IV, § 4006(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2544"},"text":"134 Stat. 2544","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
