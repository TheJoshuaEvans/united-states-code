{"tag":"section","attrib":{"id":"idbf150651-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10162"},"text":null,"children":[{"tag":"num","attrib":{"value":"10162"},"text":"§ 10162.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of monitored retrievable storage","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf150652-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10162/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nullification of Oak Ridge siting proposal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The proposal of the Secretary (EC–1022, 100th Congress) to locate a monitored retrievable storage facility at a site on the Clinch River in the Roane County portion of Oak Ridge, Tennessee, with alternative sites on the Oak Ridge Reservation of the Department of Energy and on the former site of a proposed nuclear powerplant in Hartsville, Tennessee, is annulled and revoked. In carrying out the provisions of sections 10164 and 10165 of this title, the Secretary shall make no presumption or preference to such sites by reason of their previous selection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf150653-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10162/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to site, construct, and operate one monitored retrievable storage facility subject to the conditions described in sections 10163 through 10169 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf150654-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/425/tI/s142"},"text":"Pub. L. 97–425, title I, § 142","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/d/tIII/s300"},"text":"Pub. L. 100–202, § 101(d) [title III, § 300]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-104"},"text":"101 Stat. 1329–104","children":[],"tail":", 1329–121; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tV/s5021"},"text":"Pub. L. 100–203, title V, § 5021","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-232"},"text":"101 Stat. 1330–232","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf150655-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf150656-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf150657-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" added identical sections."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
