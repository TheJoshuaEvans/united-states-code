{"tag":"section","attrib":{"id":"idbdf230c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142c"},"text":null,"children":[{"tag":"num","attrib":{"value":"7142c"},"text":"§ 7142c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Museum volunteers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdf230ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to use volunteers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may recruit, train, and accept the services of individuals or entities as volunteers for services or activities related to the Museum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdf230cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status of volunteers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdf230cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), service by a volunteer under subsection (a) shall not be considered Federal employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdf230cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdf230ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142c/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Tort Claims Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of chapter 171 of title 28, a volunteer under subsection (a) shall be treated as an employee of the Government (as defined in section 2671 of that title).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdf230cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142c/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation for work injuries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subchapter I of chapter 81 of title 5, a volunteer described in subsection (a) shall be treated as an employee (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8101"},"text":"section 8101 of title 5","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdf230d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A volunteer under subsection (a) shall serve without pay, but may receive nominal awards and reimbursement for incidental expenses, including expenses for a uniform or transportation in furtherance of Museum activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdf4a1d1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dB/tIV/s403"},"text":"Pub. L. 106–554, § 1(a)(4) [div. B, title IV, § 403]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–267.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdf4a1d2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdf4a1d3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbdf4a1d4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Miscellaneous Appropriations Act, 2001, and also as part of the Consolidated Appropriations Act, 2001, and not as part of the Department of Energy Organization Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
