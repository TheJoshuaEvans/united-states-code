{"tag":"section","attrib":{"id":"idbb305144-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1505"},"text":null,"children":[{"tag":"num","attrib":{"value":"1505"},"text":"§ 1505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds of Secretary of Housing and Urban Development","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Housing and Urban Development may use for the purposes of this subchapter any of the funds or authorizations heretofore or hereafter made available to it.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbb305145-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-06-28/ch440"},"text":"June 28, 1940, ch. 440","children":[],"tail":", title II, § 205, "},{"tag":"ref","attrib":{"href":"/us/stat/54/683"},"text":"54 Stat. 683","children":[],"tail":"; 1947 Reorg. Plan No. 3, § 4(a), eff. "},{"tag":"date","attrib":{"date":"1947-07-27"},"text":"July 27, 1947","children":[],"tail":", 12 F.R. 4981, "},{"tag":"ref","attrib":{"href":"/us/stat/61/955"},"text":"61 Stat. 955","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/174/s5/a"},"text":"Pub. L. 89–174, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-09-09"},"text":"Sept. 9, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/669"},"text":"79 Stat. 669","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb305146-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb305147-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbb305148-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions to Secretary of Housing and Urban Development, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1501"},"text":"section 1501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbb305149-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Provisions Inapplicable to This Subchapter","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1940-06-28/ch440/tII/s205"},"text":"Act June 28, 1940, ch. 440, title II, § 205","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/683"},"text":"54 Stat. 683","children":[],"tail":", provided in part: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1940-06-28/ch440/tII/s205"},"text":"“The provisions of title I of this Act shall not apply to this title [this subchapter].”","children":[],"tail":"\n The provisions of title I of act "},{"tag":"date","attrib":{"date":"1940-06-28"},"text":"June 28, 1940","children":[],"tail":", enacted section 1262a of former Title 10, Armed Forces, section 546e of former Title 34, Navy, and former sections 1151 to 1162 of the former Appendix to Title 50, War and National Defense, and amended section 40 of former Title 41, Public Contracts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
