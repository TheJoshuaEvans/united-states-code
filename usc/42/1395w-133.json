{"tag":"section","attrib":{"id":"idb95aa7d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–133"},"text":null,"children":[{"tag":"num","attrib":{"value":"1395w–133"},"text":"§ 1395w–133.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State Pharmaceutical Assistance Programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb95cf0ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–133/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for benefit coordination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95cf0cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–133/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before ","children":[{"tag":"date","attrib":{"date":"2005-07-01"},"text":"July 1, 2005","children":[],"tail":", the Secretary shall establish consistent with this section requirements for prescription drug plans to ensure the effective coordination between a part D plan (as defined in paragraph (5)) and a State Pharmaceutical Assistance Program (as defined in subsection (b)) with respect to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb95cf0cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–133/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment of premiums and coverage; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95cf0cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–133/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment for supplemental prescription drug benefits,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"for part D eligible individuals enrolled under both types of plans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95cf0ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–133/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirements under paragraph (1) shall include requirements relating to coordination of each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb95cf0cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–133/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Enrollment file sharing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95cf0d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–133/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The processing of claims, including electronic processing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95cf0d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–133/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Claims payment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95cf0d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–133/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Claims reconciliation reports.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95cf0d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–133/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Application of the protection against high out-of-pocket expenditures under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–102/b/4"},"text":"section 1395w–102(b)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95cf0d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–133/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other administrative processes specified by the Secretary.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such requirements shall be consistent with applicable law to safeguard the privacy of any individually identifiable beneficiary information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95cf0d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–133/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of lump sum per capita method","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such requirements shall include a method for the application by a part D plan of specified funding amounts from a State Pharmaceutical Assistance Program for enrolled individuals for supplemental prescription drug benefits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95cf0d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–133/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In establishing requirements under this subsection, the Secretary shall consult with State Pharmaceutical Assistance Programs, MA organizations, States, pharmaceutical benefit managers, employers, representatives of part D eligible individuals, the data processing experts, pharmacists, pharmaceutical manufacturers, and other experts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95cf0d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–133/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Part D plan defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–134"},"text":"section 1395w–134 of this title","children":[],"tail":", the term “part D plan” means a prescription drug plan and an MA–PD plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95cf0d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–133/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State Pharmaceutical Assistance Program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part, the term “State Pharmaceutical Assistance Program” means a State program—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95cf0d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–133/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which provides financial assistance for the purchase or provision of supplemental prescription drug coverage or benefits on behalf of part D eligible individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95cf0da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–133/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which, in determining eligibility and the amount of assistance to part D eligible individuals under the Program, provides assistance to such individuals in all part D plans and does not discriminate based upon the part D plan in which the individual is enrolled; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95cf0db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–133/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which satisfies the requirements of subsections (a) and (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95cf0dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–133/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to other provisions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95cf0dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–133/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medicare as primary payor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of this section shall not change or affect the primary payor status of a part D plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95cf0de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–133/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of a single card","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A card that is issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–104/b/2/A"},"text":"section 1395w–104(b)(2)(A) of this title","children":[],"tail":" for use under a part D plan may also be used in connection with coverage of benefits provided under a State Pharmaceutical Assistance Program and, in such case, may contain an emblem or symbol indicating such connection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95cf0df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–133/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–134/c"},"text":"section 1395w–134(c) of this title","children":[],"tail":" shall apply to the requirements under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95cf0e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–133/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special treatment under out-of-pocket rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In applying ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–102/b/4/C/ii"},"text":"section 1395w–102(b)(4)(C)(ii) of this title","children":[],"tail":", expenses incurred under a State Pharmaceutical Assistance Program may be counted toward the annual out-of-pocket threshold."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95cf0e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–133/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed as requiring a State Pharmaceutical Assistance Program to coordinate or provide financial assistance with respect to any part D plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95cf0e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–133/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilitation of transition and coordination with State Pharmaceutical Assistance Programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95cf0e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–133/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transitional grant program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide payments to State Pharmaceutical Assistance Programs with an application approved under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95cf0e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–133/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Payments under this section may be used by a Program for any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb95cf0e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–133/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Educating part D eligible individuals enrolled in the Program about the prescription drug coverage available through part D plans under this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95cf0e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–133/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing technical assistance, phone support, and counseling for such enrollees to facilitate selection and enrollment in such plans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95cf0e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–133/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other activities designed to promote the effective coordination of enrollment, coverage, and payment between such Program and such plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95cf0e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–133/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amount appropriated to carry out this subsection for a fiscal year, the Secretary shall allocate payments among Programs that have applications approved under paragraph (4) for such fiscal year in proportion to the number of enrollees enrolled in each such Program as of ","children":[{"tag":"date","attrib":{"date":"2003-10-01"},"text":"October 1, 2003","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95cf0e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–133/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No payments may be made under this subsection except pursuant to an application that is submitted and approved in a time, manner, and form specified by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95cf0ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–133/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Out of any funds in the Treasury not otherwise appropriated, there are appropriated for each of fiscal years 2005 and 2006, $62,500,000 to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb95cf0eb-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XVIII, § 1860D–23, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/173/tI/s101/a/2"},"text":"Pub. L. 108–173, title I, § 101(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-08"},"text":"Dec. 8, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2128"},"text":"117 Stat. 2128","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
