{"tag":"section","attrib":{"id":"idc035913c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17333"},"text":null,"children":[{"tag":"num","attrib":{"value":"17333"},"text":"§ 17333.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States trade missions to encourage private sector trade and investment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc035913d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17333/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Commerce shall direct the International Trade Administration to expand or create trade missions to and from the United States to encourage private sector trade and investment in clean and efficient energy technologies—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc035913e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17333/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by organizing and facilitating trade missions to foreign countries and by matching United States private sector companies with opportunities in foreign markets so that clean and efficient energy technologies can help to combat increases in global greenhouse gas emissions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc035913f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17333/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by creating reverse trade missions in which the Department of Commerce facilitates the meeting of foreign private and public sector organizations with private sector companies in the United States for the purpose of showcasing clean and efficient energy technologies in use or in development that could be exported to other countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0359140-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17333/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce shall submit to the appropriate congressional committees an annual report on the implementation of this section for each of the fiscal years 2008 through 2012.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0359141-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17333/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out this section, there are authorized to be appropriated to the Secretary of Commerce such sums as may be necessary for each of the fiscal years 2008 through 2012.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0359142-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIX/s913"},"text":"Pub. L. 110–140, title IX, § 913","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1726"},"text":"121 Stat. 1726","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0359143-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc0359144-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc0359145-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
