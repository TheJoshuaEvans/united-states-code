{"tag":"section","attrib":{"id":"idb5b8c824-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–27"},"text":null,"children":[{"tag":"num","attrib":{"value":"290cc–27"},"text":"§ 290cc–27.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Description of intended expenditures of grant","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5b8c825-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–27/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–21"},"text":"section 290cc–21 of this title","children":[],"tail":" unless—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5b8c826-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–27/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as part of the application required in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–29"},"text":"section 290cc–29 of this title","children":[],"tail":", the State involved submits to the Secretary a description of the intended use for the fiscal year of the amounts for which the State is applying pursuant to such section;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b8c827-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–27/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such description identifies the geographic areas within the State in which the greatest numbers of homeless individuals with a need for mental health, substance use disorder, and housing services are located;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b8c828-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–27/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such description provides information relating to the programs and activities to be supported and services to be provided, including information relating to coordinating such programs and activities with any similar programs and activities of public and private entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b8c829-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–27/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State agrees that such description will be revised throughout the year as may be necessary to reflect substantial changes in the programs and activities assisted by the State pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–22"},"text":"section 290cc–22 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b8c82a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–27/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opportunity for public comment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–21"},"text":"section 290cc–21 of this title","children":[],"tail":" unless the State involved agrees that, in developing and carrying out the description required in subsection (a), the State will provide public notice with respect to the description (including any revisions) and such opportunities as may be necessary to provide interested persons, such as family members, consumers, and mental health, substance use disorder, and housing agencies, an opportunity to present comments and recommendations with respect to the description."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b8c82b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–27/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to State comprehensive mental health services plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5b8c82c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–27/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–21"},"text":"section 290cc–21 of this title","children":[],"tail":" unless the services to be provided pursuant to the description required in subsection (a) are consistent with the State comprehensive mental health services plan required in subpart 2 "},{"tag":"ref","attrib":{"idref":"fn002237"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002237"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of part B of subchapter XVII."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b8c82d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–27/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–21"},"text":"section 290cc–21 of this title","children":[],"tail":" unless the services to be provided pursuant to the description required in subsection (a) have been considered in the preparation of, have been included in, and are consistent with, the State comprehensive mental health services plan referred to in paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5b8c82e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 527, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/77/tVI/s611/3"},"text":"Pub. L. 100–77, title VI, § 611(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-07-22"},"text":"July 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/520"},"text":"101 Stat. 520","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/645/tV/s511"},"text":"Pub. L. 101–645, title V, § 511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4730"},"text":"104 Stat. 4730","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tIX/s9004/c"},"text":"Pub. L. 114–255, div. B, title IX, § 9004(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1238"},"text":"130 Stat. 1238","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5b8c82f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5b8c830-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb5b8c831-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subpart 2 of part B of subchapter XVII, referred to in subsec. (c)(1), which related to State comprehensive mental health services plans and which was classified to section 300x–10 et seq. of this title, was repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/321/tII/s201/2"},"text":"Pub. L. 102–321, title II, § 201(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/378"},"text":"106 Stat. 378","children":[],"tail":", and a new subpart 2 of part B of subchapter XVII of this chapter, relating to block grants for prevention and treatment of substance abuse, was added by "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/s202"},"text":"section 202 of Pub. L. 102–321","children":[],"tail":" and classified to section 300x–21 et seq. of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5b8c832-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 527 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was renumbered section 548 by "},{"tag":"ref","attrib":{"href":"/us/pl/100/77/s611/2"},"text":"section 611(2) of Pub. L. 100–77","children":[],"tail":" and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290ee–3"},"text":"section 290ee–3 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5b8c833-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsecs. (a)(2), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255"},"text":"Pub. L. 114–255","children":[],"tail":" substituted “substance use disorder” for “substance abuse”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/645"},"text":"Pub. L. 101–645","children":[],"tail":" amended section generally, substituting provisions relating to description of intended expenditures of grant for provisions relating to requirement of reports by States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
