{"tag":"section","attrib":{"id":"idb67c66a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–31"},"text":null,"children":[{"tag":"num","attrib":{"value":"300aa–31"},"text":"§ 300aa–31.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Citizen’s actions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb67c66a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–31/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b), any person may commence in a district court of the United States a civil action on such person’s own behalf against the Secretary where there is alleged a failure of the Secretary to perform any act or duty under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb67c66a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–31/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No action may be commenced under subsection (a) before the date which is 60 days after the person bringing the action has given written notice of intent to commence such action to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb67c66a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–31/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs of litigation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The court, in issuing any final order in any action under this section, may award costs of litigation (including reasonable attorney and expert witness fees) to any plaintiff who substantially prevails on one or more significant issues in the action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb67c66a5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXI, § 2131, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/660/tIII/s311/a"},"text":"Pub. L. 99–660, title III, § 311(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3778"},"text":"100 Stat. 3778","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tIV/s4305"},"text":"Pub. L. 100–203, title IV, § 4305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-224"},"text":"101 Stat. 1330–224","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb67c66a6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb67c66a7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb67c66a8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1987—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":", which directed that subsec. (c) be amended by substituting “to any plaintiff who substantially prevails on one or more significant issues in the action” for “to any party, whenever the court determines that such award is appropriate”, was executed by making the substitution for “to any party, whenever the court determines such award is appropriate”, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb67c66a9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb67c66aa-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subpart effective ","children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/660/s323"},"text":"section 323 of Pub. L. 99–660","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300aa–1"},"text":"section 300aa–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
