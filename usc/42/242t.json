{"tag":"section","attrib":{"id":"idb495cbff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242t"},"text":null,"children":[{"tag":"num","attrib":{"value":"242t"},"text":"§ 242t.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" CDC surveillance and data collection for child, youth, and adult trauma","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb495cc00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242t/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data collection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Centers for Disease Control and Prevention (referred to in this section as the “Director”) may, in cooperation with the States, collect and report data on adverse childhood experiences through the Behavioral Risk Factor Surveillance System, the Youth Risk Behavior Surveillance System, and other relevant public health surveys or questionnaires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb495cc01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242t/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The collection of data under subsection (a) may occur biennially.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb495cc02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242t/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data from rural areas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall encourage each State that participates in collecting and reporting data under subsection (a) to collect and report data from rural areas within such State, in order to generate a statistically reliable representation of such areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4983d03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242t/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data from tribal areas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may, in cooperation with Indian Tribes (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":") and pursuant to a written request from an Indian Tribe, provide technical assistance to such Indian Tribe to collect and report data on adverse childhood experiences through the Behavioral Risk Factor Surveillance System, the Youth Risk Behavior Surveillance System, or another relevant public health survey or questionnaire."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4983d04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242t/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out this section, there is authorized to be appropriated $9,000,000 for each of fiscal years 2026 through 2030.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4983d05-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/tVII/s7131"},"text":"Pub. L. 115–271, title VII, § 7131","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4046"},"text":"132 Stat. 4046","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/44/tI/s109"},"text":"Pub. L. 119–44, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-01"},"text":"Dec. 1, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/677"},"text":"139 Stat. 677","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4983d06-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4983d07-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb4983d08-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Substance Use–Disorder Prevention that Promotes Opioid Recovery and Treatment for Patients and Communities Act, also known as the SUPPORT for Patients and Communities Act, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb4983d09-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/44"},"text":"Pub. L. 119–44","children":[],"tail":" substituted “$9,000,000 for each of fiscal years 2026 through 2030” for “$2,000,000 for each of fiscal years 2019 through 2023”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
