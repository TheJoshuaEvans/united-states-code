{"tag":"section","attrib":{"id":"idbe8d388f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8285a"},"text":null,"children":[{"tag":"num","attrib":{"value":"8285a"},"text":"§ 8285a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe8d3890-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8285a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Governor” means the chief executive officer of each State, including the Mayor of the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8d3891-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8285a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State” means any of the several States, the District of Columbia, the Commonwealth of Puerto Rico, the Virgin Islands, Guam, American Samoa, and the Northern Mariana Islands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8d3892-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8285a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “energy audit” means an inspection as described in section 8216(b)(1)(A) ","children":[{"tag":"ref","attrib":{"idref":"fn003828"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003828"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, or an energy audit as defined in section 8281(b)(7) "},{"tag":"ref","attrib":{"idref":"fn003828"},"text":"1","children":[],"tail":" of this title, which in addition may provide information on the utilization of renewable resources and may make energy-related improvements in the building; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8d3893-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8285a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Secretary” means the Secretary of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe8d3894-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/294/tV/s582"},"text":"Pub. L. 96–294, title V, § 582","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/761"},"text":"94 Stat. 761","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe8d3895-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe8d3896-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbe8d3897-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8216"},"text":"Section 8216 of this title","children":[],"tail":", referred to in par. (3), was omitted from the Code pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8229"},"text":"section 8229 of this title","children":[],"tail":", which terminated authority under that section "},{"tag":"date","attrib":{"date":"1989-06-30"},"text":"June 30, 1989","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8281"},"text":"Section 8281 of this title","children":[],"tail":", referred to in par. (3), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/99/412/tII/s201/a"},"text":"Pub. L. 99–412, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-28"},"text":"Aug. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/943"},"text":"100 Stat. 943","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbe8d3898-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy Security Act, and not as part of the National Energy Conservation Policy Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
