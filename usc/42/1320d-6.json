{"tag":"section","attrib":{"id":"idb8604200-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"1320d–6"},"text":"§ 1320d–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wrongful disclosure of individually identifiable health information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8604201-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offense","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person who knowingly and in violation of this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8604202-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–6/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses or causes to be used a unique health identifier;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8604203-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–6/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtains individually identifiable health information relating to an individual; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8604204-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–6/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discloses individually identifiable health information to another person,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be punished as provided in subsection (b). For purposes of the previous sentence, a person (including an employee or other individual) shall be considered to have obtained or disclosed individually identifiable health information in violation of this part if the information is maintained by a covered entity (as defined in the HIPAA privacy regulation described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320d–9/b/3"},"text":"section 1320d–9(b)(3) of this title","children":[],"tail":") and the individual obtained or disclosed such information without authorization."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8604205-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person described in subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8604206-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–6/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be fined not more than $50,000, imprisoned not more than 1 year, or both;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8604207-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–6/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the offense is committed under false pretenses, be fined not more than $100,000, imprisoned not more than 5 years, or both; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8604208-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–6/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the offense is committed with intent to sell, transfer, or use individually identifiable health information for commercial advantage, personal gain, or malicious harm, be fined not more than $250,000, imprisoned not more than 10 years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8604209-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XI, § 1177, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/191/tII/s262/a"},"text":"Pub. L. 104–191, title II, § 262(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2029"},"text":"110 Stat. 2029","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/dA/tXIII/s13409"},"text":"Pub. L. 111–5, div. A, title XIII, § 13409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/271"},"text":"123 Stat. 271","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb860420a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb860420b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb860420c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":" inserted at end “For purposes of the previous sentence, a person (including an employee or other individual) shall be considered to have obtained or disclosed individually identifiable health information in violation of this part if the information is maintained by a covered entity (as defined in the HIPAA privacy regulation described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320d–9/b/3"},"text":"section 1320d–9(b)(3) of this title","children":[],"tail":") and the individual obtained or disclosed such information without authorization.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb860420d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb860420e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":" effective 12 months after "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/s13423"},"text":"section 13423 of Pub. L. 111–5","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s17931"},"text":"section 17931 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
