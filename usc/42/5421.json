{"tag":"section","attrib":{"id":"idbd54b856-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5421"},"text":null,"children":[{"tag":"num","attrib":{"value":"5421"},"text":"§ 5421.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on waiver of rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The rights afforded manufactured home purchasers under this chapter may not be waived, and any provision of a contract or agreement entered into after ","children":[{"tag":"date","attrib":{"date":"1974-08-22"},"text":"August 22, 1974","children":[],"tail":", to the contrary shall be void."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd54b857-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/383/tVI/s622"},"text":"Pub. L. 93–383, title VI, § 622","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/712"},"text":"88 Stat. 712","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/399/tIII/s308/c/4"},"text":"Pub. L. 96–399, title III, § 308(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-08"},"text":"Oct. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1641"},"text":"94 Stat. 1641","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd54b858-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd54b859-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd54b85a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"child