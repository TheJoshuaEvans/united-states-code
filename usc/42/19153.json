{"tag":"section","attrib":{"id":"idc081dc4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19153"},"text":null,"children":[{"tag":"num","attrib":{"value":"19153"},"text":"§ 19153.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policies for review of Federal research awards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc081dc4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19153/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment of policies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Federal research agencies shall regularly assess, and update as necessary, policies, and practices to remove or reduce cultural and institutional barriers limiting the recruitment, retention, and success of groups historically underrepresented in STEM research careers, including policies and practices relevant to the unbiased review of Federal research applications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc081dc4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19153/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations and activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the requirements under subsection (a), Federal research agencies shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc081dc4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19153/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review current levels of participation of groups historically underrepresented in STEM in peer-review panels and consider approaches for expanding their participation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc081dc50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19153/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyze the data collected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s19152"},"text":"section 19152 of this title","children":[],"tail":", including funding rates of proposals from all groups, including those historically underrepresented in STEM;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc081dc51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19153/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect and disseminate best practices to remove or reduce cultural and institutional barriers limiting the recruitment, retention, and success of groups historically underrepresented in STEM research careers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc081dc52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19153/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement evidence-based policies and practices to achieve the goals of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc081dc53-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tV/s10503"},"text":"Pub. L. 117–167, div. B, title V, § 10503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1610"},"text":"136 Stat. 1610","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
