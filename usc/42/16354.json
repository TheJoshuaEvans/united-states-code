{"tag":"section","attrib":{"id":"idc00f6b1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16354"},"text":null,"children":[{"tag":"num","attrib":{"value":"16354"},"text":"§ 16354.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" External technical review of departmental programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc00f6b1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16354/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National energy research and development advisory boards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00f6b1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16354/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish one or more advisory boards to review research, development, demonstration, and commercial application programs of the Department in energy efficiency, renewable energy, nuclear energy, and fossil energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6b1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16354/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternatives","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00f6b20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16354/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate an existing advisory board within the Department to fulfill the responsibilities of an advisory board under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6b21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16354/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into appropriate arrangements with the National Academy of Sciences to establish such an advisory board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00f6b22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16354/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of existing committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall continue to use the scientific program advisory committees chartered under chapter 10 of title 5 by the Office of Science to oversee research and development programs under that Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00f6b23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16354/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each advisory board under this section shall consist of persons with appropriate expertise representing a diverse range of interests.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00f6b24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16354/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings and goals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00f6b25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16354/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each advisory board under this section shall meet at least semiannually to review and advise on the progress made by the respective one or more research, development, demonstration, and commercial application programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6b26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16354/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The advisory board shall review the measurable cost and performance-based goals for the programs as established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16181"},"text":"section 16181 of this title","children":[],"tail":", and the progress on meeting the goals."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00f6b27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16354/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic reviews and assessments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00f6b28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16354/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall enter into appropriate arrangements with the National Academy of Sciences to conduct periodic reviews and assessments of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00f6b29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16354/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the research, development, demonstration, and commercial application programs authorized by this Act and amendments made by this Act;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6b2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16354/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the measurable cost and performance-based goals for the programs as established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16181"},"text":"section 16181 of this title","children":[],"tail":", if any; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6b2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16354/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the progress on meeting the goals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6b2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16354/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The reviews and assessments shall be conducted every 5 years or more often as the Secretary considers necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6b2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16354/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall submit to Congress reports describing the results of all the reviews and assessments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc00f6b2e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s990"},"text":"Pub. L. 109–58, title IX, § 990","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/912"},"text":"119 Stat. 912","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/278"},"text":"Pub. L. 117–286, § 4(a)(278)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4336"},"text":"136 Stat. 4336","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc00f6b2f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc00f6b30-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc00f6b31-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (e)(1)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/594"},"text":"119 Stat. 594","children":[],"tail":", known as the Energy Policy Act of 2005, which enacted this chapter and enacted, amended, and repealed numerous other sections and notes in the Code. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s15801"},"text":"section 15801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc00f6b32-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 10 of title 5” for “the Federal Advisory Committee Act (5 U.S.C. App.)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
