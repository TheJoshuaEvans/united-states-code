{"tag":"section","attrib":{"id":"idc05e27f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18646"},"text":null,"children":[{"tag":"num","attrib":{"value":"18646"},"text":"§ 18646.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nuclear physics","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc05e27fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18646/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As part of the activities authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7139"},"text":"section 7139 of this title","children":[],"tail":", the Director shall carry out a research program, and support relevant facilities, to discover and understand various forms of nuclear matter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc05e27fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18646/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electron Ion Collider","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc05e27fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18646/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall support construction of an Electron Ion Collider as described in the 2015 Long Range Plan of the Nuclear Science Advisory Committee and the report from the National Academies of Science, Engineering, and Medicine entitled “An Assessment of U.S.-Based Electron-Ion Collider Science”, in order to measure the internal structure of the proton and the nucleus and answer fundamental questions about the nature of visible matter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05e27fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18646/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facility capability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that the facility described in paragraph (1) meets the requirements in the 2015 Long Range Plan described in that paragraph, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc05e27fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18646/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 70 percent polarized beams of electrons and light ions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc05e27ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18646/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ion beams from deuterium to the heaviest stable nuclei;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc05e2800-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18646/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" variable center of mass energy from 20 to 140 GeV;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc05e2801-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18646/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" high collision luminosity of 10","children":[{"tag":"sup","attrib":{},"text":"33–34","children":[],"tail":"cm"},{"tag":"sup","attrib":{},"text":"-2","children":[],"tail":"s"},{"tag":"sup","attrib":{},"text":"-1","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc05e2802-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18646/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the possibility of more than 1 interaction region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05e2803-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18646/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Start of operations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, subject to the availability of appropriations, ensure that the start of full operations of the facility under this subsection occurs before ","children":[{"tag":"date","attrib":{"date":"2030-12-31"},"text":"December 31, 2030","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05e2804-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18646/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Out of funds authorized to be appropriated under subsection (c), there are authorized to be appropriated to the Secretary to carry out construction of the facility under this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc05e2805-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18646/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $90,000,000 for fiscal year 2023;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc05e2806-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18646/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $181,000,000 for fiscal year 2024;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc05e2807-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18646/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $219,000,000 for fiscal year 2025;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc05e2808-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18646/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $297,000,000 for fiscal year 2026; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc05e2809-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18646/b/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $301,000,000 for fiscal year 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc05e280a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18646/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Out of funds authorized to be appropriated for the Office of Science in a fiscal year, there are authorized to be appropriated to the Secretary to carry out the activities described in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc05e280b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18646/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $840,480,000 for fiscal year 2023;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05e280c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18646/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $976,508,800 for fiscal year 2024;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05e280d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18646/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,062,239,328 for fiscal year 2025;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05e280e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18646/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,190,833,688 for fiscal year 2026; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05e280f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18646/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,248,463,709 for fiscal year 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc05e2810-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/246/tIII/s308"},"text":"Pub. L. 115–246, title III, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-28"},"text":"Sept. 28, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3150"},"text":"132 Stat. 3150","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tI/s10107"},"text":"Pub. L. 117–167, div. B, title I, § 10107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1449"},"text":"136 Stat. 1449","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc05e2811-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc05e2812-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc05e2813-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167"},"text":"Pub. L. 117–167","children":[],"tail":" amended section generally. Prior to amendment, text was comprised of subsec. (a) of "},{"tag":"ref","attrib":{"href":"/us/pl/115/246/s308"},"text":"section 308 of Pub. L. 115–246","children":[],"tail":" which read as follows: “The Director—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) may carry out a program for the production of isotopes, including the development of techniques to produce isotopes, that the Secretary determines are needed for research, medical, industrial, or related purposes; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) shall ensure that isotope production activities carried out under the program under this paragraph do not compete with private industry unless the Director determines that critical national interests require the involvement of the Federal Government.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior to amendment, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/246/s308"},"text":"section 308 of Pub. L. 115–246","children":[],"tail":" also contained subsec. (b) which amended "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s16321"},"text":"section 16321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
