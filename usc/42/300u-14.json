{"tag":"section","attrib":{"id":"idb65fb736-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14"},"text":null,"children":[{"tag":"num","attrib":{"value":"300u–14"},"text":"§ 300u–14.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Healthy aging, living well; evaluation of community-based prevention and wellness programs for Medicare beneficiaries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb65fb737-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Healthy aging, living well","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb65fb738-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services (referred to in this section as the “Secretary”), acting through the Director of the Centers for Disease Control and Prevention, shall award grants to State or local health departments and Indian tribes to carry out 5-year pilot programs to provide public health community interventions, screenings, and where necessary, clinical referrals for individuals who are between 55 and 64 years of age.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65fb739-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under paragraph (1), an entity shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb65fb73a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb65fb73b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State health department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb65fb73c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a local health department; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb65fb73d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribe;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb65fb73e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require including a description of the program to be carried out under the grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb65fb73f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" design a strategy for improving the health of the 55-to-64 year-old population through community-based public health interventions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb65fb740-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate the capacity, if funded, to develop the relationships necessary with relevant health agencies, health care providers, community-based organizations, and insurers to carry out the activities described in paragraph (3), such relationships to include the identification of a community-based clinical partner, such as a community health center or rural health clinic.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65fb741-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb65fb742-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State or local health department shall use amounts received under a grant under this subsection to carry out a program to provide the services described in this paragraph to individuals who are between 55 and 64 years of age.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb65fb743-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public health interventions","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb65fb744-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing and implementing such activities, a grantee shall collaborate with the Centers for Disease Control and Prevention and the Administration on Aging, and relevant local agencies and organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb65fb745-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Types of intervention activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Intervention activities conducted under this subparagraph may include efforts to improve nutrition, increase physical activity, reduce tobacco use and substance abuse, improve mental health, and promote healthy lifestyles among the target population.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb65fb746-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community preventive screenings","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb65fb747-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/a/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to community-wide public health interventions, a State or local health department shall use amounts received under a grant under this subsection to conduct ongoing health screening to identify risk factors for cardiovascular disease, cancer, stroke, and diabetes among individuals in both urban and rural areas who are between 55 and 64 years of age.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb65fb748-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/a/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Types of screening activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Screening activities conducted under this subparagraph may include—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb65fb749-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/a/3/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mental health/behavioral health and substance use disorders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb65fb74a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/a/3/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physical activity, smoking, and nutrition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb65fb74b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/a/3/C/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other measures deemed appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb65fb74c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/a/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grantees under this section shall maintain records of screening results under this subparagraph to establish the baseline data for monitoring the targeted population ","children":[{"tag":"ref","attrib":{"idref":"fn002379"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002379"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a period."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb65fb74d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clinical referral/treatment for chronic diseases","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb65fb74e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/a/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State or local health department shall use amounts received under a grant under this subsection to ensure that individuals between 55 and 64 years of age who are found to have chronic disease risk factors through the screening activities described in subparagraph (C)(ii), receive clinical referral/treatment for follow-up services to reduce such risk.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb65fb74f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/a/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mechanism","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb65fb750-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/a/3/D/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification and determination of status","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to each individual with risk factors for or having heart disease, stroke, diabetes, or any other condition for which such individual was screened under subparagraph (C), a grantee under this section shall determine whether or not such individual is covered under any public or private health insurance program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb65fb751-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/a/3/D/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insured individuals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual determined to be covered under a health insurance program under subclause (I) shall be referred by the grantee to the existing providers under such program or, if such individual does not have a current provider, to a provider who is in-network with respect to the program involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb65fb752-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/a/3/D/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uninsured individuals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to an individual determined to be uninsured under subclause (I), the grantee’s community-based clinical partner described in paragraph (4)(D) ","children":[{"tag":"ref","attrib":{"idref":"fn002380"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002380"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Paragraph (4) does not contain subpars."}],"tail":" shall assist the individual in determining eligibility for available public coverage options and identify other appropriate community health care resources and assistance programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb65fb753-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/a/3/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public health intervention program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State or local health department shall use amounts received under a grant under this subsection to enter into contracts with community health centers or rural health clinics and mental health and substance use disorder service providers to assist in the referral/treatment of at risk patients to community resources for clinical follow-up and help determine eligibility for other public programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb65fb754-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grantee evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity shall use amounts provided under a grant under this subsection to conduct activities to measure changes in the prevalence of chronic disease risk factors among participants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65fb755-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot program evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct an annual evaluation of the effectiveness of the pilot program under this subsection. In determining such effectiveness, the Secretary shall consider changes in the prevalence of uncontrolled chronic disease risk factors among new Medicare enrollees (or individuals nearing enrollment, including those who are 63 and 64 years of age) who reside in States or localities receiving grants under this section as compared with national and historical data for those States and localities for the same population.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65fb756-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this subsection, such sums as may be necessary for each of fiscal years 2010 through 2014.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb65fb757-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation and plan for community-based prevention and wellness programs for Medicare beneficiaries","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb65fb758-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct an evaluation of community-based prevention and wellness programs and develop a plan for promoting healthy lifestyles and chronic disease self-management for Medicare beneficiaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65fb759-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medicare evaluation of prevention and wellness programs","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb65fb75a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall evaluate community prevention and wellness programs including those that are sponsored by the Administration on Aging, are evidence-based, and have demonstrated potential to help Medicare beneficiaries (particularly beneficiaries that have attained 65 years of age) reduce their risk of disease, disability, and injury by making healthy lifestyle choices, including exercise, diet, and self-management of chronic diseases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb65fb75b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The evaluation under subparagraph (A) shall consist of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb65fb75c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evidence review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall review available evidence, literature, best practices, and resources that are relevant to programs that promote healthy lifestyles and reduce risk factors for the Medicare population. The Secretary may determine the scope of the evidence review and such issues to be considered, which shall include, at a minimum—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb65fb75d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/b/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physical activity, nutrition, and obesity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb65fb75e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/b/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" falls;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb65fb75f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/b/2/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chronic disease self-management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb65fb760-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/b/2/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mental health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb65fb761-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent evaluation of evidence-based community prevention and wellness programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator of the Centers for Medicare & Medicaid Services, in consultation with the Assistant Secretary for Aging, shall, to the extent feasible and practicable, conduct an evaluation of existing community prevention and wellness programs that are sponsored by the Administration on Aging to assess the extent to which Medicare beneficiaries who participate in such programs—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb65fb762-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/b/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce their health risks, improve their health outcomes, and adopt and maintain healthy behaviors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb65fb763-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/b/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve their ability to manage their chronic conditions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb65fb764-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/b/2/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce their utilization of health services and associated costs under the Medicare program for conditions that are amenable to improvement under such programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65fb765-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2013-09-30"},"text":"September 30, 2013","children":[],"tail":", the Secretary shall submit to Congress a report that includes—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb65fb766-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for such legislation and administrative action as the Secretary determines appropriate to promote healthy lifestyles and chronic disease self-management for Medicare beneficiaries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb65fb767-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any relevant findings relating to the evidence review under paragraph (2)(B)(i); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb65fb768-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of the evaluation under paragraph (2)(B)(ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65fb769-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of carrying out this subsection, the Secretary shall provide for the transfer, from the Federal Hospital Insurance Trust Fund under section 1817 of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395i"},"text":"42 U.S.C. 1395i","children":[],"tail":") and the Federal Supplemental "},{"tag":"ref","attrib":{"idref":"fn002381"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002381"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. Probably should be “Supplementary”."}],"tail":" Medical Insurance Trust Fund under section 1841 of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395t"},"text":"42 U.S.C. 1395t","children":[],"tail":"), in such proportion as the Secretary determines appropriate, of $50,000,000 to the Centers for Medicare & Medicaid Services Program Management Account. Amounts transferred under the preceding sentence shall remain available until expended."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65fb76a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Chapter 35 of title 44 shall not apply to the ","children":[{"tag":"ref","attrib":{"idref":"fn002382"},"text":"4","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002382"},"text":null,"children":[{"tag":"num","attrib":{},"text":"4","children":[],"tail":" So in original. The word “the” probably should not appear."}],"tail":" this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65fb76b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–14/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medicare beneficiary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “Medicare beneficiary” means an individual who is entitled to benefits under part A of title XVIII of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395c"},"text":"42 U.S.C. 1395c","children":[],"tail":" et seq.] and enrolled under part B of such title ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395j"},"text":"42 U.S.C. 1395j","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb65fb76c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIV/s4202"},"text":"Pub. L. 111–148, title IV, § 4202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/566"},"text":"124 Stat. 566","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb65fb76d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb65fb76e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb65fb76f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (b)(6), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Parts A and B of title XVIII of the Act are classified generally to parts A (§ 1395c et seq.) and B (§ 1395j et seq.), respectively, of subchapter XVIII of chapter 7 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb65fb770-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Patient Protection and Affordable Care Act, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
