{"tag":"section","attrib":{"id":"idc0276135-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114"},"text":null,"children":[{"tag":"num","attrib":{"value":"17114"},"text":"§ 17114.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Industrial Technology Innovation Advisory Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0276136-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0276137-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Committee” means the Industrial Technology Innovation Advisory Committee established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0276138-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Director” means the Director of the Office of Science and Technology Policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0276139-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emissions reduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “emissions reduction” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17113/a"},"text":"section 17113(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc027613a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “program” means the industrial emissions reduction technology development program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17113/b/1"},"text":"section 17113(b)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc027613b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary, in consultation with the Director, shall establish an advisory committee, to be known as the “Industrial Technology Innovation Advisory Committee”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc027613c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc027613d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall be comprised of not fewer than 16 members and not more than 20 members, who shall be appointed by the Secretary, in consultation with the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc027613e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Representation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Members appointed pursuant to paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc027613f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 1 representative of each relevant Federal agency, as determined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276140-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chair of the Secretary of Energy Advisory Board, if that position is filled;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276141-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 2 representatives of labor groups;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276142-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 3 representatives of the research community, which shall include academia and National Laboratories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276143-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 2 representatives of nongovernmental organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276144-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn004251"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004251"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. There are two subpars. (F)."}],"tail":" not less than 6 representatives of small- and large-scale industry, the collective expertise of which shall cover every focus area described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s17113/c"},"text":"section 17113(c) of this title","children":[],"tail":"; and "},{"tag":"ref","attrib":{"idref":"fn004252"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004252"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. The word “and” probably should not appear."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276145-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" not less than 1 representative of a State government; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276146-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other individuals the Secretary, in coordination with the Director, determines to be necessary to ensure that the Committee is comprised of a diverse group of representatives of industry, academia, independent researchers, and public and private entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0276147-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chair","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall designate a member of the Committee to serve as Chair.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0276148-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0276149-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc027614a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with the Secretary and the Director, propose missions and goals for the program, which shall be consistent with the purposes of the program described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17113/b/1"},"text":"section 17113(b)(1) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc027614b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" advise the Secretary with respect to the program—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc027614c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by identifying and evaluating any technologies being developed by the private sector relating to the focus areas described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17113/c"},"text":"section 17113(c) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc027614d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by identifying technology gaps in the private sector or other Federal agencies in those focus areas, and making recommendations to address those gaps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc027614e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/d/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by surveying and analyzing factors that prevent the adoption of emissions reduction technologies by the private sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc027614f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/d/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by recommending technology screening criteria for technology developed under the program to encourage adoption of the technology by the private sector; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276150-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop the strategic plan described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0276151-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategic plan","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0276152-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of the strategic plan developed under paragraph (1)(C) is to set forth a plan for achieving the goals of the program established in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17113/b/1"},"text":"section 17113(b)(1) of this title","children":[],"tail":", including for the focus areas described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s17113/c"},"text":"section 17113(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276153-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The strategic plan developed under paragraph (1)(C) shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0276154-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify near-term and long-term qualitative and quantitative objectives relating to each focus area described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17113/c"},"text":"section 17113(c) of this title","children":[],"tail":", including research, development, demonstration, and commercial application objectives;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0276155-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leverage existing roadmaps relevant to the program in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17113/b/1"},"text":"section 17113(b)(1) of this title","children":[],"tail":" and the focus areas in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s17113/c"},"text":"section 17113(c) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0276156-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify the anticipated timeframe for achieving the objectives specified under clause (i);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0276157-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/d/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include plans for developing emissions reduction technologies that are globally cost-competitive, including, as applicable, in developing economies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0276158-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/d/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the appropriate role for investment by the Federal Government, in coordination with the private sector, to achieve the objectives specified under clause (i);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0276159-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/d/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the public and private costs of achieving the objectives specified under clause (i); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc027615a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/d/2/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimate the economic and employment impact in the United States of achieving those objectives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc027615b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc027615c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Frequency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall meet not less frequently than 2 times per year, at the call of the Chair.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc027615d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial meeting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after the date on which the members are appointed under subsection (b), the Committee shall hold its first meeting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc027615e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Committee report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc027615f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", and not less frequently than once every 3 years thereafter, the Committee shall submit to the Secretary a report on the progress of achieving the purposes of the program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0276160-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0276161-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any technology innovation opportunities identified by the Committee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276162-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any technology gaps identified by the Committee under subsection (d)(1)(B)(ii);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276163-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for improving technology screening criteria and management of the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276164-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the progress of the program and the research, development, and demonstration activities funded under the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276165-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/f/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommended changes to the focus areas of the program described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17113/c"},"text":"section 17113(c) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276166-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/f/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the manner in which the Committee has carried out the duties described in subsection (d)(1) and any relevant findings as a result of carrying out those duties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276167-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/f/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if necessary, an update to the strategic plan developed by the Committee under subsection (d)(1)(C);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276168-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/f/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the progress made in achieving the goals set out in that strategic plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276169-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/f/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of the management, coordination, and industry utility of the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc027616a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/f/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the extent to which progress has been made under the program in developing commercial, cost-competitive technologies in each focus area described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17113/c"},"text":"section 17113(c) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc027616b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/f/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the effectiveness of the program in coordinating efforts within the Department and with other Federal agencies to achieve the purposes of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc027616c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after receiving a report from the Committee under subsection (f), the Secretary shall submit a copy of that report to the Committees on Appropriations and Science, Space, and Technology of the House of Representatives, the Committees on Appropriations and Energy and Natural Resources of the Senate, and any other relevant Committee of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc027616d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17114/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of Federal Advisory Committee Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this section, the Federal Advisory Committee Act (5 U.S.C. App.) ","children":[{"tag":"ref","attrib":{"idref":"fn004253"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004253"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" See References in Text note below."}],"tail":" shall apply to the Committee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc027616e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIV/s455"},"text":"Pub. L. 110–140, title IV, § 455","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tVI/s6004/a"},"text":"Pub. L. 116–260, div. Z, title VI, § 6004(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2556"},"text":"134 Stat. 2556","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc027616f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc0276170-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc0276171-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Advisory Committee Act, referred to in subsec. (h), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/463"},"text":"Pub. L. 92–463","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-06"},"text":"Oct. 6, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/770"},"text":"86 Stat. 770","children":[],"tail":", which was set out in the Appendix to Title 5, Government Organization and Employees, and was substantially repealed and restated in chapter 10 (§ 1001 et seq.) of Title 5 by "},{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":", §§ 3(a), 7, "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4197"},"text":"136 Stat. 4197","children":[],"tail":", 4361. For disposition of sections of the Act into chapter 10 of Title 5, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s101"},"text":"section 101 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
