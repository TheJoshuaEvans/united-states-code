{"tag":"section","attrib":{"id":"idbdbb41e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6734"},"text":null,"children":[{"tag":"num","attrib":{"value":"6734"},"text":"§ 6734.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration; rules; authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdbb41ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6734/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary is authorized to prescribe, after consultation with the Secretary of Labor, such rules as may be necessary for the purpose of carrying out his functions under this subchapter. Such rules should be prescribed by the Secretary not later than ninety days of ","children":[{"tag":"date","attrib":{"date":"1976-07-22"},"text":"July 22, 1976","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdbb41eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6734/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are authorized to be appropriated such sums as may be necessary for the administration of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdbb41ec-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/369/tII/s214"},"text":"Pub. L. 94–369, title II, § 214","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-07-22"},"text":"July 22, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1010"},"text":"90 Stat. 1010","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
