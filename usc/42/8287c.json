{"tag":"section","attrib":{"id":"idbe8f8208-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8287c"},"text":null,"children":[{"tag":"num","attrib":{"value":"8287c"},"text":"§ 8287c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe8f8209-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8287c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Federal agency” means each authority of the Government of the United States, whether or not it is within or subject to review by another agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8f820a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8287c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “energy savings” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe8f820b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8287c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a reduction in the cost of energy, water, or wastewater treatment, from a base cost established through a methodology set forth in the contract, used in an existing Federal building (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8259"},"text":"section 8259 of this title","children":[],"tail":") as a result of—"}],"tail":null},{"tag":"clause","attrib":{"id":"idbe8f820c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8287c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lease or purchase of operating equipment, improvements, altered operation and maintenance, or technical services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe8f820d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8287c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the increased efficient use of existing energy sources by cogeneration or heat recovery, excluding any cogeneration process for other than a Federal building (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8259"},"text":"section 8259 of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe8f820e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8287c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the increased efficient use of existing water sources in either interior or exterior applications;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe8f820f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8287c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the increased efficient use of an existing energy source by cogeneration or heat recovery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe8f8210-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8287c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if otherwise authorized by Federal or State law (including regulations), the sale or transfer of electrical or thermal energy generated on-site from renewable energy sources or cogeneration, but in excess of Federal needs, to utilities or non-Federal energy users;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe8f8211-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8287c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the increased efficient use of existing water sources in interior or exterior applications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe8f8212-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8287c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use, sale, or transfer of any energy and water incentive, rebate, grid services revenue, or credit (including a renewable energy certificate); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe8f8213-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8287c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any revenue generated from a reduction in energy or water use, more efficient waste recycling, or additional energy generated from more efficient equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8f8214-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8287c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “energy savings contract” and “energy savings performance contract” mean a contract that provides for the performance of services for the design, acquisition, installation, testing, and, where appropriate, operation, maintenance, and repair, of an identified energy or water conservation measure or series of measures at 1 or more locations. Such contracts shall, with respect to an agency facility that is a public building (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3301"},"text":"section 3301 of title 40","children":[],"tail":"), be in compliance with the prospectus requirements and procedures of "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s3307"},"text":"section 3307 of title 40","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8f8215-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8287c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “energy or water conservation measure” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe8f8216-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8287c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an energy conservation measure, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8259"},"text":"section 8259 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe8f8217-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8287c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a water conservation measure that improves the efficiency of water use, is life-cycle cost-effective, and involves water conservation, water recycling or reuse, more efficient treatment of wastewater or stormwater, improvements in operation or maintenance efficiencies, retrofit activities, or other related activities, not at a Federal hydroelectric facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe8f8218-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/619/tVIII/s804"},"text":"Pub. L. 95–619, title VIII, § 804","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tVII/s7201/a"},"text":"Pub. L. 99–272, title VII, § 7201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/143"},"text":"100 Stat. 143","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tI/s155/b"},"text":"Pub. L. 102–486, title I, § 155(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2855"},"text":"106 Stat. 2855","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/388/s4/b"},"text":"Pub. L. 105–388, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3477"},"text":"112 Stat. 3477","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tX/s1090/c"},"text":"Pub. L. 108–375, div. A, title X, § 1090(c)","children":[],"tail":"–(e), "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2067"},"text":"118 Stat. 2067","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tV/s515"},"text":"Pub. L. 110–140, title V, § 515","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1659"},"text":"121 Stat. 1659","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tI/s1002/f"},"text":"Pub. L. 116–260, div. Z, title I, § 1002(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2423"},"text":"134 Stat. 2423","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe8f8219-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe8f821a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe8f821b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Par. (2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s1002/f/1"},"text":"Pub. L. 116–260, § 1002(f)(1)","children":[],"tail":", substituted “Federal building (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8259"},"text":"section 8259 of this title","children":[],"tail":")” for “federally owned building or buildings or other federally owned facilities” in introductory provisions and in cl. (ii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(E), (F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s1002/f/2"},"text":"Pub. L. 116–260, § 1002(f)(2)","children":[],"tail":"–(4), added subpars. (E) and (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":" substituted “means—” for “means” in introductory provisions, inserted subpar. (A) designation before “a reduction”, redesignated former subpars. (A) to (C) as cls. (i) to (iii) of subpar. (A), respectively, and added subpars. (B) to (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s1090/c"},"text":"Pub. L. 108–375, § 1090(c)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “The term ‘energy savings’ means a reduction in the cost of energy, from a base cost established through a methodology set forth in the contract, utilized in an existing federally owned building or buildings or other federally owned facilities as a result of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the lease or purchase of operating equipment, improvements, altered operation and maintenance, or technical services; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the increased efficient use of existing energy sources by cogeneration or heat recovery, excluding any cogeneration process for other than a federally owned building or buildings or other federally owned facilities.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s1090/d"},"text":"Pub. L. 108–375, § 1090(d)","children":[],"tail":", amended par. (3) generally. Prior to amendment, par. (3) read as follows: “The terms ‘energy savings contract’ and ‘energy savings performance contract’ mean a contract which provides for the performance of services for the design, acquisition, installation, testing, operation, and, where appropriate, maintenance and repair, of an identified energy conservation measure or series of measures at one or more locations. Such contracts—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) may provide for appropriate software licensing agreements; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) shall, with respect to an agency facility that is a public building as such term is defined in section 13(1) of the Public Buildings Act of 1959 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s612/1"},"text":"40 U.S.C. 612(1)","children":[],"tail":"), be in compliance with the prospectus requirements and procedures of section 7 of the Public Buildings Act of 1959 ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s606"},"text":"40 U.S.C. 606","children":[],"tail":").”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s1090/e"},"text":"Pub. L. 108–375, § 1090(e)","children":[],"tail":", amended par. (4) generally. Prior to amendment, par. (4) read as follows: “The term ‘energy conservation measures’ has the meaning given such term in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8259/4"},"text":"section 8259(4) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/388"},"text":"Pub. L. 105–388","children":[],"tail":" amended par. (1) generally. Prior to amendment, par. (1) read as follows: “The term ‘Federal agency’ means an agency defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s551/1"},"text":"section 551(1) of title 5","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/s155/b/1"},"text":"Pub. L. 102–486, § 155(b)(1)","children":[],"tail":", substituted “subchapter, the following definitions apply:” for “subchapter—” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/s155/b/2"},"text":"Pub. L. 102–486, § 155(b)(2)","children":[],"tail":", substituted “The” for “the” and a period for “, and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/s155/b/3"},"text":"Pub. L. 102–486, § 155(b)(3)","children":[],"tail":", substituted “The term” for “the term”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/s155/b/4"},"text":"Pub. L. 102–486, § 155(b)(4)","children":[],"tail":", added pars. (3) and (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbe8f821c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbe8f821d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":" effective on the date that is 1 day after "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
