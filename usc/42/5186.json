{"tag":"section","attrib":{"id":"idbd1df050-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5186"},"text":null,"children":[{"tag":"num","attrib":{"value":"5186"},"text":"§ 5186.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency public transportation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President is authorized to provide temporary public transportation service in an area affected by a major disaster to meet emergency needs and to provide transportation to governmental offices, supply centers, stores, post offices, schools, major employment centers, and such other places as may be necessary in order to enable the community to resume its normal pattern of life as soon as possible.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd1df051-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tIV/s419"},"text":"Pub. L. 93–288, title IV, § 419","children":[],"tail":", formerly § 416, "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/158"},"text":"88 Stat. 158","children":[],"tail":"; renumbered § 419, "},{"tag":"ref","attrib":{"href":"/us/pl/100/707/tI/s106/j"},"text":"Pub. L. 100–707, title I, § 106(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4705"},"text":"102 Stat. 4705","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd1df052-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd1df053-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children"