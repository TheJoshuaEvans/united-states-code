{"tag":"section","attrib":{"id":"idb6d95365-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a"},"text":null,"children":[{"tag":"num","attrib":{"value":"300jj–19a"},"text":"§ 300jj–19a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electronic health record reporting program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6d95366-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting criteria","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6d95367-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Convening of stakeholders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2016-12-13"},"text":"December 13, 2016","children":[],"tail":", the Secretary shall convene stakeholders, as described in paragraph (2), for the purpose of developing the reporting criteria in accordance with paragraph (3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6d95368-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of reporting criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The reporting criteria under this subsection shall be developed through a public, transparent process that reflects input from relevant stakeholders, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6d95369-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health care providers, including primary care and specialty care health care professionals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d9536a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hospitals and hospital systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d9536b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health information technology developers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d9536c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" patients, consumers, and their advocates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d9536d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data sharing networks, such as health information exchanges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d9536e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorized certification bodies and testing laboratories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d9536f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" security experts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d95370-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relevant manufacturers of medical devices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d95371-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/a/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" experts in health information technology market economics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d95372-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/a/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public and private entities engaged in the evaluation of health information technology performance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d95373-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/a/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quality organizations, including the consensus based entity described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395aaa"},"text":"section 1395aaa of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d95374-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/a/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" experts in human factors engineering and the measurement of user-centered design; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d95375-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/a/2/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other entities or individuals, as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6d95376-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations for reporting criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The reporting criteria developed under this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6d95377-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall include measures that reflect categories including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6d95378-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d95379-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" usability and user-centered design;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d9537a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/a/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interoperability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d9537b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/a/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conformance to certification testing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d9537c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/a/3/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other categories, as appropriate to measure the performance of electronic health record technology;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d9537d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may include categories such as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6d9537e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enabling the user to order and view the results of laboratory tests, imaging tests, and other diagnostic tests;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d9537f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submitting, editing, and retrieving data from registries such as clinician-led clinical data registries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d95380-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accessing and exchanging information and data from and through health information exchanges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d95381-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/a/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accessing and exchanging information and data from medical devices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d95382-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/a/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accessing and exchanging information and data held by Federal, State, and local agencies and other applicable entities useful to a health care provider or other applicable user in the furtherance of patient care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d95383-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/a/3/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accessing and exchanging information from other health care providers or applicable users;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d95384-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/a/3/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accessing and exchanging patient generated information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d95385-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/a/3/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing the patient or an authorized designee with a complete copy of their health information from an electronic record in a computable format;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d95386-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/a/3/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing accurate patient information for the correct patient, including exchanging such information, and avoiding the duplication of patients records; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d95387-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/a/3/B/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other categories regarding performance, accessibility,","children":[{"tag":"ref","attrib":{"idref":"fn002527"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002527"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “performance or accessibility,”."}],"tail":" as the Secretary determines appropriate; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d95388-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be designed to ensure that small and startup health information technology developers are not unduly disadvantaged by the reporting criteria.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6d95389-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After the reporting criteria have been developed under paragraph (3), the Secretary may convene stakeholders and conduct a public comment period for the purpose of modifying the reporting criteria developed under such paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6d9538a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of maintaining certification under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300jj–11/c/5/D"},"text":"section 300jj–11(c)(5)(D) of this title","children":[],"tail":", a developer of certified electronic health records shall submit to an appropriate recipient of a grant, contract, or agreement under subsection (c)(1) responses to the criteria developed under subsection (a), with respect to all certified technology offered by such developer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6d9538b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6d9538c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2016-12-13"},"text":"December 13, 2016","children":[],"tail":", the Secretary shall award grants, contracts, or agreements to independent entities on a competitive basis to support the convening of stakeholders as described in subsection (a)(2), collect the information required to be reported in accordance with the criteria established as described subsection (a)(3), and develop and implement a process in accordance with paragraph (5) and report such information to the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6d9538d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An independent entity that seeks a grant, contract, or agreement under this subsection shall submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary may reasonably require, including a description of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6d9538e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proposed method for reviewing and summarizing information gathered based on reporting criteria established under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d9538f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if applicable, the intended focus on a specific subset of certified electronic health record technology users, such as health care providers, including primary care, specialty care, and care provided in rural settings; hospitals and hospital systems; and patients, consumers, and patients and consumer advocates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d95390-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan for widely distributing reports described in paragraph (6);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d95391-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period for which the grant, contract, or agreement is requested, which may be up to 2 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d95392-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the budget for reporting program participation, and whether the eligible independent entity intends to continue participation after the period of the grant, contract, or agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6d95393-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations for independent entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants, contracts, and agreements under paragraph (1), the Secretary shall give priority to independent entities with appropriate expertise in health information technology usability, interoperability, and security (especially entities with such expertise in electronic health records) with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6d95394-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health care providers, including primary care, specialty care, and care provided in rural settings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d95395-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hospitals and hospital systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d95396-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" patients, consumers, and patient and consumer advocates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6d95397-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6d95398-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment and redetermination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 4 years after ","children":[{"tag":"date","attrib":{"date":"2016-12-13"},"text":"December 13, 2016","children":[],"tail":", and every 2 years thereafter, the Secretary, in consultation with stakeholders, shall—"}],"tail":null},{"tag":"clause","attrib":{"id":"idb6d95399-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/c/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess performance of the recipients of the grants, contracts, and agreements under paragraph (1) based on quality and usability of reports described in paragraph (6); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d9539a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/c/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" re-determine grants, contracts, and agreements as necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d9539b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions on participation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not award a grant, contract, or cooperative agreement under paragraph (1) to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6d9539c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/c/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a proprietor of certified health information technology or a business affiliate of such a proprietor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d9539d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/c/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a developer of certified health information technology; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d9539e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/c/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State or local government agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6d9539f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Feedback","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Based on reporting criteria established under subsection (a), the recipients of grants, contracts, and agreements under paragraph (1) shall develop and implement a process to collect and verify confidential feedback on such criteria from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6d953a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health care providers, patients, and other users of certified electronic health record technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d953a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developers of certified electronic health record technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6d953a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6d953a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each recipient of a grant, contract, or agreement under paragraph (1) shall report on the information reported to such recipient pursuant to subsection (a) and the user feedback collected under paragraph (5) by preparing summary reports and detailed reports of such information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d953a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each recipient of a grant, contract, or agreement under paragraph (1) shall submit the reports prepared under subparagraph (A) to the Secretary for public distribution in accordance with subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6d953a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall distribute widely, as appropriate, and publish, on the Internet website of the Office of the National Coordinator—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6d953a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reporting criteria developed under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6d953a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the summary and detailed reports under subsection (c)(6).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6d953a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each recipient of a grant, contract, or agreement under paragraph (1) shall develop and implement a process through which participating electronic health record technology developers may review and recommend changes to the reports created under subsection (c)(6) for products developed by such developer prior to the publication of such report under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6d953a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–19a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional resources","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide additional resources on the Internet website of the Office of the National Coordinator to better inform consumers of health information technology. Such reports may be carried out through partnerships with private organizations with appropriate expertise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6d953aa-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXX, § 3009A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tIV/s4002/c"},"text":"Pub. L. 114–255, div. A, title IV, § 4002(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1161"},"text":"130 Stat. 1161","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
