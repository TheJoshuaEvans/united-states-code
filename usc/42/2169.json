{"tag":"section","attrib":{"id":"idbbfd65b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169"},"text":null,"children":[{"tag":"num","attrib":{"value":"2169"},"text":"§ 2169.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fingerprinting for criminal history record checks","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbbfd65b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbfd65b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbfd65b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbbfd65b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission shall require each individual or entity described in clause (ii) to fingerprint each individual described in subparagraph (B) before the individual described in subparagraph (B) is permitted access under subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbbfd65b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The individuals and entities referred to in clause (i) are individuals and entities that, on or before the date on which an individual is permitted access under subparagraph (B)—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbbfd65b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169/a/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are licensed or certified to engage in an activity subject to regulation by the Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbbfd65b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169/a/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have filed an application for a license or certificate to engage in an activity subject to regulation by the Commission; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbbfd65b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169/a/1/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have notified the Commission in writing of an intent to file an application for licensing, certification, permitting, or approval of a product or activity subject to regulation by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbfd65ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Commission shall require to be fingerprinted any individual who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbbfd65bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is permitted unescorted access to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbbfd65bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169/a/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a utilization facility; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbbfd65bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169/a/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" radioactive material or other property subject to regulation by the Commission that the Commission determines to be of such significance to the public health and safety or the common defense and security as to warrant fingerprinting and background checks; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbbfd65be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is permitted access to safeguards information under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2167"},"text":"section 2167 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbfd65bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All fingerprints obtained by an individual or entity as required in paragraph (1) shall be submitted to the Attorney General of the United States through the Commission for identification and a criminal history records check.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbfd65c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The costs of an identification or records check under paragraph (2) shall be paid by the individual or entity required to conduct the fingerprinting under paragraph (1)(A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbfd65c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding any other provision of law—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbfd65c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Attorney General may provide any result of an identification or records check under paragraph (2) to the Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbfd65c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commission, in accordance with regulations prescribed under this section, may provide the results to the individual or entity required to conduct the fingerprinting under paragraph (1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbfd65c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission, by rule, may relieve persons from the obligations imposed by this section, upon specified terms, conditions, and periods, if the Commission finds that such action is consistent with its obligations to promote the common defense and security and to protect the health and safety of the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbfd65c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of administering this section, the Commission shall prescribe requirements—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbfd65c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to implement procedures for the taking of fingerprints;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbfd65c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to establish the conditions for use of information received from the Attorney General, in order—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbfd65c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to limit the redissemination of such information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbfd65c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that such information is used solely for the purpose of determining whether an individual shall be permitted unescorted access to a utilization facility, radioactive material, or other property described in subsection (a)(1)(B) or shall be permitted access to safeguards information under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2167"},"text":"section 2167 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbfd65ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to ensure that no final determination may be made solely on the basis of information provided under this section involving—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbbfd65cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an arrest more than 1 year old for which there is no information of the disposition of the case; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbbfd65cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an arrest that resulted in dismissal of the charge or an acquittal; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbfd65cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to protect individuals subject to fingerprinting under this section from misuse of the criminal history records; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbfd65ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide each individual subject to fingerprinting under this section with the right to complete, correct, and explain information contained in the criminal history records prior to any final adverse determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbfd65cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of biometric methods","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission may require a person or individual to conduct fingerprinting under subsection (a)(1) by authorizing or requiring the use of any alternative biometric method for identification that has been approved by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbfd65d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Attorney General; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbfd65d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commission, by regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbfd65d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Processing fees; use of amounts collected","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbfd65d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission may establish and collect fees to process fingerprints and criminal history records under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbfd65d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302/b"},"text":"section 3302(b) of title 31","children":[],"tail":", and to the extent approved in appropriation Acts—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbfd65d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a portion of the amounts collected under this subsection in any fiscal year may be retained and used by the Commission to carry out this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbfd65d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the remaining portion of the amounts collected under this subsection in such fiscal year may be transferred periodically to the Attorney General and used by the Attorney General to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbfd65d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2169/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any amount made available for use under paragraph (2) shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbfd65d8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"Aug. 1, 1946, ch. 724","children":[],"tail":", title I, § 149, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/399/tVI/s606/a"},"text":"Pub. L. 99–399, title VI, § 606(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/876"},"text":"100 Stat. 876","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tIX/s902/a/8"},"text":"Pub. L. 102–486, title IX, § 902(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2944"},"text":"106 Stat. 2944","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVI/s652"},"text":"Pub. L. 109–58, title VI, § 652","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/810"},"text":"119 Stat. 810","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbfd65d9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbbfd65da-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbbfd65db-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s652/1"},"text":"Pub. L. 109–58, § 652(1)","children":[],"tail":", revised and restructured provisions of subsec. (a). Prior to amendment, subsec. (a) read as follows: “The Nuclear Regulatory Commission (in this section referred to as the ‘Commission’) shall require each licensee or applicant for a license to operate a utilization facility under section 2133 or 2134(b) of this title to fingerprint each individual who is permitted unescorted access to the facility or is permitted access to safeguards information under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2167"},"text":"section 2167 of this title","children":[],"tail":". All fingerprints obtained by a licensee or applicant as required in the preceding sentence shall be submitted to the Attorney General of the United States through the Commission for identification and a criminal history records check. The costs of any identification and records check conducted pursuant to the preceding sentence shall be paid by the licensee or applicant. Notwithstanding any other provision of law, the Attorney General may provide all the results of the search to the Commission, and, in accordance with regulations prescribed under this section, the Commission may provide such results to the licensee or applicant submitting such fingerprints.” Amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/s652/1/D"},"text":"Pub. L. 109–58, § 652(1)(D)","children":[],"tail":", which misquoted the sentence to be stricken by leaving out the word “the” before “licensee”, was nevertheless executed to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s652/2/A"},"text":"Pub. L. 109–58, § 652(2)(A)","children":[],"tail":", substituted “requirements—” for “, subject to public notice and comment, regulations—” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s652/2/B"},"text":"Pub. L. 109–58, § 652(2)(B)","children":[],"tail":", substituted “unescorted access to a utilization facility, radioactive material, or other property described in subsection (a)(1)(B)” for “unescorted access to the facility of a licensee or applicant”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s652/3"},"text":"Pub. L. 109–58, § 652(3)","children":[],"tail":", (4), added subsec. (d) and redesignated former subsec. (d) as (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbbfd65dc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbbfd65dd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399/tVI/s606/b"},"text":"Pub. L. 99–399, title VI, § 606(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/877"},"text":"100 Stat. 877","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/399/tVI/s606/b"},"text":"“The provisions of subsection a. of section 149 of the Atomic Energy Act of 1954 [subsec. (a) of this section], as added by this Act, shall take effect upon the promulgation of regulations by the Nuclear Regulatory Commission as set forth in subsection c. of such section [subsec. (c) of this section]. Such regulations shall be promulgated not later than 6 months after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
