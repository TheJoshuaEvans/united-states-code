{"tag":"section","attrib":{"id":"idbf44c83a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11374"},"text":null,"children":[{"tag":"num","attrib":{"value":"11374"},"text":"§ 11374.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf44c83b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11374/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Assistance provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11372"},"text":"section 11372 of this title","children":[],"tail":" may be used for the following activities:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf44c83c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11374/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The renovation, major rehabilitation, or conversion of buildings to be used as emergency shelters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf44c83d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11374/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The provision of essential services related to emergency shelter or street outreach, including services concerned with employment, health, education, family support services for homeless youth, substance abuse services, victim services, or mental health services, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf44c83e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11374/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such essential services have not been provided by the local government during any part of the immediately preceding 12-month period or the Secretary determines that the local government is in a severe financial deficit; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf44c83f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11374/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of assistance under this part would complement the provision of those essential services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf44c840-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11374/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Maintenance, operation, insurance, provision of utilities, and provision of furnishings related to emergency shelter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf44c841-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11374/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provision of rental assistance to provide short-term or medium-term housing to homeless individuals or families or individuals or families at risk of homelessness. Such rental assistance may include tenant-based or project-based rental assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf44c842-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11374/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Housing relocation or stabilization services for homeless individuals or families or individuals or families at risk of homelessness, including housing search, mediation or outreach to property owners, legal services, credit repair, providing security or utility deposits, utility payments, rental assistance for a final month at a location, assistance with moving costs, or other activities that are effective at—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf44c843-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11374/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stabilizing individuals and families in their current housing; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf44c844-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11374/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quickly moving such individuals and families to other permanent housing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf44c845-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11374/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum allocation for emergency shelter activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grantee of assistance provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11372"},"text":"section 11372 of this title","children":[],"tail":" for any fiscal year may not use an amount of such assistance for activities described in paragraphs (1) through (3) of subsection (a) that exceeds the greater of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf44c846-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11374/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 60 percent of the aggregate amount of such assistance provided for the grantee for such fiscal year; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf44c847-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11374/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount expended by such grantee for such activities during fiscal year ","children":[{"tag":"ref","attrib":{"idref":"fn004001"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004001"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “the fiscal year”."}],"tail":" most recently completed before the effective date under section 1503 of the Homeless Emergency Assistance and Rapid Transition to Housing Act of 2009."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf44c848-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77/tIV/s415"},"text":"Pub. L. 100–77, title IV, § 415","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/22/dB/tII/s1202"},"text":"Pub. L. 111–22, div. B, title II, § 1202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-20"},"text":"May 20, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1679"},"text":"123 Stat. 1679","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf44c849-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf44c84a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf44c84b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The effective date under section 1503 of the Homeless Emergency Assistance and Rapid Transition to Housing Act of 2009, referred to in subsec. (b)(2), is the effective date under ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/22/dB/s1503"},"text":"section 1503 of div. B of Pub. L. 111–22","children":[],"tail":", set out as an Effective Date of 2009 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11302"},"text":"section 11302 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf44c84c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 11374, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77/tIV/s415"},"text":"Pub. L. 100–77, title IV, § 415","children":[],"tail":", formerly § 414, "},{"tag":"date","attrib":{"date":"1987-07-22"},"text":"July 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/497"},"text":"101 Stat. 497","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/628/tIV"},"text":"Pub. L. 100–628, title IV","children":[],"tail":", §§ 422, 423(a), "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3231"},"text":"102 Stat. 3231","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/tVIII/s832/c"},"text":"Pub. L. 101–625, title VIII, § 832(c)","children":[],"tail":", (d), (f)(6), "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4360"},"text":"104 Stat. 4360","children":[],"tail":", 4361; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIV/s1402/e"},"text":"Pub. L. 102–550, title XIV, § 1402(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4013"},"text":"106 Stat. 4013","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/330/tV/s506/a/4"},"text":"Pub. L. 104–330, title V, § 506(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4044"},"text":"110 Stat. 4044","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/377/s1/a/1/tII/s229/b"},"text":"Pub. L. 106–377, § 1(a)(1) [title II, § 229(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-27"},"text":"Oct. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1441"},"text":"114 Stat. 1441","children":[],"tail":", 1441A–31; renumbered § 415, "},{"tag":"ref","attrib":{"href":"/us/pl/111/22/dB/tII/s1201/3"},"text":"Pub. L. 111–22, div. B, title II, § 1201(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-20"},"text":"May 20, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1678"},"text":"123 Stat. 1678","children":[],"tail":", which related to assistance used for activities relating to emergency shelter for homeless individuals, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/22/dB/tII/s1202"},"text":"Pub. L. 111–22, div. B, title II, § 1202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-20"},"text":"May 20, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1679"},"text":"123 Stat. 1679","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77/s415"},"text":"section 415 of Pub. L. 100–77","children":[],"tail":" was renumbered section 416 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11375"},"text":"section 11375 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf44c84d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf44c84e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the earlier of 18 months after ","children":[{"tag":"date","attrib":{"date":"2009-05-20"},"text":"May 20, 2009","children":[],"tail":", or 3 months after publication of certain final regulations by Secretary of Housing and Urban Development, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/22/s1503"},"text":"section 1503 of Pub. L. 111–22","children":[],"tail":", set out as an Effective Date of 2009 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11302"},"text":"section 11302 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbf44c84f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report by Comptroller General","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/628/tIV/s423/b"},"text":"Pub. L. 100–628, title IV, § 423(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3232"},"text":"102 Stat. 3232","children":[],"tail":", required the Comptroller General to conduct a study and report to Congress not later than 1 year after "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", on programs to prevent homelessness implemented by grantees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
