{"tag":"section","attrib":{"id":"idbeb0edab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9208"},"text":null,"children":[{"tag":"num","attrib":{"value":"9208"},"text":"§ 9208.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbeb0edac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9208/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring of performance; collection and evaluation of data","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in coordination with such Government agencies as may be appropriate, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbeb0edad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9208/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor the performance and operation of wind energy systems installed under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeb0edae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9208/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect and evaluate data and information on the performance and operation of wind energy systems installed under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbeb0edaf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9208/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liaison","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall also maintain continuing liaison with related industries and interests and with the scientific and technical community in order to assure that the benefits of programs under this chapter are and will continue to be realized to the maximum extent feasible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbeb0edb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9208/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall assure, subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1905"},"text":"section 1905 of title 18","children":[],"tail":", that full and complete information with respect to any program, project, or other activity conducted under this chapter is made available to Federal, State, and local authorities, relevant segments of the economy, the scientific community, and the public so that the early, widespread, and practical use of wind energy throughout the United States is promoted to the maximum extent feasible."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbeb0edb1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/345/s9"},"text":"Pub. L. 96–345, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"Sept. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1144"},"text":"94 Stat. 1144","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/tI/s1051/b"},"text":"Pub. L. 104–66, title I, § 1051(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-21"},"text":"Dec. 21, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/716"},"text":"109 Stat. 716","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbeb0edb2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbeb0edb3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbeb0edb4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1995—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/66"},"text":"Pub. L. 104–66","children":[],"tail":" struck out par. (3) which read as follows: “from time to time carry out such studies and investigations and take such other actions, including the submission of special reports to the Congress when appropriate, as may be necessary to assure that the programs for which the Secretary is responsible under this chapter effectively carry out the purposes of this chapter.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
