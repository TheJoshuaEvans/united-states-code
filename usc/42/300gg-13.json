{"tag":"section","attrib":{"id":"idb6ac0242-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–13"},"text":null,"children":[{"tag":"num","attrib":{"value":"300gg–13"},"text":"§ 300gg–13.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coverage of preventive health services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6ac0243-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–13/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A group health plan and a health insurance issuer offering group or individual health insurance coverage shall, at a minimum provide coverage for and shall not impose any cost sharing requirements for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6ac0244-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–13/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evidence-based items or services that have in effect a rating of “A” or “B” in the current recommendations of the United States Preventive Services Task Force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6ac0245-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–13/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" immunizations that have in effect a recommendation from the Advisory Committee on Immunization Practices of the Centers for Disease Control and Prevention with respect to the individual involved; and ","children":[{"tag":"ref","attrib":{"idref":"fn002457"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002457"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6ac0246-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–13/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to infants, children, and adolescents, evidence-informed preventive care and screenings provided for in the comprehensive guidelines supported by the Health Resources and Services Administration.","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6ac0247-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–13/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to women, such additional preventive care and screenings not described in paragraph (1) as provided for in comprehensive guidelines supported by the Health Resources and Services Administration for purposes of this paragraph.","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6ac0248-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–13/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the purposes of this chapter, and for the purposes of any other provision of law, the current recommendations of the United States Preventive Service Task Force regarding breast cancer screening, mammography, and prevention shall be considered the most current other than those issued in or around November 2009.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Nothing in this subsection shall be construed to prohibit a plan or issuer from providing coverage for services in addition to those recommended by United States Preventive Services Task Force or to deny coverage for services that are not recommended by such Task Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6ac0249-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–13/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interval","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6ac024a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–13/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a minimum interval between the date on which a recommendation described in subsection (a)(1) or (a)(2) or a guideline under subsection (a)(3) is issued and the plan year with respect to which the requirement described in subsection (a) is effective with respect to the service described in such recommendation or guideline.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6ac024b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–13/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The interval described in paragraph (1) shall not be less than 1 year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6ac024c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–13/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Value-based insurance design","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may develop guidelines to permit a group health plan and a health insurance issuer offering group or individual health insurance coverage to utilize value-based insurance designs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6ac024d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVII, § 2713, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1001/5"},"text":"Pub. L. 111–148, title I, § 1001(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/131"},"text":"124 Stat. 131","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6ac024e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6ac024f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb6ac0250-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 300gg–13, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tXXVII/s2713"},"text":"act July 1, 1944, ch. 373, title XXVII, § 2713","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/191/tI/s102/a"},"text":"Pub. L. 104–191, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1966"},"text":"110 Stat. 1966","children":[],"tail":", was renumbered section 2709 of act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", and transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–9"},"text":"section 300gg–9 of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI"},"text":"Pub. L. 111–148, title I","children":[],"tail":", §§ 1001(3), 1563(c)(10)(C), formerly § 1562(c)(10)(C), title X, § 10107(b)(1), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/130"},"text":"124 Stat. 130","children":[],"tail":", 268, 911."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 2713 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was successively renumbered by subsequent acts and transferred, see section 238"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb6ac0251-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb6ac0252-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective for plan years beginning on or after the date that is 6 months after ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s1004"},"text":"section 1004 of Pub. L. 111–148","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–11"},"text":"section 300gg–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb6ac0253-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rapid Coverage of Preventive Services and Vaccines for Coronavirus","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tIII/s3203"},"text":"Pub. L. 116–136, div. A, title III, § 3203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/367"},"text":"134 Stat. 367","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/136/dA/tIII/s3203"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding [section] 2713(b) of the Public Health Service Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–13"},"text":"42 U.S.C. 300gg–13","children":[],"tail":"[(b)]), the Secretary of Health and Human Services, the Secretary of Labor, and the Secretary of the Treasury shall require group health plans and health insurance issuers offering group or individual health insurance to cover (without cost-sharing) any qualifying coronavirus preventive service, pursuant to section 2713(a) of the Public Health Service Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–13/a"},"text":"42 U.S.C. 300gg–13(a)","children":[],"tail":") (including the regulations under sections 2590.715–2713 of title 29, Code of Federal Regulations, section 54.9815–2713 of title 26, Code of Federal Regulations, and section 147.130 of title 45, Code of Federal Regulations (or any successor regulations)). The requirement described in this subsection shall take effect with respect to a qualifying coronavirus preventive service on the specified date described in subsection (b)(2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualifying coronavirus preventive service","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘qualifying coronavirus preventive service’ means an item, service, or immunization that is intended to prevent or mitigate coronavirus disease 2019 and that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evidence-based item or service that has in effect a rating of ‘A’ or ‘B’ in the current recommendations of the United States Preventive Services Task Force; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an immunization that has in effect a recommendation from the Advisory Committee on Immunization Practices of the Centers for Disease Control and Prevention with respect to the individual involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Specified date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘specified date’ means the date that is 15 business days after the date on which a recommendation is made relating to the qualifying coronavirus preventive service as described in such paragraph.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional terms","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the terms ‘group health plan’, ‘health insurance issuer’, ‘group health insurance coverage’, and ‘individual health insurance coverage’ have the meanings given such terms in section 2791 of the Public Health Service Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–91"},"text":"42 U.S.C. 300gg–91","children":[],"tail":"), section 733 of the Employee Retirement Income Security Act of 1974 ("},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1191b"},"text":"29 U.S.C. 1191b","children":[],"tail":"), and section 9832 of the Internal Revenue Code ["},{"tag":"ref","attrib":{"href":"/us/usc/t26/s9832"},"text":"26 U.S.C. 9832","children":[],"tail":"], as applicable.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
