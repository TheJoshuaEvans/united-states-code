{"tag":"section","attrib":{"id":"idbb9491f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s"},"text":null,"children":[{"tag":"num","attrib":{"value":"1862s"},"text":"§ 1862s.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reaffirmation of merit-based peer review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb9491fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb9491fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sustained, predictable Federal funding of basic research is essential to United States leadership in science and technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb9491fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Foundation’s intellectual merit and broader impacts criteria are appropriate for evaluating grant proposals, as concluded by the 2011 National Science Board Task Force on Merit Review;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb9491fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" evaluating proposals on the basis of the Foundation’s intellectual merit and broader impacts criteria should be used to assure that the Foundation’s activities are in the national interest as these reviews can affirm that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb9491fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proposals funded by the Foundation are of high quality and advance scientific knowledge; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb9491ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Foundation’s grants address societal needs through basic research findings or through related activities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb949200-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as evidenced by the Foundation’s contributions to scientific advancement, economic growth, human health, and national security, its peer review and merit review processes have identified and funded scientifically and societally relevant basic research and should be preserved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb949201-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Merit review criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall maintain the intellectual merit and broader impacts criteria, among other specific criteria as appropriate, as the basis for evaluating grant proposals in the merit review process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb949202-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If after ","children":[{"tag":"date","attrib":{"date":"2017-01-06"},"text":"January 6, 2017","children":[],"tail":", a change is made to the merit-review process, the Director shall submit a report to the appropriate committees of Congress not later than 30 days after the date of the change."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb949203-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/tI/s101"},"text":"Pub. L. 114–329, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-01-06"},"text":"Jan. 6, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2970"},"text":"130 Stat. 2970","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb949204-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb949205-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb949206-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the American Innovation and Competitiveness Act, and not as part of the National Science Foundation Act of 1950 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb949207-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbb949208-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/s2"},"text":"Pub. L. 114–329, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-01-06"},"text":"Jan. 6, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2970"},"text":"130 Stat. 2970","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/329/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this Act [see Short Title of 2017 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1861"},"text":"section 1861 of this title","children":[],"tail":" and Tables], unless expressly provided otherwise:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriate committees of congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘appropriate committees of Congress’ means the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Science, Space, and Technology of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal science agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Federal science agency’ has the meaning given the term in section 103 of the America COMPETES Reauthorization Act of 2010 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6623"},"text":"42 U.S.C. 6623","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foundation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Foundation’ means the National Science Foundation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Institution of higher education","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘institution of higher education’ has the meaning given the term in section 101(a) of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001/a"},"text":"20 U.S.C. 1001(a)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"NIST","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘NIST’ means the National Institute of Standards and Technology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"STEM","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘STEM’ has the meaning given the term in section 2 of the American [sic] COMPETES Reauthorization Act of 2010 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358"},"text":"Pub. L. 111–358","children":[],"tail":"] ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6621"},"text":"42 U.S.C. 6621","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"STEM education","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘STEM education’ has the meaning given the term in section 2 of the STEM Education Act of 2015 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/59"},"text":"Pub. L. 114–59","children":[],"tail":"] ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6621"},"text":"42 U.S.C. 6621","children":[],"tail":" note).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
