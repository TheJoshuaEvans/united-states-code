{"tag":"section","attrib":{"id":"idbcbc21e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4156"},"text":null,"children":[{"tag":"num","attrib":{"value":"4156"},"text":"§ 4156.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver and modification of standards","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Administrator of General Services, with respect to standards issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4152"},"text":"section 4152 of this title","children":[],"tail":", and the Secretary of Housing and Urban Development, with respect to standards issued under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4153"},"text":"section 4153 of this title","children":[],"tail":", and the Secretary of Defense with respect to standards issued under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4154"},"text":"section 4154 of this title","children":[],"tail":", and the United States Postal Service with respect to standards issued under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4154a"},"text":"section 4154a of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcbc21e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4156/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is authorized to modify or waive any such standard, on a case-by-case basis, upon application made by the head of the department, agency, or instrumentality of the United States concerned, and upon a determination by the Administrator or Secretary, as the case may be, that such modification or waiver is clearly necessary, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcbc21e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4156/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall establish a system of continuing surveys and investigations to insure compliance with such standards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcbc21e7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/480/s6"},"text":"Pub. L. 90–480, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-12"},"text":"Aug. 12, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/719"},"text":"82 Stat. 719","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/541/tII/s201/6"},"text":"Pub. L. 94–541, title II, § 201(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-18"},"text":"Oct. 18, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2508"},"text":"90 Stat. 2508","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcbc21e8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcbc21e9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcbc21ea-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/541"},"text":"Pub. L. 94–541","children":[],"tail":", in introductory text, inserted reference to the United States Postal Service with respect to standards issued under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4154a"},"text":"section 4154a of this title","children":[],"tail":" and struck out “is authorized” at end; in par. (1), inserted introductory words “is authorized”; and in par. (2), substituted “shall establish a system of continuing surveys and investigations” for “to conduct such surveys and investigations as he deems necessary”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
