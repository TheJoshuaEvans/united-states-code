{"tag":"section","attrib":{"id":"idbf938584-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655h"},"text":null,"children":[{"tag":"num","attrib":{"value":"12655h"},"text":"§ 12655h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference for certain projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf938585-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the consideration of applications submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12655b"},"text":"section 12655b of this title","children":[],"tail":", the Corporation shall give preference to programs that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf938586-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655h/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will provide long-term benefits to the public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf938587-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655h/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will instill a work ethic and a sense of public service in the participants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf938588-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655h/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will be labor intensive, and involve youth operating in crews;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":