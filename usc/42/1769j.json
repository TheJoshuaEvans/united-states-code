{"tag":"section","attrib":{"id":"idbb6bfaee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769j"},"text":null,"children":[{"tag":"num","attrib":{"value":"1769j"},"text":"§ 1769j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ensuring safety of school meals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb6bfaef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food and Nutrition Service","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2010-12-13"},"text":"December 13, 2010","children":[],"tail":", the Secretary, acting through the Administrator of the Food and Nutrition Service, shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb6bfaf0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769j/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with the Administrator of the Agricultural Marketing Service and the Administrator of the Farm Service Agency, develop guidelines to determine the circumstances under which it is appropriate for the Secretary to institute an administrative hold on suspect foods purchased by the Secretary that are being used in school meal programs under this chapter and the Child Nutrition Act of 1966 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1771"},"text":"42 U.S.C. 1771","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb6bfaf1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769j/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work with States to explore ways for the States to increase the timeliness of notification of food recalls to schools and school food authorities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb6bfaf2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769j/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the timeliness and completeness of direct communication between the Food and Nutrition Service and States about holds and recalls, such as through the commodity alert system of the Food and Nutrition Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb6bfaf3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769j/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a timeframe to improve the commodity hold and recall procedures of the Department of Agriculture to address the role of processors and determine the involvement of distributors with processed products that may contain recalled ingredients, to facilitate the provision of more timely and complete information to schools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb6bfaf4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food Safety and Inspection Service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2010-12-13"},"text":"December 13, 2010","children":[],"tail":", the Secretary, acting through the Administrator of the Food Safety and Inspection Service, shall revise the procedures of the Food Safety and Inspection Service to ensure that schools are included in effectiveness checks."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb6bfaf5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-06-04/ch281/s29"},"text":"June 4, 1946, ch. 281, § 29","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/296/tIII/s308"},"text":"Pub. L. 111–296, title III, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-13"},"text":"Dec. 13, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3246"},"text":"124 Stat. 3246","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb6bfaf6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb6bfaf7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbb6bfaf8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Child Nutrition Act of 1966, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/642"},"text":"Pub. L. 89–642","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-11"},"text":"Oct. 11, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/885"},"text":"80 Stat. 885","children":[],"tail":", which is classified generally to chapter 13A (§ 1771 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1771"},"text":"section 1771 of this title","children":[],"tail":" and Tables."}],"tail":