{"tag":"section","attrib":{"id":"idbd3102f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5201"},"text":null,"children":[{"tag":"num","attrib":{"value":"5201"},"text":"§ 5201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd3102f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5201/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd3102f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5201/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President may prescribe such rules and regulations as may be necessary and proper to carry out any of the provisions of this chapter, and he may exercise any power or authority conferred on him by any section of this chapter either directly or through such Federal agency or agencies as he may designate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd3102f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5201/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadline for payment of assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Rules and regulations authorized by paragraph (1) shall provide that payment of any assistance under this chapter to a State shall be completed within 60 days after the date of approval of such assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd3102f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5201/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In furtherance of the purposes of this chapter, the President or his delegate may accept and use bequests, gifts, or donations of service, money, or property, real, personal, or mixed, tangible, or intangible. All sums received under this subsection shall be deposited in a separate fund on the books of the Treasury and shall be available for expenditure upon the certification of the President or his delegate. At the request of the President or his delegate, the Secretary of the Treasury may invest and reinvest excess monies in the fund. Such investments shall be in public debt securities with maturities suitable for the needs of the fund and shall bear interest at rates determined by the Secretary of the Treasury, taking into consideration current market yields on outstanding marketable obligations of the United States of comparable maturities. The interest on such investments shall be credited to, and form a part of, the fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd3102f5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tVII/s701"},"text":"Pub. L. 93–288, title VII, § 701","children":[],"tail":", formerly title VI, § 601, "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/163"},"text":"88 Stat. 163","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/446"},"text":"Pub. L. 96–446","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-13"},"text":"Oct. 13, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1893"},"text":"94 Stat. 1893","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/707/tI/s108/a"},"text":"Pub. L. 100–707, title I, § 108(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"re