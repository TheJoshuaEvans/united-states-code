{"tag":"section","attrib":{"id":"idbf9ab093-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12713"},"text":null,"children":[{"tag":"num","attrib":{"value":"12713"},"text":"§ 12713.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility under first-time homebuyer programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf9ab094-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12713/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility of displaced homemakers and single parents for Federal assistance for first-time homebuyers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf9ab095-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12713/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Displaced homemakers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No individual who is a displaced homemaker may be denied eligibility under any Federal program to assist first-time homebuyers on the basis that the individual, while a homemaker, owned a home with his or her spouse or resided in a home owned by the spouse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9ab096-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12713/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Single parents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No individual who is a single parent may be denied eligibility under any Federal program to assist first-time homebuyers on the basis that the individual, while married, owned a home with his or her spouse or resided in a home owned by the spouse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf9ab097-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12713/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf9ab098-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12713/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Displaced homemaker","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “displaced homemaker” means an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf9ab099-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12713/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an adult;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf9ab09a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12713/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not worked full-time, full-year in the labor force for a number of years but has, during such years, worked primarily without remuneration to care for the home and family; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf9ab09b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12713/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is unemployed or underemployed and is experiencing difficulty in obtaining or upgrading employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9ab09c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12713/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First-time homebuyer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “first-time homebuyer” means an individual who has never, or has not during a specified period of time, had any present ownership interest in a principal residence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9ab09d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12713/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Single parent","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “single parent” means an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf9ab09e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12713/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is unmarried or legally separated from a spouse; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf9ab09f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12713/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf9ab0a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12713/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has 1 or more minor children for whom the individual has custody or joint custody; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf9ab0a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12713/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is pregnant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf9ab0a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12713/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply to any Federal program to assist first-time homebuyers, unless the program is exempted from this section by a statute that amends this subsection or explicitly refers to this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf9ab0a3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tIX/s956"},"text":"Pub. L. 101–625, title IX, § 956","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4421"},"text":"104 Stat. 4421","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf9ab0a4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf9ab0a5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf9ab0a6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of title IX of the Cranston-Gonzalez National Affordable Housing Act, and not as part of title I of such Act which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
