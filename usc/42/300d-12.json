{"tag":"section","attrib":{"id":"idb615dc21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–12"},"text":null,"children":[{"tag":"num","attrib":{"value":"300d–12"},"text":"§ 300d–12.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of matching funds for fiscal years subsequent to first fiscal year of payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb615dc22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–12/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal contributions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb615dc23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–12/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–11/a"},"text":"section 300d–11(a) of this title","children":[],"tail":" unless the State involved agrees, with respect to the costs described in paragraph (2), to make available non-Federal contributions (in cash or in kind under subsection (b)(1)) toward such costs in an amount that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb615dc24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–12/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the second and third fiscal years of such payments to the State, is not less than $1 for each $1 of Federal funds provided in such payments for such fiscal years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb615dc25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–12/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the fourth and subsequent fiscal years of such payments to the State, is not less than $2 for each $1 of Federal funds provided in such payments for such fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb615dc26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–12/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program costs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The costs referred to in paragraph (1) are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb615dc27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–12/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs to be incurred by the State in carrying out the purpose described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–11/b"},"text":"section 300d–11(b) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb615dc28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–12/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of improving the quality and availability of emergency medical services in rural areas of the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb615dc29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–12/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial year of payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not require a State to make non-Federal contributions as a condition of receiving payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–11/a"},"text":"section 300d–11(a) of this title","children":[],"tail":" for the first fiscal year of such payments to the State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb615dc2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–12/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of amount of non-Federal contribution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to compliance with subsection (a) as a condition of receiving payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–11/a"},"text":"section 300d–11(a) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb615dc2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–12/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State may make the non-Federal contributions required in such subsection in cash or in kind, fairly evaluated, including plant, equipment, or services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb615dc2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–12/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary may not, in making a determination of the amount of non-Federal contributions, include amounts provided by the Federal Government or services assisted or subsidized to any significant extent by the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb615dc2d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XII, § 1212, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/590/s3"},"text":"Pub. L. 101–590, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2919"},"text":"104 Stat. 2919","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/183/tVI/s601/f/2"},"text":"Pub. L. 103–183, title VI, § 601(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-14"},"text":"Dec. 14, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2239"},"text":"107 Stat. 2239","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/23/s6"},"text":"Pub. L. 110–23, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-05-03"},"text":"May 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/92"},"text":"121 Stat. 92","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb615dc2e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb615dc2f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb615dc30-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/23"},"text":"Pub. L. 110–23","children":[],"tail":" amended section generally. Prior to amendment, section related to requirement of matching funds for fiscal years subsequent to first fiscal year of payments."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/183"},"text":"Pub. L. 103–183","children":[],"tail":" substituted “section 300d–11(b)” for “section 300d–11(c)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
