{"tag":"section","attrib":{"id":"idbf3b2bba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225"},"text":null,"children":[{"tag":"num","attrib":{"value":"11225"},"text":"§ 11225.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" The National Alzheimer’s Project","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf3b2bbb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of Alzheimer’s","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this Act, the term “Alzheimer’s” means Alzheimer’s disease and related dementias.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf3b2bbc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Office of the Secretary of Health and Human Services the National Alzheimer’s Project (referred to in this Act as the “Project”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf3b2bbd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of the Project","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Health and Human Services, or the Secretary’s designee, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf3b2bbe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be responsible for the creation and maintenance of an integrated national plan to overcome Alzheimer’s;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf3b2bbf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide information on, and coordination of, Alzheimer’s research and services across all Federal agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf3b2bc0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accelerate the development of treatments that would prevent, halt, or reverse the course of Alzheimer’s;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf3b2bc1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" improve the—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf3b2bc2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promotion of healthy aging and reduction and mitigation of risk factors for Alzheimer’s;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf3b2bc3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" early diagnosis of Alzheimer’s disease; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf3b2bc4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordination of the care and treatment of citizens with Alzheimer’s;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf3b2bc5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure the inclusion of ethnic and racial populations and other underserved populations, including individuals with developmental disabilities such as Down syndrome, at higher risk for Alzheimer’s or least likely to receive care, in clinical, research, and service efforts with the purpose of decreasing health disparities in Alzheimer’s;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf3b2bc6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide information on, and promote the adoption of, healthy behaviors that may reduce the risk of cognitive decline and promote and protect cognitive health; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf3b2bc7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with international bodies to integrate and inform the fight against Alzheimer’s globally.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf3b2bc8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of the Secretary","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf3b2bc9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Health and Human Services, or the Secretary’s designee, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf3b2bca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oversee the creation and updating of the national plan described in paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf3b2bcb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use discretionary authority to evaluate all Federal programs around Alzheimer’s, including budget requests and approvals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf3b2bcc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services, or the Secretary’s designee, shall carry out an annual assessment of the Nation’s progress, across public and private sectors, in preparing for the escalating burden of Alzheimer’s, including both implementation steps and recommendations for priority actions based on the assessment, including consideration of public-private collaborations, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf3b2bcd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Council","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf3b2bce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established an Advisory Council on Alzheimer’s Research, Care, and Services (referred to in this Act as the “Advisory Council”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf3b2bcf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf3b2bd0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Council shall be comprised of the following experts:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf3b2bd1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A designee of the Centers for Disease Control and Prevention.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf3b2bd2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A designee of the Administration on Aging.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf3b2bd3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A designee of the Centers for Medicare & Medicaid Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf3b2bd4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A designee of the Indian Health Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf3b2bd5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A designee of the Office of the Director of the National Institutes of Health.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf3b2bd6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Surgeon General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf3b2bd7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e/2/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A designee of the National Science Foundation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf3b2bd8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e/2/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A designee of the Department of Veterans Affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf3b2bd9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e/2/A/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A designee of the Food and Drug Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf3b2bda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e/2/A/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A designee of the Agency for Healthcare Research and Quality.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf3b2bdb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e/2/A/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A designee of the Department of Justice.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf3b2bdc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e/2/A/xii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xii"},"text":"(xii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A designee of the Federal Emergency Management Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf3b2bdd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e/2/A/xiii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xiii"},"text":"(xiii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A designee of the Social Security Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf3b2bde-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e/2/A/xiv"},"text":null,"children":[{"tag":"num","attrib":{"value":"xiv"},"text":"(xiv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 or more other designees, as determined by the Secretary of Health and Human Services, at least one of whom has expertise in risk factors associated with the development or the progression of Alzheimer’s.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf3b2bdf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the members outlined in subparagraph (A), the Advisory Council shall include 15 expert members from outside the Federal Government, which shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf3b2be0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 Alzheimer’s patient advocates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf3b2be1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 Alzheimer’s caregivers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf3b2be2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 health care providers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf3b2be3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 representatives of State health departments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf3b2be4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 researchers with Alzheimer’s-related expertise in basic, translational, clinical, or drug development science, including at least one researcher with demonstrated experience in recruitment and retention of underrepresented groups into research or clinical trials related to dementia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf3b2be5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 voluntary health association representatives, including a national Alzheimer’s disease organization that has demonstrated experience in research, care, and patient services, and a State-based advocacy organization that provides services to families and professionals, including information and referral, support groups, care consultation, education, and safety services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf3b2be6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e/2/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 individual with a diagnosis of Alzheimer’s disease; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf3b2be7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e/2/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 representative from a historically underserved population whose lifetime risk for developing Alzheimer’s is markedly higher than that of other populations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf3b2be8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Council shall meet quarterly and such meetings shall be open to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf3b2be9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Council shall advise the Secretary of Health and Human Services, or the Secretary’s designee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf3b2bea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Council shall provide to the Secretary of Health and Human Services, or the Secretary’s designee and Congress—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf3b2beb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annual evaluations of all federally funded efforts in Alzheimer’s research, risk reduction, public health, clinical care, and institutional-, home-, and community-based programs and their outcomes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf3b2bec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for priority actions to expand, eliminate, coordinate, or condense programs based on the program’s performance, mission, and purpose;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf3b2bed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" recommendations to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf3b2bee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e/5/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" reduce the financial impact of Alzheimer’s on—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbf3b2bef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e/5/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Medicare and other federally funded programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf3b2bf0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e/5/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" families living with Alzheimer’s disease; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf3b2bf1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e/5/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve health outcomes and reduce disparities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf3b2bf2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annual evaluations of the implementation, including outcomes, of the recommendations, including priorities if necessary, through an updated national plan under subsection (d)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf3b2bf3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Council shall terminate on ","children":[{"tag":"date","attrib":{"date":"2035-12-31"},"text":"December 31, 2035","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf3b2bf4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Agencies both within the Department of Health and Human Services and outside of the Department that have data relating to Alzheimer’s shall share such data with the Secretary of Health and Human Services, or the Secretary’s designee, to enable the Secretary, or the Secretary’s designee, to complete the report described in subsection (g).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf3b2bf5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Health and Human Services, or the Secretary’s designee, shall submit to Congress—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf3b2bf6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an annual report that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf3b2bf7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation; ","children":[{"tag":"ref","attrib":{"idref":"fn003990"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003990"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The semicolon probably should not appear."}],"tail":" of all federally funded efforts in Alzheimer’s research, clinical care, and institutional-, home-, and community-based programs and their outcomes; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf3b2bf8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the Secretary’s process for identifying and updating what conditions constitute Alzheimer’s disease;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf3b2bf9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of all federally funded programs based on program performance, mission, and purpose related to Alzheimer’s disease;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf3b2bfa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" recommendations for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf3b2bfb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" priority actions based on the evaluation conducted by the Secretary and the Advisory Council to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf3b2bfc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/g/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" reduce the financial impact of Alzheimer’s on—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbf3b2bfd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/g/3/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Medicare and other federally funded programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf3b2bfe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/g/3/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" families living with Alzheimer’s disease; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf3b2bff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/g/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve health outcomes and reduce disparities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf3b2c00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementation steps; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf3b2c01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/g/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" priority actions to improve the prevention, diagnosis, treatment, care, institutional-, home-, and community-based programs of Alzheimer’s disease for individuals with Alzheimer’s disease and their caregivers; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf3b2c02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an annually updated national plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf3b2c03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Professional judgment budget","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For fiscal year 2024 and each subsequent fiscal year, the Director of the National Institutes of Health shall prepare and submit, directly to the President for review and transmittal to Congress, after reasonable opportunity for comment, but without change, by the Secretary of Health and Human Services and the Advisory Council, an annual budget estimate for the initiatives of the National Institutes of Health pursuant to the reports and recommendations made under this Act, including an estimate of the number and type of personnel needs for the National Institutes of Health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf3b2c04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11225/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Project shall expire on ","children":[{"tag":"date","attrib":{"date":"2035-12-31"},"text":"December 31, 2035","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf3b2c05-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/375/s2"},"text":"Pub. L. 111–375, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4100"},"text":"124 Stat. 4100","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/92/s2"},"text":"Pub. L. 118–92, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-10-01"},"text":"Oct. 1, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1562"},"text":"138 Stat. 1562","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/93/s2"},"text":"Pub. L. 118–93, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-10-01"},"text":"Oct. 1, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1565"},"text":"138 Stat. 1565","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf3b2c06-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf3b2c07-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf3b2c08-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsecs. (a), (b), (e)(1), and (h), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/375"},"text":"Pub. L. 111–375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4100"},"text":"124 Stat. 4100","children":[],"tail":", known as the National Alzheimer’s Project Act, which enacted this subchapter and provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11201"},"text":"section 11201 of this title","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 2010 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11201"},"text":"section 11201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf3b2c09-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Alzheimer’s Project Act, and not as part of the Alzheimer’s Disease and Related Dementias Research Act of 1992 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf3b2c0a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/92/s2/1/A"},"text":"Pub. L. 118–92, § 2(1)(A)","children":[],"tail":", substituted “on, and coordination of,” for “and coordination of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/92/s2/1/B"},"text":"Pub. L. 118–92, § 2(1)(B)","children":[],"tail":", added subpar. (A) and redesignated former subpars. (A) and (B) as (B) and (C), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/92/s2/1/C"},"text":"Pub. L. 118–92, § 2(1)(C)","children":[],"tail":", inserted “and other underserved populations, including individuals with developmental disabilities such as Down syndrome,” after “populations” and substituted semicolon at end for “; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/92/s2/1/D"},"text":"Pub. L. 118–92, § 2(1)(D)","children":[],"tail":", (E), added par. (6) and redesignated former par. (6) as (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/92/s2/2"},"text":"Pub. L. 118–92, § 2(2)","children":[],"tail":", inserted “, across public and private sectors,” after “Nation’s progress” and “, including consideration of public-private collaborations, as appropriate” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2)(A)(xi) to (xiv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/92/s2/3/A/i"},"text":"Pub. L. 118–92, § 2(3)(A)(i)","children":[],"tail":", added cls. (xi) to (xiv)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/92/s2/3/A/ii/I"},"text":"Pub. L. 118–92, § 2(3)(A)(ii)(I)","children":[],"tail":", substituted “15” for “12” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2)(B)(v). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/92/s2/3/A/ii/II"},"text":"Pub. L. 118–92, § 2(3)(A)(ii)(II)","children":[],"tail":", substituted “3 researchers” for “2 researchers” and “, including at least one researcher with demonstrated experience in recruitment and retention of underrepresented groups into research or clinical trials related to dementia;” for “; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Su