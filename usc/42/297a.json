{"tag":"section","attrib":{"id":"idb5f471a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297a"},"text":null,"children":[{"tag":"num","attrib":{"value":"297a"},"text":"§ 297a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Student loan fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5f471a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements to establish and operate fund authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to enter into an agreement for the establishment and operation of a student loan fund in accordance with this part with any public or nonprofit private school of nursing which is located in a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5f471a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions of agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each agreement entered into under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5f471a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for establishment of a student loan fund by the school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5f471a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for deposit in the fund, except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s298d"},"text":"section 298d of this title","children":[],"tail":", of (A) the Federal capital contributions paid from allotments under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s297d"},"text":"section 297d of this title","children":[],"tail":" to the school by the Secretary, (B) an additional amount from other sources equal to not less than one-ninth of such Federal capital contributions, (C) collections of principal and interest on loans made from the fund, (D) collections pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s297b/f"},"text":"section 297b(f) of this title","children":[],"tail":", and (E) any other earnings of the fund;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5f471a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that the fund, except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s298d"},"text":"section 298d of this title","children":[],"tail":", shall be used only for loans to students of the school in accordance with the agreement and for costs of collection of such loans and interest thereon;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5f471a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that loans may be made from such fund only to students pursuing a full-time or half-time course of study at the school leading to a baccalaureate or associate degree in nursing or an equivalent degree or a diploma in nursing, or to a graduate degree in nursing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5f471a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain such other provisions as are necessary to protect the financial interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5f471aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulatory standards applicable to collection of loans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5f471ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any standard established by the Secretary by regulation for the collection by schools of nursing of loans made pursuant to loan agreements under this part shall provide that the failure of any such school to collect such loans shall be measured in accordance with this subsection. With respect to the student loan fund established pursuant to such agreements, this subsection may not be construed to require such schools to reimburse such loan fund for loans that became uncollectable prior to 1983.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5f471ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The measurement of a school’s failure to collect loans made under this part shall be the ratio (stated as a percentage) that the defaulted principal amount outstanding of such school bears to the matured loans of such school.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5f471ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5f471ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “default” means the failure of a borrower of a loan made under this part to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5f471af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297a/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make an installment payment when due; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5f471b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297a/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comply with any other term of the promissory note for such loan,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"except that a loan made under this part shall not be considered to be in default if the loan is discharged in bankruptcy or if the school reasonably concludes from written contacts with the borrower that the borrower intends to repay the loan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5f6bba1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “defaulted principal amount outstanding” means the total amount borrowed from the loan fund of a school that has reached the repayment stage (minus any principal amount repaid or cancelled) on loans—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5f6bba2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297a/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" repayable monthly and in default for at least 120 days; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5f6bba3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297a/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" repayable less frequently than monthly and in default for at least 180 days;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5f6bba4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297a/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “grace period” means the period of nine months beginning on the date on which the borrower ceases to pursue a full-time or half-time course of study at a school of nursing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5f6bba5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297a/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “matured loans” means the total principal amount of all loans made by a school of nursing under this part minus the total principal amount of loans made by such school to students who are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5f6bba6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297a/c/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enrolled in a full-time or half-time course of study at such school; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5f6bba7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s297a/c/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in their grace period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5f6bba8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VIII, § 835, formerly § 822, as added "},{"tag":"ref","attrib":{"href":"/us/pl/88/581/s2"},"text":"Pub. L. 88–581, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-09-04"},"text":"Sept. 4, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/913"},"text":"78 Stat. 913","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/90/490/tII/s222/a"},"text":"Pub. L. 90–490, title II, § 222(a)","children":[],"tail":", (c)(2), "},{"tag":"date","attrib":{"date":"1968-08-16"},"text":"Aug. 16, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/783"},"text":"82 Stat. 783","children":[],"tail":", 784; "},{"tag":"ref","attrib":{"href":"/us/pl/92/158/s6/d/3"},"text":"Pub. L. 92–158, § 6(d)(3)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"1971-11-18"},"text":"Nov. 18, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/478"},"text":"85 Stat. 478","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/385/s3/b"},"text":"Pub. L. 93–385, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-23"},"text":"Aug. 23, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/741"},"text":"88 Stat. 741","children":[],"tail":"; renumbered § 835 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/63/tIX"},"text":"Pub. L. 94–63, title IX","children":[],"tail":", §§ 936(a), 941(h)(1)–(3), (i)(1), (2), "},{"tag":"date","attrib":{"date":"1975-07-29"},"text":"July 29, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/362"},"text":"89 Stat. 362","children":[],"tail":", 365, 366; "},{"tag":"ref","attrib":{"href":"/us/pl/96/76/tI/s109/a"},"text":"Pub. L. 96–76, title I, § 109(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/579"},"text":"93 Stat. 579","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXVII/s2757/a"},"text":"Pub. L. 97–35, title XXVII, § 2757(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/931"},"text":"95 Stat. 931","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/92/s8/a"},"text":"Pub. L. 99–92, § 8(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-16"},"text":"Aug. 16, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/397"},"text":"99 Stat. 397","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/129/tII/s209/j/2"},"text":"Pub. L. 99–129, title II, § 209(j)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-10-22"},"text":"Oct. 22, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/536"},"text":"99 Stat. 536","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tVII/s713/a"},"text":"Pub. L. 100–607, title VII, § 713(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3160"},"text":"102 Stat. 3160","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tV/s5310/b/2"},"text":"Pub. L. 111–148, title V, § 5310(b)(2)","children":[],"tail":", (6), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/631"},"text":"124 Stat. 631","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5f6bba9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5f6bbaa-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5f6bbab-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s5310/b/2"},"text":"Pub. L. 111–148, § 5310(b)(2)","children":[],"tail":", substituted “this part” for “this subpart”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s5310/b/6"},"text":"Pub. L. 111–148, § 5310(b)(6)","children":[],"tail":", substituted “298d” for “297h” in pars. (2) and (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s5310/b/2"},"text":"Pub. L. 111–148, § 5310(b)(2)","children":[],"tail":", substituted “this part” for “this subpart” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/607"},"text":"Pub. L. 100–607","children":[],"tail":" inserted provisions relating to reimbursement of student loan fund for certain uncollectable loans."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/92"},"text":"Pub. L. 99–92","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/129/s209/j/2/A"},"text":"Pub. L. 99–129, § 209(j)(2)(A)","children":[],"tail":", substituted provisions defining “grace period” as the period of nine months beginning on the date on which the borrower ceases to pursue a full-time or half-time course of study at a school of nursing for former provisions defining “grace period” as the period of one year beginning on (i) the date on which the borrower ceased to pursue a full-time or half-time course of study at a school of nursing; or (ii) the date on which ended any period described in clause (A) or (B) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s297b/b/2"},"text":"section 297b(b)(2) of this title","children":[],"tail":" which was applicable to such borrower, whichever was later."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(D)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/129/s209/j/2/B"},"text":"Pub. L. 99–129, § 209(j)(2)(B)","children":[],"tail":", struck out “first” before “grace period.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" struck out provisions respecting prohibition on loans to students attending school before "},{"tag":"date","attrib":{"date":"1980-10-01"},"text":"Oct. 1, 1980","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/76"},"text":"Pub. L. 96–76","children":[],"tail":" substituted “1980” for “1978”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/63/s941/h/1"},"text":"Pub. L. 94–63, § 941(h)(1)","children":[],"tail":", (2), substituted “subpart” for “part” and struck out “of Health, Education, and Welfare” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/63"},"text":"Pub. L. 94–63","children":[],"tail":", §§ 936(a), 941(h)(3), (i)(2), in cl. (2) substituted “from allotments under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s297d"},"text":"section 297d of this title","children":[],"tail":"” for “under this part”, in cl. (4) substituted “"},{"tag":"date","attrib":{"date":"1978-10-01"},"text":"October 1, 1978","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1975-07-01"},"text":"July 1, 1975","children":[],"tail":"”, and in cls. (2) and (3) substituted references to sections 836 and 841 of the Act for references to sections 823 and 829, which had previously been translated as sections 297b and 297h of this title, respectively, requiring no further translations in the text as a result of the renumbering of the Public Health Service Act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/385"},"text":"Pub. L. 93–385","children":[],"tail":" substituted “1975” for “1974”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1971—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/158"},"text":"Pub. L. 92–158","children":[],"tail":" substituted “full-time or half-time course of study” for “full-time course of study” and “1974” for “1971”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/490/s222/a/1"},"text":"Pub. L. 90–490, § 222(a)(1)","children":[],"tail":", (c)(2), inserted “, except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s297h"},"text":"section 297h of this title","children":[],"tail":",” after “fund” where first appearing and added cl. (D) and redesignated former cl. (D) as (E), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/490/s222/a/1"},"text":"Pub. L. 90–490, § 222(a)(1)","children":[],"tail":", inserted “, except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s297h"},"text":"section 297h of this title","children":[],"tail":"” after “fund” where first appearing and authorized the cancellation of an additional 50 per centum of a nursery student loan."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/490/s222/a/2"},"text":"Pub. L. 90–490, § 222(a)(2)","children":[],"tail":", substituted “1971” for “1969”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5f6bbac-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb5f6bbad-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/129"},"text":"Pub. L. 99–129","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1984-06-30"},"text":"June 30, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/129/s228/b/5"},"text":"section 228(b)(5) of Pub. L. 99–129","children":[],"tail":", set out as a note under section 254"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title."}],"tail":"\n"},{"tag