{"tag":"section","attrib":{"id":"idbfa1b557-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12785"},"text":null,"children":[{"tag":"num","attrib":{"value":"12785"},"text":"§ 12785.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" REACH: asset recycling information dissemination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfa1b558-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12785/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make available upon request by any participating jurisdiction a list of eligible properties that are located within the jurisdiction and that are owned or controlled by the Department of Housing and Urban Development to facilitate the purchase, development, or rehabilitation of such properties with assistance made available under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa1b559-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12785/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible properties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible property under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfa1b55a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12785/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be an unoccupied single-family or multifamily dwelling, such that acquisition and rehabilitation of the dwelling would not result in the displacement of any residents of the dwelling; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa1b55b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12785/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have an appraised value that does not exceed (A) in the case of a 1- to 4-family dwelling, 95 percent of the median purchase price for the area for such dwellings, as determined by the Secretary, or (B) in the case of a dwelling with more than 4 units, the applicable maximum dollar amount limitation under section 1715","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(d)(3)(ii) of title 12 for elevator-type structures."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfa1b55c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tII/s245"},"text":"Pub. L. 101–625, title II, § 245","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4119"},"text":"104 Stat. 4119","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
