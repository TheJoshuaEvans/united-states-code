{"tag":"section","attrib":{"id":"idbea50619-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8818"},"text":null,"children":[{"tag":"num","attrib":{"value":"8818"},"text":"§ 8818.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbea5061a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8818/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/386/tI/s101/a"},"text":"Pub. L. 99–386, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-22"},"text":"Aug. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/821"},"text":"100 Stat. 821","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbea5061b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8818/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive list of loans, grants, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 120 days after ","children":[{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", the Secretary of Energy and the Secretary of Agriculture shall submit to the Congress a comprehensive list of all the types of loans, grants, incentives, rebates, or any other such private, State, or Federal economic or financial benefits now in effect or proposed which can be or have been used for production of alcohol to be used as a motor fuel or petroleum substitute."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbea5061c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8818/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports; report evaluating overall impact and plan for termination of Office of Alcohol Fuels","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbea5061d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8818/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbea5061e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8818/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Alcohol Fuels shall submit to the Congress and the President annual reports containing a general description of the Office’s operations during the year and a description and evaluation of each biomass energy project for which financial assistance by the Office is then in effect.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbea5061f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8818/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each annual report shall describe progress made toward meeting the goals of this subchapter and contain specific recommendations on what actions the Congress could take in order to facilitate the work of the Office in achieving such goals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbea50620-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8818/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each annual report under this subsection shall contain financial statements prepared by the Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea50621-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8818/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On or before ","children":[{"tag":"date","attrib":{"date":"1990-09-30"},"text":"September 30, 1990","children":[],"tail":", the Office shall submit to the Congress and the President a report evaluating the overall impact made by the Office and describing the status of each biomass energy project which has received financial assistance under this subchapter from the Office. Such report shall contain a plan for the termination of the work of the Office."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbea50622-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/294/tII/s218"},"text":"Pub. L. 96–294, title II, § 218","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/695"},"text":"94 Stat. 695","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/386/tI/s101/a"},"text":"Pub. L. 99–386, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-22"},"text":"Aug. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/821"},"text":"100 Stat. 821","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbea50623-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbea50624-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbea50625-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/386"},"text":"Pub. L. 99–386","children":[],"tail":" struck out subsec. (a) which related to submission of quarterly reports to the President and Congress by Secretary of Agriculture and Secretary of Energy."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbea50626-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbea50627-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions in subsec. (c)(1) of this section relating to the requirement that the Office of Alcohol Fuels submit annual reports to Congress, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance, and the 12th item on page 91 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
