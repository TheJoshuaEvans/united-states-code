{"tag":"section","attrib":{"id":"idbfc0d729-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13434"},"text":null,"children":[{"tag":"num","attrib":{"value":"13434"},"text":"§ 13434.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biofuels user facility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfc0d72a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13434/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall establish a biofuels user facility to expedite industry adoption of biofuels technologies, including production of alcohol fuels from biomass.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc0d72b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13434/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary, through such universities and colleges as the Secretary determines are qualified, shall establish a program, in accordance with sections 13541 and 13542 of this title, with respect to the production and use of diesel fuels from vegetable oils or animal fats. The program shall investigate—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc0d72c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13434/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the economic feasibility of production of oilseed crops for biofuels purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d72d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13434/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of a mobile small-scale oilseed pressing and esterification unit and a stationary small-scale commercial oilseed pressing and esterification unit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfc0d72e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXX/s2024"},"text":"Pub. L. 102–486, title XX, § 2024","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3062"},"text":"106 Stat. 3062","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
