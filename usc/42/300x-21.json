{"tag":"section","attrib":{"id":"idb669536f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–21"},"text":null,"children":[{"tag":"num","attrib":{"value":"300x–21"},"text":"§ 300x–21.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Formula grants to States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6695370-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–21/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose described in subsection (b), the Secretary, acting through the Center for Substance Abuse Treatment, shall make an allotment each fiscal year for each State in an amount determined in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–33"},"text":"section 300x–33 of this title","children":[],"tail":". The Secretary shall make a grant to the State of the allotment made for the State for the fiscal year if the State submits to the Secretary an application in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–32"},"text":"section 300x–32 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6695371-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–21/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A funding agreement for a grant under subsection (a) is that, subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–31"},"text":"section 300x–31 of this title","children":[],"tail":", the State involved will expend the grant only for the purpose of carrying out the plan developed in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–32/b"},"text":"section 300x–32(b) of this title","children":[],"tail":" and for planning, carrying out, and evaluating activities to prevent, treat, and provide recovery support services for substance use disorders and for related activities authorized in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–24"},"text":"section 300x–24 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6695372-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIX, § 1921, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tII/s202"},"text":"Pub. L. 102–321, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/388"},"text":"106 Stat. 388","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tVIII/s8002/a"},"text":"Pub. L. 114–255, div. B, title VIII, § 8002(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1229"},"text":"130 Stat. 1229","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tI/s1242"},"text":"Pub. L. 117–328, div. FF, title I, § 1242","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5678"},"text":"136 Stat. 5678","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6695373-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6695374-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb6695375-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1921 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–9"},"text":"section 300x–9 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 1921 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300y"},"text":"section 300y of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6695376-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" substituted “activities to prevent, treat, and provide recovery support services for substance use disorders” for “activities to prevent and treat substance use disorders”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255"},"text":"Pub. L. 114–255","c