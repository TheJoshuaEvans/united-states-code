{"tag":"section","attrib":{"id":"idbf852ca5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12634"},"text":null,"children":[{"tag":"num","attrib":{"value":"12634"},"text":"§ 12634.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on use of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf852ca6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12634/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited uses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No assistance made available under a grant under this subchapter shall be used to provide religious instruction, conduct worship services, or engage in any form of proselytization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf852ca7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12634/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Political activity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Assistance provided under this subchapter shall not be used by program participants and program staff to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf852ca8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12634/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist, promote, or deter union organizing; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf852ca9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12634/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" finance, directly or indirectly, any activity designed to influence the outcome of an election to Federal office or the outcome of an election to a State or local public office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf852caa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12634/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts or collective bargaining agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A program that receives assistance under this subchapter shall not impair existing contracts for services or collective bargaining agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf852cab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12634/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referrals for Federal assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A program may not receive assistance under the national service laws for the sole purpose of referring individuals to Federal assistance programs or State assistance programs funded in part by the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf852cac-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s174"},"text":"Pub. L. 101–610, title I, § 174","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3160"},"text":"104 Stat. 3160","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1603"},"text":"Pub. L. 111–13, title I, § 1603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1529"},"text":"123 Stat. 1529","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf852cad-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf852cae-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf852caf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13"},"text":"Pub. L. 111–13","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf852cb0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf852cb1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13"},"text":"Pub. L. 111–13","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s6101/a"},"text":"section 6101(a) of Pub. L. 111–13","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
