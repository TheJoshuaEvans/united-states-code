{"tag":"section","attrib":{"id":"idbc7973e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3221"},"text":null,"children":[{"tag":"num","attrib":{"value":"3221"},"text":"§ 3221.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Brownfields redevelopment report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc7973e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3221/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of brownfield site","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “brownfield site” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9601/39"},"text":"section 9601(39) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc7973e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3221/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc7973e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3221/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2004-10-27"},"text":"October 27, 2004","children":[],"tail":", the Comptroller General shall prepare a report that evaluates the grants made by the Economic Development Administration for the economic development of brownfield sites."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7973e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3221/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc7973e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3221/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify each project conducted during the previous 10-year period in which grant funds have been used for brownfield sites redevelopment activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc7973e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3221/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include for each project a description of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc7973e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3221/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type of economic development activities conducted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc7973ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3221/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if remediation activities were conducted—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbc7973eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3221/b/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type of remediation activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbc7973ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3221/b/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of grant money used for those activities in dollars and as a percentage of the total grant award;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc7973ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3221/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the economic development and environmental standards applied, if applicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc7973ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3221/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the economic development impact of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc7973ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3221/b/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the role of Federal, State, or local environmental agencies, if any; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc7973f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3221/b/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public participation in the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7973f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3221/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller General shall submit to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a copy of the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc7973f2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tVI/s611"},"text":"Pub. L. 89–136, title VI, § 611","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/373/tVI/s603/a"},"text":"Pub. L. 108–373, title VI, § 603(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-27"},"text":"Oct. 27, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1769"},"text":"118 Stat. 1769","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc7973f3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc7973f4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc7973f5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3221, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tVII/s711"},"text":"Pub. L. 89–136, title VII, § 711","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-08-26"},"text":"Aug. 26, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/574"},"text":"79 Stat. 574","children":[],"tail":", related to employment of expediters and administrative employees, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/tI/s102/b/3"},"text":"Pub. L. 105–393, title I, § 102(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3617"},"text":"112 Stat. 3617","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
