{"tag":"section","attrib":{"id":"idb5011137-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"256a–1"},"text":"§ 256a–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishing community health teams to support the patient-centered medical home","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5011138-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Health and Human Services (referred to in this section as the “Secretary”) shall establish a program to provide grants to or enter into contracts with eligible entities to establish community-based interdisciplinary, interprofessional teams (referred to in this section as “health teams”) to support primary care practices, including obstetrics and gynecology practices, within the hospital service areas served by the eligible entities. Grants or contracts shall be used to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5011139-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish health teams to provide support services to primary care providers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb501113a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide capitated payments to primary care providers as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb501113b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant or contract under subsection (a), an entity shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb501113c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb501113d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a State or State-designated entity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb501113e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be an Indian tribe or tribal organization, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1603"},"text":"section 1603 of title 25","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb501113f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit a plan for achieving long-term financial sustainability within 3 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5011140-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit a plan for incorporating prevention initiatives and patient education and care management resources into the delivery of health care that is integrated with community-based prevention and treatment resources, where available;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5011141-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the health team established by the entity includes an interdisciplinary, interprofessional team of health care providers, as determined by the Secretary; such team may include medical specialists, nurses, pharmacists, nutritionists, dieticians, social workers, behavioral and mental health providers (including substance use disorder prevention and treatment providers), doctors of chiropractic, licensed complementary and alternative medicine practitioners, and physicians’ assistants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5011142-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agree to provide services to eligible individuals with chronic conditions, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396w–4"},"text":"section 1396w–4 of this title","children":[],"tail":" (as added by section 2703), in accordance with the payment methodology established under subsection (c) of such section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5011143-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5011144-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for health teams","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A health team established pursuant to a grant or contract under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5011145-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish contractual agreements with primary care providers to provide support services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5011146-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" support patient-centered medical homes, defined as a mode of care that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5011147-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personal physicians or other primary care providers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5011148-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whole person orientation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5011149-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinated and integrated care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb501114a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" safe and high-quality care through evidence-informed medicine, appropriate use of health information technology, and continuous quality improvements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb501114b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expanded access to care; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb501114c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment that recognizes added value from additional components of patient-centered care;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb501114d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborate with local primary care providers and existing State and community based resources to coordinate disease prevention, chronic disease management, transitioning between health care providers and settings and case management for patients, including children, with priority given to those amenable to prevention and with chronic diseases or conditions identified by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb501114e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in collaboration with local health care providers, develop and implement interdisciplinary, interprofessional care plans that integrate clinical and community preventive and health promotion services for patients, including children, with a priority given to those amenable to prevention and with chronic diseases or conditions identified by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb501114f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporate health care providers, patients, caregivers, and authorized representatives in program design and oversight;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5011150-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide support necessary for local primary care providers to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5011151-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate and provide access to high-quality health care services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5011152-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate and provide access to preventive and health promotion services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5011153-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/c/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide access to appropriate specialty care and inpatient services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5011154-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/c/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide quality-driven, cost-effective, culturally appropriate, and patient- and family-centered health care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5011155-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/c/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide access to pharmacist-delivered medication management services, including medication reconciliation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5011156-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/c/6/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide coordination of the appropriate use of complementary and alternative (CAM) services to those who request such services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5011157-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/c/6/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote effective strategies for treatment planning, monitoring health outcomes and resource use, sharing information, treatment decision support, and organizing care to avoid duplication of service and other medical management approaches intended to improve quality and value of health care services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5011158-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/c/6/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide local access to the continuum of health care services in the most appropriate setting, including access to individuals that implement the care plans of patients and coordinate care, such as integrative health care practitioners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5011159-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/c/6/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect and report data that permits evaluation of the success of the collaborative effort on patient outcomes, including collection of data on patient experience of care, and identification of areas for improvement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb501115a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/c/6/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a coordinated system of early identification and referral for children at risk for developmental or behavioral problems such as through the use of infolines, health information technology, or other means as determined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb501115b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide 24-hour care management and support during transitions in care settings including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb501115c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/c/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a transitional care program that provides onsite visits from the care coordinator,","children":[{"tag":"ref","attrib":{"idref":"fn002095"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002095"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should be “and”."}],"tail":" assists with the development of discharge plans and medication reconciliation upon admission to and discharge from the hospitals,"},{"tag":"ref","attrib":{"idref":"fn002096"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002096"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “hospital,”."}],"tail":" nursing home, or other institution setting;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb501115d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/c/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discharge planning and counseling support to providers, patients, caregivers, and authorized representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb501115e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/c/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assuring that post-discharge care plans include medication management, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb501115f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/c/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" referrals for mental and behavioral health services, which may include the use of infolines; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5011160-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/c/7/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transitional health care needs from adolescence to adulthood;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5011161-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as a liaison to community prevention and treatment programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5011162-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate a capacity to implement and maintain health information technology that meets the requirements of certified EHR technology (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300jj"},"text":"section 300jj of this title","children":[],"tail":") to facilitate coordination among members of the applicable care team and affiliated primary care practices; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5038163-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where applicable, report to the Secretary information on quality measures used under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s280j–2"},"text":"section 280j–2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5038164-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement for primary care providers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A provider who contracts with a care team shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5038165-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a care plan to the care team for each patient participant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5038166-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide access to participant health records; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5038167-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet regularly with the care team to ensure integration of care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5038168-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting to Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An entity that receives a grant or contract under subsection (a) shall submit to the Secretary a report that describes and evaluates, as requested by the Secretary, the activities carried out by the entity under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5038169-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256a–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of primary care","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “primary care” means the provision of integrated, accessible health care services by clinicians who are accountable for addressing a large majority of personal health care needs, developing a sustained partnership with patients, and practicing in the context of family and community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb503816a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIII/s3502"},"text":"Pub. L. 111–148, title III, § 3502","children":[],"tail":", title X, § 10321, "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/513"},"text":"124 Stat. 513","children":[],"tail":", 952.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb503816b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb503816c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb503816d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 2703, referred to in subsec. (b)(5), means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s2703"},"text":"section 2703 of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb503816e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Patient Protection and Affordable Care Act, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb503816f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10321"},"text":"Pub. L. 111–148, § 10321","children":[],"tail":", inserted “or other primary care providers” after “physicians”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
