{"tag":"section","attrib":{"id":"idc07866dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19084"},"text":null,"children":[{"tag":"num","attrib":{"value":"19084"},"text":"§ 19084.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced computing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc07866dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19084/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computing needs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To gather information about the computational needs of Foundation-funded projects, the Director shall require award proposals submitted to the Foundation, as appropriate, to include estimates of computational resource needs for projects that require use of advanced computing. The Director shall encourage and provide access to tools that facilitate the inclusion of these measures, including those identified in the 2016 National Academies report entitled “Future Directions for NSF Advanced Computing Infrastructure to Support U.S. Science and Engineering in 2017–2020”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07866de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19084/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall document and publish every two years a summary of the amount and types of advanced computing capabilities that are needed to fully meet the Foundation’s project needs as identified under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07866df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19084/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Roadmap","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To set priorities and guide strategic decisions regarding investments in advanced computing capabilities, the Director shall develop, publish, and regularly update a 5-year advanced computing roadmap that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc07866e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19084/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the advanced computing resources and capabilities that would fully meet anticipated project needs, including through investments in the Mid-Scale Research Infrastructure program and the Major Research Equipment and Facilities Construction account;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07866e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19084/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" draws on community input, information contained in research proposals, allocation requests, insights from Foundation-funded cyber-infrastructure operators, and Foundation-wide information gathering regarding community needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07866e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19084/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considers computational needs of planned major facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07866e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19084/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reflects anticipated technology trends;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07866e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19084/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" informs users and potential partners about future facilities and services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07866e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19084/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" addresses the needs of groups historically underrepresented in STEM and geographic regions with low availability and high demand for advanced computing resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07866e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19084/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considers how Foundation-supported advanced computing capabilities can be leveraged for activities through the Directorate for Technology, Innovation, and Partnerships; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07866e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19084/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides an update to Congress about the level of funding necessary to fully meet computational resource needs for the research community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07866e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19084/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Securing American research from cyber theft","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc07866e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19084/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07866ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19084/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computing enclave pilot program","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc07866eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19084/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director, in consultation with the Director of the National Institute of Standards and Technology and the Secretary of Energy, and the heads of other relevant Federal departments and agencies, shall establish a pilot program to make awards to ensure the security of federally supported research data and to assist regional institutions of higher education and their researchers in compliance with regulations regarding the safeguarding of sensitive information and other relevant regulations and Federal guidelines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc07ad6ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19084/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Structure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the pilot program established pursuant to subparagraph (A), the Director shall select, for the development, installation, maintenance, or sustainment of secure computing enclaves, three institutions of higher education that have an established graduate student program and a demonstrated history of working with secure information, consistent with appropriate security protocols.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc07ad6ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19084/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regionalization","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc07ad6ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19084/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In selecting universities pursuant to subparagraph (B), the Director shall give preference to institutions of higher education with the capability of serving other regional universities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc07ad6ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19084/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographic dispersal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The enclaves should be geographically dispersed to better meet the needs of regional interests.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc07ad6f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19084/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall work with institutions of higher education selected pursuant to subparagraph (B) to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc07ad6f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19084/d/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop an approved design blueprint for compliance with Federal data protection protocols;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc07ad6f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19084/d/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a comprehensive and confidential list, or a bill of materials, of each binary component of the software, firmware, or product that is required to deploy additional secure computing enclaves;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc07ad6f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19084/d/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop templates for all policies and procedures required to operate the secure computing enclave in a research setting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc07ad6f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19084/d/2/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a system security plan template; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc07ad6f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19084/d/2/D/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a process for managing a plan of action and milestones for the secure computing enclave.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc07ad6f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19084/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sustainability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In reviewing applications for awards, the Director shall review and consider plans and prospects of the applicant institution of higher education to ensure long-term sustainability of the computing enclave, beyond the availability of Federal funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc07ad6f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19084/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to other availability of appropriations, the pilot program established pursuant to subparagraph (A) shall operate for not less than 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc07ad6f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19084/d/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc07ad6f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19084/d/2/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall report to Congress not later than 6 months after the completion of the pilot program under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc07ad6fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19084/d/2/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report required under clause (i) shall include—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc07ad6fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19084/d/2/G/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the pilot program under subparagraph (A), including an assessment of the security benefits provided by such secure computing enclaves;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc07ad6fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19084/d/2/G/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations related to the value of expanding the network of secure computing enclaves; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc07ad6fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19084/d/2/G/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations on the efficacy of the use of secure computing enclaves by other Federal agencies in a broader effort to expand security of Federal research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc07ad6fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19084/d/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Director, $38,000,000 for fiscal years 2023 through 2025, to carry out the activities outlined in this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc07ad6ff-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tIII/s10374"},"text":"Pub. L. 117–167, div. B, title III, § 10374","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1571"},"text":"136 Stat. 1571","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc07ad700-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc07ad701-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc07ad702-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10374"},"text":"section 10374 of Pub. L. 117–167","children":[],"tail":". Subsec. (d)(1) of "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10374"},"text":"section 10374 of Pub. L. 117–167","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s5511"},"text":"section 5511 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
