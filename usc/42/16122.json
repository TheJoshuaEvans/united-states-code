{"tag":"section","attrib":{"id":"idbff2e356-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122"},"text":null,"children":[{"tag":"num","attrib":{"value":"16122"},"text":"§ 16122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal and State procurement of fuel cell vehicles and hydrogen energy systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbff2e357-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this section are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff2e358-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to stimulate acceptance by the market of fuel cell vehicles and hydrogen energy systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e359-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support development of technologies relating to fuel cell vehicles, public refueling stations, and hydrogen energy systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e35a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to require the Federal government, ","children":[{"tag":"ref","attrib":{"idref":"fn004209"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004209"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" which is the largest single user of energy in the United States, to adopt those technologies as soon as practicable after the technologies are developed, in conjunction with private industry partners."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff2e35b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal leases and purchases","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff2e35c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff2e35d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2010-01-01"},"text":"January 1, 2010","children":[],"tail":", the head of any Federal agency that uses a light-duty or heavy-duty vehicle fleet shall lease or purchase fuel cell vehicles and hydrogen energy systems to meet any applicable energy savings goal described in subsection (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e35e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Learning demonstration vehicles","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may lease or purchase appropriate vehicles developed under subsections (a)(10) and (b)(1)(A) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16157"},"text":"section 16157 of this title","children":[],"tail":" to meet the requirement in subparagraph (A)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e35f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs of leases and purchases","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff2e360-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in cooperation with the Task Force and the Technical Advisory Committee, shall pay to Federal agencies (or share the cost under interagency agreements) the difference in cost between—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff2e361-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost to the agencies of leasing or purchasing fuel cell vehicles and hydrogen energy systems under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e362-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost to the agencies of a feasible alternative to leasing or purchasing fuel cell vehicles and hydrogen energy systems, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e363-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive costs and management structures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subparagraph (A), the Secretary, in consultation with the agency, may use the General Services Administration or any commercial vendor to ensure—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff2e364-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a cost-effective purchase of a fuel cell vehicle or hydrogen energy system; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e365-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a cost-effective management structure of the lease of a fuel cell vehicle or hydrogen energy system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e366-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff2e367-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines that the head of an agency described in paragraph (1) cannot find an appropriately efficient and reliable fuel cell vehicle or hydrogen energy system in accordance with paragraph (1), that agency shall be excepted from compliance with paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e368-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making a determination under subparagraph (A), the Secretary shall consider—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff2e369-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the needs of the agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e36a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an evaluation performed by—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbff2e36b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/b/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Task Force; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbff2e36c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/b/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Technical Advisory Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff2e36d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy savings goals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff2e36e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff2e36f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2006-12-31"},"text":"December 31, 2006","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"clause","attrib":{"id":"idbff2e370-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in cooperation with the Task Force, promulgate regulations for the period of 2008 through 2010 that extend and augment energy savings goals for each Federal agency, in accordance with any Executive order issued after March 2000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e371-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promulgate regulations to expand the minimum Federal fleet requirement and credit allowances for fuel cell vehicle systems under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13212"},"text":"section 13212 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e372-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review, evaluation, and new regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2010-12-31"},"text":"December 31, 2010","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"clause","attrib":{"id":"idbff2e373-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the regulations promulgated under subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e374-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate any progress made toward achieving energy savings by Federal agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e375-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promulgate new regulations for the period of 2011 through 2015 to achieve additional energy savings by Federal agencies relating to technical and cost-performance standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e376-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offsetting energy savings goals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An agency that leases or purchases a fuel cell vehicle or hydrogen energy system in accordance with subsection (b)(1) may use that lease or purchase to count toward an energy savings goal of the agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff2e377-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative program with State agencies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff2e378-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may establish a cooperative program with State agencies managing motor vehicle fleets to encourage purchase of fuel cell vehicles by the agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e379-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incentives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the cooperative program, the Secretary may offer incentive payments to a State agency to assist with the cost of planning, differential purchases, and administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff2e37a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is authorized to be appropriated to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff2e37b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $15,000,000 for fiscal year 2008;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e37c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $25,000,000 for fiscal year 2009;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e37d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $65,000,000 for fiscal year 2010; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e37e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16122/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as are necessary for each of fiscal years 2011 through 2015.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff2e37f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVII/s782"},"text":"Pub. L. 109–58, title VII, § 782","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/835"},"text":"119 Stat. 835","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
