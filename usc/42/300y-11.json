3/tXIX"},"text":"act July 1, 1944, ch. 373, title XIX","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIX/s901"},"text":"Pub. L. 97–35, title IX, § 901","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/559"},"text":"95 Stat. 559","children":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1983-01-04"},"text":"Jan. 4, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/97/414/s8/v"},"text":"Pub. L. 97–414, § 8(v)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2063"},"text":"96 Stat. 2063","children":[],"tail":", related to applicability of other provisions and promulgation of regulations and was classified to former "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300y–11"},"text":"section 300y–11 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/280/s5"},"text":"Pub. L. 99–280, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-04-24"},"text":"Apr. 24, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/400"},"text":"100 Stat. 400","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 300y–23, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tXIX/s1933"},"text":"act July 1, 1944, ch. 373, title XIX, § 1933","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tIV/s408/a"},"text":"Pub. L. 100–607, title IV, § 408(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3117"},"text":"102 Stat. 3117","children":[],"tail":", provided for allotments under this part."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 300y–24, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tX