{"tag":"section","attrib":{"id":"idbf42578b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a"},"text":null,"children":[{"tag":"num","attrib":{"value":"11360a"},"text":"§ 11360a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaborative applicants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf42578c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and designation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A collaborative applicant shall be established for a geographic area by the relevant parties in that geographic area to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf42578d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit an application for amounts under this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf42578e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform the duties specified in subsection (f) and, if applicable, subsection (g).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf42578f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No requirement to be a legal entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An entity may be established to serve as a collaborative applicant under this section without being a legal entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf425790-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remedial action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary finds that a collaborative applicant for a geographic area does not meet the requirements of this section, or if there is no collaborative applicant for a geographic area, the Secretary may take remedial action to ensure fair distribution of grant amounts under part C to eligible entities within that area. Such measures may include designating another body as a collaborative applicant, or permitting other eligible entities to apply directly for grants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf425791-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to displace conflict of interest or government fair practices laws, or their equivalent, that govern applicants for grant amounts under parts B and C.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf425792-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of agent","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf425793-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), a collaborative applicant may designate an agent to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf425794-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apply for a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11382/c"},"text":"section 11382(c) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf425795-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive and distribute grant funds awarded under part C; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf425796-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform other administrative duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf425797-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retention of duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any collaborative applicant that designates an agent pursuant to paragraph (1) shall regardless of such designation retain all of its duties and responsibilities under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf425798-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A collaborative applicant shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf425799-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" design a collaborative process for the development of an application under part C, and for evaluating the outcomes of projects for which funds are awarded under part B, in such a manner as to provide information necessary for the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf42579a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to determine compliance with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf42579b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/f/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the program requirements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11386"},"text":"section 11386 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf42579c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/f/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the selection criteria described under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11386a"},"text":"section 11386a of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf42579d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish priorities for funding projects in the geographic area involved;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf42579e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participate in the Consolidated Plan for the geographic area served by the collaborative applicant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf42579f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure operation of, and consistent participation by, project sponsors in a community-wide homeless management information system (in this subsection referred to as “HMIS”) that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf4257a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collects unduplicated counts of individuals and families experiencing homelessness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf4257a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyzes patterns of use of assistance provided under parts B and C for the geographic area involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf4257a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides information to project sponsors and applicants for needs analyses and funding priorities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf4257a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/f/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is developed in accordance with standards established by the Secretary, including standards that provide for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf4257a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/f/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encryption of data collected for purposes of HMIS;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf4257a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/f/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" documentation, including keeping an accurate accounting, proper usage, and disclosure, of HMIS data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf4257a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/f/3/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access to HMIS data by staff, contractors, law enforcement, and academic researchers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf4257a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/f/3/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rights of persons receiving services under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf4257a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/f/3/D/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" criminal and civil penalties for unlawful disclosure of data; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf4257a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/f/3/D/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other standards as may be determined necessary by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf4257aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unified funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf4257ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the duties described in subsection (f), a collaborative applicant shall receive from the Secretary and distribute to other project sponsors in the applicable geographic area funds for projects to be carried out by such other project sponsors, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf4257ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the collaborative applicant—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf4257ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/g/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applies to undertake such collection and distribution responsibilities in an application submitted under this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf4257ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/g/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is selected to perform such responsibilities by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf4257af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary designates the collaborative applicant as the unified funding agency in the geographic area, after—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf4257b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/g/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a finding by the Secretary that the applicant—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbf4257b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/g/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the capacity to perform such responsibilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf4257b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/g/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would serve the purposes of this chapter as they apply to the geographic area; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf4257b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/g/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary provides the collaborative applicant with the technical assistance necessary to perform such responsibilities as such assistance is agreed to by the collaborative applicant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf4257b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required actions by a unified funding agency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A collaborative applicant that is either selected or designated as a unified funding agency for a geographic area under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf4257b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require each project sponsor who is funded by a grant received under part C to establish such fiscal control and fund accounting procedures as may be necessary to assure the proper disbursal of, and accounting for, Federal funds awarded to the project sponsor under part C in order to ensure that all financial transactions carried out under part C are conducted, and records maintained, in accordance with generally accepted accounting principles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf4257b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arrange for an annual survey, audit, or evaluation of the financial records of each project carried out by a project sponsor funded by a grant received under part C.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf4257b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11360a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflict of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No board member of a collaborative applicant may participate in decisions of the collaborative applicant concerning the award of a grant, or provision of other financial benefits, to such member or the organization that such member represents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf4257b8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77/tIV/s402"},"text":"Pub. L. 100–77, title IV, § 402","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/22/dB/tI/s1102"},"text":"Pub. L. 111–22, div. B, title I, § 1102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-20"},"text":"May 20, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1674"},"text":"123 Stat. 1674","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf4257b9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf4257ba-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf4257bb-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (g)(1)(B)(i)(II), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77"},"text":"Pub. L. 100–77","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-07-22"},"text":"July 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/482"},"text":"101 Stat. 482","children":[],"tail":", known as the McKinney-Vento Homeless Assistance Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11301"},"text":"section 11301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf4257bc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77/s402"},"text":"section 402 of Pub. L. 100–77","children":[],"tail":" was renumbered section 406 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11362"},"text":"section 11362 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf4257bd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf4257be-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the earlier of 18 months after ","children":[{"tag":"date","attrib":{"date":"2009-05-20"},"text":"May 20, 2009","children":[],"tail":", or 3 months after publication of certain final regulations by Secretary of Housing and Urban Development, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/22/s1503"},"text":"section 1503 of Pub. L. 111–22","children":[],"tail":", set out as an Effective Date of 2009 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11302"},"text":"section 11302 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
