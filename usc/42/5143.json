{"tag":"section","attrib":{"id":"idbd0f9972-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5143"},"text":null,"children":[{"tag":"num","attrib":{"value":"5143"},"text":"§ 5143.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordinating officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd0f9973-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5143/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of Federal coordinating officer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Immediately upon his declaration of a major disaster or emergency, the President shall appoint a Federal coordinating officer to operate in the affected area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0f9974-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5143/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of Federal coordinating officer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to effectuate the purposes of this chapter, the Federal coordinating officer, within the affected area, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd0f9975-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5143/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make an initial appraisal of the types of relief most urgently needed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0f9976-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5143/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish such field offices as he deems necessary and as are authorized by the President;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0f9977-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5143/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate the administration of relief, including activities of the State and local governments, the American National Red Cross, the Salvation Army, the Mennonite Disaster Service, and other relief or disaster assistance organizations, which agree to operate under his advice or direction, except that nothing contained in this chapter shall limit or in any way affect the responsibilities of the American National Red Cross under chapter 3001 of title 36; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0f9978-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5143/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take such other action, consistent with authority delegated to him by the President, and consistent with the provisions of this chapter, as he may deem necessary to assist local citizens and public officials in promptly obtaining assistance to which they are entitled.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0f9979-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5143/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State coordinating officer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When the President determines assistance under this chapter is necessary, he shall request that the Governor of the affected State designate a State coordinating officer for the purpose of coordinating State and local disaster assistance efforts with those of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0f997a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5143/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Single Federal coordinating officer for multistate area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Where the area affected by a major disaster or emergency includes parts of more than 1 State, the President, at the discretion of the President, may appoint a single Federal coordinating officer for the entire affected area, and may appoint such deputy Federal coordinating officers to assist the Federal coordinating officer as the President determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd0f997b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tIII/s302"},"text":"Pub. L. 93–288, title III, § 302","children":[],"tail":", formerly § 303, "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/147"},"text":"88 Stat. 147","children":[],"tail":"; renumbered § 302 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/707/tI/s105/b"},"text":"Pub. L. 100–707, title I, § 105(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4691"},"text":"102 Stat. 4691","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s687"},"text":"Pub. L. 109–295, title VI, § 687","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1448"},"text":"120 Stat. 1448","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd0f997c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd0f997d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd0f997e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (b) and (c), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288"},"text":"Pub. L. 93–288","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/143"},"text":"88 Stat. 143","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbd0f997f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (b)(3), “chapter 3001 of title 36” substituted for “the Act of ","children":[{"tag":"date","attrib":{"date":"1905-01-05"},"text":"January 5, 1905","children":[],"tail":", as amended ("},{"tag":"ref","attrib":{"href":"/us/stat/33/599"},"text":"33 Stat. 599","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/105/225/s5/b"},"text":"Pub. L. 105–225, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1499"},"text":"112 Stat. 1499","children":[],"tail":", the first section of which enacted Title 36, Patriotic and National Observances, Ceremonies, and Organizations."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbd0f9980-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/s302"},"text":"section 302 of Pub. L. 93–288","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5142"},"text":"section 5142 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/100/707"},"text":"Pub. L. 100–707","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd0f9981-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295"},"text":"Pub. L. 109–295","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/707"},"text":"Pub. L. 100–707","children":[],"tail":" inserted “or emergency” after “major disaster”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
