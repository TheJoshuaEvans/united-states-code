{"tag":"section","attrib":{"id":"idb7a88b10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629l"},"text":null,"children":[{"tag":"num","attrib":{"value":"629l"},"text":"§ 629l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public access to State plans","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7aafb11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629l/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" create a standardized format for State plans required under sections 622 and 629b of this title used to monitor compliance with those sections;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7aafb12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629l/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produce comparisons and analyses of trends in State plans to inform future technical assistance and policy development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7aafb13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629l/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make the State plans available on a public website; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7aafb14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629l/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include on the website aggregated national summaries of State submissions as the Secretary deems appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sou