{"tag":"section","attrib":{"id":"idbaa85d47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1397d"},"text":"§ 1397d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on use of grants; waiver","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbaa85d48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subsection (b), grants made under this division may not be used by the State, or by any other person with which the State makes arrangements to carry out the purposes of this division—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaa85d49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the purchase or improvement of land, or the purchase, construction, or permanent improvement (other than minor remodeling) of any building or other facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaa85d4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the provision of cash payments for costs of subsistence or for the provision of room and board (other than costs of subsistence during rehabilitation, room and board provided for a short term as an integral but subordinate part of a social service, or temporary emergency shelter provided as a protective service);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaa85d4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397d/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for payment of the wages of any individual as a social service (other than payment of the wages of welfare recipients employed in the provision of child day care services);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaa85d4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397d/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the provision of medical care (other than family planning services, rehabilitation services, or initial detoxification of an alcoholic or drug dependent individual) unless it is an integral but subordinate part of a social service for which grants may be used under this division;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaa85d4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397d/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for social services (except services to an alcoholic or drug dependent individual or rehabilitation services) provided in and by employees of any hospital, skilled nursing facility, intermediate care facility, or prison, to any individual living in such institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaa85d4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397d/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the provision of any educational service which the State makes generally available to its residents without cost and without regard to their income;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaa85d4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397d/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any child day care services unless such services meet applicable standards of State and local law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaa85d50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397d/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the provision of cash payments as a service (except as otherwise provided in this section);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaa85d51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397d/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for payment for any item or service (other than an emergency item or service) furnished—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaa85d52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397d/a/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by an individual or entity during the period when such individual or entity is excluded under this division or subchapter V, XVIII, or XIX pursuant to section 1320a–7, 1320a–7a, 1320c–5, or 1395u(j)(2) of this title, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaa85d53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397d/a/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the medical direction or on the prescription of a physician during the period when the physician is excluded under this division or subchapter V, XVIII, or XIX pursuant to section 1320a–7, 1320a–7a, 1320c–5, or 1395u(j)(2) of this title and when the person furnishing such item or service knew or had reason to know of the exclusion (after a reasonable time period after reasonable notice has been furnished to the person); or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaa85d54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397d/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a manner inconsistent with the Assisted Suicide Funding Restriction Act of 1997 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14401"},"text":"42 U.S.C. 14401","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaa85d55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may waive the limitation contained in subsection (a)(1) and (4) upon the State’s request for such a waiver if he finds that the request describes extraordinary circumstances to justify the waiver and that permitting the waiver will contribute to the State’s ability to carry out the purposes of this division.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbaa85d56-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XX, § 2005, as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXIII/s2352/a"},"text":"Pub. L. 97–35, title XXIII, § 2352(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/869"},"text