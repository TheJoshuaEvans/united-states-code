"tag":"ref","attrib":{"href":"/us/pl/100/360/s411"},"text":"section 411 of Pub. L. 100–360","children":[],"tail":", amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/100/360"},"text":"Pub. L. 100–360","children":[],"tail":", as it relates to a provision in the Omnibus Budget Reconciliation Act of 1987, "},{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":", effective as if included in the enactment of that provision in "},{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/360/s411/a"},"text":"section 411(a) of Pub. L. 100–360","children":[],"tail":", set out as a Reference to OBRA; Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t1/s106"},"text":"section 106 of Title 1","children":[],"tail":", General Provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbaa85d5f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1987 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/93"},"text":"Pub. L. 100–93","children":[],"tail":" effective at end of fourteen-day period beginning "},{"tag":"date","attrib":{"date":"1987-08-18"},"text":"Aug. 18, 1987","children":[],"tail":", and inapplicable to administrative proceedings commenced before end of such period, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/93/s15/a"},"text":"section 15(a) of Pub. L. 100–93","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7"},"text":"section 1320a–7 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
