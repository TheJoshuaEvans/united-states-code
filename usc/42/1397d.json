. 2347","children":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1980-06-17"},"text":"June 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/96/272/tII/s206/d"},"text":"Pub. L. 96–272, title II, § 206(d)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/525"},"text":"94 Stat. 525","children":[],"tail":", related to effective date of implementing regulations, prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s2352/a"},"text":"section 2352(a) of Pub. L. 97–35","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbaa85d5b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":", which directed substitution of “this division” for “this subchapter” wherever appearing in subtitle 1 of title XX of act "},{"tag":"date","attrib":{"date":"1935-08-14"},"text":"Aug. 14, 1935","children":[],"tail":", was executed by making the substitution wherever appearing in this section, which is in subtitle A of title XX act "},{"tag":"date","attrib":{"date":"1935-08-14"},"text":"Aug. 14, 1935","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a)(10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/12"},"text":"Pub. L. 105–12","children":[],"tail":" added par. (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(9)(A), (B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/360/s411/k/10/D"},"text":"Pub. L. 100–360, § 411(k)(10)(D)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/485/s608/d/26/K/ii"},"text":"Pub. L. 100–485, § 608(d)(26)(K)(ii)","children":[],"tail":", added "},