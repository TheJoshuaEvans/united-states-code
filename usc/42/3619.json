{"tag":"section","attrib":{"id":"idbc95fc84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3619"},"text":null,"children":[{"tag":"num","attrib":{"value":"3619"},"text":"§ 3619.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any provision of this subchapter or the application thereof to any person or circumstances is held invalid, the remainder of the subchapter and the application of the provision to other persons not similarly situated or to other circumstances shall not be affected thereby.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc986c85-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/284/tVIII/s820"},"text":"Pub. L. 90–284, title VIII, § 820","children":[],"tail":", formerly § 819, "},{"tag":"date","attrib":{"date":"1968-04-11"},"text":"Apr. 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/89"},"text":"82 Stat. 89","children":[],"tail":"; renumbered § 820, "},{"tag":"ref","attrib":{"href":"/us/pl/100/430/s8/1"},"text":"Pub. L. 100–430, § 8(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-13"},"text":"Sept. 13, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1625"},"text":"102 Stat. 1625","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
