{"tag":"section","attrib":{"id":"idbd6caca4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6107"},"text":null,"children":[{"tag":"num","attrib":{"value":"6107"},"text":"§ 6107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd6caca5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6107/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Commission” means the Commission on Civil Rights;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd6caca6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6107/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Secretary” means the Secretary of Health and Human Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd6caca7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6107/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Federal department or agency” means any agency as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s551"},"text":"section 551 of title 5","children":[],"tail":" and includes the United States Postal Service and the Postal Regulatory Commission; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd6caca8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6107/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “program or activity” means all of the operations of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd6caca9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6107/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd6cacaa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6107/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a department, agency, special purpose district, or other instrumentality of a State or of a local government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd6cacab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6107/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entity of such State or local government that distributes such assistance and each such department or agency (and each other State or local government entity) to which the assistance is extended, in the case of assistance to a State or local government;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6cacac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6107/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd6cacad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6107/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a college, university, or other postsecondary institution, or a public system of higher education; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd6cacae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6107/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a local educational agency (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":"), system of vocational education, or other school system;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6cacaf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6107/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd6cacb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6107/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an entire corporation, partnership, or other private organization, or an entire sole proprietorship—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbd6cacb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6107/4/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if assistance is extended to such corporation, partnership, private organization, or sole proprietorship as a whole; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd6cacb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6107/4/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is principally engaged in the business of providing education, health care, housing, social services, or parks and recreation; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd6cacb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6107/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entire plant or other comparable, geographically separate facility to which Federal financial assistance is extended, in the case of any other corporation, partnership, private organization, or sole proprietorship; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6cacb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6107/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other entity which is established by two or more of the entities described in subparagraph (A), (B), or (C);","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"any part of which is extended Federal financial assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd6cacb5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/135/tIII/s309"},"text":"Pub. L. 94–135, title III, § 309","children":[],"tail":", formerly § 308, "},{"tag":"date","attrib":{"date":"1975-11-28"},"text":"Nov. 28, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/731"},"text":"89 Stat. 731","children":[],"tail":"; renumbered § 309, "},{"tag":"ref","attrib":{"href":"/us/pl/95/478/tIV/s401/e"},"text":"Pub. L. 95–478, title IV, § 401(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-18"},"text":"Oct. 18, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1556"},"text":"92 Stat. 1556","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tV/s509/b"},"text":"Pub. L. 96–88, title V, § 509(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/695"},"text":"93 Stat. 695","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us