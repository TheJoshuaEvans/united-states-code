{"tag":"section","attrib":{"id":"idbfc0d70e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13432"},"text":null,"children":[{"tag":"num","attrib":{"value":"13432"},"text":"§ 13432.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced automotive fuel economy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfc0d70f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13432/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program direction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct a program, in accordance with sections 13541 and 13542 of this title, to supplement ongoing research activities of a similar nature at the Department of Energy, to accelerate the near-term and mid-term development of advanced technologies to improve the fuel economy of light-duty passenger vehicles powered by a piston engine, and hybrid vehicles powered by a combination of piston engine and electric motor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc0d710-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13432/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program goal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The goal of the program established under subsection (a) shall be to stimulate the development of emerging technologies with the potential to achieve significant improvements in fuel economy while reducing emissions of air pollutants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc0d711-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13432/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 1 year after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the Secretary shall solicit proposals for conducting activities under this section, making a special effort to involve small businesses in the program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfc0d712-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXX/s2022"},"text":"Pub. L. 102–486, title XX, § 2022","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3061"},"text":"106 Stat. 3061","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
