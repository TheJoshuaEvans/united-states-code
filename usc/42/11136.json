{"tag":"section","attrib":{"id":"idbf38e25f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11136"},"text":null,"children":[{"tag":"num","attrib":{"value":"11136"},"text":"§ 11136.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure and correction of information","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"With respect to the information reported to the Secretary (or the agency designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11134/b"},"text":"section 11134(b) of this title","children":[],"tail":") under this subchapter respecting a physician or other licensed health care practitioner, the Secretary shall, by regulation, provide for—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf38e260-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11136/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disclosure of the information, upon request, to the physician or practitioner, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf38e261-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11136/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures in the case of disputed accuracy of the information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf38e262-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/660/tIV/s426"},"text":"Pub. L. 99–660, title IV, § 426","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3791"},"text":"100 Stat. 3791","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
