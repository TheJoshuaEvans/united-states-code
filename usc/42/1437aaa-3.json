{"tag":"section","attrib":{"id":"idbb0c9d9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"1437aaa–3"},"text":"§ 1437aaa–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Homeownership program requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb0c9d9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A homeownership program under this subchapter shall provide for acquisition by eligible families of ownership interests in, or shares representing, at least one-half of the units in a public housing project under any arrangement determined by the Secretary to be appropriate, such as cooperative ownership (including limited equity cooperative ownership) and fee simple ownership (including condominium ownership), for occupancy by the eligible families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb0c9d9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affordability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A homeownership program under this subchapter shall provide for the establishment of sales prices (including principal, insurance, taxes, and interest and closing costs) for initial acquisition of the property from the public housing agency if the applicant is not a public housing agency, and for sales to eligible families, such that an eligible family shall not be required to expend more than 30 percent of the adjusted income of the family per month to complete a sale under the homeownership program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb0c9d9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A homeownership program under this subchapter shall provide, and include a plan, for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb0c9d9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–3/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying and selecting eligible families to participate in the homeownership program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0c9da0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–3/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing relocation assistance to families who elect to move;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0c9da1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–3/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring continued affordability by tenants, homebuyers, and homeowners in the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0c9da2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–3/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing ongoing training and counseling for homebuyers and homeowners; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0c9da3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–3/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" replacing units in eligible projects covered by a homeownership program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb0c9da4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–3/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition and rehabilitation limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Acquisition or rehabilitation of public housing projects under a homeownership program under this subchapter may not consist of acquisition or rehabilitation of less than the whole public housing project in a project consisting of more than 1 building. The provisions of this subsection may be waived upon a finding by the Secretary that the sale of less than all the buildings in a project is feasible and will not result in a hardship to any tenants of the project who are not included in the homeownership program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb0c9da5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–3/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb0c9da6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–3/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The application shall identify and describe the proposed financing for (A) any rehabilitation, and (B) acquisition (i) of the project, where applicable, by an entity other than the public housing agency for transfer to eligible families, and (ii) by eligible families of ownership interests in, or shares representing, units in the project. Financing may include use of the implementation grant, sale for cash, or other sources of financing (subject to applicable requirements), including conventional mortgage loans and mortgage loans insured under title II of the National Housing Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1707"},"text":"12 U.S.C. 1707","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0c9da7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–3/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition against pledges","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Property transferred under this subchapter shall not be pledged as collateral for debt or otherwise encumbered except when the Secretary determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb0c9da8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–3/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such encumbrance will not threaten the long-term availability of the property for occupancy by low-income families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0c9da9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–3/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" neither the Federal Government nor the public housing agency will be exposed to undue risks related to action that may have to be taken pursuant to paragraph (3);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0c9daa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–3/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any debt obligation can be serviced from project income, including operating assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0c9dab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–3/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proceeds of such encumbrance will be used only to meet housing standards in accordance with subsection (f) or to make such additional capital improvements as the Secretary determines to be consistent with the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0c9dac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–3/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opportunity to cure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any lender that provides financing in connection with a homeownership program under this subchapter shall give the public housing agency, resident management corporation, individual owner, or other appropriate entity a reasonable opportunity to cure a financial default before foreclosing on the property, or taking other action as a result of the default.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb0c9dad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–3/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Housing quality standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The application shall include a plan ensuring that the unit—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb0c9dae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–3/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will be free from any defects that pose a danger to health or safety before transfer of an ownership interest in, or shares representing, a unit to an eligible family; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0c9daf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–3/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will, not later than 2 years after the transfer to an eligible family, meet minimum housing standards established by the Secretary for the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb0c9db0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–3/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/276/tV/s531/b/1"},"text":"Pub. L. 105–276, title V, § 531(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2573"},"text":"112 Stat. 2573","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb0c9db1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–3/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of non-purchasing families","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb0c9db2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–3/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No tenant residing in a dwelling unit in a public housing project on the date the Secretary approves an application for an implementation grant may be evicted by reason of a homeownership program approved under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0c9db3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–3/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Replacement assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the tenant decides not to purchase a unit, or is not qualified to do so, the recipient shall, during the term of any operating assistance under the implementation grant, permit each otherwise qualified tenant to continue to reside in the project at rents that do not exceed levels consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437a/a"},"text":"section 1437a(a) of this title","children":[],"tail":" or, if an otherwise qualified tenant chooses to move (at any time during the term of such operating assistance contract), the public housing agency shall, to the extent approved in appropriations Acts, offer such tenant (A) a unit in another public housing project, or (B) section 8 ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f"},"text":"42 U.S.C. 1437f","children":[],"tail":"] assistance for use in other housing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0c9db4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–3/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relocation assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The recipient shall also inform each such tenant that if the tenant chooses to move, the recipient will pay relocation assistance in accordance with the approved homeownership program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0ee6a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–3/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Tenants renting a unit in a project transferred under this subchapter shall have all rights provided to tenants of public housing under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb0ee6a6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-09-01/ch896"},"text":"Sept. 1, 1937, ch. 896","children":[],"tail":", title III, § 304, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/tIV/s411"},"text":"Pub. L. 101–625, title IV, § 411","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4153"},"text":"104 Stat. 4153","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tI/s181/g/1/A"},"text":"Pub. L. 102–550, title I, § 181(g)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3736"},"text":"106 Stat. 3736","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/19/tI/s1002/b"},"text":"Pub. L. 104–19, title I, § 1002(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-07-27"},"text":"July 27, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/236"},"text":"109 Stat. 236","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/tV/s531/b/1"},"text":"Pub. L. 105–276, title V, § 531(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2573"},"text":"112 Stat. 2573","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb0ee6a7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb0ee6a8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbb0ee6a9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Housing Act, referred to in subsec. (e)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-27/ch847"},"text":"act June 27, 1934, ch. 847","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1246"},"text":"48 Stat. 1246","children":[],"tail":". Title II of the Act is classified principally to subchapter II (§ 1707 et seq.) of chapter 13 of Title 12, Banks and Banking. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1701"},"text":"section 1701 of Title 12","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsec. (e)(3), was in the original “this subtitle”, and was translated as reading “this title”, meaning title III of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-09-01/ch896"},"text":"act Sept. 1, 1937, ch. 896","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/101/625"},"text":"Pub. L. 101–625","children":[],"tail":", to reflect the probable intent of Congress, because title III of act "},{"tag":"date","attrib":{"date":"1937-09-01"},"text":"Sept. 1, 1937","children":[],"tail":", does not contain subtitles."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb0ee6aa-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/276"},"text":"Pub. L. 105–276","children":[],"tail":" struck out subsec. (g) which prohibited transfer of projects without plan for replacement housing. See 1995 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/19"},"text":"Pub. L. 104–19","children":[],"tail":" struck out subsec. (g) which prohibited transfer of projects without plan for replacement housing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":" struck out “(not including scattered site single family housing of a public housing agency)” after “housing project”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb0ee6ab-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbb0ee6ac-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/276/s531/b/1"},"text":"section 531(b)(1) of Pub. L. 105–276","children":[],"tail":" effective with respect to any plan for the demolition, disposition, or conversion to homeownership of public housing that is approved by Secretary after "},{"tag":"date","attrib":{"date":"1995-09-30"},"text":"Sept. 30, 1995","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/s531/b/2"},"text":"section 531(b)(2) of Pub. L. 105–276","children":[],"tail":", set out as a note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbb0ee6ad-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1995 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/19"},"text":"Pub. L. 104–19","children":[],"tail":" effective for applications for demolition, disposition, or conversion to homeownership of public housing approved by the Secretary, and other consolidation and relocation activities of public housing agencies undertaken on, before, or after "},{"tag":"date","attrib":{"date":"1995-09-30"},"text":"Sept. 30, 1995","children":[],"tail":", and on or before "},{"tag":"date","attrib":{"date":"1998-09-30"},"text":"Sept. 30, 1998","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/19/s1002/d"},"text":"section 1002(d) of Pub. L. 104–19","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437c"},"text":"section 1437c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbb0ee6ae-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Homeownership Replacement Plan","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/276/tV/s531/b"},"text":"Pub. L. 105–276, title V, § 531(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2573"},"text":"112 Stat. 2573","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/276/tV/s531/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subsections (b) and (c) of section 1002 of the Emergency Supplemental Appropriations for Additional Disaster Assistance, for Anti-terrorism Initiatives, for Assistance in the Recovery from the Tragedy that Occurred At Oklahoma City, and Rescissions Act, 1995 [amending this section and enacting provision set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437c"},"text":"sect