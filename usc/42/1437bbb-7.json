{"tag":"section","attrib":{"id":"idbb0ee76c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"1437bbb–7"},"text":"§ 1437bbb–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accountability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb0ee76d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb–7/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of records","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each participating jurisdiction shall maintain such records as the Secretary may require to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb0ee76e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb–7/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" document the amounts received by the jurisdiction under this chapter and the disposition of such amounts under the demonstration program under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0ee76f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb–7/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure compliance by the jurisdiction with this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0ee770-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb–7/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the performance of the jurisdiction under the demonstration program under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb0ee771-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb–7/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each participating jurisdiction shall annually submit to the Secretary a report in a form and at a time specified by the Secretary, which shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb0ee772-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb–7/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" documentation of the use of amounts made available to the jurisdiction under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0ee773-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb–7/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any information as the Secretary may request to assist the Secretary in evaluating the demonstration program under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0ee774-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb–7/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description and analysis of the effect of assisted activities in addressing the objectives of the demonstration program under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb0ee775-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb–7/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to documents by Secretary and Comptroller General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the Comptroller General of the United States, or any duly authorized representative of the Secretary or the Comptroller General, shall have access for the purpose of audit and examination to any books, documents, papers, and records maintained by a participating jurisdiction that relate to the demonstration program under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb0ee776-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb–7/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance review and evaluation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb0ee777-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb–7/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Based on the performance standards established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437bbb–5/b/4"},"text":"section 1437bbb–5(b)(4) of this title","children":[],"tail":", the Secretary shall monitor the performance of participating jurisdictions in providing assistance under this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0ee778-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb–7/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after the conclusion of the second year of the demonstration program under this subchapter, the Secretary shall submit to Congress an interim report on the status of the demonstration program and the progress each participating jurisdiction in achieving the purposes of the demonstration program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437bbb"},"text":"section 1437bbb of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb115779-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-09-01/ch896"},"text":"Sept. 1, 1937, ch. 896","children":[],"tail":", title IV, § 408, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/tV/s561"},"text":"Pub. L. 105–276, title V, § 561","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2623"},"text":"112 Stat. 2623","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
