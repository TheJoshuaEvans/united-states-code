{"tag":"section","attrib":{"id":"idbd4ffd60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5404"},"text":null,"children":[{"tag":"num","attrib":{"value":"5404"},"text":"§ 5404.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manufactured home installation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd4ffd61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5404/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of installation design and instructions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A manufacturer shall provide with each manufactured home, design and instructions for the installation of the manufactured home that have been approved by a design approval primary inspection agency. After establishment of model standards under subsection (b)(2), a design approval primary inspection agency may not give such approval unless a design and instruction provides equal or greater protection than the protection provided under such model standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd4ffd62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5404/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Model manufactured home installation standards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd4ffd63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5404/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposed model standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after the date on which the initial appointments of all the members of the consensus committee are completed, the consensus committee shall develop and submit to the Secretary proposed model manufactured home installation standards, which shall, to the maximum extent practicable, taking into account the factors described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5403/e"},"text":"section 5403(e) of this title","children":[],"tail":", be consistent with—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd4ffd64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5404/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manufactured home designs that have been approved by a design approval primary inspection agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd4ffd65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5404/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the designs and instructions for the installation of manufactured homes provided by manufacturers under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd4ffd66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5404/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of model standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 12 months after receiving the proposed model standards submitted under paragraph (1), the Secretary shall develop and establish model manufactured home installation standards, which shall, to the maximum extent practicable, taking into account the factors described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5403/e"},"text":"section 5403(e) of this title","children":[],"tail":", be consistent with—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd4ffd67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5404/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manufactured home designs that have been approved by a design approval primary inspection agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd4ffd68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5404/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the designs and instructions for the installation of manufactured homes provided by manufacturers under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd4ffd69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5404/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors for consideration","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd4ffd6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5404/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consensus committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing the proposed model standards under paragraph (1), the consensus committee shall consider the factors described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5403/e"},"text":"section 5403(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd4ffd6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5404/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing and establishing the model standards under paragraph (2), the Secretary shall consider the factors described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5403/e"},"text":"section 5403(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd4ffd6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5404/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The model manufactured home installation standards shall be issued after notice and an opportunity for public comment in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd4ffd6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5404/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manufactured home installation programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd4ffd6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5404/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of manufactured housing residents during initial period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During the 5-year period beginning on ","children":[{"tag":"date","attrib":{"date":"2000-12-27"},"text":"December 27, 2000","children":[],"tail":", no State or manufacturer may establish or implement any installation standards that, in the determination of the Secretary, provide less protection to the residents of manufactured homes than the protection provided by the installation standards in effect with respect to the State or manufacturer, as applicable, on "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"December 27, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd4ffd6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5404/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Installation standards","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd4ffd70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5404/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of installation program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than the expiration of the 5-year period described in paragraph (1), the Secretary shall establish an installation program that meets the requirements of paragraph (3) for the enforcement of installation standards in each State described in subparagraph (B) of this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd4ffd71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5404/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of installation program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning on the expiration of the 5-year period described in paragraph (1), the Secretary shall implement the installation program established under subparagraph (A) in each State that does not have an installation program established by State law that meets the requirements of paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd4ffd72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5404/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracting out of implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out subparagraph (B), the Secretary may contract with an appropriate agent to implement the installation program established under that subparagraph, except that such agent shall not be a person or entity other than a government, nor an affiliate or subsidiary of such a person or entity, that has entered into a contract with the Secretary to implement any other regulatory program under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd4ffd73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5404/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An installation program meets the requirements of this paragraph if it is a program regulating the installation of manufactured homes that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd4ffd74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5404/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" installation standards that, in the determination of the Secretary, provide protection to the residents of manufactured homes that equals or exceeds the protection provided to those residents by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd4ffd75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5404/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the model manufactured home installation standards established by the Secretary under subsection (b)(2); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd4ffd76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5404/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the designs and instructions provided by manufacturers under subsection (a), if the Secretary determines that such designs and instructions provide protection to the residents of manufactured homes that equals or exceeds the protection provided by the model manufactured home installation standards established by the Secretary under subsection (b)(2);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd4ffd77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5404/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the training and licensing of manufactured home installers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd4ffd78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5404/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inspection of the installation of manufactured homes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd4ffd79-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/383/tVI/s605"},"text":"Pub. L. 93–383, title VI, § 605","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/702"},"text":"88 Stat. 702","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/399/tIII/s308/c/4"},"text":"Pub. L. 96–399, title III, § 308(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-08"},"text":"Oct. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1641"},"text":"94 Stat. 1641","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/tVI/s605/a"},"text":"Pub. L. 106–569, title VI, § 605(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/3006"},"text":"114 Stat. 3006","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd4ffd7a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd4ffd7b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd4ffd7c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569"},"text":"Pub. L. 106–569","children":[],"tail":" amended section catchline and text generally, substituting provisions relating to manufactured home installation for provisions relating to National Manufactured Home Advisory Council."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsecs. (a) to (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/399"},"text":"Pub. L. 96–399","children":[],"tail":" substituted “Manufactured Home” for “Mobile Home” and “manufactured home” for “mobile home” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd4ffd7d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd4ffd7e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569"},"text":"Pub. L. 106–569","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", except that amendment has no effect on any order or interpretative bulletin issued under this chapter and published as a proposed rule pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"5 U.S.C. 553","children":[],"tail":" on or before "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/s612"},"text":"section 612 of Pub. L. 106–569","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5401"},"text":"section 5401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbd4ffd7f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon the expiration of 180 days following ","children":[{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/383/s627"},"text":"section 627 of Pub. L. 93–383","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5401"},"text":"section 5401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
