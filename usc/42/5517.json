{"tag":"section","attrib":{"id":"idbd572967-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5517"},"text":null,"children":[{"tag":"num","attrib":{"value":"5517"},"text":"§ 5517.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd572968-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5517/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations to National Aeronautics and Space Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby authorized to be appropriated to the National Aeronautics and Space Administration for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1975-06-30"},"text":"June 30, 1975","children":[],"tail":", $5,000,000, to remain available until expended, to carry out the functions vested in the Administrator by this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd572969-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5517/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations to Department of Housing and Urban Development","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby authorized to be appropriated to the Department of Housing and Urban Development for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1975-06-30"},"text":"June 30, 1975","children":[],"tail":", $5,000,000, to remain available until expended. Any sums so appropriated shall be available (1) to carry out the functions vested in the Secretary of Housing and Urban Development by this subchapter, and (2) for transfer to the Department of Defense, the National Institute of Standards and Technology, and the General Services Administration to enable them to carry out their respective functions under this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd57296a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5517/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations for programs under this subchapter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby authorized to be appropriated for the fiscal years ending ","children":[{"tag":"date","attrib":{"date":"1976-06-30"},"text":"June 30, 1976","children":[],"tail":", 1977, 1978, and 1979, $50,000,000 in the aggregate to carry out the programs established by this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd57296b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/409/s19"},"text":"Pub. L. 93–409, § 19","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-03"},"text":"Sept. 3, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1078"},"text":"88 Stat. 1078","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tV/s5115/c"},"text":"Pub. L. 100–418, title V, § 5115(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1433"},"text":"102 Stat. 1433","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd57296c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd57296d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children