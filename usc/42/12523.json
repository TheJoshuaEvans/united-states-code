{"tag":"section","attrib":{"id":"idbf72198b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523"},"text":null,"children":[{"tag":"num","attrib":{"value":"12523"},"text":"§ 12523.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to States, territories, and Indian tribes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf72198c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotments to States, territories, and Indian tribes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corporation, in consultation with the Secretary of Education, may make allotments to State educational agencies, territories, and Indian tribes to pay for the Federal share of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf72198d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" planning and building the capacity within the State, territory, or Indian tribe involved to implement service-learning programs that are based principally in elementary schools and secondary schools, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf72198e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing training and professional development for teachers, supervisors, personnel from community-based entities (particularly with regard to the recruitment, utilization, and management of participants), and trainers, to be conducted by qualified individuals or organizations that have experience with service-learning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf72198f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing service-learning curricula, consistent with State or local academic content standards, to be integrated into academic programs, including curricula for an age-appropriate learning component that provides participants an opportunity to analyze and apply their service experiences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf721990-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forming local partnerships described in paragraph (2) or (4)(D) to develop school-based service-learning programs in accordance with this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf721991-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" devising appropriate methods for research on and evaluation of the educational value of service-learning and the effect of service-learning activities on communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf721992-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing effective outreach and dissemination of information to ensure the broadest possible involvement of community-based entities with demonstrated effectiveness in working with school-age youth in their communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf721993-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing effective outreach and dissemination of information to ensure the broadest possible participation of schools throughout the State, throughout the territory, or serving the Indian tribe involved with particular attention to schools implementing comprehensive support and improvement activities or targeted support and improvement activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/d"},"text":"section 6311(d) of title 20","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf721994-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" implementing, operating, or expanding school-based service-learning programs, which may include paying for the cost of the recruitment, training, supervision, placement, salaries, and benefits of service-learning coordinators, through distribution by State educational agencies, territories, and Indian tribes of Federal funds made available under this part to projects operated by local partnerships among—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf721995-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local educational agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf721996-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 1 or more community partners that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf721997-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall include a public or private nonprofit organization that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbf721998-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/a/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a demonstrated expertise in the provision of services to meet unmet human, education, environmental, or public safety needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf721999-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/a/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will make projects available for participants, who shall be students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf72199a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/a/2/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was in existence at least 1 year before the date on which the organization submitted an application under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12525"},"text":"section 12525 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf72199b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include a private for-profit business, private elementary school or secondary school, or Indian tribe (except that an Indian tribe distributing funds to a project under this paragraph is not eligible to be part of the partnership operating that project);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf72199c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" planning of school-based service-learning programs, through distribution by State educational agencies, territories, and Indian tribes of Federal funds made available under this part to local educational agencies and Indian tribes, which planning may include paying for the cost of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf72199d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the salaries and benefits of service-learning coordinators; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf72199e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recruitment, training and professional development, supervision, and placement of service-learning coordinators who may be participants in a program under division C or receive a national service educational award under division D, who may be participants in a project under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5001"},"text":"section 5001 of this title","children":[],"tail":", or who may participate in a Youthbuild program under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3226"},"text":"section 3226 of title 29","children":[],"tail":","}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"who will identify the community partners described in paragraph (2)(B) and assist in the design and implementation of a program described in paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf72199f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" implementing, operating, or expanding school-based service-learning programs to utilize adult volunteers in service-learning to improve the education of students, through distribution by State educational agencies, territories, and Indian tribes of Federal funds made available under this part to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf7219a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local educational agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7219a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian tribes (except that an Indian tribe distributing funds under this paragraph is not eligible to be a recipient of those funds);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7219a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public or private nonprofit organizations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7219a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" partnerships or combinations of local educational agencies, and entities described in subparagraph (B) or (C); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7219a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" developing, as service-learning programs, civic engagement programs that promote a better understanding of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf7219a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the principles of the Constitution, the heroes of United States history (including military heroes), and the meaning of the Pledge of Allegiance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7219a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the Nation’s government functions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7219a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the importance of service in the Nation’s character.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7219a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of service-learning coordinator","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A service-learning coordinator referred to in paragraph (2) or (3) of subsection (a) shall provide services to a local partnership described in subsection (a)(2) or entity described in subsection (a)(3), respectively, that may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf7219a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing technical assistance and information to, and facilitating the training of, teachers and assisting in the planning, development, execution, and evaluation of service-learning in their classrooms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7219aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting local partnerships described in subsection (a)(2) in the planning, development, and execution of service-learning projects, including summer of service programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7219ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting schools and local educational agencies in developing school policies and practices that support the integration of service-learning into the curriculum; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7219ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carrying out such other duties as the local partnership or entity, respectively, may determine to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7219ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Related expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An entity that receives financial assistance under this part from a State, territory, or Indian tribe may, in carrying out the activities described in subsection (a), use such assistance to pay for the Federal share of reasonable costs related to the supervision of participants, program administration, transportation, insurance, and evaluations and for other reasonable expenses related to the activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7219ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State educational agency described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12522/2/A"},"text":"section 12522(2)(A) of this title","children":[],"tail":" may designate a statewide entity (which may be a community-based entity) with demonstrated experience in supporting or implementing service-learning programs, to receive the State educational agency’s allotment under this part, and carry out the functions of the agency under this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7219af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with Secretary of Education","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corporation is authorized to enter into agreements with the Secretary of Education for initiatives (and may use funds authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12681/a/6"},"text":"section 12681(a)(6) of this title","children":[],"tail":" to enter into the agreements if the additional costs of the initiatives are warranted) that may include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf7219b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification and dissemination of research findings on service-learning and scientifically valid research based practices for service-learning; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7219b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provision of professional development opportunities that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf7219b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the quality of service-learning instruction and delivery for teachers both preservice and in-service, personnel from community-based entities and youth workers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7219b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12523/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" create and sustain effective partnerships for service-learning programs between local educational agencies, community-based entities, businesses, and other stakeholders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf7219b4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s112"},"text":"Pub. L. 101–610, title I, § 112","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1201"},"text":"Pub. L. 111–13, title I, § 1201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1468"},"text":"123 Stat. 1468","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tV/s512/u/1"},"text":"Pub. L. 113–128, title V, § 512(u)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1712"},"text":"128 Stat. 1712","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9215/bbb/2"},"text":"Pub. L. 114–95, title IX, § 9215(bbb)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{