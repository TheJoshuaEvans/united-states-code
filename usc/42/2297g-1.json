{"tag":"section","attrib":{"id":"idbc1a158a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297g–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"2297g–1"},"text":"§ 2297g–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc1a158b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297g–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Fund shall consist of deposits in the amount of $518,233,333 per fiscal year (to be annually adjusted for inflation beginning on ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", using the Consumer Price Index for all-urban consumers published by the Department of Labor) as provided in this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc1a158c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297g–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Source","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Deposits described in subsection (a) shall be from the following sources:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc1a158d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297g–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sums collected pursuant to subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc1a158e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297g–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Appropriations made pursuant to subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc1a158f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297g–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special assessment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall collect a special assessment from domestic utilities. The total amount collected for a fiscal year shall not exceed $150,000,000 (to be annually adjusted for inflation using the Consumer Price Index for all-urban consumers published by the Department of Labor). The amount collected from each utility pursuant to this subsection for a fiscal year shall be in the same ratio to the amount required under subsection (a) to be deposited for such fiscal year as the total amount of separative work units such utility has purchased from the Department of Energy for the purpose of commercial electricity generation, before ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", bears to the total amount of separative work units purchased from the Department of Energy for all purposes (including units purchased or produced for defense purposes) before "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":". For purposes of this subsection—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc1a1590-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297g–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a utility shall be considered to have purchased a separative work unit from the Department if such separative work unit was produced by the Department, but purchased by the utility from another source; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc1a1591-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297g–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a utility shall not be considered to have purchased a separative work unit from the Department if such separative work unit was purchased by the utility, but sold to another source.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc1a1592-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297g–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Fund, for the period encompassing 15 years after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", such sums as are necessary to ensure that the amount required under subsection (a) is deposited for each fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc1a1593-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297g–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of assessments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The collection of amounts under subsection (c) shall cease after the earlier of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc1a1594-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297g–1/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 15 years after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc1a1595-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297g–1/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the collection of $2,250,000,000 (to be annually adjusted for inflation using the Consumer Price Index for all-urban consumers published by the Department of Labor) under such subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc1a1596-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297g–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of deposits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (e), deposits shall continue to be made into the Fund under subsection (d) for the period specified in such subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc1a1597-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297g–1/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any special assessment levied under this section on domestic utilities for the decontamination and decommissioning of the Department’s gaseous diffusion enrichment facilities shall be deemed a necessary and reasonable current cost of fuel and shall be fully recoverable in rates in all jurisdictions in the same manner as the utility’s other fuel cost.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc1a1598-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"Aug. 1, 1946, ch. 724","children":[],"tail":", title II, § 1802, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXI/s1101"},"text":"Pub. L. 102–486, title XI, § 1101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2953"},"text":"106 Stat. 2953","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/388/s11/c"},"text":"Pub. L. 105–388, § 11(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3485"},"text":"112 Stat. 3485","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/222/s1/c"},"text":"Pub. L. 107–222, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1336"},"text":"116 Stat. 1336","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc1a1599-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc1a159a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc1a159b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/222"},"text":"Pub. L. 107–222","children":[],"tail":" substituted “$518,233,333” for “$488,333,333” and inserted “beginning on "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":",” after “inflation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/388"},"text":"Pub. L. 105–388","children":[],"tail":" substituted “$488,333,333” for “$480,000,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
