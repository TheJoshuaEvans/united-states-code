{"tag":"section","attrib":{"id":"idbffa0e21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16196"},"text":null,"children":[{"tag":"num","attrib":{"value":"16196"},"text":"§ 16196.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy Efficiency Science Initiative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbffa0e22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16196/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish an Energy Efficiency Science Initiative to be managed by the Assistant Secretary in the Department with responsibility for energy conservation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7133/a/9"},"text":"section 7133(a)(9) of this title","children":[],"tail":", in consultation with the Director of the Office of Science, for grants to be competitively awarded and subject to peer review for research relating to energy efficiency."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffa0e23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16196/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall submit to Congress, along with the annual budget request of the President submitted to Congress, a report on the activities of the Energy Efficiency Science Initiative, including a description of the process used to award the funds and an explanation of how the research relates to energy efficiency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbffa0e24-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s916"},"text":"Pub. L. 109–58, title IX, § 916","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/862"},"text":"119 Stat. 862","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
