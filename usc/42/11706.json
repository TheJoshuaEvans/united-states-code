{"tag":"section","attrib":{"id":"idbf556a65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11706"},"text":null,"children":[{"tag":"num","attrib":{"value":"11706"},"text":"§ 11706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative grant for Papa Ola Lokahi","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf556a66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11706/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to any other grant or contract under this chapter, the Secretary may make grants to, or enter into contracts with, Papa Ola Lokahi for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf556a67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11706/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordination, implementation, and updating (as appropriate) of the comprehensive health care master plan developed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11703"},"text":"section 11703 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf556a68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11706/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training for the persons described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11705/c/1/B"},"text":"section 11705(c)(1)(B) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf556a69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11706/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification of and research into the diseases that are most prevalent among Native Hawaiians, including behavioral, biomedical, epidemiological, and health services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf556a6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11706/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of an action plan outlining the contributions that each member organization of Papa Ola Lokahi will make in carrying out the policy of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf556a6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11706/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a clearinghouse function for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf556a6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11706/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the collection and maintenance of data associated with the health status of Native Hawaiians;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf556a6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11706/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification and research into diseases affecting Native Hawaiians; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf556a6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11706/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of Native Hawaiian project funds, research projects and publications;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf556a6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11706/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the coordination of the health care programs and services provided to Native Hawaiians; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf556a70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11706/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the administration of special project funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf556a71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11706/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary for fiscal years 1993 through 2019 to carry out subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf556a72-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/579/s7"},"text":"Pub. L. 100–579, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-31"},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2921"},"text":"102 Stat. 2921","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tII/s2307"},"text":"Pub. L. 100–690, title II, § 2307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4227"},"text":"102 Stat. 4227","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/396/tIX/s9168"},"text":"Pub. L. 102–396, title IX, § 9168","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-06"},"text":"Oct. 6, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1948"},"text":"106 Stat. 1948","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf556a73-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf556a74-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf556a75-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" is based on section 202(a) of title II of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The 1992 amendment is based on section 1 of S. 2681, One Hundred Second Congress, as passed by the Senate on ","children":[{"tag":"date","attrib":{"date":"1992-08-07"},"text":"Aug. 7, 1992","children":[],"tail":", and enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/102/396/s9168"},"text":"section 9168 of Pub. L. 102–396","children":[],"tail":". Section 9168, which referred to S. 2681, as passed by the Senate on “"},{"tag":"date","attrib":{"date":"1992-09-12"},"text":"September 12, 1992","children":[],"tail":"”, has been treated as referring to S. 2681, as passed by the Senate on "},{"tag":"date","attrib":{"date":"1992-08-07"},"text":"Aug. 7, 1992","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/579"},"text":"Pub. L. 100–579","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" enacted substantially identical sections. The text of this section is based on "},{"tag":"ref","attrib":{"href":"/us/pl/100/579/s7"},"text":"section 7 of Pub. L. 100–579","children":[],"tail":", as subsequently amended."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf556a76-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":", which directed the amendment of section 7(b) of the Native Hawaiian Health Care Act of 1988 by substituting “2019” for “2001”, was executed by making the amendment to this section, which is section 7 of the Native Hawaiian Health Care Improvement Act, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/396"},"text":"Pub. L. 102–396","children":[],"tail":" amended section generally. Prior to amendment, section related to assignment of personnel."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
