{"tag":"section","attrib":{"id":"idbb6e4544-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1774"},"text":null,"children":[{"tag":"num","attrib":{"value":"1774"},"text":"§ 1774.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disbursement directly to schools or institutions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb6e4545-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1774/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall withhold funds payable to a State under this chapter and disburse the funds directly to schools or institutions within the State for the purposes authorized by this chapter to the extent that the Secretary has so withheld and disbursed such funds continuously since ","children":[{"tag":"date","attrib":{"date":"1980-10-01"},"text":"October 1, 1980","children":[],"tail":", but only to such extent (except as otherwise required by subsection (b)). Any funds so withheld and disbursed by the Secretary shall be used for the same purposes, and shall be subject to the same conditions, as applicable to a State disbursing funds made available under this chapter. If the Secretary is administering (in whole or in part) any program authorized under this chapter, the State in which the Secretary is administering the program may, upon request to the Secretary, assume administration of that program."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb6e4546-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1774/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a State educational agency is not permitted by law to disburse the funds paid to it under this chapter to any of the nonpublic schools in the State, the Secretary shall disburse the funds directly to such schools within the State for the same purposes and subject to the same conditions as are authorized or required with respect to the disbursements to public schools within the State by the State educational agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb6e4547-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/642/s5"},"text":"Pub. L. 89–642, § 5","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVIII/s817/e"},"text":"Pub. L. 97–35, title VIII, § 817(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/532"},"text":"95 Stat. 532","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb6e4548-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb6e4549-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbb6e454a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1774, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/642/s5"},"text":"Pub. L. 89–642, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-11"},"text":"Oct. 11, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/887"},"text":"80 Stat. 887","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/248/s2"},"text":"Pub. L. 91–248, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-05-14"},"text":"May 14, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"hr