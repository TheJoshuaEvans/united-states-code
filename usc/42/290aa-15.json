{"tag":"section","attrib":{"id":"idb5a0fa56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–15"},"text":null,"children":[{"tag":"num","attrib":{"value":"290aa–15"},"text":"§ 290aa–15.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Health and Human Services grant accountability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5a0fa57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–15/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5a0fa58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–15/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “applicable committees” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5a0fa59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–15/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Health, Education, Labor and Pensions of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5a0fa5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–15/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Commerce of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5a0fa5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–15/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered grant” means a grant awarded by the Secretary under a program established under this Act (or an amendment made by this Act, other than sections 703 through 707), including any grant administered by the Administrator of the Substance Abuse and Mental Health Services Administration under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1536"},"text":"section 1536 of title 21","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5a0fa5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–15/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grantee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “grantee” means the recipient of a covered grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5a0fa5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–15/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a0fa5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–15/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accountability measures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each covered grant shall be subject to the following accountability requirements:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5a0fa5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–15/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effectiveness report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require grantees to report on the effectiveness of the activities carried out with amounts made available to carry out the program under which the covered grant is awarded, including the number of persons served by such grant, if applicable, the number of persons seeking services who could not be served by such grant, and such other information as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5a0fa60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–15/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on prevention of fraud, waste, and abuse","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5a0fa61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–15/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2016-07-22"},"text":"July 22, 2016","children":[],"tail":", the Secretary, in coordination with the Inspector General of the Department of Health and Human Services, shall submit to the applicable committees a report on the policies and procedures the Department has in place to prevent waste, fraud, and abuse in the administration of covered grants."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5a0fa62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–15/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The policies and procedures referred to in clause (i) shall include policies and procedures that are designed to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb5a0fa63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–15/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent grantees from utilizing funds awarded through a covered grant for unauthorized expenditures or otherwise unallowable costs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb5a0fa64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–15/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure grantees will not receive unwarranted duplicate grants for the same purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5a0fa65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–15/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conference expenditures","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5a0fa66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–15/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No amounts made available to the Secretary under this Act (or in a provision of law amended by this Act, other than sections 703 through 707) may be used by the Secretary, or by any individual or entity awarded discretionary funds through a cooperative agreement under a program established under this Act (or in a provision of law amended by this Act), to host or support any expenditure for conferences that uses more than $20,000 in funds made available by the Secretary, unless the head of the relevant operating division or program office provides prior written authorization that the funds may be expended to host or support the conference. Such written authorization shall include a written estimate of all costs associated with the conference, including the cost of all food, beverages, audio-visual equipment, honoraria for speakers, and entertainment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5a0fa67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–15/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary (or the Secretary’s designee) shall submit to the applicable committees an annual report on all conference expenditures approved by the Secretary under this subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5a0fa68-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/198/tVII/s701/c"},"text":"Pub. L. 114–198, title VII, § 701(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-22"},"text":"July 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/738"},"text":"130 Stat. 738","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5a0fa69-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5a0fa6a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb5a0fa6b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in pars. (1)(B) and (2)(C)(i), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/198"},"text":"Pub. L. 114–198","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-22"},"text":"July 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/695"},"text":"130 Stat. 695","children":[],"tail":", known as the Comprehensive Addiction and Recovery Act of 2016. Section 703 of the Act is not classified to the Code, and sections 704 to 707 of the Act enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7n"},"text":"section 1320a–7n of this title","children":[],"tail":", amended sections 1395w–101, 1395w–104, 1395w–152, 1395ddd, 1395iii, 1396a, 1396r–8, 1396w–1, and 1397bb of this title, and enacted provisions set out as notes under sections 1395w–101 and 1396r–8 of this title. For complete classification of this Act to the Code, see Short Title of 2016 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb5a0fa6c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Comprehensive Addiction and Recovery Act of 2016, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5a0fa6d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb5a0fa6e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Additional Report","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/198/tVII/s701/e"},"text":"Pub. L. 114–198, title VII, § 701(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-22"},"text":"July 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/740"},"text":"130 Stat. 740","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/198/tVII/s701/e"},"text":"“In the case of a report submitted under subsection (c) [enacting this section] to the applicable committees, if such report pertains to a grant under section 103 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1536"},"text":"21 U.S.C. 1536","children":[],"tail":"], that report shall also be submitted, in the same manner and at the same time, to the Committee on Oversight and Government Reform [now Committee on Oversight and Accountability] of the House of Representatives and to the Committee on the Judiciary of the Senate.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
