{"tag":"section","attrib":{"id":"idbfee2911-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16022"},"text":null,"children":[{"tag":"num","attrib":{"value":"16022"},"text":"§ 16022.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project management","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfee2912-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16022/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Departmental management","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfee2913-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16022/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Project shall be managed in the Department by the Office of Nuclear Energy, Science, and Technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee2914-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16022/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Generation IV Nuclear Energy Systems program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may combine the Project with the Generation IV Nuclear Energy Systems Initiative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee2915-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16022/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing DOE project management expertise","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may utilize capabilities for review of construction projects for advanced scientific facilities within the Office of Science to track the progress of the Project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee2916-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16022/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Laboratory management","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfee2917-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16022/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lead Laboratory","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Idaho National Laboratory shall be the lead National Laboratory for the Project and shall collaborate with other National Laboratories, institutions of higher education, other research institutes, industrial researchers, and international researchers to carry out the Project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee2918-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16022/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Industrial partnerships","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfee2919-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16022/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Idaho National Laboratory shall organize a consortium of appropriate industrial partners that will carry out cost-shared research, development, design, and construction activities, and operate research facilities, on behalf of the Project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfee291a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16022/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Activities of industrial partners funded by the Project shall be cost-shared in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16352"},"text":"section 16352 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfee291b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16022/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Preference in determining the final structure of the consortium or any partnerships under this part shall be given to a structure (including designating as a lead industrial partner an entity incorporated in the United States) that retains United States technological leadership in the Project while maximizing cost sharing opportunities and minimizing Federal funding responsibilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee291c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16022/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prototype plant siting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The prototype nuclear reactor and associated plant shall be sited at the Idaho National Laboratory in Idaho.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee291d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16022/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reactor test capabilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Project shall use, if appropriate, reactor test capabilities at the Idaho National Laboratory.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee291e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16022/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other Laboratory capabilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Project may use, if appropriate, facilities at other National Laboratories.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfee291f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVI/s642"},"text":"Pub. L. 109–58, title VI, § 642","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/795"},"text":"119 Stat. 795","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
