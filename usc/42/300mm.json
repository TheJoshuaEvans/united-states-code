{"tag":"section","attrib":{"id":"idb6de0f13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm"},"text":null,"children":[{"tag":"num","attrib":{"value":"300mm"},"text":"§ 300mm.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of World Trade Center Health Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6de0f14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is hereby established within the Department of Health and Human Services a program to be known as the World Trade Center Health Program, which shall be administered by the WTC Program Administrator, to provide beginning on ","children":[{"tag":"date","attrib":{"date":"2011-07-01"},"text":"July 1, 2011","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6de0f15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medical monitoring and treatment benefits to eligible emergency responders and recovery and cleanup workers (including those who are Federal employees) who responded to the ","children":[{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":", terrorist attacks; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6de0f16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" initial health evaluation, monitoring, and treatment benefits to residents and other building occupants and area workers in New York City who were directly impacted and adversely affected by such attacks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6de0f17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Components of program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The WTC Program includes the following components:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6de0f18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical monitoring for responders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Medical monitoring under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300mm–21"},"text":"section 300mm–21 of this title","children":[],"tail":", including clinical examinations and long-term health monitoring and analysis for enrolled WTC responders who were likely to have been exposed to airborne toxins that were released, or to other hazards, as a result of the "},{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":", terrorist attacks."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6de0f19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial health evaluation for survivors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An initial health evaluation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300mm–31"},"text":"section 300mm–31 of this title","children":[],"tail":", including an evaluation to determine eligibility for followup monitoring and treatment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6de0f1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Followup monitoring and treatment for WTC-related health conditions for responders and survivors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Provision under sections 300mm–22, 300mm–32, and 300mm–33 of this title of followup monitoring and treatment and payment, subject to the provisions of subsection (d), for all medically necessary health and mental health care expenses of an individual with respect to a WTC-related health condition (including necessary prescription drugs).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6de0f1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Establishment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300mm–2"},"text":"section 300mm–2 of this title","children":[],"tail":" of an education and outreach program to potentially eligible individuals concerning the benefits under this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6de0f1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clinical data collection and analysis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Collection and analysis under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300mm–3"},"text":"section 300mm–3 of this title","children":[],"tail":" of health and mental health data relating to individuals receiving monitoring or treatment benefits in a uniform manner in collaboration with the collection of epidemiological data under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300mm–52"},"text":"section 300mm–52 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6de0f1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research on health conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Establishment under part C of a research program on health conditions resulting from the ","children":[{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":", terrorist attacks."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6de0f1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No cost sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Monitoring and treatment benefits and initial health evaluation benefits are provided under part B without any deductibles, copayments, or other cost sharing to an enrolled WTC responder or certified-eligible WTC survivor. Initial health evaluation benefits are provided under part B without any deductibles, copayments, or other cost sharing to a screening-eligible WTC survivor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6de0f1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preventing fraud and unreasonable administrative costs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6de0f20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fraud","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Inspector General of the Department of Health and Human Services shall develop and implement a program to review the WTC Program’s health care expenditures to detect fraudulent or duplicate billing and payment for inappropriate services. This subchapter is a Federal health care program (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7b/f"},"text":"section 1320a–7b(f) of this title","children":[],"tail":") and is a health plan (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7c/c"},"text":"section 1320a–7c(c) of this title","children":[],"tail":") for purposes of applying sections 1320a–7 through 1320a–7e of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6de0f21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unreasonable administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Inspector General of the Department of Health and Human Services shall develop and implement a program to review the WTC Program for unreasonable administrative costs, including with respect to infrastructure, administration, and claims processing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6de0f22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quality assurance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The WTC Program Administrator working with the Clinical Centers of Excellence shall develop and implement a quality assurance program for the monitoring and treatment delivered by such Centers of Excellence and any other participating health care providers. Such program shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6de0f23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adherence to monitoring and treatment protocols;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6de0f24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate diagnostic and treatment referrals for participants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6de0f25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prompt communication of test results to participants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6de0f26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other elements as the Administrator specifies in consultation with the Clinical Centers of Excellence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6de0f27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual program report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6de0f28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 6 months after the end of each fiscal year in which the WTC Program is in operation, the WTC Program Administrator shall submit an annual report to the Congress on the operations of this subchapter for such fiscal year and for the entire period of operation of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6de0f29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents included in report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each annual report under paragraph (1) shall include at least the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6de0f2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible individuals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Information for each clinical program described in paragraph (3)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6de0f2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/f/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the number of individuals who applied for certification under part B and the number of such individuals who were so certified;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6de0f2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/f/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the individuals who were certified, on the number who received monitoring under the program and the number of such individuals who received medical treatment under the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6de0f2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/f/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to individuals so certified who received such treatment, on the WTC-related health conditions for which they were treated; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6de0f2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/f/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the projected number of individuals who will be certified under part B in the succeeding fiscal year and the succeeding 10-year period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0f2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring, initial health evaluation, and treatment costs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each clinical program so described—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6de0f30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on the costs of monitoring and initial health evaluation and the costs of treatment and on the estimated costs of such monitoring, evaluation, and treatment in the succeeding fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6de0f31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the cost of medical treatment for WTC-related health conditions that have been paid for or reimbursed by workers’ compensation, by public or private health plans, or by New York City under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300mm–41"},"text":"section 300mm–41 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0f32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Information on the cost of administering the program, including costs of program support, data collection and analysis, and research conducted under the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0f33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative experience","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Information on the administrative performance of the program, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6de0f34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/f/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the performance of the program in providing timely evaluation of and treatment to eligible individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6de0f35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/f/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of the Clinical Centers of Excellence and other providers that are participating in the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0f36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/f/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scientific reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A summary of the findings of any new scientific reports or studies on the health effects associated with exposure described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300mm–5/1"},"text":"section 300mm–5(1) of this title","children":[],"tail":", including the findings of research conducted under subsection (a) or (c) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300mm–51"},"text":"section 300mm–51 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0f37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/f/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Committee recommendations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A list of recommendations by the WTC Scientific/Technical Advisory Committee on additional WTC Program eligibility criteria and on additional WTC-related health conditions and the action of the WTC Program Administrator concerning each such recommendation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6de0f38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separate clinical programs described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In paragraph (2), each of the following shall be treated as a separate clinical program of the WTC Program:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6de0f39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Firefighters and related personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The benefits provided for enrolled WTC responders described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300mm–21/a/2/A"},"text":"section 300mm–21(a)(2)(A) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0f3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other WTC responders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The benefits provided for enrolled WTC responders not described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0f3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" WTC survivors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The benefits provided for screening-eligible WTC survivors and certified-eligible WTC survivors in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300mm–31/a"},"text":"section 300mm–31(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6de0f3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification to Congress upon reaching 80 percent of eligibility numerical limits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall promptly notify the Congress of ea