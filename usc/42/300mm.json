il":"\n"},{"tag":"subsection","attrib":{"id":"idb6de0f40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" GAO studies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6de0f41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2015-12-18"},"text":"December 18, 2015","children":[],"tail":", the Comptroller General of the United States shall submit to the Committee on Energy and Commerce of the House of Representatives and the Committee on Health, Education, Labor, and Pensions of the Senate a report that assesses, with respect to the WTC Program, the effectiveness of each of the following:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6de0f42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/i/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The quality assurance program developed and implemented under subsection (e).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0f43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/i/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The procedures for providing certifications of coverage of conditions as WTC-related health conditions for enrolled WTC responders under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300mm–22/b/2/B/iii"},"text":"section 300mm–22(b)(2)(B)(iii) of this title","children":[],"tail":" and for screening-eligible WTC survivors and certified-eligible WTC survivors under such section as applied under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300mm–32/a"},"text":"section 300mm–32(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0f44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/i/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any action under the WTC Program to ensure appropriate payment (including the avoidance of improper payments), including determining the extent to which individuals enrolled in the WTC Program are eligible for workers compensation or sources of health coverage, ascertaining the liability of such compensation or sources of health coverage, and making recommendations for ensuring effective and efficient coordination of benefits for individuals enrolled in the WTC Program that does not place an undue burden on such individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6de0f45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent assessments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 6 years and 6 months after ","children":[{"tag":"date","attrib":{"date":"2015-12-18"},"text":"December 18, 2015","children":[],"tail":", and every 5 years thereafter through fiscal year 2042, the Comptroller General of the United States shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6de0f46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult the Committee on Energy and Commerce of the House of Representatives and the Committee on Health, Education, Labor, and Pensions of the Senate on the objectives in assessing the WTC Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6de0f47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and submit to such Committees a report that assesses the WTC Program for the applicable reporting period, including the objectives described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6de0f48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The WTC Program Administrator is authorized to promulgate such regulations as the Administrator determines necessary to administer this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6de0f49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The WTC Program shall terminate on ","children":[{"tag":"date","attrib":{"date":"2090-10-01"},"text":"October 1, 2090","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6de0f4a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","