{"tag":"section","attrib":{"id":"idbb8fb07f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1862p–1"},"text":"§ 1862p–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Science Foundation manufacturing research and education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb8fb080-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manufacturing research","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall carry out a program to award merit-reviewed, competitive grants to institutions of higher education to support fundamental research leading to transformative advances in manufacturing technologies, processes, and enterprises that will support United States manufacturing through improved performance, productivity, sustainability, and competitiveness. Research areas may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb8fb081-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nanomanufacturing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb8fb082-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manufacturing and construction machines and equipment, including robotics, automation, and other intelligent systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb8fb083-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manufacturing enterprise systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb8fb084-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–1/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced sensing and control techniques;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb8fb085-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–1/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" materials processing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb8fb086-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–1/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information technologies for manufacturing, including predictive and real-time models and simulations, virtual manufacturing; ","children":[{"tag":"ref","attrib":{"idref":"fn003212"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003212"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The semicolon probably should be a comma."}],"tail":" and artificial intelligence and machine learning; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb8fb087-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–1/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" additive manufacturing, including new material designs, complex materials, rapid printing techniques, and real-time process controls.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb8fb088-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manufacturing education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to help ensure a well-trained manufacturing workforce, the Director shall award grants to strengthen and expand scientific and technical education and training in advanced manufacturing, including through the Foundation’s Advanced Technological Education program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb8fb089-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358/tV/s506"},"text":"Pub. L. 111–358, title V, § 506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4007"},"text":"124 Stat. 4007","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tIII/s10358"},"text":"Pub. L. 117–167, div. B, title III, § 10358","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1563"},"text":"136 Stat. 1563","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb8fb08a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb8fb08b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb8fb08c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the America COMPETES Reauthorization Act of 2010, also known as the America Creating Opportunities to Meaningfully Promote Excellence in Technology, Education, and Science Reauthorization Act of 2010, and also as part of the National Science Foundation Authorization Act of 2010, and not as part of the National Science Foundation Act of 1950 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb92208d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10358/2"},"text":"Pub. L. 117–167, § 10358(2)","children":[],"tail":", substituted “simulations, virtual manufacturing; and artificial intelligence and machine learning; and” for “simulations, and virtual manufacturing.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10358/1"},"text":"Pub. L. 117–167, § 10358(1)","children":[],"tail":", (3), added par. (7)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb92208e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbb92208f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358/s502"},"text":"section 502 of Pub. L. 111–358","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862p"},"text":"section 1862p of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
