{"tag":"section","attrib":{"id":"idbaad3f5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"1397m–3"},"text":"§ 1397m–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of information regarding, and evaluations of, elder justice programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbaad3f60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under this part, an applicant shall agree—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaad3f61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in paragraph (2), to provide the eligible entity conducting an evaluation under subsection (b) of the activities funded through the grant with such information as the eligible entity may require in order to conduct such evaluation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaad3f62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an applicant for a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397m/b"},"text":"section 1397m(b) of this title","children":[],"tail":", to provide the Secretary with such information as the Secretary may require to conduct an evaluation or audit under subsection (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaad3f63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of eligible entities to conduct evaluations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaad3f64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaad3f65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m–3/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reserve a portion (not less than 2 percent) of the funds appropriated with respect to each program carried out under this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaad3f66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m–3/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the funds reserved under subparagraph (A) to provide assistance to eligible entities to conduct evaluations of the activities funded under each program carried out under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaad3f67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certified EHR technology grant program not included","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this subsection shall not apply to the certified EHR technology grant program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397m/b"},"text":"section 1397m(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaad3f68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m–3/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A recipient of assistance described in paragraph (1)(B) shall use the funds made available through the assistance to conduct a validated evaluation of the effectiveness of the activities funded under a program carried out under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaad3f69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m–3/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive assistance under paragraph (1)(B), an entity shall submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary may require, including a proposal for the evaluation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaad3f6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m–3/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than a date specified by the Secretary, an eligible entity receiving assistance under paragraph (1)(B) shall submit to the Secretary, the Committee on Ways and Means and the Committee on Energy and Commerce of the House of Representatives, and the Committee on Finance of the Senate a report containing the results of the evaluation conducted using such assistance together with such recommendations as the entity determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaad3f6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations and audits of certified EHR technology grant program by the Secretary","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaad3f6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m–3/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct an evaluation of the activities funded under the certified EHR technology grant program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397m/b"},"text":"section 1397m(b) of this title","children":[],"tail":". Such evaluation shall include an evaluation of whether the funding provided under the grant is expended only for the purposes for which it is made."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaad3f6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m–3/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct appropriate audits of grants made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397m/b"},"text":"section 1397m(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbaad3f6e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XX, § 2044, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tVI/s6703/a/1/C"},"text":"Pub. L. 111–148, title VI, § 6703(a)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/796"},"text":"124 Stat. 796","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
