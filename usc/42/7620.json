{"tag":"section","attrib":{"id":"idbe5b049b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7620"},"text":null,"children":[{"tag":"num","attrib":{"value":"7620"},"text":"§ 7620.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standardized air quality modeling","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe5b049c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7620/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conferences","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than six months after ","children":[{"tag":"date","attrib":{"date":"1977-08-07"},"text":"August 7, 1977","children":[],"tail":", and at least every three years thereafter, the Administrator shall conduct a conference on air quality modeling. In conducting such conference, special attention shall be given to appropriate modeling necessary for carrying out part C of subchapter I (relating to prevention of significant deterioration of air quality)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe5b049d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7620/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conferees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The conference conducted under this section shall provide for participation by the National Academy of Sciences, representatives of State and local air pollution control agencies, and appropriate Federal agencies, including the National Science Foundation; ","children":[{"tag":"ref","attrib":{"idref":"fn003718"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003718"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The semicolon probably should be a comma."}],"tail":" the National Oceanic and Atmospheric Administration, and the National Institute of Standards and Technology."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe5b049e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7620/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comments; transcripts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Interested persons shall be permitted to submit written comments and a verbatim transcript of the conference proceedings shall be maintained.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe5b049f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7620/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promulgation and revision of regulations relating to air quality modeling","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The comments submitted and the transcript maintained pursuant to subsection (c) shall be included in the docket required to be established for purposes of promulgating or revising any regulation relating to air quality modeling under part C of subchapter I.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe5b04a0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title III, § 320, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/95/tIII/s310"},"text":"Pub. L. 95–95, title III, § 310","children":[],"tail":", "},{"tag":"date","at