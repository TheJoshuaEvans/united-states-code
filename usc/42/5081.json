{"tag":"section","attrib":{"id":"idbcf55a71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5081"},"text":null,"children":[{"tag":"num","attrib":{"value":"5081"},"text":"§ 5081.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Volunteer Antipoverty Programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcf55a72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5081/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorizations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcf55a73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5081/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Volunteers in Service to America","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out part A of subchapter I $100,000,000 for fiscal year 2010 and such sums as may be necessary for each of the fiscal years 2011 through 2014.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf55a74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5081/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special volunteer programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out part C of subchapter I such sums as may be necessary for each of fiscal years 2010 through 2014.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf55a75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5081/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specification of budget function","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authorizations of appropriations contained in this subsection shall be considered to be a component of budget function 500 as used by the Office of Management and Budget to cover education, training, employment, and social services, and, as such, shall be considered to be related to the programs of the Departments of Labor, Health and Human Services, and Education for budgetary purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf55a76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5081/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsistence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The minimum level of an allowance for subsistence required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4955/b/2"},"text":"section 4955(b)(2) of this title","children":[],"tail":", to be provided to each volunteer under subchapter I, may not be reduced or limited in order to provide for an increase in the number of volunteer service years under part A of subchapter I."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf55a77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5081/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No part of the funds appropriated to carry out part A of subchapter I may be used to provide volunteers or assistance to any program or project authorized under part C of subchapter I, or under subchapter II, unless the program or project meets the antipoverty criteria of part A of subchapter I.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf55a78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5081/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts appropriated for part A of subchapter I shall remain available for obligation until the end of the fiscal year following the fiscal year for which the amounts were appropriated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcf55a79-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/113/tV/s501"},"text":"Pub. L. 93–113, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-10-01"},"text":"Oct. 1, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/415"},"text":"87 Stat. 415","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/293/s6/a"},"text":"Pub. L. 94–293, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-27"},"text":"May 27, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/526"},"text":"90 Stat. 526","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/143/s15/a"},"text":"Pub. L. 96–143, § 15(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1979-12-13"},"text":"Dec. 13, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1082"},"text":"93 Stat. 1082","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s607/a"},"text":"Pub. L. 97–35, title VI, § 607(a)","ch