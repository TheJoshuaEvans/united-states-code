{"tag":"section","attrib":{"id":"idc054b125-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18311"},"text":null,"children":[{"tag":"num","attrib":{"value":"18311"},"text":"§ 18311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States human space flight policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc054b126-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18311/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of non-United States human space flight transportation services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc054b127-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18311/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal Government may not acquire human space flight transportation services from a foreign entity unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc054b128-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18311/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no United States Government-operated human space flight capability is available;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc054b129-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18311/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no United States commercial provider is available; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc054b12a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18311/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is a qualified foreign entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc054b12b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18311/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc054b12c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18311/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial provider","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “commercial provider” means any person providing human space flight transportation services, primary control of which is held by persons other than the Federal Government, a State or local government, or a foreign government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc054b12d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18311/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified foreign entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified foreign entity” means a foreign entity that is in compliance with all applicable safety standards and is not prohibited from providing space transportation services under other law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc054b12e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18311/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States commercial provider","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States commercial provider” means a commercial provider, organized under the laws of the United States or of a State, that is more than 50 percent owned by United States nationals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc054b12f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18311/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Arrangements with foreign entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall prevent the Administrator from negotiating or entering into human space flight transportation arrangements with foreign entities to ensure safety of flight and continued ISS operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc054b130-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18311/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States human space flight capabilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Congress reaffirms the policy stated in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s70501/a"},"text":"section 70501(a) of title 51","children":[],"tail":", that the United States shall maintain an uninterrupted capability for human space flight and operations in low-Earth orbit, and beyond, as an essential instrument of national security and of the capacity to ensure continued United States participation and leadership in the exploration and utilization of space."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc054b131-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/267/tII/s201"},"text":"Pub. L. 111–267, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-11"},"text":"Oct. 11, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2811"},"text":"124 Stat. 2811","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/10/tIII/s302/d"},"text":"Pub. L. 115–10, title III, § 302(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-03-21"},"text":"Mar. 21, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/25"},"text":"131 Stat. 25","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc054b132-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc054b133-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc054b134-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (b), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s70501/a"},"text":"section 70501(a) of title 51","children":[],"tail":"” substituted for “section 501(a) of the National Aeronautics and Space Administration Authorization Act of 2005 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s16761/a"},"text":"42 U.S.C. 16761(a)","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/111/314/s5/e"},"text":"Pub. L. 111–314, § 5(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3443"},"text":"124 Stat. 3443","children":[],"tail":", which Act enacted Title 51, National and Commercial Space Programs."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc054b135-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/10"},"text":"Pub. L. 115–10","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, text read as follows: “It is the policy of the United States that reliance upon and use of non-United States human space flight capabilities shall be undertaken only as a contingency in circumstances where no United States-owned and operated human space flight capability is available, operational, and certified for flight by appropriate Federal agencies.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
