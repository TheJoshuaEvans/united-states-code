{"tag":"section","attrib":{"id":"idbf0e015b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10106"},"text":null,"children":[{"tag":"num","attrib":{"value":"10106"},"text":"§ 10106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of classified national security information","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall require the release or disclosure to any person or to the Commission of any classified national security information.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbf0e015c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/425/s7"},"text":"Pub. L. 97–425, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-07"},"text":"Jan. 7, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2205"},"text":"96 Stat. 2205","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
