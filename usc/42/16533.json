{"tag":"section","attrib":{"id":"idc01908d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533"},"text":null,"children":[{"tag":"num","attrib":{"value":"16533"},"text":"§ 16533.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hydrocarbon systems science talent expansion program for institutions of higher education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc01908d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this section are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc01908d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to address the decline in the number of and resources available to hydrocarbon systems science programs at institutions of higher education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01908da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the number of graduates with degrees in hydrocarbon systems science, an area of strategic importance to the economic competitiveness and energy security of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01908db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of hydrocarbon systems science","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc01908dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “hydrocarbon systems science” means a science involving natural gas or other petroleum exploration, development, or production.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01908dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “hydrocarbon systems science” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc01908de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" petroleum or reservoir engineering;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01908df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental geoscience;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01908e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" petrophysics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01908e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geophysics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01908e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geochemistry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01908e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" petroleum geology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01908e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ocean engineering;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01908e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental engineering;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01908e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" computer science, as computer science relates to a science described in this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01908e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/b/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hydrocarbon spill response and remediation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01908e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish, in accordance with this section, a program to expand and enhance institution of higher education hydrocarbon systems science educational capabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01908e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hydrocarbon systems science program expansion grants for institutions of higher education","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc01908ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award up to 3 competitive grants for each fiscal year to institutions of higher education that establish new academic degree programs in hydrocarbon systems science.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01908eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In evaluating grants under this subsection, the Secretary shall give priority to proposals that involve partnerships with the National Laboratories, including the National Energy Technology Laboratory, or other hydrocarbon systems scientific entities, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01908ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Criteria for a grant awarded under this subsection shall be based on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc01908ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential to attract new students to the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01908ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" academic rigor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01908ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability to offer hands-on learning opportunities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01908f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration and amount","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc01908f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant under this subsection may be up to 5 years in duration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01908f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An institution of higher education that receives a grant under this subsection shall be eligible for up to $1,000,000 for each year of the grant period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01908f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An institution of higher education that receives a grant under this subsection may use the grant to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc01908f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recruit and retain new faculty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01908f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop core and specialized course content;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01908f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/d/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage collaboration between faculty and researchers in the hydrocarbon systems science field; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01908f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/d/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support outreach efforts to recruit students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01908f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hydrocarbon systems science competitiveness grants for institutions of higher education","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc01908f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award up to 5 competitive grants for each fiscal year to institutions of higher education with existing academic degree programs that produce graduates in hydrocarbon systems science.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01908fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Criteria for a grant awarded under this subsection shall be based on the potential for increasing the number and academic quality of graduates in hydrocarbon systems sciences who enter into careers in natural gas and other petroleum exploration, development, and production related fields.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01908fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration and amount","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc01908fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant under this subsection may be up to 5 years in duration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01908fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An institution of higher education that receives a grant under this subsection shall be eligible for up to $500,000 for each year of the grant period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01908fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An institution of higher education that receives a grant under this subsection may use the grant to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc01908ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the number of graduates in the hydrocarbon systems sciences that enter into careers in the natural gas and other petroleum exploration, development, and production science fields;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0190900-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16533/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance the teaching of advanced natural gas and other petroleum exploration, development, and production technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc