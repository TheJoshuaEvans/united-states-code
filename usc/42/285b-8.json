{"tag":"section","attrib":{"id":"idb56c7ce9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"285b–8"},"text":"§ 285b–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congenital heart disease","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb56c7cea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–8/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Institute may expand, intensify, and coordinate research and related activities of the Institute with respect to congenital heart disease, which may include congenital heart disease research with respect to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb56c7ceb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–8/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" causation of congenital heart disease, including genetic causes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56c7cec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–8/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" long-term outcomes in individuals with congenital heart disease, including infants, children, teenagers, adults, and elderly individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56c7ced-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–8/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" diagnosis, treatment, and prevention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56c7cee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–8/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" studies using longitudinal data and retrospective analysis to identify effective treatments and outcomes for individuals with congenital heart disease; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56c7cef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–8/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying barriers to life-long care for individuals with congenital heart disease.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56c7cf0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–8/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of research activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Institute may coordinate research efforts related to congenital heart disease among multiple research institutions and may develop research networks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56c7cf1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–8/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minority and medically underserved communities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the activities described in this section, the Director of the Institute shall consider the application of such research and other activities to minority and medically underserved communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb56c7cf2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 425, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10411/b/2"},"text":"Pub. L. 111–148, title X, § 10411(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/989"},"text":"124 Stat. 989","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb56c7cf3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb56c7cf4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb56c7cf5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 285b–8, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tIV/s425"},"text":"act July 1, 1944, ch. 373, title IV, § 425","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tV/s504"},"text":"Pub. L. 103–43, title V, § 504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/160"},"text":"107 Stat. 160","children":[],"tail":", authorized appropriations to carry out this subpart, prior to repeal by "},{"tag":"ref","