{"tag":"section","attrib":{"id":"idbc7702b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3193"},"text":null,"children":[{"tag":"num","attrib":{"value":"3193"},"text":"§ 3193.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with other persons and agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc7702b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3193/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation on problems relating to employment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may consult with any persons, including representatives of labor, management, agriculture, and government, who can assist in addressing the problems of area and regional unemployment or underemployment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc7702ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3193/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation on administration of chapter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide for such consultation with interested Federal agencies as the Secretary determines to be appropriate in the performance of the duties of the Secretary under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc7702bb-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tV/s503"},"text":"Pub. L. 89–136, title V, § 503","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/tI/s102/a"},"text":"Pub. L. 105–393, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3610"},"text":"112 Stat. 3610","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc7702bc-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc7702bd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc7702be-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3193, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tV/s514"},"text":"Pub. L. 89–136, title V, § 514","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/423/s11"},"text":"Pub. L. 93–423, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-27"},"text":"Sept. 27, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1162"},"text":"88 Stat. 1162","children":[],"tail":", provided for the acquisition and disposal of excess property from the Administrator of General Services by the Federal cochairman of each regional action planning commission, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/94/519"},"text":"Pub. L. 94–519","children":[],"tail":", §§ 6, 9, "},{"tag":"date","attrib":{"date":"1976-10-17"},"text":"Oct. 17, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2456"},"text":"90 Stat. 2456","children":[],"tail":", 2457, effective "},{"tag":"date","attrib":{"date":"1977-10-17"},"text":"Oct. 17, 1977","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"te