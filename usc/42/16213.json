{"tag":"section","attrib":{"id":"idbffa0e9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16213"},"text":null,"children":[{"tag":"num","attrib":{"value":"16213"},"text":"§ 16213.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Micro-cogeneration energy technology","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbffa0e9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16213/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make competitive, merit-based grants to consortia for the development of micro-cogeneration energy technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffa0e9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16213/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The consortia shall explore—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffa0e9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16213/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of small-scale combined heat and power in residential heating appliances;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0e9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16213/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of excess power to operate other appliances within the residence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0e9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16213/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the supply of excess generated power to the power grid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbffa0ea0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s923"},"text":"Pub. L. 109–58, title IX, § 923","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/865"},"text":"119 Stat. 865","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
