{"tag":"section","attrib":{"id":"idb6432e26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–11"},"text":null,"children":[{"tag":"num","attrib":{"value":"300j–11"},"text":"§ 300j–11.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian Tribes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6432e27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–11/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the provisions of subsection (b), the Administrator—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6432e28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–11/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is authorized to treat Indian Tribes as States under this subchapter,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6432e29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–11/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may delegate to such Tribes primary enforcement responsibility for public water systems and for underground injection control, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6432e2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–11/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may provide such Tribes grant and contract assistance to carry out functions provided by this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6432e2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–11/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" EPA regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6432e2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–11/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific provisions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall, within 18 months after ","children":[{"tag":"date","attrib":{"date":"1986-06-19"},"text":"June 19, 1986","children":[],"tail":", promulgate final regulations specifying those provisions of this subchapter for which it is appropriate to treat Indian Tribes as States. Such treatment shall be authorized only if:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6432e2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–11/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Indian Tribe is recognized by the Secretary of the Interior and has a governing body carrying out substantial governmental duties and powers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6432e2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–11/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the functions to be exercised by the Indian Tribe are within the area of the Tribal Government’s jurisdiction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6432e2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–11/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Indian Tribe is reasonably expected to be capable, in the Administrator’s judgment, of carrying out the functions to be exercised in a manner consistent with the terms and purposes of this subchapter and of all applicable regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6432e30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–11/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions where treatment as State inappropriate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For any provision of this subchapter where treatment of Indian Tribes as identical to States is inappropriate, administratively infeasible or otherwise inconsistent with the purposes of this subchapter, the Administrator may include in the regulations promulgated under this section, other means for administering such provision in a manner that will achieve the purpose of the provision. Nothing in this section shall be construed to allow Indian Tribes to assume or maintain primary enforcement responsibility for public water systems or for underground injection control in a manner less protective of the health of persons than such responsibility may be assumed or maintained by a State. An Indian tribe ","children":[{"tag":"ref","attrib":{"idref":"fn002351"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002351"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" shall not be required to exercise criminal enforcement jurisdiction for purposes of complying with the preceding sentence."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6432e31-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIV, § 1451, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/339/tIII/s302/a"},"text":"Pub. L. 99–339, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-19"},"text":"June 19, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/665"},"text":"100 Stat. 665","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/182/tV/s501/f/6"},"text":"Pub. L. 104–182, title V, § 501(f)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-06"},"text":"Aug. 6, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1692"},"text":"110 Stat. 1692","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6432e32-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6432e33-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6432e34-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/182"},"text":"Pub. L. 104–182","children":[],"tail":" made technical amendment to section catchline and subsec. (a) designation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
