{"tag":"section","attrib":{"id":"idb5f200de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296b"},"text":null,"children":[{"tag":"num","attrib":{"value":"296b"},"text":"§ 296b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5f200df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts provided under a grant or contract awarded under this subchapter may be used for training program development and support, faculty development, model demonstrations, trainee support including tuition, books, program fees and reasonable living expenses during the period of training, technical assistance, workforce analysis, and dissemination of information, as appropriate to meet recognized nursing objectives, in accordance with this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5f200e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of effort","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to activities for which a grant awarded under this subchapter is to be expended, the entity shall agree to maintain expenditures of non-Federal amounts for such activities at a level that is not less than the level of such expenditures maintained by the entity for the fiscal year preceding the fiscal year for which the entity receives such a grant. Such Federal funds are intended to supplement, not supplant, existing non-Federal expenditures for such activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5f200e1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VIII, § 803, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/392/tI/s123/4"},"text":"Pub. L. 105–392, title I, § 123(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3564"},"text":"112 Stat. 3564","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tIII/s3404/a/3"},"text":"Pub. L. 116–136, div. A, title III, § 3404(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/392"},"text":"134 Stat. 392","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5f200e2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5f200e3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5f200e4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 296b, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tVIII/s803"},"text":"act July 1, 1944, ch. 373, title VIII, § 803","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1964-09-04"},"text":"Sept. 4, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"hr