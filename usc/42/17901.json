{"tag":"section","attrib":{"id":"idc03cbdd6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17901"},"text":null,"children":[{"tag":"num","attrib":{"value":"17901"},"text":"§ 17901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of Federal activities with adopted standards and implementation specifications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc03cbdd7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17901/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Spending on health information technology systems","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As each agency (as defined by the Director of the Office of Management and Budget, in consultation with the Secretary of Health and Human Services) implements, acquires, or upgrades health information technology systems used for the direct exchange of individually identifiable health information between agencies and with non-Federal entities, it shall utilize, where available, health information technology systems and products that meet standards and implementation specifications adopted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300jj–14"},"text":"section 300jj–14 of this title","children":[],"tail":", as added by section 13101."},{"tag":"ref","attrib":{"idref":"fn004279"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004279"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03cbdd8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17901/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal information collection activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to a standard or implementation specification adopted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300jj–14"},"text":"section 300jj–14 of this title","children":[],"tail":", as added by section 13101, the President shall take measures to ensure that Federal activities involving the broad collection and submission of health information are consistent with such standard or implementation specification, respectively, within three years after the date of such adoption."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03cbdd9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17901/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The definitions contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300jj"},"text":"section 300jj of this title","children":[],"tail":", as added by section 13101,"},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" shall apply for purposes of this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc03cbdda-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/dA/tXIII/s13111"},"text":"Pub. L. 111–5, div. A, title XIII, § 13111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/242"},"text":"123 Stat. 242","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc03cbddb-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc03cbddc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc03cbddd-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 13101, referred to in text, means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/dA/s13101"},"text":"section 13101 of div. A of Pub. L. 111–5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
