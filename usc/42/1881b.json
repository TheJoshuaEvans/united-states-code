{"tag":"section","attrib":{"id":"idbb9e078b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1881b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1881b"},"text":"§ 1881b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presidential awards for teaching excellence","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb9e078c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1881b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb9e078d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1881b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President is authorized to make Presidential Awards for Excellence in Mathematics and Science Teaching to kindergarten through grade 12 school teachers of mathematics and science who have demonstrated outstanding teaching ability in the field of teaching mathematics or science.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb9e078e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1881b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each year the President is authorized to make no fewer than 110 awards under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb9e078f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1881b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In selecting teachers for an award authorized by this subsection, the President shall select—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb9e0790-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1881b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" at least two teachers—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbb9e0791-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1881b/1/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from each of the several States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbb9e0792-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1881b/1/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbb9e0793-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1881b/1/C/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from the Commonwealth of Puerto Rico;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbb9e0794-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1881b/1/C/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from schools established outside the several States and the District of Columbia by any agency of the Federal Government for dependents of the employees of such agency; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb9e0795-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1881b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" at least one teacher—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbb9e0796-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1881b/1/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from the Commonwealth of the Northern Mariana Islands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbb9e0797-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1881b/1/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from American Samoa;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbb9e0798-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1881b/1/C/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from the Virgin Islands of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbb9e0799-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1881b/1/C/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from Guam.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb9e079a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1881b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President shall carry out this subsection, including the establishment of the selection procedures, after consultation with the Director and other appropriate officials of Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb9e079b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1881b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb9e079c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1881b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds to carry out this subsection for any fiscal year shall be made available from amounts appropriated pursuant to annual authorization of appropriations for the Foundation for Education and Human Resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb9e079d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1881b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts made available pursuant to subparagraph (A) shall be available for making awards under this subsection, for administrative expenses, for necessary travel by teachers selected under this subsection, and for special activities related to carrying out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb9e079e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/570/tI/s117/a"},"text":"Pub. L. 100–570, title I, § 117(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-31"},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2872"},"text":"102 Stat. 2872","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/207/tII/s202/c"},"text":"Pub. L. 105–207, title II, § 202(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-29"},"text":"July 29, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/874"},"text":"112 Stat. 874","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tIII/s10321/a"},"text":"Pub. L. 117–167, div. B, title III, § 10321(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1538"},"text":"136 Stat. 1538","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb9e079f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb9e07a0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb9e07a1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Science Foundation Authorization Act of 1988, and not as part of the National Science Foundation Act of 1950 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb9e07a2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Par. (1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10321/a/1/E"},"text":"Pub. L. 117–167, § 10321(a)(1)(E)","children":[],"tail":", which directed amendment of subpar. (B) by redesignating second sentence as subpar. (C), without specifying the paragraph to be amended, was executed in subpar. (B) of par. (1), to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10321/a/1/A"},"text":"Pub. L. 117–167, § 10321(a)(1)(A)","children":[],"tail":", which directed substitution of “110” for “108” in subpar. (B), without specifying the paragraph to be amended, was executed in subpar. (B) of par. (1), to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1)(B)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10321/a/1/B"},"text":"Pub. L. 117–167, § 10321(a)(1)(B)","children":[],"tail":", which directed the striking out of cl. (iv) of subpar. (B), without specifying the paragraph to be amended, was executed in subpar. (B) of par. (1), to reflect the probable intent of Congress. Prior to amendment, cl. (iv) read as follows: “from among the Trust Territory of the Pacific Islands, the Commonwealth of the Northern Mariana Islands, and other commonwealths, territories, and possessions of the United States; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10321/a/1/C"},"text":"Pub. L. 117–167, § 10321(a)(1)(C)","children":[],"tail":"–(E), which directed amendment of subpar. (B) by redesignating second sentence as (C), inserting cl. (i) designation before “at least two teachers—”, redesignating former cls. (i), (ii), (iii), and (v) of subpar. (B) as subcls. (I) to (IV), respectively, of cl. (i) of subpar. (C), and realigning margins, without specifying the paragraph to be amended, was executed in par. (1), to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1)(C)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10321/a/2"},"text":"Pub. L. 117–167, § 10321(a)(2)","children":[],"tail":", which directed the addition of cl. (ii) in subpar. (C), without specifying the paragraph to be amended, was executed in subpar. (C) of par. (1), to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Par. (1)(B)(v). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/207/s202/c/1"},"text":"Pub. L. 105–207, § 202(c)(1)","children":[],"tail":", added cl. (v) and struck out former cl. (v) which read as follows: “from the United States Department of Defense Dependents’ School.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/207/s202/c/2"},"text":"Pub. L. 105–207, § 202(c)(2)","children":[],"tail":", substituted “Education and Human Resources” for “Science and Engineering Education”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb9e07a3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbb9e07a4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tIII/s10321/b"},"text":"Pub. L. 117–167, div. B, title III, § 10321(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1538"},"text":"136 Stat. 1538","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/167/dB/tIII/s10321/b"},"text":"“The amendments made by subsection (a) [amending this section] shall apply with respect to awards made on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbb9e07a5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbb9e07a6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Termination of Trust Territory of the Pacific Islands","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For termination of Trust Territory of the Pacific Islands, see note set out preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"section 1681 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
