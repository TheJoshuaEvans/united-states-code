91-03-31"},"text":"March 31, 1991","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1990-09-30"},"text":"September 30, 1990","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/45"},"text":"Pub. L. 101–45","children":[],"tail":" amended subsec. (f) generally. Prior to amendment, subsec. (f) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) The Commission shall appoint an Executive Director of the Commission who shall be compensated at a rate fixed by the Commission, but which shall not exceed the rate established for level V of the Executive Schedule under title 5.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) In addition to the Executive Director, the Commission may appoint and fix the compensation of such personnel as it deems advisable, in accordance with the provisions of title 5 governing appointments to the competitive service, and the provisions of chapter 51 and subchapter III of chapter 53 of such title, relating to classification and General Schedule pay rates.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s6221/3"},"text":"Pub. L. 101–239, § 6221(3)","children":[],"tail":", substituted “through fiscal year 1991, such sums” for “such sums”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (k), (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"). "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/s6221/4"},"text":"Pub. L. 101–239, § 6221(4)","children":[],"tail":", added subsecs. (k) and ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s8201/1"},"text":"Pub. L. 100–647, § 8201(1)","children":[],"tail":", (2), substituted “"},{"tag":"date","attrib":{"date":"1990-03-31"},"t