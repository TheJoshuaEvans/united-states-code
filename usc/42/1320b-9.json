e, with certain exceptions, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/3/s3"},"text":"section 3 of Pub. L. 111–3","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396"},"text":"section 1396 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb84abda0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/432/tII/s264/h"},"text":"Pub. L. 103–432, title II, § 264(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4469"},"text":"108 Stat. 4469","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/432/tII/s264/h"},"text":"“Each amendment made by this section [amending this section and sections 602, 1382a, and 1383 of this title] shall take effect as if included in the provision of OBRA–1990 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":"] to which the amendment relates at the time such provision became law.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb84abda1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/432/tII/s264/d"},"text":"Pub. L. 103–432, title II, § 264(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4468"},"text":"108 Stat. 4468","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/432/tII/s264/d"},"text":"“Section 5057 of OBRA–1990 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":", amending this section], and the amendment made by such section, are hereby repealed, and section 1139(d) of the Social Security Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320b–9/d"},"text":"42 U.S.C. 1320b–9(d)","children":[],"tail":"] shall be applied and administered as if such section 5057 had never been enacted.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
