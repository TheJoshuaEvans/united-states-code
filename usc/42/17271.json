{"tag":"section","attrib":{"id":"idc03346fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271"},"text":null,"children":[{"tag":"num","attrib":{"value":"17271"},"text":"§ 17271.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carbon dioxide sequestration capacity assessment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc03346ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0334700-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “assessment” means the national assessment of onshore capacity for carbon dioxide completed under subsection (f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0334701-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capacity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “capacity” means the portion of a sequestration formation that can retain carbon dioxide in accordance with the requirements (including physical, geological, and economic requirements) established under the methodology developed under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0334702-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Engineered hazard","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “engineered hazard” includes the location and completion history of any well that could affect potential sequestration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0334703-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Risk","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “risk” includes any risk posed by geomechanical, geochemical, hydrogeological, structural, and engineered hazards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0334704-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior, acting through the Director of the United States Geological Survey.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0334705-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sequestration formation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “sequestration formation” means a deep saline formation, unmineable coal seam, or oil or gas reservoir that is capable of accommodating a volume of industrial carbon dioxide.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0334706-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Methodology","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", the Secretary shall develop a methodology for conducting an assessment under subsection (f), taking into consideration—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0334707-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the geographical extent of all potential sequestration formations in all States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0334708-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the capacity of the potential sequestration formations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0334709-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the injectivity of the potential sequestration formations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc033470a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of potential volumes of oil and gas recoverable by injection and sequestration of industrial carbon dioxide in potential sequestration formations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc033470b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the risk associated with the potential sequestration formations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc033470c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the work done to develop the Carbon Sequestration Atlas of the United States and Canada that was completed by the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc033470d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc033470e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal coordination","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc033470f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall consult with the Secretary of Energy and the Administrator of the Environmental Protection Agency on issues of data sharing, format, development of the methodology, and content of the assessment required under this section to ensure the maximum usefulness and success of the assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0334710-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy and the Administrator shall cooperate with the Secretary to ensure, to the maximum extent practicable, the usefulness and success of the assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0334711-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall consult with State geological surveys and other relevant entities to ensure, to the maximum extent practicable, the usefulness and success of the assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0334712-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" External review and publication","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On completion of the methodology under subsection (b), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0334713-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish the methodology and solicit comments from the public and the heads of affected Federal and State agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0334714-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a panel of individuals with expertise in the matters described in paragraphs (1) through (5) of subsection (b) composed, as appropriate, of representatives of Federal agencies, institutions of higher education, nongovernmental organizations, State organizations, industry, and international geoscience organizations to review the methodology and comments received under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0334715-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on completion of the review under paragraph (2), publish in the Federal Register the revised final methodology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0334716-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic updates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The methodology developed under this section shall be updated periodically (including at least once every 5 years) to incorporate new data as the data becomes available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0334717-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National assessment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0334718-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after the date of publication of the methodology under subsection (d)(1), the Secretary, in consultation with the Secretary of Energy and State geological surveys, shall complete a national assessment of capacity for carbon dioxide in accordance with the methodology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0334719-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geological verification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As part of the assessment under this subsection, the Secretary shall carry out a drilling program to supplement the geological data relevant to determining sequestration capacity of carbon dioxide in geological sequestration formations, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc033471a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" well log data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc033471b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" core data; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc033471c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fluid sample data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc033471d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnership with other drilling programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As part of the drilling program under paragraph (2), the Secretary shall enter, as appropriate, into partnerships with other entities to collect and integrate data from other drilling programs relevant to the sequestration of carbon dioxide in geological formations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc033471e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incorporation into NatCarb","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc033471f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On completion of the assessment, the Secretary of Energy and the Secretary of the Interior shall incorporate the results of the assessment using—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0334720-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/f/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the NatCarb database, to the maximum extent practicable; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0334721-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/f/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a new database developed by the Secretary of Energy, as the Secretary of Energy determines to be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0334722-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ranking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The database shall include the data necessary to rank potential sequestration sites for capacity and risk, across the United States, within each State, by formation, and within each basin.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0334723-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after the date on which the assessment is completed, the Secretary shall submit to the Committee on Energy and Natural Resources of the Senate and the Committee on Natural Resources of the House of Representatives a report describing the findings under the assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0334724-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic updates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The national assessment developed under this section shall be updated periodically (including at least once every 5 years) to support public and private sector decisionmaking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0334725-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17271/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $30,000,000 for the period of fiscal years 2008 through 2012.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0334726-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tVII/s711"},"text":"Pub. L. 110–140, title VII, § 711","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1710"},"text":"121 Stat. 1710","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0334727-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc0334728-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc0334729-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
