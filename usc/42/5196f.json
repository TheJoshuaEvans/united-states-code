{"tag":"section","attrib":{"id":"idbd2e9273-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5196f"},"text":null,"children":[{"tag":"num","attrib":{"value":"5196f"},"text":"§ 5196f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disaster related information services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd2e9274-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5196f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5151/a"},"text":"section 5151(a) of this title","children":[],"tail":", the Administrator of Federal "},{"tag":"ref","attrib":{"idref":"fn003416"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003416"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “the” probably should appear before “Federal”."}],"tail":" Emergency Management Agency shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd2e9275-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5196f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify, in coordination with State and local governments, population groups with limited English proficiency and take into account such groups in planning for an emergency or major disaster;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd2e9276-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5196f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure that information made available to individuals affected by a major disaster or emergency is made available in formats that can be understood by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd2e9277-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5196f/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" population groups identified under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd2e9278-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5196f/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals with disabilities or other special needs; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd2e9279-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5196f/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and maintain an informational clearinghouse of model language assistance programs and best practices for State and local governments in providing services related to a major disaster or emergency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd2e927a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5196f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Group size","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (a), the Administrator of Federal ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" Emergency Management Agency shall define the size of a population group."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd2e927b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tVI/s616"},"text":"Pub. L. 93–288, title VI, § 616","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s689e"},"text":"Pub. L. 109–295, title VI, § 689e","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1452"},"text":"120 Stat. 1452","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/351/s3/c/2"},"text":"Pub. L. 111–351, § 3(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3864"},"text":"124 Stat. 3864","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd2e927c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd2e927d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd2e927e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/351"},"text":"Pub. L. 111–351","children":[],"tail":" substituted “Administrator” for “Director” in subsecs. (a) and (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
