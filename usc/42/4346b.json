{"tag":"section","attrib":{"id":"idbcc82fd6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4346b"},"text":null,"children":[{"tag":"num","attrib":{"value":"4346b"},"text":"§ 4346b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures in support of international activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Council may make expenditures in support of its international activities, including expenditures for: (1) international travel; (2) activities in implementation of international agreements; and (3) the support of international exchange programs in the United States and in foreign countries.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbcc82fd7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190/tII/s208"},"text":"Pub. L. 91–190, title II, § 208","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/52/s3"},"text":"Pub. L. 94–52, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-07-03"},"text":"July 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/258"},"text":"89 Stat. 258","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
