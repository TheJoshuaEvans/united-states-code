{"tag":"section","attrib":{"id":"idbe0c7019-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385d"},"text":null,"children":[{"tag":"num","attrib":{"value":"7385d"},"text":"§ 7385d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election of remedy for beryllium employees and atomic weapons employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe0c701a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of tort cases filed before enactment of original law","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe0c701b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), if an otherwise eligible individual filed a tort case specified in subsection (d) before ","children":[{"tag":"date","attrib":{"date":"2000-10-30"},"text":"October 30, 2000","children":[],"tail":", such individual shall be eligible for compensation and benefits under part B."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe0c701c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If such tort case remained pending as of ","children":[{"tag":"date","attrib":{"date":"2001-12-28"},"text":"December 28, 2001","children":[],"tail":", and such individual does not dismiss such tort case before "},{"tag":"date","attrib":{"date":"2003-12-31"},"text":"December 31, 2003","children":[],"tail":", such individual shall not be eligible for such compensation or benefits."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0c701d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of tort cases filed between enactment of original law and enactment of 2001 amendments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe0c701e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), if an otherwise eligible individual filed a tort case specified in subsection (d) during the period beginning on ","children":[{"tag":"date","attrib":{"date":"2000-10-30"},"text":"October 30, 2000","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"December 28, 2001","children":[],"tail":", such individual shall not be eligible for such compensation or benefits."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe0c701f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If such individual dismisses such tort case on or before the last permissible date specified in paragraph (3), such individual shall be eligible for such compensation or benefits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe0c7020-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The last permissible date referred to in paragraph (2) is the later of the following dates:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe0c7021-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385d/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"2003-04-30"},"text":"April 30, 2003","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe0c7022-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385d/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The date that is 30 months after the date the individual first becomes aware that an illness covered by part B of a covered employee may be connected to the exposure of the covered employee in the performance of duty under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7384n"},"text":"section 7384n of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0c7023-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of tort cases filed after enactment of 2001 amendments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe0c7024-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If an otherwise eligible individual files a tort case specified in subsection (d) after ","children":[{"tag":"date","attrib":{"date":"2001-12-28"},"text":"December 28, 2001","children":[],"tail":", such individual shall not be eligible for such compensation or benefits if a final court decision is entered against such individual in such tort case."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe0c7025-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If such a final court decision is not entered, such individual shall nonetheless not be eligible for such compensation or benefits, except as follows: If such individual dismisses such tort case on or before the last permissible date specified in paragraph (3), such individual shall be eligible for such compensation and benefits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe0c7026-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385d/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The last permissible date referred to in paragraph (2) is the later of the following dates:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe0c7027-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385d/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"2003-04-30"},"text":"April 30, 2003","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe0c7028-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385d/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The date that is 30 months after the date the individual first becomes aware that an illness covered by part B of a covered employee may be connected to the exposure of the covered employee in the performance of duty under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7384n"},"text":"section 7384n of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0c7029-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered tort cases","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A tort case specified in this subsection is a tort case alleging a claim referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7385b"},"text":"section 7385b of this title","children":[],"tail":" against a beryllium vendor or atomic weapons employer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0c702a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Workers’ compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section does not apply to an administrative or judicial proceeding under a State or Federal workers’ compensation law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe0c702b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dC/tXXXVI/s3645"},"text":"Pub. L. 106–398, § 1 [div. C, title XXXVI, § 3645]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–510; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dC/tXXXI/s3151/a/5"},"text":"Pub. L. 107–107, div. C, title XXXI, § 3151(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1374"},"text":"115 Stat. 1374","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe0c702c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe0c702d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe0c702e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—Subsecs. (a) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" amended headings and text of subsecs. (a) to (d) generally, substituting present provisions for provisions relating to election to file suit in subsec. (a), applicable time limits in subsec. (b), dismissal of claims in subsec. (c), and dismissal of pending suit in subsec. (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
