{"tag":"section","attrib":{"id":"idc00d21d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16325"},"text":null,"children":[{"tag":"num","attrib":{"value":"16325"},"text":"§ 16325.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Science and Technology Scholarship Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc00d21d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16325/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to establish a Science and Technology Scholarship Program to award scholarships to individuals that is designed to recruit and prepare students for careers in the Department and National Laboratories.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00d21d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16325/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may require that an individual receiving a scholarship under this section serve as a full-time employee of the Department or a National Laboratory for a fixed period in return for receiving the scholarship.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc00d21d8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s984A"},"text":"Pub. L. 109–58, title IX, § 984A","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/908"},"text":"119 Stat. 908","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
