{"tag":"section","attrib":{"id":"idbf498336-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a"},"text":null,"children":[{"tag":"num","attrib":{"value":"11386a"},"text":"§ 11386a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf498337-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award funds to recipients through a national competition between geographic areas based on criteria established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf498338-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required criteria","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf498339-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The criteria established under subsection (a) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf49833a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the previous performance of the recipient regarding homelessness, including performance related to funds provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11372"},"text":"section 11372 of this title","children":[],"tail":" (except that recipients applying from geographic areas where no funds have been awarded under this part, or under parts C, D, E, or F of subchapter IV of this chapter, as in effect prior to "},{"tag":"date","attrib":{"date":"2009-05-20"},"text":"May 20, 2009","children":[],"tail":", shall receive full credit for performance under this subparagraph), measured by criteria that shall be announced by the Secretary, that shall take into account barriers faced by individual homeless people, and that shall include—"}],"tail":null},{"tag":"clause","attrib":{"id":"idbf49833b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the length of time individuals and families remain homeless;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf49833c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which individuals and families who leave homelessness experience additional spells of homelessness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf49833d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the thoroughness of grantees in the geographic area in reaching homeless individuals and families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf49833e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" overall reduction in the number of homeless individuals and families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf49833f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" jobs and income growth for homeless individuals and families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf498340-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/1/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" success at reducing the number of individuals and families who become homeless;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf498341-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/1/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other accomplishments by the recipient related to reducing homelessness; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf498342-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/1/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for collaborative applicants that have exercised the authority under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11382/j"},"text":"section 11382(j) of this title","children":[],"tail":" to serve families with children and youth defined as homeless under other Federal statutes, success in achieving the goals and outcomes identified in subsection (b)(1)(F);"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf498343-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the plan of the recipient, which shall describe—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf498344-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the number of individuals and families who become homeless will be reduced in the community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf498345-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the length of time that individuals and families remain homeless will be reduced;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf498346-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the recipient will collaborate with local education authorities to assist in the identification of individuals and families who become or remain homeless and are informed of their eligibility for services under part B of subchapter VI of this chapter (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11431"},"text":"42 U.S.C. 11431","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf498347-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the extent to which the recipient will—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbf498348-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/1/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address the needs of all relevant subpopulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf498349-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/1/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporate comprehensive strategies for reducing homelessness, including the interventions referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11386b/d"},"text":"section 11386b(d) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf49834a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/1/B/iv/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set quantifiable performance measures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf49834b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/1/B/iv/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set timelines for completion of specific tasks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf49834c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/1/B/iv/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify specific funding sources for planned activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf49834d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/1/B/iv/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify an individual or body responsible for overseeing implementation of specific strategies; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf49834e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the recipient proposes to exercise authority to use funds under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11382/j"},"text":"section 11382(j) of this title","children":[],"tail":", and if so, how the recipient will achieve the goals and outcomes identified in subsection (b)(1)(F);"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf49834f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the methodology of the recipient used to determine the priority for funding local projects under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11382/c/1"},"text":"section 11382(c)(1) of this title","children":[],"tail":", including the extent to which the priority-setting process—"}],"tail":null},{"tag":"clause","attrib":{"id":"idbf498350-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses periodically collected information and analysis to determine the extent to which each project has resulted in rapid return to permanent housing for those served by the project, taking into account the severity of barriers faced by the people the project serves;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf498351-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considers the full range of opinions from individuals or entities with knowledge of homelessness in the geographic area or an interest in preventing or ending homelessness in the geographic area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf498352-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is based on objective criteria that have been publicly announced by the recipient; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf498353-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is open to proposals from entities that have not previously received funds under this part;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf498354-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the amount of assistance to be provided under this part to the recipient will be supplemented with resources from other public and private sources, including mainstream programs identified by the Government Accountability Office in the two reports described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11313/a/7"},"text":"section 11313(a)(7) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf498355-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrated coordination by the recipient with the other Federal, State, local, private, and other entities serving individuals and families experiencing homelessness and at risk of homelessness in the planning and operation of projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf498356-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for collaborative applicants exercising the authority under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11382/j"},"text":"section 11382(j) of this title","children":[],"tail":" to serve homeless families with children and youth defined as homeless under other Federal statutes, program goals and outcomes, which shall include—"}],"tail":null},{"tag":"clause","attrib":{"id":"idbf498357-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/1/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preventing homelessness among the subset of such families with children and youth who are at highest risk of becoming homeless, as such term is defined for purposes of this subchapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf498358-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/1/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achieving independent living in permanent housing among such families with children and youth, especially those who have a history of doubled-up and other temporary housing situations or are living in a temporary housing situation due to lack of available and appropriate emergency shelter, through the provision of eligible assistance that directly contributes to achieving such results including assistance to address chronic disabilities, chronic physical health or mental health conditions, substance addiction, histories of domestic violence or childhood abuse, or multiple barriers to employment; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf498359-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other factors as the Secretary determines to be appropriate to carry out this part in an effective and efficient manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf49835a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the criteria required under paragraph (1), the criteria established under paragraph (1) shall also include the need within the geographic area for homeless services, determined as follows and under the following conditions:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf49835b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall inform each collaborative applicant, at a time concurrent with the release of the notice of funding availability for the grants, of the pro rata estimated grant amount under this part for the geographic area represented by the collaborative applicant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf49835c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf49835d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Formula","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such estimated grant amounts shall be determined by a formula, which shall be developed by the Secretary, by regulation, not later than the expiration of the 2-year period beginning upon ","children":[{"tag":"date","attrib":{"date":"2009-05-20"},"text":"May 20, 2009","children":[],"tail":", that is based upon factors that are appropriate to allocate funds to meet the goals and objectives of this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf49835e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Combinations or consortia","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For a collaborative applicant that represents a combination or consortium of cities or counties, the estimated need amount shall be the sum of the estimated need amounts for the cities or counties represented by the collaborative applicant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf49835f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations, the Secretary shall increase the estimated need amount for a geographic area if necessary to provide 1 year of renewal funding for all expiring contracts entered into under this part for the geographic area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf498360-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Homelessness counts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not require that communities conduct an actual count of homeless people other than those described in paragraphs (1) through (4) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11302/a"},"text":"section 11302(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf498361-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may adjust the formula described in subsection (b)(2) as necessary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf498362-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that each collaborative applicant has sufficient funding to renew all qualified projects for at least one year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf498363-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11386a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that collaborative applicants are not discouraged from replacing renewal projects with new projects that the collaborative applicant determines will better be able to meet the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf498364-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77/tIV/s427"},"text":"Pub. L. 100–77, title IV, § 427","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/22/dB/tIII/s1305/3"},"text":"Pub. L. 111–22, div. B, title III, § 1305(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-20"},"text":"May 20, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1690"},"text":"123 Stat. 1690","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf498365-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf498366-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","at