{"tag":"section","attrib":{"id":"idbe07b49c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n"},"text":null,"children":[{"tag":"num","attrib":{"value":"7381n"},"text":"§ 7381n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Summer institutes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe07b49d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe07b49e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible partner","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible partner” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe07b49f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the science, engineering, or mathematics department at an institution of higher education, acting in coordination with a school, department, or program of education at an institution of higher education that provides training for teachers and principals; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe07b4a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit entity with expertise in providing professional development for science, technology, engineering, or mathematics teachers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe07b4a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Summer institute","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “summer institute” means an institute, operated during the summer, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe07b4a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is hosted by a National Laboratory or an eligible partner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe07b4a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is operated for a period of not less than 2 weeks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe07b4a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes, as a component, a program that provides direct interaction between students and faculty, including personnel of 1 or more National Laboratories who have scientific expertise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe07b4a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for follow-up training, during the academic year, that is conducted in the classroom; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe07b4a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides hands-on science, technology, engineering, or mathematics laboratory experience for not less than 2 days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe07b4a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Summer institute programs authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe07b4a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs at the National Laboratories","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director, shall establish or expand programs of summer institutes at each of the National Laboratories to provide additional training to strengthen the science, technology, engineering, and mathematics teaching skills of teachers employed at public schools for kindergarten through grade 12, in accordance with the activities authorized under paragraphs (3) and (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe07b4a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs with eligible partners","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe07b4aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director, shall identify and provide assistance as described in subparagraph (C) to eligible partners to establish or expand programs of summer institutes that provide additional training to strengthen the science, technology, engineering, and mathematics teaching skills of teachers employed at public schools for kindergarten through grade 12, in accordance with paragraphs (3) and (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe07b4ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In identifying eligible partners under subparagraph (A), the Secretary shall require that partner institutions describe—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbe07b4ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the partner institution has the capability to administer the program in accordance with this section, which may include a description of any existing programs at the institution of the applicant that are targeted at education of science and mathematics teachers and the number of teachers graduated annually from the programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe07b4ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the partner institution will assist the National Laboratory in carrying out the activities described in paragraphs (3) and (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe07b4ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Consistent with sections 7381b and 7381c of this title, the Director shall make available funds authorized under this section to carry out a program using scientific and engineering staff of the National Laboratories, during which the staff—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbe07b4af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assists in providing training to teachers at summer institutes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe07b4b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses National Laboratory scientific equipment in the training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe07b4b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds authorized under this section shall be used for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe07b4b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creating opportunities for enhanced and ongoing professional development for teachers that improves the science, technology, engineering, and mathematics content knowledge of the teachers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe07b4b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" training to improve the ability of science, technology, engineering, and mathematics teachers to translate content knowledge and recent developments in pedagogy into classroom practice, including training to use curricula that are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbe07b4b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" based on scientific research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe07b4b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aligned with challenging State academic content standards;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe07b4b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training on the use and integration of technology in the classrooms; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe07b4b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supplemental and follow-up professional development activities as described in subsection (a)(2)(D).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe07b4b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional uses of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds authorized under this section may be used for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe07b4b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training and classroom materials to assist in carrying out paragraph (3);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe07b4ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expenses associated with scientific and engineering staff at the National Laboratories assisting in providing training to teachers at summer institutes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe07b4bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" instruction in the use and integration of data and assessments to inform and instruct classroom practice; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe07b4bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stipends and travel expenses for teachers participating in the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe07b4bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the maximum extent practicable, the Director shall ensure that each summer institute program authorized under subsection (b) provides training to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe07b4be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" teachers from a wide range of school districts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe07b4bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" teachers from high-need school districts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe07b4c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" teachers from groups underrepresented in the fields of science, technology, engineering, and mathematics teaching, including women and members of minority groups.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe07b4c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination and consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall consult and coordinate with the Secretary of Education and the Director of the National Science Foundation regarding the implementation of the programs authorized under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe07b4c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation and accountability plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe07b4c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall develop an evaluation and accountability plan for the activities funded under this section that measures the impact of the activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe07b4c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The evaluation and accountability plan shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe07b4c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measurable objectives to increase the number of science, technology, and mathematics teachers who participate in the summer institutes involved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe07b4c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measurable objectives for improved student academic achievement on State science, mathematics, and to the maximum extent applicable, technology and engineering assessments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe07b4c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall submit to Congress with the annual budget submission of the Secretary a report on how the activities assisted under this section improve the science, technology, engineering, and mathematics teaching skills of participating teachers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe07b4c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe07b4c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $15,000,000 for fiscal year 2008;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe07b4ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for fiscal year 2009;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe07b4cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $25,000,000 for fiscal year 2010; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe07b4cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381n/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $25,000,000 for each of fiscal years 2011 through 2013.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe07b4cd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dC/tXXXI/s3185"},"text":"Pub. L. 101–510, div. C, title XXXI, § 3185","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/69/tV/s5003/d/3"},"text":"Pub. L. 110–69, title V, § 5003(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-09"},"text":"Aug. 9, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/609"},"text":"121 Stat. 609","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/358/tIX/s901/b"},"text":"Pub. L. 111–358, title IX, § 901(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4044"},"text":"124 Stat. 4044","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe07b4ce-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe07b4cf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe07b4d0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (f)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358"},"text":"Pub. L. 111–358","children":[],"tail":" added par. (4)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
