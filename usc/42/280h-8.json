{"tag":"section","attrib":{"id":"idb54657ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"280h–8"},"text":"§ 280h–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recognizing early childhood trauma related to substance abuse","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb54657ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–8/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination of information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Health and Human Services shall disseminate information, resources, and, if requested, technical assistance to early childhood care and education providers and professionals working with young children on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54657ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–8/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ways to properly recognize children who may be impacted by trauma, including trauma related to substance use by a family member or other adult; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54657f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–8/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how to respond appropriately in order to provide for the safety and well-being of young children and their families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54657f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–8/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The information, resources, and technical assistance provided under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54657f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–8/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educate early childhood care and education providers and professionals working with young children on understanding and identifying the early signs and risk factors of children who might be impacted by trauma, including trauma due to exposure to substance use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54657f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–8/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suggest age-appropriate communication tools, procedures, and practices for trauma-informed care, including ways to prevent or mitigate the effects of trauma;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54657f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–8/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide options for responding to children impacted by trauma, including due to exposure to substance use, that consider the needs of the child and family, including recommending resources and referrals for evidence-based services to support such family; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54657f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–8/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote whole-family and multi-generational approaches to keep families safely together when it is in the best interest of the child.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54657f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–8/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services shall coordinate with the task force to develop best practices for trauma-informed identification, referral, and support authorized under section 7132 in disseminating the information, resources, and technical assistance described under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54657f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–8/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such information, resources, and if applicable, technical assistance, shall not be construed to amend the requirements under—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54657f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–8/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Child Care and Development Block Grant Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9858"},"text":"42 U.S.C. 9858","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54657f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–8/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Head Start Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9831"},"text":"42 U.S.C. 9831","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54657fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–8/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Individuals with Disabilities Education Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"20 U.S.C. 1400","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb54657fb-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/tVII/s7135"},"text":"Pub. L. 115–271, title VII, § 7135","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4055"},"text":"132 Stat. 4055","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb54657fc-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb54657fd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb54657fe-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 7132, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s7132"},"text":"section 7132 of Pub. L. 115–271","children":[],"tail":", title VII, "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4046"},"text":"132 Stat. 4046","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Child Care and Development Block Grant Act of 1990, referred to in subsec. (d)(1), is subchapter C (§ 658A et seq.) of chapter 8 of subtitle A of title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tV/s5082/2"},"text":"Pub. L. 101–508, title V, § 5082(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-236"},"text":"104 Stat. 1388–236","children":[],"tail":", which is classified generally to subchapter II–B (§ 9857 et seq.) of chapter 105 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9857/a"},"text":"section 9857(a) of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Head Start Act, referred to in subsec. (d)(2), is subchapter B (§ 635 et seq.) of chapter 8 of subtitle A of title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/499"},"text":"95 Stat. 499","children":[],"tail":", which is classified generally to subchapter II (§ 9831 et seq.) of chapter 105 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9801"},"text":"section 9801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Individuals with Disabilities Education Act, referred to in subsec. (d)(3), is title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230"},"text":"Pub. L. 91–230","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-04-13"},"text":"Apr. 13, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/175"},"text":"84 Stat. 175","children":[],"tail":", which is classified generally to chapter 33 (§ 1400 et seq.) of Title 20, Education. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"section 1400 of Title 20","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb54657ff-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Substance Use–Disorder Prevention that Promotes Opioid Recovery and Treatment for Patients and Communities Act, also known as the SUPPORT for Patients and Communities Act, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
