{"tag":"section","attrib":{"id":"idbff79dcd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161d"},"text":null,"children":[{"tag":"num","attrib":{"value":"16161d"},"text":"§ 16161d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clean hydrogen electrolysis program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbff79dce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff79dcf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electrolysis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “electrolysis” means a process that uses electricity to split water into hydrogen and oxygen.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79dd0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electrolyzer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “electrolyzer” means a system that produces hydrogen using electrolysis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79dd1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161d/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “program” means the program established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff79dd2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Secretary shall establish a research, development, demonstration, commercialization, and deployment program for purposes of commercialization to improve the efficiency, increase the durability, and reduce the cost of producing clean hydrogen using electrolyzers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff79dd3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The goals of the program are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff79dd4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce the cost of hydrogen produced using electrolyzers to less than $2 per kilogram of hydrogen by 2026; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79dd5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other goals the Secretary determines are appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff79dd6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program, the Secretary shall fund demonstration projects—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff79dd7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to demonstrate technologies that produce clean hydrogen using electrolyzers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79dd8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to validate information on the cost, efficiency, durability, and feasibility of commercial deployment of the technologies described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff79dd9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Focus","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program shall focus on research relating to, and the development, demonstration, and deployment of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff79dda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161d/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" low-temperature electrolyzers, including liquid-alkaline electrolyzers, membrane-based electrolyzers, and other advanced electrolyzers, capable of converting intermittent sources of electric power to clean hydrogen with enhanced efficiency and durability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79ddb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161d/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" high-temperature electrolyzers that combine electricity and heat to improve the efficiency of clean hydrogen production;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79ddc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161d/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced reversible fuel cells that combine the functionality of an electrolyzer and a fuel cell;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79ddd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161d/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" new highly active, selective, and durable electrolyzer catalysts and electro-catalysts that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff79dde-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161d/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" greatly reduce or eliminate the need for platinum group metals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79ddf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161d/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enable electrolysis of complex mixtures with impurities, including seawater;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79de0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161d/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modular electrolyzers for distributed energy systems and the bulk-power system (as defined in section 824","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(a) of title 16);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79de1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161d/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" low-cost membranes or electrolytes and separation materials that are durable in the presence of impurities or seawater;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79de2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161d/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improved component design and material integration, including with respect to electrodes, porous transport layers and bipolar plates, and balance-of-system components, to allow for scale-up and domestic manufacturing of electrolyzers at a high volume;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79de3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161d/e/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clean hydrogen storage technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79de4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161d/e/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" technologies that integrate hydrogen production with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff79de5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161d/e/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clean hydrogen compression and drying technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79de6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161d/e/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clean hydrogen storage; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79de7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161d/e/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transportation or stationary systems; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79de8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161d/e/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrated systems that combine hydrogen production with renewable power or nuclear power generation technologies, including hybrid systems with hydrogen storage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff79de9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161d/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants, contracts, cooperative agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff79dea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161d/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the program, the Secretary shall award grants, on a competitive basis, to eligible entities for projects that the Secretary determines would provide the greatest progress toward achieving the goal of the program described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79deb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161d/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts and cooperative agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the program, the Secretary may enter into contracts and cooperative agreements with eligible entities and Federal agencies for projects that the Secretary determines would further the purpose of the program described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79dec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161d/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility; applications","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff79ded-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161d/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The eligibility of an entity to receive a grant under paragraph (1), to enter into a contract or cooperative agreement under paragraph (2), or to receive funding for a demonstration project under subsection (d) shall be determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79dee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161d/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity desiring to receive a grant under paragraph (1), to enter into a contract or cooperative agreement under paragraph (2), or to receive funding for a demonstration project under subsection (d) shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff79def-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16161d/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary to carry out the program $1,000,000,000 for the period of fiscal years 2022 through 2026, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff79df0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVIII/s816"},"text":"Pub. L. 109–58, title VIII, § 816","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tIII/s40314/2"},"text":"Pub. L. 117–58, div. D, title III, § 40314(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1013"},"text":"135 Stat. 1013","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbff79df1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbff79df2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbff79df3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s816"},"text":"section 816 of Pub. L. 109–58","children":[],"tail":" was renumbered section 821 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s16165"},"text":"section 16165 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbff79df4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbff79df5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
