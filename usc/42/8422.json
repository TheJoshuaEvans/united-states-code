{"tag":"section","attrib":{"id":"idbe96ad85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8422"},"text":null,"children":[{"tag":"num","attrib":{"value":"8422"},"text":"§ 8422.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe96ad86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8422/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Generally","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person owning, operating, or proposing to operate one or more existing electric powerplants required to come into compliance with the prohibitions of this chapter shall on or before ","children":[{"tag":"date","attrib":{"date":"1980-01-01"},"text":"January 1, 1980","children":[],"tail":", and annually thereafter, submit to the Secretary a report identifying all such existing electric powerplants owned or operated by such person. Such report shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe96ad87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8422/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth the anticipated schedule for compliance with the applicable requirements and prohibitions by each such electric powerplant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe96ad88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8422/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indicate proposed or existing contracts or other commitments or good faith negotiations for such contracts or commitments for coal or another alternate fuel, equipment, or combinations thereof, which would enable such powerplant to comply with such prohibitions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe96ad89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8422/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify those electric powerplants, if any, for which application for temporary or permanent exemption from the prohibitions of this chapter may be filed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe96ad8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8422/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on implementation of section 8484 plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any electric utility required to submit a conservation plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8484"},"text":"section 8484 of this title","children":[],"tail":" shall annually submit to the Secretary a report identifying the steps taken during the preceding year to implement such plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe96ad8b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/620/tVII/s712"},"text":"Pub. L. 95–620, title VII, § 712","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3332"},"text":"92 Stat. 3332","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tX/s1023/b"},"text":"Pub. L. 97–35, title X, § 1023(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/617"},"text":"95 Stat. 617","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe96ad8c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe96ad8d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbe96ad8e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/620"},"text":"Pub. L. 95–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3289"},"text":"92 Stat. 3289","children":[],"tail":", known as the Powerplant and Industrial Fuel Use Act of 1978, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8301"},"text":"section 8301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe96ad8f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1981—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbe96ad90-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbe96ad91-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s1038"},"text":"section 1038 of Pub. L. 97–35","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6240"},"text":"section 6240 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
