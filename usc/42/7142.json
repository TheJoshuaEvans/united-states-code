{"tag":"section","attrib":{"id":"idbdf23092-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142"},"text":null,"children":[{"tag":"num","attrib":{"value":"7142"},"text":"§ 7142.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Atomic Museum and National Atomic Testing Museum","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdf23093-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recognition and status","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The museum operated by the Department of Energy and currently located at Building 20358 on Wyoming Avenue South near the corner of M street within the confines of the Kirtland Air Force Base (East), Albuquerque, New Mexico—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdf23094-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is recognized as the official atomic museum of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdf23095-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be known as the “National Atomic Museum”; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdf23096-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall have the sole right throughout the United States and its possessions to have and use the name “National Atomic Museum”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdf23097-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Volunteers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdf23098-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In operating the National Atomic Museum, the Secretary of Energy may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdf23099-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recruit, train, and accept the services of individuals without compensation as volunteers for, or in aid of, interpretive functions or other services or activities of and related to the museum; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdf2309a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to volunteers incidental expenses, such as nominal awards, uniforms, and transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdf2309b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraphs (3) and (4), a volunteer who is not otherwise employed by the Federal Government is not subject to laws relating to Federal employment, including those relating to hours of work, rates of compensation, leave, unemployment compensation, and Federal employee benefits, because of service as a volunteer under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdf2309c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of chapter 171 of title 28 (relating to tort claims), a volunteer under this subsection is considered a Federal employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdf2309d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of subchapter I of chapter 81 of title 5 (relating to compensation for work-related injuries), a volunteer under this subsection is considered an employee of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdf2309e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdf2309f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In operating the National Atomic Museum, the Secretary of Energy may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdf230a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept and use donations of money or gifts pursuant to section 7262 ","children":[{"tag":"ref","attrib":{"idref":"fn003560"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003560"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, if such gifts or money are designated in a written document signed by the donor as intended for the museum, and such donations or gifts are determined by the Secretary to be suitable and beneficial for use by the museum;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdf230a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate a retail outlet on the premises of the museum for the purpose of selling or distributing mementos, replicas of memorabilia, literature, materials, and other items of an informative, educational, and tasteful nature relevant to the contents of the museum; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdf230a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exhibit, perform, display, and publish information and materials concerning museum mementos, items, memorabilia, and replicas thereof in any media or place anywhere in the world, at reasonable fees or charges where feasible and appropriate, to substantially cover costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdf230a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The net proceeds of activities authorized under subparagraphs (B) and (C) of paragraph (1) may be used by the National Atomic Museum for activities of the museum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdf230a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recognition and status of National Atomic Testing Museum","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The museum operated by the Nevada Test Site Historical Foundation and located in Las Vegas, Nevada—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdf230a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is recognized as the official atomic testing museum of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdf230a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be known as the “National Atomic Testing Museum”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdf230a7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/dC/tXXXI/s3137"},"text":"Pub. L. 102–190, div. C, title XXXI, § 3137","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1578"},"text":"105 Stat. 1578","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/35/tII/s203/b/4"},"text":"Pub. L. 103–35, title II, § 203(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-05-31"},"text":"May 31, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/102"},"text":"107 Stat. 102","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dC/tXXXI/s3114"},"text":"Pub. L. 112–81, div. C, title XXXI, § 3114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1709"},"text":"125 Stat. 1709","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdf230a8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdf230a9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbdf230aa-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7262"},"text":"Section 7262 of this title","children":[],"tail":", referred to in subsec. (c)(1)(A), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/104/206/tV/s502"},"text":"Pub. L. 104–206, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3002"},"text":"110 Stat. 3002","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbdf230ab-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Defense Authorization Act for Fiscal Years 1992 and 1993, and not as part of the Department of Energy Organization Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbdf230ac-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s3114/1"},"text":"Pub. L. 112–81, § 3114(1)","children":[],"tail":", inserted “and National Atomic Testing Museum” after “Atomic Museum” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s3114/2"},"text":"Pub. L. 112–81, § 3114(2)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/35"},"text":"Pub. L. 103–35","children":[],"tail":" struck out comma after “Secretary of Energy” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
