{"tag":"section","attrib":{"id":"idbf28187e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10402"},"text":null,"children":[{"tag":"num","attrib":{"value":"10402"},"text":"§ 10402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf28187f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10402/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alaska Native","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Alaska Native” has the meaning given the term “Native” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1602"},"text":"section 1602 of title 43","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf281880-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10402/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dating violence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “dating violence” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12291/a"},"text":"section 12291(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf281881-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10402/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Domestic violence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “domestic violence” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12291/a"},"text":"section 12291(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf281882-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10402/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Family violence","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “family violence” means any act or threatened act of violence, including any forceful detention of an individual, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf281883-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10402/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" results or threatens to result in physical injury; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf281884-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10402/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is committed by a person against another individual (including an elderly individual) to or with whom such person—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf281885-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10402/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is related by blood;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf281886-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10402/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is or was related by marriage or is or was otherwise legally related; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf281887-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10402/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is or was lawfully residing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf281888-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10402/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian; Indian tribe; tribal organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “Indian”, “Indian tribe”, and “tribal organization” have the meanings given such terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf281889-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10402/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native Hawaiian","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Native Hawaiian” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7517"},"text":"section 7517 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf28188a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10402/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personally identifying information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “personally identifying information” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12291/a"},"text":"section 12291(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf28188b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10402/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf28188c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10402/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Shelter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “shelter” means the provision of temporary refuge and supportive services in compliance with applicable State law (including regulation) governing the provision, on a regular basis, of shelter, safe homes, meals, and supportive services to victims of family violence, domestic violence, or dating violence, and their dependents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf28188d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10402/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the several States, the District of Columbia, the Commonwealth of Puerto Rico, and, except as otherwise provided, Guam, American Samoa, the United States Virgin Islands, and the Commonwealth of the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf28188e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10402/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State Domestic Violence Coalition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “State Domestic Violence Coalition” means a statewide nongovernmental nonprofit private domestic violence organization that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf28188f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10402/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a membership that includes a majority of the primary-purpose domestic violence service providers in the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf281890-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10402/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has board membership that is representative of primary-purpose domestic violence service providers, and which may include representatives of the communities in which the services are being provided in the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf281891-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10402/11/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has as its purpose to provide education, support, and technical assistance to such service providers to enable the providers to establish and maintain shelter and supportive services for victims of domestic violence and their dependents; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf281892-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10402/11/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serves as an information clearinghouse, primary point of contact, and resource center on domestic violence for the State and supports the development of polices, protocols, and procedures to enhance domestic violence intervention and prevention in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf281893-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10402/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supportive services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “supportive services” means services for adult and youth victims of family violence, domestic violence, or dating violence, and dependents exposed to family violence, domestic violence, or dating violence, that are designed to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf281894-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10402/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet the needs of such victims of family violence, domestic violence, or dating violence, and their dependents, for short-term, transitional, or long-term safety; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf281895-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10402/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide counseling, advocacy, or assistance for victims of family violence, domestic violence, or dating violence, and their dependents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf281896-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10402/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribally designated official","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “tribally designated official” means an individual designated by an Indian tribe, tribal organization, or nonprofit private organization authorized by an Indian tribe, to administer a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10409"},"text":"section 10409 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf281897-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10402/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Underserved populations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “underserved populations” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12291/a"},"text":"section 12291(a) of this title","children":[],"tail":". For the purposes of this chapter, the Secretary has the same authority to determine whether a population is an underserved population as the Attorney General has under that section 12291(a) "},{"tag":"ref","attrib":{"idref":"fn003962"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003962"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf281898-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/457/tIII/s302"},"text":"Pub. L. 98–457, title III, § 302","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/320/tII/s201"},"text":"Pub. L. 111–320, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-20"},"text":"Dec. 20, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3484"},"text":"124 Stat. 3484","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9215/ii"},"text":"Pub. L. 114–95, title IX, § 9215(ii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2175"},"text":"129 Stat. 2175","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf281899-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf28189a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf28189b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 10402, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/457/tIII/s303"},"text":"Pub. L. 98–457, title III, § 303","ch