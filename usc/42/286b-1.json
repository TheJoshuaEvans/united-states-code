{"tag":"section","attrib":{"id":"idb581d959-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286b–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"286b–1"},"text":"§ 286b–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subpart—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb581d95a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286b–1/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “medical library” means a library related to the sciences related to health; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb581d95b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286b–1/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “sciences related to health” includes medicine, osteopathy, dentistry, and public health, and fundamental and applied sciences when related thereto.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb581d95c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 470, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/158/s2"},"text":"Pub. L. 99–158, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-20"},"text":"Nov. 20, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/860"},"text":"99 Stat. 860","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
