{"tag":"section","attrib":{"id":"idbf95ce97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12703"},"text":null,"children":[{"tag":"num","attrib":{"value":"12703"},"text":"§ 12703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes of Cranston-Gonzalez National Affordable Housing Act","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this Act are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf95ce98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12703/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to help families not owning a home to save for a down payment for the purchase of a home;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf95ce99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12703/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to retain wherever feasible as housing affordable to low-income families those dwelling units produced for such purpose with Federal assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf95ce9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12703/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to extend and strengthen partnerships among all levels of government and the private sector, including for-profit and nonprofit organizations, in the production and operation of housing affordable to low-income and moderate-income families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf95ce9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12703/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to expand and improve Federal rental assistance for very low-income families; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf95ce9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12703/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the supply of supportive housing, which combines structural features and services needed to enable persons with special needs to live with dignity and independence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf95ce9d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tI/s103"},"text":"Pub. L. 101–625, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4085"},"text":"104 Stat. 4085","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf95ce9e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf95ce9f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf95cea0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625"},"text":"Pub. L. 101–625","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4079"},"text":"104 Stat. 4079","children":[],"tail":", known as the Cranston-Gonzalez National Affordable Housing Act. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12701"},"text":"section 12701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
