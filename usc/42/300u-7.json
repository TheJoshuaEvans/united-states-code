{"tag":"section","attrib":{"id":"idb65d454b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"300u–7"},"text":"§ 300u–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Adolescent Health","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb65d454c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–7/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established an Office of Adolescent Health within the Office of the Assistant Secretary for Health, which office ","children":[{"tag":"ref","attrib":{"idref":"fn002373"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002373"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" shall be headed by a director "},{"tag":"ref","attrib":{"idref":"fn002373"},"text":"1","children":[],"tail":" appointed by the Secretary. The Secretary shall carry out this section acting through the Director of such Office."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb65d454d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–7/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to adolescent health, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb65d454e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–7/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" coordinate all activities within the Department of Health and Human Services that relate to disease prevention, health promotion, preventive health services, and health information and education with respect to the appropriate use of health care, including coordinating—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb65d454f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–7/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the design of programs, support for programs, and the evaluation of programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb65d4550-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–7/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the monitoring of trends;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb65d4551-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–7/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects of research (including multidisciplinary projects) on adolescent health; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb65d4552-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–7/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the training of health providers who work with adolescents, particularly nurse practitioners, physician assistants, and social workers;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65d4553-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–7/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate the activities described in paragraph (1) with similar activities in the private sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65d4554-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–7/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support projects, conduct research, and disseminate information relating to preventive medicine, health promotion, and physical fitness and sports medicine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb65d4555-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–7/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain demonstration projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb65d4556-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–7/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (b)(3), the Secretary may make grants to carry out demonstration projects for the purpose of improving adolescent health, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb65d4557-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–7/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects to train health care providers in providing services to adolescents; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb65d4558-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–7/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects to reduce the incidence of violence among adolescents, particularly violence related to teen dating, which shall include projects to develop and implement educational program to increase abuse awareness and prevention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65d4559-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–7/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out paragraph (1), there are authorized to be appropriated $8,000,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb65d455a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–7/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information clearinghouse","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out subsection (b), the Secretary shall establish and maintain a National Information Clearinghouse on Adolescent Health to collect and disseminate to health professionals and the general public information on adolescent health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb65d455b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–7/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out subsection (b), the Secretary shall develop a national plan for improving adolescent health. The plan shall be consistent with the applicable objectives established by the Secretary for the health status of the people of the United States for the year 2000, and shall be periodically reviewed, and as appropriate, revised. The plan, and any revisions in the plan, shall be submitted to the Committee on Energy and Commerce of the House of Representatives and the Committee on Labor and Human Resources of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb65d455c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–7/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adolescent health","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “adolescent health”, with respect to adolescents of all ethnic and racial groups, means all diseases, disorders, and conditions (including with respect to mental health)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb65d455d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–7/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unique to adolescents, or more serious or more prevalent in adolescents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65d455e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–7/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which the factors of medical risk or types of medical intervention are different for adolescents, or for which it is unknown whether such factors or types are different for adolescents; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65d455f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–7/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to which there has been insufficient clinical research involving adolescents as subjects or insufficient clinical data on adolescents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb65d4560-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–7/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency Work Group","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb65d4561-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–7/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish the Federal Interagency Work Group on Teen Dating Violence (referred to in this section as the “Work Group”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65d4562-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–7/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb65d4563-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–7/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2022-03-15"},"text":"March 15, 2022","children":[],"tail":", the Secretary shall appoint representatives to the Work Group from the Administration for Children and Families, the Centers for Disease Control and Prevention, the Health Resources and Services Administration, the Department of Education, the Department of Justice, and other Federal agencies as determined appropriate by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb65d4564-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–7/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Work Group shall consult with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb65d4565-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–7/g/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" experts at the State, Tribal, and local levels with relevant backgrounds in reducing and preventing the incidence of teen dating violence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb65d4566-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–7/g/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" victims of teen dating violence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb65d4567-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–7/g/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" family members of teens who were killed by a dating partner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65d4568-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–7/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Work Group shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb65d4569-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–7/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examine all Federal efforts directed towards reducing and preventing teen dating violence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb65d456a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–7/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify strategies, resources, and supports to improve State, Tribal, and local responses to the incidence of teen dating violence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb65d456b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–7/g/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations to Congress for improving Federal programs and efforts and coordination across such programs and efforts to reduce and prevent teen dating violence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb65d456c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–7/g/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations for educating middle and high school students on teen dating violence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65d456d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–7/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report to Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Work Group shall annually prepare and submit to the Secretary, the Committee on Health, Education, Labor, and Pensions of the Senate, and the Committee on Education and Labor of the House of Representatives, a report on the activities carried out by the Work Group under subsection (c), including recommendations to reduce and prevent teen dating violence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb65d456e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XVII, § 1708, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/531/tIII/s302"},"text":"Pub. L. 102–531, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3483"},"text":"106 Stat. 3483","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/tXIII/s1315/b"},"text":"Pub. L. 117–103, div. W, title XIII, § 1315(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/938"},"text":"136 Stat. 938","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb65d456f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb65d4570-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb65d4571-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 300u–7, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tXVII/s1708"},"text":"act July 1, 1944, ch. 373, title XVII, § 1708","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/95/626/tV/s502"},"text":"Pub. L. 95–626, title V, § 502","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3594"},"text":"92 Stat. 3594","children":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1979-07-10"},"text":"July 10, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/96/32/s6"},"text":"Pub. L. 96–32, § 6","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"ref","attrib":{"href":"/us/stat/93/84"},"text":"93 Stat. 84","children":[],"tail":", related to project grants for physical fitness improvement and research projects, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/98/551/s2/c"},"text":"Pub. L. 98–551, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2816"},"text":"98 Stat. 2816","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb65d4572-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s1315/b/1"},"text":"Pub. L. 117–103, § 1315(b)(1)","children":[],"tail":", added subsec. (c) and struck out former subsec. (c) which related to grants to carry out certain demonstration projects and authorizations of appropriations for fiscal years 1993 through 1997."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s1315/b/2"},"text":"Pub. L. 117–103, § 1315(b)(2)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb65d4573-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb65d4574-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Education and Labor of House of Representatives changed to Committee on Education and the Workforce of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Labor and Human Resources of Senate changed to Committee on Health, Education, Labor, and Pensions of Senate by Senate Resolution No. 20, One Hundred Sixth Congress, ","children":[{"tag":"date","attrib":{"date":"1999-01-19"},"text":"Jan. 19, 1999","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Energy and Commerce of House of Representatives treated as referring to Committee on Commerce of House of Representatives by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/14/s1/a"},"text":"section 1(a) of Pub. L. 104–14","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s21"},"text":"section 21 of Title 2","children":[],"tail":", The Congress. Committee on Commerce of House of Representatives changed to Committee on Energy and Commerce of House of Representatives, and jurisdiction over matters relating to securities and exchanges and insurance generally transferred to Committee on Financial Services of House of Representatives by House Resolution No. 5, One Hundred Seventh Congress, "},{"tag":"date","attrib":{"date":"2001-01-03"},"text":"Jan. 3, 2001","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb65d4575-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103"},"text":"Pub. L. 117–103","children":[],"tail":" not effective until Oct. 1 of the first fiscal year beginning after "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/s4/a"},"text":"section 4(a) of div. W of Pub. L. 117–103","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6851"},"text":"section 6851 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
