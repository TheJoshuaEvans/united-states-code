{"tag":"section","attrib":{"id":"idb5c72063-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ii–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"290ii–2"},"text":"§ 290ii–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations and enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5c72064-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ii–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2000-10-17"},"text":"October 17, 2000","children":[],"tail":", the Secretary, after consultation with appropriate State and local protection and advocacy organizations, physicians, facilities, and other health care professionals and patients, shall promulgate regulations that require facilities to which the Protection and Advocacy for Mentally Ill Individuals Act of 1986 "},{"tag":"ref","attrib":{"idref":"fn002249"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002249"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10801"},"text":"42 U.S.C. 10801","children":[],"tail":" et seq.) applies, to meet the requirements of subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5c72065-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ii–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations promulgated under subsection (a) shall require that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5c72066-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ii–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilities described in subsection (a) ensure that there is an adequate number of qualified professional and supportive staff to evaluate patients, formulate written individualized, comprehensive treatment plans, and to provide active treatment measures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5c72067-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ii–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate training be provided for the staff of such facilities in the use of restraints and any alternatives to the use of restraints; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5c72068-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ii–2/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such facilities provide complete and accurate notification of deaths, as required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290ii–1/a"},"text":"section 290ii–1(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5c72069-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ii–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A facility to which this part applies that fails to comply with any requirement of this part, including a failure to provide appropriate training, shall not be eligible for participation in any program supported in whole or in part by funds appropriated to any Federal department or agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5c7206a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 593, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dB/tXXXII/s3207"},"text":"Pub. L. 106–310, div. B, title XXXII, § 3207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1196"},"text":"114 Stat. 1196","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5c7206b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5c7206c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb5c7206d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Protection and Advocacy for Mentally Ill Individuals Act of 1986, referred to in subsec. (a), was ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/319"},"text":"Pub. L. 99–319","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-05-23"},"text":"May 23, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/478"},"text":"100 Stat. 478","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/pl/99/319"},"text":"Pub. L. 99–319","children":[],"tail":" was renamed the Protection and Advocacy for Individuals with Mental Illness Act by "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dB/tXXXII/s3206/a"},"text":"Pub. L. 106–310, div. B, title XXXII, § 3206(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1193"},"text":"114 Stat. 1193","children":[],"tail":", and is classified generally to chapter 114 (§ 10801 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10801"},"text":"section 10801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
