{"tag":"section","attrib":{"id":"idbf0b8fed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10005"},"text":null,"children":[{"tag":"num","attrib":{"value":"10005"},"text":"§ 10005.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Model statute","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In order to encourage the administration of accreditation and certification programs by the States, the Secretary shall prepare and transmit to the States a model statute for radiologic procedure safety. Such model statute shall provide that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf0b8fee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10005/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it shall be unlawful in a State for individuals to perform radiologic procedures unless such individuals are certified by the State to perform such procedures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf0b8fef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10005/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any educational requirements for certification of individuals to perform radiologic procedures shall be limited to educational programs accredited by the State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf0b8ff0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIX/s980"},"text":"Pub. L. 97–35, title IX, § 980","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/600"},"text":"95 Stat. 600","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
