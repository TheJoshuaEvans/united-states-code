{"tag":"section","attrib":{"id":"idbd4db397-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5320"},"text":null,"children":[{"tag":"num","attrib":{"value":"5320"},"text":"§ 5320.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Historic preservation requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd4db398-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5320/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to applications for assistance under section 5318 ","children":[{"tag":"ref","attrib":{"idref":"fn003432"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003432"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, the Secretary of the Interior, after consulting with the Secretary, shall prescribe and implement regulations concerning projects funded under section 5318 "},{"tag":"ref","attrib":{"idref":"fn003432"},"text":"1","children":[],"tail":" of this title and their relationship with division A of subtitle III and chapter 3125 of title 54."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd4db399-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5320/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions by State historic preservation officer and Secretary of the Interior","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In prescribing and implementing such regulations with respect to applications submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5318"},"text":"section 5318 of this title","children":[],"tail":" which identify any property pursuant to subsection (c)(4)(B) of such section, the Secretary of the Interior shall provide at least that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd4db39a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5320/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate State historic preservation officer (as determined in accordance with regulations prescribed by the Secretary of the Interior) shall, not later than 45 days after receiving information from the applicant relating to the identification of properties which will be affected by the project for which the application is made and which may meet the criteria established by the Secretary of the Interior for inclusion on the National Register of Historic Places (together with documentation relating to such inclusion), submit his or her comments, together with such other information considered necessary by the officer, to the applicant concerning such properties; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd4db39b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5320/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Interior shall, not later than 45 days after receiving from the applicant the information described in paragraph (1) and the comments submitted to the applicant in accordance with paragraph (1), make a determination as to whether any of the properties affected by the project for which the application is made is eligible for inclusion on the National Register of Historic Places.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd4db39c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5320/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations by Advisory Council on Historic Preservation providing for expeditious action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Council on Historic Preservation shall prescribe regulations providing for expeditious action by the Council in making its comments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s306108"},"text":"section 306108 of title 54","children":[],"tail":" in the case of properties which are included on, or eligible for inclusion on, the National Register of Historic Places and which are affected by a project for which an application is made under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5318"},"text":"section 5318 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd4db39d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/383/tI/s121"},"text":"Pub. L. 93–383, title I, § 121","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/399/tI/s110/c"},"text":"Pub. L. 96–399, title I, § 110(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-08"},"text":"Oct. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1620"},"text":"94 Stat. 1620","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIII/s308/b"},"text":"Pub. L. 97–35, title III, § 308(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/396"},"text":"95 Stat. 396","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/287/s5/k/4"},"text":"Pub. L. 113–287, § 5(k)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3270"},"text":"128 Stat. 3270","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd4db39e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd4db39f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd4db3a0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5318"},"text":"Section 5318 of this title","children":[],"tail":", referred to in subsec. (a), probably should be a reference to section 119 of the Housing and Community Development Act of 1974, "},{"tag":"ref","attrib":{"href":"/us/pl/93/383/tI/s119"},"text":"Pub. L. 93–383, title I, § 119","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/128/tI/s110/b"},"text":"Pub. L. 95–128, title I, § 110(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-10-12"},"text":"Oct. 12, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1125"},"text":"91 Stat. 1125","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5318"},"text":"section 5318 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd4db3a1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s5/k/4/A"},"text":"Pub. L. 113–287, § 5(k)(4)(A)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, text read as follows: “With respect to applications for assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5318"},"text":"section 5318 of this title","children":[],"tail":", the Secretary of the Interior, after consulting with the Secretary, shall prescribe and implement regulations concerning projects funded under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5318"},"text":"section 5318 of this title","children":[],"tail":" and their relationship with—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ‘An Act to establish a program for the preservation of additional historic properties throughout the Nation, and for other purposes’, approved ","children":[{"tag":"date","attrib":{"date":"1966-10-14"},"text":"October 14, 1966","children":[],"tail":", as amended; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ‘An Act to provide for the preservation of historical and archaeological data (including relics and specimens) which might otherwise be lost as a result of the construction of a dam’, approved ","children":[{"tag":"date","attrib":{"date":"1960-06-27"},"text":"June 27, 1960","children":[],"tail":", as amended.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/287/s5/k/4/B"},"text":"Pub. L. 113–287, § 5(k)(4)(B)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t54/s306108"},"text":"section 306108 of title 54","children":[],"tail":"” for “section 106 of the Act referred to in subsection (a)(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" substituted “subsection (c)(4)(B)” for “subsection (c)(7)(B)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd4db3a2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd4db3a3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" effective on effective date of regulations implementing such amendments, see "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s308/c"},"text":"section 308(c) of Pub. L. 97–35","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5318"},"text":"section 5318 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
