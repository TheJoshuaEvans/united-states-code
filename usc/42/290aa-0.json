{"tag":"section","attrib":{"id":"idb59c3f29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0"},"text":null,"children":[{"tag":"num","attrib":{"value":"290aa–0"},"text":"§ 290aa–0.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Mental Health and Substance Use Policy Laboratory","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb59c3f2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be established within the Administration a National Mental Health and Substance Use Policy Laboratory (referred to in this section as the “Laboratory”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb59c3f2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Laboratory shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb59c3f2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continue to carry out the authorities and activities that were in effect for the Office of Policy, Planning, and Innovation as such Office existed prior to ","children":[{"tag":"date","attrib":{"date":"2016-12-13"},"text":"December 13, 2016","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb59c3f2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify, coordinate, and facilitate the implementation of policy changes likely to have a significant effect on mental health, mental illness, recovery supports, and the prevention and treatment of substance use disorder services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb59c3f2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work with the Center for Behavioral Health Statistics and Quality to collect, as appropriate, information from grantees under programs operated by the Administration in order to evaluate and disseminate information on evidence-based practices, including culturally and linguistically appropriate services, as appropriate, and service delivery models;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb59c3f2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide leadership in identifying and coordinating policies and programs, including evidence-based programs, related to mental and substance use disorders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb59c3f30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" periodically review programs and activities operated by the Administration relating to the diagnosis or prevention of, treatment for, and recovery from, mental and substance use disorders to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb59c3f31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify any such programs or activities that are duplicative;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3f32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify any such programs or activities that are not evidence-based, effective, or efficient; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3f33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" formulate recommendations for coordinating, eliminating, or improving programs or activities identified under subparagraph (A) or (B) and merging such programs or activities into other successful programs or activities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb59c3f34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" issue and periodically update information for entities applying for grants or cooperative agreements from the Substance Abuse and Mental Health Services Administration in order to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb59c3f35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage the implementation and replication of evidence-based practices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3f36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance to applicants for funding, including with respect to justifications for such programs and activities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb59c3f37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out other activities as deemed necessary to continue to encourage innovation and disseminate evidence-based programs and practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb59c3f38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evidence-based practices and service delivery models","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb59c3f39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (b)(3), the Laboratory—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb59c3f3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may give preference to models that improve—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb59c3f3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the coordination between mental health and physical health providers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb59c3f3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the coordination among such providers and the justice and corrections system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb59c3f3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost effectiveness, quality, effectiveness, and efficiency of health care services furnished to adults with a serious mental illness, children with a serious emotional disturbance, or individuals in a mental health crisis; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3f3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include clinical protocols and practices that address the needs of individuals with early serious mental illness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb59c3f3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Laboratory shall consult with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb59c3f40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chief Medical Officer appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290aa/g"},"text":"section 290aa(g) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3f41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of the National Institute of Mental Health, the National Institute on Drug Abuse, and the National Institute on Alcohol Abuse and Alcoholism, on an ongoing basis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3f42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other appropriate Federal agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3f43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clinical and analytical experts with expertise in psychiatric medical care and clinical psychological care, health care management, education, corrections health care, and mental health court systems, as appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3f44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other individuals and agencies as determined appropriate by the Assistant Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb59c3f45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline for beginning implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Laboratory shall begin implementation of this section not later than ","children":[{"tag":"date","attrib":{"date":"2018-01-01"},"text":"January 1, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb59c3f46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promoting innovation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb59c3f47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary, in coordination with the Laboratory, may award grants to States, local governments, Indian Tribes or Tribal organizations (as such terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"), educational institutions, and nonprofit organizations to develop evidence-based interventions, including culturally and linguistically appropriate services, as appropriate, for—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb59c3f48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" evaluating a model that has been scientifically demonstrated to show promise, but would benefit from further applied development, for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb59c3f49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancing the prevention, diagnosis, intervention, and treatment of, and recovery from, mental illness, serious emotional disturbances, substance use disorders, and co-occurring illness or disorders; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb59c3f4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrating or coordinating physical health services and mental and substance use disorders services; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3f4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" expanding, replicating, or scaling evidence-based programs across a wider area to enhance effective screening, early diagnosis, intervention, and treatment with respect to mental illness, serious mental illness, serious emotional disturbances, and substance use disorders, primarily by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb59c3f4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applying such evidence-based programs to the delivery of care, including by training staff in effective evidence-based treatments; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb59c3f4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrating such evidence-based programs into models of care across specialties and jurisdictions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb59c3f4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under this subsection, the Assistant Secretary shall, as appropriate, consult with the Chief Medical Officer, appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290aa/g"},"text":"section 290aa(g) of this title","children":[],"tail":", the advisory councils described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290aa–1"},"text":"section 290aa–1 of this title","children":[],"tail":", the National Institute of Mental Health, the National Institute on Drug Abuse, and the National Institute on Alcohol Abuse and Alcoholism, as appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb59c3f4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–0/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out this section, there is authorized to be appropriated $10,000,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb59c3f50-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 501A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tVII/s7001"},"text":"Pub. L. 114–255, div. B, title VII, § 7001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1220"},"text":"130 Stat. 1220","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/271/tVII/s7111"},"text":"Pub. L. 115–271, title VII, § 7111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4042"},"text":"132 Stat. 4042","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tI/s1121/a"},"text":"Pub. L. 117–328, div. FF, title I, § 1121(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5647"},"text":"136 Stat. 5647","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb59c3f51-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb59c3f52-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb59c3f53-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1121/a/1"},"text":"Pub. L. 117–328, § 1121(a)(1)","children":[],"tail":", substituted “Indian Tribes or Tribal organizations” for “Indian tribes or tribal organizations” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1121/a/2"},"text":"Pub. L. 117–328, § 1121(a)(2)","children":[],"tail":", struck out par. (3) which authorized appropriations for grants for fiscal years 2018 through 2020."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1121/a/3"},"text":"Pub. L. 117–328, § 1121(a)(3)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271"},"text":"Pub. L. 115–271","children":[],"tail":" added par. (6) and redesignated former par. (6) as (7)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
