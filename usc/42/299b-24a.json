{"tag":"section","attrib":{"id":"idb602c9d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24a"},"text":null,"children":[{"tag":"num","attrib":{"value":"299b–24a"},"text":"§ 299b–24a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities regarding women’s health","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb602c9d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Office of the Director, an Office of Women’s Health and Gender-Based Research (referred to in this section as the “Office”). The Office shall be headed by a director who shall be appointed by the Director of Healthcare and Research Quality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb602c9d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The official designated under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb602c9d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report to the Director on the current Agency level of activity regarding women’s health, across, where appropriate, age, biological, and sociocultural contexts, in all aspects of Agency work, including the development of evidence reports and clinical practice protocols and the conduct of research into patient outcomes, delivery of health care services, quality of care, and access to health care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb602c9d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish short-range and long-range goals and objectives within the Agency for research important to women’s health and, as relevant and appropriate, coordinate with other appropriate offices on activities within the Agency that relate to health services and medical effectiveness research, for issues of particular concern to women;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb602c9d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify projects in women’s health that should be conducted or supported by the Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb602c9da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with health professionals, nongovernmental organizations, consumer organizations, women’s health professionals, and other individuals and groups, as appropriate, on Agency policy with regard to women; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb602c9db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as a member of the Department of Health and Human Services Coordinating Committee on Women’s Health (established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s237a/b/4"},"text":"section 237a(b)(4) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb602c9dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–24a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this section, there are authorized to be appropriated such sums as may be necessary for each of the fiscal years 2010 through 2014.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb602c9dd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IX, § 925, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIII/s3509/e/2"},"text":"Pub. L. 111–148, title III, § 3509(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/534"},"text":"124 Stat. 534","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb602c9de-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb602c9df-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb602c9e0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 925 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was renumbered section 926 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s299b–25"},"text":"section 299b–25 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 925 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was renumbered section 945 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s299c–4"},"text":"section 299c–4 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 925 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s299c–4"},"text":"section 299c–4 of this title","children":[],"tail":" prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/106/129"},"text":"Pub. L. 106–129","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
