{"tag":"section","attrib":{"id":"idbfc5928b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13521"},"text":null,"children":[{"tag":"num","attrib":{"value":"13521"},"text":"§ 13521.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy on major construction projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfc5928c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13521/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report and management plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall submit to the Congress a report and management plan for any major construction project involving $100,000,000 or more, prior to the expenditure of those funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc5928d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13521/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Expenditure of funds for a project described in subsection (a) may be made after a period of 30 calendar days (not including any day on which either House of Congress is not in session because of adjournment of more than 3 calendar days prior to a day certain) has passed after receipt of the report and management plan by Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfc5928e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXXIII/s2301"},"text":"Pub. L. 102–486, title XXIII, § 2301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3092"},"text":"106 Stat. 3092","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
