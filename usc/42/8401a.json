{"tag":"section","attrib":{"id":"idbe94642c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8401a"},"text":null,"children":[{"tag":"num","attrib":{"value":"8401a"},"text":"§ 8401a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Local government” defined","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8401"},"text":"section 8401 of this title","children":[],"tail":", the term “local government” shall include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe94642d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8401a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any county, parish, city, town, township, village or other general purpose political subdivision of a State with the power to levy taxes and expend Federal, State, and local funds and exercise governmental powers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe94642e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8401a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which (in whole or in part) is located in, or has authority over the energy impacted area: ","children":[{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That such term shall include a public or private nonprofit corporation, or a school, water, sewer, highway, or other public special purpose district, authority, or body, with the concurrence of the Governor: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That such term shall be applicable to all applications for assistance received since the effective date of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8401"},"text":"section 8401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe94642f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/514/tII/s201"},"text":"Pub. L. 96–514, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2975"},"text":"94 Stat. 2975","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe946430-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe946431-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbe946432-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8401"},"text":"section 8401 of this title","children":[],"tail":", referred to in par. (2), see "},{"tag":"ref","attrib":{"href":"/us/pl/95/620/s901"},"text":"section 901 of Pub. L. 95–620","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8301"},"text":"section 8301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbe946433-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Department of the Interior and Related Agencies Appropriations Act, 1981, and not as part of the Powerplant and Industrial Fuel Use Act of 1978 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
