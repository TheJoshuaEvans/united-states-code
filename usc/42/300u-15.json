{"tag":"section","attrib":{"id":"idb65fb771-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–15"},"text":null,"children":[{"tag":"num","attrib":{"value":"300u–15"},"text":"§ 300u–15.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research on optimizing the delivery of public health services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb65fb772-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–15/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services (referred to in this section as the “Secretary”), acting through the Director of the Centers for Disease Control and Prevention, shall provide funding for research in the area of public health services and systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb65fb773-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–15/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements of research","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Research supported under this section shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb65fb774-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–15/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examining evidence-based practices relating to prevention, with a particular focus on high priority areas as identified by the Secretary in the National Prevention Strategy or Healthy People 2020, and including comparing community-based public health interventions in terms of effectiveness and cost;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65fb775-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–15/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyzing the translation of interventions from academic settings to real world settings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65fb776-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–15/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying effective strategies for organizing, financing, or delivering public health services in real world community settings, including comparing State and local health department structures and systems in terms of effectiveness and cost.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb65fb777-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–15/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing partnerships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Research supported under this section shall be coordinated with the Community Preventive Services Task Force and carried out by building on existing partnerships within the Federal Government while also considering initiatives at the State and local levels and in the private sector.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb65fb778-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–15/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, on an annual basis, submit to Congress a report concerning the activities and findings with respect to research supported under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb65fb779-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIV/s4301"},"text":"Pub. L. 111–148, title IV, § 4301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/578"},"text":"124 Stat. 578","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb65fb77a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb65fb77b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb65fb77c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Patient Protection and Affordable Care Act, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
