{"tag":"section","attrib":{"id":"idbff2e2cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16102"},"text":null,"children":[{"tag":"num","attrib":{"value":"16102"},"text":"§ 16102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Diesel fueled vehicles","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbff2e2ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of tier 2 emission standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “tier 2 emission standards” means the motor vehicle emission standards that apply to passenger cars, light trucks, and larger passenger vehicles manufactured after the 2003 model year, as issued on ","children":[{"tag":"date","attrib":{"date":"2000-02-10"},"text":"February 10, 2000","children":[],"tail":", by the Administrator of the Environmental Protection Agency under sections 7521 and 7545 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff2e2cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Diesel combustion and after-treatment technologies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall accelerate efforts to improve diesel combustion and after-treatment technologies for use in diesel fueled motor vehicles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff2e2d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out subsection (b) with a view toward achieving the following goals:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff2e2d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16102/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Developing and demonstrating diesel technologies that, not later than 2010, meet the following standards:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff2e2d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16102/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tier 2 emission standards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e2d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16102/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The heavy-duty emissions standards of 2007 that are applicable to heavy-duty vehicles under regulations issued by the Administrator of the Environmental Protection Agency as of ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e2d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16102/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Developing the next generation of low-emission, high efficiency diesel engine technologies, including homogeneous charge compression ignition technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff2e2d5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVII/s754"},"text":"Pub. L. 109–58, title VII, § 754","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/828"},"text":"119 Stat. 828","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
