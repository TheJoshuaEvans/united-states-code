{"tag":"section","attrib":{"id":"idbfcf070d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14401"},"text":null,"children":[{"tag":"num","attrib":{"value":"14401"},"text":"§ 14401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purpose","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfcf070e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14401/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfcf070f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14401/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Federal Government provides financial support for the provision of and payment for health care services, as well as for advocacy activities to protect the rights of individuals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfcf0710-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14401/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assisted suicide, euthanasia, and mercy killing have been criminal offenses throughout the United States and, under current law, it would be unlawful to provide services in support of such illegal activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfcf0711-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14401/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Because of recent legal developments, it may become lawful in areas of the United States to furnish services in support of such activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfcf0712-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14401/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Congress is not providing Federal financial assistance in support of assisted suicide, euthanasia, and mercy killing and intends that Federal funds not be used to promote such activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfcf0713-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14401/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the principal purpose of this chapter to continue current Federal policy by providing explicitly that Federal funds may not be used to pay for items and services (including assistance) the purpose of which is to cause (or assist in causing) the suicide, euthanasia, or mercy killing of any individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfcf0714-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/12/s2"},"text":"Pub. L. 105–12, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-04-30"},"text":"Apr. 30, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/23"},"text":"111 Stat. 23","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfcf0715-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfcf0716-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfcf0717-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/12"},"text":"Pub. L. 105–12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-04-30"},"text":"Apr. 30, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/23"},"text":"111 Stat. 23","children":[],"tail":", known as the Assisted Suicide Funding Restriction Act of 1997. For complete classification of this Act to the Code, see Short Title note set out below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbfcf0718-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbfcf0719-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/12/s11"},"text":"Pub. L. 105–12, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-04-30"},"text":"Apr. 30, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/29"},"text":"111 Stat. 29","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/12/s11"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The provisions of this Act [see Short Title note below] (and the amendments made by this Act) take effect upon its enactment [","children":[{"tag":"date","attrib":{"date":"1997-04-30"},"text":"Apr. 30, 1997","children":[],"tail":"] and apply, subject to subsection (b), to Federal payments made pursuant to obligations incurred after the date of the enactment of this Act for items and services provided on or after such date."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application to Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Such provisions shall apply with respect to contracts entered into, renewed, or extended after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1997-04-30"},"text":"Apr. 30, 1997","children":[],"tail":"] and shall also apply to a contract entered into before such date to the extent permitted under such contract.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idbfcf071a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/12/s1/a"},"text":"Pub. L. 105–12, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-04-30"},"text":"Apr. 30, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/23"},"text":"111 Stat. 23","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/12/s1/a"},"text":"“This Act [enacting this chapter, section 238","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title, "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1621x"},"text":"section 1621x of Title 25","children":[],"tail":", Indians, and "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1707"},"text":"section 1707 of Title 38","children":[],"tail":", Veterans’ Benefits, amending sections 295, 701, 1395y, 1395cc, 1396a, 1396b, 1397d, 2996f, 6022, 6042, 6062, 6082, and 10805 of this title, "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8902"},"text":"section 8902 of Title 5","children":[],"tail":", Government Organization and Employees, "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1073"},"text":"section 1073 of Title 10","children":[],"tail":", Armed Forces, "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s4005"},"text":"section 4005 of Title 18","children":[],"tail":", Crimes and Criminal Procedure, "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2504"},"text":"section 2504 of Title 22","children":[],"tail":", Foreign Relations and Intercourse, and "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s794e"},"text":"section 794e of Title 29","children":[],"tail":", Labor, and enacting provisions set out as notes under this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s295"},"text":"section 295 of this title","children":[],"tail":"] may be cited as the ‘Assisted Suicide Funding Restriction Act of 1997’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbfcf071b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of Conforming Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/12/s9/p"},"text":"Pub. L. 105–12, § 9(p)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-04-30"},"text":"Apr. 30, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/29"},"text":"111 Stat. 29","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/12/s9/p"},"text":"“The fact that a law is not amended under this section [enacting section 238","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title, "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1621x"},"text":"section 1621x of Title 25","children":[],"tail":", Indians, and "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1707"},"text":"section 1707 of Title 38","children":[],"tail":", Veterans’ Benefits, amending sections 701, 1395y, 1395cc, 1396a, 1396b, 1397d, 2996f, 6022, 6042, 6062, 6082, and 10805 of this title, "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8902"},"text":"section 8902 of Title 5","children":[],"tail":", Government Organization and Employees, "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1073"},"text":"section 1073 of Title 10","children":[],"tail":", Armed Forces, "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s4005"},"text":"section 4005 of Title 18","children":[],"tail":", Crimes and Criminal Procedure, "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2504"},"text":"section 2504 of Title 22","children":[],"tail":", Foreign Relations and Intercourse, and "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s794e"},"text":"section 794e of Title 29","children":[],"tail":", Labor] shall not be construed as indicating that the provisions of this Act [see Short Title note above] do not apply to such a law.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
