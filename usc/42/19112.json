{"tag":"section","attrib":{"id":"idc07d2102-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19112"},"text":null,"children":[{"tag":"num","attrib":{"value":"19112"},"text":"§ 19112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entrepreneurial fellowships","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc07d2103-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director, acting through the Directorate for Technology, Innovation, and Partnerships, shall award fellowships to scientists and engineers to help develop leaders capable of maturing promising ideas and technologies from lab to market or other use and forge connections between academic research and the government, industry, financial sectors, and other end users.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07d2104-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An applicant for a fellowship under this section shall submit to the Director an application at such time, in such manner, and containing such information as the Director may require. At a minimum, the Director shall require that applicants—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc07d2105-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19112/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have completed a doctoral degree in a STEM field no more than 5 years prior to the date of the application, or have otherwise demonstrated significant postbaccalaureate scientific research experience and are considered early career, according to requirements established by the Director; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07d2106-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19112/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have included in the application a proposal for how the fellow will be embedded in a host institution’s research environment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07d2107-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19112/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall conduct program outreach to recruit fellowship applicants—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc07d2108-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19112/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from diverse research institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07d2109-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19112/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from all regions of the country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07d210a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19112/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from groups historically underrepresented in STEM fields.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07d210b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19112/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may enter into an agreement with a qualified third-party entity to administer the fellowships, subject to the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07d210c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19112/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Director a total of $125,000,000 for fiscal years 2023 through 2027, to carry out the activities outlined in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc07d210d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tIII/s10392"},"text":"Pub. L. 117–167, div. B, title III, § 10392","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1588"},"text":"136 Stat. 1588","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
