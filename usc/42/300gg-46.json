{"tag":"section","attrib":{"id":"idb6b7e90f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–46"},"text":null,"children":[{"tag":"num","attrib":{"value":"300gg–46"},"text":"§ 300gg–46.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure to enrollees of individual market coverage","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6b7e910-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–46/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A health insurance issuer offering individual health insurance coverage or a health insurance issuer offering short-term limited duration insurance coverage shall make disclosures to enrollees in such coverage, as described in subsection (b), and reports to the Secretary, as described in subsection (c), regarding direct or indirect compensation provided by the issuer to an agent or broker associated with enrolling individuals in such coverage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6b7e911-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–46/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A health insurance issuer described in subsection (a) shall disclose to an enrollee the amount of direct or indirect compensation provided to an agent or broker for services provided by such agent or broker associated with plan selection and enrollment. Such disclosure shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6b7e912-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–46/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made prior to the individual finalizing plan selection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6b7e913-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–46/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" included on any documentation confirming the individual’s enrollment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6b7e914-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–46/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A health insurance issuer described in subsection (a) shall annually report to the Secretary, prior to the beginning of open enrollment, any direct or indirect compensation provided to an agent or broker associated with enrolling individuals in such coverage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6b7e915-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–46/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary shall finalize, through notice-and-comment rulemaking, the timing, form, and manner in which issuers described in subsection (a) are required to make the disclosures described in subsection (b) and the reports described in subsection (c). Such rulemaking may also include adjustments to notice requirements to reflect the different processes for plan renewals, in order to provide enrollees with full, timely information."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6b7e916-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVII, § 2746, as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dBB/tII/s202/c"},"text":"Pub. L. 116–260, div. BB, title II, § 202(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2899"},"text":"134 Stat. 2899","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6b7e917-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb6b7e918-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb6b7e919-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable beginning 1 year after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dBB/s202/e"},"text":"section 202(e) of div. BB of Pub. L. 116–260","children":[],"tail":", set out as an Effective Date of 2020 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1108"},"text":"section 1108 of Title 29","children":[],"tail":", Labor."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
