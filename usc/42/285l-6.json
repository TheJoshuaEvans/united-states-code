{"tag":"section","attrib":{"id":"idb578640b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"285l–6"},"text":"§ 285l–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Methods of controlling certain insect and vermin populations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director of the Institute shall conduct or support research to identify or develop methods of controlling insect and vermin populations that transmit to humans diseases that have significant adverse health consequences.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb578640c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 463B, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/75/s3"},"text":"Pub. L. 108–75, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-08-15"},"text":"Aug. 15, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/902"},"text":"117 Stat. 902","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
