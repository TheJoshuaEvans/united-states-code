{"tag":"section","attrib":{"id":"idb50aae00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256i"},"text":null,"children":[{"tag":"num","attrib":{"value":"256i"},"text":"§ 256i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community-based collaborative care network program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb50aae01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award grants to eligible entities to support community-based collaborative care networks that meet the requirements of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb50aae02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community-based collaborative care networks","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb50aae03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256i/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Description","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A community-based collaborative care network (referred to in this section as a “network”) shall be a consortium of health care providers with a joint governance structure (including providers within a single entity) that provides comprehensive coordinated and integrated health care services (as defined by the Secretary) for low-income populations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb50aae04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256i/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required inclusion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A network shall include the following providers (unless such provider does not exist within the community, declines or refuses to participate, or places unreasonable conditions on their participation):","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb50aae05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256i/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A hospital that meets the criteria in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396r–4/b/1"},"text":"section 1396r–4(b)(1) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50aae06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256i/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All Federally qualified health centers (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395x/aa"},"text":"section 1395x(aa) of this title","children":[],"tail":" "},{"tag":"ref","attrib":{"idref":"fn002105"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002105"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. A closing parenthesis probably should appear."}],"tail":" located in the community."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb50aae07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256i/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants, the Secretary shall give priority to networks that include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb50aae08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256i/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the capability to provide the broadest range of services to low-income individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50aae09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256i/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the broadest range of providers that currently serve a high volume of low-income individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50aae0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256i/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a county or municipal department of health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb50aae0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256i/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb50aae0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256i/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A network described in subsection (b) shall submit an application to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb50aae0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256i/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In subsequent years, based on the performance of grantees, the Secretary may provide renewal grants to prior year grant recipients.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb50aae0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256i/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb50aae0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256i/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use by grantees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grant funds may be used for the following activities:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb50aae10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256i/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Assist low-income individuals to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb50aae11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256i/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access and appropriately use health services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb50aae12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256i/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enroll in health coverage programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb50aae13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256i/d/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain a regular primary care provider or a medical home.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50aae14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256i/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provide case management and care management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50aae15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256i/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Perform health outreach using neighborhood health workers or through other means.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50aae16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256i/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provide transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50aae17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256i/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Expand capacity, including through telehealth, after-hours services or urgent care.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50aae18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256i/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provide direct patient care services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb50aae19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256i/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant funds to HRSA grantees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may limit the percent of grant funding that may be spent on direct care services provided by grantees of programs administered by the Health Resources and Services Administration or impose other requirements on such grantees deemed necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb50aae1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256i/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as may be necessary for each of fiscal years 2011 through 2015.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb50aae1b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 340I, formerly § 340H, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10333"},"text":"Pub. L. 111–148, title X, § 10333","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/970"},"text":"124 Stat. 970","children":[],"tail":"; renumbered § 340I, "},{"tag":"ref","attrib":{"href":"/us/pl/115/63/tIII/s301/c/2"},"text":"Pub. L. 115–63, title III, § 301(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-09-29"},"text":"Sept. 29, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1172"},"text":"131 Stat. 1172","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
