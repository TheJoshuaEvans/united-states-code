{"tag":"section","attrib":{"id":"idbff52ce0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16155"},"text":null,"children":[{"tag":"num","attrib":{"value":"16155"},"text":"§ 16155.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hydrogen and Fuel Cell Technical Task Force","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbff52ce1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16155/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the President shall establish an interagency task force chaired by the Secretary with representatives from each of the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff52ce2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16155/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Science and Technology Policy within the Executive Office of the President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52ce3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16155/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52ce4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16155/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52ce5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16155/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Commerce (including the National Institute of Standards and Technology).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52ce6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16155/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52ce7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16155/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52ce8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16155/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Aeronautics and Space Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52ce9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16155/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other Federal agencies as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff52cea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16155/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff52ceb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16155/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Planning","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Task Force shall work toward—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff52cec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16155/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a safe, economical, and environmentally sound fuel infrastructure for hydrogen and hydrogen-carrier fuels, including an infrastructure that supports buses and other fleet transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff52ced-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16155/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fuel cells in government and other applications, including portable, stationary, and transportation applications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff52cee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16155/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distributed power generation, including the generation of combined heat, power, and clean fuels including hydrogen;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff52cef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16155/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uniform hydrogen codes, standards, and safety protocols; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff52cf0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16155/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vehicle hydrogen fuel system integrity safety performance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52cf1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16155/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Task Force may organize workshops and conferences, may issue publications, and may create databases to carry out its duties. The Task Force shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff52cf2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16155/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foster the exchange of generic, nonproprietary information and technology among industry, academia, and government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff52cf3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16155/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and maintain an inventory and assessment of hydrogen, fuel cells, and other advanced technologies, including the commercial capability of each technology for the economic and environmentally safe production, distribution, delivery, storage, and use of hydrogen;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff52cf4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16155/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrate technical and other information made available as a result of the programs and activities under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff52cf5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16155/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the marketplace introduction of infrastructure for hydrogen fuel vehicles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff52cf6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16155/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct an education program to provide hydrogen and fuel cell information to potential end-users.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff52cf7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16155/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency cooperation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The heads of all agencies, including those whose agencies are not represented on the Task Force, shall cooperate with and furnish information to the Task Force, the Technical Advisory Committee, and the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff52cf8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVIII/s806"},"text":"Pub. L. 109–58, title VIII, § 806","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/848"},"text":"119 Stat. 848","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
