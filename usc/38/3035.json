{"tag":"section","attrib":{"id":"idc356bf3f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3035"},"text":null,"children":[{"tag":"num","attrib":{"value":"3035"},"text":"§ 3035.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of administration and of program costs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc356bf40-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3035/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except to the extent otherwise specifically provided in this chapter, the educational assistance programs established by this chapter shall be administered by the Department of Veterans Affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc356bf41-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3035/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc356bf42-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3035/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except to the extent provided in paragraphs (2), (3), and (4), payments for entitlement earned under subchapter II of this chapter shall be made from funds appropriated to, or otherwise available to, the Department of Veterans Affairs for the payment of readjustment benefits and from transfers from the Post-Vietnam Era Veterans Education Account pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3232/b/2/B"},"text":"section 3232(b)(2)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc356bf43-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3035/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payments for entitlement earned under subchapter II of this chapter that is established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3015/d"},"text":"section 3015(d) of this title","children":[],"tail":" at a rate in excess of the rate prescribed under subsection (a) or (b) of "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3015"},"text":"section 3015 of this title","children":[],"tail":" shall, to the extent of that excess, be made from the Department of Defense Education Benefits Fund established under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2006"},"text":"section 2006 of title 10","children":[],"tail":" or from appropriations made to the Department of Homeland Security, as appropriate."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc356bf44-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3035/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Payment for entitlements established under section 3018A or 3018B of this title shall be made—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc356bf45-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3035/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in subparagraphs (B) and (C) of this paragraph, from the Department of Defense Education Benefits Fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2006"},"text":"section 2006 of title 10","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc356bf46-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3035/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any individual described in section 3018A(a)(3), 3018B(a)(1)(C), or 3018B(a)(2)(C) of this title, from funds appropriated, or otherwise available, to the Department of Veterans Affairs for the payment of readjustment benefits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc356bf47-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3035/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the increase in payments made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3015/f"},"text":"section 3015(f) of this title","children":[],"tail":", from the Post-Vietnam Era Veterans Education Account established pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3222/a"},"text":"section 3222(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc356bf48-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3035/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payments attributable to the increased usage of benefits as a result of transfers of entitlement to basic educational assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3020"},"text":"section 3020 of this title","children":[],"tail":" shall be made from the Department of Defense Education Benefits Fund established under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2006"},"text":"section 2006 of title 10","children":[],"tail":" or from appropriations made to the Department of Transportation, as appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc356bf49-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3035/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payments for educational assistance provided under subchapter III of this chapter shall be made from the Department of Defense Education Benefits Fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2006"},"text":"section 2006 of title 10","children":[],"tail":" or from appropriations made to the Department of Homeland Security, as appropriate."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc356bf4a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3035/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds for the payment by the Secretary of benefits under this chapter that are to be paid from the Department of Defense Education Benefits Fund shall be transferred to the Department of Veterans Affairs from such Fund as necessary and in accordance with agreements entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2006"},"text":"section 2006 of title 10","children":[],"tail":" by the Secretary, the Secretary of Defense, and the Secretary of the Treasury. Funds for the payment by the Secretary of benefits under this chapter that are to be paid from appropriations made to the Department of Homeland Security shall be transferred to the Department of Veterans Affairs as necessary. The Secretary and the Secretary of Homeland Security shall enter into an agreement for the manner in which such transfers are to be made."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3592f4b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3035/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Payments for tutorial assistance benefits under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3019"},"text":"section 3019 of this title","children":[],"tail":" shall be made—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3592f4c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3035/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the first $600 of such benefits paid to an individual, from funds appropriated, or otherwise available, to the Department of Veterans Affairs for the payment of readjustment benefits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3592f4d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3035/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of payments to an individual for such benefits in excess of $600, from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3592f4e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3035/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds appropriated, or otherwise available, to the Department of Veterans Affairs for the payment of readjustment benefits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3592f4f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3035/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Defense Education Benefits Fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2006"},"text":"section 2006 of title 10","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3592f50-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3035/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds appropriated to the Department of Homeland Security,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"in the same proportion as the Fund described in subclause (B) of this clause and the funds described in subclause (A) or (C) of this clause are used to pay the educational assistance allowance to the individual under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3592f51-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/tVII/s702/a/1"},"text":"Pub. L. 98–525, title VII, § 702(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2562"},"text":"98 Stat. 2562","children":[],"tail":", § 1435; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/576/tIII/s321/8"},"text":"Pub. L. 99–576, title III, § 321(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3278"},"text":"100 Stat. 3278","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/689/tI/s107/a/2"},"text":"Pub. L. 100–689, title I, § 107(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4168"},"text":"102 Stat. 4168","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIV/s423/b/1"},"text":"Pub. L. 101–237, title IV, § 423(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2092"},"text":"103 Stat. 2092","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tV/s561/b/3"},"text":"Pu