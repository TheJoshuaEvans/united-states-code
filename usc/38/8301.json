{"tag":"section","attrib":{"id":"idc436e632-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8301"},"text":null,"children":[{"tag":"num","attrib":{"value":"8301"},"text":"§ 8301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to accept gifts, devises, and bequests","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may accept devises, bequests, and gifts, made in any manner, with respect to which the testator or donor shall have indicated the intention that such property shall be for the benefit of groups of persons formerly in the active military, naval, air, or space service who by virtue of such service alone, or disability suffered therein or therefrom, are or shall be patients or members of any one or more hospitals or homes operated by the United States Government, or has indicated the intention that such property shall be for the benefit of any such hospital or home, or shall be paid or delivered to any official, as such, or any agency in administrative control thereof. The Secretary may also accept, for use in carrying out all laws administered by the Secretary, gifts, devises, and bequests which will enhance the Secretary’s ability to provide services or benefits.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc436e633-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1254"},"text":"72 Stat. 1254","children":[],"tail":", § 5101; "},{"tag":"ref","attrib":{"href":"/us/pl/99/576/tVII/s701/89"},"text":"Pub. L. 99–576, title VII, § 701(89)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3299"},"text":"100 Stat. 3299","children":[],"tail":"; renumbered § 8301, "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404"},"text":"105 Stat. 404","children":[],"tail":", 405; "},{"tag":"ref","attrib":{"href":"/us/pl/102/86/tV/s504"},"text":"Pub. L. 102–86, title V, § 504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-14"},"text":"Aug. 14, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/426"},"text":"105 Stat. 426","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s926/a/61"},"text":"Pub. L. 116–283, div. A, title IX, § 926(a)(61)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3831"},"text":"134 Stat. 3831","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc436e634-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc436e635-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc436e636-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “air, or space service” for “or air service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5101"},"text":"section 5101 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/86"},"text":"Pub. L. 102–86","children":[],"tail":" inserted at end “The Secretary may also accept, for use in carrying out all laws administered by the Secretary, gifts, devises, and bequests which will enhance the Secretary’s ability to provide services or benefits.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576"},"text":"Pub. L. 99–576","children":[],"tail":" substituted “the” for “his” before “intention” in two places."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
