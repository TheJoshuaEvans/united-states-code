{"tag":"section","attrib":{"id":"idc3119faf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1783"},"text":null,"children":[{"tag":"num","attrib":{"value":"1783"},"text":"§ 1783.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bereavement counseling","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3119fb0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1783/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deaths of Veterans","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an individual who was a recipient of services under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1782"},"text":"section 1782 of this title","children":[],"tail":" at the time of the death of the veteran, the Secretary may provide bereavement counseling to that individual in the case of a death—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3119fb1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1783/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that was unexpected; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3119fb2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1783/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that occurred while the veteran was participating in a hospice program (or a similar program) conducted by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3119fb3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1783/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deaths In Active Service","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3119fb4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1783/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may provide bereavement counseling to an individual who is a member of the immediate family of a member of the Armed Forces who dies in the active military, naval, air, or space service in the line of duty and under circumstances not due to the person’s own misconduct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3119fb5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1783/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this subsection, the members of the immediate family of a member of the Armed Forces described in paragraph (1) include the parents of such member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3119fb6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1783/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provision of Counseling Through Vet Centers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Bereavement counseling may be provided under this section through the facilities and personnel of centers for the provision of readjustment counseling and related mental health services under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1712A"},"text":"section 1712A of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3119fb7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1783/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Bereavement Counseling Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, the term “bereavement counseling” means such counseling services, for a limited period, as the Secretary determines to be reasonable and necessary to assist an individual with the emotional and psychological stress accompanying the death of another individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3119fb8-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/135/tII/s208/b"},"text":"Pub. L. 107–135, title II, § 208(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-23"},"text":"Jan. 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2463"},"text":"115 Stat. 2463","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/461/tII/s216"},"text":"Pub. L. 109–461, title II, § 216","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3424"},"text":"120 Stat. 3424","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s926/a/31"},"text":"Pub. L. 116–283, div. A, title IX, § 926(a)(31)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3830"},"text":"134 Stat. 3830","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3119fb9-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3119fba-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc3119fbb-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1783 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3683"},"text":"section 3683 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3119fbc-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “air, or space service” for “or air service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461/s216/a"},"text":"Pub. L. 109–461, § 216(a)","children":[],"tail":", designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461/s216/b"},"text":"Pub. L. 109–461, § 216(b)","children":[],"tail":", added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
