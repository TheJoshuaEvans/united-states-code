{"tag":"section","attrib":{"id":"idc3fb3c6b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7324"},"text":null,"children":[{"tag":"num","attrib":{"value":"7324"},"text":"§ 7324.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report on use of authorities to enhance retention of experienced nurses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3fb3c6c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7324/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than January 31 each year, the Secretary, acting through the Under Secretary for Health, shall submit to Congress a report on the use during the preceding year of authorities for purposes of retaining experienced nurses in the Veterans Health Administration, as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3fb3c6d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7324/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authorities under chapter 76 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fb3c6e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7324/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority under VA Directive 5102.1, relating to the Department of Veterans Affairs nurse qualification standard, dated ","children":[{"tag":"date","attrib":{"date":"1999-11-10"},"text":"November 10, 1999","children":[],"tail":", or any successor directive."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fb3c6f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7324/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other authorities available to the Secretary for those purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3fb3c70-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7324/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under subsection (a) shall specify for the period covered by such report, for each Department medical facility and for each geographic service area of the Department, the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3fb3c71-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7324/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of waivers requested under the authority referred to in subsection (a)(2), and the number of waivers granted under that authority, to promote to the Nurse II grade or Nurse III grade under the Nurse Schedule under section 7404(b)(1) ","children":[{"tag":"ref","attrib":{"idref":"fn002106"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002106"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title any nurse who has not completed a baccalaureate degree in nursing in a recognized school of nursing, set forth by age, race, and years of experience of the individuals subject to such waiver requests and waivers, as the case may be."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fb3c72-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7324/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The programs carried out to facilitate the use of nursing education programs by experienced nurses, including programs for flexible scheduling, scholarships, salary replacement pay, and on-site classes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3fb3c73-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/135/tI/s125/a/1"},"text":"Pub. L. 107–135, title I, § 125(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-23"},"text":"Jan. 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2452"},"text":"115 Stat. 2452","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3fb3c74-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3fb3c75-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc3fb3c76-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7404/b"},"text":"Section 7404(b) of this title","children":[],"tail":", referred to in subsec. (b)(1), was amended by "},{"tag":"ref","attrib":{"href":"/us/pl/108/445/s3/a"},"text":"Pub. L. 108–445, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2636"},"text":"118 Stat. 2636","children":[],"tail":". As so amended, section 7404(b) no longer includes paragraphs. The Nurse Schedule appears under section 7404(b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3fb3c77-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3fb3c78-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Initial Report","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/135/tI/s125/b"},"text":"Pub. L. 107–135, title I, § 125(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-23"},"text":"Jan. 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2453"},"text":"115 Stat. 2453","children":[],"tail":", required that the initial report under this section be submitted to the National Commission on VA Nursing as well as to Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
