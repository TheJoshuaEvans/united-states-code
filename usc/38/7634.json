{"tag":"section","attrib":{"id":"idc4157b3c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7634"},"text":null,"children":[{"tag":"num","attrib":{"value":"7634"},"text":"§ 7634.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Breach of agreement; waiver of liability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc4157b3d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7634/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An obligation under the Educational Assistance Program (or an agreement under the program) of a participant in the Educational Assistance Program for performance of services or payment of damages is canceled upon the death of the participant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4157b3e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7634/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall prescribe regulations providing for the waiver or suspension of any obligation of a participant for service or payment under the Educational Assistance Program (or an agreement under the program) whenever noncompliance by the participant is due to circumstances beyond the control of the participant or whenever the Secretary determines that the waiver or suspension of compliance is in the best interest of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4157b3f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7634/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An obligation of a participant under the Educational Assistance Program (or an agreement thereunder) for payment of damages may not be released by a discharge in bankruptcy under title 11 before the expiration of the five-year period beginning on the first date the payment of such damages is due.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc4157b40-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/322/tII/s216/b"},"text":"Pub. L. 100–322, title II, § 216(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/529"},"text":"102 Stat. 529","children":[],"tail":", § 4334; renumbered § 7634, "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404"},"text":"105 Stat. 404","children":[],"tail":", 405.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc4157b41-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc4157b42-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc4157b43-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4334"},"text":"section 4334 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" substituted “Secretary” for “Administrator” in two places."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
