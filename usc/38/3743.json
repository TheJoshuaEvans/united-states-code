{"tag":"section","attrib":{"id":"idc3b161f4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3743"},"text":null,"children":[{"tag":"num","attrib":{"value":"3743"},"text":"§ 3743.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability on loans","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each individual who has an ownership interest in a veterans’ small business concern that is provided a direct loan under this subchapter, or that obtains a loan guaranteed under this subchapter, shall execute a note or other document evidencing the direct or guaranteed business loan, and such individuals shall be jointly and severally liable to the United States for the amount of such direct loan or, in the case of a guaranteed loan, for any amount paid by the Secretary on account of such loan.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc3b161f5-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/72/tIII/s302/a"},"text":"Pub. L. 97–72, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-11-03"},"text":"Nov. 3, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1057"},"text":"95 Stat. 1057","children":[],"tail":", § 1843; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIII/s313/b/1"},"text":"Pub. L. 101–237, title III, § 313(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2077"},"text":"103 Stat. 2077","children":[],"tail":"; renumbered § 3743, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3b161f6-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3b161f7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3b161f8-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1843"},"text":"section 1843 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" substituted “Secretary” for “Administrator”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
