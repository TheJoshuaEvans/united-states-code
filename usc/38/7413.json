{"tag":"section","attrib":{"id":"idc409940c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7413"},"text":null,"children":[{"tag":"num","attrib":{"value":"7413"},"text":"§ 7413.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of podiatrists; clinical oversight standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc409940d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7413/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Podiatrists","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided by subsection (b), a doctor of podiatric medicine who is appointed as a podiatrist under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401/1"},"text":"section 7401(1) of this title","children":[],"tail":" is eligible for any supervisory position in the Veterans Health Administration to the same degree that a physician appointed under such section is eligible for the position."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc409940e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7413/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Clinical Oversight Standards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, in consultation with appropriate stakeholders, shall establish standards to ensure that specialists appointed in the Veterans Health Administration to supervisory positions do not provide direct clinical oversight for purposes of peer review or practice evaluation for providers of other clinical specialties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc409940f-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/182/tV/s502/a/1"},"text":"Pub. L. 115–182, title V, § 502(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-06"},"text":"June 6, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1475"},"text":"132 Stat. 1475","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc4099410-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc4099411-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc4099412-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/182/s502/a/1"},"text":"Section 502(a)(1) of Pub. L. 115–182","children":[],"tail":", which directed that this section be added at the end of subchapter I of chapter 74, without specifying the Code title to be amended, was executed by adding this section at the end of this subchapter, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
