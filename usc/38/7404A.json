{"tag":"section","attrib":{"id":"idc4072364-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7404A"},"text":null,"children":[{"tag":"num","attrib":{"value":"7404A"},"text":"§ 7404A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc4072365-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7404A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Superior Accomplishments and Performance Awards Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may establish an awards program for personnel listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7421/b"},"text":"section 7421(b) of this title","children":[],"tail":" consistent with chapter 45 of title 5, to the extent practicable."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4072366-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7404A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Executive Performance Awards Program","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7425"},"text":"section 7425 of this title","children":[],"tail":" or any other provision of law, the Secretary may establish a performance awards program consistent with "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5384"},"text":"section 5384 of title 5","children":[],"tail":" for—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4072367-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7404A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personnel appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401/1"},"text":"section 7401(1) of this title","children":[],"tail":" for a position that the Secretary has determined is of equivalent rank to a Senior Executive Service position (as such term is defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3132/a"},"text":"section 3132(a) of title 5","children":[],"tail":") and is subject to an agency performance management system; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4072368-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7404A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personnel appointed under section 7306 or 7401(4) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4072369-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7404A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment of Awards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Awards under this section may be paid based on criteria established by the Secretary and shall not be considered in calculating the limitation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7431/e/4"},"text":"section 7431(e)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc407236a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7404A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Not Considered Basic Pay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Awards under this section shall not be considered basic pay for any purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc407236b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7404A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may prescribe regulations for the administration of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc407236c-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/168/tIX/s906/b/1"},"text":"Pub. L. 117–168, title IX, § 906(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-10"},"text":"Aug. 10, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1812"},"text":"136 Stat. 1812","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc407236d-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc407236e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc407236f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Limitation on Past Awards","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/168/tIX/s906/b/2"},"text":"Pub. L. 117–168, title IX, § 906(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-10"},"text":"Aug. 10, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1812"},"text":"136 Stat. 1812","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/168/tIX/s906/b/2"},"text":"“Notwithstanding any other provision of law, awards made by the Secretary of Veterans Affairs for any period on or after ","children":[{"tag":"date","attrib":{"date":"2017-01-01"},"text":"January 1, 2017","children":[],"tail":", and before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2022-08-10"},"text":"Aug. 10, 2022","children":[],"tail":"] for an employee under section 7306 or 7401(4) of title 38, United States Code, or for a position described in section 7401(1) of such title that the Secretary has determined is of equivalent rank to a Senior Executive Service position (as such term is defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3132/a"},"text":"section 3132(a) of title 5","children":[],"tail":", United States Code), may be subject to "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7404A"},"text":"section 7404A of title 38","children":[],"tail":", United States Code, as added by paragraph (1).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
