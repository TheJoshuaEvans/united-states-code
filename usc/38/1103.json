{"tag":"section","attrib":{"id":"idc2980228-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1103"},"text":null,"children":[{"tag":"num","attrib":{"value":"1103"},"text":"§ 1103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special provisions relating to claims based upon effects of tobacco products","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2980229-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, a veteran’s disability or death shall not be considered to have resulted from personal injury suffered or disease contracted in the line of duty in the active military, naval, air, or space service for purposes of this title on the basis that it resulted from injury or disease attributable to the use of tobacco products by the veteran during the veteran’s service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc298022a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in subsection (a) shall be construed as precluding the establishment of service connection for disability or death from a disease or injury which is otherwise shown to have been incurred or aggravated in active military, naval, air, or space service or which became manifest to the requisite degree of disability during any applicable presumptive period specified in section 1112 or 1116 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc298022b-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/tVIII/s8202/a/1"},"text":"Pub. L. 105–178, title VIII, § 8202(a)(1)","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIX/s9014/a"},"text":"Pub. L. 105–206, title IX, § 9014(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/865"},"text":"112 Stat. 865","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s926/a/6"},"text":"Pub. L. 116–283, div. A, title IX, § 926(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3830"},"text":"134 Stat. 3830","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc298022c-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc298022d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc298022e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1103 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1104"},"text":"section 1104 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc298022f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “air, or space service” for “or air service” in subsecs. (a) and (b)."}],"tail":"\n"}],"tail":"\n"}