{"tag":"section","attrib":{"id":"idc3165a20-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1834"},"text":null,"children":[{"tag":"num","attrib":{"value":"1834"},"text":"§ 1834.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonduplication of benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3165a21-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1834/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Monetary Allowance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of an eligible child under subchapter II of this chapter whose only covered birth defect is spina bifida, a monetary allowance shall be paid under subchapter I of this chapter. In the case of an eligible child under subchapter II of this chapter who has spina bifida and one or more additional covered birth defects, a monetary allowance shall be paid under subchapter II of this chapter. In the case of a child eligible for benefits under subchapter I or II of this chapter who is also eligible for benefits under subchapter III of this chapter, a monetary allowance shall be paid under the subchapter of this chapter elected by the child.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3165a22-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1834/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vocational Rehabilitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual may only be provided one program of vocational training under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3165a23-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/419/tIV/s401/b"},"text":"Pub. L. 106–419, title IV, § 401(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1860"},"text":"114 Stat. 1860","children":[],"tail":", § 1824; renumbered § 1834 and amended, "},{"tag":"ref","attrib":{"href":"/us/pl/108/183/tI/s102/a/1"},"text":"Pub. L. 108–183, title I, § 102(a)(1)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2003-12-16"},"text":"Dec. 16, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2653"},"text":"117 Stat. 2653","children":[],"tail":", 2654.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3165a24-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3165a25-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc3165a26-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1834 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3734"},"text":"section 3734 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3165a27-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/183/s102/a/1"},"text":"Pub. L. 108–183, § 102(a)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1824"},"text":"section 1824 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/183/s102/c"},"text":"Pub. L. 108–183, § 102(c)","children":[],"tail":", inserted at end: “In the case of a child eligible for benefits under subchapter I or II of this chapter who is also eligible for benefits under subchapter III of this chapter, a monetary allowance shall be paid under the subchapter of this chapter elected by the child.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
