{"tag":"section","attrib":{"id":"idc3ef5552-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7268"},"text":null,"children":[{"tag":"num","attrib":{"value":"7268"},"text":"§ 7268.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of proceedings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3ef5553-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7268/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (b) of this section, all decisions of the Court of Appeals for Veterans Claims and all briefs, motions, documents, and exhibits received by the Court (including a transcript of the stenographic report of the hearings) shall be public records open to the inspection of the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3ef5554-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7268/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3ef5555-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7268/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Court may make any provision which is necessary to prevent the disclosure of confidential information, including a provision that any such document or information be placed under seal to be opened only as directed by the Court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ef5556-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7268/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After the decision of the Court in a proceeding becomes final, the Court may, upon motion of the appellant or the Secretary, permit the withdrawal by the party entitled thereto of originals of books, documents, and records, and of models, diagrams, and other exhibits, submitted to the Court or the Court may, on its own motion, make such other disposition thereof as it considers advisable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3ef5557-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7268/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3ef5558-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7268/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Court shall prescribe rules, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7264/a"},"text":"section 7264(a) of this title","children":[],"tail":", to protect privacy and security concerns relating to all filing of documents and the public availability under this subsection of documents retained by the Court or filed electronically with the Court."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ef5559-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7268/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rules prescribed under paragraph (1) shall be consistent to the extent practicable with rules addressing privacy and security issues throughout the Federal courts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ef555a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7268/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rules prescribed under paragraph (1) shall take into consideration best practices in Federal and State courts to protect private information or otherwise maintain necessary information security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3ef555b-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/687/dA/tIII/s301/a"},"text":"Pub. L. 100–687, div. A, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4117"},"text":"102 Stat. 4117","children":[],"tail":", § 4068; renumbered § 7268, "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/82/s8/2"},"text":"Pub. L. 102–82, § 8(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/377"},"text":"105 Stat. 377","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/368/tV/s512/a/1"},"text":"Pub. L. 105–368, title V, § 512(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3341"},"text":"112 Stat. 3341","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/389/tVI/s602"},"text":"Pub. L. 110–389, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4177"},"text":"122 Stat. 4177","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3ef555c-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3ef555d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3ef555e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/389"},"text":"Pub. L. 110–389","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368"},"text":"Pub. L. 105–368","children":[],"tail":" substituted “Court of Appeals for Veterans Claims” for “Court of Veterans Appeals”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4068"},"text":"section 4068 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/82"},"text":"Pub. L. 102–82","children":[],"tail":" substituted “may, upon motion of the appellant or the Secretary,” for “shall” and “or the Court” for “before the Court”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3ef555f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3ef5560-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368"},"text":"Pub. L. 105–368","children":[],"tail":" effective on first day of first month beginning more than 90 days after "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/368/s513"},"text":"section 513 of Pub. L. 105–368","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7251"},"text":"section 7251 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
