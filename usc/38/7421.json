"text":"section 4108(a) of this title","children":[],"tail":" prior to the repeal of that section as part of the complete revision of chapter 73 of this title by "},{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc4099457-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/168/s906/c/1/A"},"text":"Pub. L. 117–168, § 906(c)(1)(A)","children":[],"tail":", substituted “this title” for “this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/168/s906/c/1/B"},"text":"Pub. L. 117–168, § 906(c)(1)(B)","children":[],"tail":", added par. (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/170"},"text":"Pub. L. 108–170","children":[],"tail":" added par. (8)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc4099458-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc4099459-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/170"},"text":"Pub. L. 108–170","children":[],"tail":" effective at end of 180-day period beginning on "},{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/170/s302/h"},"text":"section 302(h) of Pub. L. 108–170","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7316"},"text":"section 7316 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc409945a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Treatment of Prior Leave Balances","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/168/tIX/s906/c/5"},"text":"Pub. L. 117–168, title IX, § 906(c)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-10"},"text":"Aug. 10, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1813"},"text":"136 Stat. 1813","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/168/tIX/s906/c/5"},"text":"“Notwithstanding any other provision of law, the Secretary [of Veterans Affairs] may adjust the leave balance and carryover leave balance of any employee described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7421/b/9"},"text":"section 7421(b)(9) of title 38","children":[],"tail":", United States Code, as amended by paragraph (1)(B), to ensure any leave accrued or carried over before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2022-08-10"},"text":"Aug. 10, 2022","children":[],"tail":"] remains available to such employee.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc409945b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Preservation of Existing Collective-Bargaining Arrangements and Pending Actions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/tII/s205"},"text":"Pub. L. 102–40, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/207"},"text":"105 Stat. 207","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/40/tII/s205"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Existing Collective-Bargaining Arrangements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any determination under chapter 71 of title 5, United States Code, of a collective bargaining unit within the Veterans Health Administration of the Department of Veterans Affairs, and any recognition under that chapter of an employee labor organization as the exclusive bargaining representative for employees in a collective bargaining unit of the Department of Veterans Affairs, that is in effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":"] shall not be affected by the amendments made by this Act [see Tables for classification] and shall continue in effect in accordance with the terms of such determination or regulation."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pending Cases","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to cases pending on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":"], or those cases which are brought before the establishment of either an administrative grievance procedure pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7463"},"text":"section 7463 of title 38","children":[],"tail":", United States Code (as added by the amendments made by this title), or a negotiated grievance procedure established under a collective bargaining agreement, such cases shall proceed in the same manner as they would have if this Act [see Tables for classification] had not been enacted.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
