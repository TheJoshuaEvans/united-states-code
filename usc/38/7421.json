{"tag":"section","attrib":{"id":"idc4099447-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7421"},"text":null,"children":[{"tag":"num","attrib":{"value":"7421"},"text":"§ 7421.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel administration: in general","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc4099448-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7421/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any law, Executive order, or regulation, the Secretary shall prescribe by regulation the hours and conditions of employment and leaves of absence of employees appointed under any provision of this title in positions in the Veterans Health Administration listed in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4099449-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7421/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subsection (a) refers to the following positions:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc409944a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7421/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Physicians.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc409944b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7421/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Dentists.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc409944c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7421/b/3"},"text":null,"children":[{"tag":"num","attrib":