{"tag":"section","attrib":{"id":"idc3ef5584-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7282"},"text":null,"children":[{"tag":"num","attrib":{"value":"7282"},"text":"§ 7282.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budget and expenditures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3ef5585-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7282/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The budget of the Court of Appeals for Veterans Claims as submitted by the Court for inclusion in the budget of the President for any fiscal year shall be included in that budget without review within the executive branch.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3ef5586-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7282/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Court may make such expenditures (including expenditures for personal services and rent at the seat of Government and elsewhere, and for law books, books of reference, and periodicals) as may be necessary to execute efficiently the functions vested in the Court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3ef5587-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7282/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All expenditures of the Court shall be allowed and paid upon presentation of itemized vouchers signed by the certifying officer designated by the chief judge. Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7285"},"text":"section 7285 of this title","children":[],"tail":", all such expenditures shall be paid out of moneys appropriated for purposes of the Court."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3ef5588-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/687/dA/tIII/s301/a"},"text":"Pub. L. 100–687, div. A, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4118"},"text":"102 Stat. 4118","children":[],"tail":", § 4082; renumbered § 7282 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", (d)(1), "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":", 239; "},{"tag":"ref","attrib":{"href":"/us/pl/105/368/tV/s512/a/1"},"text":"Pub. L. 105–368, title V, § 512(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3341"},"text":"112 Stat. 3341","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3ef5589-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3ef558a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3ef558b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368"},"text":"Pub. L. 105–368","children":[],"tail":" substituted “Court of Appeals for Veterans Claims” for “Court of Veterans Appeals”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/b/1"},"text":"Pub. L. 102–40, § 402(b)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4082"},"text":"section 4082 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/d/1"},"text":"Pub. L. 102–40, § 402(d)(1)","children":[],"tail":", substituted “7285” for “4085”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3ef558c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3ef558d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368"},"text":"Pub. L. 105–368","children":[],"tail":" effective on first day of first month beginning more than 90 days after "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/368/s513"},"text":"section 513 of Pub. L. 105–368","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7251"},"text":"section 7251 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
