{"tag":"section","attrib":{"id":"idc3a309c6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3707A"},"text":null,"children":[{"tag":"num","attrib":{"value":"3707A"},"text":"§ 3707A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hybrid adjustable rate mortgages","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3a309c7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3707A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall carry out a project under this section for the purpose of guaranteeing loans in a manner similar to the manner in which the Secretary of Housing and Urban Development insures adjustable rate mortgages under section 251 of the National Housing Act in accordance with the provisions of this section with respect to hybrid adjustable rate mortgages described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3a309c8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3707A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Adjustable rate mortgages that are guaranteed under this section shall be adjustable rate mortgages (commonly referred to as “hybrid adjustable rate mortgages”) having interest rate adjustment provisions that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3a309c9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3707A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify an initial rate of interest that is fixed for a period of not less than the first three years of the mortgage term;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3a309ca-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3707A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for an initial adjustment in the rate of interest by the mortgagee at the end of the period described in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3a309cb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3707A/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comply in such initial adjustment, and any subsequent adjustment, with subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3a309cc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3707A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Interest rate adjustment provisions of a mortgage guaranteed under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3a309cd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3707A/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" correspond to a specified national interest rate index approved by the Secretary, information on which is readily accessible to mortgagors from generally available published sources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3a309ce-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3707A/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be made by adjusting the monthly payment on an annual basis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3a309cf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3707A/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of the initial contract interest rate adjustment—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3a309d0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3707A/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the initial contract interest rate remained fixed for less than 5 years, be limited to a maximum increase or decrease of 1 percentage point; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3a309d1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3707A/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the initial contract interest rate remained fixed for 5 years or more, be limited to a maximum increase or decrease of such percentage point or points as the Secretary may prescribe;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3a309d2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3707A/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any single annual interest rate adjustment after the initial contract interest rate adjustment, be limited to a maximum increase or decrease of such percentage points as the Secretary may prescribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3a309d3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3707A/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be limited, over the term of the mortgage, to a maximum increase of such number of percentage points as the Secretary shall prescribe for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3a309d4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3707A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall promulgate underwriting standards for loans guaranteed under this section, taking into account—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3a309d5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3707A/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of the interest rate index referred to in subsection (c)(1) and available at the time an underwriting decision is made, regardless of the actual initial rate offered by the lender;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3a309d6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3707A/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maximum and likely amounts of increases in mortgage payments that the loans would require;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3a309d7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3707A/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the underwriting standards applicable to adjustable rate mortgages insured under title II of the National Housing Act; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3a309d8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3707A/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other factors as the Secretary finds appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3a309d9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3707A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall require that the mortgagee make available to the mortgagor, at the time of loan application, a written explanation of the features of the adjustable rate mortgage, including a hypothetical payment schedule that displays the maximum potential increases in monthly payments to the mortgagor over the first five years of the mortgage term.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3a309da-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/330/tIII/s303/a"},"text":"Pub. L. 107–330, title III, § 303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-06"},"text":"Dec. 6, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2825"},"text":"116 Stat. 2825","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/454/tIV/s405/a"},"text":"Pub. L. 108–454, title IV, § 405(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2004-12-10"},"text":"Dec. 10, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3616"},"text":"118 Stat. 3616","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/233/tI/s102"},"text":"Pub. L. 109–233, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-06-15"},"text":"June 15, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/399"},"text":"120 Stat. 399","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/389/tV/s505/b"},"text":"Pub. L. 110–389, title V, § 505(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4176"},"text":"122 Stat. 4176","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/154/tII/s209"},"text":"Pub. L. 112–154, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1179"},"text":"126 Stat. 1179","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3a309db-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3a309dc-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc3a309dd-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Housing Act, referred to in subsecs. (a) and (d)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-27/ch847"},"text":"act June 27, 1934, ch. 847","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1246"},"text":"48 Stat. 1246","children":[],"tail":". Title II of the Act is classified generally to subchapter II (§ 1707 et seq.) of chapter 13 of Title 12, Banks and Banking. Section 251 of the Act is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1715z–16"},"text":"section 1715z–16 of Title 12","children":[],"tail":". For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1701"},"text":"section 1701 of Title 12","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3a309de-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/154"},"text":"Pub. L. 112–154","children":[],"tail":" substituted “project under this section” for “demonstration project under this section during fiscal years 2004 through 2012”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/389"},"text":"Pub. L. 110–389","children":[],"tail":" substituted “2012” for “2008”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/233"},"text":"Pub. L. 109–233","children":[],"tail":" substituted “such percentage points as the Secretary may prescribe” for “1 percentage point”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/454/s405/a"},"text":"Pub. L. 108–454, § 405(a)","children":[],"tail":", substituted “during fiscal years 2004 through 2008” for “during fiscal years 2004 and 2005”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/454/s405/b/2"},"text":"Pub. L. 108–454, § 405(b)(2)","children":[],"tail":", added par. (3) and struck out former par. (3) which read as follows: “be limited, with respect to any single annual interest rate adjustment, to a maximum increase or decrease of 1 percentage point; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/454/s405/b/2"},"text":"Pub. L. 108–454, § 405(b)(2)","children":[],"tail":", added par. (4). Former par. (4) redesignated (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/454/s405/b/1"},"text":"Pub. L. 108–454, § 405(b)(1)","children":[],"tail":", (3), redesignated par. (4) as (5) and substituted “such number of percentage points as the Secretary shall prescribe for purposes of this section” for “5 percentage points above the initial contract interest rate”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3a309df-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3a309e0-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"No Effect on Guarantee of Loans Under Hybrid Adjustable Rate Mortgage Guarantee Demonstration Project","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/454/tIV/s405/c"},"text":"Pub. L. 108–454, title IV, § 405(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-10"},"text":"Dec. 10, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3616"},"text":"118 Stat. 3616","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/454/tIV/s405/c"},"text":"“The amendments made by this section [amending this section] shall not be construed to affect the force or validity of any guarantee of a loan made by the Secretary of Veterans Affairs under the demonstration project for the guarantee of hybrid adjustable rate mortgages under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3707A"},"text":"section 3707A of title 38","children":[],"tail":", United States Code, as in effect on the day before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2004-12-10"},"text":"Dec. 10, 2004","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
