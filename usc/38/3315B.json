{"tag":"section","attrib":{"id":"idc369d153-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3315B"},"text":null,"children":[{"tag":"num","attrib":{"value":"3315B"},"text":"§ 3315B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preparatory courses for licensure, certification, or national tests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc369d154-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3315B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual entitled to educational assistance under this chapter shall also be entitled to payment for a covered preparatory course.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc369d155-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3315B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of educational assistance payable under this chapter for a covered preparatory course is the lesser of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc369d156-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3315B/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fee charged for the covered preparatory course; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc369d157-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3315B/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of entitlement available to the individual under this chapter at the time of payment for the covered preparatory course under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc369d158-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3315B/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Charge Against Entitlement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The number of months of entitlement charged an individual under this chapter for a covered preparatory course shall be pro-rated based on the actual amount of the fee charged for the covered preparatory course relative to the rate for 1 month payable—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc369d159-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3315B/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the academic year beginning on ","children":[{"tag":"date","attrib":{"date":"2020-08-01"},"text":"August 1, 2020","children":[],"tail":", $2,042; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc369d15a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3315B/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for an academic year beginning on any subsequent August 1, the amount for the previous academic year beginning on August 1 under this subsection, as increased by the percentage increase equal to the most recent percentage increase determined under section 3015(h).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc369d15b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3315B/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Preparatory Course Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “covered preparatory course” means a course—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc369d15c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3315B/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a licensing or certification test that is required or used to enter into, maintain, or advance in employment in a predetermined and identified vocation or profession; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc369d15d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3315B/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that has been approved by the State approving agency concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc369d15e-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/154/s5/a"},"text":"Pub. L. 116–154, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-08-08"},"text":"Aug. 8, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/691"},"text":"134 Stat. 691","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc369d15f-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc369d160-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc369d161-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/154/s5/d"},"text":"Pub. L. 116–154, § 5(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-08-08"},"text":"Aug. 8, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/692"},"text":"134 Stat. 692","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/154/s5/d"},"text":"“The amendment made by subsection (a) [enacting this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2021-08-01"},"text":"August 1, 2021","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
