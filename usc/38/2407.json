{"tag":"section","attrib":{"id":"idc345f63d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2407"},"text":null,"children":[{"tag":"num","attrib":{"value":"2407"},"text":"§ 2407.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to accept and maintain suitable memorials","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Subject to such restrictions as the Secretary may prescribe, the Secretary may accept gifts, devises, or bequests from legitimate societies and organizations or reputable individuals, made in any manner, which are made for the purpose of beautifying national cemeteries, or are determined to be beneficial to such cemetery. The Secretary may make land available for this purpose, and may furnish such care and maintenance as the Secretary deems necessary.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc345f63e-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/43/s2/a"},"text":"Pub. L. 93–43, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-06-18"},"text":"June 18, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/78"},"text":"87 Stat. 78","children":[],"tail":", § 1007; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/576/tVII/s701/58"},"text":"Pub. L. 99–576, title VII, § 701(58)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3296"},"text":"100 Stat. 3296","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIII/s313/b/1"},"text":"Pub. L. 101–237, title III, § 313(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2077"},"text":"103 Stat. 2077","children":[],"tail":"; renumbered § 2407, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc345f63f-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc345f640-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc345f641-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1007"},"text":"section 1007 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" substituted “Secretary” for “Administrator” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576"},"text":"Pub. L. 99–576","children":[],"tail":" substituted “the Administrator” for “he” in two places and “The Administrator” for “He”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
