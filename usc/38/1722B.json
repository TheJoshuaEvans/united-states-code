{"tag":"section","attrib":{"id":"idc3080211-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1722B"},"text":null,"children":[{"tag":"num","attrib":{"value":"1722B"},"text":"§ 1722B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Copayments: waiver of collection of copayments for telehealth and telemedicine visits of veterans","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may waive the imposition or collection of copayments for telehealth and telemedicine visits of veterans under the laws administered by the Secretary.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc3080212-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/154/tI/s103/a"},"text":"Pub. L. 112–154, title I, § 103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1169"},"text":"126 Stat. 1169","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
