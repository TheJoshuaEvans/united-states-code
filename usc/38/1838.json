{"tag":"section","attrib":{"id":"idc3165a42-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1838"},"text":null,"children":[{"tag":"num","attrib":{"value":"1838"},"text":"§ 1838.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biennial report","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Not less frequently than once every two years, the Secretary shall submit to Congress a report setting forth the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3165a43-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1838/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of covered children receiving health care or benefits under this chapter as of the date on which the report is submitted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3165a44-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1838/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of covered children for which the Department is paying for or providing a social worker as of such date.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3165a45-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1838/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Metrics on outreach conducted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1836/b"},"text":"section 1836(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3165a46-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/18/s1/b"},"text":"Pub. L. 118–18, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-10-06"},"text":"Oct. 6, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/104"},"text":"137 Stat. 104","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3165a47-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3165a48-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc3165a49-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 1841 to 1851 were renumbered sections 3741 to 3751 of this title, respectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
