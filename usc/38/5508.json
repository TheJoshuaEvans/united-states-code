{"tag":"section","attrib":{"id":"idc3deb332-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5508"},"text":null,"children":[{"tag":"num","attrib":{"value":"5508"},"text":"§ 5508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic onsite reviews of institutional fiduciaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In addition to such other reviews of fiduciaries as the Secretary may otherwise conduct, the Secretary shall provide for the periodic onsite review of any person or agency located in the United States that receives the benefits payable under laws administered by the Secretary to another individual pursuant to the appointment of such person or agency as a fiduciary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5502/a/1"},"text":"section 5502(a)(1) of this title","children":[],"tail":" in any case in which the fiduciary is serving in that capacity with respect to more than 20 beneficiaries and the total annual amount of such benefits exceeds $50,000, as adjusted pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5312"},"text":"section 5312 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc3deb333-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/454/tV/s504/a/1"},"text":"Pub. L. 108–454, title V, § 504(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-10"},"text":"Dec. 10, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3620"},"text":"118 Stat. 3620","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3deb334-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3deb335-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3deb336-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the seventh month beginning after ","children":[{"tag":"date","attrib":{"date":"2004-12-10"},"text":"Dec. 10, 2004","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/454/s507/a"},"text":"section 507(a) of Pub. L. 108–454","children":[],"tail":", set out as an Effective Date of 2004 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5312"},"text":"section 5312 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
