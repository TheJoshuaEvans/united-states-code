ministration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576"},"text":"Pub. L. 99–576","children":[],"tail":" substituted “such person’s” for “his” in three places."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
