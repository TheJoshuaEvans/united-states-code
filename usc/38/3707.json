{"tag":"section","attrib":{"id":"idc3a309b1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3707"},"text":null,"children":[{"tag":"num","attrib":{"value":"3707"},"text":"§ 3707.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustable rate mortgages","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3a309b2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3707/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall carry out a project under this section for the purpose of guaranteeing loans in a manner similar to the manner in which the Secretary of Housing and Urban Development insures adjustable rate mortgages under section 251 of the National Housing Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3a309b3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3707/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Interest rate adjustment provisions of a mortgage guaranteed under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3a309b4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3707/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" correspond to a specified national interest rate index approved by the Secretary, information on which is readily accessible to mortgagors from generally available published sources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3a309b5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3707/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be made by adjusting the monthly payment on an annual basis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3a309b6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3707/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be limited, with respect to any single annual interest rate adjustment, to a maximum increase or decrease of 1 percentage point; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3a309b7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3707/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be limited, over the term of the mortgage, to a maximum increase of 5 percentage points above the initial contract interest rate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3a309b8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3707/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall promulgate underwriting standards for loans guaranteed under this section, taking into account—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3a309b9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3707/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of the interest rate index referred to in subsection (b)(1) and available at the time an underwriting decision is made, regardless of the actual initial rate offered by the lender;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3a309ba-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3707/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maximum and likely amounts of increases in mortgage payments that the loans would require;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3a309bb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3707/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the underwriting standards applicable to adjustable rate mortgages insured under title II of the National Housing Act; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3a309bc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3707/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other factors as the Secretary finds appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3a309bd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3707/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall require that the mortgagee make available to the mortgagor, at the time of loan application, a written explanation of the features of the adjustable rate mortgage, including a hypothetical payment schedule that displays the maximum potential increases in monthly payments to the mortgagor over the first five years of the mortgage term.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3a309be-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/547/s3/a/1"},"text":"Pub. L. 102–547, § 3(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3634"},"text":"106 Stat. 3634","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/78/s7"},"text":"Pub. L. 103–78, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-13"},"text":"Aug. 13, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/769"},"text":"107 Stat. 769","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/454/tIV/s404"},"text":"Pub. L. 108–454, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-10"},"text":"Dec. 10, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3616"},"text":"118 Stat. 3616","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/389/tV/s505/a"},"text":"Pub. L. 110–389, title V, § 505(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4176"},"text":"122 Stat. 4176","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/154/tII/s208"},"text":"Pub. L. 112–154, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1179"},"text":"126 Stat. 1179","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3a309bf-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3a309c0-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc3a309c1-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Housing Act, referred to in subsecs. (a) and (c)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-27/ch847"},"text":"act June 27, 1934, ch. 847","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1246"},"text":"48 Stat. 1246","children":[],"tail":". Title II of the Act is classified generally to subchapter II (§ 1707 et seq.) of chapter 13 of Title 12, Banks and Banking. Section 251 of the Act is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1715z–16"},"text":"section 1715z–16 of Title 12","children":[],"tail":". For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1701"},"text":"section 1701 of Title 12","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3a309c2-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/154"},"text":"Pub. L. 112–154","children":[],"tail":" substituted “project under this section” for “demonstration project under this section during fiscal years 1993 through 2012”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/389"},"text":"Pub. L. 110–389","children":[],"tail":" substituted “2012” for “2008”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/454"},"text":"Pub. L. 108–454","children":[],"tail":" substituted “during fiscal years 1993 through 2008” for “during fiscal years 1993, 1994, and 1995”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/78"},"text":"Pub. L. 103–78","children":[],"tail":" struck out before semicolon at end “on the anniversary of the date on which the loan was closed”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3a309c3-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3a309c4-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Annual Report on Document Disclosure and Consumer Education","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174/tIII/s309/d"},"text":"Pub. L. 115–174, title III, § 309(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1351"},"text":"132 Stat. 1351","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/174/tIII/s309/d"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Not less frequently than once each year, the Secretary of Veterans Affairs shall issue a publicly available report that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" examines, with respect to loans provided to veterans under chapter 37 of title 38, United States Code—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the refinancing of fixed-rate mortgage loans to adjustable rate mortgage loans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether veterans are informed of the risks and disclosures associated with that refinancing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether advertising materials for that refinancing are clear and do not contain misleading statements or assertions; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes findings based on any complaints received by veterans and on an ongoing assessment of the refinancing market by the Secretary.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3a309c5-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Annual Reports on Adjustable Rate Mortgages Guaranteed Under This Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/547/s3/b"},"text":"Pub. L. 102–547, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3635"},"text":"106 Stat. 3635","children":[],"tail":", directed Secretary of Veterans Affairs to transmit adjustable rate mortgage report to Committees on Veterans’ Affairs of Senate and House of Representatives no later than "},{"tag":"date","attrib":{"date":"1993-12-31"},"text":"Dec. 31, 1993","children":[],"tail":", containing description of project carried out under this section and thereafter to transmit annual reports to such committees with respect to default rates and other information concerning loans guaranteed under this section prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/110/tII/s201/b"},"text":"Pub. L. 104–110, title II, § 201(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-13"},"text":"Feb. 13, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/770"},"text":"110 Stat. 770","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
