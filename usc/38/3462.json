en":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/295/s4/39"},"text":"Pub. L. 97–295, § 4(39)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1307"},"text":"96 Stat. 1307","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/306/tII/s206/a"},"text":"Pub. L. 97–306, title II, § 206(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-14"},"text":"Oct. 14, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1435"},"text":"96 Stat. 1435","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/160/tVII/s702/10"},"text":"Pub. L. 98–160, title VII, § 702(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-11-21"},"text":"Nov. 21, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1009"},"text":"97 Stat. 1009","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIV"},"text":"Pub. L. 101–237, title IV","children":[],"tail":", §§ 420(a)(3), 423(b)(1), "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2087"},"text":"103 Stat. 2087","children":[],"tail":", 2092; renumbered § 3462 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/14/s8/a/5"},"text":"Pub. L. 107–14, § 8(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-06-05"},"text":"June 5, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/34"},"text":"115 Stat. 34","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/183/tIII/s306/d"},"text":"Pub. L. 108–183, title III, § 306(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-16"},"text":"Dec. 16, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2661"},"text":"117 Stat. 2661","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/233/tV/s503/8/A"},"text":"Pub. L. 109–233, title V, § 503(8)(A)","children":[],"tail":", (C), "},{"tag":"date","attrib":{"date":"2006-06-15"},"text":"June 15, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/416"},"text":"120 Stat. 416","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc36e8c0b-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc36e8c0c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc36e8c0d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those comprising subsecs. (a) and (b) of this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1176"},"text":"72 Stat. 1176","children":[],"tail":", which was classified to former sections 1612(c) and 1613(a), and 1612(a) of this title, respectively, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/89/358/s4/a"},"text":"section 4(a) of Pub. L. 89–358","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc36e8c0e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsecs. (a) to (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/233/s503/8/A"},"text":"Pub. L. 109–233, § 503(8)(A)","children":[],"tail":", revised style of headings."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/233/s503/8/C"},"text":"Pub. L. 109–233, § 503(8)(C)","children":[],"tail":", inserted headings."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/183"},"text":"Pub. L. 108–183","children":[],"tail":" struck out par. (2) which related to loans under subchapter III of chapter 36 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/14"},"text":"Pub. L. 107–14","children":[],"tail":" struck out par. (3) which permitted eligible Vietnam-era veterans to use unused entitlements under section 3461 for enumerated educational purposes and directed that veterans be provided with employment counseling."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1662"},"text":"section 1662 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A), (3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “3461” for “1661”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(C)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “3491(b)(2)” for “1691(b)(2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “3011(a)(1)(A)(ii)(III)” for “1411(a)(1)(A)(ii)(III)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237/s423/b/1/A"},"text":"Pub. L. 101–237, § 423(b)(1)(A)","children":[],"tail":", substituted “Secretary” for “Administrator” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237/s420/a/3/B"},"text":"Pub. L. 101–237, § 420(a)(3)(B)","children":[],"tail":", substituted “Subject to paragraph (4) of this subsection, no” for “No”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(B), (C)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237/s423/b/1/A"},"text":"Pub. L. 101–237, § 423(b)(1)(A)","children":[],"tail":", substituted “Secretary” for “Administrator” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237/s420/a/3/A"},"text":"Pub. L. 101–237, § 420(a)(3)(A)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237/s423/b/1/A"},"text":"Pub. L. 101–237, § 423(b)(1)(A)","children":[],"tail":", substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237/s423/b/1/B"},"text":"Pub. L. 101–237, § 423(b)(1)(B)","children":[],"tail":", substituted “Department of Veterans Affairs” for “Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/160"},"text":"Pub. L. 98–160","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1980-10-01"},"text":"October 1, 1980","children":[],"tail":"” for “the effective date of the Veterans’ Rehabilitation and Education Amendments of 1980”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295/s4/39/A"},"text":"Pub. L. 97–295, § 4(39)(A)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1977-11-23"},"text":"November 23, 1977","children":[],"tail":",” for “the date of enactment of this paragraph”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(C)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/306/s206/a/1"},"text":"Pub. L. 97–306, § 206(a)(1)","children":[],"tail":", substituted “shall” for “may” after “Educational assistance”, and substituted “unless the Administrator determines, based on an examination of the veteran’s employment and training history, that the veteran is not in need of such a program or course in order to obtain a reasonably stable employment situation consistent with the veteran’s abilities and aptitudes” for “only if the veteran has been determined by the Administrator to be in need of such a program or course in order to achieve a suitable occupational or vocational objective”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/306/s206/a/2"},"text":"Pub. L. 97–306, § 206(a)(2)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1984-12-31"},"text":"December 31, 1984","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1983-12-31"},"text":"December 31, 1983","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295/s4/39/B"},"text":"Pub. L. 97–295, § 4(39)(B)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1966-06-01"},"text":"June 1, 