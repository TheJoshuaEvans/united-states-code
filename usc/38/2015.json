{"tag":"section","attrib":{"id":"idc3309926-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2015"},"text":null,"children":[{"tag":"num","attrib":{"value":"2015"},"text":"§ 2015.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training and technical assistance for entities regarding services provided to veterans at risk of, experiencing, or transitioning out of homelessness","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3309927-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2015/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide training and technical assistance to entities serving veterans at risk of, experiencing, or transitioning out of homelessness regarding—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3309928-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2015/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of such services to such veterans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3309929-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2015/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the planning and development of such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc330992a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2015/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may coordinate the provision of training and technical assistance under subsection (a) with the Secretary of Housing and Urban Development and the Secretary of Labor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc330992b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2015/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The training and technical assistance provided under subsection (a) shall include coordination and communication of best practices among all programs administered by the Veterans Health Administration directed at serving veterans at risk of, experiencing, or transitioning out of homelessness.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc330992c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2015/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provision of Training","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may provide the training and technical assistance under subsection (a) directly or through grants or contracts with such public or nonprofit private entities as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc330992d-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dU/tIII/s305/b/1/B"},"text":"Pub. L. 117–328, div. U, title III, § 305(b)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5471"},"text":"136 Stat. 5471","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
