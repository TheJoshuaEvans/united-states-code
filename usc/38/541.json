{"tag":"section","attrib":{"id":"idc289ab2e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s541"},"text":null,"children":[{"tag":"num","attrib":{"value":"541"},"text":"§ 541.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Committee on Former Prisoners of War","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc289ab2f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s541/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc289ab30-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s541/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall establish an advisory committee to be known as the Advisory Committee on Former Prisoners of War (hereinafter in this section referred to as the “Committee”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc289ab31-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s541/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc289ab32-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s541/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The members of the Committee shall be appointed by the Secretary from the general public and shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc289ab33-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s541/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate representatives of veterans who are former prisoners of war;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc289ab34-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s541/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals who are recognized authorities in fields pertinent to disabilities prevalent among former prisoners of war, including authorities in epidemiology, mental health, nutrition, geriatrics, and internal medicine; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc289ab35-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s541/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate representatives of disabled veterans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc289ab36-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s541/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee shall also include, as ex officio members, the Under Secretary for Health and the Under Secretary for Benefits, or their designees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc289ab37-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s541/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall determine the number, terms of service, and pay and allowances of members of the Committee appointed by the Secretary, except that the term of service of any such member may not exceed three years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc289ab38-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s541/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall, on a regular basis, consult with and seek the advice of the Committee with respect to the administration of benefits under this title for veterans who are former prisoners of war and the needs of such veterans with respect to compensation, health care, and rehabilitation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc289ab39-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s541/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc289ab3a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s541/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than July 1 of each odd-numbered year through 2009, the Committee shall submit to the Secretary a report on the programs and activities of the Department that pertain to veterans who are former prisoners of war. Each such report shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc289ab3b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s541/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the needs of such veterans with respect to compensation, health care, and rehabilitation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc289ab3c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s541/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of the programs and activities of the Department designed to meet such needs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc289ab3d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s541/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such recommendations (including recommendations for administrative and legislative action) as the Committee considers to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc289ab3e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s541/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall, within 60 days after receiving each report under paragraph (1), submit to the Congress a copy of the report, together with any comments concerning the report that the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc289ab3f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s541/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee may also submit to the Secretary such other reports and recommendations as the Committee considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc289ab40-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s541/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall submit with each annual report submitted to the Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s529"},"text":"section 529 of this title","children":[],"tail":" a summary of all reports and recommendations of the Committee submitted to the Secretary since the previous annual report of the Secretary submitted to the Congress pursuant to that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc289ab41-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s2/a"},"text":"Pub. L. 102–83, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/392"},"text":"105 Stat. 392","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/405/tIII/s302/c/1"},"text":"Pub. L. 102–405, title III, § 302(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-09"},"text":"Oct. 9, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1984"},"text":"106 Stat. 1984","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/419/tIV/s403/c/2"},"text":"Pub. L. 106–419, title IV, § 403(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1864"},"text":"114 Stat. 1864","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/454/tVIII/s803"},"text":"Pub. L. 108–454, title VIII, § 803","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-10"},"text":"Dec. 10, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3626"},"text":"118 Stat. 3626","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc289ab42-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc289ab43-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc289ab44-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior section 541 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1541"},"text":"section 1541 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s221"},"text":"section 221 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s2/a"},"text":"Pub. L. 102–83, § 2(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc289ab45-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/454"},"text":"Pub. L. 108–454","children":[],"tail":" substituted “2009” for “2003”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/419"},"text":"Pub. L. 106–419","children":[],"tail":" inserted “through 2003” after “each odd-numbered year” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/405"},"text":"Pub. L. 102–405","children":[],"tail":" substituted “Under Secretary for Health” for “Chief Medical Director” and “Under Secretary for Benefits” for “Chief Benefits Director”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc289ab46-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc289ab47-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Advisory Committees","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Advisory committees established after ","children":[{"tag":"date","attrib":{"date":"1973-01-05"},"text":"Jan. 5, 1973","children":[],"tail":", to terminate not later than the expiration of the 2-year period beginning on the date of their establishment, unless, in the case of a committee established by the President or an officer of the Federal Government, such committee is renewed by appropriate action prior to the expiration of such 2-year period, or in the case of a committee established by the Congress, its duration is otherwise provided by law. See "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"section 1013 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
