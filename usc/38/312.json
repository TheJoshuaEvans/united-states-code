{"tag":"section","attrib":{"id":"idc27b5311-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312"},"text":null,"children":[{"tag":"num","attrib":{"value":"312"},"text":"§ 312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspector General","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc27b5312-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is in the Department an Inspector General, who is appointed by the President, by and with the advice and consent of the Senate, as provided in chapter 4 of title 5. The Inspector General performs the functions, has the responsibilities, and exercises the powers specified in that Act.","children":[{"tag":"ref","attrib":{"idref":"fn002008"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002008"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc27b5313-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc27b5314-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall provide for not less than 40 full-time positions in the Office of Inspector General in addition to the number of such positions in that office on ","children":[{"tag":"date","attrib":{"date":"1989-03-15"},"text":"March 15, 1989","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27b5315-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President shall include in the budget transmitted to the Congress for each fiscal year pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":" an estimate of the amount for the Office of Inspector General that is sufficient to provide for a number of full-time positions in that office that is not less than the number of full-time positions in that office on "},{"tag":"date","attrib":{"date":"1989-03-15"},"text":"March 15, 1989","children":[],"tail":", plus 40."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc27b5316-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc27b5317-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whenever the Inspector General, in carrying out the duties and responsibilities established under chapter 4 of title 5, issues a work product the Inspector General shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc27b5318-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit the work product to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc27b5319-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc27b531a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Veterans’ Affairs, the Committee on Homeland Security and Governmental Affairs, and the Committee on Appropriations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc27b531b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Veterans’ Affairs, the Committee on Oversight and Government Reform, and the Committee on Appropriations of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc27b531c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/c/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the work product was initiated upon request by an individual or entity other than the Inspector General, that individual or entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc27b531d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/c/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Member of Congress upon request; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc27b531e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Inspector General shall submit all final work products to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc27b531f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the work product was initiated upon request by an individual or entity other than the Inspector General, that individual or entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc27b5320-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Member of Congress upon request; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc27b5321-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 3 days after the work product is submitted in final form to the Secretary, post the work product on the Internet website of the Inspector General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27b5322-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this subsection shall be construed to authorize the public disclosure of information that is specifically prohibited from disclosure by any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc27b5323-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc27b5324-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc27b5325-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to the authority otherwise provided by the Inspector General Act of 1978 (5 U.S.C. App.) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" and in accordance with the requirements of this subsection, the Inspector General, in carrying out the provisions of this section, may require by subpoena the attendance and testimony of witnesses as necessary in the performance of the functions assigned to the Inspector General by the Inspector General Act of 1978 (5 U.S.C. App.) "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" and this section, which in the case of contumacy or refusal to obey, such subpoena shall be enforceable by order of any appropriate district court of the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc27b5326-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Inspector General may not require by subpoena the attendance and testimony under subparagraph (A) of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc27b5327-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any current Federal employee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc27b5328-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any witness as part of any criminal proceeding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27b5329-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority to issue a subpoena under paragraph (1) may not be delegated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27b532a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc27b532b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Inspector General shall notify the Attorney General of the intent to issue a subpoena under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc27b532c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 10 days after the date on which the Attorney General is notified pursuant to subparagraph (A), the Attorney General may object in writing to the issuance of the subpoena if the subpoena will interfere with an ongoing investigation and, if the Attorney General makes such an objection, the Inspector General may not issue the subpoena.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc27b532d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Attorney General does not object in writing to the issuance of the subpoena during the 10-day period described in subparagraph (B), the Inspector General may issue the subpoena.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27b532e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Before requiring by subpoena under paragraph (1) the attendance and testimony of a witness, the Inspector General shall, to the degree practicable—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc27b532f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the witness of the intent of the Inspector General to issue the subpoena; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc27b5330-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the witness an opportunity to attend and testify voluntarily.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27b5331-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever requiring by subpoena under paragraph (1) the attendance and testimony of a witness, the Inspector General shall, to the greatest extent practicable, travel to residence ","children":[{"tag":"ref","attrib":{"idref":"fn002009"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002009"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be preceded by “the”."}],"tail":" of the witness, the principal place of business of the witness, or other similar location that is in proximity to the residence of the witness."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27b5332-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc27b5333-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/d/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Along with each semiannual report submitted by the Inspector General pursuant to section 5(b) of the Inspector General Act of 1978 (5 U.S.C. App. 5(b)),","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" the Inspector General shall include a report on the exercise of the authority provided by paragraph (1)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc27b5334-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/d/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each report submitted under subparagraph (A) shall include, for the most recently completed six-month period, the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc27b5335-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/d/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of testimonial subpoenas issued and the number of individuals interviewed pursuant to such subpoenas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc27b5336-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/d/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of proposed testimonial subpoenas with respect to which the Attorney General objected under paragraph (3)(B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc27b5337-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/d/6/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A discussion of any challenges or concerns that the Inspector General has encountered exercising the authority provided by paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc27b5338-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/d/6/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other matters as the Inspector General considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27b5339-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc27b533a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/d/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority provided by paragraph (1)(A) shall terminate on ","children":[{"tag":"date","attrib":{"date":"2026-09-30"},"text":"September 30, 2026","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc27b533b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312/d/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The termination of authority by subparagraph (A) shall not affect the enforceability of a subpoena issued under paragraph (1)(A) before the date of such termination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc27b533c-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s2/a"},"text":"Pub. L. 102–83, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/383"},"text":"105 Stat. 383","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/446/tXII/s1201/e/3"},"text":"Pub. L. 103–446, title XII, § 1201(e)(3)","children":[],"tail":", (g)(1), "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4685"},"text":"108 Stat. 4685","children":[],"tail":", 4687; "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dJ/tII/s239"},"text":"Pub. L. 114–113, div. J, title II, § 239","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2700"},"text":"129 Stat. 2700","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/223/dA/tII/s244"},"text":"Pub. L. 114–223, div. A, title II, § 244","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-09-29"},"text":"Sept. 29, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/884"},"text":"130 Stat. 884","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/136/s2/a"},"text":"Pub. L. 117–136, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-06-07"},"text":"June 7, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1251"},"text":"136 Stat. 1251","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/60"},"text":"Pub. L. 117–286, § 4(b)(60)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4350"},"text":"136 Stat. 4350","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/83/dB/tIII/s332"},"text":"Pub. L. 118–83, div. B, title III, § 332","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-09-26"},"text":"Sept. 26, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1541"},"text":"138 Stat. 1541","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/37/dG/tIV/s7401"},"text":"Pub. L. 119–37, div. G, title IV, § 7401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-11-12"},"text":"Nov. 12, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/654"},"text":"139 Stat. 654","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc27b533d-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc27b533e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc27b533f-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Inspector General Act of 1978 and that Act, referred to in subsecs. (a) and (d)(1)(A), (6)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/452"},"text":"Pub. L. 95–452","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-12"},"text":"Oct. 12, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1101"},"text":"92 Stat. 1101","children":[],"tail":", which was set out in the Appendix to Title 5, Government Organization and Employees, and was substantially repealed and restated in chapter 4 (§ 401 et seq.) of Title 5 by "},{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":", §§ 3(b), 7, "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4206"},"text":"136 Stat. 4206","children":[],"tail":", 4361. Section 5(b) of the Act was repealed and restated as "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s405/c"},"text":"section 405(c) of Title 5","children":[],"tail":". For disposition of sections of the Act into chapter 4 of Title 5, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s101"},"text":"section 101 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc27b5340-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior section 312 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1112"},"text":"section 1112 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/527/s9/b"},"text":"section 9(b) of Pub. L. 100–527","children":[],"tail":", known as the Department of Veterans Affairs Act, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s3/3"},"text":"Pub. L. 102–83, § 3(3)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc27b5341-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (d)(7)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/37"},"text":"Pub. L. 119–37","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2026-09-30"},"text":"September 30, 2026","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2025-09-30"},"text":"September 30, 2025","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2024—Subsec. (d)(7)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/83"},"text":"Pub. L. 118–83","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2025-09-30"},"text":"September 30, 2025","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2025-05-31"},"text":"May 31, 2025","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/60/A"},"text":"Pub. L. 117–286, § 4(b)(60)(A)","children":[],"tail":", substituted “chapter 4 of title 5.” for “the Inspector General Act of 1978 (5 U.S.C. App.).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/60/B"},"text":"Pub. L. 117–286, § 4(b)(60)(B)","children":[],"tail":", substituted “chapter 4 of title 5,” for “the Inspector General Act of 1978 (5 U.S.C. App.),”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/136"},"text":"Pub. L. 117–136","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/223"},"text":"Pub. L. 114–223","children":[],"tail":", in introductory provisions, struck out “that makes a recommendation or otherwise suggests corrective action,” after “work product”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113"},"text":"Pub. L. 114–113","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446/s1201/e/3"},"text":"Pub. L. 103–446, § 1201(e)(3)","children":[],"tail":", substituted “(5 U.S.C. App.)” for “(5 U.S.C. App. 3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446/s1201/g/1"},"text":"Pub. L. 103–446, § 1201(g)(1)","children":[],"tail":", struck out par. (3) which read as follows: “The Secretary shall provide the number of additional full-time positions in the Office of Inspector General required by paragraph (1) not later than "},{"tag":"date","attrib":{"date":"1991-09-30"},"text":"September 30, 1991","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc27b5342-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idc27b5343-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Oversight and Government Reform of House of Representatives changed to Committee on Oversight and Reform of House of Representatives by House Resolution No. 6, One Hundred Sixteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2019-01-09"},"text":"Jan. 9, 2019","children":[],"tail":". Committee on Oversight and Reform of House of Representatives changed to Committee on Oversight and Accountability of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, "},{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc27b5344-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/37"},"text":"Pub. L. 119–37","children":[],"tail":" effective as if enacted on "},{"tag":"date","attrib":{"date":"2025-09-30"},"text":"Sept. 30, 2025","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/119/37/s7406"},"text":"section 7406 of Pub. L. 119–37","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s111A"},"text":"section 111A of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc27b5345-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/136/s2/b"},"text":"Pub. L. 117–136, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-06-07"},"text":"June 7, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1252"},"text":"136 Stat. 1252","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/136/s2/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s312"},"text":"section 312 of title 38","children":[],"tail":", United States Code, as added by subsection (a), shall take effect on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2022-06-07"},"text":"June 7, 2022","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Semiannual report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (6) of subsection (d) of such section, as so added, shall apply beginning on the date that is seven months after the first day of the first fiscal year beginning after the date of the enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc27b5346-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Department of Veterans Affairs Employee Training Regarding Office of Inspector General","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/210/tV/s501"},"text":"Pub. L. 118–210, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-02"},"text":"Jan. 2, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2797"},"text":"138 Stat. 2797","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/210/tV/s501"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Veterans Affairs shall require each employee of the Department of Veterans Affairs who begins employment with the Department on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2025-01-02"},"text":"Jan. 2, 2025","children":[],"tail":"] to receive training that the Inspector General of the Department shall develop on the reporting of wrongdoing to, responding to requests from, and the duty of cooperating with the Office of Inspector General of the Department."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timing of Training","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out subsection (a), the Secretary shall require each employee of the Department covered under such subsection to undergo the training required by such subsection not later than one year after the date on which the employee begins employment with the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Training developed and required under subsection (a) shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Definition of the role, responsibilities, and legal authority of the Inspector General of the Department and the duties of employees of the Department for engaging with the Office of Inspector General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Identification of Federal whistleblower protection rights, including the right to report fraud, waste, abuse, and other wrongdoing to Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Identification of the circumstances and mechanisms for reporting fraud, waste, abuse, and other wrongdoing to the Inspector General, including making confidential complaints to the Inspector General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Identification of the prohibitions and remedies that help to protect employees of the Department from retaliation when reporting wrongdoing to the Inspector General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recognition of opportunities to engage with staff of the Office of Inspector General to improve programs, operations, and services of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notification of the authority of the Inspector General to subpoena the attendance and testimony of witnesses, including former employees of the Department, as necessary to carry out the duties of the Office of Inspector General under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s312"},"text":"section 312 of title 38","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Design and Update","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Inspector General of the Department shall design, and update as the Inspector General considers appropriate, the training developed and required by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"System","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall provide, via the talent management system of the Department, or successor system, the training developed and required under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relation to Certain Training","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall ensure that training developed and required under subsection (a) is separate and distinct from training provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s733"},"text":"section 733 of title 38","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"“(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice to Employees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that the Inspector General is afforded the opportunity, not less frequently than twice each year and more frequently if the Inspector General considers appropriate under extraordinary circumstances, to use the electronic mail system of the Department to notify all authorized users of such system of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The roles and responsibilities of the employees of the Department when engaging with the Office of Inspector General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The availability of training provided under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" How to access training provided under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information about how to contact the Office of Inspector General, including a link to any website-based reporting form of the Office.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
