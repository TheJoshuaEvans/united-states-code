{"tag":"section","attrib":{"id":"idc337c516-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2061"},"text":null,"children":[{"tag":"num","attrib":{"value":"2061"},"text":"§ 2061.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program for homeless veterans with special needs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc337c517-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2061/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall carry out a program to make grants to health care facilities of the Department and to entities eligible for grants and per diem payments under sections 2011 and 2012 of this title in order to encourage development by those facilities and entities of programs for homeless veterans with special needs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc337c518-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2061/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Homeless Veterans With Special Needs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, homeless veterans with special needs include homeless veterans who are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc337c519-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2061/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" women;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc337c51a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2061/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" frail elderly;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc337c51b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2061/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terminally ill;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc337c51c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2061/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chronically mentally ill; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc337c51d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2061/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals who have care of minor dependents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc337c51e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2061/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provision of Services to Dependents","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A recipient of a grant under subsection (a) may use amounts under the grant to provide services directly to a dependent of a homeless veteran with special needs who is under the care of such homeless veteran while such homeless veteran receives services from the grant recipient under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc337c51f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2061/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc337c520-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2061/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" From amounts appropriated to the Department for “Medical Services” for each of fiscal years 2007 through 2026, $5,000,000 shall be available for each such fiscal year for the purposes of the program under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc337c521-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2061/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall ensure that funds for grants under this section are designated for the first three years of operation of the program under this section as a special purpose program for which funds are not allocated through the Veterans Equitable Resource Allocation system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc337c522-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/95/s5/a/1"},"text":"Pub. L. 107–95, § 5(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-21"},"text":"Dec. 21, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/913"},"text":"115 Stat. 913","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/461/tVII/s706"},"text":"Pub. L. 109–461, title VII, § 706","children":[],"tail":", "},{"tag":"date