{"tag":"section","attrib":{"id":"idc2932116-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s728"},"text":null,"children":[{"tag":"num","attrib":{"value":"728"},"text":"§ 728.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Misuse of Department purchase cards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2932117-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s728/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2932118-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s728/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall prohibit any employee of the Department who the Secretary or the Inspector General of the Department determines has knowingly misused a purchase card from serving as a purchase card holder or approving official.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2932119-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s728/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such a prohibition shall be in addition to any other applicable penalty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc293211a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s728/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Misuse","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “misuse” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc293211b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s728/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" splitting purchases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc293211c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s728/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exceeding applicable purchase card limits or purchase thresholds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc293211d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s728/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchasing any unauthorized item;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc293211e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s728/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using a purchase card without being an authorized purchase card holder; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc293211f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s728/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" violating ethics standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2932120-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/407/tV/s501/a"},"text":"Pub. L. 115–407, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"Dec. 31, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5376"},"text":"132 Stat. 5376","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
