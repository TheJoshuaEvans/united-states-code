{"tag":"section","attrib":{"id":"idc40c0532-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7433"},"text":null,"children":[{"tag":"num","attrib":{"value":"7433"},"text":"§ 7433.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative matters","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc40c0533-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7433/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall prescribe regulations relating to the pay of physicians, optometrists, podiatrists, and dentists in the Veterans Health Administration under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc40c0534-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7433/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recommendations and Views","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In prescribing the regulations, the Secretary shall take into account the recommendations of the Under Secretary for Health on the administration of this subchapter. In formulating recommendations for the purpose of this subsection, the Under Secretary shall request the views of representatives of labor organizations that are exclusive representatives of physicians, optometrists, podiatrists, and dentists of the Department and the views of representatives of professional organizations of physicians, optometrists, podiatrists, and dentists of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc40c0535-47c4-11f1-bf59-9680b1269b8