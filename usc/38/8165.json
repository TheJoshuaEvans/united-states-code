Veterans Affairs Capital Asset Fund established under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s8118"},"text":"section 8118 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/422"},"text":"Pub. L. 108–422","children":[],"tail":" substituted “Department of Veterans Affairs Capital Asset Fund established under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s8118"},"text":"section 8118 of this title","children":[],"tail":"” for “nursing home revolving fund”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7"},"text":"Pub. L. 108–7","children":[],"tail":" substituted “Department of Veterans Affairs Medical Care Collections Fund established under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1729A"},"text":"section 1729A of this title","children":[],"tail":"” for “Department of Veterans Affairs Health Services Improvement Fund established under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1729B"},"text":"section 1729B of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/170/s202/c/1"},"text":"Pub. L. 108–170, § 202(c)(1)","children":[],"tail":", struck out “and remaining after any deduction from such funds under the laws referred to in subsection (c)” after “title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/170/s202/c/2"},"text":"Pub. L. 108–170, § 202(c)(2)","children":[],"tail":", inserted at end “The Secretary may use the proceeds from any enhanced-use lease to reimburse applicable appropriations of the Department for any expenses incurred in the development of additional enhanced-use leases.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/u