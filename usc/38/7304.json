{"tag":"section","attrib":{"id":"idc3f40ff2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7304"},"text":null,"children":[{"tag":"num","attrib":{"value":"7304"},"text":"§ 7304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3f40ff3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Unless specifically otherwise provided, the Under Secretary for Health shall prescribe all regulations necessary to the administration of the Veterans Health Administration, including regulations relating to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3f40ff4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7304/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" travel, transportation of household goods and effects, and deductions from pay for quarters and subsistence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f40ff5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7304/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the custody, use, and preservation of the records, papers, and property of the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3f40ff6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Regulations prescribed by the Under Secretary for Health are subject to the approval of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3f40ff7-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s401/a/3"},"text":"Pub. L. 102–40, title IV, § 401(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/212"},"text":"105 Stat. 212","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/405/tIII/s302/c/1"},"text":"Pub. L. 102–405, title III, § 302(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-09"},"text":"Oct. 9, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1984"},"text":"106 Stat. 1984","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3f40ff8-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3f40ff9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3f40ffa-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/405"},"text":"Pub. L. 102–405","children":[],"tail":" substituted “Under Secretary for Health” for “Chief Medical Director” in subsecs. (a) and (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
