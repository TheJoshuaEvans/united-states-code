{"tag":"section","attrib":{"id":"idc33554d9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2052"},"text":null,"children":[{"tag":"num","attrib":{"value":"2052"},"text":"§ 2052.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc33554da-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2052/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A loan referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2051"},"text":"section 2051 of this title","children":[],"tail":" meets the requirements of this subchapter if each of the following requirements is met:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc33554db-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2052/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The loan—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc33554dc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2052/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc33554dd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2052/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" construction of, rehabilitation of, or acquisition of land for a multifamily transitional housing project described in subsection (b), or more than one of such purposes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc33554de-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2052/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refinancing of an existing loan for such a project; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc33554df-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2052/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may also include additional reasonable amounts for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc33554e0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2052/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financing acquisition of furniture, equipment, supplies, or materials for the project; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc33554e1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2052/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a loan made for purposes of subparagraph (A)(i), supplying the organization carrying out the project with working capital relative to the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc33554e2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2052/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The loan is made in connection with funding or the provision of substantial property or services for such project by either a State or local government or a nongovernmental entity, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc33554e3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2052/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The maximum loan amount does not exceed the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc33554e4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2052/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that amount generally approved (utilizing prudent underwriting principles) in the consideration and approval of projects of similar nature and risk so as to assure repayment of the loan obligation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc33554e5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2052/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 90 percent of the total cost of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc33554e6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2052/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The loan is of sound value, taking into account the creditworthiness of the entity (and the individual members of the entity) applying for such loan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc33554e7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2052/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The loan is secured.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc33554e8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2052/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The loan is subject to such terms and conditions as the Secretary determines are reasonable, taking into account other housing projects with similarities in size, location, population, and services provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc33554e9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2052/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this subchapter, a multifamily transitional housing project referred to in subsection (a)(1) is a project that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc33554ea-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2052/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides transitional housing to homeless veterans, which housing may be single room occupancy (as defined in section 8(n) of the United States Housing Act of 1937 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f"},"text":"42 U.S.C. 1437f","children":[],"tail":" (n)));"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc33554eb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2052/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides supportive services and counselling services (including job counselling) at the project site with the goal of making such veterans self-sufficient;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc33554ec-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2052/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires that each such veteran seek to obtain and maintain employment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc33554ed-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2052/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" charges a reasonable fee for occupying a unit in such housing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc33554ee-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2052/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintains strict guidelines regarding sobriety as a condition of occupying such unit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc337c4ef-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2052/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such a project—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc337c4f0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2052/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include space for neighborhood retail services, other commercial activities, or job training programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc337c4f1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2052/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may provide transitional housing to veterans who are not homeless and to homeless individuals who are not veterans if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc337c4f2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2052/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the time of taking occupancy by any such veteran or homeless individual, the transitional housing needs of homeless veterans in the project area have been met;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c4f3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2052/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the housing needs of any such veteran or homeless individual can be met in a manner that is compatible with the manner in which the needs of homeless veterans are met under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c4f4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2052/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions of paragraphs (4) and (5) of subsection (b) are met.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc337c4f5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2052/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In determining whether to guarantee a loan under this subchapter, the Secretary shall consider—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc337c4f6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2052/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of Department of Veterans Affairs medical services to residents of the multifamily transitional housing project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc337c4f7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2052/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which needs of homeless veterans are met in a community, as assessed under ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/405/s107"},"text":"section 107 of Public Law 102–405","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc337c4f8-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/tVI/s601/a"},"text":"Pub. L. 105–368, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3343"},"text":"112 Stat. 3343","children":[],"tail":", § 3773; renumbered § 2052 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/95/s5/d/1"},"text":"Pub. L. 107–95, § 5(d)(1)","children":[],"tail":", (2)(C), "},{"tag":"date","attrib":{"date":"2001-12-21"},"text":"Dec. 21, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/918"},"text":"115 Stat. 918","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/454/tIV/s402/b"},"text":"Pub. L. 108–454, title IV, § 402(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-10"},"text":"Dec. 10, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3616"},"text":"118 Stat. 3616","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc337c4f9-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc337c4fa-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc337c4fb-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/405/s107"},"text":"Section 107 of Public Law 102–405","children":[],"tail":", referred to in subsec. (d)(2), is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s527"},"text":"section 527 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc337c4fc-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/454"},"text":"Pub. L. 108–454","children":[],"tail":" substituted “services, other commercial activities,” for “services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/95/s5/d/1"},"text":"Pub. L. 107–95, § 5(d)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3773"},"text":"section 3773 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/95/s5/d/2/C"},"text":"Pub. L. 107–95, § 5(d)(2)(C)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2051"},"text":"section 2051 of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3772"},"text":"section 3772 of this title","children":[],"tail":"” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc337c4fd-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc337c4fe-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/368/s602/f"},"text":"section 602(f) of Pub. L. 105–368","children":[],"tail":", set out as an Effective Date of 1998 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2106"},"text":"section 2106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
