{"tag":"section","attrib":{"id":"idc41309f2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7501"},"text":null,"children":[{"tag":"num","attrib":{"value":"7501"},"text":"§ 7501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of scholarship program; purpose","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc41309f3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of appropriations, the Secretary shall establish and carry out a scholarship program to provide financial assistance in accordance with this chapter to individuals who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc41309f4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7501/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are accepted for enrollment or currently enrolled in a program of study leading to a degree or certificate in visual impairment or orientation and mobility, or a dual degree or certification in both such areas, at an accredited (as determined by the Secretary) educational institution that is in a State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc41309f5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7501/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into an agreement with the Secretary as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7504"},"text":"section 7504 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc41309f6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The purpose of the scholarship program is to increase the supply of qualified blind rehabilitation specialists for the Department and the Nation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc41309f7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7501/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Outreach","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall publicize the scholarship program to educational institutions throughout the United States, with an emphasis on disseminating information to such institutions with high numbers of Hispanic students and to Historically Black Colleges and Universities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc41309f8-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163/tIII/s302/a"},"text":"Pub. L. 111–163, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-05-05"},"text":"May 5, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1146"},"text":"124 Stat. 1146","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc41309f9-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc41309fa-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc41309fb-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163/tIII/s302/c"},"text":"Pub. L. 111–163, title III, § 302(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-05-05"},"text":"May 5, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1149"},"text":"124 Stat. 1149","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/163/tIII/s302/c"},"text":"“The Secretary of Veterans Affairs shall implement chapter 75 of title 38, United States Code, as added by subsection (a), not later than 6 months after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2010-05-05"},"text":"May 5, 2010","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
