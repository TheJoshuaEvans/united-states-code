{"tag":"section","attrib":{"id":"idc36c4263-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3323"},"text":null,"children":[{"tag":"num","attrib":{"value":"3323"},"text":"§ 3323.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc36c4264-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3323/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc36c4265-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3323/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided in this chapter, the provisions specified in sections 3034(a)(1) and 3680(c) shall apply to the provision of educational assistance under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc36c4266-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3323/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In applying the provisions referred to in paragraph (1) to an individual entitled to educational assistance under this chapter for purposes of this section, the reference in such provisions to the term “eligible veteran” shall be deemed to refer to an individual entitled to educational assistance under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc36c4267-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3323/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule for applying section 3474","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In applying section 3474 to an individual entitled to educational assistance under this chapter for purposes of this section, the reference in such section 3474 to the term “educational assistance allowance” shall be deemed to refer to educational assistance payable under section 3313.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc36c4268-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3323/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule for applying section 3482","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In applying section 3482(g) to an individual entitled to educational assistance under this chapter for purposes of this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc36c4269-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3323/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first reference to the term “educational assistance allowance” in such section 3482(g) shall be deemed to refer to educational assistance payable under section 3313; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc36c426a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3323/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first sentence of paragraph (1) of such section 3482(g) shall be applied as if such sentence ended with “equipment”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc36c426b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3323/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information on Benefits.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc36c426c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3323/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timing for providing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall provide the information described in paragraph (2) to each member of the Armed Forces at such times as the Secretary and the Secretary of Defense shall jointly prescribe in regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc36c426d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3323/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Description of information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The information described in this paragraph is information on benefits, limitations, procedures, eligibility requirements (including time-in-service requirements), and other important aspects of educational assistance under this chapter, including application forms for such assistance under section 5102.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc36c426e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3323/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"To whom provided","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Veterans Affairs shall furnish the information and forms described in paragraph (2), and other educational materials on educational assistance under this chapter, to educational institutions, training establishments, military education personnel, and such other persons and entities as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc36c426f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3323/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc36c4270-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3323/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall prescribe regulations for the administration of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc36c4271-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3323/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Uniformity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any regulations prescribed by the Secretary of Defense for purposes of this chapter shall apply uniformly across the Armed Forces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc36c4272-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/252/tV/s5003/a/1"},"text":"Pub. L. 110–252, title V, § 5003(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-30"},"text":"June 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2374"},"text":"122 Stat. 2374","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/377/tI/s112/c"},"text":"Pub. L. 111–377, title I, § 112(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4122"},"text":"124 Stat. 4122","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc36c4273-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc36c4274-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc36c4275-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/377"},"text":"Pub. L. 111–377","children":[],"tail":" substituted “sections 3034(a)(1) and 3680(c)” for “section 3034(a)(1)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc36c4276-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc36c4277-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2009-08-01"},"text":"Aug. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/252/s5003/d"},"text":"section 5003(d) of Pub. L. 110–252","children":[],"tail":", set out as an Effective Date of 2008 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s16163"},"text":"section 16163 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
