{"tag":"section","attrib":{"id":"idc29320e8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s725"},"text":null,"children":[{"tag":"num","attrib":{"value":"725"},"text":"§ 725.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual performance plan for political appointees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc29320e9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s725/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall conduct an annual performance plan for each political appointee of the Department that is similar to the annual performance plan conducted for an employee of the Department who is appointed as a career appointee (as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3132/a"},"text":"section 3132(a) of title 5","children":[],"tail":") within the Senior Executive Service at the Department."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc29320ea-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s725/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements of Plan","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each annual performance plan conducted under subsection (a) with respect to a political appointee of the Department shall include an assessment of whether the appointee is meeting the following goals:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc29320eb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s725/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recruiting, selecting, and retaining well-qualified individuals for employment at the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc29320ec-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s725/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Engaging and motivating employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc29320ed-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s725/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Training and developing employees and preparing those employees for future leadership roles within the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc29320ee-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s725/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Holding each employee of the Department that is a manager accountable for addressing issues relating to performance, in particular issues relating to the performance of employees that report to the manager.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc29320ef-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s725/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of Political Appointee","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “political appointee” means an employee of the Department who holds—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc29320f0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s725/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a position which has been excepted from the competitive service by reason of its confidential, policy-determining, policy-making, or policy-advocating character; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc29320f1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s725/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a position in the Senior Executive Service as a noncareer appointee (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3132/a"},"text":"section 3132(a) of title 5","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc29320f2-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/46/tII/s203/a"},"text":"Pub. L. 115–46, title II, § 203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-12"},"text":"Aug. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/962"},"text":"131 Stat. 962","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
