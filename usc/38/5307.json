{"tag":"section","attrib":{"id":"idc3d787ce-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5307"},"text":null,"children":[{"tag":"num","attrib":{"value":"5307"},"text":"§ 5307.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Apportionment of benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3d787cf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5307/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" All or any part of the compensation, pension, or emergency officers’ retirement pay payable on account of any veteran may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3d787d0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5307/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the veteran is being furnished hospital treatment, institutional, or domiciliary care by the United States, or any political subdivision thereof, be apportioned on behalf of the veteran’s spouse, children, or dependent parents; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d787d1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5307/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the veteran is not living with the veteran’s spouse, or if the veteran’s children are not in the custody of the veteran, be apportioned as may be prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d787d2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5307/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Where any of the children of a deceased veteran are not in the custody of the veteran’s surviving spouse, the pension, compensation, or dependency and indemnity compensation otherwise payable to the surviving spouse may be apportioned as prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d787d3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5307/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a veteran is not living with the veteran’s spouse, or if any of the veteran’s children are not in the custody of the veteran, any subsistence allowance payable to the veteran under chapter 31 of this title or that portion of the educational assistance allowance payable on account of dependents under chapter 34 of this title may be apportioned as may be prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3d787d4-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1231"},"text":"72 Stat. 1231","children":[],"tail":", § 3107; "},{"tag":"ref","attrib":{"href":"/us/pl/92/540/tV/s505"},"text":"Pub. L. 92–540, title V, § 505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-24"},"text":"Oct. 24, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1099"},"text":"86 Stat. 1099","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/160/tVII/s703/2"},"text":"Pub. L. 98–160, title VII, § 703(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-11-21"},"text":"Nov. 21, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1010"},"text":"97 Stat. 1010","children":[],"tail":"; renumbered § 5307, "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404"},"text":"105 Stat. 404","children":[],"tail":", 405.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3d787d5-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3d787d6-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3d787d7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3107"},"text":"section 3107 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a)(2), (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/160/s703/2/A"},"text":"Pub. L. 98–160, § 703(2)(A)","children":[],"tail":", substituted “the veteran’s spouse” for “his wife”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/160/s703/2/A"},"text":"Pub. L. 98–160, § 703(2)(A)","children":[],"tail":"–(C), substituted “the veteran’s spouse” for “his wife”, “the veteran’s children” for “his children”, and “the custody of the veteran” for “his custody”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/160/s703/2/D"},"text":"Pub. L. 98–160, § 703(2)(D)","children":[],"tail":", substituted “surviving spouse” for “widow” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/160/s703/2/A"},"text":"Pub. L. 98–160, § 703(2)(A)","children":[],"tail":"–(C), (E), substituted “the veteran’s spouse” for “his wife”, “the veteran’s children” for “his children”, “the custody of the veteran” for “his custody”, and “payable to the veteran” for “payable to him”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/540"},"text":"Pub. L. 92–540","children":[],"tail":" inserted provisions relating to that portion of the educational assistance allowance payable on account of dependents under chapter 34 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3d787d8-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3d787d9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1972 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","childre