{"tag":"section","attrib":{"id":"idc3e0fd97-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5702"},"text":null,"children":[{"tag":"num","attrib":{"value":"5702"},"text":"§ 5702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Furnishing of records","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3e0fd98-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any person desiring a copy of any record, paper, and so forth, in the custody of the Secretary that may be disclosed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5701"},"text":"section 5701 of this title","children":[],"tail":" must submit to the Secretary an application in writing, including an electronic request submitted through the website or online tool established under subsection (b), for such copy. The application shall state specifically—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3e0fd99-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5702/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the particular record, paper, and so forth, a copy of which is desired and whether certified or uncertified;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e0fd9a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5702/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purpose for which such copy is desired to be used; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e0fd9b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5702/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the format in which such copy is desired, including whether in printed form or by downloadable file.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3e0fd9c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3e0fd9d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5702/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall establish and maintain a secure website or online tool for a claimant or a duly recognized agent or representative of that claimant to submit an electronic request for such records.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e0fd9e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5702/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary, upon receipt of a valid request made through the website or online tool established under paragraph (1), shall provide to the requestor—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3e0fd9f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5702/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 10 days after receipt, confirmation of such receipt; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3e0fda0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5702/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 120 days after receipt, such records requested in the form selected by the requestor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3e0fda1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5702/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may establish a schedule of fees for copies and certification of such records.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3e0fda2-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1236"},"text":"72 Stat. 1236","children":[],"tail":", § 3302; renumbered § 5702 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", (d)(1), "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":", 239; "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/2/A/xii"},"text":"Pub. L. 102–83, § 4(a)(2)(A)(xii)","children":[],"tail":", (b)(1), (2)(E), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/403-405"},"text":"105 Stat. 403–405","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/446/tXII/s1201/e/16"},"text":"Pub. L. 103–446, title XII, § 1201(e)(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4686"},"text":"108 Stat. 4686","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/21/s2/a"},"text":"Pub. L. 118–21, § 2(a)","children":[],"tail":",(b), "},{"tag":"date","attrib":{"date":"2023-11-13"},"text":"Nov. 13, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/109"},"text":"137 Stat. 109","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3e0fda3-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3e0fda4-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3e0fda5-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/21/s2/b/1"},"text":"Pub. L. 118–21, § 2(b)(1)","children":[],"tail":", substituted “in writing, including an electronic request submitted through the website or online tool established under subsection (b),” for “in writing” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/21/s2/b/2"},"text":"Pub. L. 118–21, § 2(b)(2)","children":[],"tail":"–(4), added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/21/s2/a"},"text":"Pub. L. 118–21, § 2(a)","children":[],"tail":", added subsec. (b) and redesignated former subsec. (b) as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446/s1201/e/16/A"},"text":"Pub. L. 103–446, § 1201(e)(16)(A)","children":[],"tail":", (B), inserted “(a)” before “Any person desiring” and substituted “custody of the Secretary that may be disclosed under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5701"},"text":"section 5701 of this title","children":[],"tail":" must submit to the Secretary an application in writing for such copy. The application shall state” for “custody of the Secretary, which may be disclosed under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5701"},"text":"section 5701 of this title","children":[],"tail":", must make written application therefor to the Secretary, stating”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446/s1201/e/16/C"},"text":"Pub. L. 103–446, § 1201(e)(16)(C)","children":[],"tail":", which directed amendment of subsec. (c) by substituting “may establish” for “is authorized to fix”, was executed to subsec. (b) to reflect the probable intent of Congress, because the language sought to be amended appears in subsec. (b) and this section does not contain a subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/b/1"},"text":"Pub. L. 102–40, § 402(b)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3302"},"text":"section 3302 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/2/A/xii"},"text":"Pub. L. 102–83, § 4(a)(2)(A)(xii)","children":[],"tail":", which directed amendment of subsec. (a) of this section by substituting “Secretary” for “Veterans’ Administration” in two places, was executed to the undesignated first par., to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/d/1"},"text":"Pub. L. 102–40, § 402(d)(1)","children":[],"tail":", substituted “5701” for “3301” in undesignated first par."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3e0fda6-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3e0fda7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadline; Establishment of Website or Online Tool","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/21/s2/c"},"text":"Pub. L. 118–21, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-11-13"},"text":"Nov. 13, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/109"},"text":"137 Stat. 109","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/21/s2/c"},"text":"“Not later than one year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2023-11-13"},"text":"Nov. 13, 2023","children":[],"tail":"], the Secretary of Veterans Affairs shall establish the website or online tool required under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5702/b/1"},"text":"section 5702(b)(1) of title 38","children":[],"tail":", United States Code, as added by this Act, and, to the extent practicable, the Secretary shall utilize existing online resources of the Department of Veterans Affairs for the purposes of such establishment.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
