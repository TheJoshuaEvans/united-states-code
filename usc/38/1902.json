{"tag":"section","attrib":{"id":"idc3165a5a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1902"},"text":null,"children":[{"tag":"num","attrib":{"value":"1902"},"text":"§ 1902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Premium rates and policy values","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Premium rates for insurance shall be the net rates based upon the American Experience Table of Mortality and interest at the rate of 3 per centum per annum. All cash, loan, paid-up, and extended values, and all other calculations in connection with insurance, shall be based upon said American Experience Table of Mortality and interest at the rate of 3 per centum per annum.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc3165a5b-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1148"},"text":"72 Stat. 1148","children":[],"tail":", § 702; renumbered § 1902, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3165a5c-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3165a5d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc3165a5e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior section 1902 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3902"},"text":"section 3902 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 1902, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1215"},"text":"72 Stat. 1215","children":[],"tail":", related to limitation on types of assistance furnished and veterans otherwise entitled, prior to the general revision of chapter 39 of this title by "},{"tag":"ref","attrib":{"href":"/us/pl/91/666"},"text":"Pub. L. 91–666","children":[],"tail":". See sections 3902 and 3903 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3165a5f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s702"},"text":"section 702 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
