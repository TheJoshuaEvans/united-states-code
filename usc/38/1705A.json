{"tag":"section","attrib":{"id":"idc2df6c1b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1705A"},"text":null,"children":[{"tag":"num","attrib":{"value":"1705A"},"text":"§ 1705A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management of health care: information regarding health-plan contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2df6c1c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1705A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2df6c1d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1705A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any individual who seeks hospital care or medical services under this chapter shall provide to the Secretary such current information as the Secretary may require to identify any health-plan contract under which such individual is covered.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2df6c1e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1705A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The information required to be provided to the Secretary under paragraph (1) with respect to a health-plan contract shall include, as applicable, the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2df6c1f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1705A/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The name of the entity providing coverage under the health-plan contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2df6c20-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1705A/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If coverage under the health-plan contract is in the name of an individual other than the individual required to provide information under this section, the name of the policy holder of the health-plan contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2df6c21-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1705A/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The identification number for the health-plan contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2df6c22-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1705A/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The group code for the health-plan contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2df6c23-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1705A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Action To Collect Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may take such action as the Secretary considers appropriate to collect the information required under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2df6c24-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1705A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect on Services From Department","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may not deny any services under this chapter to an individual solely due to the fact that the individual fails to provide information required under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2df6c25-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1705A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Health-Plan Contract Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “health-plan contract” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1725/h"},"text":"section 1725(h) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2df6c26-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/315/tVI/s604/a"},"text":"Pub. L. 114–315, title VI, § 604(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1571"},"text":"130 Stat. 1571","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dU/tI/s142/c/1"},"text":"Pub. L. 117–328, div. U, title I, § 142(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5424"},"text":"136 Stat. 5424","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2df6c27-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc2df6c28-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc2df6c29-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" substituted “section 1725(h)” for “section 1725(f)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
