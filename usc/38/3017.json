{"tag":"section","attrib":{"id":"idc35203aa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3017"},"text":null,"children":[{"tag":"num","attrib":{"value":"3017"},"text":"§ 3017.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Death benefit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc35203ab-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3017/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc35203ac-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3017/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the event of the service-connected death of any individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc35203ad-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3017/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc35203ae-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3017/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entitled to basic educational assistance under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc35203af-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3017/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is on active duty in the Armed Forces and but for clause (1)(A)(i) or clause (2) of section 3011(a) or clause (1)(A)(i) or (ii) or clause (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3012/a"},"text":"section 3012(a) of this title","children":[],"tail":" would be eligible for such basic educational assistance; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc35203b0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3017/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who dies while on active duty or within one year after discharge or release from active duty,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Secretary shall make a payment, subject to paragraph (2)(B) of this subsection, in the amount described in subsection (b) of this section to the person or persons described in paragraph (2)(A) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc35203b1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3017/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc35203b2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3017/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The payment referred to in paragraph (1) of this subsection shall be made to the person or persons first listed below who is surviving on the date of such individual’s death:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc35203b3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3017/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The beneficiary or beneficiaries designated by such individual under the individual’s Servicemembers’ Group Life Insurance policy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc35203b4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3017/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The surviving spouse of the individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc35203b5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3017/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The surviving child or children of the individual, in equal shares.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc35203b6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3017/a/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The surviving parent or parents of the individual, in equal shares.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc35203b7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3017/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If no such person survives such individual, no payment shall be made under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc35203b8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3017/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amount of any payment made under this section shall be equal to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc35203b9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3017/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the total of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc35203ba-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3017/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount reduced from the individual’s basic pay under section 3011(b), 3012(c), 3018(c), 3018A(b), 3018B(b), 3018C(b), or 3018C(e) of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc35203bb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3017/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount reduced from the individual’s retired pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3018C/e"},"text":"section 3018C(e) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc35203bc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3017/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount collected from the individual by the Secretary under section 3018B(b), 3018C(b), or 3018C(e) of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc35203bd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3017/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of any contributions made by the individual under section 3011(e) or 3012(f) of this title, less","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc35203be-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3017/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the total of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc35203bf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3017/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of educational assistance that has been paid to the individual under this chapter before the payment is made under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc35203c0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3017/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of accrued benefits paid or payable with respect to such individual in connection with this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc35203c1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3017/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A payment under this section shall be considered to be a benefit under this title and, for purposes of section 3035(b)(1), it shall be considered to be an entitlement earned under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc35203c2-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/689/tI/s101/a"},"text":"Pub. L. 100–689, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4161"},"text":"102 Stat. 4161","children":[],"tail":", § 1417; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIV/s423/a/3"}