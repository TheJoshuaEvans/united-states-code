. 109–233, title V, § 503(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-06-15"},"text":"June 15, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/416"},"text":"120 Stat. 416","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc35203c3-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc35203c4-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc35203c5-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/233"},"text":"Pub. L. 109–233","children":[],"tail":" substituted “3011(e)” for “3011(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/14"},"text":"Pub. L. 107–14","children":[],"tail":" amended par. (1) generally. Prior to amendment, par. (1) read as follows: “the amount reduced from the individual’s pay under section 3011(b), 3012(c), or 3018(c) of this title, less”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(1)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/419"},"text":"Pub. L. 106–419","children":[],"tail":" substituted “clause (2) of section 3011(a)” for “clause (2)(A) of section 3011(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(2)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/275"},"text":"Pub. L. 104–275","children":[],"tail":" substituted “Servicemembers’ Group” for “Servicemen’s Group”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—S