{"tag":"section","attrib":{"id":"idc4157afd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7623"},"text":null,"children":[{"tag":"num","attrib":{"value":"7623"},"text":"§ 7623.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obligated service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc4157afe-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7623/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each participant in the Tuition Reimbursement Program shall provide service in the full-time clinical practice of such participant’s profession as a full-time employee of the Department for the period of obligated service provided in the agreement of such participant entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7603"},"text":"section 7603 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4157aff-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7623/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A participant who on such participant’s course completion date is a full-time employee in the Veterans Health Administration shall be considered to have begun serving such participant’s period of obligated service on the course completion date.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4157b00-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7623/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except in the case of a participant whose tuition was paid pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7622/e"},"text":"section 7622(e) of this title","children":[],"tail":", if a participant in the Tuition Reimbursement Program fails to successfully complete a course, no reimbursement will be provided and no period of obligated service will be incurred."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4157b01-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7623/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a participant whose tuition was paid pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7622/e"},"text":"section 7622(e) of this title","children":[],"tail":" and who fails to complete the course involved, the period of obligation shall be of the same duration as it would have been if the participant had successfully completed the course and the course completion date shall be considered to be the date on which the participant’s failure becomes an established fact."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4157b02-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7623/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of this section, the term “course completion date” means the date on which a participant in the Tuition Reimbursement Program completes such participant’s course of training under the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc4157b03-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/322/tII/s216/b"},"text":"Pub. L. 100–322, title II, § 216(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/526"},"text":"102 Stat. 526","children":[],"tail":", § 4323; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/687/dB/tXV/s1503/a/3"},"text":"Pub. L. 100–687, div. B, title XV, § 1503(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4134"},"text":"102 Stat. 4134","children":[],"tail":"; renumbered § 7623 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", (d)(1), "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":", 239; "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/3"},"text":"Pub. L. 102–83, § 4(a)(3)","children":[],"tail":", (4), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404"},"text":"105 Stat. 404","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/446/tXII/s1201/b/1"},"text":"Pub. L. 103–446, title XII, § 1201(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4682"},"text":"108 Stat. 4682","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc4157b04-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc4157b05-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc4157b06-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446"},"text":"Pub. L. 103–446","children":[],"tail":" substituted “Veterans Health Administration” for “Department of Medicine and Surgery”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/b/1"},"text":"Pub. L. 102–40, § 402(b)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4323"},"text":"section 4323 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" substituted “Department” for “Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/d/1"},"text":"Pub. L. 102–40, § 402(d)(1)","children":[],"tail":", substituted “7603” for “4303”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/d/1"},"text":"Pub. L. 102–40, § 402(d)(1)","children":[],"tail":", substituted “7622(e)” for “4322(e)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/687"},"text":"Pub. L. 100–687","children":[],"tail":" substituted “4322(e)” for “4322(f)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
