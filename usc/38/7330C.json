{"tag":"section","attrib":{"id":"idc3fff790-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C"},"text":null,"children":[{"tag":"num","attrib":{"value":"7330C"},"text":"§ 7330C.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quadrennial Veterans Health Administration review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3fff791-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Market Area Assessments","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3fff792-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not less frequently than every 4 years, the Secretary shall perform market area assessments regarding the health care services furnished under the laws administered by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fff793-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each market area assessment established under paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3fff794-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of the demand for health care from the Department, disaggregated by geographic market areas as determined by the Secretary, including the number of requests for health care services under the laws administered by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fff795-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An inventory of the health care capacity of the Department across the Department’s system of facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fff796-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of the health care capacity to be provided through contracted community care providers and providers who entered into a provider agreement with the Department under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1703A"},"text":"section 1703A of this title","children":[],"tail":", including the number of providers, the geographic location of the providers, and categories or types of health care services provided by the providers."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fff797-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment obtained from other Federal direct delivery systems of their capacity to provide health care to veterans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fff798-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of the health care capacity of non-contracted providers where there is insufficient network supply.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fff799-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of the health care capacity of academic affiliates and other collaborations of the Department as it relates to providing health care to veterans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fff79a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of the effects on health care capacity of the access standards and standards for quality established under sections 1703B and 1703C of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fff79b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The number of appointments for health care services under the laws administered by the Secretary, disaggregated by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc3fff79c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/a/2/H/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appointments at facilities of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3fff79d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/a/2/H/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appointments with non-Department health care providers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fff79e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3fff79f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall submit to the appropriate committees of Congress the market area assessments established in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fff7a0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary also shall submit to the appropriate committees of Congress the market area assessments completed by or being performed on the day before the date of the enactment of the Caring for Our Veterans Act of 2018.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fff7a1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3fff7a2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall use the market area assessments established under paragraph (1) to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc3fff7a3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the capacity of the health care provider networks established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1703/h"},"text":"section 1703(h) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3fff7a4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inform the Department budget, in accordance with subparagraph (B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3fff7a5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/a/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inform and assess the appropriateness of the access standards established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1703B"},"text":"section 1703B of this title","children":[],"tail":" and standards for quality under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1703C"},"text":"section 1703C of this title","children":[],"tail":" and to make recommendations for any changes to such standards."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fff7a6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall ensure that the Department budget for any fiscal year (as submitted with the budget of the President under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":") reflects the findings of the Secretary with respect to the most recent market area assessments under paragraph (1) and health care utilization data from the Department and non-Department entities or providers furnishing care and services to covered veterans as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1703/b"},"text":"section 1703(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3fff7a7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Strategic Plan To Meet Health Care Demand","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3fff7a8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than 1 year after the date of the enactment of the Caring for Our Veterans Act of 2018 and not less frequently than once every 4 years thereafter, the Secretary shall submit to the appropriate committees of Congress a strategic plan that specifies a 4-year forecast of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3fff7a9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the demand for health care from the Department, disaggregated by geographic area as determined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fff7aa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the health care capacity to be provided at each medical center of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fff7ab-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the health care capacity to be provided through community care providers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fff7ac-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In preparing the strategic plan under paragraph (1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3fff7ad-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the access standards and standards for quality established under sections 1703B and 1703C of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fff7ae-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the market area assessments established under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fff7af-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the needs of the Department based on identified services that provide management of conditions or disorders related to military service for which there is limited experience or access in the national market, the overall health of veterans throughout their lifespan, or other services as the Secretary determines appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fff7b0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with key stakeholders within the Department, the heads of other Federal agencies, and other relevant governmental and nongovernmental entities, including State, local, and tribal government officials, members of Congress, veterans service organizations, private sector representatives, academics, and other policy experts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fff7b1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify emerging issues, trends, problems, and opportunities that could affect health care services furnished under the laws administered by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fff7b2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop recommendations regarding both short- and long-term priorities for health care services furnished under the laws administered by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fff7b3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after consultation with veterans service organizations and other key stakeholders on survey development or modification of an existing survey, consider a survey of veterans who have used hospital care, medical services, or extended care services furnished by the Veterans Health Administration during the most recent 2-year period to assess the satisfaction of the veterans with service and quality of care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fff7b4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct a comprehensive examination of programs and policies of the Department regarding the delivery of health care services and the demand of health care services for veterans in future years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fff7b5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the remediation of medical service lines of the Department as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1706A"},"text":"section 1706A of this title","children":[],"tail":" in conjunction with the utilization of non-Department entities or providers to offset remediation; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fff7b6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/b/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider such other matters as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3fff7b7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall be responsible for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3fff7b8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" overseeing the transformation and organizational change across the Department to achieve a high-performing integrated health care network;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fff7b9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing the capital infrastructure planning and procurement processes, whether minor or major construction projects or leases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fff7ba-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing a multi-year budget process that is capable of forecasting future year budget requirements and projecting the cost of delivering health care services under such a high-performing integrated health care network.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3fff7bb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriate Committees of Congress Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “appropriate committees of Congress” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3fff7bc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Veterans’ Affairs and the Committee on Appropriations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fff7bd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330C/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Veterans’ Affairs and the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3fff7be-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/182/tI/s106/a"},"text":"Pub. L. 115–182, title I, § 106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-06"},"text":"June 6, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1413"},"text":"132 Stat. 1413","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/251/tII/s211/a/11"},"text":"Pub. L. 115–251, title II, § 211(a)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-29"},"text":"Sept. 29, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3175"},"text":"132 Stat. 3175","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3fff7bf-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3fff7c0-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc3fff7c1-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the Caring for Our Veterans Act of 2018, referred to in subsecs. (a)(3)(B) and (b), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/182"},"text":"Pub. L. 115–182","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2018-06-06"},"text":"June 6, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3fff7c2-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/251/s211/a/11/A/i"},"text":"Pub. L. 115–251, § 211(a)(11)(A)(i)","children":[],"tail":", substituted “Secretary shall” for “Secretary of Veterans Affairs shall”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/251/s211/a/11/A/ii/I"},"text":"Pub. L. 115–251, § 211(a)(11)(A)(ii)(I)","children":[],"tail":", substituted “Department across” for “Department of Veterans Affairs across”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/251/s211/a/11/A/ii/II"},"text":"Pub. L. 115–251, § 211(a)(11)(A)(ii)(II