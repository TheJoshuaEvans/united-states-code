{"tag":"section","attrib":{"id":"idc27dc3a1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s317"},"text":null,"children":[{"tag":"num","attrib":{"value":"317"},"text":"§ 317.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Center for Minority Veterans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc27dc3a2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s317/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is in the Department a Center for Minority Veterans. There is at the head of the Center a Director.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc27dc3a3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s317/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall be a career or noncareer appointee in the Senior Executive Service. The Director shall be appointed for a term of six years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc27dc3a4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s317/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director reports directly to the Secretary or the Deputy Secretary concerning the activities of the Center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc27dc3a5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s317/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Director shall perform the following functions with respect to veterans who are minorities:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc27dc3a6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s317/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Serve as principal adviser to the Secretary on the adoption and implementation of policies and programs affecting veterans who are minorities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27dc3a7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s317/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Make recommendations to the Secretary, the Under Secretary for Health, the Under Secretary for Benefits, and other Department officials for the establishment or improvement of programs in the Department for which veterans who are minorities are eligible.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27dc3a8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s317/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Promote the use of benefits authorized by this title by veterans who are minorities and the conduct of outreach activities to veterans who are minorities, in conjunction with outreach activities carried out under chapter 77 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27dc3a9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s317/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Disseminate information and serve as a resource center for the exchange of information regarding innovative and successful programs which improve the services available to veterans who are minorities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27dc3aa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s317/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Conduct and sponsor appropriate social and demographic research on the needs of veterans who are minorities and the extent to which programs authorized under this title meet the needs of those veterans, without regard to any law concerning the collection of information from the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27dc3ab-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s317/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Analyze and evaluate complaints made by or on behalf of veterans who are minorities about the adequacy and timeliness of services provided by the Department and advise the appropriate official of the Department of the results of such analysis or evaluation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27dc3ac-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s317/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Consult with, and provide assistance and information to, officials responsible for administering Federal, State, local, and private programs that assist veterans, to encourage those officials to adopt policies which promote the use of those programs by veterans who are minorities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27dc3ad-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s317/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advise the Secretary when laws or policies have the effect of discouraging the use of benefits by veterans who are minorities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27dc3ae-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s317/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Publicize the results of medical research which are of particular significance to veterans who are minorities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27dc3af-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s317/d/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advise the Secretary and other appropriate officials on the effectiveness of the Department’s efforts to accomplish the goals of section 492B of the Public Health Service Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s289a–2"},"text":"42 U.S.C. 289a–2","children":[],"tail":") with respect to the inclusion of minorities in clinical research and on particular health conditions affecting the health of members of minority groups which should be studied as part of the Department’s medical research program and promote cooperation between the Department and other sponsors of medical research of potential benefit to veterans who are minorities."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27dc3b0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s317/d/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provide support and administrative services to the Advisory Committee on Minority Veterans provided for under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s544"},"text":"section 544 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27dc3b1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s317/d/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Perform such other duties consistent with this section as the Secretary shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc27dc3b2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s317/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall ensure that the Director is furnished sufficient resources to enable the Director to carry out the functions of the Center in a timely manner.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc27dc3b3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s317/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall include in documents submitted to Congress by the Secretary in support of the President’s budget for each fiscal year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc27dc3b4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s317/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detailed information on the budget for the Center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27dc3b5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s317/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary’s opinion as to whether the resources (including the number of employees) proposed in the budget for that fiscal year are adequate to enable the Center to comply with its statutory and regulatory duties; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27dc3b6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s317/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a report on the activities and significant accomplishments of the Center during the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc27dc3b7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s317/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc27dc3b8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s317/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “veterans who are minorities” means veterans who are minority group members.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27dc3b9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s317/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “minority group member” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s544/d"},"text":"section 544(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc27dc3ba-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446/tV/s509/a"},"text":"Pub. L. 103–446, title V, § 509(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4665"},"text":"108 Stat. 4665","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/275/tV/s501/a"},"text":"Pub. L. 104–275, title V, § 501(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3340"},"text":"110 Stat. 3340","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc27dc3bb-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc27dc3bc-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc27dc3bd-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior section 317, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/218/s1/a"},"text":"Pub. L. 102–218, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-11"},"text":"Dec. 11, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1671"},"text":"105 Stat. 1671","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/446/tXII/s1201/e/4"},"text":"Pub. L. 103–446, title XII, § 1201(e)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4685"},"text":"108 Stat. 4685","children":[],"tail":", related to Chief Minority Affairs Officer, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/446/s509/a"},"text":"Pub. L. 103–446, § 509(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc27dc3be-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/275/s501/a"},"text":"Pub. L. 104–275, § 501(a)","children":[],"tail":", inserted “career or” before “noncareer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(10) to (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/275/s501/b"},"text":"Pub. L. 104–275, § 501(b)","children":[],"tail":", added pars. (10) and (11) and redesignated former par. (10) as (12)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/275/s501/c"},"text":"Pub. L. 104–275, § 501(c)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
