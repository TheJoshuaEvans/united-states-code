{"tag":"section","attrib":{"id":"idc2fc1ba5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720B"},"text":null,"children":[{"tag":"num","attrib":{"value":"1720B"},"text":"§ 1720B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Respite care","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2fc1ba6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may furnish respite care services to a veteran who is enrolled to receive care under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1710"},"text":"section 1710 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2fc1ba7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purpose of this section, the term “respite care services” means care and services which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2fc1ba8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720B/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are of limited duration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2fc1ba9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720B/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are furnished on an intermittent basis to a veteran who is suffering from a chronic illness and who resides primarily at home; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2fc1baa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720B/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are furnished for the purpose of helping the veteran to continue residing primarily at home.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2fc1bab-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720B/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In furnishing respite care services, the Secretary may enter into contract arrangements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2fc1bac-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576/tII/s201/a/1"},"text":"Pub. L. 99–576, title II, § 201(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3254"},"text":"100 Stat. 3254","children":[],"tail":", § 620B; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tII/s201/a"},"text":"Pub. L. 101–237, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2066"},"text":"103 Stat. 2066","children":[],"tail":"; renumbered § 1720B and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":", §§ 4(a)(3), (4), (b)(1), (2)(E), 5(a), (c)(1), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404-406"},"text":"105 Stat. 404–406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/585/tV/s502"},"text":"Pub. L. 102–585, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4955"},"text":"106 Stat. 4955","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/117/tI/s101/e"},"text":"Pub. L. 106–117, title I, § 101(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-30"},"text":"Nov. 30, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1549"},"text":"113 Stat. 1549","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2fc1bad-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc2fc1bae-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc2fc1baf-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117/s101/e/1"},"text":"Pub. L. 106–117, § 101(e)(1)","children":[],"tail":", substituted “enrolled” for “eligible”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117/s101/e/2"},"text":"Pub. L. 106–117, § 101(e)(2)","children":[],"tail":", in introductory provisions, substituted “the term ‘respite care services’ means care and services” for “the term ‘respite care’ means hospital or nursing home care”, in par. (1) substituted “are” for “is”, in par. (2) substituted “are” for “is” and struck out “in a Department facility” after “furnished”, and in par. (3) substituted “are” for “is”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117/s101/e/3"},"text":"Pub. L. 106–117, § 101(e)(3)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/585"},"text":"Pub. L. 102–585","children":[],"tail":" struck out subsec. (c) which read as follows: “The authority provided by this section terminates on "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"September 30, 1992","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s620B"},"text":"section 620B of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “1710” for “610”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/3"},"text":"Pub. L. 102–83, § 4(a)(3)","children":[],"tail":", (4), substituted “Department” for “Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"September 30, 1992","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1989-09-30"},"text":"September 30, 1989","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc2fc