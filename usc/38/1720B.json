{"href":"/us/stat/103/682"},"text":"103 Stat. 682","children":[],"tail":", ratified actions of the Secretary of Veterans Affairs in carrying out this section, "},{"tag":"ref","attrib":{"href":"/us/pl/100/322/s115"},"text":"section 115 of Pub. L. 100–322","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1712"},"text":"38 U.S.C. 1712","children":[],"tail":" note], "},{"tag":"ref","attrib":{"href":"/us/pl/100/440/s618"},"text":"section 618 of Pub. L. 100–440","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t5/s6302"},"text":"5 U.S.C. 6302","children":[],"tail":" note], or section 1829 [now 3729] of this title, by contract or otherwise, during the period beginning "},{"tag":"date","attrib":{"date":"1989-10-01"},"text":"Oct. 1, 1989","children":[],"tail":", and ending "},{"tag":"date","attrib":{"date":"1989-10-06"},"text":"Oct. 6, 1989","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc2fc1bb2-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Interim Extension of Respite Care Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/110/s1/a"},"text":"Pub. L. 101–110, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-10-06"},"text":"Oct. 6, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/682"},"text":"103 Stat. 682","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/110/s1/a"},"text":"“Notwithstanding the provisions of subsection (c) of section 620B [now 1720B] of title 38, United States Code, the authority provided by such section shall terminate on ","children":[{"tag":"date","attrib":{"date":"1989-11-30"},"text":"November 30, 1989","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc2fc1bb3-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576/tII/s201/b"},"text":"Pub. L. 99–576, title II, § 201(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3254"},"text":"100 Stat. 3254","children":[],"tail":", provided that if the Administrator of Veterans’ Affairs furnished respite care under this section, the Administrator was to conduct an evaluation of the health efficacy and cost-effectiveness of furnishing such care and submit to the Committees on Veterans’ Affairs of the Senate and House of Representatives not later than "},{"tag":"date","attrib":{"date":"1989-02-01"},"text":"Feb. 1, 1989","children":[],"tail":", a report containing the results of such evaluation and appropriate recommendations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
