(1)(I), 1710(a)(2), 1710(b), and 1712(a)(2)(B)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66"},"text":"Pub. L. 103–66","children":[],"tail":" substituted “1998” for “1997”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/568"},"text":"Pub. L. 102–568","children":[],"tail":" substituted “1997” for “1992”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3117"},"text":"section 3117 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" substituted “1315” for “415”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" substituted “1710(a)(1)(I)”, “1710(a)(2)”, “1710(b)”, and “1712(a)(2)(B)” for “610(a)(1)(I)”, “610(a)(2)”, “610(b)”, and “612(a)(2)(B)”, respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3d9d184-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3d9d185-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Notification Prior to Use of Income Information From Other Federal Agencies","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/tVIII/s8051/c"},"text":"Pub. L. 101–508, title VIII, § 8051(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-351"},"text":"104 Stat. 1388–351","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/508/tVIII/s8051/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Veterans Affairs shall notify individuals who (as of the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":"]) are applicants for or recipients of the benefits described in subsection (c) (other than paragraph (3)) of section 3117 [now 5317] of title 38, United States Code (as added by subsection (b)), that income information furnished to the Secretary by such applicants and recipients may be compared with information obtained by the Secretary from the Secretary of Health and Human Services or the Secretary of the Treasury under clause (viii) of section 6103("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(7)(D) of the Internal Revenue Code of 1986 ["},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6103"},"text":"26 U.S.C. 6103","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(7)(D)] (as added by subsection (a))."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notification under paragraph (1) shall be made not later than 90 days after the date of the enactment of this Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Veterans Affairs may not obtain information from the Secretary of Health and Human Services or the Secretary of the Treasury under section 6103(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(7)(D)(viii) of the Internal Revenue Code of 1986 (as added by subsection (a)) until notification under paragraph (1) is made.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3d9d186-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study by Comptroller General on Effectiveness of Amendments by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/tVIII/s8051/d"},"text":"Pub. L. 101–508, title VIII, § 8051(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-351"},"text":"104 Stat. 1388–351","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/508/tVIII/s8051/d"},"text":"“The Comptroller General of the United States shall conduct a study of the effectiveness of the amendments made by this section [enacting this section] and shall submit a report on such study to the Committees on Veterans’ Affairs and Ways and Means of the House of Representatives and the Committees on Veterans’ Affairs and Finance of the Senate not later than ","children":[{"tag":"date","attrib":{"date":"1992-01-01"},"text":"January 1, 1992","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
