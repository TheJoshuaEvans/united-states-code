{"tag":"section","attrib":{"id":"idc410c00b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7456A"},"text":null,"children":[{"tag":"num","attrib":{"value":"7456A"},"text":"§ 7456A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nurses: alternate work schedules","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc410c00c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7456A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section applies to registered nurses appointed under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc410c00d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7456A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"72/80 Work Schedule","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc410c00e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7456A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc410c00f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7456A/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2), if the Secretary determines it to be necessary in order to obtain or retain the services of registered nurses at any Department health-care facility, the Secretary may provide, in the case of nurses employed at such facility, that such nurses who work six regularly scheduled 12-hour tours of duty within a 14-day period shall be considered for all purposes to have worked a full 80-hour pay period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc410c010-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7456A/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A nurse who works under the authority in subparagraph (A) shall be considered a 0.90 full-time equivalent employee in computing full-time equivalent employees for the purposes of determining compliance with personnel ceilings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc410c011-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7456A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc410c012-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7456A/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Basic and additional pay for a nurse who is considered under paragraph (1) to have worked a full 80-hour pay period shall be subject to subparagraphs (B) and (C).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc410c013-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7456A/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The hourly rate of basic pay for a nurse covered by this paragraph for service performed as part of a regularly scheduled 36-hour tour of duty within the work week shall be derived by dividing the nurse’s annual rate of basic pay by 1,872.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc410c014-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7456A/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall pay overtime pay to a nurse covered by this paragraph who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc410c015-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7456A/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performs a period of service in excess of such nurse’s regularly scheduled 36-hour tour of duty within an administrative work week;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc410c016-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7456A/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for officially ordered or approved service, performs a period of service in excess of 8 hours on a day other than a day on which such nurse’s regularly scheduled 12-hour tour of duty falls;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc410c017-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7456A/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performs a period of service in excess of 12 hours for any day included in the regularly scheduled 36-hour tour of duty work week; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc410c018-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7456A/b/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performs a period of service in excess of 40 hours during an administrative work week.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc410c019-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7456A/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may provide a nurse to whom this subsection applies with additional pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7453"},"text":"section 7453 of this title","children":[],"tail":" for any period included in a regularly scheduled 12-hour tour of duty."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc410c01a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7456A/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A nurse who works a work schedule described in this subsection who is absent on approved sick leave or annual leave during a scheduled 12-hour tour of duty shall be charged for such leave at a rate of ten hours of leave for every nine hours of absence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc410c01b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7456A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Holiday Pay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A nurse working a work schedule under subsection (b) that includes a holiday designated by law or Executive order shall be eligible for holiday pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7453/d"},"text":"section 7453(d) of this title","children":[],"tail":" for any service performed by the nurse on such holiday under such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc410c01c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7456A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 9-","children":[{"tag":"inline","attrib":{},"text":"Month Work Schedule for Certain Nurses","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc410c01d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7456A/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may authorize a registered nurse appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7405"},"text":"section 7405 of this title","children":[],"tail":", with the nurse’s written consent, to work full time for nine months with 3 months off duty, within a fiscal year, and be paid at 75 percent of the full-time rate for such nurse’s grade for each pay period of such fiscal year."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc410c01e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7456A/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A nurse who works under the authority in paragraph (1) shall be considered a 0.75 full-time equivalent employee in computing full-time equivalent employees for the purposes of determining compliance with personnel ceilings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc410c01f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7456A/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Work under this subsection shall be considered part-time service for purposes of computing benefits under chapters 83 and 84 of title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc410c020-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7456A/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A nurse who works under the authority in paragraph (1) shall be considered a full-time employee for purposes of chapter 89 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc410c021-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7456A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification of Modification of Benefits","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall provide each employee with respect to whom an alternate work schedule under this section may apply written notice of the effect, if any, that the alternate work schedule will have on the employee’s health care premium, retirement, life insurance premium, probationary status, or other benefit or condition of employment. The notice shall be provided not later than 14 days before the employee consents to the alternate work schedule.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc410c022-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7456A/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall prescribe regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc410c023-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/445/s4/a/1"},"text":"Pub. L. 108–445, § 4(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2643"},"text":"118 Stat. 2643","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/163/tVI/s602/c"},"text":"Pub. L. 111–163, title VI, § 602(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-05-05"},"text":"May 5, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1173"},"text":"124 Stat. 1173","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc410c024-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc410c025-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc410c026-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163/s602/c/2/A"},"text":"Pub. L. 111–163, § 602(c)(2)(A)","children":[],"tail":", substituted “72/80” for “36/40” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163/s602/c/1"},"text":"Pub. L. 111–163, § 602(c)(1)","children":[],"tail":", substituted “six regularly scheduled 12-hour tours of duty within a 14-day period shall be considered for all purposes to have worked a full 80-hour pay period.” for “three regularly scheduled 12-hour tours of duty within a work week shall be considered for all purposes to have worked a full 40-hour basic work week.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163/s602/c/2/B"},"text":"Pub. L. 111–163, § 602(c)(2)(B)","children":[],"tail":", substituted “80-hour pay period” for “40-hour basic work week”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163/s602/c/2/C"},"text":"Pub. L. 111–163, § 602(c)(2)(C)","children":[],"tail":", struck out “regularly” before “scheduled 12-hour tour”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
