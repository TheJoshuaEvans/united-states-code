{"tag":"section","attrib":{"id":"idc362a5cd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3234"},"text":null,"children":[{"tag":"num","attrib":{"value":"3234"},"text":"§ 3234.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tutorial assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc362a5ce-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3234/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual entitled to benefits under this chapter shall also be entitled to the benefits provided an eligible veteran under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3492"},"text":"section 3492 of this title","children":[],"tail":", subject to the conditions applicable to an eligible veteran under such section. Any amount paid to an individual under this section shall be in addition to the amount of other benefits paid under this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc362a5cf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3234/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual’s period of entitlement to educational assistance under this chapter shall be charged only with respect to the amount of educational assistance paid to the individual under this section in excess of $600.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc362a5d0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3234/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual’s period of entitlement to educational assistance under this chapter shall be charged at the rate of one month for each amount of assistance paid to the individual under this section in excess of $600 that is equal to the amount of monthly educational assistance the individual is otherwise eligible to receive for full-time pursuit of an institutional course under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc362a5d1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3234/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Payments of benefits under this section shall be made—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc362a5d2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3234/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the first $600 of such benefits paid to an individual, from funds appropriated, or otherwise available, to the Department of Veterans Affairs for the payment of readjustment benefits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc362a5d3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3234/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of payments to an individual for such benefits in excess of $600, from the fund from contributions made to the fund by the veteran and by the Secretary of Defense in the same proportion as these contributions are used to pay other educational assistance to the individual under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc362a5d4-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/689/tI/s107/b/1"},"text":"Pub. L. 100–689, title I, § 107(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4168"},"text":"102 Stat. 4168","children":[],"tail":", § 1634; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIV/s423/b/1/B"},"text":"Pub. L. 101–237, title IV, § 423(b)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2092"},"text":"103 Stat. 2092","children":[],"tail":"; renumbered § 3234 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc362a5d5-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc362a5d6-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc362a5d7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1634"},"text":"section 1634 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “3492” for “1692”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" substituted “Department of Veterans Affairs” for “Veterans’ Administration”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
