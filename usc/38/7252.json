{"tag":"section","attrib":{"id":"idc3ece47a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7252"},"text":null,"children":[{"tag":"num","attrib":{"value":"7252"},"text":"§ 7252.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction; finality of decisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3ece47b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7252/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Court of Appeals for Veterans Claims shall have exclusive jurisdiction to review decisions of the Board of Veterans’ Appeals. The Secretary may not seek review of any such decision. The Court shall have power to affirm, modify, or reverse a decision of the Board or to remand the matter, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3ece47c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7252/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Review in the Court shall be on the record of proceedings before the Secretary and the Board. The extent of the review shall be limited to the scope provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7261"},"text":"section 7261 of this title","children":[],"tail":". The Court may not review the schedule of ratings for disabilities adopted under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1155"},"text":"section 1155 of this title","children":[],"tail":" or any action of the Secretary in adopting or revising that schedule."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3ece47d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7252/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Decisions by the Court are subject to review as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7292"},"text":"section 7292 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3ece47e-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/687/dA/tIII/s301/a"},"text":"Pub. L. 100–687, div. A, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4113"},"text":"102 Stat. 4113","children":[],"tail":", § 4052; renumbered § 7252 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", (d)(1), "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":", 239; "},{"tag":"ref","attrib":{"href":"/us/pl/102/54/s14/e/3"},"text":"Pub. L. 102–54, § 14(e)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-06-13"},"text":"June 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/287"},"text":"105 Stat. 287","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":", §§ 4(b)(1), (2)(E), 5(c)(1), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404-406"},"text":"105 Stat. 404–406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/368/tV/s512/a/1"},"text":"Pub. L. 105–368, title V, § 512(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3341"},"text":"112 Stat. 3341","children":[],"ta