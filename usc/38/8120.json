{"tag":"section","attrib":{"id":"idc4288d95-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8120"},"text":null,"children":[{"tag":"num","attrib":{"value":"8120"},"text":"§ 8120.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quarterly report on super construction projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc4288d96-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8120/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Quarterly Reports Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after the last day of each fiscal quarter the Secretary shall submit to the Committees on Veterans’ Affairs of the Senate and House of Representatives a report on the super construction projects carried out by the appropriate non-Department Federal entity described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s8103/e/1"},"text":"section 8103(e)(1) of this title","children":[],"tail":" during such quarter. Each such report shall include, for each such project—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4288d97-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8120/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the budgetary and scheduling status of the project, as of the last day of the quarter covered by the report; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4288d98-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8120/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actual cost and schedule variances of the project, as of such day, compared to the planned cost and schedules for the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4288d99-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8120/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Super Construction Project Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “super construction project” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s8103/e/3"},"text":"section 8103(e)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc4288d9a-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/315/tVIII/s801/d/1"},"text":"Pub. L. 114–315, title VIII, § 801(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1591"},"text":"130 Stat. 1591","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
