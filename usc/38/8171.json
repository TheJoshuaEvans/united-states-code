{"tag":"section","attrib":{"id":"idc4347442-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8171"},"text":null,"children":[{"tag":"num","attrib":{"value":"8171"},"text":"§ 8171.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4347443-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8171/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc4347444-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8171/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Veterans’ Affairs and the Committee on Appropriations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4347445-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8171/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Veterans’ Affairs and the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4347446-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8171/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “information technology” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s11101"},"text":"section 11101 of title 40","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4347447-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8171/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc4347448-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8171/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “information technology project” means a project or program of the Department (including a project or program of any element of the Department) for, or including, the acquisition or implementation of information technology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4347449-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8171/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In cases where the Secretary transmits to the Director of the Office of Management and Budget information regarding information technology investments, which may consist of individual or multiple projects, the term “information technology project” refers to an individual project or program or a grouping of multiple projects or programs resulting in the acquisition or implementation of discrete information technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc434744a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8171/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “life cycle costs” means all direct and indirect costs to acquire, implement, operate, and maintain information technology, including with respect to costs of any element of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc434744b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8171/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “major information technology project” means an information technology project if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc434744c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8171/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project is designated by the Secretary, the Chief Information Officer of the Department, or the Director of the Office of Management and Budget as a major information technology investment, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s11302"},"text":"section 11302 of title 40","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc434744d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8171/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the dollar value of the project is estimated by the Secretary to exceed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc434744e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8171/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000,000,000 (as adjusted for inflation pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1908"},"text":"section 1908 of title 41","children":[],"tail":") for the total life cycle costs of the project; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc434744f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8171/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $200,000,000 (as adjusted for inflation pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1908"},"text":"section 1908 of title 41","children":[],"tail":") annually."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4347450-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8171/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “business owner” means, with respect to an information technology project, the program manager, project manager, or other supervisory official of the Department responsible for the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc4347451-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dU/tIV/s403/a"},"text":"Pub. L. 117–328, div. U, title IV, § 403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5486"},"text":"136 Stat. 5486","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
