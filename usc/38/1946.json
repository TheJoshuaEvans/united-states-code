{"tag":"section","attrib":{"id":"idc31fcff4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1946"},"text":null,"children":[{"tag":"num","attrib":{"value":"1946"},"text":"§ 1946.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dividends to pay premiums","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Until and unless the Secretary has received from the insured a request in writing for payment of dividends in cash or that the dividends be placed on deposit in accordance with the provisions of the insured’s policy, any regular annual dividends shall be applied in payment of premiums becoming due on insurance after the date the dividend is payable on or after ","children":[{"tag":"date","attrib":{"date":"1958-12-31"},"text":"December 31, 1958","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc31fcff5-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1159"},"text":"72 Stat. 1159","children":[],"tail":", § 746; "},{"tag":"ref","attrib":{"href":"/us/pl/99/576/tVII/s701/30"},"text":"Pub. L. 99–576, title VII, § 701(30)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3293"},"text":"100 Stat. 3293","children":[],"tail":"; renumbered § 1946 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":", §§ 4(a)(2)(A)(iii)(V), 5(a), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/403"},"text":"105 Stat. 403","children":[],"tail":", 406.)"}],"tail":"\n"},{"tag