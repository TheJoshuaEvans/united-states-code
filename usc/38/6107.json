{"tag":"section","attrib":{"id":"idc3e5df80-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6107"},"text":null,"children":[{"tag":"num","attrib":{"value":"6107"},"text":"§ 6107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reissuance of benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3e5df81-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reissuance of Misused Benefits","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3e5df82-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6107/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any case in which a fiduciary misuses all or part of an individual’s benefit paid to such fiduciary, the Secretary shall pay to the beneficiary or the beneficiary’s successor fiduciary an amount equal to the amount of such benefit so misused.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e5df83-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6107/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any case in which the Secretary reissues a benefit payment (in whole or in part) under paragraph (1), the Secretary shall make a good faith effort to obtain recoupment from the fiduciary to whom the payment was originally made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e5df84-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6107/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any case in which the Secretary obtains recoupment from a fiduciary who has misused benefits, the Secretary shall promptly remit payment of the recouped amounts to the beneficiary or the beneficiary’s successor fiduciary, as the case may be, to the extent that such amounts have not been paid under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3e5df85-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reissuance of Amounts in the Case of a Deceased Beneficiary","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3e5df86-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6107/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a beneficiary described in subsection (a)(1) predeceases a payment under such subsection, the Secretary shall pay such amount, subject to paragraph (2), to an individual or entity in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5121"},"text":"section 5121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e5df87-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6107/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not make a payment under this subsection to a fiduciary who misused benefits of the beneficiary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3e5df88-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6107/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Total Amount Paid","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The total of the amounts paid to a beneficiary or the beneficiary’s successor fiduciary under this section may not exceed the total benefit amount misused by the fiduciary with respect to that beneficiary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3e5df89-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6107/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Oversight of Negligence","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3e5df8a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6107/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall establish methods and timing with respect to determining whether an instance of misuse by a fiduciary, of all or part of an individual’s benefit paid to such fiduciary, is the result of negligence by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e5df8b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6107/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not withhold the reissuing of a benefit payment under subsection (a)(1) by reason of a pending determination under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e5df8c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6107/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary is not required to make a determination under paragraph (1) for each instance of misuse by a fiduciary, of all or part of an individual’s benefit paid to such fiduciary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3e5df8d-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/454/tV/s503/a/1"},"text":"Pub. L. 108–454, title V, § 503(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-10"},"text":"Dec. 10, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3619"},"text":"118 Stat. 3619","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/315/tVII/s7005/a"},"text":"Pub. L. 116–315, title VII, § 7005(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/5059"},"text":"134 Stat. 5059","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/114/s2"},"text":"Pub. L. 118–114, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-11-25"},"text":"Nov. 25, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1605"},"text":"138 Stat. 1605","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/56/s2"},"text":"Pub. L. 119–56, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-12"},"text":"Dec. 12, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/709"},"text":"139 Stat. 709","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3e5df8e-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3e5df8f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3e5df90-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/56"},"text":"Pub. L. 119–56","children":[],"tail":" amended section generally. Prior to amendment, section related to reissuance of benefits after misuse of benefits by a fiduciary in cases of negligent failure of the Secretary to investigate or monitor the fiduciary or in other cases."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2024—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/114/s2/1"},"text":"Pub. L. 118–114, § 2(1)","children":[],"tail":", (2), added subsec. (c) and redesignated former subsec. (c) as (d). Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/114/s2/1"},"text":"Pub. L. 118–114, § 2(1)","children":[],"tail":", (3), redesignated subsec. (d) as (e) and substituted “this section” for “subsection (a) or (b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/s7005/a/1"},"text":"Pub. L. 116–315, § 7005(a)(1)","children":[],"tail":", substituted “In any case not covered by subsection (a) in which a fiduciary” for “In any case in which a fiduciary described in paragraph (2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/s7005/a/2"},"text":"Pub. L. 116–315, § 7005(a)(2)","children":[],"tail":", (3), redesignated par. (3) as (2) and struck out former par. (2) which read as follows: “Paragraph (1) applies to a fiduciary that—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) is not an individual; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) is an individual who, for any month during a period when misuse occurs, serves 10 or more individuals who are beneficiaries under this title.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3e5df91-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3e5df92-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/tVII/s7005/b"},"text":"Pub. L. 116–315, title VII, § 7005(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/5059"},"text":"134 Stat. 5059","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/315/tVII/s7005/b"},"text":"“The amendments made by subsection (a) [amending this section] shall apply with respect to any determination by the Secretary of Veterans Affairs made on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":"] regarding the misuse of benefits by a fiduciary.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3e5df93-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to any determinations by the Secretary of Veterans Affairs made after ","children":[{"tag":"date","attrib":{"date":"2004-12-10"},"text":"Dec. 10, 2004","children":[],"tail":", of misuse of funds by a fiduciary, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/454/s507/b/2"},"text":"section 507(b)(2) of Pub. L. 108–454","children":[],"tail":", set out as an Effective Date of 2004 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5312"},"text":"section 5312 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
