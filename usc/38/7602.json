{"tag":"section","attrib":{"id":"idc4130a39-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7602"},"text":null,"children":[{"tag":"num","attrib":{"value":"7602"},"text":"§ 7602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc4130a3a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7602/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4130a3b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7602/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To be eligible to participate in the Educational Assistance Program under subchapter II, III, VI, or IX of this chapter, an individual must be accepted for enrollment or be currently enrolled as a student at a qualifying educational institution in a course of education or training that is approved by the Secretary and that leads toward completion of a degree in a field of education or training for which a scholarship may be awarded under subchapter II of this chapter, for which tuition reimbursement may be provided under subchapter III of this chapter, or for which a scholarship may be awarded under subchapter VI or IX of this chapter, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4130a3c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7602/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A qualifying educational institution for purposes of this section is an educational institution that is in a State and that (as determined by the Secretary) is an accredited institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4130a3d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7602/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual is not eligible to apply to participate in the Educational Assistance Program under subchapter II, III, VI, or IX of this chapter if the individual is obligated under any other Federal program to perform service after completion of the course of education or training of such individual referred to in subsection (a) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc4130a3e-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/322/tII/s216/b"},"text":"Pub. L. 100–322, title II, § 216(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/518"},"text":"102 Stat. 518","children":[],"tail":", § 4302; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/366/tII/s205/c/2"},"text":"Pub. L. 101–366, title II, § 205(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-15"},"text":"Aug. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/441"},"text":"104 Stat. 441","children":[],"tail":"; renumbered § 7602, "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404"},"text":"105 Stat. 404","children":[],"tail":", 405; "},{"tag":"ref","attrib":{"href":"/us/pl/105/368/tVIII/s805/2"},"text":"Pub. L. 105–368, title VIII, § 805(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3358"},"text":"112 Stat. 3358","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/171/tV/s502/b/1/B"},"text":"Pub. L. 116–171, title V, § 502(b)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-17"},"text":"Oct. 17, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/818"},"text":"134 Stat. 818","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc4130a3f-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc4130a40-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc4130a41-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/171/s502/b/1/B/i"},"text":"Pub. L. 116–171, § 502(b)(1)(B)(i)","children":[],"tail":", substituted “VI, or IX” for “or VI” and “subchapter VI or IX” for “subchapter VI”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/171/s502/b/1/B/ii"},"text":"Pub. L. 116–171, § 502(b)(1)(B)(ii)","children":[],"tail":", substituted “VI, or IX” for “or VI”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/s805/2/A"},"text":"Pub. L. 105–368, § 805(2)(A)","children":[],"tail":", substituted “subchapter II, III, or VI” for “subchapter I or II”, substituted “, for which” for “or for which”, and inserted before period at end “, or for which a scholarship may be awarded under subchapter VI of this chapter, as the case may be”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/s805/2/B"},"text":"Pub. L. 105–368, § 805(2)(B)","children":[],"tail":", substituted “subchapter II, III, or VI” for “subchapter I or II”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4302"},"text":"section 4302 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" substituted “Secretary” for “Administrator” in pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsecs. (a)(1), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/366"},"text":"Pub. L. 101–366","children":[],"tail":" inserted “under subchapter I or II of this chapter” after “Educational Assistance Program”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
