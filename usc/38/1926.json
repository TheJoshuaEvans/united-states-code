{"tag":"section","attrib":{"id":"idc31d86b1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1926"},"text":null,"children":[{"tag":"num","attrib":{"value":"1926"},"text":"§ 1926.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority for higher interest rates for amounts payable to beneficiaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding sections 1902, 1923, and 1925 of this title, if the beneficiary of an insurance policy receives the proceeds of such policy under a settlement option under which such proceeds are paid in equal monthly installments over a limited period of months, the interest that may be added to each such installment may be at a rate that is higher than the interest rate prescribed in the appropriate section of this subchapter. The Secretary may from time to time establish a higher interest rate under the preceding sentence only in accordance with a determination that such higher rate is administratively and actuarially sound for the program of insurance concerned. Any such higher interest rate shall be paid on the unpaid balance of such monthly installments.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc31d86b2-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/128/tIII/s302/a"},"text":"Pub. L. 96–128, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-11-28"},"text":"Nov. 28, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/986"},"text":"93 Stat. 986","children":[],"tail":", § 726; renumbered § 1926 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":", §§ 4(b)(1), (2)(E), 5(a), (c)(1), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404-406"},"text":"105 Stat. 404–406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc31d86b3-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc31d86b4-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc31d86b5-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s726"},"text":"section 726 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “1902, 1923, and 1925” for “702, 723, and 725”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc31d86b6-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc31d86b7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attr