{"tag":"section","attrib":{"id":"idc31fcfed-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1945"},"text":null,"children":[{"tag":"num","attrib":{"value":"1945"},"text":"§ 1945.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewal","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"At the expiration of any term period any insurance policy issued on the five-year level premium term plan which has not been exchanged or converted to a permanent plan of insurance and which is not lapsed shall be renewed as level premium term insurance without application for a successive five-year period at the premium rate for the attained age without medical examination. However, renewal shall be effected in cases where the policy is lapsed only if the insured makes application for reinstatement and renewal of the insured’s term policy within five years after the date of lapse, and reinstatement in such cases shall be under the terms and conditions prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc31fcfee-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1159"},"text":"72 Stat. 1159","children":[],"tail":", § 745; "},{"tag":"ref","attrib":{"href":"/us/pl/91/291/s11"},"text":"Pub. L. 91–291, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-25"},"text":"June 25, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/331"},"text":"84 Stat. 331","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/576/tVII/s701/30"},"text":"Pub. L. 99–576, title VII, § 701(30)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3293"},"text":"100 Stat. 3293","children":[],"tail":"; renumbered § 1945 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":", §§ 4(b)(1), (2)(E), 5(a), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404-406"},"text":"105 Stat. 404–406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc31fcfef-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc31fcff0-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc31fcff1-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s745"},"text":"section 745 of this title","children":[],"tail":" as this section and substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576"},"text":"Pub. L. 99–576","children":[],"tail":" substituted “the insured’s” for “his”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/291"},"text":"Pub. L. 91–291","children":[],"tail":" struck out effective date provision for renewal of policies, provisions that, in case of lapsed policies, such lapse have occurred within two months before the expiration of the term period, special provisions for the interim period between "},{"tag":"date","attrib":{"date":"1953-07-23"},"text":"July 23, 1953","children":[],"tail":" and "},{"tag":"date","attrib":{"date":"1953-12-31"},"text":"December 31, 1953","children":[],"tail":", and provisions that the section take effect on "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", and required that the insurer make application for reinstatement and renewal of his term policy within five years after the date of the lapse."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc31fcff2-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc31fcff3-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/291"},"text":"Pub. L. 91–291","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1970-06-25"},"text":"June 25, 1970","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/291/s14/a"},"text":"section 14(a) of Pub. L. 91–291","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1317"},"text":"section 1317 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
