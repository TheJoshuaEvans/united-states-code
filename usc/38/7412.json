{"tag":"section","attrib":{"id":"idc4099403-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7412"},"text":null,"children":[{"tag":"num","attrib":{"value":"7412"},"text":"§ 7412.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual determination of staffing shortages; recruitment and appointment for needed occupations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc4099404-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7412/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than September 30 of each year, the Inspector General of the Department shall determine, and the Secretary shall publish in the Federal Register, at a minimum, the five clinical occupations and the five nonclinical occupations of personnel of this title of the Department covered under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401"},"text":"section 7401 of this title","children":[],"tail":" for which there are the largest staffing shortages with respect to each medical center of the Department, as calculated over the five-year period preceding the determination."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4099405-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7412/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recruitment and Appointment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding sections 3304 and 3309 through 3318 of title 5, the Secretary may, upon a determination by the Inspector General under subsection (a) that there is a staffing shortage throughout the Department with respect to a particular occupation, recruit and directly appoint, during the fiscal year after the fiscal year during which such determination is made, qualified personnel to serve in that particular occupation for the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc4099406-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/146/tIII/s301/a/1"},"text":"Pub. L. 113–146, title III, § 301(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-08-07"},"text":"Aug. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1784"},"text":"128 Stat. 1784","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/315/tVIII/s802/4"},"text":"Pub. L. 114–315, title VIII, § 802(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1592"},"text":"130 Stat. 1592","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/46/tII/s201"},"text":"Pub. L. 115–46, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-12"},"text":"Aug. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/959"},"text":"131 Stat. 959","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc4099407-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc4099408-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc4099409-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/46"},"text":"Pub. L. 115–46","children":[],"tail":" substituted “at a minimum, the five clinical occupations and the five nonclinical occupations” for “the five occupations” and “with respect to each medical center of the Department,” for “throughout the Department”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/315"},"text":"Pub. L. 114–315","children":[],"tail":" substituted “under subsection (a)” for “under paragraph (1)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc409940a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc409940b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadline for First Determination","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/146/tIII/s301/a/3"},"text":"Pub. L. 113–146, title III, § 301(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-08-07"},"text":"Aug. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1784"},"text":"128 Stat. 1784","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/146/tIII/s301/a/3"},"text":"“Notwithstanding the deadline under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7412"},"text":"section 7412 of title 38","children":[],"tail":", United States Code, as added by paragraph (1), for the annual determination of staffing shortages in the Veterans Health Administration, the Inspector General of the Department of Veterans Affairs shall make the first determination required under such section, and the Secretary of Veterans Affairs shall publish in the Federal Register such determination, by not later than the date that is 180 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2014-08-07"},"text":"Aug. 7, 2014","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
