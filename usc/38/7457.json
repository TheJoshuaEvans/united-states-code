{"tag":"section","attrib":{"id":"idc410c027-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7457"},"text":null,"children":[{"tag":"num","attrib":{"value":"7457"},"text":"§ 7457.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" On-call pay","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc410c028-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7457/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may pay an employee to whom this section applies pay at the rate provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7453/h"},"text":"section 7453(h) of this title","children":[],"tail":" except for such time as the employee may be called back to work."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc410c029-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7457/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This section applies to an employee who meets each of the following criteria:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc410c02a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7457/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The employee is employed in a position listed in paragraph (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401"},"text":"section 7401 of this title","children":[],"tail":" or meets the criteria specified in clauses (i), (ii), and (iii) of "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7455/a/2/B"},"text":"section 7455(a)(2)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc410c02b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7457/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The employee is employed in a work unit for which on-call premium pay is authorized.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc410c02c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7457/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The employee is officially scheduled to be on call outside such employee’s regular hours or on a holiday designated by Federal statute or Executive order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc410c02d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7457/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An employee who is eligible for on-call pay under subsection (a) and who was receiving standby premium pay pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5545"},"text":"section 5545 of title 5","children":[],"tail":" on "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", shall, as long as such employee is employed in the same position and work unit and remains eligible for such standby pay, receive pay for any period of on-call duty at the rate equal to the greater of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc410c02e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7457/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate of pay which such employee would receive if being paid the rate of standby pay pursuant to such section that such individual would be entitled to receive if such individual were not scheduled to be on call instead, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc410c02f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7457/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate of pay which such employee is entitled to receive including on-call premium pay described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc410c030-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s401/b/4"},"text":"Pub. L. 102–40, title IV, § 401(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/236"},"text":"105 Stat. 236","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc410c031-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc410c032-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc410c033-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4107/j"},"text":"section 4107(j) of this title","children":[],"tail":" prior to the repeal of that section as part of the complete revision of chapter 73 of this title by "},{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
