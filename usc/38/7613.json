{"tag":"section","attrib":{"id":"idc4157a93-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7613"},"text":null,"children":[{"tag":"num","attrib":{"value":"7613"},"text":"§ 7613.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scholarship","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc4157a94-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7613/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A scholarship provided to a participant in the Scholarship Program for a school year under the Scholarship Program shall consist of payment of the tuition of the participant for that school year, payment of other reasonable educational expenses (including fees, books, and laboratory expenses) for that school year, and a stipend determined under subsection (b) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4157a95-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7613/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A stipend under this section for a school year shall be payment to the participant of not in excess of $485 per month (adjusted in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7631"},"text":"section 7631 of this title","children":[],"tail":") for each of the 12 consecutive months beginning with the first month of the school year, except that a stipend may not be paid to a participant who is a full-time employee of the Department. The stipend of a participant who is a part-time student shall be adjusted as provided in sections 7614(1) and 7614(2) of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4157a96-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7613/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may arrange with an educational institution in which a participant in the Scholarship Program is enrolled for the payment to the educational institution of the amounts of tuition and other reasonable educational expenses described in subsection (a) of this section. Such payments may be made without regard to subsections (a) and (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3324"},"text":"section 3324 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc4157a97-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/322/tII/s216/b"},"text":"Pub. L. 100–322, title II, § 216(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/521"},"text":"102 Stat. 521","children":[],"tail":", § 4313; renumbered § 7613 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", (d)(1), "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":", 239; "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/3"},"text":"Pub. L. 102–83, § 4(a)(3)","children":[],"tail":", (4), (b)(1), (2)(E), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404"},"text":"105 Stat. 404","children":[],"tail":", 405.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc4157a98-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc4157a99-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc4157a9a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/b/1"},"text":"Pub. L. 102–40, § 402(b)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4313"},"text":"section 4313 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/3"},"text":"Pub. L. 102–83, § 4(a)(3)","children":[],"tail":", (4), substituted “Department” for “Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/d/1"},"text":"Pub. L. 102–40, § 402(d)(1)","children":[],"tail":", substituted “7631” for “4331” and “7614(1) and 7614(2)” for “4314(1) and “4314(2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
