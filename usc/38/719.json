{"tag":"section","attrib":{"id":"idc290d6ae-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s719"},"text":null,"children":[{"tag":"num","attrib":{"value":"719"},"text":"§ 719.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction of benefits of employees convicted of certain crimes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc290d6af-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s719/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reduction of Annuity for Removed Employee","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc290d6b0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s719/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall order that the covered service of an employee of the Department removed from a position for performance or misconduct under section 713, 714, or 7461 of this title or any other provision of law shall not be taken into account for purposes of calculating an annuity with respect to such individual under chapter 83 or chapter 84 of title 5, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc290d6b1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s719/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that the individual is convicted of a felony (and the conviction is final) that influenced the individual’s performance while employed in the position; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc290d6b2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s719/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" before such order is made, the individual is afforded—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc290d6b3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s719/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notice of the proposed order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc290d6b4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s719/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an opportunity to respond to the proposed order by not later than ten business days following receipt of such notice; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc290d6b5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s719/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary issues the order—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc290d6b6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s719/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a proposed order to which an individual responds under subparagraph (B)(ii), not later than five business days after receiving the response of the individual; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc290d6b7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s719/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a proposed order to which an individual does not respond, not later than 15 business days after the Secretary provides notice to the individual under subparagraph (B)(i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc29320a8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s719/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any individual with respect to whom an annuity is reduced under this subsection may appeal the reduction to the Director of the Office of Personnel Management pursuant to such regulations as the Director may prescribe for purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc29320a9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s719/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reduction of Annuity for Retired Employee","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc29320aa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s719/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may order that the covered service of an individual who the Secretary proposes to remove for performance or misconduct under section 713, 714, or 7461 of this title or any other provision of law but who leaves employment at the Department prior to the issuance of a final decision with respect to such action shall not be taken into account for purposes of calculating an annuity with respect to such individual under chapter 83 or chapter 84 of title 5, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc29320ab-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s719/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that individual is convicted of a felony (and the conviction is final) that influenced the individual’s performance while employed in the position; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc29320ac-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s719/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" before such order is made, the individual is afforded—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc29320ad-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s719/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notice of the proposed order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc29320ae-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s719/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" opportunity to respond to the proposed order by not later than ten business days following receipt of such notice; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc29320af-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s719/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary issues the order—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc29320b0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s719/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a proposed order to which an individual responds under subparagraph (B)(ii), not later than five business days after receiving the response of the individual; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc29320b1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s719/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a proposed order to which an individual does not respond, not later than 15 business days after the Secretary provides notice to the individual under subparagraph (B)(i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc29320b2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s719/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon the issuance of an order by the Secretary under paragraph (1), the individual shall have an opportunity to appeal the order to the Director of the Office of Personnel Management before the date that is seven business days after the date of such issuance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc29320b3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s719/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Office of Personnel Management shall make a final decision with respect to an appeal under paragraph (2) within 30 business days of receiving the appeal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc29320b4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s719/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 37 business days after the Secretary issues a final order under subsection (a) or (b) with respect to an individual, the Director of the Office of Personnel Management shall recalculate the annuity of the individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc29320b5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s719/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lump-Sum Annuity Credit","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any individual with respect to whom an annuity is reduced under subsection (a) or (b) shall be entitled to be paid so much of such individual’s lump-sum credit as is attributable to the period of covered service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc29320b6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s719/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Spouse or Children Exception","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc29320b7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s719/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary, in consultation with the Director of the Office of Personnel Management, shall prescribe regulations that may provide for the payment to the spouse or children of any individual referred to in subsection (a) or (b) of any amounts which (but for this subsection) would otherwise have been nonpayable by reason of such subsections.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc29320b8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s719/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Regulations prescribed under paragraph (1) shall be consistent with the requirements of section 8332(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(6) and 8411("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(5) of title 5, as the case may be."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc29320b9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s719/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc29320ba-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s719/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “covered service” means, with respect to an individual subject to a removal for performance or misconduct under section 719 or 7461 of this title or any other provision of law, the period of service beginning on the date that the Secretary determines under such applicable provision that the individual engaged in activity that gave rise to such action and ending on the date that the individual is removed from or leaves a position of employment at the Department prior to the issuance of a final decision with respect to such action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc29320bb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s719/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “lump-sum credit” has the meaning given such term in section 8331(8) or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8401/19"},"text":"section 8401(19) of title 5","children":[],"tail":", as the case may be."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc29320bc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s719/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “service” has the meaning given such term in section 8331(12) or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8401/26"},"text":"section 8401(26) of title 5","children":[],"tail":", as the case may be."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc29320bd-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/41/tII/s203/a/1"},"text":"Pub. L. 115–41, title II, § 203(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-06-23"},"text":"June 23, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/873"},"text":"131 Stat. 873","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/192/s2/b"},"text":"Pub. L. 118–192, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2661"},"text":"138 Stat. 2661","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc29320be-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc29320bf-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc29320c0-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 719 and 720 were renumbered sections 1919 and 1920 of this title, respectively.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc29320c1-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/192"},"text":"Pub. L. 118–192","children":[],"tail":" substituted “section 8332("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(6)” for “section 8332("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(5)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc29320c2-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc29320c3-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/41/tII/s203/b"},"text":"Pub. L. 115–41, title II, § 203(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-06-23"},"text":"June 23, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/875"},"text":"131 Stat. 875","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/41/tII/s203/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s719"},"text":"Section 719 of title 38","children":[],"tail":", United States Code, as added by subsection (a)(1), shall apply to any action of removal of an employee of the Department of Veterans Affairs under section 719 or 7461 of such title or any other provision of law, commencing on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2017-06-23"},"text":"June 23, 2017","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
