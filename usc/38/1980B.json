{"tag":"section","attrib":{"id":"idc32bde16-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1980B"},"text":null,"children":[{"tag":"num","attrib":{"value":"1980B"},"text":"§ 1980B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic review of automatic maximum coverage","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc32bde17-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1980B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"On ","children":[{"tag":"date","attrib":{"date":"2026-01-01"},"text":"January 1, 2026","children":[],"tail":", and every five years thereafter, the Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc32bde18-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1980B/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complete a review of how the amount specified in section 1967(a)(3)(A)(i) compares to the amount described in subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc32bde19-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1980B/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Committees on Veterans’ Affairs of the House of Representatives and the Senate the results of the review, which may serve as a guide for coverage increases within the existing administrative incremental structure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc32bde1a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1980B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount Described","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount described in this subsection is the amount equal to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc32bde1b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1980B/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $500,000; multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc32bde1c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1980B/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average percentage by which the Consumer Price Index changed during the five fiscal years preceding the review under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc32bde1d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1980B/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consumer Price Index Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “Consumer Price Index” means the Consumer Price Index for All Urban Consumers published by the Bureau of Labor Statistics of the Department of Labor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc32bde1e-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/54/s2/a"},"text":"Pub. L. 119–54, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-12"},"text":"Dec. 12, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/705"},"text":"139 Stat. 705","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
