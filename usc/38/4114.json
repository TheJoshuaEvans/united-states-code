ag":"ref","attrib":{"href":"/us/usc/t38/s7472"},"text":"section 7472 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 4123, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/541/s3/a"},"text":"Pub. L. 92–541, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-24"},"text":"Oct. 24, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1107"},"text":"86 Stat. 1107","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/581/tI/s113"},"text":"Pub. L. 94–581, title I, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2852"},"text":"90 Stat. 2852","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/576/tII/s212/c"},"text":"Pub. L. 99–576, title II, § 212(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3257"},"text":"100 Stat. 3257","children":[],"tail":", related to personnel eligible for training. See "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7473"},"text":"section 7473 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 4124, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/541/s3/a"},"text":"Pub. L. 92–541, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-24"},"text":"Oct. 24, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1108"},"text":"86 Stat. 1108","children":[],"tail":", related to consultation with special medical advisory group. See "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7474"},"text":"section 7474 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior sections 4131 to 4134 were renumbered sections 7331 to 7334 of this title, resp