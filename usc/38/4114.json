:", related to eligibility, application, and written contracts for program."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 4143, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/330/tII/s201/a/1"},"text":"Pub. L. 96–330, title II, § 201(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-08-26"},"text":"Aug. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1044"},"text":"94 Stat. 1044","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/251/s3/b"},"text":"Pub. L. 97–251, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-08"},"text":"Sept. 8, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/714"},"text":"96 Stat. 714","children":[],"tail":", related to obligated service."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 4144, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/330/tII/s201/a/1"},"text":"Pub. L. 96–330, title II, § 201(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-08-26"},"text":"Aug. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1045"},"text":"94 Stat. 1045","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/251/s3/c"},"text":"Pub. L. 97–251, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-08"},"text":"Sept. 8, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/715"},"text":"96 Stat. 715","children":[],"tail":", related to liability for breach of contracts and waiver, suspension, discharge, etc., thereof."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 4145, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/330/tII/s201/a/1"},"text":"Pub. L. 96–330, title II, § 201(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-08-26"},"text":"Aug. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1047"},"text":"94 Stat. 1047","children":[],"tail":", related to exemption of scholarship payments from taxation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 4146, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/330/tII/s201/a/1"},"text":"Pub. L. 96–330, title II, § 201(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-08-26"},"text":"Aug. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1047"},"text":"94 Stat. 1047","children":[],"tail":", provided that authority of Administrator to make payments under former subchapter IV of chapter 73 of this title was subject to availability of appropriations for such purposes."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For provisions similar to former sections 4142 to 4146 of this title, see chapter 76 (§ 7601 et seq.) of this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior sections 4151 and 4152 were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s401/a/2/A"},"text":"Pub. L. 102–40, title IV, § 401(a)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/210"},"text":"105 Stat. 210","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 4151, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/166/tII/s204/a/1"},"text":"Pub. L. 99–166, title II, § 204(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-03"},"text":"Dec. 3, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/950"},"text":"99 Stat. 950","children":[],"tail":", related to quality-assurance program. See "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7311"},"text":"section 7311 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 4152, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/166/tII/s204/a/1"},"text":"Pub. L. 99–166, title II, § 204(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-03"},"text":"Dec. 3, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/951"},"text":"99 Stat. 951","children":[],"tail":", related to quality-assurance reports. See "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7311"},"text":"section 7311 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior sections 4161 to 4168 were renumbered sections 7361 to 7368 of this title, respectively.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3bf930c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/56/s237/a/1"},"text":"Pub. L. 112–56, § 237(a)(1)","children":[],"tail":", substituted “shall” for “may”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/56/s237/a/2/A"},"text":"Pub. L. 112–56, § 237(a)(2)(A)","children":[],"tail":", substituted “Assistant Secretary for Veterans’ Employment and Training shall, in consultation with the Assistant Secretary for Employment and Training,” for “Assistant Secretary shall” and “not more than five military” for “not less than 10 military” and inserted “for Veterans’ Employment and Training” after “selected by the Assistant Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/56/s237/a/2/B"},"text":"Pub. L. 112–56, § 237(a)(2)(B)","children":[],"tail":", substituted “enter into a contract with an appropriate entity representing a coalition of State governors to consult with appropriate Federal, State, and industry officials and” for “consult with appropriate Federal, State, and industry officials to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d) to (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/56/s237/a/3"},"text":"Pub. L. 112–56, § 237(a)(3)","children":[],"tail":", added subsec. (d) and struck out former subsecs. (d) to (h) which related to task force, consultation, contract authority, period of project, and funding, respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3bf930d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3bf930e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Veteran Skills to Jobs","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/147"},"text":"Pub. L. 112–147","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-23"},"text":"July 23, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1138"},"text":"126 Stat. 1138","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/147"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“SECTION 1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SHORT TITLE.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“This Act may be cited as the ‘Veteran Skills to Jobs Act’.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“SEC. 2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" CONSIDERATION OF RELEVANT MILITARY TRAINING FOR ISSUANCE OF A FEDERAL LICENSE.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of each Federal licensing authority shall consider and may accept, in the case of any individual applying for a license, any relevant training received by such individual while serving as a member of the armed forces, for the purpose of satisfying the requirements for such license.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this Act—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘license’ means a license, certification, or other grant of permission to engage in a particular activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘Federal licensing authority’ means a department, agency, or other entity of the Government having authority to issue a license;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘armed forces’ has the meaning given such term by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2101/2"},"text":"section 2101(2) of title 5","children":[],"tail":", United States Code; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘Government’ means the Government of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“SEC. 3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" REGULATIONS.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“The head of each Federal licensing authority shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to any license a licensing authority grants or is empowered to grant as of the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2012-07-23"},"text":"July 23, 2012","children":[],"tail":"], prescribe any regulations necessary to carry out this Act not later than 180 days after such date; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to any license of a licensing authority not constituted or not empowered to grant the license as of the date of enactment of this Act, prescribe any regulations necessary to carry out this Act not later than 180 days after the date on which the agency is so constituted or empowered, as the case may be.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
