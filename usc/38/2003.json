ext":"section 4107 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 2007, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1220"},"text":"72 Stat. 1220","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/70/s29/b"},"text":"Pub. L. 86–70, § 29(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-06-25"},"text":"June 25, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/148"},"text":"73 Stat. 148","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/624/s25/c"},"text":"Pub. L. 86–624, § 25(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-12"},"text":"July 12, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/418"},"text":"74 Stat. 418","children":[],"tail":", defined “Korean conflict veterans”, “unemployment compensation”, and “State”, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/87/675/s1/a"},"text":"Pub. L. 87–675, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-19"},"text":"Sept. 19, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/558"},"text":"76 Stat. 558","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior section 2008 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4108"},"text":"section 4108 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 2008, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1220"},"text":"72 Stat. 1220","children":[],"tail":", enumerated provisions which forbade duplication of benefits, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/87/675/s1/a"},"text":"Pub. L. 87–675, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-19"},"text":"Sept. 19, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/558"},"text":"76 Stat. 558","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior section 2009 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4109"},"text":"section 4109 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 2009, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1221"},"text":"72 Stat. 1221","children":[],"tail":", provided termination dates for the payment of benefits under chapter 41 of this title, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/87/675/s1/a"},"text":"Pub. L. 87–675, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-19"},"text":"Sept. 19, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/558"},"text":"76 Stat. 558","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior section 2010 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4110"},"text":"section 4110 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 2010 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4101"},"text":"section 4101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior section 2010A was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4110A"},"text":"section 4110A of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc32e2881-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" inserted at end “In the case of vouchers provided under the HUD–VASH program under section 8("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(19) of such Act, for purposes of the preceding sentence, the term ‘veteran’ shall have the meaning given such term in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2002/b"},"text":"section 2002(b) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315"},"text":"Pub. L. 116–315","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc32e2882-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc32e2883-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report on Staffing of Department of Housing and Urban Development-Department of Veterans Affairs Supported Housing Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/tIV/s4208"},"text":"Pub. L. 116–315, title IV, § 4208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/5015"},"text":"134 Stat. 5015","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/315/tIV/s4208"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":"], and every three years thereafter, the Secretary of Veterans Affairs shall submit to the Committee on Veterans’ Affairs of the Senate and the Committee on Veterans’ Affairs of the House of Representatives a report that includes the following:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An assessment of the hiring needs of the program carried out under section 8(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(19) of the United States Housing Act of 1937 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f"},"text":"42 U.S.C. 1437f","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(19)) (in this section referred to as the ‘HUD-VASH program’), including—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an identification of the number of case managers of the HUD-VASH program as of the date of the report including—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of vacancies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vacancies at each medical center of the Department of Veterans Affairs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of case managers of the HUD-VASH program that the Secretary of Veterans Affairs and the Secretary of Housing and Urban Development jointly determine necessary to meet the needs of the Department and the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of turnover among case managers of the HUD-VASH program and whether the turnover was planned or unexpected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of how compensation, including recruitment and retention incentives, for case managers of the HUD-VASH program affects turnover, and what percentage of retention compensation is provided to such case managers at each medical center of the Department of Veterans Affairs (compared to other positions).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A comparison of compensation described in paragraph (2) with the compensation provided to State, local, and nongovernmental housing employees at comparable training and experience levels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Examples of how the Department of Veterans Affairs and the Department of Housing and Urban Development have worked with non-Federal partners (such as local governments, nongovernmental organizations, veterans service organizations, and employee unions) to meet the staffing needs of the HUD-VASH program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Examples of how medical centers of the Department of Veterans Affairs with high retention rates for case managers of the HUD-VASH program have been able to maintain staffing levels.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
