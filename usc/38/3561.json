{"tag":"section","attrib":{"id":"idc37f54b4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3561"},"text":null,"children":[{"tag":"num","attrib":{"value":"3561"},"text":"§ 3561.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority and duties of Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc37f54b5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3561/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may provide the educational and vocational counseling authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3520"},"text":"section 3520 of this title","children":[],"tail":", and may provide additional counseling if the Secretary deems it to be necessary to accomplish the purposes of this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc37f54b6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3561/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Where any provision of this chapter authorizes or requires any function, power, or duty to be exercised by a State, or by any officer or agency thereof, such function, power, or duty shall, with respect to the Republic of the Philippines, be exercised by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc37f54b7-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1200"},"text":"72 Stat. 1200","children":[],"tail":", § 1761; "},{"tag":"ref","attrib":{"href":"/us/pl/89/358/s3/a/1"},"text":"Pub. L. 89–358, § 3(a)(1)","children":[],"tai