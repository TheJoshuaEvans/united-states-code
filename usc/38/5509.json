{"tag":"section","attrib":{"id":"idc3deb337-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5509"},"text":null,"children":[{"tag":"num","attrib":{"value":"5509"},"text":"§ 5509.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to require fiduciary to receive payments at regional offices of the Department when failing to provide required accounting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3deb338-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5509/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required Reports and Accountings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may require a fiduciary to file a report or accounting pursuant to regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3deb339-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5509/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Actions Upon Failure To File","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In any case in which a fiduciary fails to submit a report or accounting required by the Secretary under subsection (a), the Secretary may, after furnishing notice to such fiduciary and the beneficiary entitled to such payment of benefits, require that such fiduciary appear in person at a regional office of the Department serving the area in which the beneficiary resides in order to receive such payments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3deb33a-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/454/tV/s504/a/1"},"text":"Pub. L. 108–454, title V, § 504(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-10"},"text":"Dec. 10, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3621"},"text":"118 Stat. 3621","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3deb33b-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3deb33c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3deb33d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the seventh month beginning after ","children":[{"tag":"date","attrib":{"date":"2004-12-10"},"text":"Dec. 10, 2004","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/454/s507/a"},"text":"section 507(a) of Pub. L. 108–454","children":[],"tail":", set out as an Effective Date of 2004 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5312"},"text":"section 5312 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
