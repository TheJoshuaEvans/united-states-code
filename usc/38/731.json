{"tag":"section","attrib":{"id":"idc2932122-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s731"},"text":null,"children":[{"tag":"num","attrib":{"value":"731"},"text":"§ 731.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adverse actions against supervisory employees who commit prohibited personnel actions relating to whistleblower complaints","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2932123-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s731/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2932124-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s731/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In accordance with paragraph (2), the Secretary shall carry out the following adverse actions against supervisory employees (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7103/a"},"text":"section 7103(a) of title 5","children":[],"tail":") whom the Secretary, an administrative judge, the Merit Systems Protection Board, the Office of Special Counsel, an adjudicating body provided under a union contract, a Federal judge, or the Inspector General of the Department determines committed a prohibited personnel action described in subsection (c):"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2932125-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s731/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to the first offense, an adverse action that is not less than a 12-day suspension and not more than removal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2932126-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s731/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to the second offense, removal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2932127-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s731/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2932128-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s731/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee against whom an adverse action under paragraph (1) is proposed is entitled to written notice.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2932129-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s731/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc293212a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s731/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee who is notified under subparagraph (A) of being the subject of a proposed adverse action under paragraph (1) is entitled to 10 days following such notification to answer and furnish evidence in support of the answer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc293212b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s731/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the employee does not furnish any such evidence as described in clause (i) or if the Secretary determines that such evidence is not sufficient to reverse the determination to propose the adverse action, the Secretary shall carry out the adverse action following such 10-day period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc293212c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s731/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraphs (1) and (2) of subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7513"},"text":"section 7513 of title 5","children":[],"tail":", subsection (c) of such section, paragraphs (1) and (2) of subsection (b) of section 7543 of such title, and subsection (c) of such section shall not apply with respect to an adverse action carried out under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc293212d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s731/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Other Adverse Actions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to a prohibited personnel action described in subsection (c), if the Secretary carries out an adverse action against a supervisory employee, the Secretary may carry out an additional adverse action under this section based on the same prohibited personnel action if the total severity of the adverse actions do not exceed the level specified in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc293212e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s731/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibited Personnel Action Described","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A prohibited personnel action described in this subsection is any of the following actions:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc293212f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s731/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Taking or failing to take a personnel action in violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2302"},"text":"section 2302 of title 5","children":[],"tail":" against an employee relating to the employee—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2932130-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s731/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making a whistleblower disclosure to the Assistant Secretary for Accountability and Whistleblower Protection, the Inspector General of the Department, the Special Counsel, or Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2932131-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s731/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing information or participating as a witness in an investigation of a whistleblower disclosure made to the Assistant Secretary for Accountability and Whistleblower Protection, the Inspector General of the Department, the Special Counsel, or Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2932132-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s731/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participating in an audit or investigation by the Comptroller General of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2932133-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s731/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refusing to perform an action that is unlawful or prohibited by the Department; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2932134-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s731/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engaging in communications that are related to the duties of the position or are otherwise protected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2932135-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s731/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Preventing or restricting an employee from making an action described in any of subparagraphs (A) through (E) of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2932136-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s731/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Conducting a negative peer review or opening a retaliatory investigation because of an activity of an employee that is protected by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2302"},"text":"section 2302 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2932137-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s731/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Requesting a contractor to carry out an action that is prohibited by section 4705(b) or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s4712/a/1"},"text":"section 4712(a)(1) of title 41","children":[],"tail":", as the case may be."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2932138-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s731/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Whistleblower Disclosure Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “whistleblower disclosure” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s323/g"},"text":"section 323(g) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2932139-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/223/dA/tII/s247/a/1"},"text":"Pub. L. 114–223, div. A, title II, § 247(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-09-29"},"text":"Sept. 29, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/887"},"text":"130 Stat. 887","children":[],"tail":", § 733; renumbered § 731 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/41/tI/s102/a/2"},"text":"Pub. L. 115–41, title I, § 102(a)(2)","children":[],"tail":", (c), title II, § 206, "},{"tag":"date","attrib":{"date":"2017-06-23"},"text":"June 23, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/865"},"text":"131 Stat. 865","children":[],"tail":", 867, 877.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc293213a-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc293213b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc293213c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 731, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/223/dA/tII/s247/a/1"},"text":"Pub. L. 114–223, div. A, title II, § 247(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-09-29"},"text":"Sept. 29, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/884"},"text":"130 Stat. 884","children":[],"tail":", defined whistleblower complaint, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/115/41/tI/s102/a/1"},"text":"Pub. L. 115–41, title I, § 102(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-06-23"},"text":"June 23, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/865"},"text":"131 Stat. 865","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc293213d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/41/s102/a/2"},"text":"Pub. L. 115–41, § 102(a)(2)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s733"},"text":"section 733 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/41/s206"},"text":"Pub. L. 115–41, § 206","children":[],"tail":", substituted “10 days” for “14 days” in cl. (i) and “10-day period” for “14-day period” in cl. (ii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/41/s102/c/1/A/i"},"text":"Pub. L. 115–41, § 102(c)(1)(A)(i)","children":[],"tail":", added subpar. (A) and struck out former subpar. (A) which read as follows: “filing a whistleblower complaint in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s732"},"text":"section 732 of this title","children":[],"tail":";”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/41/s102/c/1/A"},"text":"Pub. L. 115–41, § 102(c)(1)(A)","children":[],"tail":", redesignated subpar. (C) as (B), substituted “disclosure made to the Assistant Secretary for Accountability and Whistleblower Protection,” for “complaint in accordance with section 732 or with”, and struck out former subpar. (B) which read as follows: “filing a whistleblower complaint with the Inspector General of the Department, the Special Counsel, or Congress;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(C) to (F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/41/s102/c/1/A/ii"},"text":"Pub. L. 115–41, § 102(c)(1)(A)(ii)","children":[],"tail":", redesignated subpars. (C) to (F) as (B) to (E), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/41/s102/c/1/B"},"text":"Pub. L. 115–41, § 102(c)(1)(B)","children":[],"tail":", substituted “through (E)” for “through (F)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/41/s102/c/2"},"text":"Pub. L. 115–41, § 102(c)(2)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc293213e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc293213f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Improvement of Training for Supervisors","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/41/tII/s209"},"text":"Pub. L. 115–41, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-06-23"},"text":"June 23, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/879"},"text":"131 Stat. 879","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/41/tII/s209"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Veterans Affairs shall provide to each employee of the Department of Veterans Affairs who is employed as a supervisor periodic training on the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rights of whistleblowers and how to address a report by an employee of a hostile work environment, reprisal, or harassment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" How to effectively motivate, manage, and reward the employees who report to the supervisor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" How to effectively manage employees who are performing at an unacceptable level and access assistance from the human resources office of the Department and the Office of the General Counsel of the Department with respect to those employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Supervisor","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘supervisor’ has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7103/a"},"text":"section 7103(a) of title 5","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Whistleblower","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘whistleblower’ has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s323/g"},"text":"section 323(g) of title 38","children":[],"tail":", United States Code, as added by section 101.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
