{"tag":"section","attrib":{"id":"idc31d86dc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1941"},"text":null,"children":[{"tag":"num","attrib":{"value":"1941"},"text":"§ 1941.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of insurance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"United States Government life insurance shall be issued against death or total permanent disability in any multiple of $500 and not less than $1,000 or more than $10,000. No person may carry a combined amount of National Service Life Insurance and United States Government life insurance in excess of $10,000 at any one time. The limitations of this section shall not apply to the additional paid up insurance the purchase of which is authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1907"},"text":"section 1907 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc31d86dd-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1158"},"text":"72 Stat. 1158","children":[],"tail":", § 741; "},{"tag":"ref","attrib":{"href":"/us/pl/92/188/s1"},"text":"Pub. L. 92–188, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-15"},"text":"Dec. 15, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/645"},"text":"85 Stat. 645","children":[],"tail":"; renumbered § 1941 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Sta