{"tag":"section","attrib":{"id":"idc3080226-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1724"},"text":null,"children":[{"tag":"num","attrib":{"value":"1724"},"text":"§ 1724.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hospital care, medical services, and nursing home care abroad","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3080227-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1724/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsections (b), (c), and (f), the Secretary shall not furnish hospital or domiciliary care or medical services outside any State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3080228-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1724/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3080229-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1724/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may furnish hospital care and medical services outside a State to a veteran who is otherwise eligible to receive hospital care and medical services if the Secretary determines that such care and services are needed for the treatment of a service-connected disability of the veteran or as part of a rehabilitation program under chapter 31 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc308022a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1724/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Care and services for a service-connected disability of a veteran who is not a citizen of the United States may be furnished under this subsection only—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc308022b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1724/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the veteran is in the Republic of the Philippines or in Canada; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc308022c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1724/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary determines, as a matter of discretion and pursuant to regulations which the Secretary shall prescribe, that it is appropriate and feasible to furnish such care and services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc308022d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1724/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Within the limits of those facilities of the Veterans Memorial Medical Center at Manila, Republic of the Philippines, for which the Secretary may contract, the Secretary may furnish necessary hospital care to a veteran for any non-service-connected disability if such veteran is unable to defray the expenses of necessary hospital care. The Secretary may enter into contracts to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc308022e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1724/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may furnish nursing home care, on the same terms and conditions set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1720/a"},"text":"section 1720(a) of this title","children":[],"tail":", to any veteran who has been furnished hospital care in the Philippines pursuant to this section, but who requires a protracted period of nursing home care."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc308022f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1724/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Within the limits of an outpatient clinic in the Republic of the Philippines that is under the direct jurisdiction of the Secretary, the Secretary may furnish a veteran who has a service-connected disability with such medical services as the Secretary determines to be needed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3080230-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1724/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3080231-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1724/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3080232-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1724/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may furnish hospital care and medical services in the Freely Associated States, subject to agreements the Secretary shall enter into with the governments of the Freely Associated States as described in section 209(a)(4)(A) of the Compact of Free Association Amendments Act of 2024, and subject to subparagraph (B), to a veteran who is otherwise eligible to receive hospital care and medical services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3080233-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1724/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The agreements described in subparagraph (A) shall incorporate, to the extent practicable, the applicable laws of the Freely Associated States and define the care and services that can be legally provided by the Secretary in the Freely Associated States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3080234-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1724/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In furnishing hospital care and medical services under paragraph (1), the Secretary may furnish hospital care and medical services through—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3080235-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1724/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contracts or other agreements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3080236-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1724/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reimbursement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3080237-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1724/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the direct provision of care by health care personnel of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3080238-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1724/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In furnishing hospital care and medical services under paragraph (1), the Secretary may furnish hospital care and medical services for any condition regardless of whether the condition is connected to the service of the veteran in the Armed Forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3080239-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1724/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc308023a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1724/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A veteran who has received hospital care or medical services in a country pursuant to this subsection shall remain eligible, to the extent determined advisable and practicable by the Secretary, for hospital care or medical services in that country regardless of whether the country continues to qualify as a Freely Associated State for purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc308023b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1724/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the Secretary determines it is no longer advisable or practicable to allow veterans described in subparagraph (A) to remain eligible for hospital care or medical services pursuant to such subparagraph, the Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc308023c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1724/f/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide direct notice of that determination to such veterans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc308023d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1724/f/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish that determination and the reasons for that determination in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc308023e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1724/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this subsection, the term “Freely Associated States” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc308023f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1724/f/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federated States of Micronesia, during such time as it is a party to the Compact of Free Association set forth in section 201 of the Compact of Free Association Act of 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/239"},"text":"Public Law 99–239","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1901"},"text":"48 U.S.C. 1901","children":[],"tail":" note);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3080240-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1724/f/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Republic of the Marshall Islands, during such time as it is a party to the Compact of Free Association set forth in section 201 of the Compact of Free Association Act of 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/239"},"text":"Public Law 99–239","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1901"},"text":"48 U.S.C. 1901","children":[],"tail":" note); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3080241-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1724/f/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Republic of Palau, during such time as it is a party to the Compact of Free Association between the United States and the Government of Palau set forth in section 201 of Joint ","children":[{"tag":"ref","attrib":{"idref":"fn002038"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002038"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by “the”."}],"tail":" Resolution entitled “Joint Resolution to approve the ‘Compact of Free Association’ between the United States and the Government of Palau, and for other purposes” ("},{"tag":"ref","attrib":{"href":"/us/pl/99/658"},"text":"Public Law 99–658","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1931"},"text":"48 U.S.C. 1931","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3080242-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1144"},"text":"72 Stat. 1144","children":[],"tail":", § 624; "},{"tag":"ref","attrib":{"href":"/us/pl/86/152"},"text":"Pub. L. 86–152","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-08-11"},"text":"Aug. 11, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/332"},"text":"73 Stat. 332","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/624/s25/a"},"text":"Pub. L. 86–624, § 25(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-12"},"text":"July 12, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/418"},"text":"74 Stat. 418","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/815/s4"},"text":"Pub. L. 87–815, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-15"},"text":"Oct. 15, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/927"},"text":"76 Stat. 927","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/82/tI/s108"},"text":"Pub. L. 93–82, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-08-02"},"text":"Aug. 2, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/186"},"text":"87 Stat. 186","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/581/tII"},"text":"Pub. L. 94–581, title II","children":[],"tail":", §§ 202("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), 210(a)(11), "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2856"},"text":"90 Stat. 2856","children":[],"tail":", 2863; "},{"tag":"ref","attrib":{"href":"/us/pl/95/520/s3/a"},"text":"Pub. L. 95–520, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-26"},"text":"Oct. 26, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1820"},"text":"92 Stat. 1820","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/72/tI/s107/a"},"text":"Pub. L. 97–72, title I, § 107(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-11-03"},"text":"Nov. 3, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1051"},"text":"95 Stat. 1051","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/295/s4/20"},"text":"Pub. L. 97–295, § 4(20)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1306"},"text":"96 Stat. 1306","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/322/tI/s105"},"text":"Pub. L. 100–322, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/493"},"text":"102 Stat. 493","children":[],"tail":"; renumbered § 1724 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":", §§ 4(b)(1), (2)(E), 5(a), (c)(1), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404-406"},"text":"105 Stat. 404–406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/377/s1/a/1/tV/s501/c"},"text":"Pub. L. 106–377, § 1(a)(1) [title V, § 501(c)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-27"},"text":"Oct. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1441"},"text":"114 Stat. 1441","children":[],"tail":", 1441A–58; "},{"tag":"ref","attrib":{"href":"/us/pl/118/42/dG/tII/s209/a/2"},"text":"Pub. L. 118–42, div. G, title II, § 209(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-03-09"},"text":"Mar. 9, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/438"},"text":"138 Stat. 438","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3080243-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3080244-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc3080245-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 209(a)(4)(A) of the Compact of Free Association Amendments Act of 2024, referred to in subsec. (f)(1)(A), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1988/a/4/A"},"text":"section 1988(a)(4)(A) of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc3080246-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior section 1724 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3524"},"text":"section 3524 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior section 1725, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1197"},"text":"72 Stat. 1197","children":[],"tail":", related to period of operation for approval by Administrator, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/92/540/tIV/s402/2"},"text":"Pub. L. 92–540, title IV, § 402(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-24"},"text":"Oct. 24, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1090"},"text":"86 Stat. 1090","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3689"},"text":"section 3689 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3080247-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/42/s209/a/2/A"},"text":"Pub. L. 118–42, § 209(a)(2)(A)","children":[],"tail":", substituted “subsections (b), (c), and (f)” for “subsections (b) and (c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/42/s209/a/2/B"},"text":"Pub. L. 118–42, § 209(a)(2)(B)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/377"},"text":"Pub. L. 106–377","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s624"},"text":"section 624 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “1720(a)” for “620(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/322"},"text":"Pub. L. 100–322","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “The Administrator may furnish necessary hospital care and medical services to any otherwise eligible veteran for any service-connected disability if the veteran (1) is a citizen of the United States sojourning or residing abroad, or (2) is in the Republic of the Philippines.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295"},"text":"Pub. L. 97–295","children":[],"tail":" substituted “Hospital care, medical services, and nursing home care abroad” for “Hospital care and medical services abroad” in section catchline, without regard to a prior amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/93/82"},"text":"Pub. L. 93–82","children":[],"tail":", which had substituted “Hospital care, medical services and nursing home care abroad” for “Hospital care and medical services abroad”. See 1973 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/72"},"text":"Pub. L. 97–72","children":[],"tail":" struck out “and at the same rate as specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s632/a/4"},"text":"section 632(a)(4) of this title","children":[],"tail":"” after “on the same terms and conditions set forth in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s620/a"},"text":"section 620(a) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/520"},"text":"Pub. L. 95–520","children":[],"tail":" substituted “Veterans Memorial Medical Center” for “Veterans Memorial Hospital”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/581"},"text":"Pub. L. 94–581","children":[],"tail":" substituted “the Administrator may furnish” for “he may furnish” and “hospital care to a veteran for any” for “hospital care to a veteran of any war for any”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/82/s108/b"},"text":"Pub. L. 93–82, § 108(b)","children":[],"tail":", substituted “Hospital care, medical services and nursing home care abroad” for “Hospital care and medical services abroad” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/82/s108/a"},"text":"Pub. L. 93–82, § 108(a)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/815"},"text":"Pub. L. 87–815","children":[],"tail":" struck out “temporarily” before “sojourning”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/624"},"text":"Pub. L. 86–624","children":[],"tail":" substituted “outside any State” for “outside the continental limits of the United States, or a Territory, Commonwealth, or possession of the United States”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1959—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/152"},"text":"Pub. L. 86–152","children":[],"tail":" extended authority to provide hospital and medical care for veterans who are United States citizens temporarily residing abroad to include those with peacetime service-incurred disabilities."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3080248-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment",