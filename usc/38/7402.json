{"tag":"section","attrib":{"id":"idc404d8cd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402"},"text":null,"children":[{"tag":"num","attrib":{"value":"7402"},"text":"§ 7402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications of appointees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc404d8ce-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To be eligible for appointment to the positions in the Administration covered by subsection (b), a person must have the applicable qualifications set forth in that subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc404d8cf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc404d8d0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Physician","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to be appointed to a physician position, a person must—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc404d8d1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold the degree of doctor of medicine or of doctor of osteopathy from a college or university approved by the Secretary,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc404d8d2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have completed an internship satisfactory to the Secretary, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc404d8d3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be licensed to practice medicine, surgery, or osteopathy in a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc404d8d4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Dentist","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to be appointed to a dentist position, a person must—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc404d8d5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold the degree of doctor of dental surgery or dental medicine from a college or university approved by the Secretary, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc404d8d6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be licensed to practice dentistry in a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc404d8d7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nurse","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to be appointed to a nurse position, a person must—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc404d8d8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have successfully completed a full course of nursing in a recognized school of nursing, approved by the Secretary, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc404d8d9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be registered as a graduate nurse in a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc404d8da-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Director of a Hospital, Domiciliary, Center, or Outpatient Clinic","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To be eligible to be appointed to a director position, a person must have such business and administrative experience and qualifications as the Secretary shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc404d8db-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Podiatrist","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to be appointed to a podiatrist position, a person must—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc404d8dc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold the degree of doctor of podiatric medicine, or its equivalent, from a school of podiatric medicine approved by the Secretary, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc404d8dd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be licensed to practice podiatry in a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc404d8de-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Optometrist","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to be appointed to an optometrist position, a person must—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc404d8df-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold the degree of doctor of optometry, or its equivalent, from a school of optometry approved by the Secretary, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc404d8e0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be licensed to practice optometry in a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc404d8e1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pharmacist","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to be appointed to a pharmacist position, a person must—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc404d8e2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold the degree of bachelor of science in pharmacy, or its equivalent, from a school of pharmacy, approved by the Secretary, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc404d8e3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be registered as a pharmacist in a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc404d8e4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Psychologist","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to be appointed to a psychologist position, a person must—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc404d8e5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold a doctoral degree in psychology from a college or university approved by the Secretary,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc404d8e6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have completed study for such degree in a specialty area of psychology and an internship which are satisfactory to the Secretary, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc404d8e7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be licensed or certified as a psychologist in a State, except that the Secretary may waive the requirement of licensure or certification for an individual psychologist for a period not to exceed two years on the condition that that psychologist provide patient care only under the direct supervision of a psychologist who is so licensed or certified.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc404d8e8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Social Worker","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to be appointed to a social worker position, a person must—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc404d8e9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold a master’s degree in social work from a college or university approved by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc404d8ea-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be licensed or certified to independently practice social work in a State, except that the Secretary may waive the requirement of licensure or certification for an individual social worker for a reasonable period of time recommended by the Under Secretary for Health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc404d8eb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Marriage and Family Therapist","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to be appointed to a marriage and family therapist position, a person must—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc404d8ec-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold a master’s degree in marriage and family therapy, or a comparable degree in mental health, from a college or university approved by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc404d8ed-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be licensed or certified to independently practice marriage and family therapy in a State, except that the Secretary may waive the requirement of licensure or certification for an individual marriage and family therapist for a reasonable period of time recommended by the Under Secretary for Health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc404d8ee-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Licensed Professional Mental Health Counselor","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to be appointed to a licensed professional mental health counselor position, a person must—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc404d8ef-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold a master’s degree or doctoral degree in mental health counseling, or a related field, from a college or university approved by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc404d8f0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be licensed or certified to independently practice mental health counseling.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc404d8f1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chiropractor","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to be appointed to a chiropractor position, a person must—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc404d8f2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold the degree of doctor of chiropractic, or its equivalent, from a college of chiropractic approved by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc404d8f3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be licensed to practice chiropractic in a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc404d8f4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peer Specialist.—","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to be appointed to a peer specialist position, a person must—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc404d8f5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a veteran who has recovered or is recovering from a mental health condition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc404d8f6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be certified by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc404d8f7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/13/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a not-for-profit entity engaged in peer specialist training as having met such criteria as the Secretary shall establish for a peer specialist position; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc404d8f8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/13/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State as having satisfied relevant State requirements for a peer specialist position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc404d8f9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/b/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Health-Care Positions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To be appointed as a physician assistant, expanded-function dental auxiliary, certified or registered respiratory therapist, licensed physical therapist, licensed practical or vocational nurse, occupational therapist, dietitian, microbiologist, chemist, biostatistician, medical technologist, dental technologist, hearing aid specialist, or other position, a person must have such medical, dental, scientific, or technical qualifications as the Secretary shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc404d8fa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7407/a"},"text":"section 7407(a) of this title","children":[],"tail":", a person may not be appointed in the Administration to a position listed in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401/1"},"text":"section 7401(1) of this title","children":[],"tail":" unless the person is a citizen of the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc404d8fb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person may not be appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401/1"},"text":"section 7401(1) of this title","children":[],"tail":" to serve in the Administration in any direct patient-care capacity unless the Under Secretary for Health determines that the person possesses such basic proficiency in spoken and written English as will permit such degree of communication with patients and other health-care personnel as will enable the person to carry out the person’s health-care responsibilities satisfactorily. Any determination by the Under Secretary for Health under this subsection shall be in accordance with regulations which the Secretary shall prescribe."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc404d8fc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person may not serve as Chief of Staff of a Department health-care facility if the person is not serving on a full-time basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc404d8fd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person may not be employed in a position under subsection (b) (other than under paragraph (4) of that subsection) if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc404d8fe-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person is or has been licensed, registered, or certified (as applicable to such position) in more than one State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc404d8ff-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" either—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc404d900-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any of those States has terminated such license, registration, or certification for cause; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc404d901-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person has voluntarily relinquished such license, registration, or certification in any of those States after being notified in writing by that State of potential termination for cause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc404d902-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may enter into contracts with not-for-profit entities to provide—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc404d903-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" peer specialist training to veterans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc404d904-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7402/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certification for veterans under subsection (b)(13)(B)(i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc404d905-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s401/b/2"},"text":"Pub. L. 102–40, title IV, § 401(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/222"},"text":"105 Stat. 222","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/86/tIII/s305/a"},"text":"Pub. L. 102–86, title III, § 305(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-14"},"text":"Aug. 14, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/417"},"text":"105 Stat. 417","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/405/tIII/s302/c/1"},"text":"Pub. L. 102–405, title III, § 302(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-09"},"text":"Oct. 9, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1984"},"text":"106 Stat. 1984","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/117/tII/s209"},"text":"Pub. L. 106–117, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-30"},"text":"Nov. 30, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1569"},"text":"113 Stat. 1569","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/419/tII/s205"},"text":"Pub. L. 106–419, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1842"},"text":"114 Stat. 1842","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/170/tIII/s302/b"},"text":"Pub. L. 108–170, title III, § 302(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2058"},"text":"117 Stat. 2058","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/461/tII/s201/b"},"text":"Pub. L. 109–461, title II, § 201(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3409"},"text":"120 Stat. 3409","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/387/tIV/s405"},"text":"Pub. L. 110–387, title IV, § 405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4129"},"text":"122 Stat. 4129","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/256/s4/a/2"},"text":"Pub. L. 114–256, § 4(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-14"},"text":"Dec. 14, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1347"},"text":"130 Stat. 1347","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/315/tVI/s613"},"text":"Pub. L. 114–315, title VI, § 613","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1576"},"text":"130 Stat. 1576","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc404d906-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc404d907-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc404d908-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in sections 4105 and 4108(b) of this title prior to the repeal of those sections as part of the complete revision of chapter 73 of this title by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc404d909-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(11)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/315"},"text":"Pub. L. 114–315","children":[],"tail":" inserted “or doctoral degree” after “master’s degree”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/256"},"text":"Pub. L. 114–256","children":[],"tail":" inserted “, hearing aid specialist” after “dental technologist”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/387/s405/a/1"},"text":"Pub. L. 110–387, § 405(a)(1)","children":[],"tail":", redesignated par. (11) relating to other health care positions as (14)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/387/s405/a/2"},"text":"Pub. L. 110–387, § 405(a)(2)","children":[],"tail":", added par. (13)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/387/s405/a/1"},"text":"Pub. L. 110–387, § 405(a)(1)","children":[],"tail":", redesignated par. (11) relating to other health care positions as (14)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/387/s405/b"},"text":"Pub. L. 110–387, § 405(b)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(10) to (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461"},"text":"Pub. L. 109–461","children":[],"tail":" added par. (10) and the par. (11) relating to licensed professional health counselor and redesignated former par. (10) as (12)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (b)(10), (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/170"},"text":"Pub. L. 108–170","children":[],"tail":" added par. (10) and redesignated former par. (10) as (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (b)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/419"},"text":"Pub. L. 106–419","children":[],"tail":" substituted “a person must—” and subpars. (A) and (B) for “a person must hold a master’s degree in social work from a college or university approved by the Secretary and satisfy the social worker licensure, certification, or registration requirements, if any, of the State in which the social worker is to be employed, except that the Secretary may waive the licensure, certification, or registration requirement of this paragraph for an individual social worker for a reasonable period, not to exceed 3 years, in order for the social worker to take any actions necessary to satisfy the licensure, certification, or registration requirements of such State.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117"},"text":"Pub. L. 106–117","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/405"},"text":"Pub. L. 102–405","children":[],"tail":" substituted “Under Secretary for Health” for “Chief Medical Director” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (b)(9), (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/86"},"text":"Pub. L. 102–86","children":[],"tail":" added par. (9) and redesignated former par. (9) as (10)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc404d90a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc404d90b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/170"},"text":"Pub. L. 108–170","children":[],"tail":" effective at end of 180-day period beginning on "},{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/170/s302/h"},"text":"section 302(h) of Pub. L. 108–170","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7316"},"text":"section 7316 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc404d90c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/86/tIII/s305/b"},"text":"Pub. L. 102–86, title III, § 305(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-14"},"text":"Aug. 14, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/417"},"text":"105 Stat. 417","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/86/tIII/s305/b"},"text":"“The amendment made by subsection (a) [amending this section] does not apply to any person employed as a social worker by the Department of Veterans Affairs on or before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1991-08-14"},"text":"Aug. 14, 1991","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc404d90d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prescription of Technical Qualifications for Licensed Hearing Aid Specialists and Requirement for Appointment of Such Specialists","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/171/tVII/s703"},"text":"Pub. L. 116–171, title VII, § 703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-17"},"text":"Oct. 17, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/829"},"text":"134 Stat. 829","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/171/tVII/s703"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Technical Qualifications.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2020-10-17"},"text":"Oct. 17, 2020","children":[],"tail":"], the Secretary of Veterans Affairs shall prescribe the technical qualifications required under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7402/b/14"},"text":"section 7402(b)(14) of title 38","children":[],"tail":", United States Code, to be appointed as a licensed hearing aid specialist under section 7401(3) of such title."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements for qualifications","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In prescribing the qualifications for licensed hearing aid specialists under paragraph (1), the Secretary shall, at a minimum, ensure that such qualifications are consistent with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the standards for licensure of hearing aid specialists that are required by a majority of States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any competencies needed to perform tasks and services commonly performed by hearing aid specialists pursuant to such standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any competencies needed to perform tasks specific to providing care to individuals under the laws administered by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to Set and Maintain Duties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall retain the authority to set and maintain the duties for licensed hearing aid specialists appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401/3"},"text":"section 7401(3) of title 38","children":[],"tail":", United States Code, for the purposes of the employment of such specialists with the Department of Veterans Affairs."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2022-09-30"},"text":"September 30, 2022","children":[],"tail":", the Secretary shall appoint not fewer than one licensed hearing aid specialist at each medical center of the Department."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2022-09-30"},"text":"September 30, 2022","children":[],"tail":", and annually thereafter, the Secretary shall submit to the Committee on Veterans’ Affairs of the Senate and the Committee on Veterans’ Affairs of the House of Representatives a report—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing the progress of the Secretary in appointing licensed hearing aid specialists under subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing potential conflicts or obstacles that prevent the appointment of licensed hearing aid specialists;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing the factors that led to such conflicts or obstacles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing access of patients to comprehensive hearing health care services from the Department consistent with the requirements under section 4(b) of the Veterans Mobility Safety Act of 2016 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/256"},"text":"Public Law 114–256","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401"},"text":"38 U.S.C. 7401","children":[],"tail":" note), including an assessment of the impact of infrastructure and equipment limitations on wait times for audiologic care; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indicating the medical centers of the Department with vacancies for audiologists or licensed hearing aid specialists.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc404d90e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Requirements Respecting Basic Proficiency in Spoken and Written English of Appointees After ","children":[{"tag":"date","attrib":{"date":"1977-11-23"},"text":"November 23, 1977","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/201/s4/a/3"},"text":"Pub. L. 95–201, § 4(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-11-23"},"text":"Nov. 23, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1430"},"text":"91 Stat. 1430","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/201/s4/a/3"},"text":"“Notwithstanding any other provision of law, with respect to persons other than those described in subsection (c) of section 4105 and subsection (f) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4114"},"text":"section 4114 of title 38","children":[],"tail":", United States Code [former sections 4105(c) and 4114(f) of this title, see subsec. (d) of this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7407/d"},"text":"section 7407(d) of this title","children":[],"tail":"] (as added by paragraphs (1) and (2) of this subsection), who are appointed after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1977-11-23"},"text":"Nov. 23, 1977","children":[],"tail":"] in the Department of Medicine and Surgery in the Veterans’ Administration [now Veterans Health Administration of the Department of Veterans Affairs] in any direct patient-care capacity, and with respect to persons described in such subsections who are appointed after such enactment date and prior to "},{"tag":"date","attrib":{"date":"1978-01-01"},"text":"January 1, 1978","children":[],"tail":", the Administrator of Veterans’ Affairs [now Secretary of Veterans Affairs], upon the recommendation of the Chief Medical Director [now Under Secretary for Health], shall take appropriate steps to provide reasonable assurance that such persons possess such basic proficiency in spoken and written English as will permit such degree of communication with patients and other health-care personnel as will enable such persons to carry out their health-care responsibilities satisfactorily.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
