{"tag":"section","attrib":{"id":"idc35dea8c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3114"},"text":null,"children":[{"tag":"num","attrib":{"value":"3114"},"text":"§ 3114.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vocational rehabilitation outside the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Under regulations which the Secretary shall prescribe, a vocational rehabilitation program under this chapter may be provided outside the United States if the Secretary determines that such training is (1) necessary in the particular case to provide the preparation needed to render a veteran employable and enable such veteran to obtain and retain suitable employment, and (2) in the best interest of such veteran and the Federal Government.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc35dea8d-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466/tI/s101/a"},"text":"Pub. L. 96–466, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2182"},"text":"94 Stat. 2182","children":[],"tail":", § 1514; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIV/s423/b/1/A"},"text":"Pub. L. 101–237, title IV, § 423(b)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2092"},"text":"103 Stat. 2092","children":[],"tail":"; renumbered § 3114, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tai