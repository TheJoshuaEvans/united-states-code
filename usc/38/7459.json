{"tag":"section","attrib":{"id":"idc410c052-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7459"},"text":null,"children":[{"tag":"num","attrib":{"value":"7459"},"text":"§ 7459.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nursing staff: special rules for overtime duty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc410c053-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7459/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (c), the Secretary may not require nursing staff to work more than 40 hours (or 24 hours if such staff is covered under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7456"},"text":"section 7456 of this title","children":[],"tail":") in an administrative work week or more than eight consecutive hours (or 12 hours if such staff is covered under section 7456 or 7456A of this title)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc410c054-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7459/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Voluntary Overtime","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc410c055-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7459/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nursing staff may on a voluntary basis elect to work hours otherwise prohibited by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc410c056-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7459/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The refusal of nursing staff to work hours prohibited by subsection (a) shall not be grounds—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc410c057-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7459/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to discriminate (within the meaning of section 704(a) of the Civil Rights Act of 1964 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e–3/a"},"text":"42 U.S.C. 2000e–3(a)","children":[],"tail":")) against the staff;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc410c058-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7459/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to dismiss or discharge the staff; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc410c059-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7459/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any other adverse personnel action against the staff.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc410c05a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7459/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Overtime Under Emergency Circumstances","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc410c05b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7459/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to paragraph (2), the Secretary may require nursing staff to work hours otherwise prohibited by subsection (a) if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc410c05c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7459/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the work is a consequence of an emergency that could not have been reasonably anticipated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc410c05d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7459/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the emergency is non-recurring and is not caused by or aggravated by the inattention of the Secretary or lack of reasonable contingency planning by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc410c05e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7459/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary has exhausted all good faith, reasonable attempts to obtain voluntary workers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc410c05f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7459/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nurse staff have critical skills and expertise that are required for the work; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc410c060-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7459/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the work involves work for which the standard of care for a patient assignment requires continuity of care through completion of a case, treatment, or procedure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc410c061-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7459/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nursing staff may not be required to work hours under this subsection after the requirement for a direct role by the staff in responding to medical needs resulting from the emergency ends.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc410c062-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7459/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nursing Staff Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “nursing staff” includes the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc410c063-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7459/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A registered nurse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc410c064-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7459/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A licensed practical or vocational nurse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc410c065-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7459/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A nurse assistant appointed under this chapter or title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc410c066-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7459/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other nurse position designated by the Secretary for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc410c067-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163/tVI/s602/a/1"},"text":"Pub. L. 111–163, title VI, § 602(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-05-05"},"text":"May 5, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1172"},"text":"124 Stat. 1172","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
