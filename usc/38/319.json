{"tag":"section","attrib":{"id":"idc27dc3dc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s319"},"text":null,"children":[{"tag":"num","attrib":{"value":"319"},"text":"§ 319.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Employment Discrimination Complaint Adjudication","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc27dc3dd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s319/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc27dc3de-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s319/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is in the Department an Office of Employment Discrimination Complaint Adjudication. There is at the head of the Office a Director.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27dc3df-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s319/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall be a career appointee in the Senior Executive Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27dc3e0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s319/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director reports directly to the Secretary or the Deputy Secretary concerning matters within the responsibility of the Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc27dc3e1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s319/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc27dc3e2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s319/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director is responsible for making the final agency decision within the Department on the merits of any employment discrimination complaint filed by an employee, or an applicant for employment, with the Department. The Director shall make such decisions in an impartial and objective manner.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27dc3e3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s319/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No person may make any ex parte communication to the Director or to any employee of the Office with respect to a matter on which the Director has responsibility for making a final agency decision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc27dc3e4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s319/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever the Director has reason to believe that there has been retaliation against an employee by reason of the employee asserting rights under an equal employment opportunity law, the Director shall report the suspected retaliatory action directly to the Secretary or Deputy Secretary, who shall take appropriate action thereon.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc27dc3e5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s319/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc27dc3e6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s319/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office shall employ a sufficient number of attorneys and other personnel as are necessary to carry out the functions of the Office. Attorneys shall be compensated at a level commensurate with attorneys employed by the Office of the General Counsel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27dc3e7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s319/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall ensure that the Director is furnished sufficient resources in addition to personnel under paragraph (1) to enable the Director to carry out the functions of the Office in a timely manner.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27dc3e8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s319/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall ensure that any performance appraisal of the Director of the Office of Employment Discrimination Complaint Adjudication or of any employee of the Office does not take into consideration the record of the Director or employee in deciding cases for or against the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc27dc3e9-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/114/tI/s102/a/1"},"text":"Pub. L. 105–114, title I, § 102(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2280"},"text":"111 Stat. 2280","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc27dc3ea-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc27dc3eb-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc27dc3ec-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/114/tI/s102/c"},"text":"Pub. L. 105–114, title I, § 102(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2281"},"text":"111 Stat. 2281","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/114/tI/s102/c"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s319"},"text":"Section 319 of title 38","children":[],"tail":", United States Code, as added by subsection (a), shall take effect 90 days after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc27dc3ed-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reports on Implementation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/114/tI/s102/b"},"text":"Pub. L. 105–114, title I, § 102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2281"},"text":"111 Stat. 2281","children":[],"tail":", required the Director of the Office of Employment Discrimination Complaint Adjudication of the Department of Veterans Affairs to submit to the Secretary of Veterans Affairs and to Congress reports on the implementation and the operation of the office, with the first report due not later than "},{"tag":"date","attrib":{"date":"1998-04-01"},"text":"Apr. 1, 1998","children":[],"tail":", and subsequent reports due not later than "},{"tag":"date","attrib":{"date":"1999-01-01"},"text":"Jan. 1, 1999","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"2000-01-01"},"text":"Jan. 1, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
