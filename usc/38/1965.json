functions:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) Bathing.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) Continence.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) Dressing.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) Eating.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(E) Toileting.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(F) Transferring.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Par. (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/13"},"text":"Pub. L. 109–13","children":[],"tail":" added par. (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Par. (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/14"},"text":"Pub. L. 107–14","children":[],"tail":" added par. (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Par. (5)(C), (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/419"},"text":"Pub. L. 106–419","children":[],"tail":" added subpar. (C) and redesignated former subpar. (C) as (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Par. (5)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/275/s402/a/1"},"text":"Pub. L. 104–275, § 402(a)(1)","children":[],"tail":", inserted “and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5)(C) to (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/275/s402/a/2"},"text":"Pub. L. 104–275, § 402(a)(2)","children":[],"tail":", (3), redesignated subpar. (E) as (C) and struck out former subpars. (C) and (D) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) a person assigned to, or who upon application would be eligible for assignment to, the Retired Reserve of a uniformed service who has not received the first increment of retirement pay or has not yet reached sixty-one years of age and has completed at least twenty years of satisfactory service creditable for retirement purposes under chapter 1223 of title 10 (or under chapter 67 of that title as in effect before the effective date of the Reserve Officer Personnel Management Act);","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) a person transferred to the Retired Reserve of a uniformed service under the temporary special retirement authority provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1331a"},"text":"section 1331a of title 10","children":[],"tail":" who has not received the first increment of retirement pay or has not reached sixty-one years of age; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Par. (5)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1677/d/1"},"text":"Pub. L. 103–337, § 1677(d)(1)","children":[],"tail":", substituted “chapter 1223 of title 10 (or under chapter 67 of that title as in effect before the effective date of the Reserve Officer Personnel Management Act)” for “chapter 67 of title 10”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5)(D), (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s651/a"},"text":"Pub. L. 103–337, § 651(a)","children":[],"tail":", added subpar. (D) and redesignated former subpar. (D) as (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s765"},"text":"section 765 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/54/s14/b/16/A"},"text":"Pub. L. 102–54, § 14(b)(16)(A)","children":[],"tail":", redesignated cls. (i) and (ii) as (A) and (B), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/54/s14/b/16/B"},"text":"Pub. L. 102–54, § 14(b)(16)(B)","children":[],"tail":", redesignated cls. (a) to (e) as (A) to (E), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “1966(b)” for “766(b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/54/s14/b/16/B"},"text":"Pub. L. 102–54, § 14(b)(16)(B)","children":[],"tail":", redesignated cls. (a) to (e) as (A) to (E), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Par. (5)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576/s701/35/A"},"text":"Pub. L. 99–576, § 701(35)(A)","children":[],"tail":", substituted “such person” for “he”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576/s701/35/B"},"text":"Pub. L. 99–576, § 701(35)(B)","children":[],"tail":", substituted “the child’s” for “his” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Par. (1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/289/s10/1"},"text":"Pub. L. 93–289, § 10(1)","children":[],"tail":", substituted “National Oceanic and Atmospheric Administration” for “Environmental Science Services Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/289/s3"},"text":"Pub. L. 93–289, § 3","children":[],"tail":", added cls. (B) and (C), redesignated former cl. (B) as (D), and substituted “midshipman of” for “midshipman at” in cl. (A)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/289/s10/1"},"text":"Pub. L. 93–289, § 10(1)","children":[],"tail":", substituted “National Oceanic and Atmospheric Administration” for “Environmental Science Services Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Par. (1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/315/s1/3"},