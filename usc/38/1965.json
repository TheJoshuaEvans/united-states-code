{"tag":"section","attrib":{"id":"idc3224187-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1965"},"text":null,"children":[{"tag":"num","attrib":{"value":"1965"},"text":"§ 1965.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3224188-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1965/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “active duty” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3224189-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1965/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" full-time duty in the Armed Forces, other than active duty for training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc322418a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1965/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" full-time duty (other than for training purposes) as a commissioned officer of the Regular or Reserve Corps ","children":[{"tag":"ref","attrib":{"idref":"fn002040"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002040"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Change of Name note below."}],"tail":" of the Public Health Service;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc322418b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1965/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" full-time duty as a commissioned officer of the National Oceanic and Atmospheric Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc322418c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1965/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" full-time duty as a cadet or midshipman at the United States Military Academy, United States Naval Academy, United States Air Force Academy, or the United States Coast Guard Academy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc322418d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1965/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “active duty for training” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc322418e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1965/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" full-time duty in the Armed Forces performed by Reserves, or by members of the Space Force in a space force active status (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/e/1"},"text":"section 101(e)(1) of title 10","children":[],"tail":") but not on sustained duty under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s20105"},"text":"section 20105 of title 10","children":[],"tail":", for training purposes;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc322418f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1965/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" full-time duty for training purposes performed as a commissioned officer of the Reserve Corps ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of the Public Health Service;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3224190-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1965/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" full-time duty as a member, cadet, or midshipman of the Reserve Officers Training Corps while attending field training or practice cruises; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3224191-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1965/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of members of the National Guard or Air National Guard of any State, full-time duty under sections 316, 502, 503, 504, or 505 of title 32, United States Code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3224192-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1965/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “inactive duty training” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3224193-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1965/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" duty (other than full-time duty) prescribed or authorized for Reserves (including commissioned officers of the Reserve Corps ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of the Public Health Service), or for members of the Space Force in a space force active status (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/e/1"},"text":"section 101(e)(1) of title 10","children":[],"tail":"), which duty is scheduled in advance by competent authority to begin at a specific time and place; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3224194-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1965/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a member of the National Guard or Air National Guard of any State, such term means duty (other than full-time duty) which is scheduled in advance by competent authority to begin at a specific time and place under sections 316, 502, 503, 504, or 505 of title 32, United States Code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3224195-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1965/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “active duty for training” and “inactive duty training” do not include duty performed as a temporary member of the Coast Guard Reserve, and the term “inactive duty training” does not include (A) work or study performed in connection with correspondence courses, or (B) attendance at an educational institution in an inactive status.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3224196-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1965/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “member” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3224197-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1965/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person on active duty, active duty for training, or inactive duty training in the uniformed services in a commissioned, warrant, or enlisted rank, or grade, or as a cadet or midshipman of the United States Military Academy, United States Naval Academy, United States Air Force Academy, or the United States Coast Guard Academy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3224198-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1965/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person who volunteers for assignment to the Ready Reserve of a uniformed service and is assigned to a unit or position in which such person may be required to perform active duty, or active duty for training, and each year will be scheduled to perform at least twelve periods of inactive duty training that is creditable for retirement purposes under chapter 1223 of title 10 (or under chapter 67 of that title as in effect before the effective date of the Reserve Officer Personnel Management Act);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3224199-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1965/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person who volunteers for assignment to a mobilization category in the Individual Ready Reserve, as defined in section 12304(i)(1) ","children":[{"tag":"ref","attrib":{"idref":"fn002041"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002041"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of title 10; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc322419a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1965/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member, cadet, or midshipman of the Reserve Officers Training Corps while attending field training or practice cruises.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc322419b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1965/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “uniformed services” means the Army, Navy, Air Force, Marine Corps, Coast Guard, the commissioned corps of the Public Health Service, and the commissioned corps of the National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc322419c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1965/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “widow” or “widower” means a person who is the lawful spouse of the insured member at the time of his death.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc322419d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1965/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “child” means a legitimate child, a legally adopted child, an illegitimate child as to the mother, or an illegitimate child as to the alleged father, only if (A) he acknowledged the child in writing signed by him; or (B) he has been judicially ordered to contribute to the child’s support; or (C) he has been, before his death, judicially decreed to be the father of such child; or (D) proof of paternity is established by a certified copy of the public record of birth or church record of baptism showing that the insured was the informant and was named as father of the child; or (E) proof of paternity is established from service department or other public records, such as school or welfare agencies, which show that with his knowledge the insured was named as the father of the child.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc322419e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1965/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “parent” means a father of a legitimate child, mother of a legitimate child, father through adoption, mother through adoption, mother of an illegitimate child, and father of an illegitimate child but only if (A) he acknowledged paternity of the child in writing signed by him before the child’s death; or (B) he has been judicially ordered to contribute to the child’s support; or (C) he has been judicially decreed to be the father of such child; or (D) proof of paternity is established by a certified copy of the public record of birth or church record of baptism showing that the claimant was the informant and was named as father of the child; or (E) proof of paternity is established from service department or other public records, such as school or welfare agencies, which show that with his knowledge the claimant was named as father of the child. No person who abandoned or willfully failed to support a child during the child’s minority, or consented to the child’s adoption may be recognized as a parent for the purpose of this subchapter. However, the immediately preceding sentence shall not be applied so as to require duplicate payments in any case in which insurance benefits have been paid prior to receipt in the administrative office established under sub","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1966/b"},"text":"section 1966(b) of this title","children":[],"tail":" of sufficient evidence to clearly establish that the person so paid could not qualify as a parent solely by reason of such sentence."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc322419f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1965/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “insurable dependent”, with respect to a member, means the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc32241a0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1965/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The member’s spouse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc32241a1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1965/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The member’s child, as defined in the first sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s101/4/A"},"text":"section 101(4)(A) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc32241a2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1965/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The member’s stillborn child.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc32241a3-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/214/s1/a"},"text":"Pub. L. 89–214, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-09-29"},"text":"Sept. 29, 1965","children":[],"tail":", 