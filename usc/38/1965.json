xt":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1971 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/92/185/s2"},"text":"Pub. L. 92–185, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-15"},"text":"Dec. 15, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/643"},"text":"85 Stat. 643","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/92/185/s2"},"text":"“The provisions of this Act [amending this section] shall apply only to Servicemen’s Group Life Insurance in effect on the life of an insured member who dies on or after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1971-12-15"},"text":"Dec. 15, 1971","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc32241af-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/291"},"text":"Pub. L. 91–291","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1970-06-25"},"text":"June 25, 1970","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/291/s14/a"},"text":"section 14(a) of Pub. L. 91–291","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1317"},"text":"section 1317 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/291/s14/b"},"text":"Pub. L. 91–291, § 14(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-25"},"text":"June 25, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/333"},"text":"84 Stat. 333","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/91/291/s14/b"},"text":"“The provisions of section 765(7), (8), and (9) [now 1765(7), (8), and (9)] of title 38, United States Code, as added by the first section of this Act shall apply only to servicemen’s group life insurance in effect on the life of an insured member who dies on and after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1970-06-25"},"text":"June 25, 1970","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idc32241b0-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of authorities, functions, personnel, and assets of the Coast Guard, including the authorities and functions of the Secretary of Transportation relating thereto, to the Department of Homeland Security, and for treatment of related references, see sections 468(b), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc32241b1-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Renaming of Group Life Insurance Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/275/tIV/s405/a"},"text":"Pub. L. 104–275, title IV, § 405(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3339"},"text":"110 Stat. 3339","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/275/tIV/s405/a"},"text":"“The program of insurance operated by the Secretary of Veterans Affairs under subchapter III of chapter 19 of title 38, United States Code, is hereby redesignated as the Servicemembers’ Group Life Insurance program.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc32241b2-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References to Servicemen’s Group Life Insurance or Advisory Council on Servicemen’s Group Life Insurance","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/275/tIV/s405/d"},"text":"Pub. L. 104–275, title IV, § 405(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3340"},"text":"110 Stat. 3340","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/275/tIV/s405/d"},"text":"“Any reference to Servicemen’s Group Life Insurance or to the Advisory Council on Servicemen’s Group Life Insurance in any Federal law, Executive order, regulation, delegation of authority, or other document of the Federal Government shall be deemed to refer to Servicemembers’ Group Life Insurance or the Advisory Council on Servicemembers’ Group Life Insurance, respectively.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
