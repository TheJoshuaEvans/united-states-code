f":"/us/pl/109/233/tV/s501/c/1"},"text":"Pub. L. 109–233, title V, § 501(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-06-15"},"text":"June 15, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/415"},"text":"120 Stat. 415","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/389/tIV/s402/a"},"text":"Pub. L. 110–389, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4174"},"text":"122 Stat. 4174","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1723/a/2"},"text":"Pub. L. 118–31, div. A, title XVII, § 1723(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/674"},"text":"137 Stat. 674","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc32241a4-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc32241a5-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc32241a6-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Chapter 67 of title 10 as in effect before the effective date of the Reserve Officer Personnel Management Act, referred to in par. (5)(B), means chapter 67 (§ 1331 et seq.) of Title 10, Armed Forces, prior to its transfer to part II of subtitle E of Title 10, its renumbering as chapter 1223, and its general revision by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1662/j/1"},"text":"section 1662(j)(1) of Pub. L. 103–337","children":[],"tail":". A new chapter 67 (§ 1331) of Title 10 was added by "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1662/j/7"},"text":"section 1662(j)(7) of Pub. L. 103–337","children":[],"tail":". For effective date of the Reserve Officer Personnel Management Act ("},{"tag":"ref","attrib":{"href":"/us/pl/103/337/tXVI"},"text":"Pub. L. 103–337, title XVI","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691"},"text":"section 1691 of Pub. L. 103–337","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of Title 10","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12304/i/1"},"text":"Section 12304(i)(1) of title 10","children":[],"tail":", referred to in par. (5)(C), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12304/j/1"},"text":"section 12304(j)(1) of title 10","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tV/s522/b"},"text":"Pub. L. 109–364, div. A, title V, § 522(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2192"},"text":"120 Stat. 2192","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12304/j/1"},"text":"Section 12304(j)(1) of title 10","children":[],"tail":" was subsequently redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12304/k/2"},"text":"section 12304(k)(2) of title 10","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXV/s1532/2"},"text":"Pub. L. 118–31, div. A, title XV, § 1532(2)","children":[],"tail":", (7)(A), "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"