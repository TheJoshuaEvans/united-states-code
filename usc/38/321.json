{"tag":"section","attrib":{"id":"idc2800dfe-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s321"},"text":null,"children":[{"tag":"num","attrib":{"value":"321"},"text":"§ 321.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Survivors Assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2800dff-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s321/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish in the Department an Office of Survivors Assistance (in this section referred to as the “Office”) to serve as a resource regarding all benefits and services furnished by the Department—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2800e00-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s321/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to survivors and dependents of deceased veterans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2800e01-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s321/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to survivors and dependents of deceased members of the Armed Forces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2800e02-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s321/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advisory Duties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Office shall serve as a primary advisor to the Secretary on all matters related to the policies, programs, legislative issues, and other initiatives affecting the survivors and dependents described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2800e03-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s321/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidance From Stakeholders","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In establishing the Office, the Secretary shall seek guidance from interested stakeholders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2800e04-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s321/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Resources","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall ensure that appropriate personnel, funding, and other resources are provided to the Office to carry out its responsibilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2800e05-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s321/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inclusion of Information on Office in Annual Report on Department Activities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall include in each annual Performance and Accountability report submitted by the Secretary to Congress a description of the activities of the Office during the fiscal year covered by such report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2800e06-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/389/tII/s222/a"},"text":"Pub. L. 110–389, title II, § 222(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4156"},"text":"122 Stat. 4156","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
