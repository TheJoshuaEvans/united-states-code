{"tag":"section","attrib":{"id":"idc2bbb7ab-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1505"},"text":null,"children":[{"tag":"num","attrib":{"value":"1505"},"text":"§ 1505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of pension during confinement in penal institutions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2bbb7ac-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No pension under public or private laws administered by the Secretary shall be paid to or for an individual who has been imprisoned in a Federal, State, local, or other penal institution or correctional facility as a result of conviction of a felony or misdemeanor for any part of the period beginning sixty-one days after such individual’s imprisonment begins and ending when such individual’s imprisonment ends.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2bbb7ad-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Where any veteran is disqualified for pension for any period solely by reason of subsection (a) of this section, the Secretary may apportion and pay to such veteran’s spouse or children the pension which such veteran would receive for that period but for this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2bbb7ae-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1505/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Where any surviving spouse or child of a veteran is disqualified for pension for any period solely by reason of subsection (a) of this section, the Secretary may (1) if the surviving spouse is so disqualified, pay to the child, or children, the pension which would be payable if there were no such surviving spouse or (2) if a child is so disqualified, pay to the surviving spouse or other children, as applicable, the pension which would be payable if there were no such child.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2bbb7af-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1134"},"text":"72 Stat. 1134","children":[],"tail":", § 505; "},{"tag":"ref","attrib":{"href":"/us/pl/94/169/tI/s106/9"},"text":"Pub. L. 94–169, title I, § 106(9)","children":[],"tail":"–(11), "},{"tag":"date","attrib":{"date":"1975-12-23"},"text":"Dec. 23, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/1017"},"text":"89 Stat. 1017","children":[],"tail":"; renumbered § 1505 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":", §§ 4(a)(1), (b)(1), (2)(E), 5(a), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/403-406"},"text":"105 Stat. 403–406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/461/tX/s1002/a"},"text":"Pub. L. 109–461, title X, § 1002(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3464"},"text":"120 Stat. 3464","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2bbb7b0-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc2bbb7b1-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc2bbb7b2-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior section 1505 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3105"},"text":"section 3105 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 1505, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1172"},"text":"72 Stat. 1172","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/502/tI/s104/5"},"text":"Pub. L. 94–502, title I, § 104(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-15"},"text":"Oct. 15, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2384"},"text":"90 Stat. 2384","children":[],"tail":", related to leaves of absence to veterans pursuing a course of vocational rehabilitation training under chapter 31 of this title, prior to the general revision of chapter 31 of this title by "},{"tag":"ref","attrib":{"href":"/us/pl/96/466"},"text":"Pub. L. 96–466","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/pl/96/466/s802/a/3"},"text":"Section 802(a)(3) of Pub. L. 96–466","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3100"},"text":"section 3100 of this title","children":[],"tail":", provided that this prior section 1505 continue in effect until "},{"tag":"date","attrib":{"date":"1981-03-31"},"text":"Mar. 31, 1981","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3110"},"text":"section 3110 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc2bbb7b3-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461"},"text":"Pub. L. 109–461","children":[],"tail":" substituted “local, or other penal institution or correctional facility” for “or local penal institution”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s505"},"text":"section 505 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/1"},"text":"Pub. L. 102–83, § 4(a)(1)","children":[],"tail":", substituted “administered by the Secretary” for “administered by the Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/169/s106/9"},"text":"Pub. L. 94–169, § 106(9)","children":[],"tail":", substituted “such individual’s” for “his” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/169/s106/10"},"text":"Pub. L. 94–169, § 106(10)","children":[],"tail":", substituted “such veteran’s spouse” for “his wife”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/169/s106/11"},"text":"Pub. L. 94–169, § 106(11)","children":[],"tail":", substituted “surviving spouse” for “widow” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc2bbb7b4-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc2bbb7b5-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1975 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/169/tI/s106"},"text":"Pub. L. 94–169, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-23"},"text":"Dec. 23, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/1017"},"text":"89 Stat. 1017","children":[],"tail":", provided that the amendment made by that section is effective "},{"tag":"date","attrib":{"date":"1976-01-01"},"text":"Jan. 1, 1976","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
