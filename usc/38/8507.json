{"tag":"section","attrib":{"id":"idc4392f70-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8507"},"text":null,"children":[{"tag":"num","attrib":{"value":"8507"},"text":"§ 8507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of small shipping charges","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Upon receipt of a proper claim for such property under the provisions of this subchapter the Secretary is hereby authorized, in the Secretary’s discretion and in accordance with regulations prescribed by the Secretary, to pay mailing or shipping charges not to exceed $25 in the case of each deceased veteran as hereinabove defined.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc4392f71-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1259"},"text":"72 Stat. 1259","children":[],"tail":", § 5207; "},{"tag":"ref","attrib":{"href":"/us/pl/99/576/tVII/s701/98"},"text":"Pub. L. 99–576, title VII, § 701(98)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3300"},"text":"100 Stat. 3300","children":[],"tail":"; renumbered § 8507, "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), "},{"tag":"date","attrib":{