{"tag":"section","attrib":{"id":"idc37f54cb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3564"},"text":null,"children":[{"tag":"num","attrib":{"value":"3564"},"text":"§ 3564.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual adjustment of amounts of educational assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc37f54cc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3564/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to any fiscal year, the Secretary shall provide a percentage increase in the rates payable under sections 3532, 3534(b), and 3542(a) of this title equal to the percentage by which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc37f54cd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3564/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Consumer Price Index (all items, United States city average) for the 12-month period ending on the June 30 preceding the beginning of the fiscal year for which the increase is made, exceeds","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc37f54ce-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3564/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such Consumer Price Index for the 12-month period preceding the 12-month period described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc37f54cf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3564/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any increase under subsection (a) in a rate with respect to a fiscal year after fiscal year 2004 and before fiscal year 2014 shall be rounded down to the next lower whole dollar amount. Any such increase with respect to a fiscal year after fiscal year 2013 shall be rounded to the nearest whole dollar amount.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc37f54d0-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/419/tI/s111/f/1/A"},"text":"Pub. L. 106–419, title I, § 111(f)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1831"},"text":"114 Stat. 1831","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/183/tIII/s304/b"},"text":"Pub. L. 108–183, title III, § 304(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-16"},"text":"Dec. 16, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2660"},"text":"117 Stat. 2660","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc37f54d1-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc37f54d2-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc37f54d3-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/183"},"text":"Pub. L. 108–183","children":[],"tail":" designated existing provisions as subsec. (a), struck out “(rounded to the nearest dollar)” after “percentage increase”, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc37f54d4-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc37f54d5-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/419/tI/s111/f/3"},"text":"Pub. L. 106–419, title I, § 111(f)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1831"},"text":"114 Stat. 1831","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/107/14/s8/b/1"},"text":"Pub. L. 107–14, § 8(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-06-05"},"text":"June 5, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/36"},"text":"115 Stat. 36","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/14/s8/b/1"},"text":"“Sections 3564 and 3687(d) of title 38, United States Code, as added by this subsection, shall take effect on ","children":[{"tag":"date","attrib":{"date":"2001-10-01"},"text":"October 1, 2001","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
