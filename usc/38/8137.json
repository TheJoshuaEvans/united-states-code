{"tag":"section","attrib":{"id":"idc42fba26-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8137"},"text":null,"children":[{"tag":"num","attrib":{"value":"8137"},"text":"§ 8137.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State control of operations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as otherwise specifically provided, nothing in this subchapter shall be construed as conferring on any Federal officer or employee the right to exercise any supervision or control over the administration, personnel, maintenance, or operation of any State home for which facilities are constructed or acquired with assistance received under this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc42fba27-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/450/s4/a"},"text":"Pub. L. 88–450, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-08-19"},"text":"Aug. 19, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/503"},"text":"78 Stat. 503","children":[],"tail":", § 5037; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/528/tI/s105/5"},"text":"Pub. L. 98–528, title I, § 105(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2690"},"text":"98 Stat. 2690","children":[],"tail":"; renumbered § 8137, "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc42fba28-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc42fba29-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc42fba2a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5037"},"text":"section 5037 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/528"},"text":"Pub. L. 98–528","children":[],"tail":" inserted “or acquired” after “constructed”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
