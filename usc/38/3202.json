rve”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1602"},"text":"section 1602 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/54"},"text":"Pub. L. 102–54","children":[],"tail":" inserted comma after last reference to “1977”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1)(D)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “3452(a)(3)(C)” for “1652(a)(3)(C)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “3452(b)” for “1652(b)” in subpar. (A) and “3687(a)” for “1787(a)” and “3482(a)(2)” for “1682(a)(2)” in subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “3452(c)” for “1652(c)” in par. (4) and “3452(e)” for “1652(e)” in par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Par. (2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/689"},"text":"Pub. L. 100–689","children":[],"tail":" inserted designation “(i)” after “includes” and added cl. (ii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Par. (1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576/s309/a/2"},"text":"Pub. L. 99–576, § 309(a)(2)","children":[],"tail":", inserted “and before "},{"tag":"date","attrib":{"date":"1985-07-01"},"text":"July 1, 1985","children":[],"tail":",” in two places and substituted “commencing on or after "},{"tag":"date","attrib":{"date":"1977-01-01"},"text":"January 1, 1977","children":[],"tail":"” for “commencing on or after such date” and “released from active duty after "},{"tag":"date","attrib":{"date":"1977-01-01"},"text":"January 1, 1977","children":[],"tail":"” for “released from active duty after such date”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576/s310/a/1"},"text":"Pub. L. 99–576, § 310(a)(1)","children":[],"tail":", added par. (2) and struck out former par. (2) which read as follows: “The terms ‘program of education’ and ‘educational institution’ shall have the same meaning ascribed to them in sections 1652(b) and 1652(c), respectively, of this title.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576/s310/a/2"},"text":"Pub. L. 99–576, § 310(a)(2)","children":[],"tail":", added pars. (4) and (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Par. (1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/223"},"text":"Pub. L. 98–223","children":[],"tail":" added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Par. (1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466"},"text":"Pub. L. 96–466","children":[],"tail":" inserted “who is not eligible for educational assistance under chapter 34 of this title and” after “any veteran” and struck out “initially” before “entered military service” in two places."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3603430-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3603431-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/689"},"text":"Pub. L. 100–689","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1989-01-01"},"text":"Jan. 1, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/689/s108/c"},"text":"section 108(c) of Pub. L. 100–689","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3002"},"text":"section 3002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3603432-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466/tVIII/s802/d/1"},"text":"Pub. L. 96–466, title VIII, § 802(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2218"},"text":"94 Stat. 2218","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/466/tVIII/s802/d/1"},"text":"“The amendments made by section 401 [amending this section] shall take effect as of ","children":[{"tag":"date","attrib":{"date":"1977-01-01"},"text":"January 1, 1977","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3603433-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1977-01-01"},"text":"Jan. 1, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/502/s406"},"text":"section 406 of Pub. L. 94–502","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3201"},"text":"section 3201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idc3603434-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of authorities, functions, personnel, and assets of the Coast Guard, including the authorities and functions of the Secretary of Transportation relating thereto, to the Department of Homeland Security, and for treatment of related references, see sections 468(b), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3603435-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Enrollment in Program Before ","children":[{"tag":"date","attrib":{"date":"1987-04-01"},"text":"April 1, 1987","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"For provisions for continued eligibility for enrollment in the program established by this chapter until ","children":[{"tag":"date","attrib":{"date":"1987-04-01"},"text":"Apr. 1, 1987","children":[],"tail":", of individuals on active duty in the Armed Forces who were eligible therefor on "},{"tag":"date","attrib":{"date":"1985-06-30"},"text":"June 30, 1985","children":[],"tail":", and requiring notice of such continued eligibility to affected individuals, see section 309(c), (d) of "},{"tag":"ref","attrib":{"href":"/us/pl/99/576"},"text":"Pub. L. 99–576","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3201"},"text":"section 3201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
