."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/432/s204/1"},"text":"Pub. L. 94–432, § 204(1)","children":[],"tail":", substituted “$57” and “$24” for “$53” and “$22”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/432/s204/2"},"text":"Pub. L. 94–432, § 204(2)","children":[],"tail":", substituted “$2,890” for “$2,700”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/169"},"text":"Pub. L. 94–169","children":[],"tail":", §§ 101(2)(D), 104(1), substituted “surviving spouse” for “widow”, struck out “his” before “death,” and, effective for period beginning "},{"tag":"date","attrib":{"date":"1976-01-01"},"text":"Jan. 1, 1976","children":[],"tail":", and ending "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", substituted “$53” for “$49” and “$22” for “$20”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/169/s104"},"text":"Pub. L. 94–169, § 104","children":[],"tail":", substituted, effective for period beginning "},{"tag":"date","attrib":{"date":"1976-01-01"},"text":"Jan. 1, 1976","children":[],"tail":", and ending "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", “$2700” for “$2400”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/527/s4/1"},"text":"Pub. L. 93–527, § 4(1)","children":[],"tail":", substituted “$49” and “$20” for “$44” and “$18”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/527/s4/2"},"text":"Pub. L. 93–527, § 4(2)","children":[],"tail":", substituted “$2,400” for “$2,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"197