{"tag":"section","attrib":{"id":"idc3d787c6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5306"},"text":null,"children":[{"tag":"num","attrib":{"value":"5306"},"text":"§ 5306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renouncement of right to benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3d787c7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person entitled to pension, compensation, or dependency and indemnity compensation under any of the laws administered by the Secretary may renounce the right thereto. The application renouncing the right shall be in writing over the person’s signature. Upon the filing of such an application, payment of such benefits and the right thereto shall be terminated, and such person shall be denied any and all rights thereto from such filing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d787c8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Renouncement of rights shall not preclude any person from filing a new application for pension, compensation, or dependency and indemnity compensation at a later date, but such new application shall be treated as an original application, and no payments shall be made for any period before the date such new application is filed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d787c9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5306/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding subsection (b), if a new application for pension under chapter 15 of this title or for dependency and indemnity compensation for parents under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1315"},"text":"section 1315 of this title","children":[],"tail":" is filed within one year after renouncement of that benefit, such application shall not be treated as an original application and benefits will be payable as if the renouncement had not occurred."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3d787ca-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1231"},"text":"72 Stat. 1231","children":[],"tail":", § 3106; "},{"tag":"ref","attrib":{"href":"/us/pl/99/576/tVII/s701/73"},"text":"Pub. L. 99–576, title VII, § 701(73)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3297"},"text":"100 Stat. 3297","children":[],"tail":"; renumbered § 5306, "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/1"},"text":"Pub. L. 102–83, § 4(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/403"},"text":"105 Stat. 403","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/446/tV/s503"},"text":"Pub. L. 103–446, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4663"},"text":"108 Stat. 4663","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3d787cb-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3d787cc-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3d787cd-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446"},"text":"Pub. L. 103–446","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3106"},"text":"section 3106 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" substituted “administered by the Secretary” for “administered by the Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576"},"text":"Pub. L. 99–576","children":[],"tail":" substituted “the” for “his” before “right” in first sentence."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
