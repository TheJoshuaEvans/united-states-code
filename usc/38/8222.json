{"tag":"section","attrib":{"id":"idc436e5f2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8222"},"text":null,"children":[{"tag":"num","attrib":{"value":"8222"},"text":"§ 8222.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc436e5f3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8222/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is authorized to be appropriated for carrying out programs authorized under this chapter $50,000,000 for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1973-06-30"},"text":"June 30, 1973","children":[],"tail":"; a like sum for each of the six succeeding fiscal years; $15,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1980-09-30"},"text":"September 30, 1980","children":[],"tail":"; $25,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1981-09-30"},"text":"September 30, 1981","children":[],"tail":"; and $30,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1982-09-30"},"text":"September 30, 1982","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc436e5f4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8222/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sums appropriated pursuant to subsection (a) of this section shall remain available until the end of the sixth fiscal year following the fiscal year for which they are appropriated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc436e5f5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8222/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is authorized to be appropriated for fiscal year 1979 to carry out the programs authorized under this chapter such sums as may be necessary (1) to make to institutions with which the Secretary has entered into agreements under subchapter I of this chapter supplemental grants for which the Secretary had, before ","children":[{"tag":"date","attrib":{"date":"1978-05-01"},"text":"May 1, 1978","children":[],"tail":", approved applications from such institutions, and (2) to meet fully the commitments made by the Secretary before "},{"tag":"date","attrib":{"date":"1978-05-01"},"text":"May 1, 1978","children":[],"tail":", for grants and applications approved under authority of this subchapter and subchapters III and IV of this chapter, except that no funds appropriated under this subsection may be used for grants and applications approved under this subchapter and such subchapters III and IV until the full amounts for which applications had been so approved have been obligated under such subchapter I."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc436e5f6-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/541/s2/a"},"text":"Pub. L. 92–541, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-24"},"text":"Oct. 24, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1104"},"text":"86 Stat. 1104","children":[],"tail":", § 5082; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/520/s7"},"text":"Pub. L. 95–520, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-26"},"text":"Oct. 26, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1822"},"text":"92 Stat. 1822","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/151/tI/s103/b/1"},"text":"Pub. L. 96–151, title I, § 103(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-12-20"},"text":"Dec. 2