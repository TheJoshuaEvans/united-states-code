{"tag":"section","attrib":{"id":"idc3f8f251-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7312"},"text":null,"children":[{"tag":"num","attrib":{"value":"7312"},"text":"§ 7312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special medical advisory group","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3f8f252-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7312/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall establish an advisory committee to be known as the special medical advisory group. The advisory group shall advise the Secretary, through the Under Secretary for Health, and the Under Secretary for Health directly, relative to the care and treatment of disabled veterans and other matters pertinent to the Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3f8f253-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7312/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Members of the special medical advisory group shall be appointed by the Secretary upon the recommendation of the Under Secretary for Health. The special medical advisory group shall be composed of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3f8f254-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7312/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of the medical, dental, podiatric, optometric, and allied scientific professions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f8f255-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7312/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other individuals considered by the Under Secretary for Health to have experience pertinent to the mission of the Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f8f256-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7312/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a disabled veteran.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3f8f257-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7312/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The special medical advisory group shall meet on a regular basis as prescribed by the Secretary. The number, terms of service, pay, and allowances of members of the advisory group shall be prescribed in accordance with existing law and regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3f8f258-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7312/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than February 1 of each year, the special medical advisory group shall submit to the Secretary and the Congress a report on the activities of the advisory group during the preceding fiscal year. No report shall be required under this subsection after ","children":[{"tag":"date","attrib":{"date":"2004-12-31"},"text":"December 31, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3f8f259-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s401/a/3"},"text":"Pub. L. 102–40, title IV, § 401(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/215"},"text":"105 Stat. 215","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/405/tIII/s302/c/1"},"text":"Pub. L. 102–405, title III, § 302(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-09"},"text":"Oct. 9, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1984"},"text":"106 Stat. 1984","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/446/tXII/s1201/e/20"},"text":"Pub. L. 103–446, title XII, § 1201(e)(20)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4686"},"text":"108 Stat. 4686","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/419/tIV/s403/c/5"},"text":"Pub. L. 106–419, title IV, § 403(c)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1864"},"text":"114 Stat. 1864","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3f8f25a-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3f8f25b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3f8f25c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/419"},"text":"Pub. L. 106–419","children":[],"tail":" inserted at end “No report shall be required under this subsection after "},{"tag":"date","attrib":{"date":"2004-12-31"},"text":"December 31, 2004","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446"},"text":"Pub. L. 103–446","children":[],"tail":" substituted “the activities of the advisory group” for “the advisory groups activities”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/405"},"text":"Pub. L. 102–405","children":[],"tail":" substituted “Under Secretary for Health” for “Chief Medical Director” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
