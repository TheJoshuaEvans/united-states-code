{"tag":"section","attrib":{"id":"idc3aa3670-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3721"},"text":null,"children":[{"tag":"num","attrib":{"value":"3721"},"text":"§ 3721.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incontestability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any evidence of guaranty or insurance issued by the Secretary shall be conclusive evidence of the eligibility of the loan for guaranty or insurance under the provisions of this chapter and of the amount of such guaranty or insurance. Nothing in this section shall preclude the Secretary from establishing, as against the original lender, defenses based on fraud or material misrepresentation. The Secretary shall not, by reason of anything contained in this section, be barred from establishing, by regulations in force at the date of such issuance or disbursement, whichever is the earlier, partial defenses to the amount payable on the guaranty or insurance.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc3aa3671-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1213"},"text":"72 Stat. 1213","children":[],"tail":", § 1821; "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIII/s313/b/1"},"text":"Pub. L. 101–237, title III, § 313(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2077"},"text":"103 Stat. 2077","children":[],"tail":"; renumbered § 3721, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3aa3672-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3aa3673-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3aa3674-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1821"},"text":"section 1821 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" substituted “Secretary” for “Administrator” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
