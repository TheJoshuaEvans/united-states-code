{"tag":"section","attrib":{"id":"idc2800e6d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s325"},"text":null,"children":[{"tag":"num","attrib":{"value":"325"},"text":"§ 325.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Veterans experience office ","children":[{"tag":"ref","attrib":{"idref":"fn002012"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002012"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Veterans Experience Office”."}],"tail":null}],"tail":null},{"tag":"subsection","attrib":{"id":"idc2800e6e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s325/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established in the Department within the Office of the Secretary an office to be known as the “Veterans Experience Office” (in this section referred to as the “Office”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2800e6f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s325/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Head of Office","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2800e70-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s325/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of the Office shall be the Chief Veterans Experience Officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2800e71-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s325/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Chief Veterans Experience Officer shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2800e72-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s325/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be appointed by the Secretary from among individuals the Secretary considers qualified to perform the duties of the position;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2800e73-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s325/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report directly to the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2800e74-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s325/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be responsible for carrying out the functions of the Office set forth under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2800e75-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s325/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Function","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The functions of the Office are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2800e76-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s325/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Carrying out the key customer experience initiatives of the Department relating to veterans’ and other beneficiaries’ satisfaction with and usage of benefits and services furnished under laws administered by the Secretary for which they are eligible, including setting the strategy, framework, policy, and other guidance for the Department relating to customer experience, including ensuring the activities of the Office and those of other organizations and offices within the Department are coordinated and not duplicative.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2800e77-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s325/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Requiring the heads of other organizations and offices within the Department to report regularly on customer experience metrics, action plans, and other customer experience improvement efforts to the Chief Veterans Experience Officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2800e78-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s325/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Collecting veteran-derived data—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2800e79-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s325/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine veteran and beneficiary satisfaction with and usage of the benefits and services furnished under laws administered by the Secretary for which they are eligible; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2800e7a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s325/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be considered during policymaking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2800e7b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s325/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing strategic guidance and strategies to Department entities for engaging with veterans and beneficiaries regarding benefits and services furnished under laws administered by the Secretary, including those not using such benefits and services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2800e7c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s325/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assessing and advising the Secretary on the accuracy and helpfulness of the websites and other customer-facing information of the Department, be it available electronically or in any other format.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2800e7d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s325/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assessing and advising the Secretary on the status and opportunities for improvement of the customer service efforts of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2800e7e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s325/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2800e7f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s325/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each year, the Chief Veterans Experience Officer shall submit to the Secretary a summary of the data received by the Chief Veterans Experience Officer under subsection (c)(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2800e80-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s325/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each year, not later than 180 days after the date on which the Secretary receives the summary under paragraph (1), the Secretary shall submit to Congress an annual summary and analysis of the matters summarized pursuant to such paragraph.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2800e81-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s325/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each annual summary submitted pursuant to paragraph (2) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2800e82-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s325/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Data regarding customer service and experience feedback, disaggregated by benefit or service furnished under laws administered by the Secretary, and relevant demographic data of the veterans and beneficiaries providing the feedback.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2800e83-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s325/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Data regarding veteran and beneficiary satisfaction with and usage of benefits or services, disaggregated by benefit or service furnished under laws administered by the Secretary, and relevant demographic data of the veterans and beneficiaries providing the feedback, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc2800e84-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s325/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" potential reasons for not using the benefits or services, such as—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc2800e85-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s325/d/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligibility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc2800e86-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s325/d/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lack of knowledge or awareness of existence of benefit or service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc2827e87-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s325/d/3/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" barriers of technology, information, or time; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc2827e88-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s325/d/3/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other related reasons; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc2827e89-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s325/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of how such reasons may be addressed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2827e8a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s325/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Staff and Resources","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2827e8b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s325/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall ensure that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2827e8c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s325/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office has such staff, resources, and access to customer service and experience information as may be necessary to carry out the functions of the Office; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2827e8d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s325/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any information provided to the Office does not include personally identifiable information of an individual veteran, survivor, dependent, or other beneficiary unless such individual provides appropriate consent to allow such information to be shared with the Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2827e8e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s325/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds available for basic pay and other administrative expenses of other Department organizations and offices may be available to reimburse the Office for all services provided at rates which will recover actual costs for services provided to such organizations if the Secretary determines that contributing to such costs will not undermine the ability of any such organization or office to provide services required by such office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2827e8f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s325/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this subsection shall be construed to authorize an increase in the number of full-time employees otherwise authorized for the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2827e90-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s325/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Privacy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to authorize the Chief Veterans Experience Officer to disclose any record in contravention of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of title 5","children":[],"tail":" (commonly referred to as the “Privacy Act of 1974”)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2827e91-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s325/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sunset","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The requirements and authorities of this section shall terminate on ","children":[{"tag":"date","attrib":{"date":"2028-09-30"},"text":"September 30, 2028","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2827e92-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/33/s2/b/1"},"text":"Pub. L. 119–33, § 2(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-08-14"},"text":"Aug. 14, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/485"},"text":"139 Stat. 485","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2827e93-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc2827e94-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idc2827e95-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For short title of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/33/s2"},"text":"section 2 of Pub. L. 119–33","children":[],"tail":", which enacted this section, as the “Improving Veterans’ Experience Act of 2025”, see "},{"tag":"ref","attrib":{"href":"/us/pl/119/33/s2/a"},"text":"section 2(a) of Pub. L. 119–33","children":[],"tail":", set out as a Short Title of 2025 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
