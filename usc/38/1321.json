{"tag":"section","attrib":{"id":"idc2b94631-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1321"},"text":null,"children":[{"tag":"num","attrib":{"value":"1321"},"text":"§ 1321.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certifications with respect to pay grade","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary concerned shall, at the request of the Secretary, certify to the Secretary the pay grade of deceased persons with respect to whose deaths applications for benefits are filed under this chapter. The certification of the Secretary concerned shall be binding upon the Secretary.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc2b94632-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1132"},"text":"72 Stat. 1132","children":[],"tail":", § 421; "},{"tag":"ref","attrib":{"href":"/us/pl/91/96/s4"},"text":"Pub. L. 91–96, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-10-27"},"text":"Oct. 27, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/145"},"text":"83 Stat. 145","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/433/tIV/s405/17"},"text":"Pub. L. 94–433, title IV, § 405(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1380"},"text":"90 Stat. 1380","children":[],"tail":"; renumbered § 1321 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":", §§ 4(b)(1), (2)(E), 5(a), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"t