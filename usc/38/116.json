{"tag":"section","attrib":{"id":"idc2742747-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s116"},"text":null,"children":[{"tag":"num","attrib":{"value":"116"},"text":"§ 116.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress: cost information","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Whenever the Secretary submits to Congress, or any committee of Congress, a report that is required by law or by a joint explanatory statement of a committee of conference of the Congress, the Secretary shall include with the report—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2742748-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s116/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of the cost of preparing the report; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2742749-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s116/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a brief explanation of the methodology used in preparing that cost statement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc274274a-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/419/tIV/s403/d/1/A"},"text":"Pub. L. 106–419, title IV, § 403(d)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1864"},"text":"114 Stat. 1864","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc274274b-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc274274c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc274274d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/419/tIV/s403/d/2"},"text":"Pub. L. 106–419, title IV, § 403(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1864"},"text":"114 Stat. 1864","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/419/tIV/s403/d/2"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s116"},"text":"Section 116 of title 38","children":[],"tail":", United States Code, as added by paragraph (1) of this subsection, shall apply with respect to any report submitted by the Secretary of Veterans Affairs after the end of the 90-day period beginning on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
