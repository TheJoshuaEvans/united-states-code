{"tag":"section","attrib":{"id":"idc3309909-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2013"},"text":null,"children":[{"tag":"num","attrib":{"value":"2013"},"text":"§ 2013.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program to improve retention of housing by formerly homeless veterans and veterans at risk of becoming homeless","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc330990a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2013/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall carry out a program under which the Secretary shall provide case management services to improve the retention of housing by veterans who were previously homeless and are transitioning to permanent housing and veterans who are at risk of becoming homeless.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc330990b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2013/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Services provided under the program shall include services to assist veterans described in subsection (a) with navigating resources provided by the Federal Government and State, local, and Tribal governments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc330990c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2013/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Staffing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In geographic areas where individuals who meet the licensure and certification requirements to provide services under the program are in high demand as determined by the Secretary, such services may be provided through one or more individuals with a master’s degree in social work who are undergoing training to meet such requirements, if such individuals are under the supervision of an individual who meets such requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc330990d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2013/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grants","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc330990e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2013/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall carry out the program through the award of grants.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc330990f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2013/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3309910-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2013/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In awarding grants under paragraph (1), the Secretary shall give priority to organizations that demonstrate a capability to provide case management services as described in subsection (a), particularly organizations that are successfully providing or have successfully provided transitional housing services using amounts provided by the Secretary under sections 2012 and 2061 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3309911-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2013/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In giving priority under subparagraph (A), the Secretary shall give extra priority to an organization described in such subparagraph that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc3309912-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2013/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" voluntarily stops receiving amounts provided by the Secretary under sections 2012 and 2061 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3309913-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2013/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" converts a facility that the organization used to provide transitional housing services into a facility that the organization uses to provide permanent housing that meets housing quality standards established under section 8(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(8)(B) of the United States Housing Act of 1937 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f"},"text":"42 U.S.C. 1437f","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(8)(B))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3309914-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2013/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any case in which a facility, with respect to which a person received a grant for construction, rehabilitation, or acquisition under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2011"},"text":"section 2011 of this title","children":[],"tail":", is converted as described in subparagraph (B)(ii), such conversion shall be considered to have been carried out pursuant to the needs of the Department and such person shall not be considered in noncompliance with the terms of such grant by reason of such conversion."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3309915-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2013/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall require each recipient of a grant awarded under this subsection to submit to the Secretary a report that describes the services provided or coordinated with amounts under such grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3309916-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/315/tVII/s712/a/1/B"},"text":"Pub. L. 114–315, title VII, § 712(a)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1586"},"text":"130 Stat. 1586","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dU/tIII/s302"},"text":"Pub. L. 117–328, div. U, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5466"},"text":"136 Stat. 5466","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3309917-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3309918-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc3309919-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2013 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2016"},"text":"section 2016 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 2013 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4213"},"text":"section 4213 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 2013 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4104"},"text":"section 4104 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc330991a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s302/1"},"text":"Pub. L. 117–328, § 302(1)","children":[],"tail":", (2), added subsecs. (b) and (c) and redesignated former subsec. (b) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s302/3"},"text":"Pub. L. 117–328, § 302(3)","children":[],"tail":", added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc330991b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc330991c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/315/tVII/s712/b"},"text":"Pub. L. 114–315, title VII, § 712(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1587"},"text":"130 Stat. 1587","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/315/tVII/s712/b"},"text":"“Not later than 1 year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":"], the Secretary of Veterans Affairs shall prescribe regulations to carry out section 2013 of such title ["},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2013"},"text":"38 U.S.C. 2013","children":[],"tail":"], as added by subsection (a)(1)(B).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
