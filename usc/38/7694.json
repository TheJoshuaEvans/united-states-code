{"tag":"section","attrib":{"id":"idc417ec21-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7694"},"text":null,"children":[{"tag":"num","attrib":{"value":"7694"},"text":"§ 7694.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specialty education loan repayment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc417ec22-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7694/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Payments under the Specialty Education Loan Repayment Program shall consist of payments for the principal and interest on loans described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7682/a/2"},"text":"section 7682(a)(2) of this title","children":[],"tail":" for individuals selected to participate in the Program to the holders of such loans."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc417ec23-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7694/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Frequency of Payment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall make payments for any given participant in the Specialty Education Loan Repayment Program on a schedule determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc417ec24-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7694/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum Amount; Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc417ec25-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7694/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of payments made for a participant under the Specialty Education Loan Repayment Program may not exceed $160,000 over a total of 4 years of participation in the Program, of which not more than $40,000 of such payments may be made in each year of participation in the Program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc417ec26-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7694/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc417ec27-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7694/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may waive the limitations under paragraph (1) in the case of a participant described in subparagraph (B). In the case of such a waiver, the total amount of payments payable to or for that participant is the total amount of the principal and the interest on the participant’s loans referred to in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc417ec28-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7694/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A participant described in this subparagraph is a participant in the Program who the Secretary determines serves in a position for which there is a shortage of qualified employees by reason of either the location or the requirements of the position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc417ec29-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/182/tIII/s303/a"},"text":"Pub. L. 115–182, title III, § 303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-06"},"text":"June 6, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1465"},"text":"132 Stat. 1465","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
