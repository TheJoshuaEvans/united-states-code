{"tag":"section","attrib":{"id":"idc417ec41-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7698"},"text":null,"children":[{"tag":"num","attrib":{"value":"7698"},"text":"§ 7698.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement for program","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As part of the Educational Assistance Program, the Secretary shall carry out a scholarship program under this subchapter. The program shall be known as the Department of Veterans Affairs Readjustment Counseling Service Scholarship Program (in this subchapter referred to as the “Program”).","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc41a3532-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/171/tV/s502/a"},"text":"Pub. L. 116–171, title V, § 502(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-17"},"text":"Oct. 17, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/815"},"text":"134 Stat. 815","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc41a3533-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc41a3534-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc41a3535-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/171/tV/s502/c"},"text":"Pub. L. 116–171, title V, § 502(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-17"},"text":"Oct. 17, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/818"},"text":"134 Stat. 818","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/171/tV/s502/c"},"text":"“The Secretary of Veterans Affairs shall begin awarding scholarships under subchapter IX of chapter 76 of title 38, United States Code, as added by subsection (a), for programs of study beginning not later than one year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2020-10-17"},"text":"Oct. 17, 2020","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
