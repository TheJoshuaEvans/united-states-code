{"tag":"section","attrib":{"id":"idc36e8c1e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3470"},"text":null,"children":[{"tag":"num","attrib":{"value":"3470"},"text":"§ 3470.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of program","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Subject to the provisions of this chapter, each eligible veteran may select a program of education to assist the veteran in attaining an educational, professional, or vocational objective at any educational institution (approved in accordance with chapter 36 of this title) selected by the veteran, which will accept and retain the veteran as a student or trainee in any field or branch of knowledge which such institution finds the veteran qualified to undertake or pursue.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc36e8c1f-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/358/s2"},"text":"Pub. L. 89–358, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-03-03"},"text":"Mar. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/15"},"text":"80 Stat. 15","children":[],"tail":", § 1670; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/502/tII/s211/5"},"text":"Pub. L. 94–502, title II, § 211(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-15"},"text":"Oct. 15, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2388"},"text":"90 Stat. 2388","children":[],"tail":"; renumbered § 3470, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","