{"tag":"section","attrib":{"id":"idc37ce4a6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3543"},"text":null,"children":[{"tag":"num","attrib":{"value":"3543"},"text":"§ 3543.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special administrative provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc37ce4a7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3543/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out the Secretary’s responsibilities under this chapter the Secretary may by agreement arrange with public or private educational institutions or others to provide training arrangements as may be suitable and necessary to accomplish the purposes of this subchapter. In any instance where the Secretary finds that a customary tuition charge is not applicable, the Secretary may agree on the fair and reasonable amounts which may be charged for the training provided to the eligible person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc37ce4a8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3543/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall make such rules and regulations as the Secretary may deem necessary in order to promote good conduct on the part of the persons who are following courses of special restorative training and otherwise to carry out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc37ce4a9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3543/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In a case in which the Secretary authorizes training under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3541/a"},"text":"section 3541(a) of this title","children":[],"tail":" on behalf of an eligible person, the parent or guardian shall be entitled—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc37ce4aa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3543/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to receive on behalf of the eligible person the special training allowance provided for under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3542/a"},"text":"section 3542(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc37ce4ab-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3543/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to elect an increase in the basic monthly allowance provided for under such section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc37f54ac-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3543/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to agree with the Secretary on the fair and reasonable amounts which may be charged under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc37f54ad-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1200"},"text":"72 Stat. 1200","children":[],"tail":", § 1743; "},{"tag":"ref","attrib":{"href":"/us/pl/94/502/tIII/s310/22"},"text":"Pub. L. 94–502, title III, § 310(22)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-15"},"text":"Oct. 15, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2392"},"text":"90 Stat. 2392","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIV/s423/b/1/A"},"text":"Pub. L. 101–237, title IV, § 423(b)(1)(A)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2092"},"text":"103 Stat. 2092","children":[],"tail":"; renumbered § 3543, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/103/tI/s109/b/3"},"text":"Pub. L. 107–103, title I, § 109(b)(3)","children":[],"tail":", (4), "},{"tag":"date","attrib":{"date":"2001-12-27"},"text":"Dec. 27, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/986"},"text":"115 Stat. 986","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc37f54ae-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc37f54af-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc37f54b0-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/103/s109/b/3"},"text":"Pub. L. 107–103, § 109(b)(3)","children":[],"tail":", substituted “for the training provided to the eligible person” for “the parent or guardian for the training provided to an eligible person” in last sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/103/s109/b/4"},"text":"Pub. L. 107–103, § 109(b)(4)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1743"},"text":"section 1743 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" substituted “Secretary’s” for “Administrator’s” in subsec. (a) and “Secretary” for “Administrator” wherever appearing in subsecs. (a) and (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/502"},"text":"Pub. L. 94–502","children":[],"tail":" substituted “the Administrator’s” for “his” and “the Administrator may agree” for “he may agree”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/502"},"text":"Pub. L. 94–502","children":[],"tail":" substituted “the Administrator may deem” for “he may deem”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc37f54b1-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc37f54b2-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"head