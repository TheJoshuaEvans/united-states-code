{"tag":"section","attrib":{"id":"idc39268b2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3681"},"text":null,"children":[{"tag":"num","attrib":{"value":"3681"},"text":"§ 3681.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on educational assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc39268b3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3681/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No educational assistance allowance granted under chapter 30, 34, 35, or 36 of this title or 106 or 107 of title 10, or subsistence allowance granted under chapter 31 of this title shall be paid to any eligible person (1) who is on active duty and is pursuing a course of education which is being paid for by the Armed Forces (or by the Department of Health and Human Services in the case of the Public Health Service; or (2) who is attending a course of education or training paid for under chapter 41 of title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc39268b4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3681/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No person may receive benefits concurrently under two or more of the provisions of law listed below:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc39268b5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3681/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapters 30, 31, 32, 34, 35, and 36 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc39268b6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3681/b/2"},"text":null,"children":[{"tag":"num","a