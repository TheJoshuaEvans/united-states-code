:{"href":"/us/usc/t10/s2141"},"text":"section 2141 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Hostage Relief Act of 1980, referred to in subsec. (b)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/449"},"text":"Pub. L. 96–449","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-14"},"text":"Oct. 14, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1967"},"text":"94 Stat. 1967","children":[],"tail":", which was formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5561"},"text":"section 5561 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Omnibus Diplomatic Security and Antiterrorism Act of 1986, referred to in subsec. (b)(5), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399"},"text":"Pub. L. 99–399","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/853"},"text":"100 Stat. 853","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4801"},"text":"section 4801 of Title 22","children":[],"tail":", Foreign Relations and Intercourse, and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc39268be-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those comprising this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1182"},"text":"72 Stat. 1182","children":[],"tail":", 1201, which was classified to former sections 1632(h)(1) and 1762(b) of this title, prior to repeal by sections 4(a) and 3(a)(2) of "},{"tag":"ref","attrib":{"href":"/us/pl/89/358"},"text":"Pub. L. 89–358","children":[],"tail":", respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc39268bf-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/377"},"text":"Pub. L. 111–377","children":[],"tail":" inserted “and section 510” after “and 107”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/568"},"text":"Pub. L. 102–568","children":[],"tail":" struck out before period at end “and whose full salary is being paid to such person while so training”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1781"},"text":"section 1781 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576"},"text":"Pub. L. 99–576","children":[],"tail":" struck out “for the pursuit of the same program of education” after “provisions of law listed below” in introductory text and substituted “Chapters 106 and 107” for “Chapter 107” in par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/s703/c/1/A"},"text":"Pub. L. 98–525, § 703(c)(1)(A)","children":[],"tail":"–(C), inserted initial reference to chapter 30 of this title, inserted references to chapters 106 and 107 of title 10, and struck out comma after “chapter 31”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/223/s203/c/1/A"},"text":"Pub. L. 98–223, § 203(c)(1)(A)","children":[],"tail":", designated existing provisions as subsec. (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/s703/c/2"},"text":"Pub. L. 98–525, § 703(c)(2)","children":[],"tail":", inserted reference to chapter 30 of this title in par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/223/s203/c/1/B"},"text":"Pub. L. 98–223, § 203(c)(1)(B)","children":[],"tail":", added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295"},"text":"Pub. L. 97–295","children":[],"tail":" substituted “chapter 41 of title 5” for “the Government Employees’ Training Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466"},"text":"Pub. L. 96–466","children":[],"tail":" inserted “, or subsistence allowance granted under chapter 31,” after “chapter 34, 35, or 36” and substituted “Department of Health and Human Services” for “Department of Health, Education, and Welfare”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/502"},"text":"Pub. L. 94–502","children":[],"tail":" substituted “such person” for “him”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/540"},"text":"Pub. L. 92–540","children":[],"tail":" substituted “granted under chapter 34, 35, or 36” for “or special training allowance granted under chapter 34 or 35”."}],"tail":"\n"}