{"tag":"section","attrib":{"id":"idc313e922-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1788"},"text":null,"children":[{"tag":"num","attrib":{"value":"1788"},"text":"§ 1788.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transplant procedures with live donors and related services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc313e923-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1788/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subsections (b) and (c), in a case in which a veteran is eligible for a transplant procedure from the Department, the Secretary may provide for an operation on a live donor to carry out such procedure for such veteran, notwithstanding that the live donor may not be eligible for health care from the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc313e924-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1788/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the availability of appropriations for such purpose, the Secretary shall furnish to a live donor any care or services before and after conducting the transplant procedure under subsection (a) that may be required in connection with such procedure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc313e925-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1788/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Non-Department Facilities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out this section, the Secretary may provide for the operation described in subsection (a) on a live donor and furnish to the live donor the care and services described in subsection (b) at a non-Department facility pursuant to an agreement entered into by the Secretary under this title. The live donor shall be deemed to be an individual eligible for hospital care and medical services at a non-Department facility pursuant to such an agreement solely for the purposes of receiving such operation, care, and services at the non-Department facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc313e926-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/182/tI/s153/a"},"text":"Pub. L. 115–182, title I, § 153(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-06"},"text":"June 6, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1437"},"text":"132 Stat. 1437","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/251/tII/s211/a/10"},"text":"Pub. L. 115–251, title II, § 211(a)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-29"},"text":"Sept. 29, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3175"},"text":"132 Stat. 3175","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc313e927-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc313e928-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc313e929-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/251"},"text":"Pub. L. 115–251","children":[],"tail":" substituted “this title” for “this chapter”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
