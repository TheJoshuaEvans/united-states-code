{"tag":"section","attrib":{"id":"idc35deaf5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3121"},"text":null,"children":[{"tag":"num","attrib":{"value":"3121"},"text":"§ 3121.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Veterans’ Advisory Committee on Rehabilitation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc35deaf6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3121/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc35deaf7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3121/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall appoint an advisory committee to be known as the Veterans’ Advisory Committee on Rehabilitation (hereinafter in this section referred to as the “Committee”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc35deaf8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3121/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The members of the Committee shall be appointed by the Secretary from the general public and shall serve for terms to be determined by the Secretary not to exceed three years. Veterans with service-connected disabilities shall be appropriately represented in the membership of the Committee, and the Committee shall also include persons who have distinguished themselves in the public and private sectors in the fields of rehabilitation medicine, vocational guidance, vocational rehabilitation, and employment and training programs. The Secretary may designate one of the members of the Committee appointed under this paragraph to chair the Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc35deaf9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3121/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee shall also include as ex officio members the following: (A) one representative from the Veterans Health Administration and one from the Veterans Benefits Administration, (B) one representative from the Rehabilitation Services Administration of the Department of Education and one from the National Institute for Handicapped Research of the Department of Education, and (C) one representative of the Assistant Secretary of Labor for Veterans’ Employment and Training of the Department of Labor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc36033ea-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3121/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall, on a regular basis, consult with and seek the advice of the Committee with respect to the administration of veterans’ rehabilitation programs under this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc36033eb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3121/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee shall submit to the Secretary an annual report on the rehabilitation programs and activities of the Department of Veterans Affairs and shall submit such other reports and recommendations to the Secretary as the Committee determines appropriate. The annual report shall include an assessment of the rehabilitation needs of veterans and a review of the programs and activities of the Department of Veterans Affairs designed to meet such needs. The Secretary shall submit with each annual report submitted to the Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s529"},"text":"section 529 of this title","children":[],"tail":" a copy of all reports and recommendations of the Committee submitted to the Secretary since the previous annual report of the Secretary was submitted to the Congress pursuant to such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc36033ec-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466/tI/s101/a"},"text":"Pub. L. 96–466, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2186"},"text":"94 Stat. 2186","children":[],"tail":", § 1521; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIV/s423/b/1"},"text":"Pub. L. 101–237, title IV, § 423(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2092"},"text":"103 Stat. 2092","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/54/s14/c/5"},"text":"Pub. L. 102–54, § 14(c)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-06-13"},"text":"June 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/285"},"text":"105 Stat. 285","children":[],"tail":"; renumbered § 3121 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":", §§ 2(c)(3), 5(a), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/402"},"text":"105 Stat. 402","children":[],"tail":", 406; "},{"tag":"ref","attrib":{"href":"/us/pl/103/446/tXII/s1201/b/1"},"text":"Pub. L. 103–446, title XII, § 1201(b)(1)","children":[],"tail":", (i)(5), "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4682"},"text":"108 Stat. 4682","children":[],"tail":", 4688.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc36033ed-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc36033ee-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc36033ef-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446"},"text":"Pub. L. 103–446","children":[],"tail":" substituted “Veterans Health Administration” for “Department of Medicine and Surgery” and “Veterans Benefits Administration” for “Department of Veterans’ Benefits”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1521"},"text":"section 1521 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/54"},"text":"Pub. L. 102–54","children":[],"tail":" substituted “Veterans’ Employment and Training” for “Veterans’ Employment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s2/c/3"},"text":"Pub. L. 102–83, § 2(c)(3)","children":[],"tail":", substituted “section 529” for “section 214”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsecs. (a)(1), (2), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" substituted “Secretary” and “Department of Veterans Affairs” for “Administrator” and “Veterans’ Administration”, respectively, wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc36033f0-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc36033f1-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1980-10-01"},"text":"Oct. 1, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/466/s802/a/2"},"text":"section 802(a)(2) of Pub. L. 96–466","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3100"},"text":"section 3100 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
