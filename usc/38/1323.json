{"tag":"section","attrib":{"id":"idc2b94644-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1323"},"text":null,"children":[{"tag":"num","attrib":{"value":"1323"},"text":"§ 1323.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certifications with respect to circumstances of death","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever the Secretary determines on the basis of a claim for benefits filed with the Secretary that a death occurred under the circumstances referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1476/a"},"text":"section 1476(a) of title 10","children":[],"tail":", the Secretary shall certify that fact to the Secretary concerned. In all other cases, the Secretary shall make the determination referred to in such section at the request of the Secretary concerned."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc2b94645-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1133"},"text":"72 Stat. 1133","children":[],"tail":", § 423; "},{"tag":"ref","attrib":{"href":"/us/pl/94/433/tIV/s405/19"},"text":"Pub. L. 94–433, title IV, § 405(19)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1380"},"text":"90 Stat. 1380","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/54/s14/b/4"},"text":"Pub. L. 102–54, § 14(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-06-13"},"text":"June 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/283"},"text":"105 Stat. 283","children":[],"tail":"; renumbered § 1323 and amende