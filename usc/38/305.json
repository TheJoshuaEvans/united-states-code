{"tag":"section","attrib":{"id":"idc27908b0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s305"},"text":null,"children":[{"tag":"num","attrib":{"value":"305"},"text":"§ 305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Under Secretary for Health","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc27908b1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc27908b2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s305/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is in the Department an Under Secretary for Health, who is appointed by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27908b3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s305/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Under Secretary for Health shall be appointed without regard to political affiliation or activity and solely—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc27908b4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s305/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the basis of demonstrated ability in the medical profession, in health-care administration and policy formulation, or in health-care fiscal management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc27908b5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s305/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the basis of substantial experience in connection with the programs of the Veterans Health Administration or programs of similar content and scope.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc27908b6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary for Health is the head of, and is directly responsible to the Secretary for the operation of, the Veterans Health Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc27908b7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s305/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc27908b8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s305/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever a vacancy in the position of Under Secretary for Health occurs or is anticipated, the Secretary shall establish a commission to recommend individuals to the President for appointment to the position.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27908b9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s305/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A commission established under this subsection shall be composed of the following members appointed by the Secretary:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc27908ba-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s305/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three persons representing clinical care and medical research and education activities affected by the Veterans Health Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc27908bb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s305/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two persons representing veterans served by the Veterans Health Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc27908bc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s305/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two persons who have experience in the management of veterans health services and research programs, or programs of similar content and scope.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc27908bd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s305/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Deputy Secretary of Veterans Affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc27908be-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s305/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chairman of the Special Medical Advisory Group established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7312"},"text":"section 7312 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc27908bf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s305/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One person who has held the position of Under Secretary for Health (including service as Chief Medical Director of the Veterans’ Administration), if the Secretary determines that it is desirable for such person to be a member of the commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27908c0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s305/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A commission established under this subsection shall recommend at least three individuals for appointment to the position of Under Secretary for Health. The commission shall submit all recommendations to the Secretary. The Secretary shall forward the recommendations to the President with any comments the Secretary considers appropriate. Thereafter, the President may request the commission to recommend additional individuals for appointment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27908c1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s305/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary or Deputy Assistant Secretary of Veterans Affairs who performs personnel management and labor relations functions shall serve as the executive secretary of a commission established under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc27908c2-47c4-11f1-bf59-9680b1269b87"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":", §§ 2(a), 4(a)(3), (4), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/379"},"text":"105 Stat. 379","children":[],"tail":", 404; "},{"tag":"ref","attrib":{"href":"/us/pl/102/405/tIII/s302/c/1"},"text":"Pub. L. 102–405, title III, § 302(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-09"},"text":"Oct. 9, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1984"},"text":"106 Stat. 1984","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/446/tXII/s1201/c/1"},"text":"Pub. L. 103–446, title XII, § 1201(c)(1)","children":[],"tail":", (e)(2), "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4683"},"text":"108 Stat. 4683","children":[],"tail":", 4685; "},{"tag":"ref","attrib":{"href":"/us/pl/108/422/tV/s503"},"text":"Pub. L. 108–422, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-11-30"},"text":"Nov. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2396"},"text":"118 Stat. 2396","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/461/tII/s210/a"},"text":"Pub. L. 109–461, title II, § 210(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3418"},"text":"120 Stat. 3418","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc27908c3-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc27908c4-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc27908c5-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/527/s3/b"},"text":"section 3(b) of Pub. L. 100–527","children":[],"tail":", known as the Department of Veterans Affairs Act, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s3/3"},"text":"Pub. L. 102–83, § 3(3)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc27908c6-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461"},"text":"Pub. L. 109–461","children":[],"tail":" redesignated subsec. (d) as (c) and struck out former subsec. (c) which read as follows: “The Under Secretary for Health shall be appointed for a period of four years, with reappointment permissible for successive like periods. If the President removes the Under Secretary for Health before the completion of the term for which the Under Secretary for Health was appointed, the President shall communicate the reasons for the removal to Congress.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/422/s503/1"},"text":"Pub. L. 108–422, § 503(1)","children":[],"tail":", struck out “shall be a doctor of medicine and” after “The Under Secretary for Health” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/422/s503/2"},"text":"Pub. L. 108–422, § 503(2)","children":[],"tail":", substituted “or in health-care” for “and in health-care”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446/s1201/c/1/A"},"text":"Pub. L. 103–446, § 1201(c)(1)(A)","children":[],"tail":", substituted “an Under Secretary” for “a Under Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446/s1201/c/1/B"},"text":"Pub. L. 103–446, § 1201(c)(1)(B)","children":[],"tail":", (e)(2), substituted “Chief Medical Director of the Veterans’ Administration)” for “Under Secretary for Health of the Department)” and “commission” for “Commission”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/405"},"text":"Pub. L. 102–405","children":[],"tail":" substituted “Under Secretary for Health” for “Chief Medical Director” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (d)(2)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/3"},"text":"Pub. L. 102–83, § 4(a)(3)","children":[],"tail":", (4), substituted “Department” for “Veterans’ Administration”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc27908c7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idc27908c8-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/405/tIII/s302/a"},"text":"Pub. L. 102–405, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-09"},"text":"Oct. 9, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1984"},"text":"106 Stat. 1984","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/405/tIII/s302/a"},"text":"“The position of Chief Medical Director of the Department of Veterans Affairs is hereby redesignated as Under Secretary for Health of the Department of Veterans Affairs.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/405/tIII/s302/e"},"text":"Pub. L. 102–405, title III, § 302(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-09"},"text":"Oct. 9, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1985"},"text":"106 Stat. 1985","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/405/tIII/s302/e"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Any reference in any Federal law, Executive order, rule, regulation, or delegation of authority, or any document of or pertaining to the Department of Veterans Affairs—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Chief Medical Director of the Department of Veterans Affairs shall be deemed to refer to the Under Secretary for Health of the Department of Veterans Affairs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Chief Benefits Director of the Department of Veterans Affairs shall be deemed to refer to the Under Secretary for Benefits of the Department of Veterans Affairs.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
