","attrib":{"topic":"amendments","id":"idc37ce464-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1735"},"text":"section 1735 of this title","children":[],"tail":" as this section and substituted “3536” for “1736”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/540"},"text":"Pub. L. 92–540","children":[],"tail":" substituted reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1736"},"text":"section 1736 of this title","children":[],"tail":" for reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1737"},"text":"section 1737 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/358"},"text":"Pub. L. 89–358","children":[],"tail":" redesignated former subsec. (a) as the entire section, struck out therefrom the introductory phrase “Until the date for the expiration of all education and training under chapter 33 of this title,”, substituted “An eligible person” for “and eligible person”, “chapter” for “subchapter”, and “subchapter I of chapter 36 of this title” for “this section or subchapter VII of this chapter”, and struck out former subsec. (b) which provided for scope of approval and is now incorporated in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1770/b"},"text":"section 1770(b) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1963—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/126/s2/1"},"text":"Pub. L. 88–126, § 2(1)","children":[],"tail":", (2), inserted “Until the date for the expiration of all education and training under chapter 33 of this title, and” before “eligible person”, and “or subchapter VII of this chapter” after “this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/126/s2/3"},"text":"Pub. L. 88–126, § 2(3)","children":[],"tail":", inserted “or section 1778.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/126/s2/4"},"text":"Pub. L. 88–126, § 2(4)","children":[],"tail":", repealed subsec. (c) which related to the responsibility of the Administrator, after the expiration date of all education and training under chapter 33 of this title, for the approval of any additional courses."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
