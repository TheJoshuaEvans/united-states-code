{"tag":"section","attrib":{"id":"idc37ce45f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3535"},"text":null,"children":[{"tag":"num","attrib":{"value":"3535"},"text":"§ 3535.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of courses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"An eligible person shall receive the benefits of this chapter while enrolled in a course of education offered by an educational institution only if such course (1) is approved in accordance with the provisions of subchapter I ","children":[{"tag":"ref","attrib":{"idref":"fn002067"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002067"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of chapter 36 of this title, or (2) is approved for the enrollment of the particular individual under the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3536"},"text":"section 3536 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc37ce460-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1199"},"text":"72 Stat. 1199","children":[],"tail":", § 1735; "},{"tag":"ref","attrib":{"href":"/us/pl/88/126/s2"},"text":"Pub. L. 88–126, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-09-23"},"text":"Sept. 23, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/162"},"text":"77 Stat. 162","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/358/s4/n"},"text":"Pub. L. 89–358, § 4(n)","children":[],"tail":", "},{"tag":"date","attrib":{"dat