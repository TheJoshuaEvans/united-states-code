{"tag":"section","attrib":{"id":"idc3e5dfb3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6302"},"text":null,"children":[{"tag":"num","attrib":{"value":"6302"},"text":"§ 6302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biennial plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3e5dfb4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Biennial Plan Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall, during the first nine months of every odd-numbered year, prepare a biennial plan for the outreach activities of the Department for the two-fiscal-year period beginning on October 1 of that year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3e5dfb5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each biennial plan under subsection (a) shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3e5dfb6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6302/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Plans for efforts to identify eligible veterans and eligible dependents who are not enrolled or registered with the Department for benefits or services under the programs administered by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e5dfb7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6302/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Plans for informing eligible veterans and eligible dependents of modifications of the benefits and services under the programs administered by the Secretary, including eligibility for medical and nursing care and services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3e5dfb8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6302/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination in Development","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the biennial plan under subsection (a), the Secretary shall consult with the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3e5dfb9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6302/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Directors or other appropriate officials of organizations approved by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5902"},"text":"section 5902 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e5dfba-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6302/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Directors or other appropriate officials of State and local education and training programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e5dfbb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6302/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Representatives of nongovernmental organizations that carry out veterans outreach programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e5dfbc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6302/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Representatives of State and local veterans employment organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e5dfbd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6302/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other individuals and organizations that the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3e5dfbe-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/233/tIV/s402/a"},"text":"Pub. L. 109–233, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-06-15"},"text":"June 15, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/408"},"text":"120 Stat. 408","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
