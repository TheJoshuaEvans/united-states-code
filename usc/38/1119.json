to a duty station in, including airspace above—"}],"tail":null},{"tag":"clause","attrib":{"id":"idc2a8a493-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1119/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Afghanistan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc2a8a494-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1119/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Djibouti;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc2a8a495-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1119/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Egypt;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc2a8a496-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1119/c/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Jordan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc2a8a497-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1119/c/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Lebanon;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc2a8a498-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1119/c/1/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Syria;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc2a8a499-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1119/c/1/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Yemen;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc2a8a49a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1119/c/1/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Uzbekistan; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc2a8a49b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1119/c/1/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other country determined relevant by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2a8a49c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1119/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “exposure tracking record system”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2a8a49d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1119/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means any system, program, or pilot program used by the Secretary of Veterans Affairs or the Secretary of Defense to track how veterans or members of the Armed Forces have been exposed to various occupational or environmental hazards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2a8a49e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1119/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes the Individual Longitudinal Exposure Record, or successor system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2a8a49f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1119/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “toxic exposure risk activity” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1710/e/4"},"text":"section 1710(e)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2a8a4a0-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/168/tIII/s302"},"text":"Pub. L. 117–168, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-10"},"text":"Aug. 10, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1777"},"text":"136 Stat. 1777","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2a8a4a1-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc2a8a4a2-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc2a8a4a3-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the Sergeant First Class Heath Robinson Honoring our Promise to Address Comprehensive Toxics Act of 2022, referred to in subsec. (b)(3), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/168"},"text":"Pub. L. 117–168","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2022-08-10"},"text":"Aug. 10, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
