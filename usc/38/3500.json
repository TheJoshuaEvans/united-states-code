{"tag":"section","attrib":{"id":"idc375b82e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3500"},"text":null,"children":[{"tag":"num","attrib":{"value":"3500"},"text":"§ 3500.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Congress hereby declares that the educational program established by this chapter is for the purpose of providing opportunities for education to children whose education would otherwise be impeded or interrupted by reason of the disability or death of a parent from a disease or injury incurred or aggravated in the Armed Forces after the beginning of the Spanish-American War, and for the purpose of aiding such children in attaining the educational status which they might normally have aspired to and obtained but for the disability or death of such parent. The Congress further declares that the educational program extended to the surviving spouses of veterans who died of service-connected disabilities and to spouses of veterans with a service-connected total disability permanent in nature is for the purpose of assisting them in preparing to support themselves and their families at a standard of living level which the veteran, but for the veteran’s death or service disability, could have expected to provide for the veteran’s family.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc375b82f-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/631/s2/a/1"},"text":"Pub. L. 90–631, § 2(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-23"},"text":"Oct. 23, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1331"},"text":"82 Stat. 1331","children":[],"tail":", § 1700; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/502/tIII/s310/1"},"text":"Pub. L. 94–502, title III, § 310(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-15"},"text":"Oct. 15, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2391"},"text":"90 Stat. 2391","children":[],"tail":"; renumbered § 3500, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc375b830-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc375b831-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc375b832-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1700"},"text":"section 1700 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/502"},"text":"Pub. L. 94–502","children":[],"tail":" substituted “surviving spouses” for “widows”, “spouses” for “wives”, and “the veteran’s” for “his” in two places."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc375b833-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and