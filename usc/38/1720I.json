{"tag":"section","attrib":{"id":"idc3034805-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I"},"text":null,"children":[{"tag":"num","attrib":{"value":"1720I"},"text":"§ 1720I.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mental and behavioral health care for certain former members of the Armed Forces","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3034806-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall furnish to former members of the Armed Forces described in subsection (b)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3034807-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an initial mental health assessment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3034808-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the mental healthcare or behavioral healthcare services authorized under this chapter that are required to treat the mental or behavioral health care needs of the former service members, including risk of suicide or harming others.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3034809-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Individuals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A former member of the Armed Forces described in this subsection is an individual who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc303480a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a former member of the Armed Forces, including the reserve components;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc303480b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" while serving in the active military, naval, air, or space service, was discharged or released therefrom under a condition that is not honorable but not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc303480c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a dishonorable discharge; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc303480d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a discharge by court-martial;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc303480e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not enrolled in the health care system established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1705"},"text":"section 1705 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc303480f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3034810-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc3034811-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" served in the Armed Forces for a period of more than 100 cumulative days; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3034812-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was deployed in a theater of combat operations, in support of a contingency operation, or in an area at a time during which hostilities are occurring in that area during such service, including by controlling an unmanned aerial vehicle from a location other than such theater or area; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3034813-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while serving in the Armed Forces, was the victim of a physical assault of a sexual nature, a battery of a sexual nature, or sexual harassment (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1720D/f"},"text":"section 1720D(f) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3034814-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Non-Department Care","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3034815-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In furnishing mental or behavioral health care services to an individual under this section, the Secretary may provide such mental or behavioral health care services at a non-Department facility if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3034816-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the judgment of a mental health professional employed by the Department, the receipt of mental or behavioral health care services by that individual in facilities of the Department would be clinically inadvisable; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3034817-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilities of the Department are not capable of furnishing such mental or behavioral health care services to that individual economically because of geographical inaccessibility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3034818-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall carry out paragraph (1) pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1703"},"text":"section 1703 of this title","children":[],"tail":" or any other provision of law authorizing the Secretary to enter into contracts or agreements to furnish hospital care and medical services to veterans at non-Department facilities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3034819-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Setting and Referrals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In furnishing mental and behavioral health care services to individuals under this section, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc303481a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek to ensure that such services are furnished in settings that are therapeutically appropriate, taking into account the circumstances that resulted in the need for such services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc303481b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide referral services to assist former members who are not eligible for services under this chapter to obtain services from sources outside the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc303481c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide information on the mental and behavioral health care services available under this section. Efforts by the Secretary to provide such information—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc303481d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall include notification of each eligible individual described in subsection (b) about the eligibility of the individual for covered mental and behavioral health care under this section not later than the later of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc303481e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 180 days after the date of the enactment of the Military Construction, Veterans Affairs, and Related Agencies Appropriations Act, 2018; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc303481f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 180 days after the date on which the individual was discharged or released from the active military, naval, air, or space service;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3034820-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include availability of a toll-free telephone number (commonly referred to as an 800 number);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3034821-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall ensure that information about the mental health care services available under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3034822-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is revised and updated as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3034823-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is made available and visibly posted at appropriate facilities of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3034824-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is made available to State veteran agencies and through appropriate public information services; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3034825-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include coordination with the Secretary of Defense seeking to ensure that members of the Armed Forces and individuals who are being separated from active military, naval, air, or space service are provided appropriate information about programs, requirements, and procedures for applying for mental health care services under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3034826-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Reports","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3034827-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than February 15 each year, the Secretary shall submit to the Committee on Veterans’ Affairs of the Senate and the Committee on Veterans’ Affairs of the House of Representatives a report on the mental and behavioral health care services provided under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3034828-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each report submitted under paragraph (1) shall include, with respect to the year preceding the submittal of the report, the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3034829-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of eligible individuals who were furnished mental or behavioral health care services under this section, disaggregated by the number of men who received such services and the number of women who received such services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc303482a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of individuals who requested an initial mental health assessment under subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc303482b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The types of mental or behavioral health care needs treated under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc303482c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The demographics of individuals being treated under this section, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc303482d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/f/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" age;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc303482e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/f/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" era of service in the Armed Forces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc303482f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/f/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" branch of service in the Armed Forces; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3034830-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/f/2/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geographic location.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3034831-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/f/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The average number of visits for an individual for mental or behavioral health care under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3034832-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720I/f/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other information as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3034833-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/dJ/tII/s258/a"},"text":"Pub. L. 115–141, div. J, title II, § 258(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/826"},"text":"132 Stat. 826","children":[],"tail":", § 1712I; renumbered § 1720I, "},{"tag":"ref","attrib":{"href":"/us/pl/115/182/tV/s511"},"text":"Pub. L. 115–182, title V, § 511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-06"},"text":"June 6, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1481"},"text":"132 Stat. 1481","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/251/tII/s205"},"text":"Pub. L. 115–251, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-29"},"text":"Sept. 29, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3173"},"text":"132 Stat. 3173","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/171/tI/s104"},"text":"Pub. L. 116–171, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-17"},"text":"Oct. 17, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/782"},"text":"134 Stat. 782","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s926/a/29"},"text":"Pub. L. 116–283, div. A, title IX, § 926(a)(29)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3830"},"text":"134 Stat. 3830","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3034834-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3034835-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b",