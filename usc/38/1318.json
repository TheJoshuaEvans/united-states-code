{"tag":"section","attrib":{"id":"idc2b9461f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1318"},"text":null,"children":[{"tag":"num","attrib":{"value":"1318"},"text":"§ 1318.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefits for survivors of certain veterans rated totally disabled at time of death","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2b94620-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1318/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall pay benefits under this chapter to the surviving spouse and to the children of a deceased veteran described in subsection (b) of this section in the same manner as if the veteran’s death were service connected.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2b94621-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1318/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A deceased veteran referred to in subsection (a) of this section is a veteran who dies, not as the result of the veteran’s own willful misconduct, and who was in receipt of or entitled to receive (or but for the receipt of retired or retirement pay was entitled to receive) compensation at the time of death for a service-connected disability rated totally disabling if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2b94622-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1318/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disability was continuously rated totally disabling for a period of 10 or more years immediately preceding death;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2b94623-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1318/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disability was continuously rated totally disabling for a period of not less than five years from the date of such veteran’s discharge or other release from active duty; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2b94624-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1318/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the veteran was a former prisoner of war and the disability was continuously rated totally disabling for a period of not less than one year immediately preceding death.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2b94625-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1318/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Benefits may not be paid under this chapter by reason of this section to a surviving spouse of a veteran unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2b94626-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1318/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the surviving spouse was married to the veteran for one year or more immediately preceding the veteran’s death; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2b94627-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1318/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a child was born of the marriage or was born to them before the marriage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2b94628-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1318/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a surviving spouse or a child receives any money or property of value pursuant to an award in a judicial proceeding based upon, or a settlement or compromise of, any cause of action for damages for the death of a veteran described in subsection (a) of this section, benefits under this chapter payable to such surviving spouse or child by virtue of this section shall not be paid for any month following a month in which any such money or property is received until such time as the total amount of such benefits that would otherwise have been payable equals the total of the amount of the money received and the fair market value of the property received.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2b94629-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1318/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of sections 1448(d) and 1450(c) of title 10, eligibility for benefits under this chapter by virtue of this section shall be deemed eligibility for dependency and indemnity compensation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1311/a"},"text":"section 1311(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2b9462a-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/687/dB/tXIV/s1403/a/1"},"text":"Pub. L. 100–687, div. B, title XIV, § 1403(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4130"},"text":"102 Stat. 4130","children":[],"tail":", § 418; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tI/s113"},"text":"Pub. L. 101–237, title I, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2065"},"text":"103 Stat. 2065","children":[],"tail":"; renumbered § 1318 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":", §§ 4(b)(1), (2)(E), 5(a), (c)(1), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404-406"},"text":"105 Stat. 404–406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/117/tV/s501/b"},"text":"Pub. L. 106–117, title V, § 501(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-30"},"text":"Nov. 30, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1573"},"text":"113 Stat. 1573","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/419/tIV/s404/a/2"},"text":"Pub. L. 106–419, title IV, § 404(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1864"},"text":"114 Stat. 1864","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/275/tVI/s603/a"},"text":"Pub. L. 111–275, title VI, § 603(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-13"},"text":"Oct. 13, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2885"},"text":"124 Stat. 2885","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2b9462b-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc2b9462c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc2b9462d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/275"},"text":"Pub. L. 111–275","children":[],"tail":" struck out “who died after "},{"tag":"date","attrib":{"date":"1999-09-30"},"text":"September 30, 1999","children":[],"tail":",” after “prisoner of war”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/419"},"text":"Pub. L. 106–419","children":[],"tail":" substituted “not less than” for “not later than”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117/s501/b/1"},"text":"Pub. L. 106–117, § 501(b)(1)","children":[],"tail":", substituted “rated totally disabling if—” for “that either—” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117/s501/b/2"},"text":"Pub. L. 106–117, § 501(b)(2)","children":[],"tail":", inserted “the disability” after “(1)” and struck out “or” after “death;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117/s501/b/3"},"text":"Pub. L. 106–117, § 501(b)(3)","children":[],"tail":", substituted “the disability was continuously rated totally disabling” for “if so rated for a lesser period, was so rated continuously” and substituted “; or” for the period at the end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117/s501/b/4"},"text":"Pub. L. 106–117, § 501(b)(4)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s418"},"text":"section 418 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “1311(a)” for “411(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" substituted “one year” for “two years”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc2b9462e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc2b9462f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/275/tVI/s603/b"},"text":"Pub. L. 111–275, title VI, § 603(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-13"},"text":"Oct. 13, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2885"},"text":"124 Stat. 2885","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/275/tVI/s603/b"},"text":"“The amendment made by subsection (a) [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2011-10-01"},"text":"October 1, 2011","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
