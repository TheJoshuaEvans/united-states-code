{"tag":"section","attrib":{"id":"idc3d2cc4b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5110"},"text":null,"children":[{"tag":"num","attrib":{"value":"5110"},"text":"§ 5110.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective dates of awards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3d2cc4c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5110/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3d2cc4d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5110/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Unless specifically provided otherwise in this chapter, the effective date of an award based on an initial claim, or a supplemental claim, of compensation, dependency and indemnity compensation, or pension, shall be fixed in accordance with the facts found, but shall not be earlier than the date of receipt of application therefor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d2cc4e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5110/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of determining the effective date of an award under this section, the date of application shall be considered the date of the filing of the initial application for a benefit if the claim is continuously pursued by filing any of the following, either alone or in succession:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3d2cc4f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5110/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A request for higher-level review under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5104B"},"text":"section 5104B of this title","children":[],"tail":" on or before the date that is one year after the date on which the agency of original jurisdiction issues a decision."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3d2cc50-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5110/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A supplemental claim under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5108"},"text":"section 5108 of this title","children":[],"tail":" on or before the date that is one year after the date on which the agency of original jurisdiction issues a decision."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3d2cc51-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5110/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A notice of disagreement on or before the date that is one year after the date on which the agency of original jurisdiction issues a decision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3d2cc52-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5110/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A supplemental claim under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5108"},"text":"section 5108 of this title","children":[],"tail":" on or before the date that is one year after the date on which the Board of Veterans’ Appeals issues a decision."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3d2cc53-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5110/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A supplemental claim under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5108"},"text":"section 5108 of this title","children":[],"tail":" on or before the date that is one year after the date on which the Court of Appeals for Veterans Claims issues a decision."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d2cc54-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5110/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided in this section, for supplemental claims received more than one year after the date on which the agency of original jurisdiction issued a decision or the Board of Veterans’ Appeals issued a decision, the effective date shall be fixed in accordance with the facts found, but shall not be earlier than the date of receipt of the supplemental claim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d2cc55-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5110/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3d2cc56-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5110/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The effective date of an award of disability compensation to a veteran shall be the day following the date of the veteran’s discharge or release if application therefor is received within one year from such date of discharge or release.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d2cc57-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5110/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3d2cc58-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5110/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The effective date of an award of disability compensation to a veteran who submits an application therefor that sets forth an original claim that is fully-developed (as determined by the Secretary) as of the date of submittal shall be fixed in accordance with the facts found, but shall not be earlier than the date that is one year before the date of receipt of the application.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3d2cc59-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5110/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this paragraph, an original claim is an initial claim filed by a veteran for disability compensation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3d2cc5a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5110/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This paragraph shall take effect on the date that is one year after the date of the enactment of the Honoring America’s Veterans and Caring for Camp Lejeune Families Act of 2012 and shall not apply with respect to claims filed after the date that is three years after the date of the enactment of such Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d2cc5b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5110/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The effective date of an award of increased compensation shall be the earliest date as of which it is ascertainable that an increase in disability had occurred, if application is received within one year from such date.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d2cc5c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5110/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3d2cc5d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5110/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The effective date of an award of disability pension to a veteran described in subparagraph (B) of this paragraph shall be the date of application or the date on which the veteran became permanently and totally disabled, if the veteran applies for a retroactive award within one year from such date, whichever is to the advantage of the veteran.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3d2cc5e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5110/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A veteran referred to in subparagraph (A) of this paragraph is a veteran who is permanently and totally disabled and who is prevented by a disability from applying for disability pension for a period of at least 30 days beginning on the date on which the veteran became permanently and totally disabled.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d2cc5f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5110/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The effective date of an award of disability compensation by reason of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1151"},"text":"section 1151 of this title","children":[],"tail":" shall be the date such injury or aggravation was suffered if an application therefor is received within one year from such date."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d2cc60-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5110/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The effective date of an award of death compensation, dependency and indemnity compensation, or death pension for which application is received within one year from the date of death shall be the first day of the month in which the death occurred.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d2cc61-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5110/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3d2cc62-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5110/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2) of this subsection, the effective date of an award of dependency and indemnity compensation to a child shall be the first day of the month in which the child’s entitlement arose if application therefor is received within one year from such date.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d2cc63-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5110/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a child who is eighteen years of age or over and who immediately before becoming eighteen years of age was counted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1311/b"},"text":"section 1311(b) of this title","children":[],"tail":" in determining the amount of the dependency and indemnity compensation of a surviving spouse, the effective date of an award of dependency and indemnity compensation to such child shall be the date the child attains the age of eighteen years if application therefor is received within one year from such date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d2cc64-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5110/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An award of additional compensation on account of dependents based on the establishment of a disability rating in the percentage evaluation specified by law for the purpose shall be payable from the effective date of such rating; but only if proof of dependents is received within one year from the date of notification of such rating action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d2cc65-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5110/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5101"},"text":"section 5101 of this title","children":[],"tail":", where compensation, dependency and indemnity compensation, or pension is awarded or increased pursuant to any Act or administrative issue, the effective date of such award or increase shall be fixed in accordance with the facts found but shall not be earlier than the effective date of the Act or administrative issue. In no event shall such award or increase be retroactive for more than one year from the date of application therefor or the date of administrative determination of entitlement, whichever is earlier."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d2cc66-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5110/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Where an award of pension has been deferred or pension has been awarded at a rate based on anticipated income for a year and the claimant later establishes that income for that year was at a rate warranting entitlement or increased entitlement, the effective date of such entitlement or increase shall be fixed in accordance with the facts found if satisfactory evidence is received before the expiration of the next calendar year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d2cc67-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5110/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever any disallowed claim is readjudicated and thereafter allowed on the basis of new and relevant evidence resulting from the correction of the military records of the proper service department under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1552"},"text":"section 1552 of title 10","children":[],"tail":", or the change, correction, or modification of a discharge or dismissal under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1553"},"text":"section 1553 of title 10","children":[],"tail":", or from other corrective action by competent authority, the effective date of commencement of the benefits so awarded shall be the date on which an application was filed for correction of the military record or for the change, modification, or correction of a discharge or dismissal, as the case may be, or the date such disallowed claim was filed, whichever date is the later, but in no event shall such award of benefits be retroactive for more than one year from the date of readjudication of such disallowed claim. This subsection shall not apply to any application or claim for Government life insurance benefits."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d2cc68-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5110/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Where a report or a finding of death of any person in the active military, naval, air, or space service has been made by the Secretary concerned, the effective date of an award of death compensation, dependency and indemnity compensation, or death pension, as applicable, shall be the first day of the month fixed by that Secretary as the month of death in such report or finding, if application therefor is received within one year from the date such report or finding has been made; however, such benefits shall not be payable to any person for any period for which such person has received, or was entitled to receive, an allowance, allotment, or service pay of the deceased.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d2cc69-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5110/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The effective date of the award of benefits to a surviving spouse or of an award or increase of benefits based on recognition of a child, upon annulment of a marriage shall be the date the judicial decree of annulment becomes final if a claim therefor is filed within one year from the date the judicial decree of annulment becomes final; in all other cases the effective date shall be the date the claim is filed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d2cc6a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5110/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The effective date of an award of benefits to a surviving spouse based upon a termination of a remarriage by death or divorce, or of an award or increase of benefits based on recognition of a child upon termination of the child’s marriage by death or divorce, shall be the date of death or the date the judicial decree or divorce becomes final, if an application therefor is received within one year from such termination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"status":"repealed","id":"idc3d2cc6b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5110/m"},"text":null,"children":[{"tag":"num","attrib":{"value":"m"},"text":"[(m)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446/tXII/s1201/i/8"},"text":"Pub. L. 103–446, title XII, § 1201(i)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4688"},"text":"108 Stat. 4688","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d2cc6c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5110/n"},"text":null,"children":[{"tag":"num","attrib":{"value":"n"},"text":"(n)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The effective date of the award of any benefit or any increase therein by reason of marriage or the birth or adoption of a child shall be the date of such event if proof of such event is received by the Secretary within one year from the date of the marriage, birth, or adoption.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3d2cc6d-47c4-11f1-bf59-9680b1269b87"},"text":"(","childr