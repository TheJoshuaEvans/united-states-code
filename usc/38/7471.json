{"tag":"section","attrib":{"id":"idc41309ca-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7471"},"text":null,"children":[{"tag":"num","attrib":{"value":"7471"},"text":"§ 7471.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of Regional Medical Education Centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc41309cb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7471/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out the Secretary’s functions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7302"},"text":"section 7302 of this title","children":[],"tail":" with regard to the training of health personnel, the Secretary shall implement a program under which the Secretary shall designate as Regional Medical Education Centers such Department hospitals as the Secretary determines appropriate to carry out the provisions of this subchapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc41309cc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7471/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each Regional Medical Education Center (hereinafter in this subchapter referred to as “Center”) designated under subsection (a) shall provide continuing medical and related education programs for personnel eligible for training under this subchapter. Such programs shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc41309cd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7471/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The teaching of newly developed medical skills and the use of newly developed medical technologies and equipment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc41309ce-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7471/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advanced clinical instruction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc41309cf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7471/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The opportunity for conducting clinical investigations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc41309d0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7471/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Clinical demonstrations in the use of new types of health personnel and in the better use of the skills of existing health personnel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc41309d1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7471/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Routine verification of basic medical skills and, where determined necessary, remediation of any deficiency in such skills.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc41309d2-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s401/b/5"},"text":"Pub. L. 102–40, title IV, § 401(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/237"},"text":"105 Stat. 237","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc41309d3-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc41309d4-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc41309d5-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4121"},"text":"section 4121 of this title","children":[],"tail":" prior to the repeal of that section as part of the complete revision of chapter 73 of this title by "},{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
