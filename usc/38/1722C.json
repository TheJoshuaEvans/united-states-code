{"tag":"section","attrib":{"id":"idc3080213-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1722C"},"text":null,"children":[{"tag":"num","attrib":{"value":"1722C"},"text":"§ 1722C.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Copayments: prohibition on collection of copayments for first three mental health care outpatient visits of veterans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3080214-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1722C/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1710/g"},"text":"section 1710(g) of this title","children":[],"tail":" or any other provision of law, the Secretary may not impose or collect a copayment for the first three mental health care outpatient visits of a veteran in a calendar year for which the veteran would otherwise be required to pay a copayment under the laws administered by the Secretary."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3080215-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1722C/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Copayment for Medications","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The prohibition under subsection (a) shall not apply with respect to the imposition or collection of copayments for medications pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1722A"},"text":"section 1722A of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3080216-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1722C/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Mental Health Care Outpatient Visit Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “mental health care outpatient visit” means an outpatient visit with a qualified mental health professional for the primary purpose of seeking mental health care or treatment for substance abuse disorder.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3080217-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1722C/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sunset","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall terminate on the date that is five years after the date of the enactment of the Joseph Maxwell Cleland and Robert Joseph Dole Memorial Veterans Benefits and Health Care Improvement Act of 2022.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3080218-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dU/tI/s193A/a"},"text":"Pub. L. 117–328, div. U, title I, § 193A(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5440"},"text":"136 Stat. 5440","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3080219-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc308021a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc308021b-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the Joseph Maxwell Cleland and Robert Joseph Dole Memorial Veterans Benefits and Health Care Improvement Act of 2022, referred to in subsec. (d), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc308021c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc308021d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2023 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dU/tI/s193A/b"},"text":"Pub. L. 117–328, div. U, title I, § 193A(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5440"},"text":"136 Stat. 5440","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dU/tI/s193A/b"},"text":"“The amendment made by subsection (a) [enacting this section] shall apply with respect to mental health care outpatient visits occurring on or after the date that is 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
