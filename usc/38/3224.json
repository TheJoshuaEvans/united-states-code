{"tag":"section","attrib":{"id":"idc3603463-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3224"},"text":null,"children":[{"tag":"num","attrib":{"value":"3224"},"text":"§ 3224.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Death of participant","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In the event of a participant’s death, the amount of such participant’s unused contributions to the fund shall be paid to the living person or persons first listed below:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3603464-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3224/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The beneficiary or beneficiaries designated by such participant under such participant’s Servicemembers’ Group Life Insurance policy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3603465-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3224/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The surviving spouse of the participant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3603466-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3224/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The surviving child or children of the participant, in equal shares.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3603467-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3224/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The surviving parent or parents of the participant, in equal shares.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"If there is no such person living, such amount shall be paid to such participant’s estate.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3603468-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/502/tIV/s404"},"text":"Pub. L. 94–502, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-15"},"text":"Oct. 15, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2395"},"text":"90 Stat. 2395","children":[],"tail":", § 1624; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/466/tIV/s402"},"text":"Pub. L. 96–466, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2201"},"text":"94 Stat. 2201","children":[],"tail":"; renumbered § 3224, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/275/tIV/s405/c/2"},"text":"Pub. L. 104–275, title IV, § 405(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3340"},"text":"110 Stat. 3340","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3603469-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc360346a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc360346b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/275"},"text":"Pub. L. 104–275","children":[],"tail":" substituted “Servicemembers’ Group” for “Servicemen’s Group”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1624"},"text":"section 1624 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466"},"text":"Pub. L. 96–466","children":[],"tail":" expanded provisions to require payment of a participant’s unused contributions to the fund to the surviving spouse, the surviving child or children, or to the surviving parent or parents before payment of such amount to the participant’s estate."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc360346c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc360346d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466/tVIII/s802/d/2"},"text":"Pub. L. 96–466, title VIII, § 802(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"