{"tag":"section","attrib":{"id":"idc417ec0a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7693"},"text":null,"children":[{"tag":"num","attrib":{"value":"7693"},"text":"§ 7693.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility; preferences; covered costs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc417ec0b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7693/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual is eligible to participate in the Specialty Education Loan Repayment Program if the individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc417ec0c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7693/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will be eligible for appointment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401"},"text":"section 7401 of this title","children":[],"tail":" to work in an occupation described in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7692"},"text":"section 7692 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc417ec0d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7693/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owes any amount of principal or interest under a loan, the proceeds of which were used by or on behalf of that individual to pay costs relating to a course of education or training which led to a degree that qualified the individual for the position referred to in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc417ec0e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7693/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc417ec0f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7693/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recently graduated from an accredited medical or osteopathic school and matched to an accredited residency program in a medical specialty described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7692"},"text":"section 7692 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc417ec10-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7693/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a physician in training in a medical specialty described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7692"},"text":"section 7692 of this title","children":[],"tail":" with more than 2 years remaining in such training."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc417ec11-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7693/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preferences","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting individuals for participation in the Specialty Education Loan Repayment Program under this subchapter, the Secretary may give preference to the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc417ec12-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7693/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Individuals who are, or will be, participating in residency programs in health care facilities—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc417ec13-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7693/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" located in rural areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc417ec14-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7693/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operated by Indian tribes, tribal organizations, or the Indian Health Service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc417ec15-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7693/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affiliated with underserved health care facilities of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc417ec16-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7693/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Veterans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc417ec17-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7693/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Costs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a)(2), costs relating to a course of education or training include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc417ec18-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7693/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tuition expenses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc417ec19-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7693/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all other reasonable educational expenses, including expenses for fees, books, equipment, and laboratory expenses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc417ec1a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7693/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonable living expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc417ec1b-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/182/tIII/s303/a"},"text":"Pub. L. 115–182, title III, § 303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-06"},"text":"June 6, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1464"},"text":"132 Stat. 1464","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/251/tII/s211/a/12"},"text":"Pub. L. 115–251, title II, § 211(a)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-29"},"text":"Sept. 29, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3176"},"text":"132 Stat. 3176","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc417ec1c-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc417ec1d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc417ec1e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/251"},"text":"Pub. L. 115–251","children":[],"tail":" substituted “will be eligible for appointment” for “is hired”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc417ec1f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc417ec20-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Preference","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/182/tIII/s303/d"},"text":"Pub. L. 115–182, title III, § 303(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-06"},"text":"June 6, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1467"},"text":"132 Stat. 1467","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/115/251/tII/s211/b/6/A"},"text":"Pub. L. 115–251, title II, § 211(b)(6)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-29"},"text":"Sept. 29, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3176"},"text":"132 Stat. 3176","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/251/tII/s211/b/6/A"},"text":"“In granting preference under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7693"},"text":"section 7693 of title 38","children":[],"tail":", United States Code, as enacted by subsection (a), the Secretary of Veterans Affairs shall determine whether a facility of the Department of Veterans Affairs is underserved based on the criteria developed under section 401 of this Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t38/s8110"},"text":"38 U.S.C. 8110","children":[],"tail":" note].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
