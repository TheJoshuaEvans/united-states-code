{"tag":"section","attrib":{"id":"idc35dea82-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3113"},"text":null,"children":[{"tag":"num","attrib":{"value":"3113"},"text":"§ 3113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vocational rehabilitation for hospitalized members of the Armed Forces and veterans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc35dea83-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3113/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Services and assistance may be provided under this chapter to a person described in subparagraphs (A)(ii) and (B) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3102/1"},"text":"section 3102(1) of this title","children":[],"tail":" who is hospitalized pending discharge from active military, naval, air, or space service. In such cases, no subsistence allowance shall be paid."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc35dea84-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3113/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Services and assistance may be provided under this chapter to a veteran who is receiving care in a Department of Veterans Affairs hospital, nursing home, or domiciliary facility or in any other hospital or medical facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc35dea85-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466/tI/s101/a"},"text":"Pub. L. 96–466, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2181"},"text":"94 Stat. 2181","children":[],"tail":", § 1513; amended "},{"t