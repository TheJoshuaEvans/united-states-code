{"tag":"section","attrib":{"id":"idc402689b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7382"},"text":null,"children":[{"tag":"num","attrib":{"value":"7382"},"text":"§ 7382.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research personnel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc402689c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7382/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver of Intergovernmental Personnel Act Mobility Program Limits","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may waive the limit on the period and number of assignments required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3372/a"},"text":"section 3372(a) of title 5","children":[],"tail":" with respect to an individual who performs research for the Department under the mobility program under subchapter VI of chapter 33 of such title (commonly referred to as the “Intergovernmental Personnel Act Mobility Program”)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc402689d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7382/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Outside Earned Income for Research for the Department","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc402689e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7382/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Compensation from a nonprofit corporation established under subchapter IV of this chapter, or a university affiliated with the Department, may be paid, without regard to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s209"},"text":"section 209 of title 18","children":[],"tail":", to an employee described in paragraph (2), for research conducted pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7303"},"text":"section 7303 of this title","children":[],"tail":" if—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc402689f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7382/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the research has been approved in accordance with procedures prescribed by the Under Secretary for Health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc40268a0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7382/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee conducts research under the supervision of personnel of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc40268a1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7382/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary agreed to the terms of such compensation in writing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc40268a2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7382/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee described in this subsection is an employee who has an appointment within the Department, whether with or without compensation, and without regard to the source of such compensation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc40268a3-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dU/tI/s182/a"},"text":"Pub. L. 117–328, div. U, title I, § 182(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5436"},"text":"136 Stat. 5436","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
