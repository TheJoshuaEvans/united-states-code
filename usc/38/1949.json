{"tag":"section","attrib":{"id":"idc31fd003-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1949"},"text":null,"children":[{"tag":"num","attrib":{"value":"1949"},"text":"§ 1949.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Beneficiaries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc31fd004-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1949/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person who enrolls in United States Government life insurance may designate a beneficiary of the insurance policy. Subject to regulations, the insured person shall at all times have the right to change the beneficiary or beneficiaries of a United States Government life insurance policy without the consent of such beneficiary or beneficiaries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc31fd005-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1949/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination in Cases of Non-Designation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a person enrolled in United States Government life insurance does not designate a beneficiary under subsection (a) before the insured person dies, or if a designated beneficiary predeceases the insured person, the Secretary shall determine the beneficiary in the following order:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc31fd006-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1949/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The surviving spouse of the insured person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc31fd007-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1949/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The children of the insured person and descendants of deceased children by representation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc31fd008-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1949/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The parents of the insured person or the survivors of the parents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc31fd009-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1949/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The duly appointed executor or administrator of the estate of the insured person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc31fd00a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1949/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other next of kin of the insured person entitled under the laws of domicile of the insured person at the time of the death of the insured person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc31fd00b-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1160"},"text":"72 Stat. 1160","children":[],"tail":", § 749; renumbered § 1949, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/313/s3/b/1"},"text":"Pub. L. 117–313, § 3(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4400"},"text":"136 Stat. 4400","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc31fd00c-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc31fd00d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc31fd00e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/313"},"text":"Pub. L. 117–313","children":[],"tail":" amended section generally. Prior to amendment, text read as follows: “Subject to regulations, the insured shall at all times have the right to change the beneficiary or beneficiaries of a United States Government life insurance policy without the consent of such beneficiary or beneficiaries.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s749"},"text":"section 749 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc31fd00f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc31fd010-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/313"},"text":"Pub. L. 117–313","children":[],"tail":" applicable with respect to the death of an insured person occurring on or after the date that is two years before "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/313/s3/c"},"text":"section 3(c) of Pub. L. 117–313","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1917"},"text":"section 1917 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
