{"tag":"section","attrib":{"id":"idc2769769-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s119"},"text":null,"children":[{"tag":"num","attrib":{"value":"119"},"text":"§ 119.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracting for statistical analyses and data evaluation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc276976a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s119/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may enter into a contract or other agreement with an academic institution or other qualified entity, as determined by the Secretary, to carry out statistical analyses and data evaluation as required of the Secretary by law.”.","children":[{"tag":"ref","attrib":{"idref":"fn002006"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002006"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The quotation marks and second period probably should not appear."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc276976b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s119/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section may be construed to limit the authority of the Secretary to enter into contracts or other agreements for statistical analyses and data evaluation under any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc276976c-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/171/tIII/s306/a"},"text":"Pub. L. 116–171, title III, § 306(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-17"},"text":"Oct. 17, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/805"},"text":"134 Stat. 805","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
