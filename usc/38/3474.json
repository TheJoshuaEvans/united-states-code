","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1178"},"text":"72 Stat. 1178","children":[],"tail":", which was classified to former "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1624"},"text":"section 1624 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/89/358/s4/a"},"text":"section 4(a) of Pub. L. 89–358","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc370fd43-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1674"},"text":"section 1674 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “3691” for “1791”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237/s423/b/1/A"},"text":"Pub. L. 101–237, § 423(b)(1)(A)","children":[],"tail":", substituted “Secretary” for “Administrator” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237/s412/b"},"text":"Pub. L. 101–237, § 412(b)","children":[],"tail":", substituted “attendance, conduct,” for “conduct”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237/s411/a"},"text":"Pub. L. 101–237, § 411(a)","children":[],"tail":", added pars. (1) and (2) and struck out former pars. (1) and (2) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) the cause of the unsatisfactory conduct or progress of the eligible veteran has been removed; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the program which the eligible veteran now proposes to pursue (whether the same or revised) is suitable to the veteran’s aptitudes, interests, and abilities.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466"},"text":"Pub. L. 96–466","children":[],"tail":" struck out provisions relating to the conditions upon which a veteran’s progress would be considered unsatisfactory."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/202"},"text":"Pub. L. 95–202","children":[],"tail":" inserted provisions authorizing the Administrator to determine the veteran’s progress to be satisfactory even though the veteran will graduate within a length of time exceeding the approved length if the additional length of time is reasonable in accordance with regulations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/502/s211/8"},"text":"Pub. L. 94–502, § 211(8)","children":[],"tail":", inserted provision specifying progress as unsatisfactory when the veteran will not be able to graduate within the approved length of the course."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/502/s206"},"text":"Pub. L. 94–502, § 206","children":[],"tail":", substituted “the veteran’s” for “his” in two places and “if the Administrator finds” for “if he finds”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc370fd44-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tai