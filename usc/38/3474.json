{"tag":"section","attrib":{"id":"idc370fd39-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3474"},"text":null,"children":[{"tag":"num","attrib":{"value":"3474"},"text":"§ 3474.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discontinuance for unsatisfactory conduct or progress","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall discontinue the educational assistance allowance of an eligible veteran if, at any time, the Secretary finds that according to the regularly prescribed standards and practices of the educational institution, the veteran’s attendance, conduct, or progress is unsatisfactory. The Secretary may renew the payment of the educational assistance allowance only if the Secretary finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc370fd3a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3474/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the veteran will be resuming enrollment at the same educational institution in the same program of education and the educational institution has both approved such veteran’s reenrollment and certified it to the Department of Veterans Affairs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc370fd3b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3474/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a proposed change of either educational institution or program of education by the veteran—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc370fd3c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3474/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cause of the unsatisfactory attendance, conduct, or progress has been removed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc370fd3d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3474/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the program proposed to be pursued is suitable to the veteran’s aptitudes, interests, and abilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc370fd3e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3474/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a proposed change of program is involved, the change meets the requirements for approval under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3691"},"text":"section 3691 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc370fd3f-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/358/s2"},"text":"Pub. L. 89–358, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-03-03"},"text":"Mar. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/16"},"text":"80 Stat. 16","children":[],"tail":", § 1674; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/502/tII"},"text":"Pub. L. 94–502, title II","children":[],"tail":", §§ 206, 211(8), "},{"tag":"date","attrib":{"date":"1976-10-15"},"text":"Oct. 15, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2387"},"text":"90 Stat. 2387","children":[],"tail":", 2388; "},{"tag":"ref","attrib":{"href":"/us/pl/95/202/tIII/s305/b/1"},"text":"Pub. L. 95–202, title III, § 305(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-11-23"},"text":"Nov. 23, 1977","children":[],"tail":"