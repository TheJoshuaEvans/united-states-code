/pl/94/502"},"text":"Pub. L. 94–502","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1976-12-01"},"text":"Dec. 1, 1976","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"1976-10-15"},"text":"Oct. 15, 1976","children":[],"tail":", respectively, see section 703(b), (c) of "},{"tag":"ref","attrib":{"href":"/us/pl/94/502"},"text":"Pub. L. 94–502","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3693"},"text":"section 3693 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc370fd48-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study of Methods To Improve Process Under Which Postsecondary Educational Institutions and Courses Are Approved; Report by ","children":[{"tag":"date","attrib":{"date":"1979-09-30"},"text":"September 30, 1979","children":[],"tail":"; Suspension of Implementation of 1976 Amendment"}],"tail":null},{"tag":"p","attrib":{},"text":"Section 305(b)(2)–(4) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/202"},"text":"Pub. L. 95–202","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/96/466/tVIII/s801/m/2"},"text":"Pub. L. 96–466, title VIII, § 801(m)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2217"},"text":"94 Stat. 2217","children":[],"tail":", directed Administrator of Veterans’ Affairs to study specific methods for improving process by which postsecondary educational institutions and courses at such institutions are approved for purposes of chapters 32, 34, 35, and 36 of this title, and need for legislative and administrative action regarding discontinuing educational assistance allowances to eligible veterans whose conduct or progress is unsatisfactory, required submission of a report on the study to President and Congress not later than "},{"tag":"date","attrib":{"date":"1979-09-30"},"text":"Sept. 30, 1979","children":[],"tail":", and directed Administrator to suspend implementation of certain amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/94/502"},"text":"Pub. L. 94–502","children":[],"tail":" until submission of report."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
