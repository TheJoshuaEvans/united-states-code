{"tag":"section","attrib":{"id":"idc26ab110-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s102"},"text":null,"children":[{"tag":"num","attrib":{"value":"102"},"text":"§ 102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dependent parents","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc26ab111-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Dependency of a parent, which may arise before or after the death of a veteran, shall be determined in accordance with regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc26ab112-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Dependency of a parent shall not be denied (1) solely because of remarriage, or (2) in any case in any State where the monthly income for a mother or father does not exceed minimum levels which the Secretary shall prescribe by regulation, giving due regard to the marital status of the mother or father and additional members of the family whom the mother or father is under a moral or legal obligation to support.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc26ab113-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of this section, in determining monthly income the Secretary shall not consider any payments under laws administered by the Secretary because of disability or death or payments of bonus or similar cash gratuity by any State based upon service in the Armed Forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc26ab114-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1109"},"text":"72 Stat. 1109","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/358/s4/e"},"text":"Pub. L. 89–358, § 4(e)","children":[],"tail":", (f), "},{"tag":"date","attrib":{"date":"1966-03-03"},"text":"Mar. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/24"},"text":"80 Stat. 24","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/540/tIV/s408"},"text":"Pub. L. 92–540, title IV, § 408","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-24"},"text":"Oct. 24, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1092"},"text":"86 Stat. 1092","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/432/tIV/s402"},"text":"Pub. L. 94–432, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1372"},"text":"90 Stat. 1372","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/576/tVII/s701/1"},"text":"Pub. L. 99–576, title VII, § 701(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3289"},"text":"100 Stat. 3289","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/54/s14/a/2"},"text":"Pub. L. 102–54, § 14(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-06-13"},"text":"June 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/282"},"text":"105 Stat. 282","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/1"},"text":"Pub. L. 102–83, § 4(a)(1)","children":[],"tail":", (b)(1), (2)(E), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/403-405"},"text":"105 Stat. 403–405","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc26ab115-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc26ab116-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc26ab117-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary shall” for “Administrator shall”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/1"},"text":"Pub. L. 102–83, § 4(a)(1)","children":[],"tail":", substituted “administered by the Secretary” for “administered by the Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/54"},"text":"Pub. L. 102–54","children":[],"tail":" substituted “(c)” for “(C)” as subsec. designation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576/s701/1/B"},"text":"Pub. L. 99–576, § 701(1)(B)","children":[],"tail":", substituted “Dependent parents” for “Dependent parents; husbands” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576/s701/1/A/ii"},"text":"Pub. L. 99–576, § 701(1)(A)(ii)","children":[],"tail":", (iii), (v), struck out par. (1) designation and redesignated par. (2) of subsec. (a) as subsec. (b) and par. (3) of subsec. (a) as subsec. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576/s701/1/A/i"},"text":"Pub. L. 99–576, § 701(1)(A)(i)","children":[],"tail":", (iii), (iv), redesignated former subsec. (a)(2) as subsec. (b) and substituted “(1)” and “(2)” for “(A)” and “(B)”, respectively. Former subsec. (b), which read “For the purposes of this title, (1) the term ‘wife’ includes the husband of any female veteran; and (2) the term ‘widow’ includes the widower of any female veteran”, was struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576/s701/1/A/v"},"text":"Pub. L. 99–576, § 701(1)(A)(v)","children":[],"tail":", redesignated former subsec. (a)(3) as subsec. (C) and substituted “For the purposes of this section,” for “For the purposes of this subsection”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/432"},"text":"Pub. L. 94–432","children":[],"tail":" substituted prohibition against denial of dependency of a parent “(B) in any case in any State where the monthly income for a mother or father does not exceed minimum levels which the Administrator shall prescribe by regulation, giving due regard to the marital status of the mother or father and additional members of the family whom the mother or father is under a moral or legal obligation to support” for such prohibition “(B) in any case in any State where the monthly income for a mother or father, not living together, is not more than $105, or where the monthly income for a mother and father living together, is not more than $175, plus, in either case, $45, for each additional member of the family whom the father or mother is under a moral or legal obligation to support, as determined by the Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/540/s408/2"},"text":"Pub. L. 92–540, § 408(2)","children":[],"tail":", substituted “Dependent parents; husbands” for “Dependent parents and dependent husbands” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/540/s408/1"},"text":"Pub. L. 92–540, § 408(1)","children":[],"tail":", struck out exception which made definition of terms inapplicable to chapter 19 of this title and struck out from definitions of “wife” and “widow” provisions relating to the ability of such persons to maintain and support themselves."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/358/s4/e"},"text":"Pub. L. 89–358, § 4(e)","children":[],"tail":", substituted “Dependency” for “Except for the purposes of chapter 33 of this title, dependency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/358/s4/f"},"text":"Pub. L. 89–358, § 4(f)","children":[],"tail":", struck out from introductory parenthetical phrase reference to chapter 33 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc26ab118-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc26ab119-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/432"},"text":"Pub. L. 94–432","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/432/s405/a"},"text":"section 405(a) of Pub. L. 94–432","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1521"},"text":"section 1521 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
