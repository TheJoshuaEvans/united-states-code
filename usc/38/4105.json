{"tag":"section","attrib":{"id":"idc3bad833-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4105"},"text":null,"children":[{"tag":"num","attrib":{"value":"4105"},"text":"§ 4105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation of Federal agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3bad834-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All Federal agencies shall furnish the Secretary such records, statistics, or information as the Secretary may deem necessary or appropriate in administering the provisions of this chapter, and shall otherwise cooperate with the Secretary in providing continuous employment and training opportunities for eligible veterans and eligible persons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3bad835-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of assisting the Secretary and the Secretary of Veterans Affairs in identifying employers with potential job training opportunities under the Veterans’ Job Training Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/77"},"text":"Public Law 98–77","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1721"},"text":"29 U.S.C. 1721","children":[],"tail":" note) "},{"tag":"ref","attrib":{"idref":"fn002093"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002093"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and otherwise in order to carry out this chapter, the Secretary of Defense shall, on the 15th day of each month, provide the Secretary and the Secretary of Veterans Affairs with updated information regarding any list maintained by the Secretary of Defense of employers participating in the National Committee for Employer Support of the Guard and Reserve."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3bad836-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1219"},"text":"72 Stat. 1219","children":[],"tail":", § 2014; renumbered § 2005 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/87/675/s1/a"},"text":"Pub. L. 87–675, § 1(a)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1962-09-19"},"text":"Sept. 19, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/558"},"text":"76 Stat. 558","children":[],"tail":", 559; "},{"tag":"ref","attrib":{"href":"/us/pl/92/540/tV/s502/a"},"text":"Pub. L. 92–540, title V, § 502(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-24"},"text":"Oct. 24, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1095"},"text":"86 Stat. 1095","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/508/tIV/s401/d"},"text":"Pub. L. 93–508, title IV, § 401(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-12-03"},"text":"Dec. 3, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1592"},"text":"88 Stat. 1592","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/502/tVI/s606/3"},"text":"Pub. L. 94–502, title VI, § 606(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-15"},"text":"Oct. 15, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2405"},"text":"90 Stat. 2405","children":[],"tail":"; "},{"tag":"ref","attrib":