{"tag":"section","attrib":{"id":"idc37ce48f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3542"},"text":null,"children":[{"tag":"num","attrib":{"value":"3542"},"text":"§ 3542.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special training allowance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc37ce490-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3542/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" While the eligible person is enrolled in and pursuing a full-time course of special restorative training, the eligible person shall be entitled to receive a special training allowance computed at the basic rate of $788 per month. If the charges for tuition and fees applicable to any such course are more than $247 per calendar month, the basic monthly allowance may be increased by the amount that such charges exceed $247 a month, upon election by the eligible person to have such person’s period of entitlement reduced by one day for each such increased amount of allowance that is equal to one-thirtieth of the full-time basic monthly rate of special training allowance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc37ce491-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3542/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No payments of a special training allowance shall be made for the same period for which the payment of an educational assistance allowance is made or for any period during which the training is pursued on less than a full-time basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc37ce492-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3542/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Full-time training for the purpose of this section shall be determined by the Secretary with respect to the capacities of the individual trainee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc37ce493-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1200"},"text":"72 Stat. 1200","children":[],"tail":", § 1742; "},{"tag":"ref","attrib":{"href":"/us/pl/89/222/s2"},"text":"Pub. L. 89–222, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-09-30"},"text":"Sept. 30, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/896"},"text":"79 Stat. 896","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/219/tI/s104/c"},"text":"Pub. L. 91–219, title I, § 104(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-03-26"},"text":"Mar. 26, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/78"},"text":"84 Stat. 78","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/540/tI/s103/4"},"text":"Pub. L. 92–540, title I, § 103(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-24"},"text":"Oct. 24, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1076"},"text":"86 Stat. 1076","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/508/tI/s103/4"},"text":"Pub. L. 93–508, title I, § 103(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-12-03"},"text":"Dec. 3, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1580"},"text":"88 Stat. 1580","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/602/tII/s204/b"},"text":"Pub. L. 93–602, title II, § 204(