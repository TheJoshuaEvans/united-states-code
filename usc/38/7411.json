{"tag":"section","attrib":{"id":"idc40993fe-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7411"},"text":null,"children":[{"tag":"num","attrib":{"value":"7411"},"text":"§ 7411.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full-time board-certified physicians and dentists: reimbursement of continuing professional education expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall reimburse any full-time board-certified physician or dentist appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401/1"},"text":"section 7401(1) of this title","children":[],"tail":" for expenses incurred, up to $1,000 per year, for continuing professional education."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc40993ff-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/tI/s103/a/s1"},"text":"Pub. L. 102–40, title I, § 103(a)[(1)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/199"},"text":"105 Stat. 199","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc4099400-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc4099401-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc4099402-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/tI/s103/b"},"text":"Pub. L. 102–40, title I, § 103(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/199"},"text":"105 Stat. 199","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/40/tI/s103/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7411"},"text":"Section 7411 of title 38","children":[],"tail":", United States Code, as added by subsection (a), shall apply with respect to expenses incurred for continuing professional education that is pursued after "},{"tag":"date","attrib":{"date":"1991-09-30"},"text":"September 30, 1991","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
