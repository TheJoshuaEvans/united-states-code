{"tag":"section","attrib":{"id":"idc2d38496-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1702"},"text":null,"children":[{"tag":"num","attrib":{"value":"1702"},"text":"§ 1702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presumptions: psychosis after service in World War II and following periods of war; mental illness after service in the Persian Gulf War","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2d38497-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Psychosis","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purposes of this chapter, any veteran of World War II, the Korean conflict, the Vietnam era, or the Persian Gulf War who developed an active psychosis (1) within two years after discharge or release from the active military, naval, or air service, and (2) before ","children":[{"tag":"date","attrib":{"date":"1949-07-26"},"text":"July 26, 1949","children":[],"tail":", in the case of a veteran of World War II, before "},{"tag":"date","attrib":{"date":"1957-02-01"},"text":"February 1, 1957","children":[],"tail":", in the case of a veteran of the Korean conflict, before "},{"tag":"date","attrib":{"date":"1977-05-08"},"text":"May 8, 1977","children":[],"tail":", in the case of a Vietnam era veteran, or before the end of the two-year period beginning on the last day of the Persian Gulf War, in the case of a veteran of the Persian Gulf War, shall be deemed to have incurred such disability in the active military, naval, or air service."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2d38498-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Mental Illness","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter, any veteran of the Persian Gulf War who develops an active mental illness (other than psychosis) shall be deemed to have incurred such disability in the active military, naval, or air service if such veteran develops such disability—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2d38499-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1702/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within two years after discharge or release from the active military, naval, or air service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2d3849a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1702/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before the end of the two-year period beginning on the last day of the Persian Gulf War.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2d5f59b-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1141"},"text":"72 Stat. 1141","children":[],"tail":", § 602; "},{"tag":"ref","attrib":{"href":"/us/pl/90/77/tII/s203/a"},"text":"Pub. L. 90–77, title II, § 203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-08-31"},"text":"Aug. 31, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/183"},"text":"81 Stat. 183","children":[],"tail":"; "},{"tag":"ref","attrib"