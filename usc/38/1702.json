n":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc2d5f59e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s1708/a/2"},"text":"Pub. L. 110–181, § 1708(a)(2)","children":[],"tail":", substituted “Presumptions: psychosis after service in World War II and following periods of war; mental illness after service in the Persian Gulf War” for “Presumption relating to psychosis” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s1708/a/1"},"text":"Pub. L. 110–181, § 1708(a)(1)","children":[],"tail":", designated existing text as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s602"},"text":"section 602 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/25"},"text":"Pub. L. 102–25","children":[],"tail":" substituted “the Vietnam era, or the Persian Gulf War” for “or the Vietnam era”, struck out “or” before “before "},{"tag":"date","attrib":{"date":"1977-05-08"},"text":"May 8, 1977","children":[],"tail":"”, and inserted “or before the end of the two-year period beginning on the last day of the Persian Gulf War, in the case of a veteran of the Persian Gulf War,” after “Vietnam era veterans,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576"},"text":"Pub. L. 99–576","children":[],"tail":" struck out “his” before “discharge”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295"},"text":"Pub. L. 97–295","children":[],"tail":" substituted “before "},{"tag":"date","attrib":{"date":"1957-02-01"},"text":"February 1, 1957","children":[],"tail":", in the case of a veteran of the Korean conflict, or before "},{"tag":"date","attrib":{"date":"1977-05-08"},"text":"May 8, 1977","children":[],"tail":",” for “or "},{"tag":"date","attrib":{"date":"1957-02-01"},"text":"February 1, 1957","children":[],"tail":", in the case of a veteran of the Korean conflict, or before the expiration of two years following termination of the Vietnam era”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/77"},"text":"Pub. L. 90–77","children":[],"tail":" made the presumption relating to psychosis applicable to any veteran of the Vietnam era who developed an active psychosis within two years after his discharge from active service and before the expiration of two years following termination of the Vietnam era."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc2d5f59f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc2d5f5a0-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1967 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/77"},"text":"Pub. L. 90–77","children":[],"tail":" effective first day of first calendar month which begins more than ten days after "},{"tag":"date","attrib":{"date":"1967-08-31"},"text":"Aug. 31, 1967","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/77/s405"},"text":"section 405 of Pub. L. 90–77","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
