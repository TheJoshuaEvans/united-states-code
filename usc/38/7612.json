{"tag":"section","attrib":{"id":"idc4130a6d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7612"},"text":null,"children":[{"tag":"num","attrib":{"value":"7612"},"text":"§ 7612.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility; application; agreement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc4130a6e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7612/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4130a6f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7612/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2) of this subsection, an individual must be accepted for enrollment or be enrolled (as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7602"},"text":"section 7602 of this title","children":[],"tail":") as a full-time student to be eligible to participate in the Scholarship Program."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4130a70-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7612/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual who is an eligible Department employee may be accepted as a participant if accepted for enrollment or enrolled (as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7602"},"text":"section 7602 of this title","children":[],"tail":") for study on less than a full-time but not less than a half-time basis. (Such a participant is hereinafter in this subchapter referred to as a “part-time student”.)"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4130a71-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7612/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of paragraph (2) of this subsection, an eligible Department employee is a full-time Department employee who is permanently assigned to a Department health-care facility on the date on which the individual submits the application referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7603"},"text":"section 7603 of this title","children":[],"tail":" and on the date on which the individual becomes a participant in the Scholarship Program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4130a72-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7612/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4130a73-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7612/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A scholarship may be awarded under this subchapter only in a qualifying field of education or training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4130a74-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7612/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A qualifying field of education or training for purposes of this subchapter is education or training leading to employment as an appointee under paragraph (1) or (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401"},"text":"section 7401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4130a75-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7612/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may designate additional fields of education or training as qualifying fields of education or training if the education or training leads to employment in a position which would qualify the individual for increased basic pay under subsection (a)(1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7455"},"text":"section 7455 of this title","children":[],"tail":" for personnel described in subsection (a)(2)(B) of such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4130a76-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7612/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Before awarding the initial scholarship in a course of education or training other than medicine or nursing, the Secretary shall notify the Committees on Veterans’ Affairs of the Senate and House of Representatives of the Secretary’s intent to award a scholarship in such course of education or training. The notice shall include a statement of the reasons why the award of scholarships in that course of education or training is necessary to assist in providing the Department with an adequate supply of personnel in the health profession concerned. Any such notice shall be given not less than 60 days before the first such scholarship is awarded.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4130a77-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7612/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In selecting applicants for the Scholarship Program, the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc4130a78-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7612/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall give priority to applicants who will be entering their final year in a course of training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4130a79-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7612/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall give priority to applicants pursuing a course of education or training toward a career in an occupation for which the Inspector General of the Department has, in the most current determination published in the Federal Register pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7412/a"},"text":"section 7412(a) of this title","children":[],"tail":", determined that there is one of the largest staffing shortages throughout the Department with respect to such occupation; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4130a7a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7612/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall ensure an equitable allocation of scholarships to persons enrolled in the second year of a program leading to an associate degree in nursing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4130a7b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7612/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc4130a7c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7612/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Of the scholarships awarded under this subchapter, the Secretary shall ensure that not less than 50 scholarships are awarded each year to individuals who are accepted for enrollment or enrolled (as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7602"},"text":"section 7602 of this title","children":[],"tail":") in a program of education or training leading to employment as a physician or dentist until such date as the Secretary determines that the staffing shortage of physicians and dentists in the Department is less than 500."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4130a7d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7612/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After such date, the Secretary shall ensure that of the scholarships awarded under this subchapter, a number of scholarships is awarded each year to individuals referred to in subparagraph (A) in an amount equal to not less than ten percent of the staffing shortage of physicians and dentists in the Department, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4130a7e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7612/b/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding subsection (c)(1), the agreement between the Secretary and a participant in the Scholarship Program who receives a scholarship pursuant to this paragraph shall provide the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc4130a7f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7612/b/6/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary’s agreement to provide the participant with a scholarship under this subchapter for a specified number (from two to four) of school years during which the participant is pursuing a course of education or training leading to employment as a physician or dentist.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc4130a80-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7612/b/6/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The participant’s agreement to serve as a full-time employee in the Veterans Health Administration for a period of time (hereinafter in this subchapter referred to as the “period of obligated service”) of 18 months for each school year or part thereof for which the participant was provided a scholarship under the Scholarship Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4130a81-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7612/b/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In providing scholarships pursuant to this paragraph, the Secretary may provide a preference for applicants who are veterans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4157a82-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7612/b/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On an annual basis, the Secretary shall provide to appropriate educational institutions informational material about the availability of scholarships under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4157a83-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7612/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4157a84-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7612/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An agreement between the Secretary and a participant in the Scholarship Program shall (in addition to the requirements set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7604"},"text":"section 7604 of this title","children":[],"tail":") include the following:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc4157a85-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7612/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary’s agreement to provide the participant with a scholarship under this subchapter for a specified number (from one to four) of school years during which the participant is pursuing a course of education or training described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7602"},"text":"section 7602 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4157a86-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7612/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The participant’s agreement to serve as a full-time employee in the Veterans Health Administration for a period of time (hereinafter in this subchapter referred to as the “period of obligated service”) of one calendar year for each school year or part thereof for which the participant was provided a scholarship under the Scholarship Program, but for not less than two years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4157a87-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7612/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In a case in which an extension is granted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7614/3"},"text":"section 7614(3) of this title","children":[],"tail":", the number of years for which a scholarship may be provided under this subchapter shall be the number of school years provided for as a result of the extension."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4157a88-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7612/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of a participant who is a part-time student—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc4157a89-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7612/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period of obligated service shall be reduced in accordance with the proportion that the number of credit hours carried by such participant in any such school year bears to the number of credit hours required to be carried by a full-time student in the course of training being pursued by the participant, but in no event to less than one year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4157a8a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7612/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agreement shall include the participant’s agreement to maintain employment, while enrolled in such course of education or training, as a Department employee permanently assigned to a Department health-care facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4157a8b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7612/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a participant’s period of obligated service is deferred under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7616/b/3/A/i"},"text":"section 7616(b)(3)(A)(i) of this title","children":[],"tail":", the agreement terms under paragraph (1) of this subsection shall provide for the participant to serve any additional period of obligated service that is prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7616/b/4/B"},"text":"section 7616(b)(4)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc4157a8c-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/322/tII/s216/b"},"text":"Pub. L. 100–322, title II, § 216(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/520"},"text":"102 Stat. 520","children":[],"tail":", § 4312; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tII/s207/a"},"text":"Pub. L. 101–237, title II, § 207(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2068"},"text":"103 Stat. 2068","children":[],"tail":"; renumbered § 7612 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV"},"text":"Pub. L. 102–40, title IV","children":[],"tail":", §§ 402(b)(1), (d)(1), 403(b)(4), "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":", 239; "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/3"},"text":"Pub. L. 102–83, § 4(a)(3)","children":[],"tail":", (4), (b)(1), (2)(E), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404"},"text":"105 Stat. 404","children":[],"tail":", 405; "},{"tag":"ref","attrib":{"href":"/us/pl/102/405/tII/s202/a"},"text":"Pub. L. 102–405, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-09"},"text":"Oct. 9, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1983"},"text":"106 Stat. 1983","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/446/tXII/s1201/b/1"},"text":"Pub. L. 103–446, title XII, § 1201(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4682"},"text":"108 Stat. 4682","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/163/tVI/s603/b"},"text":"Pub. L. 111–163, title VI, § 603(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-05-05"},"text":"May 5, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1173"},"text":"124 Stat. 1173","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/146/tIII/s301/c"},"text":"Pub. L. 113–146, title III, § 301(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-08-07"},"text":"Aug. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1786"},"text":"128 Stat. 1786","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/182/tIII/s301/a"},"text":"Pub. L. 115–182, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-06"},"text":"June 6, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1462"},"text":"132 Stat. 1462","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc4157a8d-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc4157a8e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc4157a8f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/182"},"text":"Pub. L. 115–182","children":[],"tail":" added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (b)(5)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/146"},"text":"Pub. L. 113–146","children":[],"tail":" added subpar. (B) and redesignated former subpar. (B) as (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163"},"text":"Pub. L. 111–163","children":[],"tail":" substituted “as an appointee under paragraph (1) or (3) of "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401"},"text":"section 7401 of this title","children":[],"tail":".” for “(under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401"},"text":"section 7401 of this title","children":[],"tail":") as any of the following:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) A physician, dentist, podiatrist, optometrist, nurse, physician assistant, or expanded function dental auxiliary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) A psychologist described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401/3"},"text":"section 7401(3) of this title","children":[],"tail":" or a certified or registered respiratory therapist, licensed physical therapist, or licensed practical or vocational nurse.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446"},"text":"Pub. L. 103–446","children":[],"tail":" substituted “Veterans Health Administration” for “Department of Medicine and Surgery”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/405"},"text":"Pub. L. 102–405","children":[],"tail":" inserted before period at end “, but for not less than two years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/b/1"},"text":"Pub. L. 102–40, § 402(b)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4312"},"text":"section 4312 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/d/1"},"text":"Pub. L. 102–40, § 402(d)(1)","children":[],"tail":", substituted “7602” for “4302”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/3"},"text":"Pub. L. 102–83, § 4(a)(3)","children":[],"tail":", (4), substituted “Department” for “Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/d/1"},"text":"Pub. L. 102–40, § 402(d)(1)","children":[],"tail":", substituted “7602” for “4302”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/3"},"text":"Pub. L. 102–83, § 4(a)(3)","children":[],"tail":", (4), substituted “Department” for “Veterans’ Administration” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/d/1"},"text":"Pub. L. 102–40, § 402