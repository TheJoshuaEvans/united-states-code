{"tag":"section","attrib":{"id":"idc2f4efca-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1712C"},"text":null,"children":[{"tag":"num","attrib":{"value":"1712C"},"text":"§ 1712C.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dental insurance plan for veterans and survivors and dependents of veterans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2f4efcb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1712C/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall establish and administer a dental insurance plan for veterans and survivors and dependents of veterans described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2f4efcc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1712C/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Veterans and Survivors and Dependents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The veterans and survivors and dependents of veterans described in this subsection are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2f4efcd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1712C/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any veteran who is enrolled in the system of annual patient enrollment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1705"},"text":"section 1705 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2f4efce-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1712C/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any survivor or dependent of a veteran who is eligible for medical care under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1781"},"text":"section 1781 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2f4efcf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1712C/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall contract with a dental insurer to administer the dental insurance plan under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2f4efd0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1712C/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Benefits","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The dental insurance plan under this section shall provide such benefits for dental care and treatment as the Secretary considers appropriate for the dental insurance plan, including diagnostic services, preventative services, endodontics and other restorative services, surgical services, and emergency services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2f4efd1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1712C/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enrollment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2f4efd2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1712C/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Enrollment in the dental insurance plan under this section shall be voluntary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2f4efd3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1712C/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Enrollment in the dental insurance plan shall be for such minimum period as the Secretary shall prescribe for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2f4efd4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1712C/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Premiums","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2f4efd5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1712C/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Premiums for coverage under the dental insurance plan under this section shall be in such amount or amounts as the Secretary shall prescribe to cover all costs associated with carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2f4efd6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1712C/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall adjust the premiums payable under this section for coverage under the dental insurance plan on an annual basis. Each individual covered by the dental insurance plan at the time of such an adjustment shall be notified of the amount and effective date of such adjustment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2f4efd7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1712C/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each individual covered by the dental insurance plan shall pay the entire premium for coverage under the dental insurance plan, in addition to the full cost of any copayments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2f4efd8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1712C/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Voluntary Disenrollment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2f4efd9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1712C/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to enrollment in the dental insurance plan under this section, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2f4efda-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1712C/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit the voluntary disenrollment of an individual in the dental insurance plan if the disenrollment occurs during the 30-day period beginning on the date of the enrollment of the individual in the dental insurance plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2f4efdb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1712C/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit the voluntary disenrollment of an individual in the dental insurance plan for such circumstances as the Secretary shall prescribe for purposes of this subsection, but only to the extent such disenrollment does not jeopardize the fiscal integrity of the dental insurance plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2f4efdc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1712C/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The circumstances prescribed under paragraph (1)(B) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2f4efdd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1712C/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If an individual enrolled in the dental insurance plan relocates to a location outside the jurisdiction of the dental insurance plan that prevents use of the benefits under the dental insurance plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2f4efde-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1712C/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If an individual enrolled in the dental insurance plan is prevented by a serious medical condition from being able to obtain benefits under the dental insurance plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2f4efdf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1712C/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other circumstances as the Secretary shall prescribe for purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2f4efe0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1712C/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall establish procedures for determinations on the permissibility of voluntary disenrollments under paragraph (1)(B). Such procedures shall ensure timely determinations on the permissibility of such disenrollments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2f4efe1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1712C/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Dental Care Provided by Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall affect the responsibility of the Secretary to provide dental care under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1712"},"text":"section 1712 of this title","children":[],"tail":", and the participation of an individual in the dental insurance plan under this section shall not affect the entitlement of the individual to outpatient dental services and treatment, and related dental appliances, under such section 1712."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2f4efe2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1712C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The dental insurance plan under this section shall be administered under such regulations as the Secretary shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2f4efe3-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/218/s2/a/1"},"text":"Pub. L. 114–218, § 2(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-29"},"text":"July 29, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/842"},"text":"130 Stat. 842","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/42/s2"},"text":"Pub. L. 117–42, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-09-30"},"text":"Sept. 30, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/342"},"text":"135 Stat. 342","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2f4efe4-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc2f4efe5-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc2f4efe6-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/42"},"text":"Pub. L. 117–42","children":[],"tail":" struck out subsec. (j). Text read as follows: “This section terminates on "},{"tag":"date","attrib":{"date":"2021-12-31"},"text":"December 31, 2021","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
