{"tag":"section","attrib":{"id":"idc33c8049-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2102B"},"text":null,"children":[{"tag":"num","attrib":{"value":"2102B"},"text":"§ 2102B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adaptations to residences of veterans in rehabilitation programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc33c804a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2102B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subsections (b) and (c), the Secretary may assist a veteran who is entitled to services and assistance under chapter 31 of this title and is pursuing a rehabilitation program under such chapter in acquiring such adaptations to such veteran’s residence as are determined necessary by the Secretary to accomplish the purposes of such rehabilitation program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc33c804b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2102B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc33c804c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2102B/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The aggregate amount of assistance available to a veteran under subsection (a) may not exceed $77,307. The Secretary may waive this limitation for a veteran if the Secretary determines a waiver is necessary for the rehabilitation program of the veteran.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc33c804d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2102B/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Effective on October 1 of each year (beginning in 2017), the Secretary shall increase the amount described in paragraph (1) by the percentage calculated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2102/e/2"},"text":"section 2102(e)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc33c804e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2102B/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Beginning on ","children":[{"tag":"date","attrib":{"date":"2019-10-01"},"text":"October 1, 2019","children":[],"tail":", the Secretary shall submit to the Committees on Veterans’ Affairs of the Senate and House of Representatives a biennial report on the use of the waiver authority under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc33c804f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2102B/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc33c8050-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2102B/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rehabilitation Program Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “rehabilitation program” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc33c8051-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/177/s1/a"},"text":"Pub. L. 115–177, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-01"},"text":"June 1, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1376"},"text":"132 Stat. 1376","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc33c8052-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc33c8053-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc33c8054-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/177/s1/b"},"text":"Pub. L. 115–177, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-01"},"text":"June 1, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1376"},"text":"132 Stat. 1376","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/177/s1/b"},"text":"“The Secretary may provide assistance under section 2102B of such title [meaning title 38, United States Code], as added by subsection (a), in advance of regulations by issuing notice specifying the criteria for the application, approval, and oversight processes relating to the provision of assistance under such section.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
