{"tag":"section","attrib":{"id":"idc417eb75-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7671"},"text":null,"children":[{"tag":"num","attrib":{"value":"7671"},"text":"§ 7671.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority for program","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As part of the Educational Assistance Program, the Secretary may carry out a scholarship program under this subchapter. The program shall be known as the Department of Veterans Affairs Employee Incentive Scholarship Program (hereinafter in this subchapter referred to as the “Program”). The purpose of the Program is to assist, through the establishment of an incentive program for individuals employed in the Veterans Health Administration, in meeting the staffing needs of the Veterans Health Administration for health professional occupations for which recruitment or retention of qualified personnel is difficult.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc417eb76-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/tVIII/s802/a"},"text":"Pub. L. 105–368, title VIII, § 802(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3352"},"text":"112 Stat. 3352","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/14/s8/a/16"},"text":"Pub. L. 107–14, § 8(a)(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-06-05"},"text":"June 5, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/35"},"text":"115 Stat. 35","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc417eb77-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc417eb78-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc417eb79-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/14"},"text":"Pub. L. 107–14","children":[],"tail":" substituted “hereinafter” for “hereafter”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
