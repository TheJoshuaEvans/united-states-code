{"tag":"section","attrib":{"id":"idc36c4296-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3326"},"text":null,"children":[{"tag":"num","attrib":{"value":"3326"},"text":"§ 3326.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on student progress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc36c4297-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3326/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submittal of Information by Educational Institutions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As a condition of approval under chapter 36 of this title of a course offered by an educational institution (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3452"},"text":"section 3452 of this title","children":[],"tail":"), each year, each educational institution (as so defined) that received a payment in that year on behalf of an individual entitled to educational assistance under this chapter shall submit to the Secretary such information regarding the academic progress of the individual as the Secretary may require."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc36c4298-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3326/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than March 1 of each year, the Secretary shall submit to Congress a report that includes a summary of the information provided by educational institutions under subsection (a) for the calendar year preceding the year during which such report is submitted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc36c4299-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/315/tIV/s404/a/2"},"text":"Pub. L. 114–315, title IV, § 404(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1554"},"text":"130 Stat. 1554","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/48/tI/s114"},"text":"Pub. L. 115–48, title I, § 114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-16"},"text":"Aug. 16, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/985"},"text":"131 Stat. 985","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc36c429a-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc36c429b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc36c429c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/48"},"text":"Pub. L. 115–48","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc36c429d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc36c429e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 1 year after ","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/315/s404/c"},"text":"section 404(c) of Pub. L. 114–315","children":[],"tail":", set out as an Effective Date of 2016 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3325"},"text":"section 3325 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
