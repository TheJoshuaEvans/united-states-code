{"tag":"section","attrib":{"id":"idc30f2df4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1742"},"text":null,"children":[{"tag":"num","attrib":{"value":"1742"},"text":"§ 1742.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspections of such homes; restrictions on beneficiaries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc30f2df5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1742/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may inspect any State home at such times as the Secretary deems necessary. No payment or grant may be made to any home under this subchapter unless such home is determined by the Secretary to meet such standards as the Secretary shall prescribe, which standards with respect to nursing home care shall be no less stringent than those prescribed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1720/b"},"text":"section 1720(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc30f2df6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1742/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may ascertain the number of persons on account of whom payments may be made under this subchapter on account of any State home, but shall have no authority over the management or control of any State home.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc30f2df7-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1146"},"text":"72 Stat. 1146","children":[],"tail":", § 642; "},{"tag":"ref","attrib":{"href":"/us/pl/94/581/tI/s107/a"},"text":"Pub. L. 94–581, title I, § 107(a)","children":[],"tail":", title II, § 210(a)(16), "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2847"},"text":"90 Stat. 2847","children":[],"tail":", 2863; renumbered § 1742 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":", §§ 4(b)(1), (2)(E), 5(a), (c)(1), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404-406"},"text":"105 Stat. 404–406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc30f2df8-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc30f2df9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc30f2dfa-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior section 1742 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3542"},"text":"section 3542 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc30f2dfb-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t