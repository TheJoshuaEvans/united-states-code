{"tag":"section","attrib":{"id":"idc34f933f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3014"},"text":null,"children":[{"tag":"num","attrib":{"value":"3014"},"text":"§ 3014.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of basic educational assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc34f9340-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3014/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall pay to each individual entitled to basic educational assistance who is pursuing an approved program of education a basic educational assistance allowance to help meet, in part, the expenses of such individual’s subsistence, tuition, fees, supplies, books, equipment, and other educational costs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc34f9341-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3014/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc34f9342-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3014/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an individual entitled to basic educational assistance who is pursuing education or training described in subsection (a) or (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2007"},"text":"section 2007 of title 10","children":[],"tail":", the Secretary shall, at the election of the individual, pay the individual a basic educational assistance allowance to meet all or a portion of the charges of the educational institution for the education or training that are not paid by the Secretary of the military department concerned under such subsection."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc34f9343-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3014/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc34f9344-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3014/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of the basic educational assistance allowance payable to an individual under this subsection for a month shall be the amount of the basic educational assistance allowance to which the individual would be entitled for the month under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3015"},"text":"section 3015 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc34f9345-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3014/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The maximum number of months for which an individual may be paid a basic educational assistance allowance under paragraph (1) is 36.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc34f9346-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3014/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of months of entitlement charged under this chapter in the case of an individual who has been paid a basic educational assistance allowance under this subsection shall be equal to the number (including any fraction) determined by dividing the total amount of such educational assistance allowance paid the individual by the full-time monthly institutional rate of educational assistance which such individual would otherwise be paid under subsection (a)(1), (b)(1), (c)(1), (d)(1), or (e)(1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3015"},"text":"section 3015 of this title","children":[],"tail":", as the case may be."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc34f9347-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/tVII/s702/a/1"},"text":"Pub. L. 98–525, title VII, § 702(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2557"},"text":"98 Stat. 2557","children":[],"tail":", § 1414; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIV/s423/b/1/A"},"text":"Pub. L. 101–237, title IV, § 423(b)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2092"},"text":"103 Stat. 2092","children":[],"tail":"; renumbered § 3014, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title XVI, § 1602(b)(2)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–359; "},{"tag":"ref","attrib":{"href":"/us/pl/107/14/s7/b/1"},"text":"Pub. L. 107–14, § 7(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-06-05"},"text":"June 5, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/31"},"text":"115 Stat. 31","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc34f9348-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc34f9349-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc34f934a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/14/s7/b/1/A"},"text":"Pub. L. 107–14, § 7(b)(1)(A)","children":[],"tail":", struck out “(without regard to subsection (g) of that section) were payment made under that section instead of under this subsection” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/14/s7/b/1/B"},"text":"Pub. L. 107–14, § 7(b)(1)(B)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1414"},"text":"section 1414 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" substituted “Secretary” for “Administrator”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc34f934b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc34f934c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2001 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/14/s7/b/3"},"text":"Pub. L. 107–14, § 7(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-06-05"},"text":"June 5, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/32"},"text":"115 Stat. 32","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/14/s7/b/3"},"text":"“The amendments made by this subsection [amending this section and sections 3015 and 3032 of this title] shall take effect as if enacted on ","children":[{"tag":"date","attrib":{"date":"2000-11-01"},"text":"November 1, 2000","children":[],"tail":", immediately after the enactment of the Veterans Benefits and Health Care Improvement Act of 2000 ("},{"tag":"ref","attrib":{"href":"/us/pl/106/419"},"text":"Public Law 106–419","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
