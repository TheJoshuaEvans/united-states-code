{"tag":"section","attrib":{"id":"idc3165a50-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1901"},"text":null,"children":[{"tag":"num","attrib":{"value":"1901"},"text":"§ 1901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3165a51-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1901/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “insurance” means National Service Life Insurance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3165a52-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1901/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “widow” or “widower” mean a person who was the lawful spouse of the insured at the maturity of the insurance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3165a53-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1901/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “child” means a legitimate child, an adopted child, and, if designated as beneficiary by the insured, a stepchild or an illegitimate child.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3165a54-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1901/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “parent”, “father”, and “mother” mean a father, mother, father through adoption, mother through adoption, persons who have stood in loco parentis to a member of the military or naval forces at any time before entry into active service for a period of not less than one year, and a step­parent, if designated as beneficiary by the insured.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3165a55-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1148"},"text":"72 Stat. 1148","children":[],"tail":", § 701; renumbered § 1901, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3165a56-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3165a57-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc3165a58-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior section 1901 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3901"},"text":"section 3901 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 1901, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1215"},"text":"72 Stat. 1215","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/90/77/tII/s204/a"},"text":"Pub. L. 90–77, title II, § 204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-08-31"},"text":"Aug. 31, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/184"},"text":"81 Stat. 184","children":[],"tail":", related to veterans eligible for assistance, prior to the general revision of chapter 39 of this title by "},{"tag":"ref","attrib":{"href":"/us/pl/91/666"},"text":"Pub. L. 91–666","children":[],"tail":". See sections 3901 and 3902 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3165a59-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s701"},"text":"section 701 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
