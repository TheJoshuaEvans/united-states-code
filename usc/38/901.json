{"tag":"section","attrib":{"id":"idc293219a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s901"},"text":null,"children":[{"tag":"num","attrib":{"value":"901"},"text":"§ 901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to prescribe rules for conduct and penalties for violations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc293219b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s901/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc293219c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s901/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall prescribe regulations to provide for the maintenance of law and order and the protection of persons and property on Department property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc293219d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s901/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this chapter, the term “Department property” means land and buildings that are under the jurisdiction of the Department and are not under control of the Administrator of General Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc293219e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s901/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Regulations under subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc293219f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s901/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rules for conduct on Department property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc29321a0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s901/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the penalties, within the limits specified in subsection (c), for violations of such rules.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc29321a1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s901/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever violates any rule prescribed by regulation under subsection (b)(1) shall be fined in accordance with title 18 or imprisoned not more than six months, or both. The Secretary may prescribe by regulation a maximum fine less than that which would otherwise apply under the preceding sentence or a maximum term of imprisonment of a shorter period than that which would otherwise apply under the preceding sentence, or both. Any such regulation shall apply notwithstanding any provision of title 18 or any other law to the contrary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc29321a2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s901/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rules prescribed under subsection (a), together with the penalties for violations of such rules, shall be posted conspicuously on property to which they apply.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc29321a3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s901/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall consult with the Attorney General before prescribing regulations under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc29321a4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s901/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc29321a5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s901/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not prohibit the use of a covered service dog in any facility or on any property of the Department or in any facility or on any property that receives funding from the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc29321a6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s901/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this subsection, a covered service dog is a service dog that has been trained by an entity that is accredited by an appropriate accrediting body that evaluates and accredits organizations which train guide or service dogs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc29321a7-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s2/a"},"text":"Pub. L. 102–83, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/397"},"text":"105 Stat. 397","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/154/tI/s109"},"text":"Pub. L. 112–154, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1174"},"text":"126 Stat. 1174","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc29321a8-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc29321a9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc29321aa-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior section 901 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2301"},"text":"section 2301 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s218/a"},"text":"section 218(a) of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s2/a"},"text":"Pub. L. 102–83, § 2(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc29321ab-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/154"},"text":"Pub. L. 112–154","children":[],"tail":" added subsec. (f)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
