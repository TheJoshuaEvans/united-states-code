{"tag":"section","attrib":{"id":"idc362a5f3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3243"},"text":null,"children":[{"tag":"num","attrib":{"value":"3243"},"text":"§ 3243.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits; reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Deductions made by the Department of Defense from the military pay of any participant shall be promptly transferred to the Secretary for deposit in the fund. The Secretary of Defense shall also submit to the Secretary a report each month showing the name, service number, and the amount of the deduction made from the military pay of each initial enrollee, any contribution made by the Secretary of Defense pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3222/c"},"text":"section 3222(c) of this title","children":[],"tail":", as well as any changes in each participant’s enrollment and/or contribution. The report shall also include any additional information the Secretary and the Secretary of Defense deem necessary to administer this program. The Secretary shall maintain accounts showing contributions made to the fund by individual participants and by the Secretary of Defense as well as disbursements made from the fund in the form of benefits."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc362a5f4-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/502/tIV/s404"},"text":"Pub. L. 94–502, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-15"},"text":"Oct. 15, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2397"},"text":"90 Stat. 2397","children":[],"tail":", § 1643; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/160/tVII/s702/9"},"text":"Pub. L. 98–160, title VII, § 702(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-11-21"},"text":"Nov. 21, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1009"},"text":"97 Stat. 1009","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIV/s423/b/1/A"},"text":"Pub. L. 101–237, title IV, § 423(b)(1)(A)","children":[],"tail":", (4)(D), "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2092"},"text":"103 Stat. 2092","children":[],"tail":"; renumbered § 3243 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc362a5f5-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc362a5f6-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc362a5f7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 3301 to 3305 and 3311 to 3313, which comprised chapter 57, were renumbered sections 5701 to 5705 and 5711 to 5713, respectively, of this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior sections 3401 to 3405, which comprised chapter 59, were renumbered sections 5901 to 5905, respectively, of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc362a5f8-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1643"},"text":"section 1643 of this title","children":[],"tail":" as this section and substituted “3222(c)” for “1622(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" substituted “Secretary” for “Administrator” wherever appearing and inserted “of Defense” after “Secretary” in four places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/160"},"text":"Pub. L. 98–160","children":[],"tail":" inserted “of this title” after “section 1622(c)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc362a5f9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc362a5fa-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1977-01-01"},"text":"Jan. 1, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/502/s406"},"text":"section 406 of Pub. L. 94–502","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3201"},"text":"section 3201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
