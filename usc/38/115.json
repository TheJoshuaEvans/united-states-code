{"tag":"section","attrib":{"id":"idc2742740-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s115"},"text":null,"children":[{"tag":"num","attrib":{"value":"115"},"text":"§ 115.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of real property","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of sections 314, 315, 316, and 2406 of this title and subchapter I of chapter 81 of this title, the Secretary may acquire and use real property—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2742741-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s115/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before title to the property is approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3111"},"text":"section 3111 of title 40","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2742742-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s115/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" even though the property will be held in other than a fee simple interest in a case in which the Secretary determines that the interest to be acquired is sufficient for the purposes of the intended use.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2742743-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/86/tIV/s402/a"},"text":"Pub. L. 102–86, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-14"},"text":"Aug. 14, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/422"},"text":"105 Stat. 422","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(