{"tag":"section","attrib":{"id":"idc37ce443-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3533"},"text":null,"children":[{"tag":"num","attrib":{"value":"3533"},"text":"§ 3533.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special assistance for the educationally disadvantaged","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc37ce444-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3533/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc37ce445-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3533/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any eligible person shall be entitled to the assistance provided an eligible veteran under section 3491(a) (if pursued in a State) of this title and be paid an educational assistance allowance therefor in the manner prescribed by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3491/b"},"text":"section 3491(b) of this title","children":[],"tail":", except that the corresponding rate provisions of this chapter shall apply, as determined by the Secretary, to such pursuit by an eligible person."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc37ce446-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3533/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Educational assistance under this chapter for the first five months of full-time pursuit of a program (or the equivalent thereof in part-time educational assistance) consisting of such course or courses shall be provided without charge to entitlement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc37ce447-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3533/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any eligible person shall, without charge to any entitlement such person may have under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3511"},"text":"section 3511 of this title","children":[],"tail":", be entitled to the benefits provided an eligible veteran under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3492"},"text":"section 3492 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc37ce448-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/540/tIII/s313"},"text":"Pub. L. 92–540, title III, § 313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-24"},"text":"Oct. 24, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1084"},"text":"86 Stat. 1084","children":[],"tail":", § 1733; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/502/tIII/s310/17"},"text":"Pub. L. 94–502, title III, § 310(17)","children":[],"tail":", (18), "},{"tag":"date","attrib":{"date":"1976-10-15"},"text":"Oct. 15, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2392"},"text":"90 Stat. 2392","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/223/tII/s203/b"},"text":"Pub. L. 98–223, title II, § 203(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-03-02"},"text":"Mar. 2, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/41"},"text":"98 Stat. 41","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/689/tI/s106/c"},"text":"Pub. L. 100–689, title I, § 106(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4167"},"text":"102 Stat. 4167","children":[],"tail":"; "},{"tag":"ref",