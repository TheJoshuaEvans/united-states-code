{"tag":"section","attrib":{"id":"idc29320f3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s726"},"text":null,"children":[{"tag":"num","attrib":{"value":"726"},"text":"§ 726.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report on performance awards and bonuses awarded to certain high-level employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc29320f4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s726/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 100 days after the end of each fiscal year, the Secretary shall submit to the appropriate committees of Congress a report that contains, for the most recent fiscal year ending before the submittal of the report, a description of all performance awards or bonuses awarded to each of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc29320f5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s726/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Regional Office Director of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc29320f6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s726/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Director of a Medical Center of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc29320f7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s726/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Director of a Veterans Integrated Service Network.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc29320f8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s726/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Senior executive of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc29320f9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s726/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report submitted under subsection (a) shall include the following with respect to each performance award or bonus awarded to an individual described in such subsection:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc29320fa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s726/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of each award or bonus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc29320fb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s726/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The job title of the individual awarded the award or bonus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc29320fc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s726/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The location where the individual awarded the award or bonus works.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc29320fd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s726/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc29320fe-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s726/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “appropriate committees of Congress” means the Committees on Veterans’ Affairs and Appropriations of the Senate and House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc29320ff-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s726/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “senior executive” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2932100-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s726/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a career appointee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2932101-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s726/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an individual—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc2932102-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s726/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in an administrative or executive position; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc2932103-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s726/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appointed under section 7306(a) or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401/1"},"text":"section 7401(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2932104-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s726/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “career appointee” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3132/a"},"text":"section 3132(a) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2932105-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/182/tV/s501/a"},"text":"Pub. L. 115–182, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-06"},"text":"June 6, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1474"},"text":"132 Stat. 1474","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/251/tII/s211/a/1"},"text":"Pub. L. 115–251, title II, § 211(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-29"},"text":"Sept. 29, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3174"},"text":"132 Stat. 3174","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2932106-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc2932107-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc2932108-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/182/s501/a"},"text":"Section 501(a) of Pub. L. 115–182","children":[],"tail":", which directed that this section be added at the end of this chapter, was executed by adding this section at the end of this subchapter, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc2932109-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/251"},"text":"Pub. L. 115–251","children":[],"tail":" struck out “, United States Code” after “of title 5”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
