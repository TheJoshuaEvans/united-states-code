{"tag":"section","attrib":{"id":"idc34866c5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2410A"},"text":null,"children":[{"tag":"num","attrib":{"value":"2410A"},"text":"§ 2410A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Arlington National Cemetery: other administrative matters","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc34866c6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2410A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"One Gravesite","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc34866c7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2410A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than one gravesite may be provided at Arlington National Cemetery to a veteran or member of the Armed Forces who is eligible for interment or inurnment at such cemetery.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc34866c8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2410A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Army may waive the prohibition in paragraph (1) as the Secretary of the Army considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc34866c9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2410A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition Against Reservation of Gravesites","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc34866ca-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2410A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A gravesite at Arlington National Cemetery may not be reserved for an individual before the death of such individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc34866cb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2410A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc34866cc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2410A/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President may waive the prohibition in paragraph (1) as the President considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc34866cd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2410A/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Upon waiving the prohibition in paragraph (1), the President shall submit notice of such waiver to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc34866ce-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2410A/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Veterans’ Affairs and the Committee on Armed Services of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc34866cf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2410A/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Veterans’ Affairs and the Committee on Armed Services of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc34866d0-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/154/tVI/s602/a"},"text":"Pub. L. 112–154, title VI, § 602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1199"},"text":"126 Stat. 1199","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc34866d1-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc34866d2-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc34866d3-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/154/tVI/s602/c"},"text":"Pub. L. 112–154, title VI, § 602(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1200"},"text":"126 Stat. 1200","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/154/tVI/s602/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2410A"},"text":"section 2410A of title 38","children":[],"tail":", United States Code, as added by subsection (a), shall apply with respect to all interments at Arlington National Cemetery after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (b) of such section, as so added, shall not apply with respect to the interment of an individual for whom a request for a reserved gravesite was approved by the Secretary of the Army before ","children":[{"tag":"date","attrib":{"date":"1962-01-01"},"text":"January 1, 1962","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
