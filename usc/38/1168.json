{"tag":"section","attrib":{"id":"idc2afd047-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1168"},"text":null,"children":[{"tag":"num","attrib":{"value":"1168"},"text":"§ 1168.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical nexus examinations for toxic exposure risk activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2afd048-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1168/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Medical Examinations and Medical Opinions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2afd049-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1168/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subsection (b), if a veteran submits to the Secretary a claim for compensation for a service-connected disability under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1110"},"text":"section 1110 of this title","children":[],"tail":" with evidence of a disability and evidence of participation in a toxic exposure risk activity during active military, naval, air, or space service, and such evidence is not sufficient to establish a service connection for the disability, the Secretary shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2afd04a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1168/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the veteran with a medical examination under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5103A/d"},"text":"section 5103A(d) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2afd04b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1168/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain a medical opinion (to be requested by the Secretary in connection with the medical examination under subparagraph (A)) as to whether it is at least as likely as not that there is a nexus between the disability and the toxic exposure risk activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2afd04c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1168/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When providing the Secretary with a medical opinion under paragraph (1)(B) for a veteran, the health care provider shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2afd04d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1168/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total potential exposure through all applicable military deployments of the veteran; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2afd04e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1168/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the synergistic, combined effect of all toxic exposure risk activities of the veteran.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2afd04f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1168/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The requirement under paragraph (2)(B) shall not be construed as requiring a health care provider to consider the synergistic, combined effect of each of the substances, chemicals, and airborne hazards identified in the list under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1119/b/2"},"text":"section 1119(b)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2afd050-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1168/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) shall not apply if the Secretary determines there is no indication of an association between the disability claimed by the veteran and the toxic exposure risk activity for which the veteran submitted evidence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2afd051-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1168/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Toxic Exposure Risk Activity Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “toxic exposure risk activity” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1710/e/4"},"text":"section 1710(e)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2afd052-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/168/tIII/s303"},"text":"Pub. L. 117–168, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-10"},"text":"Aug. 10, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1779"},"text":"136 Stat. 1779","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
