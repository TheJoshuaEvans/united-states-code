{"tag":"section","attrib":{"id":"idc3d9d1c5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5501A"},"text":null,"children":[{"tag":"num","attrib":{"value":"5501A"},"text":"§ 5501A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Beneficiaries’ rights in mental competence determinations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make an adverse determination concerning the mental capacity of a beneficiary to manage monetary benefits paid to or for the beneficiary by the Secretary under this title unless such beneficiary has been provided all of the following, subject to the procedures and timelines prescribed by the Secretary for determinations of incompetency:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3dc41c6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5501A/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notice of the proposed adverse determination and the supporting evidence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3dc41c7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5501A/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An opportunity to request a hearing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3dc41c8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5501A/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An opportunity to present evidence, including an opinion from a medical professional or other person, on the capacity of the beneficiary to manage monetary benefits paid to or for the beneficiary by the Secretary under this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3dc41c9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5501A/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An opportunity to be represented at no expense to the Government (including by counsel) at any such hearing and to bring a medical professional or other person to provide relevant testimony at any such hearing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3dc41ca-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tXIV/s14017/a"},"text":"Pub. L. 114–255, div. B, title XIV, § 14017(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1307"},"text":"130 Stat. 1307","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3dc41cb-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3dc41cc-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3dc41cd-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tXIV/s14017/c"},"text":"Pub. L. 114–255, div. B, title XIV, § 14017(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1307"},"text":"130 Stat. 1307","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/255/dB/tXIV/s14017/c"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5501A"},"text":"Section 5501A of title 38","children":[],"tail":", United States Code, as added by subsection (a), shall apply to determinations made by the Secretary of Veterans Affairs on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
