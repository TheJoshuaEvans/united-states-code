{"tag":"section","attrib":{"id":"idc3bad80b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104A"},"text":null,"children":[{"tag":"num","attrib":{"value":"4104A"},"text":"§ 4104A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaborative veterans’ training, mentoring, and placement program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3bad80c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall award grants to eligible nonprofit organizations to provide training and mentoring for eligible veterans who seek employment. The Secretary shall award the grants to not more than three organizations, for periods of two years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3bad80d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Collaboration and Facilitation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that the recipients of the grants—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3bad80e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" collaborate with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3bad80f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104A/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate disabled veterans’ outreach specialists (in carrying out the functions described in section 4103A(a)) and the appropriate local veterans’ employment representatives (in carrying out the functions described in section 4104); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bad810-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104A/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate State boards and local boards (as such terms are defined in section 3 of the Workforce Innovation and Opportunity Act) for the areas to be served by recipients of the grants; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3bad811-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" based on the collaboration, facilitate the placement of the veterans that complete the training in meaningful employment that leads to economic self-sufficiency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3bad812-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under this section, a nonprofit organization shall submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary may require. At a minimum, the information shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3bad813-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104A/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" information describing how the organization will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3bad814-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104A/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborate with disabled veterans’ outreach specialists and local veterans’ employment representatives and the appropriate State boards and local boards (as such terms are defined in section 3 of the Workforce Innovation and Opportunity Act);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bad815-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104A/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" based on the collaboration, provide training that facilitates the placement described in subsection (b)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bad816-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104A/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available, for each veteran receiving the training, a mentor to provide career advice to the veteran and assist the veteran in preparing a resume and developing job interviewing skills; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3bad817-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104A/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that the organization will provide the information necessary for the Secretary to prepare the reports described in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3bad818-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3bad819-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104A/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than six months after the date of the enactment of the VOW to Hire Heroes Act of 2011, the Secretary shall prepare and submit to the appropriate committees of Congress a report that describes the process for awarding grants under this section, the recipients of the grants, and the collaboration described in subsections (b) and (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3bad81a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104A/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than 18 months after the date of enactment of the VOW to Hire Heroes Act of 2011, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3bad81b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104A/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct an assessment of the performance of the grant recipients, disabled veterans’ outreach specialists, and local veterans’ employment representatives in carrying out activities under this section, which assessment shall include collecting information on the number of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc3bad81c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104A/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" veterans who applied for training under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3bad81d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104A/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" veterans who entered the training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3bad81e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104A/d/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" veterans who completed the training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3bad81f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104A/d/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" veterans who were placed in meaningful employment under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3bad820-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104A/d/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" veterans who remained in such employment as of the date of the assessment; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bad821-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104A/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit to the appropriate committees of Congress a report that includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc3bad822-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104A/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the grant recipients used the funds made available under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3bad823-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104A/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of the assessment conducted under subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3bad824-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104A/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recommendations of the Secretary as to whether amounts should be appropriated to carry out this section for fiscal years after 2013.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3bad825-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated to carry out this section $4,500,000 for the period consisting of fiscal years 2012 and 2013.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3bad826-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104A/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3bad827-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104A/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “appropriate committees of Congress” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3bad828-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104A/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Veterans’ Affairs and the Committee on Health, Education, Labor, and Pension of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bad829-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104A/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Veterans’ Affairs and the Committee on Education and Workforce ","children":[{"tag":"ref","attrib":{"idref":"fn002092"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002092"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by “the”."}],"tail":" of the House of Representatives; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3bad82a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104A/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “nonprofit organization” means an organization that is described in section 501(c)(3) of the Internal Revenue Code of 1986 and that is exempt from taxation under section 501(a) of such Code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3bad82b-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/56/tII/s234/a"},"text":"Pub. L. 112–56, title II, § 234(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-11-21"},"text":"Nov. 21, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/721"},"text":"125 Stat. 721","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tV/s512/gg/3"},"text":"Pub. L. 113–128, title V, § 512(gg)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1719"},"text":"128 Stat. 1719","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3bad82c-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3bad82d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc3bad82e-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 3 of the Workforce Innovation and Opportunity Act, referred to in subsecs. (b)(1)(B) and (c)(1)(A), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3102"},"text":"section 3102 of Title 29","children":[],"tail":", Labor."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of enactment of the VOW to Hire Heroes Act of 2011, referred to in subsec. (d), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/56"},"text":"Pub. L. 112–56","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2011-11-21"},"text":"Nov. 21, 2011","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 501 of the Internal Revenue Code of 1986, referred to in subsec. (f)(2), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501"},"text":"section 501 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc3bad82f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4104A, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323/s4/a/1"},"text":"Pub. L. 100–323, § 4(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/562"},"text":"102 Stat. 562","children":[],"tail":", § 2004A; renumbered § 4104A and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":", related to performance of disabled veterans’ outreach program specialists and local veterans’ employment representatives, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/107/288/s4/a/3/A/i"},"text":"Pub. L. 107–288, § 4(a)(3)(A)(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-07"},"text":"Nov. 7, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2042"},"text":"116 Stat. 2042","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2002-11-07"},"text":"Nov. 7, 2002","children":[],"tail":", and applicable for program and fiscal years under this chapter beginning on or after such date."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3bad830-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsecs. (b)(1)(B), (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":" substituted “the appropriate State boards and local boards (as such terms are defined in section 3 of the Workforce Innovation and Opportunity Act)” for “the appropriate State boards and local boards (as such terms are defined in section 101 of the Workforce Investment Act of 1998 ("},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2801"},"text":"29 U.S.C. 2801","children":[],"tail":"))”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3bad831-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3bad832-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":" effective on the first day of the first full program year after "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2015-07-01"},"text":"July 1, 2015","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/s506"},"text":"section 506 of Pub. L. 113–128","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of Title 29","children":[],"tail":", Labor."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
