{"tag":"section","attrib":{"id":"idc4026833-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7363"},"text":null,"children":[{"tag":"num","attrib":{"value":"7363"},"text":"§ 7363.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of directors; executive director","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc4026834-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7363/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall provide for the appointment of a board of directors for any corporation established under this subchapter. The board shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4026835-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7363/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to the Department medical center—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc4026836-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7363/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc4026837-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7363/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the director (or directors of each Department medical center, in the case of a multi-medical center research corporation);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc4026838-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7363/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the chief of staff; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc4026839-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7363/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as appropriate for the activities of such corporation, the associate chief of staff for research and the associate chief of staff for education; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc402683a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7363/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a Department medical center at which one or more of the positions referred to in subparagraph (A) do not exist, the official or officials who are responsible for carrying out the responsibilities of such position or positions at the Department medical center; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc402683b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7363/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to subsection (c), not less than two members who are not officers or employees of the Federal Government and who have backgrounds, or business, legal, financial, medical, or scientific expertise, of benefit to the operations of the corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc402683c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7363/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each such corporation shall have an executive director who shall be appointed by the board of directors with the concurrence of the Under Secretary for Health of the Department. The executive director of a corporation shall be responsible for the operations of the corporation and shall have such specific duties and responsibilities as the board may prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc402683d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7363/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual appointed under subsection (a)(2) to the board of directors of a corporation established under this subchapter may not be affiliated with or employed by any entity that is a source of funding for research or education by the Department unless that source of funding is a governmental entity or an entity the income of which is exempt from taxation under the Internal Revenue Code of 1986.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc402683e-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/322/tII/s204/a"},"text":"Pub. L. 100–322, title II, § 204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/510"},"text":"102 Stat. 510","children":[],"tail":", § 4163; renumbered § 7363 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV"},"text":"Pub. L. 102–40, title IV","children":[],"tail":", §§ 401(a)(4)(B), 403(a)(1), (2), (4), "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/221"},"text":"105 Stat. 221","children":[],"tail":", 239; "},{"tag":"ref","attrib":{"href":"/us/pl/102/405/tIII/s302/c/1"},"text":"Pub. L. 102–405, title III, § 302(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-09"},"text":"Oct. 9, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1984"},"text":"106 Stat. 1984","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/262/tIII/s343/b"},"text":"Pub. L. 104–262, title III, § 343(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3207"},"text":"110 Stat. 3207","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/117/tII/s204/c"},"text":"Pub. L. 106–117, title II, § 204(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-30"},"text":"Nov. 30, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1562"},"text":"113 Stat. 1562","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/163/tVIII/s803"},"text":"Pub. L. 111–163, title VIII, § 803","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-05-05"},"text":"May 5, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1177"},"text":"124 Stat. 1177","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc402683f-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc4026840-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc4026841-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Internal Revenue Code of 1986, referred to in subsec. (c), is classified generally to Title 26, Internal Revenue Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc4026842-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163/s803/a"},"text":"Pub. L. 111–163, § 803(a)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “the director of the medical center, the chief of staff of the medical center, and as appropriate, the assistant chief of staff for research for the medical center and the assistant chief of staff for education for the medical center, or, in the case of a facility at which such positions do not exist, those officials who are responsible for carrying out the responsibilities of the medical center director, chief of staff, and, as appropriate, the assistant chief of staff for research and the assistant chief of staff for education; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163/s803/b"},"text":"Pub. L. 111–163, § 803(b)","children":[],"tail":", inserted “not less than two” before “members who are not” and substituted “and who have backgrounds, or business, legal, financial, medical, or scientific expertise, of benefit to the operations of the corporation.” for “and who are familiar with issues involving medical and scientific research or education, as appropriate.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163/s803/c"},"text":"Pub. L. 111–163, § 803(c)","children":[],"tail":", substituted “or employed by” for “, employed by, or have any other financial relationship with”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117/s204/c/1"},"text":"Pub. L. 106–117, § 204(c)(1)","children":[],"tail":", substituted “as appropriate, the assistant chief of staff for research for the medical center and the assistant chief of staff for education for the medical center, or, in the case of a facility at which such positions do not exist, those officials who are responsible for carrying out the responsibilities of the medical center director, chief of staff, and, as appropriate, the assistant chief of staff for research and the assistant chief of staff for education; and” for “the assistant chief of staff for research of the medical center; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117/s204/c/2"},"text":"Pub. L. 106–117, § 204(c)(2)","children":[],"tail":", inserted “or education, as appropriate” after “research”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117/s204/c/3"},"text":"Pub. L. 106–117, § 204(c)(3)","children":[],"tail":", inserted “or education” after “research”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/262"},"text":"Pub. L. 104–262","children":[],"tail":" struck out “section 501(c)(3) of” before “the Internal Revenue Code of 1986”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/405"},"text":"Pub. L. 102–405","children":[],"tail":" substituted “Under Secretary for Health” for “Chief Medical Director”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s401/a/4/B"},"text":"Pub. L. 102–40, § 401(a)(4)(B)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4163"},"text":"section 4163 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s403/a/1"},"text":"Pub. L. 102–40, § 403(a)(1)","children":[],"tail":", substituted “Secretary” for “Administrator” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s403/a/4"},"text":"Pub. L. 102–40, § 403(a)(4)","children":[],"tail":", struck out “of this section” after “subsection (c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s403/a/2"},"text":"Pub. L. 102–40, § 403(a)(2)","children":[],"tail":", substituted “Department” for “Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s403/a/4"},"text":"Pub. L. 102–40, § 403(a)(4)","children":[],"tail":", struck out “of this section” after “subsection (a)(2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s403/a/2"},"text":"Pub. L. 102–40, § 403(a)(2)","children":[],"tail":", substituted “Department” for “Veterans’ Administration”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
