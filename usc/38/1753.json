{"tag":"section","attrib":{"id":"idc30f2e54-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1753"},"text":null,"children":[{"tag":"num","attrib":{"value":"1753"},"text":"§ 1753.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary participation; confidentiality","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc30f2e55-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1753/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The participation by any person in any program or portion thereof under this subchapter shall be wholly voluntary and shall not be a prerequisite to eligibility for or receipt of any other service or assistance from, or to participation in, any other program under this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc30f2e56-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1753/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Patient records prepared or obtained under this subchapter shall be held confidential in the same manner and under the same conditions prescribed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7332"},"text":"section 7332 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc30f2e57-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/82/tI/s109/a"},"text":"Pub. L. 93–82, title I, § 109(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-08-02"},"text":"Aug. 2, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/187"},"text":"87 Stat. 187","children":[],"tail":", § 653; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/581/tI/s111/b"},"text":"Pub. L. 94–581, title I, § 111(b)","children":[],"t