{"tag":"section","attrib":{"id":"idc3d515e3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5122"},"text":null,"children":[{"tag":"num","attrib":{"value":"5122"},"text":"§ 5122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cancellation of checks mailed to deceased payees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A check received by a payee in payment of accrued benefits shall, if the payee died on or after the last day of the period covered by the check, be returned to the issuing office and canceled, unless negotiated by the payee or the duly appointed representative of the payee’s estate. The amount represented by such check, or any amount recovered by reason of improper negotiation of any such check, shall be payable in the manner provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5121"},"text":"section 5121 of this title","children":[],"tail":", without regard to "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5121/c"},"text":"section 5121(c) of this title","children":[],"tail":". Any amount not paid in the manner provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5121"},"text":"section 5121 of this title","children":[],"tail":" shall be paid to the estate of the deceased payee unless the estate will escheat."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc3d515e4-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1229"},"text":"72 Stat. 1229","children":[],"tail":", § 3022; "},{"tag":"ref","attrib":{"href":"/us/pl/99/576/tVII/s701/67"},"text":"Pub. L. 99–576, title VII, § 701(67)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3296"},"text":"100 Stat. 3296","children":[],"tail":"; renumbered § 5122 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", (d)(1), "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":", 239; "},{"tag":"ref","attrib":{"href":"/us/pl/104/316/tII/s202/t"},"text":"Pub. L. 104–316, title II, § 202(t)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3845"},"text":"110 Stat. 3845","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3d515e5-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3d515e6-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3d515e7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/316"},"text":"Pub. L. 104–316","children":[],"tail":" in last sentence struck out “upon settlement by the General Accounting Office” after “shall be paid”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3022"},"text":"section 3022 of this title","children":[],"tail":" as this section and substituted “5121” for “3021” in two places and “5121(c)” for “3021(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576"},"text":"Pub. L. 99–576","children":[],"tail":" substituted “the payee’s” for “his” in first sentence."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
