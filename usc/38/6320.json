{"tag":"section","attrib":{"id":"idc3e82938-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6320"},"text":null,"children":[{"tag":"num","attrib":{"value":"6320"},"text":"§ 6320.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solid Start program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3e82939-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6320/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out a program, to be known as the “Solid Start program”, under which the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3e8293a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6320/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" build the capacity of the Department to efficiently and effectively respond to the queries and needs of veterans who have recently separated from the Armed Forces; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e8293b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6320/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" systemically integrate and coordinate efforts to assist veterans, including efforts—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3e8293c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6320/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to proactively reach out to newly separated veterans to inform them of their eligibility for programs of and benefits provided by the Department, including how to enroll in the system of annual patient enrollment established and operated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1705"},"text":"section 1705 of this title","children":[],"tail":" and the ability to seek care and services under sections 1703 and 1710 of this title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3e8293d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6320/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to connect veterans in crisis to resources that address their immediate needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3e8293e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6320/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Activities of the Solid Start Program","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3e8293f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6320/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary, in coordination with the Secretary of Defense, shall carry out the Solid Start program of the Department by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3e82940-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6320/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collecting up-to-date contact information during transition classes or separation counseling for all members of the Armed Forces who are separating from the Armed Forces, while explaining the existence and purpose of the Solid Start program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3e82941-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6320/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" calling each veteran, regardless of separation type or characterization of service, three times within the first year after separation of the veteran from the Armed Forces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3e82942-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6320/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing information about the Solid Start program on the website of the Department and in materials of the Department, especially transition booklets and other resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3e82943-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6320/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring calls are truly tailored to the needs of each veteran’s unique situation by conducting quality assurance tests;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3e82944-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6320/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prioritizing outreach to veterans who have accessed mental health resources prior to separation from the Armed Forces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3e82945-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6320/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing women veterans with information that is tailored to their specific health care and benefit needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3e82946-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6320/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as feasible, providing information on access to State and local resources, including Vet Centers and veterans service organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3e82947-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6320/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gathering and analyzing data assessing the effectiveness of the Solid Start program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e82948-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6320/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary, in coordination with the Secretary of Defense, may carry out the Solid Start program by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3e82949-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6320/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging members of the Armed Forces who are transitioning to civilian life to authorize alternate points of contact who can be reached should the member be unavailable during the first year following the separation of the member from the Armed Forces; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3e8294a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6320/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" following up missed phone calls with tailored mailings to ensure the veteran still receives similar information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e8294b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6320/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3e8294c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6320/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Vet Center” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1712A/h"},"text":"section 1712A(h) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3e8294d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6320/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “veterans service organization” means an organization recognized by the Secretary for the representation of veterans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5902"},"text":"section 5902 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3e8294e-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/205/s2/a"},"text":"Pub. L. 117–205, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-10-17"},"text":"Oct. 17, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2232"},"text":"136 Stat. 2232","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/210/tI/s102/b"},"text":"Pub. L. 118–210, title I, § 102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-02"},"text":"Jan. 2, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2710"},"text":"138 Stat. 2710","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3e8294f-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3e82950-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3e82951-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/210"},"text":"Pub. L. 118–210","children":[],"tail":" inserted “, including how to enroll in the system of annual patient enrollment established and operated under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1705"},"text":"section 1705 of this title","children":[],"tail":" and the ability to seek care and services under sections 1703 and 1710 of this title” before “; and”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
