{"tag":"section","attrib":{"id":"idc417eb7a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7672"},"text":null,"children":[{"tag":"num","attrib":{"value":"7672"},"text":"§ 7672.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility; agreement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc417eb7b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7672/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To be eligible to participate in the Program, an individual must be an eligible Department employee who is accepted for enrollment or enrolled (as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7602"},"text":"section 7602 of this title","children":[],"tail":") as a full-time or part-time student in a field of education or training described in subsection (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc417eb7c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7672/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Department Employees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of subsection (a), an eligible Department employee is any employee of the Department who, as of the date on which the employee submits an application for participation in the Program, has been continuously employed by the Department for not less than one year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc417eb7d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7672/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualifying Fields of Education or Training","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A scholarship may be awarded under the Program only for education and training in a field leading to appointment or retention in a position under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401"},"text":"section 7401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc417eb7e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7672/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Award of Scholarships","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7603/d"},"text":"section 7603(d) of this title","children":[],"tail":", the Secretary, in selecting participants in the Program, may award a scholarship only to applicants who have a record of employment with the Veterans Health Administration which, in the judgment of the Secretary, demonstrates a high likelihood that the applicant will be successful in completing such education or training and in employment in such field."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc417eb7f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7672/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreement","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc417eb80-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7672/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An agreement between the Secretary and a participant in the Program shall (in addition to the requirements set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7604"},"text":"section 7604 of this title","children":[],"tail":") include the following:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc417eb81-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7672/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary’s agreement to provide the participant with a scholarship under the Program for a specified number (from one to three) of school years during which the participant pursues a course of education or training described in subsection (c) that meets the requirements set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7602/a"},"text":"section 7602(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc417eb82-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7672/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The participant’s agreement to serve as a full-time employee in the Veterans Health Administration for a period of time (hereinafter in this subchapter referred to as the “period of obligated service”) determined in accordance with regulations prescribed by the Secretary of up to three calendar years for each school year or part thereof for which the participant was provided a scholarship under the Program, but for not less than 3 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc417eb83-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7672/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The participant’s agreement to serve under subparagraph (B) in a Department facility selected by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc417eb84-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7672/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In a case in which an extension is granted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7673/c/2"},"text":"section 7673(c)(2) of this title","children":[],"tail":", the number of years for which a scholarship may be provided under the Program shall be the number of school years provided for as a result of the extension."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc417eb85-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7672/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a participant who is a part-time student, the period of obligated service shall be reduced in accordance with the proportion that the number of credit hours carried by such participant in any such school year bears to the number of credit hours required to be carried by a full-time student in the course of training being pursued by the participant, but in no event to less than 1 year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc417eb86-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/tVIII/s802/a"},"text":"Pub. L. 105–368, title VIII, § 802(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3352"},"text":"112 Stat. 3352","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/14/s8/a/16"},"text":"Pub. L. 107–14, § 8(a)(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-06-05"},"text":"June 5, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/35"},"text":"115 Stat. 35","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/135/tI/s101/b"},"text":"Pub. L. 107–135, title I, § 101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-23"},"text":"Jan. 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2447"},"text":"115 Stat. 2447","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc417eb87-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc417eb88-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc417eb89-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/135"},"text":"Pub. L. 107–135","children":[],"tail":" substituted “one year” for “2 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (e)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/14"},"text":"Pub. L. 107–14","children":[],"tail":" substituted “hereinafter” for “hereafter”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
