{"tag":"section","attrib":{"id":"idc41a356f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7701"},"text":null,"children":[{"tag":"num","attrib":{"value":"7701"},"text":"§ 7701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organization of the Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc41a3570-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7701/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is in the Department of Veterans Affairs a Veterans Benefits Administration. The primary function of the Veterans Benefits Administration is the administration of nonmedical benefits programs of the Department which provide assistance to veterans and their dependents and survivors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc41a3571-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7701/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Veterans Benefits Administration is under the Under Secretary for Benefits, who is directly responsible to the Secretary for the operations of the Administration. The Under Secretary for Benefits may be referred to as the Chief Benefits Director.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc41a3572-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s2/b"},"text":"Pub. L. 102–83, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/399"},"text":"105 Stat. 399","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/405/tIII/s302/c/1"},"text":"Pub. L. 102–405, title III, § 302(c)(1)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"1992-10-09"},"text":"Oct. 9, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1984"},"text":"106 Stat. 1984","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc41a3573-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc41a3574-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc41a3575-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/405"},"text":"Pub. L. 102–405","children":[],"tail":" substituted “Under Secretary for Benefits” for “Chief Benefits Director” and inserted at end “The Under Secretary for Benefits may be referred to as the Chief Benefits Director.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
