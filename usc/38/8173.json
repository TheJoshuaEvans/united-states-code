{"tag":"section","attrib":{"id":"idc4347477-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8173"},"text":null,"children":[{"tag":"num","attrib":{"value":"8173"},"text":"§ 8173.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information technology activities of the Financial Services Center","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc4347478-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8173/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Management","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Consistent with sections 11302 and 11319 of title 40—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4347479-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8173/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Chief Information Officer of the Department shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc434747a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8173/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exercise authority over the management, governance, and oversight processes relating to existing or proposed information technology of the Financial Services Center of the Department, or such successor office; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc434747b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8173/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supervise the information technology employees and contractors of the Financial Services Center; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc434747c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8173/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Financial Services Center of the Department, or the head of such successor office, may not enter into a contract or other agreement for information technology or information technology services unless the contract or other agreement has been reviewed and approved by the Chief Information Officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc434747d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8173/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Oversight","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chief Information Officer shall have oversight and operational authority over all information security practices of the Financial Services Center of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc434747e-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dU/tIV/s403/a"},"text":"Pub. L. 117–328, div. U, title IV, § 403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5488"},"text":"136 Stat. 5488","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc434747f-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc4347480-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc4347481-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dU/tIV/s403/d"},"text":"Pub. L. 117–328, div. U, title IV, § 403(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5490"},"text":"136 Stat. 5490","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dU/tIV/s403/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Section 8173 of such title, as added by subsection (a), shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a)(2) of such section shall apply with respect to contracts and agreements entered into on or after the date of the enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
