{"tag":"section","attrib":{"id":"idc34866b8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2410"},"text":null,"children":[{"tag":"num","attrib":{"value":"2410"},"text":"§ 2410.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Burial of cremated remains in Arlington National Cemetery","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc34866b9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2410/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Army shall designate an area of appropriate size within Arlington National Cemetery for the unmarked interment, in accordance with such regulations as the Secretary may prescribe, of the ashes of persons eligible for interment in Arlington National Cemetery whose remains were cremated. Such area shall be an area not suitable for the burial of casketed remains.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc34866ba-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2410/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of each military department shall make available appropriate forms on which those members of the Armed Forces who so desire may indicate their desire to be buried within the area to be designated under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc34866bb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2410/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc34866bc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2410/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Army shall ensure that, under such regulations as the Secretary may prescribe, the cremated remains of any person described in paragraph (2) are eligible for above ground inurnment in Arlington National Cemetery with military honors in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1491"},"text":"section 1491 of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc34866bd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2410/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person described in this paragraph is a person whose service has been determined to be active duty service pursuant to section 401 of the GI Bill Improvement Act of 1977 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/202"},"text":"Public Law 95–202","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s106"},"text":"38 U.S.C. 106","children":[],"tail":" note) as of the date of the enactment of this paragraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc34866be-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237/tV/s502/a"},"text":"Pub. L. 101–237, title V, § 502(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2093"},"text":"103 Stat. 2093","children":[],"tail":", § 1010; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/54/s14/b/22"},"text":"Pub. L. 102–54, § 14(b)(22)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-06-13"},"text":"June 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/284"},"text":"105 Stat. 284","children":[],"tail":"; renumbered § 2410, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/158/s1/a"},"text":"Pub. L. 114–158, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-05-20"},"text":"May 20, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/394"},"text":"130 Stat. 394","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc34866bf-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc34866c0-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc34866c1-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this paragraph, referred to in subsec. (c)(2), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/158"},"text":"Pub. L. 114–158","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2016-05-20"},"text":"May 20, 2016","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc34866c2-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/158"},"text":"Pub. L. 114–158","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1010"},"text":"section 1010 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/54"},"text":"Pub. L. 102–54","children":[],"tail":" substituted “each military department” for “the military departments”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc34866c3-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc34866c4-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/158/s1/b"},"text":"Pub. L. 114–158, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-05-20"},"text":"May 20, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/394"},"text":"130 Stat. 394","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/158/s1/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amendment made by subsection (a) [amending this section] shall apply with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the remains of a person that are not formally interred or inurned as of the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2016-05-20"},"text":"May 20, 2016","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person who dies on or after the date of the enactment of this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Formally interred or inurned defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subsection, the term ‘formally interred or inurned’ means interred or inurned in a cemetery, crypt, mausoleum, columbarium, niche, or other similar formal location.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
