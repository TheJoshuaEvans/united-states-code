{"tag":"section","attrib":{"id":"idc369d162-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3316"},"text":null,"children":[{"tag":"num","attrib":{"value":"3316"},"text":"§ 3316.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplemental educational assistance: members with critical skills or specialty; members serving additional service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc369d163-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3316/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Increased Assistance for Members With Critical Skills or Specialty.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc369d164-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3316/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of an individual who has a skill or specialty designated by the Secretary concerned as a skill or specialty in which there is a critical shortage of personnel or for which it is difficult to recruit or, in the case of critical units, retain personnel, the Secretary concerned may increase the monthly amount of educational assistance otherwise payable to the individual under paragraph (1)(B) of section 3313(c), or under paragraphs (2) through (6) of such section (as applicable).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc369d165-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3316/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum amount of increase in assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of the increase in educational assistance authorized by paragraph (1) may not exceed the amount equal to the monthly amount of increased basic educational assistance providable under section 3015(d)(1) at the time of the increase under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc369d166-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3316/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Supplemental Assistance for Additional Service.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc369d167-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3316/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned may provide for the payment to an individual entitled to educational assistance under this chapter of supplemental educational assistance for additional service authorized by subchapter III of chapter 30. The amount so payable shall be payable as an increase in the monthly amount of educational assistance otherwise payable to the individual under paragraph (1)(B) of section 3313(c), or under paragraphs (2) through (6) of such section (as applicable).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc369d168-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3316/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Eligibility for supplemental educational assistance under this subsection shall be determined in accordance with the provisions of subchapter III of chapter 30, except that any reference in such provisions to eligibility for basic educational assistance under a provision of subchapter II of chapter 30 shall be treated as a reference to eligibility for educational assistance under the appropriate provision of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc369d169-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3316/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of supplemental educational assistance payable under this subsection shall be the amount equal to the monthly amount of supplemental educational assistance payable under section 3022.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc369d16a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3316/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continuation of Increased Educational Assistance.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc369d16b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3316/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual who made an election to receive educational assistance under this chapter pursuant to section 5003(c)(1)(A) of the Post-9/11 Veterans Educational Assistance Act of 2008 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3301"},"text":"38 U.S.C. 3301","children":[],"tail":" note) and who, at the time of the election, was entitled to increased educational assistance under section 3015(d) or "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s16131/i"},"text":"section 16131(i) of title 10","children":[],"tail":" shall remain entitled to increased educational assistance in the utilization of the individual’s entitlement to educational assistance under this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc369d16c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3316/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rate","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The monthly rate of increased educational assistance payable to an individual under paragraph (1) shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc369d16d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3316/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate of educational assistance otherwise payable to the individual under section 3015(d) or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s16131/i"},"text":"section 16131(i) of title 10","children":[],"tail":", as the case may be, had the individual not made the election described in paragraph (1), multiplied by"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc369d16e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3316/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the lesser of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc369d16f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3316/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1.0; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc369d170-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3316/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of course hours borne by the individual in pursuit of the program of education involved divided by the minimum number of course hours required for full-time pursuit of the program of education, rounded to the nearest multiple of 10.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc369d171-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3316/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Frequency of payment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Payment of the amounts payable under paragraph (1) during pursuit of a program of education shall be made on a monthly basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc369d172-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3316/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Payments for increased educational assistance under this section shall be made from the Department of Defense Education Benefits Fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2006"},"text":"section 2006 of title 10","children":[],"tail":" or from appropriations available to the Department of Homeland Security for that purpose, as applicable."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc369d173-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3316/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretaries concerned shall administer this section in accordance with such regulations as the Secretary of Defense shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc369d174-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/252/tV/s5003/a/1"},"text":"Pub. L. 110–252, title V, § 5003(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-30"},"text":"June 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2367"},"text":"122 Stat. 2367","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/275/tX/s1001/g/4"},"text":"Pub. L. 111–275, title X, § 1001(g)(4)","children":[],"tail":", (5), "},{"tag":"date","attrib":{"date":"2010-10-13"},"text":"Oct. 13, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2896"},"text":"124 Stat. 2896","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/377/tI/s109/a"},"text":"Pub. L. 111–377, title I, § 109(a)","children":[],"tail":"–(b)(1), "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4119"},"text":"124 Stat. 4119","children":[],"tail":", 4120; "},{"tag":"ref","attrib":{"href":"/us/pl/115/48/tI/s105/c/3"},"text":"Pub. L. 115–48, title I, § 105(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-16"},"text":"Aug. 16, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/976"},"text":"131 Stat. 976","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc369d175-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc369d176-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc369d177-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 5003(c)(1)(A) of the Post-9/11 Veterans Educational Assistance Act of 2008, referred to in subsec. (c)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/252/s5003/c/1/A"},"text":"section 5003(c)(1)(A) of Pub. L. 110–252","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3301"},"text":"section 3301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc369d178-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsecs. (a)(1), (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/48"},"text":"Pub. L. 115–48","children":[],"tail":" substituted “paragraphs (2) through (6)” for “paragraphs (2) through (7)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/377/s109/a/2"},"text":"Pub. L. 111–377, § 109(a)(2)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/377/s109/b/1"},"text":"Pub. L. 111–377, § 109(b)(1)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/377/s109/a/1"},"text":"Pub. L. 111–377, § 109(a)(1)","children":[],"tail":", redesignated subsec. (c) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/275/s1001/g/4"},"text":"Pub. L. 111–275, § 1001(g)(4)","children":[],"tail":", substituted “supplemental” for “supplement”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/275/s1001/g/5"},"text":"Pub. L. 111–275, § 1001(g)(5)","children":[],"tail":", substituted “educational assistance payable under section 3022” for “educational payable under section 3022”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc369d179-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc369d17a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/48"},"text":"Pub. L. 115–48","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2020-08-01"},"text":"Aug. 1, 2020","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/48/s105/d"},"text":"section 105(d) of Pub. L. 115–48","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3311"},"text":"section 3311 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc369d17b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/377"},"text":"Pub. L. 111–377","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2011-08-01"},"text":"Aug. 1, 2011","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/377/s109/c"},"text":"section 109(c) of Pub. L. 111–377","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2006"},"text":"section 2006 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc369d17c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2009-08-01"},"text":"Aug. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/252/s5003/d"},"text":"section 5003(d) of Pub. L. 110–252","children":[],"tail":", set out as an Effective Date of 2008 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s16163"},"text":"section 16163 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
