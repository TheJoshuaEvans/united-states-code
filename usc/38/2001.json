{"tag":"section","attrib":{"id":"idc32e2854-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2001"},"text":null,"children":[{"tag":"num","attrib":{"value":"2001"},"text":"§ 2001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The purpose of this chapter is to provide for the special needs of homeless veterans.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc32e2855-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/95/s5/a/1"},"text":"Pub. L. 107–95, § 5(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-21"},"text":"Dec. 21, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/905"},"text":"115 Stat. 905","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc32e2856-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc32e2857-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc32e2858-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2001 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4101"},"text":"section 4101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 2001, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1217"},"text":"72 Stat. 1217","children":[],"tail":", related to compensation for veterans under agreements with States, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/87/675/s1/a"},"text":"section 1(a) of Pub. L. 87–675","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc32e2859-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc32e285a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authorization for Secretary of Veterans Affairs To Use Certain Funds for Improved Flexibility in Assistance to Homeless Veterans","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/210/tIV/s403"},"text":"Pub. L. 118–210, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-02"},"text":"Jan. 2, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2796"},"text":"138 Stat. 2796","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/210/tIV/s403"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the period beginning on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2025-01-02"},"text":"Jan. 2, 2025","children":[],"tail":"] and ending on the termination date specified in subsection (d), the Secretary of Veterans Affairs may provide to a covered veteran, as the Secretary determines necessary—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" food, shelter, clothing, blankets, and hygiene items required for the safety and survival of the veteran;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transportation required to support the stability and health of the veteran for appointments with service providers, the conduct of housing and employment searches, and the obtainment of food and supplies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tablets, smartphones, disposable phones and other technology, and related service plans required to support the stability and health of the veteran through the maintenance of contact with service providers, prospective landlords, and family members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Homeless Veterans on Department of Veterans Affairs Land.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may collaborate, to the extent practicable, with one or more organizations to manage the use of land of the Department of Veterans Affairs for homeless veterans for living and sleeping.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Forms of collaboration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Collaboration under paragraph (1) may include the provision by either the Secretary or the head of the organization concerned of food services and security for property, buildings, and other facilities owned or controlled by the Department of Veterans Affairs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than six months after the date of the enactment of this Act, and annually thereafter until the date specified in subsection (d), the Secretary shall submit to Congress a report that includes, with respect to the period covered by such report—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a statement, disaggregated by each medical center of the Department of Veterans Affairs, of the amount of funds under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each such medical center requested from the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to which the Secretary provided each such medical center;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data, disaggregated by each such medical center, relating to how each such medical center used amounts provided by the Secretary under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of covered veterans to which the Secretary provided assistance under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount of assistance the Secretary provided to covered veterans pursuant to subsection (a)(3) for communications equipment, broken down by the type of equipment provided;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount of assistance the Secretary provided covered veterans pursuant to subsection (a)(2) for ridesharing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of covered veterans who received such assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description, for each rideshare used by a covered veteran with such assistance, of the reasons such covered veteran used such rideshare.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"“(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of covered veterans who lived or slept on Department land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"“(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of funds used to make available Department land for covered veterans to live and sleep;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"“(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of Department employees whose primary responsibilities involved providing services for covered veterans living or sleeping on Department land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"“(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average length of time a covered veteran lived or slept on Department land, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"“(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period of time the Secretary expects Department land will be made available for covered veterans to live and sleep.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The termination date specified in this subsection is ","children":[{"tag":"date","attrib":{"date":"2027-09-30"},"text":"September 30, 2027","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term ‘covered veteran’ means—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a homeless veteran, as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2002"},"text":"section 2002 of title 38","children":[],"tail":", United States Code; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a veteran participating in the program carried out under section 8(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(19) of the United States Housing Act of 1937 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f"},"text":"42 U.S.C. 1437f","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(19)).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc32e285b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Annual Reports","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dH/tXCI/s9103/c"},"text":"Pub. L. 116–283, div. H, title XCI, § 9103(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4781"},"text":"134 Stat. 4781","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/283/dH/tXCI/s9103/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not less frequently than once each year, the Secretary of Veterans Affairs shall submit to the Committee on Veterans’ Affairs of the Senate and the Committee on Veterans’ Affairs of the House of Representatives a report on the homelessness services provided under programs of the Department of Veterans Affairs, including services under HUD–VASH program under section 8","children":[{"tag":"i","attrib":{},"text":"(o)","children":[],"tail":"(19) of the United States Housing Act of 1937 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f"},"text":"42 U.S.C. 1437f","children":[],"tail":null},{"tag":"i","attrib":{},"text":"(o)","children":[],"tail":"(19))."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Included information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each such annual report shall include, with respect to the year preceding the submittal of the report, a statement of the number of eligible individuals who were furnished such homelessness services and the number of individuals furnished such services under each such program, disaggregated by the number of men who received such services and the number of women who received such services, and such other information as the Secretary considers appropriate.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc32e285c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"National Goal To End Homelessness Among Veterans","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461/tVII/s701"},"text":"Pub. L. 109–461, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3439"},"text":"120 Stat. 3439","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/461/tVII/s701"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reaffirmation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Congress reaffirms the national goal to end chronic homelessness among veterans within a decade of the enactment of the Homeless Veterans Comprehensive Assistance Act of 2001 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/95"},"text":"Public Law 107–95","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/115/903"},"text":"115 Stat. 903","children":[],"tail":") ["},{"tag":"date","attrib":{"date":"2001-12-21"},"text":"Dec. 21, 2001","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reaffirmation of Encouragement of Cooperative Efforts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Congress reaffirms its encouragement, as specified in the Homeless Veterans Comprehensive Assistance Act of 2001 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/95"},"text":"Public Law 107–95","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/115/903"},"text":"115 Stat. 903","children":[],"tail":"), that all departments and agencies of the Federal, State, and local governments, quasi-governmental organizations, private and public sector entities, including community-based organizations, faith-based organizations, and individuals, work cooperatively to end chronic homelessness among veterans.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/95/s3"},"text":"Pub. L. 107–95, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-21"},"text":"Dec. 21, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/903"},"text":"115 Stat. 903","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/95/s3"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National Goal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Congress hereby declares it to be a national goal to end chronic homelessness among veterans within a decade of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2001-12-21"},"text":"Dec. 21, 2001","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperative Efforts Encouraged","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Congress hereby encourages all departments and agencies of Federal, State, and local governments, quasi-governmental organizations, private and public sector entities, including community-based organizations, faith-based organizations, and individuals to work cooperatively to end chronic homelessness among veterans within a decade.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc32e285d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Sense of the Congress Regarding the Needs of Homeless Veterans and the Responsibility of Federal Agencies","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/95/s4"},"text":"Pub. L. 107–95, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-21"},"text":"Dec. 21, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/904"},"text":"115 Stat. 904","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/95/s4"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“It is the sense of the Congress that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" homelessness is a significant problem in the veterans community and veterans are disproportionately represented among homeless men;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while many effective programs assist homeless veterans to again become productive and self-sufficient members of society, current resources provided to such programs and other activities that assist homeless veterans are inadequate to provide all needed essential services, assistance, and support to homeless veterans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the most effective programs for the assistance of homeless veterans should be identified and expanded;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" federally funded programs for homeless veterans should be held accountable for achieving clearly defined results;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal efforts to assist homeless veterans should include prevention of homelessness; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal agencies, particularly the Department of Veterans Affairs, the Department of Housing and Urban Development, and the Department of Labor, should cooperate more fully to address the problem of homelessness among veterans.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc32e285e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Evaluation Centers for Homeless Veterans Programs","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/95/s6/a"},"text":"Pub. L. 107–95, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-21"},"text":"Dec. 21, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/919"},"text":"115 Stat. 919","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/95/s6/a"},"text":"“The Secretary of Veterans Affairs shall support the continuation within the Department of Veterans Affairs of at least one center for evaluation to monitor the structure, process, and outcome of programs of the Department of Veterans Affairs that address homeless veterans.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idc32e285f-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/95"},"text":"Pub. L. 107–95","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/95/s2"},"text":"Pub. L. 107–95, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-21"},"text":"Dec. 21, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/903"},"text":"115 Stat. 903","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/95/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“For purposes of this Act [see Short Title of 2001 Amendments note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of this title","children":[],"tail":"]:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘homeless veteran’ has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2002"},"text":"section 2002 of title 38","children":[],"tail":", United States Code, as added by section 5(a)(1)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘grant and per diem provider’ means an entity in receipt of a grant under section 2011 or 2012 of title 38, United States Code, as so added.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
