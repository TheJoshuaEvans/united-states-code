{"tag":"section","attrib":{"id":"idc2827eea-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s512"},"text":null,"children":[{"tag":"num","attrib":{"value":"512"},"text":"§ 512.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation of authority; assignment of functions and duties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2827eeb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s512/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided by law, the Secretary may assign functions and duties, and delegate, or authorize successive redelegation of, authority to act and to render decisions, with respect to all laws administered by the Department, to such officers and employees as the Secretary may find necessary. Within the limitations of such delegations, redelegations, or assignments, all official acts and decisions of such officers and employees shall have the same force and effect as though performed or rendered by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2827eec-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s512/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There shall be included on the technical and administrative staff of the Secretary such staff officers, experts, inspectors, and assistants (including legal assistants) as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2827eed-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s2/a"},"text":"Pub. L. 102–83, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/389"},"text":"105 Stat. 389","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2827eee-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc2827eef-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc2827ef0-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior section 512 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1512"},"text":"section 1512 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s212"},"text":"section 212 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s2/a"},"text":"Pub. L. 102–83, § 2(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
