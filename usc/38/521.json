{"tag":"section","attrib":{"id":"idc284ef58-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s521"},"text":null,"children":[{"tag":"num","attrib":{"value":"521"},"text":"§ 521.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to certain rehabilitation activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc284ef59-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s521/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may assist any organization named in or approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5902"},"text":"section 5902 of this title","children":[],"tail":" in providing recreational activities which would further the rehabilitation of disabled veterans. Such assistance may be provided only if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc284ef5a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s521/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the activities are available to disabled veterans on a national basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc284ef5b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s521/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a significant percentage of the individuals participating in the activities are eligible for rehabilitative services under chapter 17 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc284ef5c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s521/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may accept from any appropriate source contributions of funds and of other assistance to support the Secretary’s provision of assistance for such activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc284ef5d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s521/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc284ef5e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s521/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to paragraph (2), the Secretary may authorize the use, for purposes approved by the Secretary in connection with the activity involved, of the seal and other official symbols of the Department and the name “Department of Veterans Affairs” by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc284ef5f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s521/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any organization which provides an activity described in subsection (a) with assistance from the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc284ef60-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s521/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any individual or entity from which the Secretary accepts a significant contribution under subsection (b) or an offer of such a contribution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc284ef61-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s521/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The use of such seal or name of any official symbol of the Department in an advertisement may be authorized by the Secretary under this subsection only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc284ef62-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s521/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary has approved the advertisement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc284ef63-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s521/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the advertisement contains a clear statement that no product, project, or commercial line of endeavor referred to in the advertisement is endorsed by the Department of Veterans Affairs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc284ef64-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s2/a"},"text":"Pub. L. 102–83, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/390"},"text":"105 Stat. 390","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc284ef65-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc284ef66-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc284ef67-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior section 521 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1521"},"text":"section 1521 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s216"},"text":"section 216 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s2/a"},"text":"Pub. L. 102–83, § 2(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
