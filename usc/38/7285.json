30 per year” after “by the Court”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/103/s604/c/1"},"text":"Pub. L. 107–103, § 604(c)(1)","children":[],"tail":", substituted “Practice and registration fees” for “Practice fee” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/103/s604/a"},"text":"Pub. L. 107–103, § 604(a)","children":[],"tail":", inserted at end “The Court may also impose a registration fee on persons (other than judges of the Court) participating at judicial conferences convened pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7286"},"text":"section 7286 of this title","children":[],"tail":" or in any other court-sponsored activity.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/103/s604/b"},"text":"Pub. L. 107–103, § 604(b)","children":[],"tail":", substituted “for the following purposes:” and pars. (1) and (2) for “for the purposes of (1) employing independent counsel to pursue disciplinary matters, and (2) defraying administrative costs for the implementation of the standards of proficiency prescribed for practice before the Court.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368"},"text":"Pub. L. 105–368","children":[],"tail":" substituted “Court of Appeals for Veterans Claims” for “Court of Veterans Appeals”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4085"},"text":"section 4085 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3ef55a7-47c4-11f1-bf59-9680b1269b87