{"tag":"section","attrib":{"id":"idc3ef559c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7285"},"text":null,"children":[{"tag":"num","attrib":{"value":"7285"},"text":"§ 7285.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Practice and registration fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3ef559d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7285/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Court of Appeals for Veterans Claims may impose a reasonable periodic registration fee on persons admitted to practice before the Court. The frequency and amount of such fee shall be determined by the Court. The Court may also impose a reasonable registration fee on persons (other than judges of the Court) participating at judicial conferences convened pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7286"},"text":"section 7286 of this title","children":[],"tail":" or in any other court-sponsored activity."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3ef559e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7285/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Amounts received by the Court under subsection (a) of this section shall be available to the Court for the following purposes:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3ef559f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7285/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Conducting investigations and proceedings, including employing independent counsel, to pursue disciplinary matters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ef55a0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7285/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Defraying the expenses of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3ef55a1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7285/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" judicial conferences convened pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7286"},"text":"section 7286 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3ef55a2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7285/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other activities and programs of the Court that are intended to support and foster communication and relationships between the Court and persons practicing before the Court or the study, understanding, public commemoration, or improvement of veterans law or of the work of the Court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3ef55a3-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/687/dA/tIII/s301/a"},"text":"Pub. L. 100–687, div. A, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4119"},"text":"102 Stat. 4119","children":[],"tail":", § 4085; renumbered § 7285, "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children