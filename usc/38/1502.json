,"children":[],"tail":", which related to vocational rehabilitation for blinded veterans, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/89/138/s2/3"},"text":"Pub. L. 89–138, § 2(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-08-26"},"text":"Aug. 26, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/578"},"text":"79 Stat. 578","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc2bbb772-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/233"},"text":"Pub. L. 109–233","children":[],"tail":" substituted “blind, or so nearly blind or significantly disabled as to” for “helpless or blind, or so nearly helpless or blind as to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/103"},"text":"Pub. L. 107–103","children":[],"tail":" substituted “such person is any of the following:” and pars. (1) to (4) for “such a person is unemployable as a result of disability reasonably certain to continue throughout the life of the disabled person, or is suffering from—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) any disability which is sufficient to render it impossible for the average person to follow a substantially gainful occupation, but only if it is reasonably certain that such disability will continue throughout the life of the disabled person; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) any disease or disorder determined by the Secretary to be of such a nature or extent as to justify a determination that persons suffering therefrom are permanently and totally disabled.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s502"},"text":"section 502 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" amended introductory provisions generally. Prior to amendment, introductory provisions read as follows: “For the purposes of this chapter, a person shall be considered to be permanently and totally disabled if such person is sixty-five years of age or older or became unemployable after age 65, or suffering from—”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/432"},"text":"Pub. L. 94–432","children":[],"tail":" inserted “or became unemployable after age 65,” after “or older”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsecs. (a) and (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/169"},"text":"Pub. L. 94–169","children":[],"tail":" substituted “such person” for “he”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/169"},"text":"Pub. L. 94–169","children":[],"tail":" substituted “such veteran’s” for “his” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/77/s102/a"},"text":"Pub. L. 90–77, § 102(a)","children":[],"tail":", provided for consideration of a person sixty-five years of age or older as permanently and totally disabled."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/77/s102/b"},"text":"Pub. L. 90–77, § 102(b)","children":[],"tail":", added cl. (1) and designated existing provisions as cl. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1964—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/664"},"text":"Pub. L. 88–664","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc2bbb773-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc2bbb774-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2001 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/103/tII/s206/b"},"text":"Pub. L. 107–103, title II, § 206(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-27"},"text":"Dec. 27, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/991"},"text":"115 Stat. 991","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/103/tII/s206/b"},"text":"“The amendment made by subsection (a) [amending this section] shall take effect as of ","children":[{"tag":"date","attrib":{"date":"2001-09-17"},"text":"September 17, 2001","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc2bbb775-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/tVIII/s8002/b"},"text":"Pub