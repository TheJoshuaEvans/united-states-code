{"tag":"section","attrib":{"id":"idc2bbb764-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1502"},"text":null,"children":[{"tag":"num","attrib":{"value":"1502"},"text":"§ 1502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations with respect to disability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2bbb765-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purposes of this chapter, a person shall be considered to be permanently and totally disabled if such person is any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2bbb766-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1502/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A patient in a nursing home for long-term care because of disability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2bbb767-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1502/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Disabled, as determined by the Commissioner of Social Security for purposes of any benefits administered by the Commissioner.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2bbb768-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1502/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Unemployable as a result of disability reasonably certain to continue throughout the life of the person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2bbb769-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1502/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Suffering from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2bbb76a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1502/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any disability which is sufficient to render it impossible for the average person to follow a substantially gainful occupation, but only if it is reasonably certain that such disability will continue throughout the life of the person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2bbb76b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1502/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any disease or disorder determined by the Secretary to be of such a nature or extent as to justify a determination that persons suffering therefrom are permanently and totally disabled.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2bbb76c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of this chapter, a person shall be considered to be in need of regular aid and attendance if such person is (1) a patient in a nursing home or (2) blind, or so nearly blind or significantly disabled as to need or require the regular aid and attendance of another person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2bbb76d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of this chapter, the requirement of “permanently housebound” will be considered to have been met when the veteran is substantially confined to such veteran’s house (ward or clinical areas, if institutionalized) or immediate premises due to a disability or disabilities which it is reasonably certain will remain throughout such veteran’s lifetime.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2bbb76e-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1134"},"text":"72 Stat. 1134","children":[],"tail":", § 502; "},{"tag":"ref","attrib":{"href":"/us/pl/88/664/s6/b"},"text":"Pub. L. 88–664, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-10-13"},"text":"Oct. 13, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1095"},"text":"78 Stat. 1095","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/77/tI/s102"},"text":"Pub. L. 90–77, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-08-31"},"text":"Aug. 31, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/178"},"text":"81 Stat. 178","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/169/tI/s106/2"},"text":"Pub. L. 94–169, title I, § 106(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-23"},"text":"Dec. 23, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/1017"},"text":"89 Stat. 1017","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/432/tII/s201"},"text":"Pub. L. 94–432, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":