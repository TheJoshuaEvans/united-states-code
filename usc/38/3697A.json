{"tag":"section","attrib":{"id":"idc39bddcf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3697A"},"text":null,"children":[{"tag":"num","attrib":{"value":"3697A"},"text":"§ 3697A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Educational and vocational counseling","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc39bddd0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3697A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall make available to an individual described in subsection (b) of this section, upon such individual’s request, counseling services, including such educational and vocational counseling and guidance, testing, and other assistance as the Secretary determines necessary to aid the individual in selecting—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc39bddd1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3697A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an educational or training objective and an educational institution or training establishment appropriate for the attainment of such objective; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc39bddd2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3697A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employment objective that would be likely to provide such individual with satisfactory employment opportunities in the light of the individual’s personal circumstances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc39bddd3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3697A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purposes of this section, the term “individual” means an individual who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc39bddd4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3697A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is eligible for educational assistance under chapter 30, 31, 32, or 33 of this title or chapter 106 or 107 of title 10;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc39bddd5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3697A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was discharged or released from active duty under conditions other than dishonorable if not more than one year has elapsed since the date of such last discharge or release from active duty; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc39bddd6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3697A/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is serving on active duty in any State with the Armed Forces and is within 180 days of the estimated date of such individual’s discharge or release from active duty under conditions other than dishonorable, including those who are making a determination of whether to continue as members of the Armed Forces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc39bddd7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3697A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any case in which the Secretary has rated the individual as being incompetent, the counseling services described in subsection (a) of this section shall be required to be provided to the individual before the selection of a program of education or training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc39bddd8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3697A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At such intervals as the Secretary determines necessary, the Secretary shall make available information concerning the need for general education and for trained personnel in the various crafts, trades, and professions. Facilities of other Federal agencies collecting such information shall be utilized to the extent the Secretary determines practicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc39bddd9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3697A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall take appropriate steps (including individual notification where feasible) to acquaint all individuals described in subsection (b) of this section with the availability and advantages of counseling services under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc39bddda-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/16/s2/a"},"text":"Pub. L. 102–16, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-03-22"},"text":"Mar. 22, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/48"},"text":"105 Stat. 48","children":[],"tail":", § 1797A; renumbered § 3697A, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/252/tV/s5003/b/2/B"},"text":"Pub. L. 110–252, title V, § 5003(b)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-30"},"text":"June 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2375"},"text":"122 Stat. 2375","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc39bdddb-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc39bdddc-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc39bdddd-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/252"},"text":"Pub. L. 110–252","children":[],"tail":" substituted “32, or 33” for “or 32”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1797A"},"text":"section 1797A of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc39bddde-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc39bdddf-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/252"},"text":"Pub. L. 110–252","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-08-01"},"text":"Aug. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/252/s5003/d"},"text":"section 5003(d) of Pub. L. 110–252","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s16163"},"text":"section 16163 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc39bdde0-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Department of Veterans Affairs Provision of Information on Articulation Agreements Between Institutions of Higher Learning","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/315/tIV/s415"},"text":"Pub. L. 114–315, title IV, § 415","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1564"},"text":"130 Stat. 1564","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/315/tIV/s415"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Department of Veterans Affairs counselors who provide educational or vocational counseling services pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3697A"},"text":"section 3697A of title 38","children":[],"tail":", United States Code, shall provide to any eligible individual who requests such counseling services information about the articulation agreements of each institution of higher learning in which the individual is interested."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification of Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When the Secretary of Veterans Affairs provides to an individual a certification of eligibility for educational assistance provided by the Department of Veterans Affairs, the Secretary shall also include detailed information on such educational assistance, including information on requesting education counseling services and on articulation agreements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘institution of higher learning’ has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3452/f"},"text":"section 3452(f) of title 38","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘articulation agreement’ has the meaning given such term in section 486A of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329"},"text":"Public Law 89–329","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1093a"},"text":"20 U.S.C. 1093a","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadline for Implementation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Veterans Affairs shall implement this section not later than 90 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
