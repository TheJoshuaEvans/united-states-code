{"tag":"section","attrib":{"id":"idc3544e0e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3018C"},"text":null,"children":[{"tag":"num","attrib":{"value":"3018C"},"text":"§ 3018C.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opportunity for certain VEAP participants to enroll","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3544e0f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3018C/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding any other provision of law, an individual who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3544e10-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3018C/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a participant on ","children":[{"tag":"date","attrib":{"date":"1996-10-09"},"text":"October 9, 1996","children":[],"tail":", in the educational benefits program provided by chapter 32 of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3544e11-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3018C/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is serving on active duty (excluding the periods referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3202/1/C"},"text":"section 3202(1)(C) of this title","children":[],"tail":") on such date;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3544e12-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3018C/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before applying for benefits under this section, has completed the requirements of a secondary school diploma (or equivalency certificate) or has successfully completed (or otherwise received academic credit for) the equivalent of 12 semester hours in a program of education leading to a standard college degree;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3544e13-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3018C/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if discharged or released from active duty after the date on which the individual makes the election described in paragraph (5), is discharged or released therefrom with an honorable discharge; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3544e14-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3018C/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the one-year period beginning on ","children":[{"tag":"date","attrib":{"date":"1996-10-09"},"text":"October 9, 1996","children":[],"tail":", makes an irrevocable election to receive benefits under this section in lieu of benefits under chapter 32 of this title, pursuant to procedures which the Secretary of each military department shall provide in accordance with regulations prescribed by the Secretary of Defense for the purpose of carrying out this section or which the Secretary of Homeland Security shall provide for such purpose with respect to the Coast Guard when it is not operating as a service in the Navy;"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"may elect to become entitled to basic educational assistance under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3544e15-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3018C/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to an individual who makes an election under subsection (a) to become entitled to basic education assistance under this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3544e16-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3018C/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the basic pay of the individual shall be reduced (in a manner determined by the Secretary of Defense) until the total amount by which such basic pay is reduced is $1,200; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3544e17-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3018C/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent that basic pay is not so reduced before the individual’s discharge or release from active duty as specified in subsection (a)(4), the Secretary shall collect from the individual an amount equal to the difference between $1,200 and the total amount of reductions under paragraph (1), which shall be paid into the Treasury of the United States as miscellaneous receipts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3544e18-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3018C/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3544e19-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3018C/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (3), an individual who is enrolled in the educational benefits program provided by chapter 32 of this title and who makes the election described in subsection (a)(5) shall be disenrolled from such chapter 32 program as of the date of such election.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3544e1a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3018C/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For each individual who is disenrolled from such program, the Secretary shall refund—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3544e1b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3018C/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the individual, as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3223/b"},"text":"section 3223(b) of this title","children":[],"tail":" and subject to subsection (b)(2) of this section, the unused contributions made by the individual to the Post-Vietnam Era Veterans Education Account established pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3222/a"},"text":"section 3222(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3544e1c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3018C/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Secretary of Defense the unused contributions (other than contributions made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3222/c"},"text":"section 3222(c) of this title","children":[],"tail":") made by such Secretary to the Account on behalf of such individual."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3544e1d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3018C/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any contribution made by the Secretary of Defense to the Post-Vietnam Era Veterans Education Account pursuant to subsection (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3222"},"text":"section 3222 of this title","children":[],"tail":" on behalf of any individual referred to in paragraph (1) shall remain in such account to make payments of benefits to such individual under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3015/f"},"text":"section 3015(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3544e1e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3018C/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The procedures provided in regulations referred to in subsection (a) shall provide for notice of the requirements of subparagraphs (B), (C), and (D) of section 3011(a)(3) and of subparagraph (A) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3012/a/3"},"text":"section 3012(a)(3) of this title","children":[],"tail":". Receipt of such notice shall be acknowledged in writing."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3544e1f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3018C/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3544e20-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3018C/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A qualified individual (described in paragraph (2)) may make an irrevocable election under this subsection, during the one-year period beginning on the date of the enactment of this subsection, to become entitled to basic educational assistance under this chapter. Such an election shall be made in the same manner as elections made under subsection (a)(5).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3544e21-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3018C/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A qualified individual referred to in paragraph (1) is an individual who meets each of the following requirements:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3544e22-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3018C/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The individual was a participant in the educational benefits program under chapter 32 of this title on or before ","children":[{"tag":"date","attrib":{"date":"1996-10-09"},"text":"October 9, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3544e23-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3018C/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The individual has continuously served on active duty since ","children":[{"tag":"date","attrib":{"date":"1996-10-09"},"text":"October 9, 1996","children":[],"tail":" (excluding the periods referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3202/1/C"},"text":"section 3202(1)(C) of this title","children":[],"tail":"), through at least "},{"tag":"date","attrib":{"date":"2000-04-01"},"text":"April 1, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3544e24-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3018C/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The individual meets the requirements of subsection (a)(3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3544e25-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3018C/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The individual, when discharged or released from active duty, is discharged or released therefrom with an honorable discharge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3544e26-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3018C/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3544e27-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3018C/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to the succeeding provisions of this paragraph, with respect to a qualified individual who makes an election under paragraph (1) to become entitled to basic education assistance under this chapter—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc3544e28-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3018C/e/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the basic pay of the qualified individual shall be reduced (in a manner determined by the Secretary concerned) until the total amount by which such basic pay is reduced is $2,700; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3544e29-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3018C/e/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to the extent that basic pay is not so reduced before the qualified individual’s discharge or release from active duty as specified in subsection (a)(4), at the election of the qualified individual—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc3544e2a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3018C/e/3/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary concerned shall collect from the qualified individual; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc3544e2b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3018C/e/3/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary concerned shall reduce the retired or retainer pay of the qualified individual by,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"an amount equal to the difference between $2,700 and the total amount of reductions under clause (i), which shall be paid into the Treasury of the United States as miscellaneous receipts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3544e2c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3018C/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc3544e2d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3018C/e/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned shall provide for an 18-month period, beginning on the date the qualified individual makes an election under paragraph (1), for the qualified individual to pay that Secretary the amount due under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3544e2e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3018C/e/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in clause (i) shall be construed as modifying the period of eligibility for and entitlement to basic education assistance under this chapter applicable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3031"},"text":"section 3031 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3544e2f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3018C/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of subsection (c) shall apply to qualified individuals making elections under this subsection in the same manner as they applied to individuals making elections under subsection (a)(5).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3544e30-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3018C/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to qualified individuals referred to in paragraph (3)(A)(ii), no amount of educational assistance allowance under this chapter shall be paid to the qualified individual until the earlier of the date on which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3544e31-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3018C/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary concerned collects the applicable amount under subclause (I) of such paragraph; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3544e32-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3018C/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the retired or retainer pay of the qualified individual is first reduced under subclause (II) of such paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3544e33-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3018C/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary, in conjunction with the Secretary of Defense, shall provide for notice to participants in the educational benefits program under chapter 32 of this title of the opportunity under this subsection to elect to become entitled to basic educational assistance under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3544e34-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/275/tI/s106/a"},"text":"Pub. L. 104–275, title I, § 106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3327"},"text":"110 Stat. 3327","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/114/tIV/s401/c"},"text":"Pub. L. 105–114, title IV, § 401(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2293"},"text":"111 Stat. 2293","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/368/tII/s203/a"},"text":"Pub. L. 105–368, title II, § 203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3326"},"text":"112 Stat. 3326","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title XVI, § 1601], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–357; "},{"tag":"ref","attrib":{"href":"/us/pl/106/419/tI/s104/a"},"text":"Pub. L. 106–419, title I, § 104(a)","children":[],"tail":"–(c)(1), "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1827"},"text":"114 Stat. 1827","children":[],"tail":", 1828; "},{"tag":"ref","attrib":{"href":"/us/pl/107/14/s7/e/1"},"text":"Pub. L. 107–14, § 7(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-06-05"},"text":"June 5, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/33"},"text":"115 Stat. 33","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVII/s1704/d"},"text":"Pub. L. 107–296, title XVII, § 1704(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2315"},"text":"116 Stat. 2315","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/330/tIII/s308/g/9"},"text":"Pub. L. 107–330, title III, § 308(g)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-06"},"text":"Dec. 6, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2829"},"text":"116 Stat. 2829","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3544e35-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3544e36-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc3544e37-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this subsection, referred to in subsec. (e)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/419"},"text":"Pub. L. 106–419","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3544e38-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" substituted “of Homeland Security” for “of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/330"},"text":"Pub. L. 107–330","children":[],"tail":" struck out comma after “April”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/14"},"text":"Pub. L. 107–14","children":[],"tail":" struck out “or (e)” after “subsection (a)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/419/s104/c/1"},"text":"Pub. L. 106–419, § 104(c)(1)","childr