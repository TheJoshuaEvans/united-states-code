{"tag":"section","attrib":{"id":"idc2be27f5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1512"},"text":null,"children":[{"tag":"num","attrib":{"value":"1512"},"text":"§ 1512.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Spanish-American War veterans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2be27f6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1512/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2be27f7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1512/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall pay to each veteran of the Spanish-American War who meets the service requirements of this subsection a pension at the following monthly rate:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2be27f8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1512/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $101.59; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2be27f9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1512/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $135.45 if the veteran is in need of regular aid and attendance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2be27fa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1512/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A veteran meets the service requirements of this subsection if such veteran served in the active military or naval service—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2be27fb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1512/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for ninety days or more during the Spanish-American War;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2be27fc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1512/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the Spanish-American War and was discharged or released from such service for a service-connected disability; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2be27fd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1512/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a period of ninety consecutive days or more and such period began or ended during the Spanish-American War.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2be27fe-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1512/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2be27ff-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1512/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any veteran eligible for pension under this subsection shall, if such veteran so elects, be paid pension at the rates prescribed by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1521"},"text":"section 1521 of this title","children":[],"tail":" (except the rate provided under subsection (g) of such section), and under the conditions (other than the service requirements) applicable to pension paid under that section to veterans of a period of war. If pension is paid pursuant to such an election, the election shall be irrevocable."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2be2800-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1512/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall pay each month to each Spanish-American War veteran who is receiving, or entitled to receive, pension based on a need of regular aid and attendance, whichever amount is greater (i) that provided by subparagraph (B) of subsection (a)(1) of this section, or (ii) that which is payable to the veteran under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1521"},"text":"section 1521 of this title","children":[],"tail":" as in effect on "},{"tag":"date","attrib":{"date":"1978-12-31"},"text":"December 31, 1978","children":[],"tail":", under regulations which the Secretary shall prescribe. Each change in the amount of pension payment required by this subparagraph shall be effective as of the first day of the month during which the facts of the particular case warrant such change, and shall be made without specific application therefor."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2be2801-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1512/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2be2802-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1512/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall pay to each veteran of the Spanish-American War who does not meet the service requirements of subsection (a), but who meets the service requirements of this subsection, a pension at the following monthly rate:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2be2803-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1512/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $67.73; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2be2804-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1512/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $88.04 if the veteran is in need of regular aid and attendance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2be2805-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1512/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A veteran meets the service requirements of this subsection if such veteran served in the active military or naval service—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2be2806-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1512/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for seventy days or more during the Spanish-American War; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2be2807-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1512/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a period of seventy consecutive days or more and such period began or ended during the Spanish-American War.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2be2808-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1135"},"text":"72 Stat. 1135","children":[],"tail":", § 512; "},{"tag":"ref","attrib":{"href":"/us/pl/86/670/s2"},"text":"Pub. L. 86–670, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-14"},"text":"July 14, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/545"},"text":"74 Stat. 545","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/77/tI/s111/b"},"text":"Pub. L. 90–77, title I, § 111(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-08-31"},"text":"Aug. 31, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/181"},"text":"81 Stat. 181","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/169/tI/s106/17"},"text":"Pub. L. 94–169, title I, § 106(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-23"},"text":"Dec. 23, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/1017"},"text":"89 Stat. 1017","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/588/tI/s105"},"text":"Pub. L. 95–588, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-04"},"text":"Nov. 4, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2500"},"text":"92 Stat. 2500","children":[],"tail":"; renumbered § 1512 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":", §§ 4(b)(1), (2)(E), 5(a), (c)(1), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404-406"},"text":"105 Stat. 404–406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2be2809-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc2be280a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc2be280b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1512 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3112"},"text":"section 3112 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc2be280c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s512"},"text":"section 512 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “1521” for “521”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “1521” for “521”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (a)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/588/s105/1"},"text":"Pub. L. 95–588, § 105(1)","children":[],"tail":", inserted “(except the rate provided under subsection (g) of such section)” after “of this title”, substituted “a period of war” for “World War I”, and struck out exception to pension elections formerly provided pursuant to subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/588/s105/2"},"text":"Pub. L. 95–588, § 105(2)","children":[],"tail":", substituted “as in effect on "},{"tag":"date","attrib":{"date":"1978-12-31"},"text":"December 31, 1978","children":[],"tail":", under regulations which the Administrator shall prescribe” for “if such veteran has elected, or would be payable if such veteran were to elect, to receive pension under such section pursuant to subparagraph (A) of this paragraph”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/169"},"text":"Pub. L. 94–169","children":[],"tail":" substituted “such veteran” for “he” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/169"},"text":"Pub. L. 94–169","children":[],"tail":" substituted “such veteran” for “he”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/77"},"text":"Pub. L. 90–77","children":[],"tail":" designated existing provisions as subpar. (A), inserted “except as provided in subparagraph (B)”, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/670"},"text":"Pub. L. 86–670","children":[],"tail":" added cl. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc2be280d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc2be280e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/588"},"text":"Pub. L. 95–588","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1979-01-01"},"text":"Jan. 1, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/588/s401"},"text":"section 401 of Pub. L. 95–588","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc2be280f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1975 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/169/tI/s106"},"text":"Pub. L. 94–169, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-23"},"text":"Dec. 23, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/1017"},"text":"89 Stat. 1017","children":[],"tail":", provided that the amendment made by that section is effective "},{"tag":"date","attrib":{"date":"1976-01-01"},"text":"Jan. 1, 1976","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc2be2810-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1967 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/77"},"text":"Pub. L. 90–77","children":[],"tail":" effective first day of first calendar month which begins more than ten days after "},{"tag":"date","attrib":{"date":"1967-08-31"},"text":"Aug. 31, 1967","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/77/s405"},"text":"section 405 of Pub. L. 90–77","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc2be2811-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1960 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/670"},"text":"Pub. L. 86–670","children":[],"tail":" effective first day of second calendar month which begins after "},{"tag":"date","attrib":{"date":"1960-07-14"},"text":"July 14, 1960","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/86/670/s3"},"text":"section 3 of Pub. L. 86–670","children":[],"tail":", set out as a note und