{"tag":"section","attrib":{"id":"idc417ebdb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7682"},"text":null,"children":[{"tag":"num","attrib":{"value":"7682"},"text":"§ 7682.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc417ebdc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7682/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual is eligible to participate in the Education Debt Reduction Program if the individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc417ebdd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7682/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an employee in the Veterans Health Administration serving in a position (as determined by the Secretary) providing direct-patient care services or services incident to direct-patient care services for which recruitment or retention of qualified health-care personnel (as so determined) is difficult; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc417ebde-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7682/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owes any amount of principal or interest under a loan, the proceeds of which were used by or on behalf of that individual to pay costs relating to a course of education or training which led to a degree that qualified the individual for the position referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc417ebdf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7682/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Costs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a)(2), costs relating to a course of education or training include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc417ebe0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7682/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tuition expenses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc417ebe1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7682/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all other reasonable educational expenses, including expenses for fees, books, and laboratory expenses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc417ebe2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7682/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonable living expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc417ebe3-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/tVIII/s803/a"},"text":"Pub. L. 105–368, title VIII, § 803(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3357"},"text":"112 Stat. 3357","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/135/tI/s102/b"},"text":"Pub. L. 107–135, title I, § 102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-23"},"text":"Jan. 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2448"},"text":"115 Stat. 2448","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/163/tIII/s301/b"},"text":"Pub. L. 111–163, title III, § 301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-05-05"},"text":"May 5, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1146"},"text":"124 Stat. 1146","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc417ebe4-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc417ebe5-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc417ebe6-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163/s301/b/1"},"text":"Pub. L. 111–163, § 301(b)(1)","children":[],"tail":", substituted “an” for “a recently appointed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163/s301/b/2"},"text":"Pub. L. 111–163, § 301(b)(2)","children":[],"tail":", struck out subsec. (c). Text read as follows: “For purposes of subsection (a), an individual shall be considered to be recently appointed to a position if the individual has held that position for less than 6 months.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/135"},"text":"Pub. L. 107–135","children":[],"tail":" substituted “in a position (as determined by the Secretary) providing direct-patient care services or services incident to direct-patient care services” for “under an appointment under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7402/b"},"text":"section 7402(b) of this title","children":[],"tail":" in a position” and “(as so determined)” for “(as determined by the Secretary)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc417ebe7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc417ebe8-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Inclusion of Vet Center Employees in Education Debt Reduction Program of Department of Veterans Affairs","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/182/tIII/s306"},"text":"Pub. L. 115–182, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-06"},"text":"June 6, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1470"},"text":"132 Stat. 1470","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/182/tIII/s306"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Veterans Affairs shall ensure that clinical staff working at Vet Centers are eligible to participate in the Education Debt Reduction Program of the Department of Veterans Affairs under subchapter VII of chapter 76 of title 38, United States Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-06-06"},"text":"June 6, 2018","children":[],"tail":"], the Secretary shall submit to the Committee on Veterans’ Affairs of the Senate and the Committee on Veterans’ Affairs of the House of Representatives a report on the number of participants in the Education Debt Reduction Program of the Department under such subchapter who work at Vet Centers."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vet Center Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term ‘Vet Center’ has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1712A/h"},"text":"section 1712A(h) of title 38","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc417ebe9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Temporary Expansion of Individuals Eligible for Participation in Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/135/tI/s102/e"},"text":"Pub. L. 107–135, title I, § 102(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-23"},"text":"Jan. 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2449"},"text":"115 Stat. 2449","children":[],"tail":", granted the Secretary of Veterans Affairs authority to treat certain individuals as recently appointed employees in the Veterans Health Administration under subsec. (a) of this section for purposes of eligibility in the Education Debt Reduction Program under this subchapter but prohibited exercise of this authority after "},{"tag":"date","attrib":{"date":"2002-06-30"},"text":"June 30, 2002","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
