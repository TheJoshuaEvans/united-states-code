5","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/146/s1/a"},"text":"Pub. L. 116–146, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-07-02"},"text":"July 2, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/658"},"text":"134 Stat. 658","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/96/s1/b"},"text":"Pub. L. 117–96, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-14"},"text":"Mar. 14, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/34"},"text":"136 Stat. 34","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dS/tI/s102/b"},"text":"Pub. L. 117–103, div. S, title I, § 102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/822"},"text":"136 Stat. 822","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/168/tIX"},"text":"Pub. L. 117–168, title IX","children":[],"tail":", §§ 904(b), 906(a), "},{"tag":"date","attrib":{"date":"2022-08-10"},"text":"Aug. 10, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1811"},"text":"136 Stat. 1811","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/210/tI/s142/b"},"text":"Pub. L. 118–210, title I, § 142(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-02"},"text":"Jan. 2, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2746"},"text":"138 Stat. 2746","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc4072355-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc4072356-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc4072357-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Level III of the Executive Schedule, referred to in subsec. (a)(3)(B)(i), is set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Level II of the Executive Schedule, referred to in subsec. (a)(3)(B)(ii), is set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc4072358-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/182/tV/s502/b/1"},"text":"Pub. L. 115–182, title V, § 502(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-06"},"text":"June 6, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1475"},"text":"132 Stat. 1475","children":[],"tail":", which directed amendment of “section 7404(b) of such title” without specifying the Code title to be amended, was executed to this section, which is "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7404"},"text":"section 7404 of Title 38","children":[],"tail":", Veterans’ Benefits, to reflect the probable intent of Congress. See 2018 Amendment note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc4072359-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in section 4107(a)–(d) of this title prior to the repeal of that section as part of the complete revision of chapter 73 of this title by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc407235a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/210/s142/b/1"},"text":"Pub. L. 118–210, § 142(b)(1)","children":[],"tail":", substituted “podiatrists, optometrists, and dentists” for “podiatrists, and dentists”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/210/s142/b/2/A"},"text":"Pub. L. 118–210, § 142(b)(2)(A)","children":[],"tail":", (C), substituted “"},{"tag":"inline","attrib":{},"text":"podiatrist (dpm), optometrist (od), and dentist","children":[],"tail":"” for “"},{"tag":"inline","attrib":{},"text":"podiatrist (dpm), and dentist","children":[],"tail":"” in first heading in table and inserted “optometrist grade” after “Podiatrist grade” in second item under that heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/210/s142/b/2/B"},"text":"Pub. L. 118–210, § 142(b)(2)(B)","children":[],"tail":", which directed substitution of “"},{"tag":"inline","attrib":{},"text":"clinical chiropractor schedule","children":[],"tail":"” for “"},{"tag":"inline","attrib":{},"text":"clinical chiropractor and optometrist schedule","children":[],"tail":",” in third heading in table, was executed by making the substitution for “"},{"tag":"inline","attrib":{},"text":"clinical chiropractor and optometrist schedule","children":[],"tail":"”, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/168/s904/b"},"text":"Pub. L. 117–168, § 904(b)","children":[],"tail":", inserted “7306 or” before “7401(4)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s102/b/1"},"text":"Pub. L. 117–103, § 102(b)(1)","children":[],"tail":", designated existing provisions as subpar. (A) and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/96/s1/b/1"},"text":"Pub. L. 117–96, § 1(b)(1)","children":[],"tail":", inserted “, podiatrists,” after “physicians”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/96/s1/b/2"},"text":"Pub. L. 117–96, § 1(b)(2)","children":[],"tail":", substituted “"},{"tag":"inline","attrib":{},"text":"podiatrist (dpm)","children":[],"tail":"” for “"},{"tag":"inline","attrib":{},"text":"podiatrist","children":[],"tail":"” in first heading in table."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/168/s906/a"},"text":"Pub. L. 117–168, § 906(a)","children":[],"tail":", designated existing provisions as par. (1), inserted “or 7401(4)” after “section 7306”, substituted “or in a covered executive position under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401/1"},"text":"section 7401(1) of this title","children":[],"tail":"” for “who is not eligible for pay under subchapter III” and “section 4507” for “sections 4507 and 5384”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s102/b/2"},"text":"Pub. L. 117–103, § 102(b)(2)","children":[],"tail":", inserted “basic pay” after “paid” and substituted “rates established under subchapter IV of this chapter” for “rate established for the Senior Executive Service under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5382"},"text":"section 5382 of title 5","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/146"},"text":"Pub. L. 116–146","children":[],"tail":" inserted “and except for individuals appointed under sections 7401(4) and 7306 of this title,” after “"},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7457"},"text":"section 7457 of this title","children":[],"tail":",”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/12"},"text":"Pub. L. 116–12","children":[],"tail":" substituted “"},{"tag":"inline","attrib":{},"text":"podiatrist","children":[],"tail":"” for “"},{"tag":"inline","attrib":{},"text":"podiatric surgeon (dpm)","children":[],"tail":"” in first heading in table and inserted item relating to Podiatrist grade under that heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/182"},"text":"Pub. L. 115–182","children":[],"tail":" substituted “"},{"tag":"inline","attrib":{},"text":"physician and surgeon (md/do), podiatric surgeon (dpm), and dentist and oral surgeon (dds, dmd) schedule","children":[],"tail":"” for “"},{"tag":"inline","attrib":{},"text":"physician and dentist schedule","children":[],"tail":"” as first heading in table and “Physician and surgeon grade” for “Physician grade” as first item under that heading and substituted “"},{"tag":"inline","attrib":{},"text":"chiropractor, and","children":[],"tail":"” for “"},{"tag":"inline","attrib":{},"text":"podiatrist, chiropractor, and","children":[],"tail":"” in third heading in table. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/41"},"text":"Pub. L. 115–41","children":[],"tail":" designated existing provisions as subpar. (A), inserted “and 7401(4)” after “section 7306”, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163"},"text":"Pub. L. 111–163","children":[],"tail":" designated first sentence as par. (1) and second sentence as par. (2), substituted “under paragraph (1)” for “under the preceding sentence” in par. (2), and added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461/s202/1"},"text":"Pub. L. 109–461, § 202(1)","children":[],"tail":", substituted “subsection (e), subchapter III, and” for “subchapter III and in”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461/s202/2"},"text":"Pub. L. 109–461, § 202(2)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/445/s3/a/2"},"text":"Pub. L. 108–445, § 3(a)(2)","children":[],"tail":", inserted at end “The pay of physicians and dentists serving in positions to which an Executive order applies under the preceding sentence shall be determined under subchapter III of this chapter instead of such Executive order.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/445/s3/a/1"},"text":"Pub. L. 108–445, § 3(a)(1)","children":[],"tail":", struck out “(1)” after “(b)”, inserted items relating to Physician grade and Dentist grade under heading “"},{"tag":"inline","attrib":{},"text":"physician and dentist schedule","children":[],"tail":"” and struck out former items under that heading, which read “Director grade”, “Executive grade”, “Chief grade”, “Senior grade”, “Intermediate grade”, “Full grade”, and “Associate grade”, 