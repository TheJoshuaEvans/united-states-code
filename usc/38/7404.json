,{"tag":"inline","attrib":{},"text":"clinical podiatrist and optometrist schedule","children":[],"tail":"” as third center heading in table."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/585"},"text":"Pub. L. 102–585","children":[],"tail":" inserted items relating to Nurse V through I under heading “"},{"tag":"inline","attrib":{},"text":"nurse schedule","children":[],"tail":"” and struck out former items under that heading, “Director grade”, “Senior grade”, “Intermediate grade”, and “Entry grade”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/405/s206"},"text":"Pub. L. 102–405, § 206","children":[],"tail":", inserted “, or comparable position” before period at end of first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/405/s302/c/1"},"text":"Pub. L. 102–405, § 302(c)(1)","children":[],"tail":", substituted “Under Secretary for Health” for “Chief Medical Director”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc407235b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc407235c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163/tVI/s601/d/2"},"text":"Pub. L. 111–163, title VI, § 601(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-05-05"},"text":"May 5, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/u