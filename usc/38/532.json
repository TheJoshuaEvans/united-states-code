{"tag":"section","attrib":{"id":"idc289aae8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s532"},"text":null,"children":[{"tag":"num","attrib":{"value":"532"},"text":"§ 532.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to advertise in national media; VetStar Award Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc289aae9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s532/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advertising in National Media","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may purchase advertising in national media outlets for the purpose of promoting awareness of benefits under laws administered by the Secretary, including promoting awareness of assistance provided by the Secretary, including assistance for programs to assist homeless veterans, to promote veteran-owned small businesses, and to provide opportunities for employment in the Department of Veterans Affairs and for education, training, compensation, pension, vocational rehabilitation, and healthcare benefits, and mental healthcare (including the prevention of suicide among veterans).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc289aaea-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s532/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"VetStar Award Program","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc289aaeb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s532/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall establish an award program, to be known as the “VetStar Award Program”, to recognize annually businesses for their contributions to veterans’ employment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc289aaec-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s532/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall establish a process for the administration of the award program, including criteria for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc289aaed-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s532/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" categories and sectors of businesses eligible for recognition each year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc289aaee-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s532/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" objective measures to be used in selecting businesses to receive the award.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc289aaef-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/389/tVIII/s809/a"},"text":"Pub. L. 110–389, title VIII, § 809(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4189"},"text":"122 Stat. 4189","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/154/tVII/s709/a"},"text":"Pub. L. 112–154, title VII, § 709(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1207"},"text":"126 Stat. 1207","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc289aaf0-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc289aaf1-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc289aaf2-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/154"},"text":"Pub. L. 112–154","children":[],"tail":" inserted “; VetStar Award Program” after “national media” in section catchline, designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
