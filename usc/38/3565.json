. 103–446","children":[],"tail":" applicable with respect to payments made after "},{"tag":"date","attrib":{"date":"1994-12-31"},"text":"Dec. 31, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/446/s507/c"},"text":"section 507(c) of Pub. L. 103–446","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s107"},"text":"section 107 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"idc37f54e3-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/358/s12/b"},"text":"Pub. L. 89–358, § 12(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-03-03"},"text":"Mar. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/28"},"text":"80 Stat. 28","children":[],"tail":", provided that the provisions of subsec. (b) of this section, relating to payment of reporting allowance at rate of $1 per month, as in effect before "},{"tag":"date","attrib":{"date":"1966-03-03"},"text":"Mar. 3, 1966","children":[],"tail":", were to remain in effect through "},{"tag":"date","attrib":{"date":"1966-05-31"},"text":"May 31, 1966","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
