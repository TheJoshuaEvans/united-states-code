{"tag":"section","attrib":{"id":"idc37f54d7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3565"},"text":null,"children":[{"tag":"num","attrib":{"value":"3565"},"text":"§ 3565.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Children of certain Philippine veterans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc37f54d8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3565/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Basic Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “eligible person” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3501/a/1"},"text":"section 3501(a)(1) of this title","children":[],"tail":" includes the children of those Commonwealth Army veterans and “New” Philippine Scouts who meet the requirements of service-connected disability or death, based on service as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3566"},"text":"section 3566 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc37f54d9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3565/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The provisions of this chapter and chapter 36 shall apply to the educational assistance for children of Commonwealth Army veterans and “New” Philippine Scouts, except that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc37f54da-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3565/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educational assistance allowances authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3532"},"text":"section 3532 of this title","children":[],"tail":" and the special training allowance authorized by "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3542"},"text":"section 3542 of this title","children":[],"tail":" shall be paid at the rate of $0.50 for each dollar, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc37f54db-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3565/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any reference to a State approving agency shall be deemed to refer to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc37f54dc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3565/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delimiting Dates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of any individual who is an eligible person solely by virtue of subsection (a) of this section, and who is above the age of seventeen years and below the age of twenty-three years on ","children":[{"tag":"date","attrib":{"date":"1966-09-30"},"text":"September 30, 1966","children":[],"tail":", the period referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3512"},"text":"section 3512 of this title","children":[],"tail":" shall not end until the expiration of the five-year period which begins on "},{"tag":"date","attrib":{"date":"1966-09-30"},"text":"September 30, 1966","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc37f54dd-47c4-11f1-bf59-968