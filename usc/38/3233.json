{"tag":"section","attrib":{"id":"idc362a5bc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3233"},"text":null,"children":[{"tag":"num","attrib":{"value":"3233"},"text":"§ 3233.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Apprenticeship or other on-job training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc362a5bd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3233/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subsection (b) of this section, the amount of the monthly benefit payment to an individual pursuing a full-time program of apprenticeship or other on-job training under this chapter is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc362a5be-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3233/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each of the first six months of the individual’s pursuit of such program, 75 percent of the monthly benefit payment otherwise payable to such individual under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc362a5bf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3233/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each of the second six months of the individual’s pursuit of such program, 55 percent of such monthly benefit payment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc362a5c0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3233/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each of the months following the first 12 months of the individual’s pursuit of such program, 35 percent of such monthly benefit payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc362a5c1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3233/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any month in which an individual pursuing a program of education consisting of a program of apprenticeship or other on-job training fails to complete 120 hours of training, the amount of the monthly benefit payment payable under this chapter to the individual shall be limited to the same proportion of the applicable rate determined under subsection (a) of this section as the number of hours worked during such month, rounded to the nearest eight hours, bears to 120 hours.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc362a5c2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3233/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For each month that an individual is paid a monthly benefit payment under this chapter, the individual’s entitlement under this chapter shall be charged at the rate of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc362a5c3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3233/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 75 percent of a month in the case of payments made in accordance with subsection (a)(1) of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc362a5c4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3233/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 55 percent of a month in the case of payments made in accordance with subsection (a)(2) of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc362a5c5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3233/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 35 percent of a month in the case of payments made in accordance with subsection (a)(3) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc362a5c6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3233/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For any month in which an individual fails to complete 120 hours of training, the entitlement otherwise chargeable under subsection (c) of this section shall be reduced in the same proportion as the monthly benefit payment payable is reduced under subsection (b) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc362a5c7-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576/tIII/s310/b/2"},"text":"Pub. L. 99–576, title III, § 310(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3271"},"text":"100 Stat. 3271","children":[],"tail":", § 1633; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIV/s423/a/7"},"text":"Pub. L. 101–237, title IV, § 423(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2091"},"text":"103 Stat. 2091","children":[],"tail":"; renumbered § 3233, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc362a5c8-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc362a5c9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc362a5ca-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1633"},"text":"section 1633 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc362a5cb-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc362a5cc-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Increase in Benefit for Individuals Pursuing Apprenticeship or On-Job Training; Post-Vietnam Era Veterans’ Educational Assistance","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/454/tI/s103/b"},"text":"Pub. L. 108–454, title I, § 103(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-10"},"text":"Dec. 10, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3600"},"text":"118 Stat. 3600","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/454/tI/s103/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“For months beginning on or after ","children":[{"tag":"date","attrib":{"date":"2005-10-01"},"text":"October 1, 2005","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"2008-01-01"},"text":"January 1, 2008","children":[],"tail":", subsection (a) of "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3233"},"text":"section 3233 of title 38","children":[],"tail":", United States Code, shall be applied as if—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reference to ‘75 percent’ in paragraph (1) were a reference to ‘85 percent’;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reference to ‘55 percent’ in paragraph (2) were a reference to ‘65 percent’; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reference to ‘35 percent’ in paragraph (3) were a reference to ‘45 percent’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
