{"tag":"section","attrib":{"id":"idc4026826-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7362"},"text":null,"children":[{"tag":"num","attrib":{"value":"7362"},"text":"§ 7362.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of corporations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc4026827-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7362/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A corporation established under this subchapter shall be established to provide a flexible funding mechanism for the conduct of approved research and education at one or more Department medical centers and to facilitate functions related to the conduct of research as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7303/a"},"text":"section 7303(a) of this title","children":[],"tail":" and education and training as described in sections 7302, 7471, 8154, and 1701(6)(B) "},{"tag":"ref","attrib":{"idref":"fn002109"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002109"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title in conjunction with the applicable Department medical center or centers."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4026828-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7362/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this section, the term “education” includes education and training and means the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4026829-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7362/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of employees of the Veterans Health Administration, such term means work-related instruction or other learning experiences to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc402682a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7362/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve performance of current duties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc402682b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7362/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist employees in maintaining or gaining specialized proficiencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc402682c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7362/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expand understanding of advances and changes in patient care, technology, and health care administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc402682d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7362/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of veterans under the care of the Veterans Health Administration, such term means instruction or other learning experiences related to improving and maintaining the health of veterans and includes education and training for patients and families and guardians of patients.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"