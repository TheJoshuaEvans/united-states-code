{"tag":"section","attrib":{"id":"idc337c5ae-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2068"},"text":null,"children":[{"tag":"num","attrib":{"value":"2068"},"text":"§ 2068.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mental health consultations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc337c5af-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2068/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than two weeks after the date on which a veteran described in subsection (b) enters into a program administered by the Homeless Programs Office of the Department, the Secretary shall offer the veteran a mental health consultation to assess the health needs of, and care options for, the veteran.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc337c5b0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2068/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Veteran Described","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A veteran described in this subsection is a veteran to whom a mental health consultation is not offered or provided through the case management services of the program of the Homeless Programs Office into which the veteran enters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc337c5b1-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dV/tIV/s404/b/1"},"text":"Pub. L. 117–328, div. V, title IV, § 404(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5513"},"text":"136 Stat. 5513","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
