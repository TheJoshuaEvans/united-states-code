{"tag":"section","attrib":{"id":"idc3165a17-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1833"},"text":null,"children":[{"tag":"num","attrib":{"value":"1833"},"text":"§ 1833.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of receipt of monetary allowance and other benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3165a18-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1833/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination With Other Benefits Paid to the Recipient","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, receipt by an individual of a monetary allowance under this chapter shall not impair, infringe, or otherwise affect the right of the individual to receive any other benefit to which the individual is otherwise entitled under any law administered by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3165a19-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1833/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination With Benefits Based on Relationship of Recipients","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, receipt by an individual of a monetary allowance under this chapter shall not impair, infringe, or otherwise affect the right of any other individual to receive any benefit to which such other individual is entitled under any law administered by the Secretary based on the relationship of such other individual to the individual who receives such monetary allowance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3165a1a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1833/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Monetary Allowance Not To Be Considered as Income or Resources for Certain Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, a monetary allowance paid an individual under this chapter shall not be considered as income or resources in determining eligibility for, or the amount of benefits under, any Federal or federally assisted program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3165a1b-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/419/tIV/s401/b"},"text":"Pub. L. 106–419, title IV, § 401(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1860"},"text":"114 Stat. 1860","children":[],"tail":", § 1823; renumbered § 1833, "},{"tag":"ref","attrib":{"href":"/us/pl/108/183/tI/s102/a/1"},"text":"Pub. L. 108–183, title I, § 102(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-16"},"text":"Dec. 16, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2653"},"text":"117 Stat. 2653","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3165a1c-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3165a1d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc3165a1e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1833 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3733"},"text":"section 3733 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3165a1f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/183"},"text":"Pub. L. 108–183","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1823"},"text":"section 1823 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
