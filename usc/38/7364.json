{"tag":"section","attrib":{"id":"idc4026843-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7364"},"text":null,"children":[{"tag":"num","attrib":{"value":"7364"},"text":"§ 7364.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General powers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc4026844-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7364/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4026845-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7364/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A corporation established under this subchapter may, solely to carry out the purposes of this subchapter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc4026846-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7364/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept, administer, retain, and spend funds derived from gifts, contributions, grants, fees, reimbursements, and bequests from individuals and public and private entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4026847-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7364/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into contracts and agreements with individuals and public and private entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4026848-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7364/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to paragraph (2), set fees for education and training facilitated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7362"},"text":"section 7362 of this title","children":[],"tail":", and receive, retain, administer, and spend funds in furtherance of such education and training;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4026849-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7364/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reimburse amounts to the applicable appropriation account of the Department for the Office of General Counsel for any expenses of that Office in providing legal services attributable to research and education agreements under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc402684a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7364/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employ such employees as the corporation considers necessary for such purposes and fix the compensation of such employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc402684b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7364/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fees charged pursuant to paragraph (1)(C) for education and training described in that paragraph to individuals who are officers or employees of the Department may not be paid for by any funds appropriated to the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc402684c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7364/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts reimbursed to the Office of General Counsel under paragraph (1)(D) shall be available for use by the Office of the General Counsel only for staff and training, and related travel, for the provision of legal services described in that paragraph and shall remain available for such use without fiscal year limitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc402684d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7364/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer and Administration of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc402684e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7364/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), any funds received by the Secretary for the conduct of research or education at a Department medical center or centers, other than funds appropriated to the Department, may be transferred to and administered by a corporation established under this subchapter for such purposes. Any amounts so transferred after ","children":[{"tag":"date","attrib":{"date":"2016-09-30"},"text":"September 30, 2016","children":[],"tail":", shall be available without regard to fiscal year limitations, notwithstanding "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1535/d"},"text":"section 1535(d) of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc402684f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7364/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Department medical center may reimburse the corporation for all or a portion of the pay, benefits, or both of an employee of the corporation who is assigned to the Department medical center if the assignment is carried out pursuant to subchapter VI of chapter 33 of title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4026850-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7364/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Department medical center may retain and use funds provided to it by a corporation established under this subchapter. Such funds shall be credited to the applicable appropriation account of the Department and shall be available, without fiscal year limitation, for the purposes of that account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4026851-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7364/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Research Projects","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except for reasonable and usual preliminary costs for project planning before its approval, a corporation established under this subchapter may not spend funds for a research project unless the project is approved in accordance with procedures prescribed by the Under Secretary for Health for research carried out with Department funds. Such procedures shall include a scientific review process.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4026852-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7364/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Education Activities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except for reasonable and usual preliminary costs for activity planning before its approval, a corporation established under this subchapter may not spend funds for an education activity unless the activity is approved in accordance with procedures prescribed by the Under Secretary for Health.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4026853-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7364/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Policies and Procedures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Under Secretary for Health may prescribe policies and procedures to guide the spending of funds by corporations established under this subchapter that are consistent with the purpose of such corporations as flexible funding mechanisms and with Federal and State laws and regulations, and executive orders, circulars, and directives that apply generally to the receipt and expenditure of funds by nonprofit organizations exempt from taxation under section 501(c)(3) of the Internal Revenue Code of 1986.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc4026854-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/322/tII/s204/a"},"text":"Pub. L. 100–322, title II, § 204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/511"},"text":"102 Stat. 511","children":[],"tail":", § 4164; renumbered § 7364 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV"},"text":"Pub. L. 102–40, title IV","children":[],"tail":", §§ 401(a)(4)(B), 403(a)(2), "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/221"},"text":"105 Stat. 221","children":[],"tail":", 239; "},{"tag":"ref","attrib":{"href":"/us/pl/102/405/tIII/s302/c/1"},"text":"Pub. L. 102–405, title III, § 302(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-09"},"text":"Oct. 9, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1984"},"text":"106 Stat. 1984","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/117/tII/s204/d"},"text":"Pub. L. 106–117, title II, § 204(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-30"},"text":"Nov. 30, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1562"},"text":"113 Stat. 1562","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/163/tVIII/s804/a"},"text":"Pub. L. 111–163, title VIII, § 804(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-05-05"},"text":"May 5, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1177"},"text":"124 Stat. 1177","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/315/tVII/s7006"},"text":"Pub. L. 116–315, title VII, § 7006","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/5059"},"text":"134 Stat. 5059","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc4026855-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc4026856-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc4026857-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 501(c)(3) of the Internal Revenue Code of 1986, referred to in subsec. (e), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc4026858-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315"},"text":"Pub. L. 116–315","children":[],"tail":" inserted “Any amounts so transferred after "},{"tag":"date","attrib":{"date":"2016-09-30"},"text":"September 30, 2016","children":[],"tail":", shall be available without regard to fiscal year limitations, notwithstanding "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1535/d"},"text":"section 1535(d) of title 31","children":[],"tail":".” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163"},"text":"Pub. L. 111–163","children":[],"tail":" amended section generally. Prior to amendment, section related to the general powers of a corporation established under this subchapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117"},"text":"Pub. L. 106–117","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/405"},"text":"Pub. L. 102–405","children":[],"tail":" substituted “Under Secretary for Health” for “Chief Medical Director”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s401/a/4/B"},"text":"Pub. L. 102–40, § 401(a)(4)(B)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4164"},"text":"section 4164 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s403/a/2"},"text":"Pub. L. 102–40, § 403(a)(2)","children":[],"tail":", substituted “Department” for “Veterans’ Administration”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
