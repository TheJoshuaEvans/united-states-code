{"tag":"section","attrib":{"id":"idc3bd48c8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110A"},"text":null,"children":[{"tag":"num","attrib":{"value":"4110A"},"text":"§ 4110A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special unemployment study","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3bd48c9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3bd48ca-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary, through the Bureau of Labor Statistics, shall conduct an annual study of unemployment among each of the following categories of veterans:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3bd48cb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110A/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Veterans who were called to active duty while members of the National Guard or a Reserve Component.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bd48cc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110A/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Veterans who served in combat or in a war zone in the Post 9/11 Global Operations theaters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bd48cd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110A/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Veterans who served on active duty during the Post 9/11 Global Operations period who did not serve in the Post 9/11 Global Operations theaters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bd48ce-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110A/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Veterans of the Vietnam era who served in the Vietnam theater of operations during the Vietnam era.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bd48cf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110A/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Veterans who served on active duty during the Vietnam era who did not serve in the Vietnam theater of operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bd48d0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110A/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Veterans discharged or released from active duty within four years of the applicable study.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bd48d1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110A/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Special disabled veterans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3bd48d2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Within each of the categories of veterans specified in paragraph (1), the Secretary shall include a separate category for women who are veterans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3bd48d3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall promptly submit to Congress a report on the results of each study under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3bd48d4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3bd48d5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110A/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Post 9/11 Global Operations period” means the period of the Persian Gulf War beginning on ","children":[{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":", and ending on the date thereafter prescribed by Presidential proclamation or law."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3bd48d6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110A/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Post 9/11 Global Operations theaters” means Afghanistan, Iraq, or any other theater in which the Global War on Terrorism Expeditionary Medal is awarded for service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3bd48d7-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323/s9/a"},"text":"Pub. L. 100–323, § 9(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/566"},"text":"102 Stat. 566","children":[],"tail":", § 2010A; renumbered § 4110A, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/446/tVII/s701/c"},"text":"Pub. L. 103–446, title VII, § 701(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4674"},"text":"108 Stat. 4674","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/368/tX/s1005/b/14"},"text":"Pub. L. 105–368, title X, § 1005(b)(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3365"},"text":"112 Stat. 3365","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/389/tIII/s317"},"text":"Pub. L. 110–389, title III, § 317","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4167"},"text":"122 Stat. 4167","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3bf92c8-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3bf92c9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3bf92ca-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/389/s317/a"},"text":"Pub. L. 110–389, § 317(a)","children":[],"tail":", substituted “an annual study” for “a study every two years” in introductory provisions, added subpars. (A) to (G), and struck out former subpars. (A) to (E) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) Special disabled veterans.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) Veterans of the Vietnam era who served in the Vietnam theater of operations during the Vietnam era.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) Veterans who served on active duty during the Vietnam era who did not serve in the Vietnam theater of operations.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) Veterans who served on active duty after the Vietnam era.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(E) Veterans discharged or released from active duty within four years of the applicable study.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/389/s317/b"},"text":"Pub. L. 110–389, § 317(b)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/s1005/b/14/B"},"text":"Pub. L. 105–368, § 1005(b)(14)(B)","children":[],"tail":", redesignated par. (3) as subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368"},"text":"Pub. L. 105–368","children":[],"tail":" redesignated subsec. (a)(3) as (b), substituted “subsection (a)” for “paragraph (1)”, and struck out former subsec. (b) which read as follows: “The first study under this section shall be completed not later than 180 days after the date of the enactment of this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446"},"text":"Pub. L. 103–446","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “The Secretary, through the Bureau of Labor Statistics, shall conduct, on a biennial basis, studies of unemployment among special disabled veterans and among veterans who served in the Vietnam Theater of Operations during the Vietnam era and promptly report to the Congress on the results of such studies.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2010A"},"text":"section 2010A of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3bf92cb-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3bf92cc-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on 60th day after ","children":[{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/323/s16/b/2"},"text":"section 16(b)(2) of Pub. L. 100–323","children":[],"tail":", set out as an Effective Date of 1988 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3104"},"text":"section 3104 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3bf92cd-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of reporting provisions in subsec. (b) of this section, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance, and page 125 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
