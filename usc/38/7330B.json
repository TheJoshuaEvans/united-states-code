{"tag":"section","attrib":{"id":"idc3fff77f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330B"},"text":null,"children":[{"tag":"num","attrib":{"value":"7330B"},"text":"§ 7330B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report on Veterans Health Administration and furnishing of hospital care, medical services, and nursing home care","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3fff780-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than March 1 of each of years 2018 through 2022, the Secretary shall submit to the Committee on Veterans’ Affairs of the Senate and the Committee on Veterans’ Affairs of the House of Representatives a report on, for the calendar year preceding the calendar year during which the report is submitted—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3fff781-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330B/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the furnishing of hospital care, medical services, and nursing home care under the laws administered by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fff782-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330B/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the administration of the furnishing of such care and services by the Veterans Health Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3fff783-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report required by subsection (a) shall include each of the following for the year covered by the report:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3fff784-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330B/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An evaluation of the effectiveness of the Veterans Health Administration in increasing the access of veterans to hospital care, medical services, and nursing home care furnished by the Secretary for which such veterans are eligible.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fff785-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330B/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An evaluation of the effectiveness of the Veterans Health Administration in improving the quality of health care provided to veterans, without increasing the costs incurred for such health care by the Federal Government or veterans, including relevant information for each medical center and Veterans Integrated Service Network of the Department set forth separately.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fff786-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330B/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An assessment of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3fff787-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330B/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the workload of physicians and other employees of the Veterans Health Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fff788-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330B/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" patient demographics and utilization rates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fff789-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330B/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physician compensation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fff78a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330B/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the productivity of physicians and other employees of the Veterans Health Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fff78b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330B/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage of hospital care, medical services, and nursing home care provided to veterans in facilities of the Department and in non-Department facilities and any changes in such percentages compared to the year preceding the year covered by the report;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fff78c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330B/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pharmaceutical prices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fff78d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330B/b/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" third-party health billings owed to the Department, including the total amount of such billings and the total amount collected by the Department, set forth separately for claims greater than $1,000 and for claims equal to or less than $1,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3fff78e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7330B/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the terms “hospital care”, “medical services”, “nursing home care”, “facilities of the Department”, and “non-Department facilities” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1701"},"text":"section 1701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3fff78f-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/315/tVI/s612/a"},"text":"Pub. L. 114–315, title VI, § 612(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1575"},"text":"130 Stat. 1575","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
