{"tag":"section","attrib":{"id":"idc284efa3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s522"},"text":null,"children":[{"tag":"num","attrib":{"value":"522"},"text":"§ 522.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Studies of rehabilitation of disabled persons","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc284efa4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s522/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may conduct studies and investigations, and prepare reports, relative to the rehabilitation of disabled persons, the relative abilities, aptitudes, and capacities of the several groups of the variously handicapped, and how their potentialities can best be developed and their services best used in gainful and suitable employment including the rehabilitation programs of foreign nations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc284efa5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s522/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out this section, the Secretary (1) may cooperate with such public and private agencies as the Secretary considers advisable; and (2) may employ consultants who shall receive a reasonable per diem, as prescribed by the Secretary, for each day actually employed, plus necessary travel and other expenses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc284efa6-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s2/a"},"text":"Pub. L. 102–83, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/390"},"text":"105 Stat. 390","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc284efa7-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc284efa8-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc284efa9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior section 522 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1522"},"text":"section 1522 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s217"},"text":"section 217 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s2/a"},"text":"Pub. L. 102–83, § 2(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
