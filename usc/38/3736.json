{"tag":"section","attrib":{"id":"idc3b16190-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3736"},"text":null,"children":[{"tag":"num","attrib":{"value":"3736"},"text":"§ 3736.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirements","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The annual report required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s529"},"text":"section 529 of this title","children":[],"tail":" shall include a discussion of the activities under this chapter. Beginning with the report submitted at the close of fiscal year 1996, and every second year thereafter, this discussion shall include information regarding the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3b16191-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3736/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Loans made to veterans whose only qualifying service was in the Selected Reserve.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3b16192-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3736/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Interest rates and discount points which were negotiated between the lender and the veteran pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3703/c/4/A/i"},"text":"section 3703(c)(4)(A)(i) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3b16193-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3736/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The determination of reasonable value by lenders pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3731/f"},"text":"section 3731(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3b16194-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3736/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Loans that include funds for energy efficiency improvements pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3710/a/10"},"text":"section 3710(a)(10) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3b16195-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3736/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Direct loans to Native American veterans made pursuant to subchapter V of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3b16196-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/110/tII/s201/a/1"},"text":"Pub. L. 104–110, title II, § 201(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-13"},"text":"Feb. 13, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/770"},"text":"110 Stat. 770","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
