{"tag":"section","attrib":{"id":"idc3e828ca-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6304"},"text":null,"children":[{"tag":"num","attrib":{"value":"6304"},"text":"§ 6304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Veterans assistance offices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3e828cb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall establish and maintain veterans assistance offices at such places throughout the United States and its territories and possessions, and in the Commonwealth of Puerto Rico, as the Secretary determines to be necessary to carry out the purposes of this subchapter. The Secretary may maintain such offices on such military installations located elsewhere as the Secretary, after consultation with the Secretary of Defense and taking into account recommendations, if any, of the Secretary of Labor, determines to be necessary to carry out such purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3e828cc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Location of Offices","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In establishing and maintaining such offices, the Secretary shall give due regard to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3e828cd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6304/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the geographical distribution of veterans recently discharged or released from active military, naval, air, or space service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e828ce-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6304/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the special needs of educationally disadvantaged veterans (including their need for accessibility of outreach services); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e828cf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6304/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the necessity of providing appropriate outreach services in less populated areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3e828d0-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/233/tIV/s402/a"},"text":"Pub. L. 109–233, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-06-15"},"text":"June 15, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/409"},"text":"120 Stat. 409","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s926/a/60"},"text":"Pub. L. 116–283, div. A, title IX, § 926(a)(60)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3830"},"text":"134 Stat. 3830","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/205/s2/b/2"},"text":"Pub. L. 117–205, § 2(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-10-17"},"text":"Oct. 17, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2233"},"text":"136 Stat. 2233","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3e828d1-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3e828d2-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc3e828d3-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7723"},"text":"section 7723 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/109/233"},"text":"Pub. L. 109–233","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3e828d4-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/205"},"text":"Pub. L. 117–205","children":[],"tail":" substituted “this subchapter” for “this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “air, or space service” for “or air service”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
