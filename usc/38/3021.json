{"tag":"section","attrib":{"id":"idc3544e88-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3021"},"text":null,"children":[{"tag":"num","attrib":{"value":"3021"},"text":"§ 3021.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplemental educational assistance for additional service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3544e89-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3021/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary concerned, pursuant to regulations to be prescribed by the Secretary of Defense, may provide for the payment of supplemental educational assistance under this subchapter to any individual eligible for basic educational assistance under section 3011 or 3018 of this title who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3544e8a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3021/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serves five or more consecutive years of active duty in the Armed Forces after the years of active duty counted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3011/a/1"},"text":"section 3011(a)(1) of this title","children":[],"tail":" without a break in such service; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3544e8b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3021/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" after completion of the service described in clause (1) of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3544e8c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3021/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is discharged from service with an honorable discharge, is placed on the retired list, is transferred to the Fleet Reserve or Fleet Marine Corps Reserve, or is placed on the temporary disability retired list;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3544e8d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3021/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continues on active duty without a break in service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3544e8e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3021/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is released from active duty for further service in a reserve component of the Armed Forces after service on active duty characterized by the Secretary concerned as honorable service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3544e8f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3021/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary concerned, pursuant to regulations to be prescribed by the Secretary of Defense, may provide for the payment of supplemental educational assistance under this subchapter to any individual eligible for basic educational assistance under section 3012 or 3018 of this title who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3544e90-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3021/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serves two or more consecutive years of active duty in the Armed Forces after the years of active duty counted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3012/a/1"},"text":"section 3012(a)(1) of this title","children":[],"tail":" and four or more consecutive years of duty in the Selected Reserve after the years of duty in the Selected Reserve counted under such section without a break in service; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3544e91-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3021/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" after completion of the service described in clause (1) of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3544e92-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3021/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is discharged from service with an honorable discharge, is placed on the retired list, is transferred to the Fleet Reserve or Fleet Marine Corps Reserve, or is placed on the temporary disability retired list; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3544e93-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3021/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continues on active duty or in the Selected Reserve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3544e94-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3021/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Continuity of service of a member in the Selected Reserve for purposes of subsection (b)(1) of this section shall not be considered to be broken—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3544e95-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3021/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by any period of time (not to exceed a maximum period prescribed by the Secretary concerned by regulation) during which the member is not able to locate a unit of the Selected Reserve of the member’s Armed Force that the member is eligible to join or that has a vacancy; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3544e96-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3021/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by any other period of time (not to exceed a maximum period prescribed by the Secretary concerned by regulation) during which the member is not attached to a unit of the Selected Reserve that the Secretary concerned, pursuant to regulations, considers to be inappropriate to consider for such purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3544e97-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3021/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A period of active duty or duty in the Selected Reserve that occurs before the period of duty by which the individual concerned qualifies for basic educational assistance may not be counted for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3544e98-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/tVII/s702/a/1"