s","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc3544e9b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior section 3021 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5121"},"text":"section 5121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3544e9c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1421"},"text":"section 1421 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “3011 or 3018” for “1411 or 1418” in introductory provisions and “3011(a)(1)” for “1411(a)(1)” in par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “3012 or 3018” for “1412 or 1418” in introductory provisions and “3012(a)(1)” for “1412(a)(1)” in par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" inserted “of Defense” after second reference to “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/689"},"text":"Pub. L. 100–689","children":[],"tail":" inserted reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1418"},"text":"section 1418 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576/s321/5"},"text":"Pub. L. 99–576, § 321(5)","children":[],"tail":", substituted “after” for “in addition to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576/s321/5"},"text":"Pub. L. 99–576, § 321(5)","children":[],"tail":", substituted “after” for “in addition to” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576/s321/6"},"text":"Pub. L. 99–576, § 321(6)","children":[],"tail":", substituted “the member’s” for “his”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3544e9d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3544e9e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/tVII/s702/b"},"text":"Pub. L. 98–525, title VII, § 702(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2563"},"text":"98 Stat. 2563","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/525/tVII/s702/b"},"text":"“Subchapter III of chapter 30 of title 38, United States Code, as added by subsection (a), shall take effect on ","children":[{"