secs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" substituted “Secretary” for “Administrator” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295/s4/43/A"},"text":"Pub. L. 97–295, § 4(43)(A)","children":[],"tail":", inserted “of this title” after “section 1671”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295/s4/43/B"},"text":"Pub. L. 97–295, § 4(43)(B)","children":[],"tail":", inserted “of this title” after “section 1682(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/306"},"text":"Pub. L. 97–306","children":[],"tail":" substituted “section 1673(d)(1)” for “section 1673(d)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466/s311/1"},"text":"Pub. L. 96–466, § 311(1)","children":[],"tail":", in provisions preceding par. (1) struck out “not on active duty” after “eligible veteran”, in par. (1) struck out “at the time of the veteran’s discharge or release from active duty” after “(or an equivalency certificate)”, and in par. (2) inserted “is not on active duty and who,” before “in order to pursue”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466/s311/2"},"text":"Pub. L. 96–466, § 311(2)","children":[],"tail":", designated existing provisions as par. (1), substituted reference to subsec. (a)(2) of this section for reference to subsec. (a) of this section, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466/s311/3"},"text":"Pub. L. 96–466, § 311(3)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/502"},"text":"Pub. L. 94–502","children":[],"tail":" substituted “the veteran’s” for “his” and “the veteran” for “he” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/540"},"text":"Pub. L. 92–540","children":[],"tail":" struck out provision relating to the approval in excess of half-time training as defined pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1684"},"text":"section 1684 of this title","children":[],"tail":" of enrollment in adult evening secondary school courses."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc375b80a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc375b80b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466"},"text":"Pub. L. 96–466","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-10-01"},"text":"Oct. 1, 1980","children":[],"tail":", except that subsec. (b)(2) of this section, as added by "},{"tag":"ref","attrib":{"href":"/us/pl/96/466/s311/2/C"},"text":"section 311(2)(C) of Pub. L. 96–466","children":[],"tail":", not applicable to any person receiving educational assistance under this chapter on "},{"tag":"date","attrib":{"date":"1980-10-01"},"text":"Oct. 1, 1980","children":[],"tail":", for the pursuit of a program of education in which such person is enrolled on that date, for as long as such person continuously thereafter is so enrolled and meets the requirements of eligibility for such assistance for pursuit of such program, see "},{"tag":"ref","attrib":{"href":"/us/pl/96/466/s802/c"},"text":"section 802(c) of Pub. L. 96–466","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3452"},"text":"section 3452 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc375b80c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/502"},"text":"Pub. L. 94–502","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1976-10-15"},"text":"Oct. 15, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/502/s703/b"},"text":"section 703(b) of Pub. L. 94–502","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3693"},"text":"section 3693 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
