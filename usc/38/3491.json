{"tag":"section","attrib":{"id":"idc375b7fd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3491"},"text":null,"children":[{"tag":"num","attrib":{"value":"3491"},"text":"§ 3491.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elementary and secondary education and preparatory educational assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc375b7fe-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3491/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of any eligible veteran who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc375b7ff-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3491/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not received a secondary school diploma (or an equivalency certificate), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc375b800-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3491/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not on active duty and who, in order to pursue a program of education for which the veteran would otherwise be eligible, needs refresher courses, deficiency courses, or other preparatory or special educational assistance to qualify for admission to an appropriate educational institution,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Secretary may, without regard to so much of the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3471"},"text":"section 3471 of this title","children":[],"tail":" as prohibit the enrollment of an eligible veteran in a program of education in which the veteran is “already qualified”, approve the enrollment of such veteran in an appropriate course or courses or other special educational assistance program."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc375b801-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3491/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc375b802-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3491/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall pay to an eligible veteran pursuing a course or courses or program pursuant to subsection (a)(2) of this section, an educational assistance allowance as provided in sections 3481 and 3482(a) or (b) of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc375b803-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3491/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall pay to an eligible veteran described in subsection (a)(1) of this section who is pursuing a course or courses or program under this subchapter for the purpose of attaining a secondary school diploma (or an equivalency certificate) an educational assistance allowance (A) at the rate of established charges for tuition and fees required of similarly circumstanced nonveterans enrolled in the same course, courses, or program, or (B) at the institutional full-time rate provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3482/a"},"text":"section 3482(a) of this title","children":[],"tail":", whichever is the lesser."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc375b804-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3491/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of section 3473(d)(1) ","children":[{"tag":"ref","attrib":{"idref":"fn002066"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002066"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, relating to the disapproval of enrollment in certain courses, shall be applicable to the enrollment of an eligible veteran who, while serving on active duty, enrolls in one or more courses under this subchapter for the purpose of attaining a secondary school diploma (or an equivalency certificate)."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc375b805-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/219/tII/s204/a/4"},"text":"Pub. L. 91–219, title II, § 204(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-03-26"},"text":"Mar. 26, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/79"},"text":"84 Stat. 79","children":[],"tail":", § 1691; amended "},{"tag":"ref","attrib":{"href":"/us/pl/92/540/tIII/s305"},"text":"Pub. L. 92–540, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-24"},"text":"Oct. 24, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1081"},"text":"86 Stat. 1081","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/502/tII/s211/12"},"text":"Pub. L. 94–502, title II, § 211(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-15"},"text":"Oct. 15, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2389"},"text":"90 Stat. 2389","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/466/tIII/s311"},"text":"Pub. L. 96–466, title III, § 311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"19