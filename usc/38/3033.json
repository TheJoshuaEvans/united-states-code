. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/449"},"text":"Pub. L. 96–449","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-14"},"text":"Oct. 14, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1967"},"text":"94 Stat. 1967","children":[],"tail":", which was formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5561"},"text":"section 5561 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc356bf1e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/252/s5003/b/1/A/i"},"text":"Pub. L. 110–252, § 5003(b)(1)(A)(i)","children":[],"tail":", inserted “33,” after “32,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/252/s5003/b/1/A/ii"},"text":"Pub. L. 110–252, § 5003(b)(1)(A)(ii)","children":[],"tail":", substituted “two or more of the programs established by this chapter, chapter 33 of this title, and chapters 1606 and 1607 of title 10” for “both the program established by this chapter and the program established by chapter 106 of title 10”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1433"},"text":"section 1433 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/16"},"text":"Pub. L. 102–16","children":[],"tail":" substituted “chapter 109 of title 10” for “section 902 of the Department of Defense Authorization Act, 1981 ("},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2141"},"text":"10 U.S.C. 2141","children":[],"tail":" note),”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsecs. (a)(1), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576/s306/a"},"text":"Pub. L. 99–576, § 306(a)","children":[],"tail":", substituted “chapter 31, 32, or 35 of this title, under chapter 106 or 107 of title 10, or under the Hostage Relief Act of 1980 ("},{"tag":"ref","attrib":{"href":"/us/pl/96/449"},"text":"Public Law 96–449","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5561"},"text":"5 U.S.C. 5561","children":[],"tail":" note) may not receive assistance under two or more of such programs” for “chapter 31, 34, or 35 of this title or under chapter 106 or 107 of title 10 may not receive assistance under both programs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576/s306/b"},"text":"Pub. L. 99–576, § 306(b)","children":[],"tail":", amended subsec. (c) generally. Prior to amendment, subsec. (c) read as follows: “An individual who is entitled to educational assistance under chapter 106 of title 10 may not also receive educational assistance under this chapter based on entitlement under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1412"},"text":"section 1412 of this title","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc356bf1f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDa