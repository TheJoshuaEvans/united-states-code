{"tag":"section","attrib":{"id":"idc356bf14-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3033"},"text":null,"children":[{"tag":"num","attrib":{"value":"3033"},"text":"§ 3033.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bar to duplication of educational assistance benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc356bf15-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3033/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc356bf16-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3033/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual entitled to educational assistance under a program established by this chapter who is also eligible for educational assistance under a program under chapter 31, 32, 33, or 35 of this title, under chapter 106 or 107 of title 10, or under the Hostage Relief Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/449"},"text":"Public Law 96–449","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5561"},"text":"5 U.S.C. 5561","children":[],"tail":" note) may not receive assistance under two or more of such programs concurrently but shall elect (in such form and manner as the Secretary may prescribe) under which program to receive educational assistance."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc356bf17-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3033/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual entitled to educational assistance under chapter 34 of this title may not receive assistance under this chapter before ","children":[{"tag":"date","attrib":{"date":"1990-01-01"},"text":"January 1, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc356bf18-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3033/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A period of service counted for purposes of repayment under chapter 109 of title 10 of an education loan may not also be counted for purposes of entitlement to educational assistance under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc356bf19-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3033/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual who serves in the Selected Reserve may not receive credit for such service under two or more of the programs established by this chapter, chapter 33 of this title, and chapters 1606 and 1607 of title 10 but shall elect (in such form and manner as the Secretary may prescribe) the program to which such service is to be credited.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc356bf1a-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/tVII/s702/a/1"},"text":"Pub. L. 98–525, title VII, § 702(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2561"},"text":"98 Stat. 2561","children":[],"tail":", § 1433; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/576/tIII/s306"},"text":"Pub. L. 99–576, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3269"},"text":"100 Stat. 3269","children":[],"tail":"; "},{"tag":"ref","attrib":{"hr