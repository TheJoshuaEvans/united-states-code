{"tag":"section","attrib":{"id":"idc2932140-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s732"},"text":null,"children":[{"tag":"num","attrib":{"value":"732"},"text":"§ 732.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of whistleblowers as criteria in evaluation of supervisors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2932141-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s732/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Development and Use of Criteria Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the Assistant Secretary of Accountability and Whistleblower Protection, shall develop criteria that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2932142-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s732/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall use as a critical element in any evaluation of the performance of a supervisory employee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2932143-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s732/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promotes the protection of whistleblowers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2932144-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s732/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Principles for Protection of Whistleblowers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The criteria required by subsection (a) shall include principles for the protection of whistleblowers, such as the degree to which supervisory employees respond constructively when employees of the Department report concerns, take responsible action to resolve such concerns, and foster an environment in which employees of the Department feel comfortable reporting concerns to supervisory employees or to the appropriate authorities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2932145-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s732/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Supervisory Employee and Whistleblower Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the terms “supervisory employee” and “whistleblower” have the meanings given such terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s323"},"text":"section 323 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2932146-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/41/tI/s102/a/3"},"text":"Pub. L. 115–41, title I, § 102(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-06-23"},"text":"June 23, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/865"},"text":"131 Stat. 865","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2932147-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc2932148-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc2932149-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 732, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/223/dA/tII/s247/a/1"},"text":"Pub. L. 114–223, div. A, title II, § 247(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-09-29"},"text":"Sept. 29, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/884"},"text":"130 Stat. 884","children":[],"tail":", related to treatment of whistleblower complaints, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/115/41/tI/s102/a/1"},"text":"Pub. L. 115–41, title I, § 102(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-06-23"},"text":"June 23, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/865"},"text":"131 Stat. 865","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
