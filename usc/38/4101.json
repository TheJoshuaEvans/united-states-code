},{"tag":"ref","attrib":{"href":"/us/stat/99/950"},"text":"99 Stat. 950","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/322/tI/s135"},"text":"Pub. L. 100–322, title I, § 135","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/507"},"text":"102 Stat. 507","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/687/dB/tXV/s1506/a"},"text":"Pub. L. 100–687, div. B, title XV, § 1506(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4135"},"text":"102 Stat. 4135","children":[],"tail":", related to functions of Department of Medicine and Surgery, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s401/a/3"},"text":"Pub. L. 102–40, title IV, § 401(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/210"},"text":"105 Stat. 210","children":[],"tail":". See sections 7301 to 7303, 7314, 7315, 7317, and 7425 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3b88d53-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Par. (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":" substituted “The term ‘career services’ means local employment and training services of the type described in section 134(c)(2) of the Workforce Innovation and Opportunity Act” for “The term ‘intensive services’ means local employment and training services of the type described in section 134(d)(3) of the Workforce Investment Act of 1998”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/288/s5/c/1"},"text":"Pub. L. 107–288, § 5(c)(1)","children":[],"tail":", amended par. (7) generally. Prior to amendment, par. (7) read as follows: “The term ‘local employment service office’ means a service delivery point which has an intrinsic management structure and at which employment services are offered in accordance with the Wagner-Peyser Act.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/288/s5/a/1/A"},"text":"Pub. L. 107–288, § 5(a)(1)(A)","children":[],"tail":", added par. (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2001"},"text":"section 2001 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (1) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “4211(1)” for “2011(1)” in par. (1), “4211(2)” for “2011(2)” in par. (2), “4211(3)” for “2011(3)” in par. (3), and “4211(4)” for “2011(4)” in par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Pars. (7), (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323"},"text":"Pub. L. 100–323","children":[],"tail":" added pars. (7) and (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466/s503/1"},"text":"Pub. L. 96–466, § 503(1)","children":[],"tail":", substituted provisions defining “special disabled veteran” for provisions that term “eligible veteran” meant a person who served in the active military, naval, or air service and who was discharged or released therefrom with other than a dishonorable discharge."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466/s503/2"},"text":"Pub. L. 96–466, § 503(2)","children":[],"tail":", added pars. (2) to (4). Former pars. (2) and (3) redesignated (5) and (6), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466"},"text":"Pub. L. 96–466","children":[],"tail":", §§ 503(2), 801(h)(1), redesignated former par. (2) as (5) and substituted “The term” for “the term”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466"},"text":"Pub. L. 96–466","children":[],"tail":", §§ 503(2), 801(h)(2), redesignated former par. (3) as (6) and inserted “the Commonwealth of the Northern Marianas Islands,” after “the Virgin Islands,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Pars. (2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/508"},"text":"Pub. L. 93–508","children":[],"tail":" added par. (2) and redesignated former par. (2) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/540"},"text":"Pub. L. 92–540","children":[],"tail":" substituted provisions defining “eligible veteran” and “State”, for provisions stating the Congressional declaration of purpose."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/358"},"text":"Pub. L. 89–358","children":[],"tail":" inserted “or of service after "},{"tag":"date","attrib":{"date":"1955-01-31"},"text":"January 31, 1955","children":[],"tail":"” after “veterans of any war”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3b88d54-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"t