{"tag":"section","attrib":{"id":"idc289aad7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s531"},"text":null,"children":[{"tag":"num","attrib":{"value":"531"},"text":"§ 531.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements relating to naming of Department property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc289aad8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s531/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Naming Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as expressly provided by law or as authorized under subsection (b), a facility, structure, or real property of the Department, and a major portion (such as a wing or floor) of any such facility, structure, or real property, may be named only for the geographic area in which the facility, structure, or real property is located.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc289aad9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s531/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of Names.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc289aada-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s531/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may transfer the name of covered property of the Department to other covered property of the Department if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc289aadb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s531/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the original covered property was designated with that name by law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc289aadc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s531/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department no longer offers benefits or services at the original covered property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc289aadd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s531/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the other covered property is similar in type and purpose as the original covered property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc289aade-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s531/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the other covered property is located in a different location or at a different address from the original covered property within the town, city, or other local government area specified in the designation made by such law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc289aadf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s531/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such transfer occurs not less than 30 days after the Secretary notifies the Committee on Veterans’ Affairs of the Senate, the Committee on Veterans’ Affairs of the House of Representatives, and each member of Congress representing the State in which the original covered property and other covered property are located of the intent of the Secretary to transfer the name of the original covered property to the other covered property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc289aae0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s531/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"References","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary transfers the name of covered property under paragraph (1), any reference in a law, regulation, map, document, paper, or other record of the United States to the covered property originally named by law shall be deemed to be a reference to the covered property to which the name has been transferred under such paragraph.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc289aae1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s531/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered property","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subsection, the term “covered property” means a facility, structure, or real property of the Department or a major portion (such as a wing or floor) of any such facility, structure, or real property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc289aae2-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/tX/s1001/a/1"},"text":"Pub. L. 105–368, title X, § 1001(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3363"},"text":"112 Stat. 3363","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/137/s1/a"},"text":"Pub. L. 117–137, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-06-07"},"text":"June 7, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1254"},"text":"136 Stat. 1254","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc289aae3-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc289aae4-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc289aae5-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/137/s1/a/2"},"text":"Pub. L. 117–137, § 1(a)(2)","children":[],"tail":", (3), designated existing provisions as subsec. (a), inserted heading, inserted “or as authorized under subsection (b)” after “Except as expressly provided by law”, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/137/s1/a/1"},"text":"Pub. L. 117–137, § 1(a)(1)","children":[],"tail":", substituted “Requirements” for “Requirement” in section catchline."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc289aae6-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc289aae7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/tX/s1001/b"},"text":"Pub. L. 105–368, title X, § 1001(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3363"},"text":"112 Stat. 3363","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/368/tX/s1001/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s531"},"text":"Section 531 of title 38","children":[],"tail":", United States Code, as added by subsection (a)(1), shall apply with respect to the assignment or designation of the name of a facility, structure, or real property of the Department of Veterans Affairs (or of a major portion thereof) after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
