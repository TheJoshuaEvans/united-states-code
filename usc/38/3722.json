{"tag":"section","attrib":{"id":"idc3aa3675-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3722"},"text":null,"children":[{"tag":"num","attrib":{"value":"3722"},"text":"§ 3722.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Veterans Housing Benefit Program Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3aa3676-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3722/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is hereby established in the Treasury of the United States a fund known as the Veterans Housing Benefit Program Fund (hereinafter in this section referred to as the “Fund”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3aa3677-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3722/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Fund shall be available to the Secretary, without fiscal year limitation, for all housing loan operations under this chapter, other than administrative expenses, consistent with the Federal Credit Reform Act of 1990.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3aa3678-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3722/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" There shall be deposited into the Fund the following, which shall constitute the assets of the Fund:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3aa3679-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3722/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any amount appropriated to the Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3aa367a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3722/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts paid into the Fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3729"},"text":"section 3729 of this title","children":[],"tail":" or any other provision of law or regulation established by the Secretary imposing fees on persons or other entities participating in the housing loan programs under this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3aa367b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3722/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" All other amounts received by the Secretary on or after ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"October 1, 1998","children":[],"tail":", incident to housing loan operations under this chapter, including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3aa367c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3722/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collections of principal and interest on housing loans made by the Secretary under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3aa367d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3722/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proceeds from the sale, rental, use, or other disposition of property acquired under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3aa367e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3722/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proceeds from the sale of loans pursuant to sections 3720(h) and 3733(a)(3) of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3aa367f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3722/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" penalties collected pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3710/g/4/B"},"text":"section 3710(g)(4)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3aa3680-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3722/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts deposited into the Fund under paragraphs (2) and (3) of subsection (c) shall be deposited in the appropriate financing or liquidating account of the Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3aa3681-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3722/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this section, the term “housing loan” shall not include a loan made pursuant to subchapter V of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3aa3682-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/tVI/s602/a/2"},"text":"Pub. L. 105–368, title VI, § 602(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"ta