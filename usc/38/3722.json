":{"topic":"priorProvisions","id":"idc3aa3686-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior to renumbering of sections 1801 to 1851 of this chapter as sections 3701 to 3751 by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":", section 1822 of this chapter, "},{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1214"},"text":"72 Stat. 1214","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/358/s5/c"},"text":"Pub. L. 89–358, § 5(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-03-03"},"text":"Mar. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/26"},"text":"88 Stat. 26","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/623/s1"},"text":"Pub. L. 89–623, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-04"},"text":"Oct. 4, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/873"},"text":"80 Stat. 873","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/301/s2/b"},"text":"Pub. L. 90–301, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-05-07"},"text":"May 7, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/113"},"text":"82 Stat. 113","children":[],"tail":", which provided for bringing of an action in district court, by veteran or Attorney General, against one who knowingly participated in sale of property to a veteran for consideration in excess of reasonable value of property, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/93/569"},"text":"Pub. L. 93–569","children":[],"tail":", §§ 7(a), 10, "},{"tag":"date","attrib":{"date":"1974-12-31"},"text":"Dec. 31, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1866"},"text":"88 Stat. 1866","children":[],"tail":", 1867, effective "},{"tag":"date","attrib":{"date":"1974-12-31"},"text":"Dec. 31, 1974","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3aa3687-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/14"},"text":"Pub. L. 107–14","children":[],"tail":" substituted “hereinafter” for “hereafter”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3aa3688-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3ac7f79-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/368/s602/f"},"text":"section 602(f) of Pub. L. 105–368","children":[],"tail":", set out as an Effective Date of 1998 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2106"},"text":"section 2106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3ac7f7a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transfers of Amounts Into Veterans Housing Benefit Program Fund","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/tVI/s602/b"},"text":"Pub. L. 105–368, title VI, § 602(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3346"},"text":"112 Stat. 3346","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/368/tVI/s602/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“All amounts in the following funds are hereby transferred to the Veterans Housing Benefit Program Fund:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Direct Loan Revolving Fund, as such fund was continued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3723"},"text":"section 3723 of title 38","children":[],"tail":", United States Code (as such section was in effect on the day before the effective date of this title ["},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":"])."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Veterans Affairs Loan Guaranty Revolving Fund, as established by section 3724 of such title (as such section was in effect on the day before the effective date of this title).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Guaranty and Indemnity Fund, as established by section 3725 of such title (as such section was in effect on the day before the effective date of this title).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
