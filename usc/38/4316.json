{"tag":"section","attrib":{"id":"idc3c6becd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4316"},"text":null,"children":[{"tag":"num","attrib":{"value":"4316"},"text":"§ 4316.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights, benefits, and obligations of persons absent from employment for service in a uniformed service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3c6bece-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4316/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person who is reemployed under this chapter is entitled to the seniority and other rights and benefits determined by seniority that the person had on the date of the commencement of service in the uniformed services plus the additional seniority and rights and benefits that such person would have attained if the person had remained continuously employed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3c6becf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4316/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3c6bed0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4316/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to paragraphs (2) through (6), a person who is absent from a position of employment by reason of service in the uniformed services shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3c6bed1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4316/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deemed to be on furlough or leave of absence while performing such service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3c6bed2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4316/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entitled to such other rights and benefits not determined by seniority as are generally provided by the employer of the person to employees having similar seniority, status, and pay who are on furlough or leave of absence under a contract, agreement, policy, practice, or plan in effect at the commencement of such service or established while such person performs such service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3c6bed3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4316/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3c6bed4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4316/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to subparagraph (B), a person who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc3c6bed5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4316/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is absent from a position of employment by reason of service in the uniformed services, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3c6bed6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4316/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly provides written notice of intent not to return to a position of employment after service in the uniformed service,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is not entitled to rights and benefits under paragraph (1)(B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3c6bed7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4316/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of subparagraph (A), the employer shall have the burden of proving that a person knowingly provided clear written notice of intent not to return to a position of employment after service in the uniformed service and, in doing so, was aware of the specific rights and benefits to be lost under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3c6bed8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4316/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person deemed to be on furlough or leave of absence under this subsection while serving in the uniformed services shall not be entitled under this subsection to any benefits to which the person would not otherwise be entitled if the person had remained continuously employed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3c6bed9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4316/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such person may be required to pay the employee cost, if any, of any funded benefit continued pursuant to paragraph (1) to the extent other employees on furlough or leave of absence are so required.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3c6beda-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4316/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The entitlement of a person to coverage under a health plan is provided for under section 4317.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3c6bedb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4316/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The entitlement of a person to a right or benefit under an employee pension benefit plan is provided for under section 4318.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3c6bedc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4316/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person who is reemployed by an employer under this chapter shall not be discharged from such employment, except for cause—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3c6bedd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4316/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within one year after the date of such reemployment, if the person’s period of service before the reemployment was more than 180 days; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3c6bede-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4316/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within 180 days after the date of such reemployment, if the person’s period of service before the reemployment was more than 30 days but less than 181 days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3c6bedf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4316/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person whose employment with an employer is interrupted by a period of service in the uniformed services shall be permitted, upon request of that person, to use during such period of service any vacation, annual, or similar leave with pay accrued by the person before the commencement of such service. No employer may require any such person to use vacation, annual, or similar leave during such period of service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3c6bee0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4316/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3c6bee1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4316/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employer shall grant an employee who is a member of a reserve component an authorized leave of absence from a position of employment to allow that employee to perform funeral honors duty as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12503"},"text":"section 12503 of title 10","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t32/s115"},"text":"section 115 of title 32","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3c6bee2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4316/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4312/e/1"},"text":"section 4312(e)(1) of this title","children":[],"tail":", an employee who takes an authorized leave of absence under paragraph (1) is deemed to have notified the employer of the employee’s intent to return to such position of employment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3c6bee3-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/353/s2/a"},"text":"Pub. L. 103–353, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3160"},"text":"108 Stat. 3160","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/275/tIII/s311/6"},"text":"Pub. L. 104–275, title III, § 311(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3335"},"text":"110 Stat. 3335","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/419/tIII/s323/b"},"text":"Pub. L. 106–419, title III, § 323(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1855"},"text":"114 Stat. 1855","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3c6bee4-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3c6bee5-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc3c6bee6-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4316 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7616"},"text":"section 7616 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3c6bee7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/419"},"text":"Pub. L. 106–419","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/275"},"text":"Pub. L. 104–275","children":[],"tail":" inserted at end “No employer may require any such person to use vacation, annual, or similar leave during such period of service.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3c6bee8-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3c6bee9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/419"},"text":"Pub. L. 106–419","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/419/s323/c"},"text":"section 323(c) of Pub. L. 106–419","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4303"},"text":"section 4303 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3c6beea-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/275"},"text":"Pub. L. 104–275","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/275/s313"},"text":"section 313 of Pub. L. 104–275","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4301"},"text":"section 4301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3c6beeb-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective with respect to reemployments initiated on or after the first day after the 60-day period beginning ","children":[{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", with transition rules, except that the provisions concerning insurance coverage (other than health) are effective with respect to furloughs or leaves of absence initiated on or after "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", and subsec. (b)(2) of this section is applicable only to the rights and benefits provided in subsec. (b)(1)(B) of this section and to persons who leave a position of employment for service in the uniformed services more than 60 days after "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", and not applicable to any other right or benefit of a person under this chapter, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/353/s8"},"text":"section 8 of Pub. L. 103–353","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4301"},"text":"section 4301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
