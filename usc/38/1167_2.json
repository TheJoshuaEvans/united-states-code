{"tag":"section","attrib":{"id":"idc2afd053-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1167"},"text":null,"children":[{"tag":"num","attrib":{"value":"1167"},"text":"§ 1167.","children":[{"tag":"ref","attrib":{"idref":"fn002026"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002026"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" Another section 1167 is set out preceding section 1168."}],"tail":null}],"tail":null},{"tag":"heading","attrib":{},"text":" Mental health consultations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2afd054-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1167/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days after the date on which a veteran submits to the Secretary a claim for compensation under this chapter for a service-connected disability relating to a mental health diagnosis, the Secretary shall offer the veteran a mental health consultation to assess the mental health needs of, and care options for, the veteran.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2afd055-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1167/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2afd056-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1167/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offer a veteran a consultation under subsection (a) without regard to any previous denial or approval of a claim of that veteran for a service-connected disability relating to a mental health diagnosis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2afd057-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1167/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that a veteran offered a mental health consultation under subsection (a) may elect to receive such consultation during the one-year period beginning on the date on which the consultation is offered or during such longer period beginning on such date as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2afd058-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1167/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A consultation provided to a veteran under this section shall not be construed as a determination that any disability of such veteran is service-connected for the purposes of any benefit under the laws administered by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2afd059-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dV/tIV/s404/a/1"},"text":"Pub. L. 117–328, div. V, title IV, § 404(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5512"},"text":"136 Stat. 5512","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
