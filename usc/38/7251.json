{"tag":"section","attrib":{"id":"idc3ece46e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7251"},"text":null,"children":[{"tag":"num","attrib":{"value":"7251"},"text":"§ 7251.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is hereby established, under Article I of the Constitution of the United States, a court of record to be known as the United States Court of Appeals for Veterans Claims.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc3ece46f-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/687/dA/tIII/s301/a"},"text":"Pub. L. 100–687, div. A, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4113"},"text":"102 Stat. 4113","children":[],"tail":", § 4051; renumbered § 7251, "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/368/tV/s511/b"},"text":"Pub. L. 105–368, title V, § 511(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3341"},"text":"112 Stat. 3341","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3ece470-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3ece471-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3ece472-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368"},"text":"Pub. L. 105–368","children":[],"tail":" substituted “Court of Appeals for Veterans Claims” for “Court of Veterans Appeals”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4051"},"text":"section 4051 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3ece473-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idc3ece474-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/tV/s511/a"},"text":"Pub. L. 105–368, title V, § 511(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3341"},"text":"112 Stat. 3341","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/368/tV/s511/a"},"text":"“The United States Court of Veterans Appeals is hereby renamed as, and shall hereafter be known and designated as, the United States Court of Appeals for Veterans Claims.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/tV/s512/c"},"text":"Pub. L. 105–368, title V, § 512(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3342"},"text":"112 Stat. 3342","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/368/tV/s512/c"},"text":"“Any reference in a law, regulation, document, paper, or other record of the United States to the United States Court of Veterans Appeals shall be deemed to be a reference to the United States Court of Appeals for Veterans Claims.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3ece475-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2001 Amendment; Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/103/tVI/s603/c"},"text":"Pub. L. 107–103, title VI, § 603(c)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"2001-12-27"},"text":"Dec. 27, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/999"},"text":"115 Stat. 999","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/103/tVI/s603/c"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The repeal in subsection (a) [repealing ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/687/s402"},"text":"section 402 of Pub. L. 100–687","children":[],"tail":", formerly set out as a note below] may not be construed to confer upon the United States Court of Appeals for Veterans Claims jurisdiction over any appeal or other matter not within the jurisdiction of the Court as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7266/a"},"text":"section 7266(a) of title 38","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The repeals made by subsections (a) and (b) [repealing ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/687/s402"},"text":"section 402 of Pub. L. 100–687","children":[],"tail":", formerly set out as a note below, and "},{"tag":"ref","attrib":{"href":"/us/pl/100/687/s403"},"text":"section 403 of Pub. L. 100–687","children":[],"tail":", formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5904"},"text":"section 5904 of this title","children":[],"tail":"] shall apply to any appeal filed with the United States Court of Appeals for Veterans Claims—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2001-12-27"},"text":"Dec. 27, 2001","children":[],"tail":"]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before the date of the enactment of this Act but in which a final decision has not been made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7291"},"text":"section 7291 of title 38","children":[],"tail":", United States Code, as of that date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3ece476-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/tV/s513"},"text":"Pub. L. 105–368, title V, § 513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3342"},"text":"112 Stat. 3342","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/368/tV/s513"},"text":"“This subtitle [subtitle B (§§ 511–513) of title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368"},"text":"Pub. L. 105–368","children":[],"tail":", see Tables for classification], and the amendments made by this subtitle, shall take effect on the first day of the first month beginning more than 90 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3ece477-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/687/dA/tIV/s401"},"text":"Pub. L. 100–687, div. A, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4122"},"text":"102 Stat. 4122","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/101/94/tIII/s301"},"text":"Pub. L. 101–94, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-16"},"text":"Aug. 16, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/628"},"text":"103 Stat. 628","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/94/tIII/s301"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided in this section, this division (and the amendments made by this Act) [div. A (§§ 1–403) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/687"},"text":"Pub. L. 100–687","children":[],"tail":", known as the ‘Veterans’ Judicial Review Act’, see Tables for classification] shall take effect on "},{"tag":"date","attrib":{"date":"1989-09-01"},"text":"September 1, 1989","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date for Certain Transition Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendment made by section 201(a) [amending section 4001 [now 7101] of this title] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1989-02-01"},"text":"February 1, 1989","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Date of Enactment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Sections 201 (other than subsection (a)), 208, 209, 302, and 303, and the amendments made by those sections [see Tables for classification], shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Board of Veterans’ Appeals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Sections 202, 203, 205, 206, and 207 [see Tables for classification] shall take effect as of ","children":[{"tag":"date","attrib":{"date":"1989-01-01"},"text":"January 1, 1989","children":[],"tail":". Section 204 [amending section 4004 [now 7104] of this title] shall take effect on "},{"tag":"date","attrib":{"date":"1989-09-01"},"text":"September 1, 1989","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commencement of Operation of Court of Veterans Appeals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subsection (a), the United States Court of Veterans Appeals [now United States Court of Appeals for Veterans Claims] established pursuant to chapter 72 of title 38, United States Code (as added by section 301) shall not begin to operate until at least three judges have been appointed to the court.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3ece478-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Chapter Applicable to Claims Alleging Previous Determination the Product of Clear and Unmistakable Error","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/111/s1/c/2"},"text":"Pub. L. 105–111, § 1(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2272"},"text":"111 Stat. 2272","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/111/s1/c/2"},"text":"“Notwithstanding section 402 of the Veterans Judicial Review Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7251"},"text":"38 U.S.C. 7251","children":[],"tail":" note), chapter 72 of title 38, United States Code, shall apply with respect to any decision of the Board of Veterans’ Appeals on a claim alleging that a previous determination of the Board was the product of clear and unmistakable error if that claim is filed after, or was pending before the Department of Veterans Affairs, the Court of Veterans Appeals [now Court of Appeals for Veterans Claims], the Court of Appeals for the Federal Circuit, or the Supreme Court on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3ece479-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Chapter Applicable to Cases Filed On or After ","children":[{"tag":"date","attrib":{"date":"1988-11-18"},"text":"November 18, 1988","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/687/dA/tIV/s402"},"text":"Pub. L. 100–687, div. A, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4122"},"text":"102 Stat. 4122","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/d/2"},"text":"Pub. L. 102–40, title IV, § 402(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/239"},"text":"105 Stat. 239","children":[],"tail":", which provided that this chapter applied to any case in which a notice of disagreement was filed under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7105"},"text":"section 7105 of this title","children":[],"tail":" on or after "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/107/103/tVI/s603/a"},"text":"Pub. L. 107–103, title VI, § 603(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-27"},"text":"Dec. 27, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/999"},"text":"115 Stat. 999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
