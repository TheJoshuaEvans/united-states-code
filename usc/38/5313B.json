{"tag":"section","attrib":{"id":"idc3d9d11e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313B"},"text":null,"children":[{"tag":"num","attrib":{"value":"5313B"},"text":"§ 5313B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on providing certain benefits with respect to persons who are fugitive felons","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3d9d11f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A veteran who is otherwise eligible for a benefit specified in subsection (c) may not be paid or otherwise provided such benefit for any period during which such veteran is a fugitive felon. A dependent of a veteran who is otherwise eligible for a benefit specified in subsection (c) may not be paid or otherwise provided such benefit for any period during which such veteran or such dependent is a fugitive felon.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d9d120-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3d9d121-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313B/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “fugitive felon” means a person who is a fugitive by reason of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3d9d122-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313B/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fleeing to avoid prosecution, or custody or confinement after conviction, for an offense, or an attempt to commit an offense, which is a felony under the laws of the place from which the person flees; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3d9d123-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313B/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" violating a condition of probation or parole imposed for commission of a felony under Federal or State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d9d124-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313B/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “felony” includes a high misdemeanor under the laws of a State which characterizes as high misdemeanors offenses that would be felony offenses under Federal law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d9d125-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313B/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “dependent” means a spouse, surviving spouse, child, or dependent parent of a veteran.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d9d126-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313B/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A benefit specified in this subsection is a benefit under any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3d9d127-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313B/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 11 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d9d128-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313B/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 13 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d9d129-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313B/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 15 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d9d12a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313B/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 17 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d9d12b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313B/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 19 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d9d12c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313B/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 30, 31, 32, 34, or 35 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d9d12d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313B/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 37 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d9d12e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313B/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3d9d12f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313B/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall furnish to any Federal, State, or local law enforcement official, upon the written request of such official, the most current address maintained by the Secretary of a person who is eligible for a benefit specified in subsection (c) if such official—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3d9d130-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313B/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides to the Secretary such information as the Secretary may require to fully identify the person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3d9d131-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313B/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies the person as being a fugitive felon; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3d9d132-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313B/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certifies to the Secretary that apprehending such person is within the official duties of such official.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d9d133-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313B/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall enter into memoranda of understanding with Federal law enforcement agencies, and may enter into agreements with State and local law enforcement agencies, for purposes of furnishing information to such agencies under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3d9d134-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/103/tV/s505/a/1"},"text":"Pub. L. 107–103, title V, § 505(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-27"},"text":"Dec. 27, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/995"},"text":"115 Stat. 995","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
