{"tag":"section","attrib":{"id":"idc2dd2192-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703F"},"text":null,"children":[{"tag":"num","attrib":{"value":"1703F"},"text":"§ 1703F.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credentialing verification requirements for providers of non-Department health care services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2dd2193-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703F/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall ensure that Third Party Administrators and credentials verification organizations comply with the requirements specified in subsection (b) to help ensure certain health care providers are excluded from providing non-Department health care services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2dd2194-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703F/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements Specified","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall require Third Party Administrators and credentials verification organizations to carry out the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2dd2195-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703F/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hold and maintain an active credential verification accreditation from a national health care accreditation body.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2dd2196-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703F/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Conduct initial verification of provider history and license sanctions for all States and United States territories for a period of time—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2dd2197-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703F/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that includes the period before the provider began providing non-Department health care services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2dd2198-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703F/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dating back not less than 10 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2dd2199-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703F/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not less frequently than every three years, perform recredentialing, including verifying provider history and license sanctions for all States and United States territories.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2dd219a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703F/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Implement continuous monitoring of each provider through the National Practitioner Data Bank established pursuant to the Health Care Quality Improvement Act of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11101"},"text":"42 U.S.C. 11101","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2dd219b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703F/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Perform other forms of credentialing verification as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2dd219c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703F/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2dd219d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703F/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “credentials verification organization” means an entity that manages the provider credentialing process and performs credentialing verification for non-Department providers that participate in the Veterans Community Care Program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1703"},"text":"section 1703 of this title","children":[],"tail":" through a Veterans Care Agreement."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2dd219e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703F/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Third Party Administrator” means an entity that manages a provider network and performs administrative services related to such network within the Veterans Community Care Program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1703"},"text":"section 1703 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2dd219f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703F/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Veterans Care Agreement” means an agreement for non-Department health care services entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1703A"},"text":"section 1703A of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2dd21a0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703F/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “non-Department health care services” means services—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2dd21a1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703F/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provided under this subchapter at non-Department facilities (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1701"},"text":"section 1701 of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2dd21a2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703F/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provided under section 101 of the Veterans Access, Choice, and Accountability Act of 2014 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/146"},"text":"Public Law 113–146","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1701"},"text":"38 U.S.C. 1701","children":[],"tail":" note);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2dd21a3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703F/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchased through the Medical Community Care account of the Department; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2dd21a4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703F/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchased with amounts deposited in the Veterans Choice Fund under section 802 of the Veterans Access, Choice, and Accountability Act of 2014 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/146"},"text":"Public Law 113–146","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1701"},"text":"38 U.S.C. 1701","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2dd21a5-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dU/tI/s141/a/1"},"text":"Pub. L. 117–328, div. U, title I, § 141(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5422"},"text":"136 Stat. 5422","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2dd21a6-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc2dd21a7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc2dd21a8-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Health Care Quality Improvement Act of 1986, referred to in subsec. (b)(4), is title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/660"},"text":"Pub. L. 99–660","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3784"},"text":"100 Stat. 3784","children":[],"tail":", which is classified generally to chapter 117 (§ 11101 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11101"},"text":"section 11101 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc2dd21a9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc2dd21aa-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadline for Implementation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dU/tI/s141/b"},"text":"Pub. L. 117–328, div. U, title I, § 141(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5423"},"text":"136 Stat. 5423","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dU/tI/s141/b"},"text":"“Not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":"], the Secretary of Veterans Affairs shall commence the implementation of "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1703F"},"text":"section 1703F of title 38","children":[],"tail":", United States Code, as added by subsection (a)(1).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
