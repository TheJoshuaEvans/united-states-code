{"tag":"section","attrib":{"id":"idc332e2d5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2023"},"text":null,"children":[{"tag":"num","attrib":{"value":"2023"},"text":"§ 2023.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referral and counseling services: veterans at risk of homelessness who are transitioning from certain institutions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc332e2d6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2023/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary and the Secretary of Labor (hereinafter in this section referred to as the “Secretaries”) shall carry out a program of referral and counseling services to eligible veterans with respect to benefits and services available to such veterans under this title and under State law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc332e2d7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2023/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Location of Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The program shall be carried out in at least 12 locations. One location shall be a penal institution under the jurisdiction of the Bureau of Prisons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc332e2d8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2023/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope of Program","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc332e2d9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2023/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the extent practicable, the program shall provide both referral and counseling services, and in the case of counseling services, shall include counseling with respect to job training and placement (including job readiness), housing, health care, and other benefits to assist the eligible veteran in the transition from institutional living.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc332e2da-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2023/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc332e2db-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2023/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the extent that referral or counseling services are provided at a location under the program, referral services shall be provided in person during such period of time that the Secretaries may specify that precedes the date of release or discharge of the eligible veteran, and counseling services shall be furnished after such date.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc332e2dc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2023/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretaries may, as part of the program, furnish to officials of penal institutions outreach information with respect to referral and counseling services for presentation to veterans in the custody of such officials during the 18-month period that precedes such date of release or discharge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc332e2dd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2023/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretaries may make grants to carry out the referral and counseling services required under the program with entities or organizations that meet such requirements as the Secretaries may establish.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc332e2de-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2023/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In developing the program, the Secretaries shall consult with officials of the Bureau of Prisons, officials of penal institutions of States and political subdivisions of States, and such other officials as the Secretaries determine appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc332e2df-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2023/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “eligible veteran” means a veteran who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc332e2e0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2023/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a resident of a penal institution or an institution that provides long-term care for mental illness; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc332e2e1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2023/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is at risk for homelessness absent referral and counseling services provided under the demonstration program (as determined under guidelines established by the Secretaries).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc332e2e2-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/95/s5/a/1"},"text":"Pub. L. 107–95, § 5(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-21"},"text":"Dec. 21, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/912"},"text":"115 Stat. 912","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/28/tV/s5705"},"text":"Pub. L. 110–28, title V, § 5705","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-05-25"},"text":"May 25, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/170"},"text":"121 Stat. 170","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/387/tVI/s602/a"},"text":"Pub. L. 110–387, title VI, § 602(a)","children":[],"tail":"–(d)(2), "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4132"},"text":"122 Stat. 4132","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tV/s590"},"text":"Pub. L. 112–239, div. A, title V, § 590","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1769"},"text":"126 Stat. 1769","children":[],"tail":"; "},{"tag":"ref