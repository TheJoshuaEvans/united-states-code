59, div. E, title III, § 5303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-01"},"text":"Oct. 1, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/750"},"text":"134 Stat. 750","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/315/tIV/s4205/a"},"text":"Pub. L. 116–315, title IV, § 4205(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/5014"},"text":"134 Stat. 5014","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc332e2e3-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc332e2e4-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc332e2e5-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 2023 to 2027 were renumbered sections 4303 to 4307 of this title, respectively, and subsequently omitted in the general amendment of chapter 43 of this title by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/353/s2/a"},"text":"Pub. L. 103–353, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3150"},"text":"108 Stat. 3150","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc332e2e6-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315"},"text":"Pub. L. 116–315","children":[],"tail":" redesignated subsec. (e) as (d) and struck out former subsec. (d). Prior to amendment, text of subsec. (d) read as follows: “The authority of the Secretaries to enter into a contract to provide referral and counseling services under the demonstration program shall cease on "},{"tag":"date","attrib":{"date":"2022-09-30"},"text":"September 30, 2022","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/159"},"text":"Pub. L. 116–159","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2022-09-30"},"text":"September 30, 2022","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2020-09-30"},"text":"September 30, 2020","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/251"},"text":"Pub. L. 115–251","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2020-09-30"},"text":"September 30, 2020","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2018-09-30"},"text":"September 30, 2018","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/62"},"text":"Pub. L. 115–62","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2018-09-30"},"text":"September 30, 2018","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2017-09-30"},"text":"September 30, 2017","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/228"},"text":"Pub. L. 114–228","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2017-09-30"},"text":"September 30, 2017","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2016-09-30"},"text":"September 30, 2016","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/58"},"text":"Pub. L. 114–58","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2016-09-30"},"text":"September 30, 2016","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2015-09-30"},"text":"September 30, 2015","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/175/s203/b"},"text":"Pub. L. 113–175, § 203(b)","children":[],"tail":", substituted “make grants” for “enter into contracts”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/175/s203/a"},"text":"Pub. L. 113–175, § 203(a)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2015-09-30"},"text":"September 30, 2015","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2014-09-30"},"text":"September 30, 2014","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/37"},"text":"Pub. L. 113–37","children":[],"tail":" inserted “to enter into a contract” before “to provide” and substituted “"},{"tag":"date","attrib":{"date":"2014-09-30"},"text":"September 30, 2014","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2013-09-30"},"text":"September 30, 2013","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2013-09-30"},"text":"September 30, 2013","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2012-09-30"},"text":"September 30, 2012","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/387/s602/d/2"},"text":"Pub. L. 110–387, § 602(d)(2)","children":[],"tail":", amended section catchline generally. Prior to amendment, catchline read as follows: “Demonstration program of referral and counseling for veterans transitioning from certain institutions who are at risk for homelessness”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/387/s602/a"},"text":"Pub. L. 110–387, § 602(a)","children":[],"tail":", substituted “a program of” for “a demonstration program for the purpose of determining the costs and benefits of providing”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/387/s602/b"},"text":"Pub. L. 110–387, § 602(b)","children":[],"tail":", in heading, struck out “Demonstration” before “Program” and in text, struck out “demonstration” before “program” and substituted “12 locations” for “six locations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/387/s602/d/1"},"text":"Pub. L. 110–387, § 602(d)(1)","children":[],"tail":", struck out “demonstration” before “program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/387/s602/c"},"text":"Pub. L. 110–387, § 602(c)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2012-09-30"},"text":"September 30, 2012","children":[],"tail":".” for “"},{"tag":"date","attrib":{"date":"2007-09-30"},"text":"September 30, 2007","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/28"},"text":"Pub. L. 110–28","children":[],"tail":" substituted “shall cease on "},{"tag":"date","attrib":{"date":"2007-09-30"},"text":"September 30, 2007","children":[],"tail":"” for “shall cease on the date that is four years after the date of the commencement of the program”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc332e2e7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc332e2e8-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/37"},"text":"Pub. L. 113–37","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2013-10-01"},"text":"Oct. 1, 2013","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/113/37/s4/a"},"text":"section 4(a) of Pub. L. 113–37","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s322"},"text":"section 322 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
