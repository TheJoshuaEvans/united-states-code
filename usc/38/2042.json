{"tag":"section","attrib":{"id":"idc3355461-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2042"},"text":null,"children":[{"tag":"num","attrib":{"value":"2042"},"text":"§ 2042.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supported housing for veterans participating in compensated work therapies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may authorize homeless veterans in the compensated work therapy program to be provided housing through the therapeutic residence program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2032"},"text":"section 2032 of this title","children":[],"tail":" or through grant and per diem providers under subchapter II of this chapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc3355462-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/95/s5/a/1"},"text":"Pub. L. 107–95, § 5(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-21"},"text":"Dec. 21, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/913"},"text":"115 Stat. 913","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
