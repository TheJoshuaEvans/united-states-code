{"tag":"section","attrib":{"id":"idc4099413-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414"},"text":null,"children":[{"tag":"num","attrib":{"value":"7414"},"text":"§ 7414.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with requirements for examining qualifications and clinical abilities of health care professionals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc4099414-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance With Credentialing Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that each medical center of the Department, in a consistent manner—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4099415-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" compiles, verifies, and reviews documentation for each health care professional of the Department at such medical center regarding, at a minimum—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc4099416-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the professional licensure, certification, or registration of the health care professional;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4099417-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the health care professional holds a Drug Enforcement Administration registration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4099418-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the education, training, experience, malpractice history, and clinical competence of the health care professional; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4099419-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continuously monitors any changes to the matters under paragraph (1), including with respect to suspensions, restrictions, limitations, probations, denials, revocations, and other changes, relating to the failure of a health care professional to meet generally accepted standards of clinical practice in a manner that presents reasonable concern for the safety of patients.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc409941a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Registration Regarding Controlled Substances","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc409941b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), the Secretary shall ensure that each covered health care professional holds an active Drug Enforcement Administration registration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc409941c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc409941d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the circumstances in which a medical center of the Department must obtain a waiver under section 302(d) of the Controlled Substances Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s822/d"},"text":"21 U.S.C. 822(d)","children":[],"tail":") with respect to covered health care professionals; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc409941e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a process for medical centers to request such waivers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc409941f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out paragraph (1), the Secretary shall ensure that each medical center of the Department monitors the Drug Enforcement Administration registrations of covered health care professionals at such medical center in a manner that ensures the medical center is made aware of any change in status in the registration by not later than seven days after such change in status.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4099420-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If a covered health care professional does not hold an active Drug Enforcement Administration registration, the Secretary shall carry out any of the following actions, as the Secretary determines appropriate:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc4099421-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Obtain a waiver pursuant to paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4099422-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transfer the health care professional to a position that does not require prescribing, dispensing, administering, or conducting research with controlled substances.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4099423-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Take appropriate actions under subchapter V of this chapter, with respect to an employee of the Department, or take appropriate contract administration actions, with respect to a contractor of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4099424-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reviews of Concerns Relating to Quality of Clinical Care","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4099425-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall ensure that each medical center of the Department, in a consistent manner, carries out—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc4099426-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ongoing, retrospective, and comprehensive monitoring of the performance and quality of the health care delivered by each health care professional of the Department located at the medical center, including with respect to the safety of such care; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4099427-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" timely and documented reviews of such care if an individual notifies the Secretary of any potential concerns relating to a failure of a health care professional of the Department to meet generally accepted standards of clinical practice in a manner that presents reasonable concern for the safety of patients.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4099428-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall establish a policy to carry out paragraph (1), including with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc4099429-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determining the period by which a medical center of the Department must initiate the review of a concern described in subparagraph (B) of such paragraph following the date on which the concern is received; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc409942a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring the compliance of each medical center with such policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc409942b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance With Requirements for Reporting Quality of Care Concerns","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary substantiates a concern relating to the clinical competency of, or quality of care delivered by, a health care professional of the Department (including a former health care professional of the Department), the Secretary shall ensure that the appropriate medical center of the Department timely notifies the following entities of such concern, as appropriate:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc409942c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The appropriate licensing, registration, or certification body in each State in which the health care professional is licensed, registered, or certified.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc409942d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Drug Enforcement Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc409942e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Practitioner Data Bank established pursuant to the Health Care Quality Improvement Act of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11101"},"text":"42 U.S.C. 11101","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc409942f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other relevant entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4099430-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on Certain Settlement Agreement Terms","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4099431-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not enter into a settlement agreement relating to an adverse action against a health care professional of the Department if such agreement includes terms that require the Secretary to conceal from the personnel file of the employee a serious medical error or lapse in clinical practice that constitutes a substantial failure to meet generally accepted standards of clinical practice as to raise reasonable concern for the safety of patients.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4099432-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Nothing in paragraph (1) limits—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc4099433-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the right of an employee to appeal a quality of care determination; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4099434-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rights of an employee under sections 1214 and 1221 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4099435-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not less frequently than annually, the Secretary shall provide mandatory training on the following duties to employees of the Department who are responsible for performing such duties:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4099436-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Compiling, validating, or reviewing the credentials of health care professionals of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4099437-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reviewing the quality of clinical care delivered by health care professionals of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4099438-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Taking adverse privileging actions or making determinations relating to other disciplinary actions or employment actions against health care professionals of the Department for reasons relating to the failure of a health care professional to meet generally accepted standards of clinical practice in a manner that presents reasonable concern for the safety of patients.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4099439-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Making notifications under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc409943a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc409943b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “controlled substance” has the meaning given that term in section 102 of the Controlled Substances Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s802"},"text":"21 U.S.C. 802","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc409943c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “covered health care professional” means an individual employed in a position as a health care professional of the Department, or a contractor of the Department, that requires the individual to be authorized to prescribe, dispense, administer, or conduct research with, controlled substances.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc409943d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Drug Enforcement Administration registration” means registration with the Drug Enforcement Administration under section 303 of the Controlled Substances Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s823"},"text":"21 U.S.C. 823","children":[],"tail":") 302 of the Controlled Substances Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s822"},"text":"21 U.S.C. 822","children":[],"tail":") by health care practitioners authorized to dispense, prescribe, administer, or conduct research with, controlled substances."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc409943e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7414/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “health care professional of the Department” means an individual working for the Department in a position described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401"},"text":"section 7401 of this title","children":[],"tail":", including a contractor of the Department serving in such a position."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc409943f-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dU/tI/s112/a"},"text":"Pub. L. 117–328, div. U, title I, § 112(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5411"},"text":"136 Stat. 5411","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc4099440-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc4099441-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc4099442-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Health Care Quality Improvement Act of 1986, referred to in subsec. (d)(3), is title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/660"},"text":"Pub. L. 99–660","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3784"},"text":"100 Stat. 3784","children":[],"tail":", which is classified generally to chapter 117 (§ 11101 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11101"},"text":"section 11101 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc4099443-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc4099444-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadline for Implementation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dU/tI/s112/c"},"text":"Pub. L. 117–328, div. U, title I, § 112(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5414"},"text":"136 Stat. 5414","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dU/tI/s112/c"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Secretary of Veterans Affairs shall commence the implementation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7414"},"text":"section 7414 of title 38","children":[],"tail":", United States Code, as added by subsection (a), by the following dates:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to subsections (a), (c)(2), (d), and (f) of such section, not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to subsection (c)(1) of such section, not later than one year after the date of the enactment of this Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to subsection (b)(2) of such section, not later than 18 months after the date of the enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc4099445-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Audits and Reports","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dU/tI/s112/d"},"text":"Pub. L. 117–328, div. U, title I, § 112(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5414"},"text":"136 Stat. 5414","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dU/tI/s112/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Audits.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Veterans Affairs shall carry out annual audits of the compliance of medical centers of the Department of Veterans Affairs with the matters required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7414"},"text":"section 7414 of title 38","children":[],"tail":", United States Code, as added by subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conduct of audits","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out audits under subparagraph (A), the Secretary—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not authorize the medical center being audited to conduct the audit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may enter into an agreement with another department or agency of the Federal Government or a nongovernmental entity to conduct such audits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than one year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":"], and annually thereafter for five years, the Secretary of Veterans Affairs shall submit to the Committee on Veterans’ Affairs of the Senate and the Committee on Veterans’ Affairs of the House of Representatives a report on the audits conducted under paragraph (1)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each report submitted under subparagraph (A) shall include a summary of the compliance by each medical center of the Department of Veterans Affairs with the matters required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7414"},"text":"section 7414 of title 38","children":[],"tail":", United States Code, as added by subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Initial report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall include in the first report submitted under subparagraph (A) the following:","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the progress made by the Secretary in implementing ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7414"},"text":"section 7414 of title 38","children":[],"tail":", United States Code, as added by subsection (a), including any matters under such section that the Secretary has not fully implemented."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An analysis of the feasibility, advisability, and cost of requiring credentialing employees of the Department to be trained by an outside entity and to maintain a credentialing certification.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
