{"tag":"section","attrib":{"id":"idc313e943-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1803"},"text":null,"children":[{"tag":"num","attrib":{"value":"1803"},"text":"§ 1803.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health care","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc313e944-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1803/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In accordance with regulations which the Secretary shall prescribe, the Secretary shall provide a child of a Vietnam veteran who is suffering from spina bifida with health care under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc313e945-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1803/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may provide health care under this section directly or by contract or other arrangement with any health care provider.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc313e946-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1803/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc313e947-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1803/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “health care”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc313e948-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1803/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means home care, hospital care, nursing home care, outpatient care, preventive care, habilitative and rehabilitative care, case management, and respite care; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc313e949-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1803/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc313e94a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1803/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the training of appropriate members of a child’s family or household in the care of the child; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc313e94b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1803/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of such pharmaceuticals, supplies, equipment, devices, appliances, assistive technology, direct transportation costs to and from approved sources of health care, and other materials as the Secretary determines necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc313e94c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1803/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “health care provider” includes specialized spina bifida clinics, health care plans, insurers, organizations, institutions, and any other entity or individual furnishing health care services that the Secretary determines are authorized under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc313e94d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1803/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “home care” means outpatient care, habilitative and rehabilitative care, preventive health services, and health-related services furnished to an individual in the individual’s home or other place of residence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc313e94e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1803/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “hospital care” means care and treatment for a disability furnished to an individual who has been admitted to a hospital as a patient.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc313e94f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1803/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “nursing home care” means care and treatment for a disability furnished to an individual who has been admitted to a nursing home as a resident.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc313e950-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1803/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “outpatient care” means care and treatment of a disability, and preventive health services, furnished to an individual other than hospital care or nursing home care.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc313e951-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1803/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “preventive care” means care and treatment furnished to prevent disability or illness, including periodic examinations, immunizations, patient health education, and such other services as the Secretary determines necessary to provide effective and economical preventive health care.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc313e952-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1803/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “habilitative and rehabilitative care” means such professional, counseling, and guidance services and treatment programs (other than vocational training under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1804"},"text":"section 1804 of this title","children":[],"tail":") as are necessary to develop, maintain, or restore, to the maximum extent practicable, the functioning of a disabled person."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc313e953-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1803/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “respite care” means care furnished on an intermittent basis for a limited period to an individual who resides primarily in a private residence when such care will help the individual to continue residing in such private residence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc313e954-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/204/tIV/s421/b/1"},"text":"Pub. L. 104–204, title IV, § 421(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-26"},"text":"Sept. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2923"},"text":"110 Stat. 2923","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/368/tX/s1005/b/4"},"text":"Pub. L. 105–368, title X, § 1005(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3365"},"text":"112 Stat. 3365","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/387/tIV/s408/a"},"text":"Pub. L. 110–387, title IV, § 408(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4130"},"text":"122 Stat. 4130","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc313e955-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc313e956-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc313e957-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1803 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3703"},"text":"section 3703 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc313e958-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/387"},"text":"Pub. L. 110–387","children":[],"tail":" substituted “health care under this section” for “such health care as the Secretary determines is needed by the child for the spina bifida or any disability that is associated with such condition”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368"},"text":"Pub. L. 105–368","children":[],"tail":" substituted “furnishing health care services that the Secretary determines are authorized” for “who furnishes health care that the Secretary determines authorized”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc313e959-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc313e95a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/387/tIV/s408/b"},"text":"Pub. L. 110–387, title IV, § 408(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4130"},"text":"122 Stat. 4130","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/387/tIV/s408/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply with respect to care furnished after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
