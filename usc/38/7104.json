{"tag":"section","attrib":{"id":"idc3ea9ac5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7104"},"text":null,"children":[{"tag":"num","attrib":{"value":"7104"},"text":"§ 7104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction of the Board; decisions; notice","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3ea9ac6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All questions in a matter which under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s511/a"},"text":"section 511(a) of this title","children":[],"tail":" is subject to decision by the Secretary shall be subject to one review on appeal to the Secretary. Final decisions on such appeals shall be made by the Board. Decisions of the Board shall be based on the entire record in the proceeding and upon consideration of all evidence and material of record and applicable provisions of law and regulation."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3ea9ac7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5108"},"text":"section 5108 of this title","children":[],"tail":", when a claim is disallowed by the Board, the claim may not thereafter be readjudicated and allowed and a claim based upon the same factual basis may not be considered."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3ea9ac8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board shall be bound in its decisions by the regulations of the Department, instructions of the Secretary, and the precedent opinions of the chief legal officer of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3ea9ac9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7104/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each decision of the Board shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3ea9aca-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7104/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a written statement of the Board’s findings and conclusions, and the reasons or bases for those findings and conclusions, on all material issues of fact and law presented on the record;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ea9acb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7104/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a general statement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3ea9acc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7104/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reflecting whether evidence was not considered in making the decision because the evidence was received at a time when not permitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7113"},"text":"section 7113 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3ea9acd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7104/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" noting such options as may be available for having the evidence considered by the Department; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ea9ace-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7104/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an order granting appropriate relief or denying relief.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3ea9acf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7104/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" After reaching a decision on an appeal, the Board shall promptly issue notice (as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5100"},"text":"section 5100 of this title","children":[],"tail":") of such decision to the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3ea9ad0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7104/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The appellant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ea9ad1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7104/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other party with a right to notice of such decision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ea9ad2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7104/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any authorized representative of the appellant or party described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3ea9ad3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7104/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3ea9ad4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7104/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may provide notice under subsection (e) electronically if a claimant (or the claimant’s representative) elects to receive such notice electronically.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ea9ad5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7104/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A claimant (or the claimant’s representative) may revoke such an election at any time, by means prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3ea9ad6-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1241"},"text":"72 Stat. 1241","children":[],"tail":", § 4004; "},{"tag":"ref","attrib":{"href":"/us/pl/87/97/s1"},"text":"Pub. L. 87–97, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-07-20"},"text":"July 20, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/215"},"text":"75 Stat. 215","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/687/dA/tI/s101/b"},"text":"Pub. L. 100–687, div. A, title I, § 101(b)","children":[],"tail":", title II, §§ 203(a), 204, 205, "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4106"},"text":"102 Stat. 4106","children":[],"tail":", 4110, 4111; renumbered § 7104 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", (d)(1), "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":", 239; "},{"tag":"ref","attrib":{"href":"/us/pl/102/54/s14/g/2"},"text":"Pub. L. 102–54, § 14(g)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-06-13"},"text":"June 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/288"},"text":"105 Stat. 288","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/3"},"text":"Pub. L. 102–83, § 4(a)(3)","children":[],"tail":", (4), (b)(1), (2)(E), (c), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404-406"},"text":"105 Stat. 404–406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/271"},"text":"Pub. L. 103–271","children":[],"tail":", §§ 7(b)(1), 8, "},{"tag":"date","attrib":{"date":"1994-07-01"},"text":"July 1, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/743"},"text":"108 Stat. 743","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/275/tV/s509"},"text":"Pub. L. 104–275, title V, § 509","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3344"},"text":"110 Stat. 3344","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/55/s2/p"},"text":"Pub. L. 115–55, § 2(p)","children":[],"tail":", (w)(2), "},{"tag":"date","attrib":{"date":"2017-08-23"},"text":"Aug. 23, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1111"},"text":"131 Stat. 1111","children":[],"tail":", 1114; "},{"tag":"ref","attrib":{"href":"/us/pl/117/168/tVIII/s807/a/5"},"text":"Pub. L. 117–168, title VIII, § 807(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-10"},"text":"Aug. 10, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1806"},"text":"136 Stat. 1806","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3ea9ad7-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3ea9ad8-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3ea9ad9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/168/s807/a/5/A"},"text":"Pub. L. 117–168, § 807(a)(5)(A)","children":[],"tail":", inserted “; decisions; notice” after “Board” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/168/s807/a/5/B"},"text":"Pub. L. 117–168, § 807(a)(5)(B)","children":[],"tail":", added subsecs. (e) and (f) and struck out former subsec. (e) which related to mailing a copy of a written decision to the claimant or mailing or otherwise sending a copy to an authorized representative of the claimant."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/55/s2/p"},"text":"Pub. L. 115–55, § 2(p)","children":[],"tail":", substituted “readjudicated” for “reopened”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/55/s2/w/2"},"text":"Pub. L. 115–55, § 2(w)(2)","children":[],"tail":", added par. (2) and redesignated former par. (2) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/275"},"text":"Pub. L. 104–275","children":[],"tail":" amended subsec. (e) generally. Prior to amendment, subsec. (e) read as follows: “After reaching a decision in a case, the Board shall promptly mail a copy of its written decision to the claimant and the claimant’s authorized representative (if any) at the last known address of the claimant and at the last known address of such representative (if any).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/271/s8"},"text":"Pub. L. 103–271, § 8","children":[],"tail":", substituted “511(a)” for “211(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/271/s7/b/1"},"text":"Pub. L. 103–271, § 7(b)(1)","children":[],"tail":", struck out after second sentence “The Board shall decide any such appeal only after affording the claimant an opportunity for a hearing.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/b/1"},"text":"Pub. L. 102–40, § 402(b)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4004"},"text":"section 4004 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/54"},"text":"Pub. L. 102–54","children":[],"tail":" made a technical correction to "},{"tag":"ref","attrib":{"href":"/us/pl/100/687/s101/b"},"text":"Pub. L. 100–687, § 101(b)","children":[],"tail":". See 1988 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/d/1"},"text":"Pub. L. 102–40, § 402(d)(1)","children":[],"tail":", substituted “5108” for “3008”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/c"},"text":"Pub. L. 102–83, § 4(c)","children":[],"tail":", substituted “chief legal officer of the Department” for “chief law officer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/3"},"text":"Pub. L. 102–83, § 4(a)(3)","children":[],"tail":", (4), substituted “Department” for “Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/687/s101/b"},"text":"Pub. L. 100–687, § 101(b)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/102/54"},"text":"Pub. L. 102–54","children":[],"tail":", substituted “All questions in a matter which under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s211/a"},"text":"section 211(a) of this title","children":[],"tail":" is subject to decision by the Administrator” for “All questions on claims involving benefits under the laws administered by the Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/687/s203/a"},"text":"Pub. L. 100–687, § 203(a)","children":[],"tail":", inserted at end “The Board shall decide any such appeal only after affording the claimant an opportunity for a hearing. Decisions of the Board shall be based on the entire record in the proceeding and upon consideration of all evidence and material of record and applicable provisions of law and regulation.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/687/s204"},"text":"Pub. L. 100–687, § 204","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “When a claim is disallowed by the Board, it may not thereafter be reopened and allowed, and no claim based upon the same factual basis shall be considered; however, where subsequent to disallowance of a claim, new and material evidence in the form of official reports from the proper service department is secured, the Board may authorize the reopening of the claim and review of the former decision.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/687/s205"},"text":"Pub. L. 100–687, § 205","children":[],"tail":", added subsecs. (d) and (e) and struck out former subsec. (d) which read as follows: “The decisions of the Board shall be in writing and shall contain findings of fact and conclusions of law separately stated.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1961—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/97"},"text":"Pub. L. 87–97","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3ea9ada-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3ea9adb-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/55"},"text":"Pub. L. 115–55","children":[],"tail":" applicable to all claims for which the Secretary of Veterans Affairs provides notice of a decision under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5104"},"text":"section 5104 of this title","children":[],"tail":" on or after the later of 540 days after "},{"tag":"date","attrib":{"date":"2017-08-23"},"text":"Aug. 23, 2017","children":[],"tail":", or 30 days after the date on which the Secretary submits to Congress a certification of certain capabilities of the Department of Veterans Affairs to carry out the new appeals system established by "},{"tag":"ref","attrib":{"href":"/us/pl/115/55"},"text":"Pub. L. 115–55","children":[],"tail":" and to address appeals of decisions on legacy claims, with provision for early applicability of the new appeals system to certain claims, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/55/s2/x"},"text":"section 2(x) of Pub. L. 115–55","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of this title","children":[],"tail":", and bracketed note thereunder."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3ea9adc-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/54/s14/g/2"},"text":"Pub. L. 102–54, § 14(g)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-06-13"},"text":"June 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/288"},"text":"105 Stat. 288","children":[],"tail":", provided that the amendment made by that section is effective "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3ea9add-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by sections 101(b) and 204 of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/687"},"text":"Pub. L. 100–687","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1989-09-01"},"text":"Sept. 1, 1989","children":[],"tail":", and amendment by sections 203(a) and 205 of "},{"tag":"ref","attrib":{"href":"/us/pl/100/687"},"text":"Pub. L. 100–687","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1989-01-01"},"text":"Jan. 1, 1989","children":[],"tail":", see section 401(a), (d) of "},{"tag":"ref","attrib":{"href":"/us/pl/100/687"},"text":"Pub. L. 100–687","children":[],"tail":", as amended, set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7251"},"text":"section 7251 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3ea9ade-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1961 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/87/97/s2"},"text":"Pub. L. 87–97, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-07-20"},"text":"July 20, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/215"},"text":"75 Stat. 215","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/87/97/s2"},"text":"“The amendment made by this Act [amending this section] shall take effect as of ","children":[{"tag":"date","attrib":{"date":"1962-01-01"},"text":"January 1, 1962","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3ea9adf-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/168"},"text":"Pub. L. 117–168","children":[],"tail":" not to be construed to apply "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5104/a"},"text":"section 5104(a) of this title","children":[],"tail":" to decisions of the Board of Veterans’ Appeals under chapter 71 of this title, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/168/s807/b"},"text":"section 807(b) of Pub. L. 117–168","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5100"},"text":"section 5100 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
