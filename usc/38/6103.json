two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/328"},"text":"Pub. L. 92–328","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/24"},"text":"Pub. L. 91–24","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1959-09-01"},"text":"September 1, 1959","children":[],"tail":"” for “the date of enactment of this subsection” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1959—Subsecs. (d) and (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/222"},"text":"Pub. L. 86–222","children":[],"tail":" added subsecs. (d) and (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3e5df5e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3e5df5f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1972 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/328"},"text":"Pub. L. 92–328","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1972-06-30"},"text":"June 30, 1972","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/92/328/s301/c"},"text":"section 301(c) of Pub. L. 92–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3713"},"text":"section 3713 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
