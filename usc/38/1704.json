{"tag":"section","attrib":{"id":"idc2dd21b7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1704"},"text":null,"children":[{"tag":"num","attrib":{"value":"1704"},"text":"§ 1704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preventive health services: annual report","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Not later than October 31 each year, the Secretary shall submit to the Committees on Veterans’ Affairs of the Senate and House of Representatives a report on preventive health services. Each such report shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2dd21b8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1704/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A description of the programs and activities of the Department with respect to preventive health services during the preceding fiscal year, including a description of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2dd21b9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1704/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The programs conducted by the Department—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc2dd21ba-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1704/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to educate veterans with respect to health promotion and disease prevention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc2dd21bb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1704/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide veterans with preventive health screenings and other clinical services, with such description setting forth the types of resources used by the Department to conduct such screenings and services and the number of veterans reached by such screenings and services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc2dd21bc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1704/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide veterans each immunization on the recommended adult immunization schedule at the time such immunization is indicated on that schedule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2dd21bd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1704/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The means by which the Secretary addressed the specific preventive health services needs of particular groups of veterans (including veterans with service-connected disabilities, elderly veterans, low-income veterans, women veterans, institutionalized veterans, and veterans who are at risk for mental illness).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2dd21be-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1704/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The manner in which the provision of such services was coordinated with the activities of the Medical and Prosthetic Research Service of the Department and the National Center for Preventive Health.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2dd21bf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1704/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The manner in which the provision of such services was integrated into training programs of the Department, including initial and continuing medical training of medical students, residents, and Department staff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2dd21c0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1704/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The manner in which the Department participated in cooperative preventive health efforts with other governmental and private entities (including State and local health promotion offices and not-for-profit organizations).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2dd21c1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1704/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The specific research carried out by the Department with respect to the long-term relationships among screening activities, treatment, and morbidity and mortality outcomes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2dd21c2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1704/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The cost effectiveness of such programs and activities, including an explanation of the means by which the costs and benefits (including the quality of life of veterans who participate in such programs and activities) of such programs and activities are measured.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2dd21c3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1704/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A specific description of research activities on preventive health services carried out during that period using employees, funds, equipment, office space, or other support services of the Department, with such description setting forth—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2dd21c4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1704/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the source of funds for those activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2dd21c5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1704/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the articles or publications (including the authors of the articles and publications) in which those activities are described;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2dd21c6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1704/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal, State, or local governmental entity or private entity, if any, with which such activities were carried out; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2dd21c7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1704/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the clinical, research, or staff education projects for which funding applications were submitted (including the source of the funds applied for) and upon which a decision is pending or was denied.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2dd21c8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1704/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An accounting of the expenditure of funds during that period by the National Center for Preventive Health under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7318"},"text":"section 7318 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2dd21c9-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/585/tV/s512/a"},"text":"Pub. L. 102–585, title V, § 512(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4957"},"text":"106 Stat. 4957","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/315/tVI/s602/b"},"text":"Pub. L. 114–315, title VI, § 602(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1569"},"text":"130 Stat. 1569","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2dd21ca-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc2dd21cb-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc2dd21cc-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Par. (1)(A)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/315"},"text":"Pub. L. 114–315","children":[],"tail":" added cl. (iii)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc2dd21cd-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc2dd21ce-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Nothing in amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/315"},"text":"Pub. L. 114–315","children":[],"tail":" to be construed to require a veteran to receive an immunization that the veteran does not want to receive, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/315/s602/d"},"text":"section 602(d) of Pub. L. 114–315","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1701"},"text":"section 1701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
