{"tag":"section","attrib":{"id":"idc3119fa0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1782"},"text":null,"children":[{"tag":"num","attrib":{"value":"1782"},"text":"§ 1782.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counseling, training, and mental health services for immediate family members and caregivers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3119fa1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1782/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Counseling for Family Members of Veterans Receiving Service-Connected Treatment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of a veteran who is receiving treatment for a service-connected disability pursuant to paragraph (1) or (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1710/a"},"text":"section 1710(a) of this title","children":[],"tail":", the Secretary shall provide to individuals described in subsection (c) such consultation, professional counseling, marriage and family counseling, training, and mental health services as are necessary in connection with that treatment."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3119fa2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1782/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Counseling for Family Members of Veterans Receiving Non-Service-Connected Treatment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of a veteran who is eligible to receive treatment for a non-service-connected disability under the conditions described in paragraph (1), (2), or (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1710/a"},"text":"section 1710(a) of this title","children":[],"tail":", the Secretary may, in the discretion of the Secretary, provide to individuals described in subsection (c) such consultation, professional counseling, marriage and family counseling, training, and mental health services as are necessary in connection with that treatment."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3119fa3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1782/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Individuals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Individuals who may be provided services under this subsection are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3119fa4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1782/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the members of the immediate family or the legal guardian of a veteran;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3119fa5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1782/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a family caregiver of an eligible veteran or a caregiver of a covered veteran (as those terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1720G"},"text":"section 1720G of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3119fa6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1782/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual in whose household such veteran certifies an intention to live.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3119fa7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1782/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Travel and Transportation Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Services provided under subsections (a) and (b) may include, under the terms and conditions set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s111"},"text":"section 111 of this title","children":[],"tail":", travel and incidental expenses of individuals described in subsection (c) in the case of any of the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3119fa8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1782/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A veteran who is receiving care for a service-connected disability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3119fa9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1782/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A dependent or survivor receiving care under the last sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1783/b"},"text":"section 1783(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3119faa-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/135/tII/s208/b"},"text":"Pub. L. 107–135, title II, § 208(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-23"},"text":"Jan. 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2462"},"text":"115 Stat. 2462","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/387/tIII/s301/a/2"},"text":"Pub. L. 110–387, title III, § 301(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4120"},"text":"122 Stat. 4120","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/163/tI/s103/a"},"text":"Pub. L. 111–163, title I, § 103(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2010-05-05"},"text":"May 5, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1139"},"text":"124 Stat. 1139","children":[],"tail":", 1140.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3119fab-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3119fac-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc3119fad-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1782 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3682"},"text":"section 3682 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3119fae-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163/s103/b"},"text":"Pub. L. 111–163, § 103(b)","children":[],"tail":", inserted “and caregivers” after “members” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163/s103/a"},"text":"Pub. L. 111–163, § 103(a)","children":[],"tail":", added par. (2) and redesignated former par. (2) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/387/s301/a/2/A"},"text":"Pub. L. 110–387, § 301(a)(2)(A)","children":[],"tail":", inserted “marriage and family counseling,” after “professional counseling,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/387/s301/a/2/B"},"text":"Pub. L. 110–387, § 301(a)(2)(B)","children":[],"tail":", inserted “marriage and family counseling,” after “professional counseling,” and substituted period at end for “if—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) those services were initiated during the veteran’s hospitalization; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the continued provision of those services on an outpatient basis is essential to permit the discharge of the veteran from the hospital.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
