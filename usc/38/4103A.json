(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-21"},"text":"Dec. 21, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/920"},"text":"115 Stat. 920","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/288/s4/b/1"},"text":"Pub. L. 107–288, § 4(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-07"},"text":"Nov. 7, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2043"},"text":"116 Stat. 2043","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/461/tVI/s602/a"},"text":"Pub. L. 109–461, title VI, § 602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3437"},"text":"120 Stat. 3437","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/56/tII"},"text":"Pub. L. 112–56, title II","children":[],"tail":", §§ 234(b), 241(a), "},{"tag":"date","attrib":{"date":"2011-11-21"},"text":"Nov. 21, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/722"},"text":"125 Stat. 722","children":[],"tail":", 728.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3bad7e8-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3bad7e9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3bad7ea-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/56/s234/b/1"},"text":"Pub. L. 112–56, § 234(b)(1)","children":[],"tail":", inserted “and facilitate placements” after “intensive services” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/56/s234/b/2"},"text":"Pub. L. 112–56, § 234(b)(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/56/s241/a"},"text":"Pub. L. 112–56, § 241(a)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461"},"text":"Pub. L. 109–461","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/288"},"text":"Pub. L. 107–288","children":[],"tail":" amended section generally, substituting subsecs. (a) and (b) for former subsecs. (a) to (c) relating to appointment, services and stationing, and functions of disabled veterans’ outreach program specialists."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (c)(11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/95"},"text":"Pub. L. 107–95","children":[],"tail":" added par. (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368"},"text":"Pub. L. 105–368","children":[],"tail":", in first sentence, substituted “for each 7,400 veterans who are between the ages of 20 and 64 residing in such State.” for “for each 6,900 veterans residing in such State who are either veterans of the Vietnam era, veterans who first entered on active duty as a member of the Armed Forces after "},{"tag":"date","attrib":{"date":"1975-05-07"},"text":"May 7, 1975","children":[],"tail":", or disabled veterans.”, in third sentence, struck out “of the Vietnam era” after “disabled veterans”, and struck out after third sentence “If the Secretary finds that a qualified disabled veteran of the Vietnam era is not available for any such appointment, preference for such appointment shall be given to other qualified disabled veterans.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s101/f/tVIII/s405/f/21/B"},"text":"Pub. L. 105–277, § 101(f) [title VIII, § 405(f)(21)(B)]","children":[],"tail":", struck out “part C of title IV of the Job Training Partnership Act and” after “training programs including”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s101/f/tVIII/s405/d/29/B"},"text":"Pub. L. 105–277, § 101(f) [title VIII, § 405(d)(29)(B)]","children":[],"tail":", substituted “including part C of title IV of the Job Training Partnership Act and title I of the Workforce Investment Act of 1998” for “(including part C of title IV of the Job Training Partnership Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1501"},"text":"29 U.S.C. 1501","children":[],"tail":" et seq.))”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446"},"text":"Pub. L. 103–446","children":[],"tail":" substituted “rates comparable to those paid other professionals performing essentially similar duties” for “a rate not less than the rate prescribed for an entry level professional”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/568/s501"},"text":"Pub. L. 102–568, § 501","children":[],"tail":", substituted “specialist for each 6,900 veterans residing in such State who are either veterans of the Vietnam era, veterans who first entered on active duty as a member of the Armed Forces after "},{"tag":"date","attrib":{"date":"1975-05-07"},"text":"May 7, 1975","children":[],"tail":", or disabled veterans.” for “specialist for each 5,300 veterans of the Vietnam era and disabled veterans residing in such State.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/568/s503"},"text":"Pub. L. 102–568, § 503","children":[],"tail":", amended subpar. (A) generally. Prior to amendment, subpar. (A) read as follows: “Services to disabled veterans of the Vietnam era who are participating in or have completed a program of vocational rehabilitation under chapter 31 of this title.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2003A"},"text":"section 2003A of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “4102A(b)(5)(A)(i)” for “2002A(b)(5)(A)(i)” in par. (1) and “4104” for “2004” in par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “4103” for “2003” and “1712A” for “612A”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s2/c/4"},"text":"Pub. L. 102–83, § 2(c)(4)","children":[],"tail":", substituted “7723” for “242”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “3687” for “1787”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsecs. (b)(2), (c)(2), (3), (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" substituted “Secretary of Veterans Affairs” and “Department of Veterans Affairs” for “Administrator” and “Veterans’ Administration”, respectively, wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323/s2/e/1/A/i"},"text":"Pub. L. 100–323, § 2(e)(1)(A)(i)","children":[],"tail":", (ii), redesignated par. (2) as (1), substituted “The amount of funds made available for use in a State under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2002A/b/5/A/i"},"text":"section 2002A(b)(5)(A)(i) of this title","children":[],"tail":" shall be sufficient to support the appointment of one disabled veterans’ outreach program specialist for each 5,300 veterans of the Vietnam era and disabled veterans residing in such State.” for “Funds provided for use in a State under this subsection shall be sufficient to support the appointment of one disabled veterans’ outreach program specialist for each 5,300 veterans of the Vietnam era and disabled veterans residing in such State.”, inserted “qualified” before “veteran” in second sentence, inserted “qualified” before “disabled” wherever appearing in third, fourth, and fifth sentences, inserted “qualified” after “any” in fifth sentence, and struck out former par. (1) which read as follows: “The Secretary of Labor, acting through the Assistant Secretary for Veterans’ Employment, shall make available for use in each State, directly or by grant or contract, such funds as may be necessary to support a disabled veterans’ outreach program designed to meet the employment needs of veterans, especially disabled veterans of the Vietnam era.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323/s2/e/1/A/i"},"text":"Pub. L. 100–323, § 2(e)(1)(A)(i)","children":[],"tail":", (iii), redesignated par. (4) as (2) and struck out “paragraph (2) of” after “appointed pursuant to”. Former par. (2) redesignated (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323/s2/e/1/A/i"},"text":"Pub. L. 100–323, § 2(e)(1)(A)(i)","children":[],"tail":", struck out par. (3) which read as follows: “The Secretary, acting through the Assistant Secretary of Labor for Veterans’ Employment, shall also make available for use in the States such funds, in addition to those made available to carry out paragraphs (1) and (2) of this subsection, as may be necessary to support the reasonable expenses of such specialists for training, travel, supplies, and fringe benefits.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323/s2/e/1/A/i"},"text":"Pub. L. 100–323, § 2(e)(1)(A)(i)","children":[],"tail":", redesignated par. (4) as (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323/s2/e/1/A/i"},"text":"Pub. L. 100–323, § 2(e)(1)(A)(i)","children":[],"tail":", struck out par. (5) which read as follows: “The distribution and use of funds provided for use in States under this section shall be subject to the continuing supervision and monitoring of the Assistant Secretary for Veterans’ Employment and shall not be governed by the provisions of any other law, or any regulations prescribed thereunder, that are inconsistent with this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323/s15/c/1"},"text":"Pub. L. 100–323, § 15(c)(1)","children":[],"tail":", substituted “Director for Veterans’ Employment and Training” for “State Director for Veterans’ Employment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323/s7/b/1"},"text":"Pub. L. 100–323, § 7(b)(1)","children":[],"tail":", inserted “(including part C of title IV of the Job Training Partnership Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1501"},"text":"29 U.S.C. 1501","children":[],"tail":" et seq.))” after “programs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323/s7/b/2"},"text":"Pub. L. 100–323, § 7(b)(2)","children":[],"tail":", inserted “(including the program conducted under the Veterans’ Job Training Act ("},{"tag":"ref","attrib":{"href":"/us/pl/98/77"},"text":"Public Law 98–77","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1721"},"text":"29 U.S.C. 1721","children":[],"tail":" note))” after “programs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(9), (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323/s7/b/3"},"text":"Pub. L. 100–323, § 7(b)(3)","children":[],"tail":", added pars. (9) and (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323/s2/e/1/B"},"text":"Pub. L. 100–323, § 2(e)(1)(B)","children":[],"tail":", struck out subsec. (d) which read as follows: “The Secretary of Labor shall administer the program provided for by this section through the Assistant Secretary of Labor for Veterans’ Employment. The Secretary shall monitor the appointment of disabled veterans’ outreach program specialists to ensure compliance with the provisions of subsection (a)(2) of this section with respect to the employment of such specialists.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/306/s305/a/1"},"text":"Pub. L. 97–306, § 305(a)(1)","children":[],"tail":", (3), inserted “, acting through the Assistant Secretary for Veterans’ Employment,” after “Secretary of Labor”, and substituted “available for use in” for “available to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/306/s305/a/4"},"text":"Pub. L. 97–306, § 305(a)(4)","children":[],"tail":", substituted “provided for use in” for “provided to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/306/s305/a/2"},"text":"Pub. L. 97–306, § 305(a)(2)","children":[],"tail":", (3), inserted “, acting through the Assistant Secretary of Labor for Veterans’ Employment,” after “Secretary”, and substituted “available for use in” for “available to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/306/s305/a/5"},"text":"Pub. L. 97–306, § 305(a)(5)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/306/s305/b"},"text":"Pub. L. 97–306, § 305(b)","children":[],"tail":", inserted provision relating to waiver of the limitation on stationing at local employment service offices of disabled veterans’ outreach program specialists and substituted “section 612A” for “section 621A”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/306/s305/c/1"},"text":"Pub. L. 97–306, § 305(c)(1)","children":[],"tail":", substituted “appropriate grantees under other Federal and federally funded employment and training programs” for “prime sponsors under the Comprehensive Employment and Training Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/306/s305/c/2"},"text":"Pub. L. 97–306, § 305(c)(2)","children":[],"tail":", added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/306/s305/d"},"text":"Pub. L. 97–306, § 305(d)","children":[],"tail":", redesignated subsec. (e) as (d) and inserted provision that the Secretary shall monitor the appointment of disabled veterans’ outreach program specialists to ensure compliance with the provisions of subsec. (a)(2) of this section with respect to the employment of such specialists. Former subsec. (d), which provided that persons serving as staff in the disabled veterans outreach program conducted under title III of the Comprehensive Employment and Training Act on the date of enactment of this section would be appointed as disabled veterans’ outreach program specialists in the State in which such individual was so serving, unless the Secretary for good cause shown determined that such individual was not qualified for such appointment, was struck out."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3bad7eb-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3bad7ec-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461/tVI/s602/c"},"text":"Pub. L. 109–461, title VI, § 602(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3437"},"text":"120 Stat. 3437","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/461/tVI/s602/c"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4103A/c"},"text":"Section 4103A(c) of title 38","children":[],"tail":", United States Code, as added by subsection (a), and section 4104(d) of such title, as amended by subsection (b), shall apply with respect to pay periods beginning after the date that is 180 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"d