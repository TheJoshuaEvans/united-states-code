{"tag":"section","attrib":{"id":"idc3bad7da-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4103A"},"text":null,"children":[{"tag":"num","attrib":{"value":"4103A"},"text":"§ 4103A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disabled veterans’ outreach program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3bad7db-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4103A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement for Employment by States of a Sufficient Number of Specialists","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3bad7dc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4103A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to approval by the Secretary, a State shall employ such full- or part-time disabled veterans’ outreach program specialists as the State determines appropriate and efficient to carry out intensive services and facilitate placements under this chapter to meet the employment needs of eligible veterans with the following priority in the provision of services:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3bad7dd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4103A/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Special disabled veterans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bad7de-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4103A/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other disabled veterans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bad7df-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4103A/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other eligible veterans in accordance with priorities determined by the Secretary taking into account applicable rates of unemployment and the employment emphases set forth in chapter 42 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3bad7e0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4103A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the provision of services in accordance with this subsection, maximum emphasis in meeting the employment needs of veterans shall be placed on assisting economically or educationally disadvantaged veterans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3bad7e1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4103A/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In facilitating placement of a veteran under this program, a disabled veterans’ outreach program specialist shall help to identify job opportunities that are appropriate for the veteran’s employment goals and assist that veteran in developing a cover letter and resume that are targeted for those particular jobs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3bad7e2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4103A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement for Qualified Veterans","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A State shall, to the maximum extent practicable, employ qualified veterans to carry out the services referred to in subsection (a). Preference shall be given in the appointment of such specialists to qualified disabled veterans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3bad7e3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4103A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Part-Time Employees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A part-time disabled veterans’ outreach program specialist shall perform the functions of a disabled veterans’ outreach program specialist under this section on a half-time basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3bad7e4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4103A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Requirement for Full-time Employees","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3bad7e5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4103A/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A full-time disabled veterans’ outreach program specialist shall perform only duties related to meeting the employment needs of eligible veterans, as described in subsection (a), and shall not perform other non-veteran-related duties that detract from the specialist’s ability to perform the specialist’s duties related to meeting the employment needs of eligible veterans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3bad7e6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4103A/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall conduct regular audits to ensure compliance with paragraph (1). If, on the basis of such an audit, the Secretary determines that a State is not in compliance with paragraph (1), the Secretary may reduce the amount of a grant made to the State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4102A/b/5"},"text":"section 4102A(b)(5) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3bad7e7-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466/tV/s506/a"},"text":"Pub. L. 96–466, title V, § 506(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2204"},"text":"94 Stat. 2204","children":[],"tail":", § 2003A; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/306/tIII/s305"},"text":"Pub. L. 97–306, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-14"},"text":"Oct. 14, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1439"},"text":"96 Stat. 1439","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/323"},"text":"Pub. L. 100–323","children":[],"tail":", §§ 2(e)(1), 7(b), 15(c)(1), "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/559"},"text":"102 Stat. 559","children":[],"tail":", 565, 574; "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIV/s423/b/8"},"text":"Pub. L. 101–237, title IV, § 423(b)(8)","children":[],"tail":", "},{"tag":"date","attrib"