{"tag":"section","attrib":{"id":"idc3d2cc7b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5111"},"text":null,"children":[{"tag":"num","attrib":{"value":"5111"},"text":"§ 5111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencement of period of payment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3d2cc7c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5111/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3d2cc7d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5111/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5110"},"text":"section 5110 of this title","children":[],"tail":" or any other provision of law and except as provided in paragraph (2) and subsection (c), payment of monetary benefits based on an award or an increased award of compensation, dependency and indemnity compensation, or pension may not be made to an individual for any period before the first day of the calendar month following the month in which the award or increased award became effective as provided under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5110"},"text":"section 5110 of this title","children":[],"tail":" or such other provision of law."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d2cc7e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5111/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3d2cc7f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5111/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a veteran who is retired or separated from the active military, naval, air, or space service for a catastrophic disability or disabilities, payment of monetary benefits based on an award of compensation based on an original claim shall be made as of the date on which such award becomes effective as provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5110"},"text":"section 5110 of this title","children":[],"tail":" or another applicable provision of law."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3d2cc80-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5111/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of this paragraph, the term “catastrophic disability”, with respect to a veteran, means a permanent, severely disabling injury, disorder, or disease that compromises the ability of the veteran to carry out the activities of daily living to such a degree that the veteran requires personal or mechanical assistance to leave home or bed, or requires constant supervision to avoid physical harm to self or others.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d2cc81-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5111/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3d2cc82-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5111/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2) of this subsection, during the period between the effective date of an award or increased award as provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5110"},"text":"section 5110 of this title","children":[],"tail":" or other provision of law and the commencement of the period of payment based on such award as provided under subsection (a) of this section, an individual entitled to receive monetary benefits shall be deemed to be in receipt of such benefits for the purpose of all laws administered by the Secretary."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d2cc83-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5111/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If any person who is in receipt of retired or retirement pay would also be eligible to receive compensation or pension upon the filing of a waiver of such pay in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5305"},"text":"section 5305 of this title","children":[],"tail":", such waiver shall not become effective until the first day of the month following the month in which such waiver is filed, and nothing in this section shall prohibit the receipt of retired or retirement pay for any period before such effective date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d2cc84-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5111/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3d2cc85-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5111/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall not apply to payments made pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5310"},"text":"section 5310 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d2cc86-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5111/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a temporary increase in compensation for hospitalization or treatment where such hospitalization or treatment commences and terminates within the same calendar month, the period of payment shall commence on the first day of such month.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d2cc87-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5111/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purposes of this section, the term “award or increased award” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3d2cc88-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5111/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an original award or award based on a supplemental claim; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d2cc89-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5111/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an award that is increased because of an added dependent, increase in disability or disability rating, or reduction in income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3d2cc8a-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/253/tIV/s401/a/1"},"text":"Pub. L. 97–253, title IV, § 401(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-08"},"text":"Sept. 8, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/801"},"text":"96 Stat. 801","children":[],"tail":", § 3011; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/223/tI/s113"},"text":"Pub. L. 98–223, title I, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-03-02"},"text":"Mar. 2, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/40"},"text":"98 Stat. 40","children":[],"tail":"; renumbered § 5111 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", (d)(1), "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":", 239; "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/1"},"text":"Pub. L. 102–83, § 4(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/403"},"text":"105 Stat. 403","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/275/tVI/s605/a"},"text":"Pub. L. 111–275, title VI, § 605(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-13"},"text":"Oct. 13, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2885"},"text":"124 Stat. 2885","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/154/tV/s507/b"},"text":"Pub. L. 112–154, title V, § 507(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1194"},"text":"126 Stat. 1194","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/55/s2/m"},"text":"Pub. L. 115–55, § 2(m)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-23"},"text":"Aug. 23, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1110"},"text":"131 Stat. 1110","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s926/a/53"},"text":"Pub. L. 116–283, div. A, title IX, § 926(a)(53)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3830"},"text":"134 Stat. 3830","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3d2cc8b-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3d2cc8c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3d2cc8d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “air, or space service” for “or air service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/55"},"text":"Pub. L. 115–55","children":[],"tail":" substituted “award or award based on a supplemental claim” for “or reopened award”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/154"},"text":"Pub. L. 112–154","children":[],"tail":" substituted “not apply to payments made pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5310"},"text":"section 5310 of this title","children":[],"tail":"” for “apply to payments made pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5310"},"text":"section 5310 of this title","children":[],"tail":" only if the monthly amount of dependency and indemnity compensation or pension payable to the surviving spouse is greater than the amount of compensation or pension the veteran would have received, but for such veteran’s death, for the month in which such veteran’s death occurred”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/275"},"text":"Pub. L. 111–275","children":[],"tail":" designated existing provisions as par. (1), substituted “in paragraph (2) and subsection (c)” for “in subsection (c) of this section”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/b/1"},"text":"Pub. L. 102–40, § 402(b)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3011"},"text":"section 3011 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/d/1"},"text":"Pub. L. 102–40, § 402(d)(1)","children":[],"tail":", substituted “5110” for “3010” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" substituted “administered by the Secretary” for “administered by the Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/d/1"},"text":"Pub. L. 102–40, § 402(d)(1)","children":[],"tail":", substituted “5110” for “3010”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/d/1"},"text":"Pub. L. 102–40, § 402(d)(1)","children":[],"tail":", substituted “5305” for “3105”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/d/1"},"text":"Pub. L. 102–40, § 402(d)(1)","children":[],"tail":", substituted “5310” for “3110”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/223"},"text":"Pub. L. 98–223","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3d2cc8e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3d2cc8f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/55"},"text":"Pub. L. 115–55","children":[],"tail":" applicable to all claims for which the Secretary of Veterans Affairs provides notice of a decision under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5104"},"text":"section 5104 of this title","children":[],"tail":" on or after the later of 540 days after "},{"tag":"date","attrib":{"date":"2017-08-23"},"text":"Aug. 23, 2017","children":[],"tail":", or 30 days after the date on which the Secretary submits to Congress a certification of certain capabilities of the Department of Veterans Affairs to carry out the new appeals system established by "},{"tag":"ref","attrib":{"href":"/us/pl/115/55"},"text":"Pub. L. 115–55","children":[],"tail":" and to address appeals of decisions on legacy claims, with provision for early applicability of the new appeals system to certain claims, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/55/s2/x"},"text":"section 2(x) of Pub. L. 115–55","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of this title","children":[],"tail":", and bracketed note thereunder."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3d2cc90-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/154/tV/s507/c"},"text":"Pub. L. 112–154, title V, § 507(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1194"},"text":"126 Stat. 1194","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/154/tV/s507/c"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5310"},"text":"section 5310 of this title","children":[],"tail":"] shall take effect on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":"], and shall apply with respect to deaths that occur on or after that date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3d2cc91-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/275/tVI/s605/b"},"text":"Pub. L. 111–275, title VI, § 605(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-13"},"text":"Oct. 13, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2886"},"text":"124 Stat. 2886","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/275/tVI/s605/b"},"text":"“The amendments made by subsection (a) [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2011-10-01"},"text":"October 1, 2011","children":[],"tail":", and shall apply with respect to awards of compensation based on original claims that become effective on or after that date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3d2cc92-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/223"},"text":"Pub. L. 98–223","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1983-10-01"},"text":"Oct. 1, 1983","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/223/s114"},"text":"section 114 of Pub. L. 98–223","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1112"},"text":"section 1112 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3d2cc93-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/253/tIV/s401/b"},"text":"Pub. L. 97–253, title IV, § 401(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-08"},"text":"Sept. 8, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/802"},"text":"96 Stat. 802","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/253/tIV/s401/b"},"text":"“Section 3011 [now 5111] of title 38, United States Code, as added by subsection (a), shall apply to awards and increased awards the effective dates of which are after ","children":[{"tag":"date","attrib":{"date":"1982-09-30"},"text":"September 30, 1982","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
