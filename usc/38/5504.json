{"tag":"section","attrib":{"id":"idc3dc420e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5504"},"text":null,"children":[{"tag":"num","attrib":{"value":"5504"},"text":"§ 5504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of trust funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All cash balances in the personal funds of patients and the funds due incompetent beneficiaries trust funds administered by the Secretary, and all moneys received which are properly for deposit into these funds, may be deposited, respectively, into deposit fund accounts with the United States Treasury and such balances and deposits shall thereupon be available for disbursement for properly authorized purposes. When any balances have been on deposit with the Treasurer of the United States for more than one year and represent moneys belonging to individuals whose whereabouts are unknown, they shall be transferred and disposed of as directed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1322/a"},"text":"section 1322(a) of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc3dc420f-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1235"},"text":"72 Stat. 1235","children":[],"tail":", § 3204; "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s3/k/5"},"text":"Pub. L. 97–258, § 3(k)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1065"},"text":"96 Stat. 1065","children":[],"tail":"; renumbered § 5504, "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"tex