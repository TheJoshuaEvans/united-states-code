te":"1985-07-01"},"text":"July 1, 1985","children":[],"tail":", with respect to individuals discharged or released for medical condition which preexisted service on active duty or in Selected Reserve and which Administrator determines is not service connected, and effective "},{"tag":"date","attrib":{"date":"1987-10-01"},"text":"Oct. 1, 1987","children":[],"tail":", with respect to individuals involuntarily discharged or released for convenience of Government as a result of reduction in force, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/689/s102/c"},"text":"section 102(c) of Pub. L. 100–689","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3011"},"text":"section 3011 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3d787a2-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-10-17"},"text":"Oct. 17, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/66/s701/b/1"},"text":"section 701(b)(1) of Pub. L. 97–66","children":[],"tail":", set out as an Effective Date of 1981 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1114"},"text":"section 1114 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3d787a3-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Delayed Application of Exclusion; Additional Wages Considered Benefit","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/306/tIV/s408/b"},"text":"Pub. L. 97–306, title IV, § 408(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-14"},"text":"Oct. 14, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1446"},"text":"96 Stat. 1446","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/306/tIV/s408/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (d) of section 3103A [now 5303A] of title 38, United States Code, as added by subsection (a)(2), shall not apply with respect to the receipt by any person of any benefit provided by or pursuant to law before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1982-10-14"},"text":"Oct. 14, 1982","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of paragraph (1) of this subsection, additional wages deemed to have been paid under section 229(a) of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s429/a"},"text":"42 U.S.C. 429(a)","children":[],"tail":") shall be considered to be a benefit that was received by a person on the date that such person was discharged or released from active duty (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s101/21"},"text":"section 101(21) of title 38","children":[],"tail":", United States Code).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3d787a4-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Scope of Exclusion","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/306/tIV/s408/d"},"text":"Pub. L. 97–306, title IV, § 408(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-14"},"text":"Oct. 14, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1446"},"text":"96 Stat. 1446","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/306/tIV/s408/d"},"text":"“Section 3103A [now 5303A] of title 38, United States Code, as amended by subsection (a), is the law with respect to the matters stated in such section and applies, in accordance with its terms, with respect to benefits under Federal law, regardless of the particular title of the United States Code or other law under which any such benefit is provided or the department, agency, or instrumentality which administers any such benefit.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3d787a5-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Applicability","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/66/tVI/s604/b"},"text":"Pub. L. 97–66, title VI, § 604(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-10-17"},"text":"Oct. 17, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1036"},"text":"95 Stat. 1036","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/66/tVI/s604/b"},"text":"“Section 5303A [formerly 3103A] of title 38, United States Code, as added by subsection (a), shall not apply with respect to the receipt by any person of any benefit provided by or pursuant to law before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1981-10-17"},"text":"Oct. 17, 1981","children":[],"tail":"]. Notwithstanding such section, a person who before such date has received a certificate of eligibility from the Administrator of Veterans’ Affairs [now Secretary of Veterans Affairs] for benefits under chapter 37 of title 38, United States Code, is eligible for such benefits after such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
