/100/689"},"text":"Pub. L. 100–689","children":[],"tail":" amended subpar. (F) generally. Prior to amendment, subpar. (F) read as follows: “to benefits under chapter 30 of this title in the case of a person entitled to benefits under such chapter by reason of "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1411/a/1/A/ii/II"},"text":"section 1411(a)(1)(A)(ii)(II) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b)(3)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576"},"text":"Pub. L. 99–576","children":[],"tail":" added subpar. (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/306/s408/a/1"},"text":"Pub. L. 97–306, § 408(a)(1)","children":[],"tail":", substituted “after "},{"tag":"date","attrib":{"date":"1981-10-16"},"text":"October 16, 1981","children":[],"tail":",” for “on or after the date of the enactment of the Veterans’ Disability Compensation, Housing, and Memorial Benefits Amendments of 1981”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/306/s408/a/2"},"text":"Pub. L. 97–306, § 408(a)(2)","children":[],"tail":", added subsec. (d) and redesignated former subsec. (d) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/306/s408/a/3"},"text":"Pub. L. 97–306, § 408(a)(3)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3d7879e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3d7879f-47c4-11f1-bf59-9680b1269b87"},"text":null,"