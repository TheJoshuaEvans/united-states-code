), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/403-406"},"text":"105 Stat. 403–406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/353/s3"},"text":"Pub. L. 103–353, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3169"},"text":"108 Stat. 3169","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/446/tIX/s908"},"text":"Pub. L. 103–446, title IX, § 908","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4678"},"text":"108 Stat. 4678","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/368/tX/s1005/b/15"},"text":"Pub. L. 105–368, title X, § 1005(b)(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3365"},"text":"112 Stat. 3365","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/315/tVII/s703"},"text":"Pub. L. 114–315, title VII, § 703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1585"},"text":"130 Stat. 1585","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3d7879a-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3d7879b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc3d7879c-47c4-11f1-bf