{"tag":"section","attrib":{"id":"idc3d78774-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5303A"},"text":null,"children":[{"tag":"num","attrib":{"value":"5303A"},"text":"§ 5303A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum active-duty service requirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3d78775-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5303A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, any requirements for eligibility for or entitlement to any benefit under this title or any other law administered by the Secretary that are based on the length of active duty served by a person who initially enters such service after ","children":[{"tag":"date","attrib":{"date":"1980-09-07"},"text":"September 7, 1980","children":[],"tail":", shall be exclusively as prescribed in this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d78776-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5303A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3d78777-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5303A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in paragraph (3) of this subsection, a person described in paragraph (2) of this subsection who is discharged or released from a period of active duty before completing the shorter of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3d78778-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5303A/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 24 months of continuous active duty, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3d78779-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5303A/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the full period for which such person was called or ordered to active duty,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is not eligible by reason of such period of active duty for any benefit under this title or any other law administered by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d7877a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5303A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Paragraph (1) of this subsection applies—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3d7877b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5303A/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any person who originally enlists in a regular component of the Armed Forces after ","children":[{"tag":"date","attrib":{"date":"1980-09-07"},"text":"September 7, 1980","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3d7877c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5303A/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any other person who enters on active duty after ","children":[{"tag":"date","attrib":{"date":"1981-10-16"},"text":"October 16, 1981","children":[],"tail":", and has not previously completed a continuous period of active duty of at least 24 months or been discharged or released from active duty under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1171"},"text":"section 1171 of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d7877d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5303A/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Paragraph (1) of this subsection does not apply—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3d7877e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5303A/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a person who is discharged or released from active duty under section 1171 or 1173 of title 10;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3d7877f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5303A/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a person who is discharged or released from active duty for a disability incurred or aggravated in line of duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3d78780-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5303A/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a person who has a disability that the Secretary has determined to be compensable under chapter 11 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3d78781-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5303A/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the provision of a benefit for or in connection with a service-connected disability, condition, or death;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3d78782-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5303A/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to benefits under chapter 19 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3d78783-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5303A/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to benefits under section 2011, 2012, 2013, 2044, or 2061 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3d78784-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5303A/b/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to benefits under chapter 30 or chapter 37 of this title by reason of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc3d78785-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5303A/b/3/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a discharge or release from active duty for the convenience of the Government, as described in sections 3011(a)(1)(A)(ii)(II) and 3012(b)(1)(A)(iv) of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3d78786-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5303A/b/3/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a discharge or release from active duty for a medical condition which preexisted service on active duty and which the Secretary determines is not service connected, as described in clauses (A)(ii)(I) and (B)(ii)(I) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3011/a/1"},"text":"section 3011(a)(1) of this title","children":[],"tail":" and in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3012/b/1/A/ii"},"text":"section 3012(b)(1)(A)(ii) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3d78787-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5303A/b/3/G/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an involuntary discharge or release from active duty for the convenience of the Government as a result of a reduction in force, as described in clauses (A)(ii)(III) and (B)(ii)(III) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3011/a/1"},"text":"section 3011(a)(1) of this title","children":[],"tail":" and in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3012/b/1/A/v"},"text":"section 3012(b)(1)(A)(v) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3d78788-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5303A/b/3/G/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a discharge or release from active duty for a physical or mental condition that was not characterized as a disability and did not result from the individual’s own willful misconduct but did interfere with the individual’s performance of duty, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3011/a/1/A/ii/I"},"text":"section 3011(a)(1)(A)(ii)(I) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3d78789-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5303A/b/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to benefits under chapter 43 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d7878a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5303A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3d7878b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5303A/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2) of this subsection, no dependent or survivor of a person as to whom subsection (b) of this section requires the denial of benefits shall, by reason of such person’s period of active duty, be provided with any benefit under this title or any other law administered by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d7878c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5303A/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (1) of this subsection does not apply to benefits under chapters 19 and 37 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d7878d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5303A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3d7878e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5303A/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding any other provision of law and except as provided in paragraph (3) of this subsection, a person described in paragraph (2) of this subsection who is discharged or released from a period of active duty before completing the shorter of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3d7878f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5303A/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 24 months of continuous active duty, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3d78790-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5303A/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the full period for which such person was called or ordered to active duty,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is not eligible by reason of such period of active duty for any benefit under Federal law (other than this title or any other law administered by the Secretary), and no dependent or survivor of such person shall be eligible for any such benefit by reason of such period of active duty of such person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d78791-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5303A/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Paragraph (1) of this subsection applies—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3d78792-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5303A/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any person who originally enlists in a regular component of the Armed Forces after ","children":[{"tag":"date","attrib":{"date":"1980-09-07"},"text":"September 7, 1980","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3d78793-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5303A/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any other person who enters on active duty after ","children":[{"tag":"date","attrib":{"date":"1982-10-13"},"text":"October 13, 1982","children":[],"tail":", and has not previously completed a continuous period of active duty of at least 24 months or been discharged or released from active duty under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1171"},"text":"section 1171 of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d78794-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5303A/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Paragraph (1) of this subsection does not apply—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3d78795-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5303A/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any person described in clause (A), (B), or (C) of subsection (b)(3) of this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3d78796-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5303A/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a benefit under (i) the Social Security Act other than additional wages deemed to have been paid, under section 229(a) ","children":[{"tag":"ref","attrib":{"idref":"fn002101"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002101"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Social Security Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s429/a"},"text":"42 U.S.C. 429(a)","children":[],"tail":"), for any calendar quarter beginning after "},{"tag":"date","attrib":{"date":"1982-10-13"},"text":"October 13, 1982","children":[],"tail":", or (ii) title 5 other than a benefit based on meeting the definition of preference eligible in section 2108(3) of such title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d78797-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5303A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of this section, the term “benefit” includes a right or privilege, but does not include a refund of a participant’s contributions to the educational benefits program provided by chapter 32 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d78798-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5303A/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this section shall be construed to deprive any person of any procedural rights, including any rights to assistance in applying for or claiming a benefit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3d78799-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/66/tVI/s604/a/1"},"text":"Pub. L. 97–66, title VI, § 604(a)(1)","children":[],"tail":", "},{"tag":"date",