{"tag":"section","attrib":{"id":"idc26f6b7f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s108"},"text":null,"children":[{"tag":"num","attrib":{"value":"108"},"text":"§ 108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seven-year absence presumption of death","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc26f6b80-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s108/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No State law providing for presumption of death shall be applicable to claims for benefits under laws administered by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc26f6b81-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s108/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If evidence satisfactory to the Secretary is submitted establishing the continued and unexplained absence of any individual from that individual’s home and family for seven or more years, and establishing that after diligent search no evidence of that individual’s existence after the date of disappearance has been found or received, the death of such individual as of the date of the expiration of such period shall be considered as sufficiently proved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc26f6b82-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s108/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except in a suit brought pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1984"},"text":"section 1984 of this title","children":[],"tail":", the finding of death made by the Secretary shall be final and conclusive."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc26f6b83-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1112"},"text":"72 Stat. 1112","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/576/tVII/s701/7"},"text":"Pub. L. 99–576, title VII, § 701(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3291"},"text":"100 Stat. 3291","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":", §§ 4(a)(1), (b)(1), (2)(E), 5(c)(1), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/403-406"},"text":"105 Stat. 403–406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc26f6b84-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc26f6b85-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc26f6b86-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/1"},"text":"Pub. L. 102–83, § 4(a)(1)","children":[],"tail":", substituted “administered by the Secretary” for “administered by the Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “1984” for “784”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576"},"text":"Pub. L. 99–576","children":[],"tail":" substituted “that individual’s” for “his” in two places."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
