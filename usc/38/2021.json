{"tag":"section","attrib":{"id":"idc330993f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021"},"text":null,"children":[{"tag":"num","attrib":{"value":"2021"},"text":"§ 2021.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Homeless veterans reintegration programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3309940-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of appropriations provided for such purpose, the Secretary of Labor shall conduct, directly or through grant or contract, such programs as that Secretary determines appropriate to provide job training, counseling, and placement services (including job readiness and literacy and skills training) to expedite the reintegration into the labor force of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3309941-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" homeless veterans, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3309942-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" veterans who were homeless but found housing during the 60-day period preceding the date on which the veteran begins to participate in a program under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3309943-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" veterans who are at risk of homelessness during the 60-day period beginning on the date on which the veteran begins to participate in a program under this section;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3309944-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" veterans participating in the Department of Housing and Urban Development-Department of Veterans Affairs supported housing program for which rental assistance is provided pursuant to section 8(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(19) of the United States Housing Act of 1937 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f"},"text":"42 U.S.C. 1437f","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(19)) or the Tribal HUD-VA Supportive Housing (Tribal HUD-VASH) program;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3309945-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indians who are veterans and receiving assistance under the Native American Housing Assistance and Self-Determination Act of 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4101"},"text":"25 U.S.C. 4101","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3309946-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" veterans described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2023/d"},"text":"section 2023(d) of this title","children":[],"tail":" or any other veterans who are transitioning from being incarcerated; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3309947-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" veterans participating in the Department of Veterans Affairs rapid rehousing and prevention program authorized in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2044"},"text":"section 2044 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3309948-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grants","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3309949-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In awarding grants for purposes of conducting programs described in subsection (a), the Secretary of Labor shall, to the maximum extent practicable, consider applications for fundable grants from entities in all States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc330994a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In each State in which no entity has been awarded a grant described in paragraph (1) as of the date of the enactment of the Joseph Maxwell Cleland and Robert Joseph Dole Memorial Veterans Benefits and Health Care Improvement Act of 2022, the Secretary of Labor shall, in coordination with the Director of Veterans’ Employment and Training in the State, organize and conduct an outreach and education program to ensure communities are aware of the programs conducted under this section and the benefits of the programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc330994b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training and Technical Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc330994c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Labor shall provide training and technical assistance to entities seeking a grant or contract under this section and recipients of a grant or contract under this section regarding the planning, development, and provision of services for which the grant or contract is awarded, including before and during the grant application or contract award period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc330994d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The training and technical assistance provided under paragraph (1) shall include outreach and assistance specifically designed for entities serving regions and populations underserved by the programs conducted under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc330994e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Labor may provide training and technical assistance under paragraph (1) directly or through grants or contracts with such public or nonprofit private entities as that Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc330994f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement to Monitor Expenditures of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3309950-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Labor shall collect such information as that Secretary considers appropriate to monitor and evaluate the distribution and expenditure of funds appropriated to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3309951-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information collected under paragraph (1) shall include data with respect to the results or outcomes of the services provided to each homeless veteran under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3309952-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information collected under paragraph (1) shall be furnished in such form and manner as the Secretary of Labor may specify.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3309953-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration Through Assistant Secretary of Labor for Veterans’ Employment and Training","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Labor shall carry out this section through the Assistant Secretary of Labor for Veterans’ Employment and Training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3309954-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provision of Services to Veterans in Certain Institutions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3309955-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General of the United States shall permit a recipient of a grant or contract under this section or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2023"},"text":"section 2023 of this title","children":[],"tail":" to provide services under this section or "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2023"},"text":"section 2023 of this title","children":[],"tail":" to any veteran described in subsection (a)(4) who is residing in a penal institution under the jurisdiction of the Bureau of Prisons."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3309956-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The recipient of a grant or contract under this section may provide to officials of an institution described in paragraph (1) information regarding the services provided to veterans under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2023"},"text":"section 2023 of this title","children":[],"tail":" during the 18-month period preceding the release or discharge of a veteran from the institution."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3309957-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report on Services Provided","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3309958-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Labor shall require each recipient of a grant or contract under this section to submit to that Secretary a report on the services provided and veterans served using grant or contract amounts not later than 90 days after the end of each program year, beginning with the program year the ","children":[{"tag":"ref","attrib":{"idref":"fn002043"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002043"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “that”."}],"tail":" begins after the date of the enactment of the Joseph Maxwell Cleland and Robert Joseph Dole Memorial Veterans Benefits and Health Care Improvement Act of 2022."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3309959-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To the extent practicable, each report submitted under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc330995a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" disaggregate the number of veterans served by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc330995b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/g/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sex;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc330995c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/g/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" age;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc330995d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/g/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" race;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc330995e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/g/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ethnicity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc330995f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/g/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approximate era in which the veteran served in the Armed Forces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3309960-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/g/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the highest level of education attained;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3309961-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/g/2/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average period of time the veteran was unemployed or underemployed before receiving services under this section and while receiving such services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3309962-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/g/2/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" housing status as of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc3309963-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/g/2/A/viii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the veteran is first enrolled in services under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc3309964-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/g/2/A/viii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any subsequent date, if such data is available; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3309965-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include data on the number of veterans receiving services under this section who are eligible for health care and benefits provided by the Department of Veterans Affairs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3309966-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3309967-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not less frequently than every two years, the Secretary of Labor shall submit to Congress a report on the programs conducted under this section. The Secretary of Labor shall include in the report the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3309968-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An evaluation of services furnished to veterans under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3309969-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An analysis of the information collected under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc330996a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/h/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An identification of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc330996b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/h/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of applications for grants under this section that the Secretary of Labor received during the fiscal year preceding the date on which the report is submitted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc330996c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/h/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of such applications that were denied.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc330996d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/h/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to each State in which no entity was awarded a grant under this section during the fiscal year preceding the date on which the report is submitted—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc330996e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/h/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of the top five reasons why entities that applied for such a grant were not awarded the grant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc330996f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/h/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information regarding the specific criteria used to score the applications and an explanation of if, how, or why such criteria differed from the previous fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3309970-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than 180 days after the end of the program year that begins after the date of the enactment of the Joseph Maxwell Cleland and Robert Joseph Dole Memorial Veterans Benefits and Health Care Improvement Act of 2022, and not later than 120 days after the end of each program year thereafter, the Secretary of Labor shall submit to the Committee on Veterans’ Affairs of the Senate and the Committee on Veterans’ Affairs of the House of Representatives a report setting forth the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3309971-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Data obtained from the reports submitted under subsection (g), disaggregated by geographic location.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3309972-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of grants and contracts not awarded under this section due to insufficient funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3309973-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of returning recipients of grants or contracts that were and were not awarded grants or contracts under this section during the most recent application cycle.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc332e264-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/h/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of applications received from entities in States in which no entities received a grant or contract under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc332e265-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/h/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of veterans who were admitted to a program conducted under this section but not placed in a job following participation in such program, disaggregated by geographic location, age, sex, and race or ethnicity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc332e266-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc332e267-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" There are authorized to be appropriated to carry out this section amounts as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc332e268-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/i/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,000,000 for fiscal year 2002.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc332e269-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/i/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,000,000 for fiscal year 2003.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc332e26a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/i/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,000,000 for fiscal year 2004.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc332e26b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/i/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,000,000 for fiscal year 2005.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc332e26c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/i/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,000,000 for fiscal year 2006.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc332e26d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/i/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,000,000 for each of fiscal years 2007 through 2023.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc332e26e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/i/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $60,000,000 for fiscal year 2024 and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc332e26f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds appropriated to carry out this section shall remain available until expended. Funds obligated in any fiscal year to carry out this section may be expended in that fiscal year and the succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc332e270-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/95/s5/a/1"},"text":"Pub. L. 107–95, § 5(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-21"},"text":"Dec. 21, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href"