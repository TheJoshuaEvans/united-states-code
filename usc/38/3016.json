{"tag":"section","attrib":{"id":"idc3520397-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3016"},"text":null,"children":[{"tag":"num","attrib":{"value":"3016"},"text":"§ 3016.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inservice enrollment in a program of education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3520398-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3016/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A member of the Armed Forces who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3520399-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3016/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" first becomes a member or first enters on active duty as a member of the Armed Forces after ","children":[{"tag":"date","attrib":{"date":"1985-06-30"},"text":"June 30, 1985","children":[],"tail":", and does not make an election under section 3011(c)(1) or section 3012(d)(1);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc352039a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3016/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" completes at least two years of service on active duty after such date;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc352039b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3016/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after such service, continues on active duty or in the Selected Reserve without a break in service (except as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3012/b/2"},"text":"section 3012(b)(2) of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc352039c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3016/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" but for section 3011(a)(1)(A)(i)(I) ","children":[{"tag":"ref","attrib":{"idref":"fn002050"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002050"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" or 3012(a)(1)(A)(ii) of this title would be eligible for basic educational assistance,"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"may receive educational assistance under this chapter for enrollment in an approved program of education while continuing to perform the duty described in section 3011(a)(1)(A)(i)(I) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" or 3012(a)(1)(A)(ii) of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc352039d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3016/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A member of the Armed Forces who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc352039e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3016/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as of ","children":[{"tag":"date","attrib":{"date":"1989-12-31"},"text":"December 31, 1989","children":[],"tail":", is eligible for educational assistance benefits under chapter 34 of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc352039f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3016/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after ","children":[{"tag":"date","attrib":{"date":"1985-06-30"},"text":"June 30, 1985","children":[],"tail":", has served the two years required by section 3012(a)(1)(B)(i); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc35203a0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3016/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" but for ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3012/a/1/B/ii"},"text":"section 3012(a)(1)(B)(ii) of this title","children":[],"tail":" would be eligible for basic educational assistance,"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"may, after ","children":[{"tag":"date","attrib":{"date":"1989-12-31"},"text":"December 31, 1989","children":[],"tail":", receive educational assistance under this chapter for enrollment in an approved program of education while continuing to perform the duty described in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3012/a/1/B/ii"},"text":"section 3012(a)(1)(B)(ii) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc35203a1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3016/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A member of the Armed Forces who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc35203a2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3016/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" completes at least two years of service on active duty after ","children":[{"tag":"date","attrib":{"date":"1985-06-30"},"text":"June 30, 1985","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc35203a3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3016/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after such service continues on active duty without a break in service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc35203a4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3016/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" but for ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3018/b/3/A"},"text":"section 3018(b)(3)(A) of this title","children":[],"tail":" would be entitled to basic educational assistance under this chapter,"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"may receive such assistance for enrollment in an approved program of education while continuing to perform the service described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3018/b/2"},"text":"section 3018(b)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc35203a5-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/tVII/s702/a/1"},"text":"Pub. L. 98–525, title VII, § 702(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2558"},"text":"98 Stat. 2558","children":[],"tail":", § 1416; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/576/tIII/s321/4"},"text":"Pub. L. 99–576, title III, § 321(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3278"},"text":"100 Stat. 3278","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/689/tI/s103/b/4"},"text":"Pub. L. 100–689, title I, § 103(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4165"},"text":"102 Stat. 4165","children":[],"tail":"; renumbered § 3016 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc35203a6-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc35203a7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc35203a8-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 3011(a)(1)(A)(i), referred to in subsec. (a), was amended generally by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/419/tI/s103/a/1/A"},"text":"Pub. L. 106–419, title I, § 103(a)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1825"},"text":"114 Stat. 1825","children":[],"tail":", and, as so amended, does not contain a subcl. (I)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc35203a9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1416"},"text":"section 1416 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “3011(c)(1)” for “1411(c)(1)”, “3012(d)(1)” for “1412(d)(1)”, “3012(b)(2)” for “1412(b)(2)”, and “3011(a)(1)(A)(i)(I) or 3012(a)(1)(A)(ii)” for “1411(a)(1)(A)(i)(I) or 1412(a)(1)(A)(ii)” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “3012(a)(1)(B)(i)” for “1412(a)(1)(B)(i)” and “3012(a)(1)(B)(ii)” for “1412(a)(1)(B)(ii)” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “3018(b)(3)(A)” for “1418(b)(3)(A)” and “3018(b)(2)” for “1418(b)(2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/689"},"text":"Pub. L. 100–689","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576"},"text":"Pub. L. 99–576","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “A member of the Armed Forces who has completed at least two years of service on active duty after "},{"tag":"date","attrib":{"date":"1985-06-30"},"text":"June 30, 1985","children":[],"tail":", has continued on active duty or in the Selected Reserve without a break in service (except as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1412/b/2"},"text":"section 1412(b)(2) of this title","children":[],"tail":"), and who but for section 1411(a)(1) or 1412(a)(1) of this title would be eligible for basic educational assistance may receive educational assistance under this chapter for enrollment in an approved program of education while continuing to perform the duty described in section 1411(a)(1) or 1412(a)(1) of this title.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
