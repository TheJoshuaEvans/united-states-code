{"tag":"section","attrib":{"id":"idc3296d85-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1976"},"text":null,"children":[{"tag":"num","attrib":{"value":"1976"},"text":"§ 1976.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The insurance provided for in this subchapter and the deductions and contributions for that purpose shall take effect on the date designated by the Secretary and certified by the Secretary to each Secretary concerned.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc3296d86-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/214/s1/a"},"text":"Pub. L. 89–214, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-09-29"},"text":"Sept. 29, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/885"},"text":"79 Stat. 885","children":[],"tail":", § 776; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/576/tVII/s701/42"},"text":"Pub. L. 99–576, title VII, § 701(42)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3294"},"text":"100 Stat. 3294","children":[],"tail":"; renumbered § 1976 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":", §§ 4(b)(1), (2)(E), 5(a), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404-406"},"text":"105 Stat. 404–406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3296d87-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3296d88-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3296d89-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s776"},"text":"section 776 of this title","children":[],"tail":" as this section and substituted “Secretary” for “Administrator” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576"},"text":"Pub. L. 99–576","children":[],"tail":" substituted “the Administrator” for “him” after “certified by”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3296d8a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3296d8b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Interim Coverage Until Effective Date of Group Plan; $5,000 Death Gratuity","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/214/s3"},"text":"Pub. L. 89–214, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-09-29"},"text":"Sept. 29, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/886"},"text":"79 Stat. 886","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/89/730/s6/a"},"text":"Pub. L. 89–730, § 6(a)","children":[],"tail":"–(d), "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1159"},"text":"80 Stat. 1159","children":[],"tail":", provided for payment of a death gratuity of up to $5,000 in certain cases of death of veterans while in active military, naval, or air service during the period from "},{"tag":"date","attrib":{"date":"1957-01-01"},"text":"Jan. 1, 1957","children":[],"tail":", to the date immediately preceding the date on which the Servicemen’s Group Life Insurance program was placed in effect under this section, and required that an application for such gratuity had to be made within one year after "},{"tag":"date","attrib":{"date":"1965-09-29"},"text":"Sept. 29, 1965","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/730/s6/e"},"text":"Pub. L. 89–730, § 6(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1159"},"text":"80 Stat. 1159","children":[],"tail":", provided that any waiver of future benefits executed by any person under "},{"tag":"ref","attrib":{"href":"/us/pl/89/214/s3/a"},"text":"section 3(a) of Pub. L. 89–214","children":[],"tail":" (see above), as in effect prior to "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", was to have no effect."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/730/s6/f"},"text":"Pub. L. 89–730, § 6(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1159"},"text":"80 Stat. 1159","children":[],"tail":", provided that in any case in which the death gratuity paid to any person under "},{"tag":"ref","attrib":{"href":"/us/pl/89/214/s3"},"text":"section 3 of Pub. L. 89–214","children":[],"tail":" (see above), was reduced pursuant to clause (B) of subsection (c)(1) of such section, as in effect prior to "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", the Administrator of Veterans’ Affairs was to pay to such person an amount equal to the amount by which such death gratuity was reduced."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/730/s6/g"},"text":"Pub. L. 89–730, § 6(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1159"},"text":"80 Stat. 1159","children":[],"tail":", provided that notwithstanding the time limitation prescribed in "},{"tag":"ref","attrib":{"href":"/us/pl/89/214/s3/a"},"text":"section 3(a) of Pub. L. 89–214","children":[],"tail":" (see above), any application for death gratuity filed under such section shall be valid if filed within one year after "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
