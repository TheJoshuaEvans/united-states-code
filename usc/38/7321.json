{"tag":"section","attrib":{"id":"idc3fb3c0d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7321"},"text":null,"children":[{"tag":"num","attrib":{"value":"7321"},"text":"§ 7321.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Committee on Care of Severely Chronically Mentally Ill Veterans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3fb3c0e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7321/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary, acting through the Under Secretary for Health, shall establish in the Veterans Health Administration a Committee on Care of Severely Chronically Mentally Ill Veterans. The Under Secretary shall appoint employees of the Department with expertise in the care of the chronically mentally ill to serve on the committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3fb3c0f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7321/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The committee shall assess, and carry out a continuing assessment of, the capability of the Veterans Health Administration to meet effectively the treatment and rehabilitation needs of mentally ill veterans whose mental illness is severe and chronic and who are eligible for health care furnished by the Department, including the needs of such veterans who are women. In carrying out that responsibility, the committee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3fb3c10-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7321/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the care provided to such veterans through the Veterans Health Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fb3c11-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7321/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify systemwide problems in caring for such veterans in facilities of the Veterans Health Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fb3c12-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7321/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify specific facilities within the Veterans Health Administration at which program enrichment is needed to improve treatment and rehabilitation of such veterans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fb3c13-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7321/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify model programs which the committee considers to have been successful in the treatment and rehabilitation of such veterans and which should be implemented more widely in or through facilities of the Veterans Health Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3fb3c14-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7321/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The committee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3fb3c15-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7321/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Under Secretary regarding the development of policies for the care and rehabilitation of severely chronically mentally ill veterans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fb3c16-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7321/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" make recommendations to the Under Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3fb3c17-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7321/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for improving programs of care of such veterans at specific facilities and throughout the Veterans Health Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fb3c18-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7321/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for establishing special programs of education and training relevant to the care of such veterans for employees of the Veterans Health Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fb3c19-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7321/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regarding research needs and priorities relevant to the care of such veterans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fb3c1a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7321/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regarding the appropriate allocation of resources for all such activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3fb3c1b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7321/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3fb3c1c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7321/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"1997-04-01"},"text":"April 1, 1997","children":[],"tail":", the Secretary shall submit to the Committees on Veterans’ Affairs of the Senate and House of Representatives a report on the implementation of this section. The report shall include the following:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3fb3c1d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7321/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A list of the members of the committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fb3c1e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7321/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The assessment of the Under Secretary for Health, after review of the initial findings of the committee, regarding the capability of the Veterans Health Administration, on a systemwide and facility-by-facility basis, to meet effectively the treatment and rehabilitation needs of severely chronically mentally ill veterans who are eligible for Department care.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fb3c1f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7321/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The plans of the committee for further assessments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fb3c20-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7321/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The findings and recommendations made by the committee to the Under Secretary for Health and the views of the Under Secretary on such findings and recommendations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fb3c21-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7321/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the steps taken, plans made (and a timetable for their execution), and resources to be applied toward improving the capability of the Veterans Health Administration to meet effectively the treatment and rehabilitation needs of severely chronically mentally ill veterans who are eligible for Department care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fb3c22-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7321/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than June 1 of each year through 2012, the Secretary shall submit to the Committees on Veterans’ Affairs of the Senate and House of Representatives a report containing information updating the reports submitted under this subsection before the submission of such report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3fb3c23-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/262/tIII/s335/a"},"text":"Pub. L. 104–262, title III, § 335(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3204"},"text":"110 Stat. 3204","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/419/tIV/s402/f"},"text":"Pub. L. 106–419, title IV, § 402(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1863"},"text":"114 Stat. 1863","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/170/tIV/s405/c"},"text":"Pub. L. 108–170, title IV, § 405(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2063"},"text":"117 Stat. 2063","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/387/tVIII/s807"},"text":"Pub. L. 110–387, title VIII, § 807","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4141"},"text":"122 Stat. 4141","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3fb3c24-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3fb3c25-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3fb3c26-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/387"},"text":"Pub. L. 110–387","children":[],"tail":" substituted “through 2012” for “through 2008”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/170"},"text":"Pub. L. 108–170","children":[],"tail":" substituted “June 1 of each year through 2008” for “"},{"tag":"date","attrib":{"date":"1998-02-01"},"text":"February 1, 1998","children":[],"tail":", and February 1 of each of the six following years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/419"},"text":"Pub. L. 106–419","children":[],"tail":", substituted “six following years” for “three following years”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
