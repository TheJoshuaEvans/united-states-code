{"tag":"section","attrib":{"id":"idc2ab154a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1153"},"text":null,"children":[{"tag":"num","attrib":{"value":"1153"},"text":"§ 1153.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aggravation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A preexisting injury or disease will be considered to have been aggravated by active military, naval, air, or space service, where there is an increase in disability during such service, unless there is a specific finding that the increase in disability is due to the natural progress of the disease.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc2ab154b-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1124"},"text":"72 Stat. 1124","children":[],"tail":", § 353; renumbered § 1153, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s926/a/15"},"text":"Pub. L. 116–283, div. A, title IX, § 926(a)(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3830"},"text":"134 Stat. 3830","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2ab154c-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc2ab