{"tag":"section","attrib":{"id":"idc4157aed-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7622"},"text":null,"children":[{"tag":"num","attrib":{"value":"7622"},"text":"§ 7622.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility; application; agreement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc4157aee-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7622/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To be eligible to participate in the Tuition Reimbursement Program, an individual must be a full-time employee in the Department permanently assigned to a Department health-care facility and must be enrolled in a course of training offered by an institution approved by the Secretary leading toward completion of (1) an associate or higher degree in nursing, or (2) a masters degree or doctoral degree in nursing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4157aef-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7622/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In selecting applicants for acceptance in the Tuition Reimbursement Program, the Secretary (in addition to according priorities as set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7603/d"},"text":"section 7603(d) of this title","children":[],"tail":") shall give special consideration and emphasis to individuals pursuing a course of study which will expedite an increase in the number of registered nurses employed by the Department. The Secretary shall then give priority, in the following order, to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4157af0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7622/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals who have been employed as full-time employees in the Nursing Service in the Veterans Health Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4157af1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7622/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals who have previously received tuition reimbursement under the Tuition Reimbursement Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4157af2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7622/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An agreement between the Secretary and a participant in the Tuition Reimbursement Program shall (in addition to the requirements set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7604"},"text":"section 7604 of this title","children":[],"tail":") contain the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4157af3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7622/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary’s agreement to provide the participant with tuition reimbursement following successful completion (as determined, pursuant to regulations prescribed by the Secretary, by the educational institution involved) of (A) a course or courses required for the course of study described in subsection (a) of this section, or (B) a course or courses taken as necessary prerequisites for degree program enrollment if a letter regarding the potential enrollment of the participant from an appropriate official of the institution involved includes a statement specifying such prerequisites.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4157af4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7622/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The participant’s agreement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc4157af5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7622/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain employment, while enrolled in the course of training being pursued by such participant, as a full-time Department employee in the Veterans Health Administration permanently assigned to a Department health-care facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4157af6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7622/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to continue to serve as a full-time employee in the Veterans Health Administration for one year (hereinafter in this subchapter referred to as the “period of obligated service”) after completion of the course for which the participant received tuition reimbursement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4157af7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7622/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tuition reimbursement provided to a participant in the Tuition Reimbursement Program may not exceed $2,000 per year (adjusted in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7631"},"text":"section 7631 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4157af8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7622/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may arrange with an educational institution pursuant to which such an institution would provide a course or courses at a Department health-care facility to participants in the Tuition Reimbursement Program. Under such an arrangement, the Secretary may agree to pay to the institution an amount not in excess of an amount determined by multiplying the number of participants in such a course by the amount of tuition reimbursement each participant would receive for enrolling and successfully completing such course.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc4157af9-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/322/tII/s216/b"},"text":"Pub. L. 100–322, title II, § 216(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/525"},"text":"102 Stat. 525","children":[],"tail":", § 4322; renumbered § 7622 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", (d)(1), "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":", 239; "},{"tag":"ref","attrib":{"href":"/us/pl/102/54/s14/e/9"},"text":"Pub. L. 102–54, § 14(e)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-06-13"},"text":"June 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/287"},"text":"105 Stat. 287","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/3"},"text":"Pub. L. 102–83, § 4(a)(3)","children":[],"tail":", (4), (b)(1), (2)(E), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404"},"text":"105 Stat. 404","children":[],"tail":", 405; "},{"tag":"ref","attrib":{"href":"/us/pl/103/446/tXII/s1201/b"},"text":"Pub. L. 103–446, title XII, § 1201(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4682"},"text":"108 Stat. 4682","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc4157afa-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc4157afb-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc4157afc-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsecs. (b)(1), (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446/s1201/b/1"},"text":"Pub. L. 103–446, § 1201(b)(1)","children":[],"tail":", substituted “Veterans Health Administration” for “Department of Medicine and Surgery”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446/s1201/b/2"},"text":"Pub. L. 103–446, § 1201(b)(2)","children":[],"tail":", substituted “the Veterans Health Administration” for “such Department”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/b/1"},"text":"Pub. L. 102–40, § 402(b)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4322"},"text":"section 4322 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/3"},"text":"Pub. L. 102–83, § 4(a)(3)","children":[],"tail":", (4), substituted “Department” for “Veterans’ Administration” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator” in two places in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/3"},"text":"Pub. L. 102–83, § 4(a)(3)","children":[],"tail":", (4), substituted “Department” for “Veterans’ Administration” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/d/1"},"text":"Pub. L. 102–40, § 402(d)(1)","children":[],"tail":", substituted “7603(d)” for “4303(d)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator” in introductory provisions and in par. (1) and “Secretary’s” for “Administrator’s” in par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/d/1"},"text":"Pub. L. 102–40, § 402(d)(1)","children":[],"tail":", substituted “7604” for “4304” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/3"},"text":"Pub. L. 102–83, § 4(a)(3)","children":[],"tail":", (4), substituted “Department” for “Veterans’ Administration” in two places in par. (2)(A)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/54"},"text":"Pub. L. 102–54","children":[],"tail":" amended subsec. (d) as in effect immediately before the enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" by inserting an open parenthesis before “adjusted in”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/d/1"},"text":"Pub. L. 102–40, § 402(d)(1)","children":[],"tail":", substituted “7631” for “4331”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/3"},"text":"Pub. L. 102–83, § 4(a)(3)","children":[],"tail":", (4), substituted “Department” for “Veterans’ Administration”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
