{"tag":"section","attrib":{"id":"idc3b16223-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3750"},"text":null,"children":[{"tag":"num","attrib":{"value":"3750"},"text":"§ 3750.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incorporation of other provisions by the Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may provide that the provisions of sections of other subchapters of this chapter that are not otherwise applicable to loans made or guaranteed under this subchapter shall be applicable to loans made or guaranteed under this subchapter. The Secretary shall exercise authority under the preceding sentence by regulations prescribed after publication in the Federal Register and a period of not less than thirty days for public comment.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc3b16224-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/72/tIII/s302/a"},"text":"Pub. L. 97–72, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-11-03"},"text":"Nov. 3, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1059"},"text":"95 Stat. 1059","children":[],"tail":", § 1850; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIII/s313/b/1"},"text":"Pub. L. 101–237, title III, § 313(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2077"},"text":"103 Stat. 2077","children":[],"tail":"; renumbered § 3750, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3b16225-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3b16226-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3b16227-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1850"},"text":"section 1850 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" substituted “Secretary” for “Administrator” in section catchline and wherever appearing in text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
