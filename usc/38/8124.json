dc42afedb-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5024"},"text":"section 5024 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" substituted “Secretary” for “Administrator” wherever appearing and “Secretary’s” for “Administrator’s”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/581"},"text":"Pub. L. 94–581","children":[],"tail":" substituted “the Administrator” for “he” wherever appearing and “under the Administrator’s supervision” for “under his supervision”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc42afedc-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc42afedd-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/581"},"text":"Pub. L. 94–581","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/581/s211"},"text":"section 211 of Pub. L. 94–581","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us