{"tag":"section","attrib":{"id":"idc40723d3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7408"},"text":null,"children":[{"tag":"num","attrib":{"value":"7408"},"text":"§ 7408.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of additional employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc40723d4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7408/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There shall be appointed by the Secretary under civil service laws, rules, and regulations, such additional employees, other than those provided in section 7306 and paragraphs (1) and (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401"},"text":"section 7401 of this title","children":[],"tail":" and those specified in sections 7405 and 7406 of this title, as may be necessary to carry out the provisions of this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc40723d5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7408/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary, after considering an individual’s existing pay, higher or unique qualifications, or the special needs of the Department, may appoint the individual to a position in the Administration providing direct patient-care services or services incident to direct patient-services at a rate of pay above the minimum rate of the appropriate grade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc40723d6-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s401/b/2"},"text":"Pub. L. 102–40, title IV, § 401(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/229"},"text":"105 Stat. 229","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/446/tXII/s1201/e/21"},"text":"Pub. L. 103–446, title XII, § 1201(e)(21)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4686"},"text":"108 Stat. 4686","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc40723d7-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc40723d8-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc40723d9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4111"},"text":"section 4111 of this title","children":[],"tail":" prior to the repeal of that section as part of the complete revision of chapter 73 of this title by "},{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc40723da-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446"},"text":"Pub. L. 103–446","children":[],"tail":" substituted “civil service” for “civil-service”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
