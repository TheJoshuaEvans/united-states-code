{"tag":"section","attrib":{"id":"idc3c92f21-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4319"},"text":null,"children":[{"tag":"num","attrib":{"value":"4319"},"text":"§ 4319.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment and reemployment rights in foreign countries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3c92f22-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4319/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Liability of Controlling United States Employer of Foreign Entity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If an employer controls an entity that is incorporated or otherwise organized in a foreign country, any denial of employment, reemployment, or benefit by such entity shall be presumed to be by such employer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3c92f23-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4319/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability to Foreign Employer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subchapter does not apply to foreign operations of an employer that is a foreign person not controlled by an United States employer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3c92f24-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4319/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination of Controlling Employer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purpose of this section, the determination of whether an employer controls an entity shall be based upon the interrelations of operations, common management, centralized control of labor relations, and common ownership or financial control of the employer and the entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3c92f25-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4319/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exemption","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of this subchapter, an employer, or an entity controlled by an employer, shall be exempt from compliance with any of sections 4311 through 4318 of this title with respect to an employee in a workplace in a foreign country, if compliance with that section would cause such employer, or such entity controlled by an employer, to violate the law of the foreign country in which the workplace is located.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3c92f26-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/tII/s212/b/1"},"text":"Pub. L. 105–368, title II, § 212(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3331"},"text":"112 Stat. 3331","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3c92f27-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3c92f28-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3c92f29-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable only with respect to causes of action arising after ","children":[{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/368/s212/c"},"text":"section 212(c) of Pub. L. 105–368","children":[],"tail":", set out as an Effective Date of 1998 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4303"},"text":"section 4303 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
