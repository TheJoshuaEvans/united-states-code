{"tag":"section","attrib":{"id":"idc27b530c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s311"},"text":null,"children":[{"tag":"num","attrib":{"value":"311"},"text":"§ 311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General Counsel","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is in the Department the Office of the General Counsel. There is at the head of the office a General Counsel, who is appointed by the President, by and with the advice and consent of the Senate. The General Counsel is the chief legal officer of the Department and provides legal assistance to the Secretary concerning the programs and policies of the Department.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc27b530d-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s2/a"},"text":"Pub. L. 102–83, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/383"},"text":"105 Stat. 383","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc27b530e-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc27b530f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc27b5310-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior section 311 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1111"},"text":"section 1111 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/527/s8/a"},"text":"section 8(a) of Pub. L. 100–527","children":[],"tail":", known as the Department of Veterans Affairs Act, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s3/3"},"text":"Pub. L. 102–83, § 3(3)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
