{"tag":"section","attrib":{"id":"idc32e2860-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2002"},"text":null,"children":[{"tag":"num","attrib":{"value":"2002"},"text":"§ 2002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc32e2861-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2002/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc32e2862-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2002/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “homeless veteran” means a veteran who is homeless (as that term is defined in subsection (a) or (b) of section 103 of the McKinney-Vento Homeless Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11302"},"text":"42 U.S.C. 11302","children":[],"tail":"))."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc32e2863-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2002/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “grant and per diem provider” means an entity in receipt of a grant under section 2011 or 2012 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc32e2864-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2002/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Veteran Defined","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc32e2865-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2002/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s101/2"},"text":"section 101(2) of this title","children":[],"tail":" and except as provided in paragraph (2), for purposes of sections 2011, 2012, 2013, 2044, and 2061 of this title, the term “veteran” means a person who served in the active military, naval, air, or space service, regardless of length of service, and who was discharged or released therefrom."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc32e2866-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2002/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of paragraph (1), the term “veteran” excludes a person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc32e2867-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2002/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" received a dishonorable discharge from the Armed Forces; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc32e2868-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2002/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was discharged or dismissed from the Armed Forces by reason of the sentence of a general court-martial.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc32e2869-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/95/s5/a/1"},"text":"Pub. L. 107–95, § 5(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-21"},"text":"Dec. 21, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/905"},"text":"115 Stat. 905","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/444/s8/a/3"},"text":"Pub. L. 109–444, § 8(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-21"},"text":"Dec. 21, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3313"},"text":"120 Stat. 3313","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/461/tX"},"text":"Pub. L. 109–461, title X","children":[],"tail":", §§ 1004(a)(3), 1006(b), "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3465"},"text":"120 Stat. 3465","children":[],"tail":", 3468; "},{"tag":"ref","attrib":{"href":"/us/pl/114/315/tVII/s701"},"text":"Pub. L. 114–315, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1584"},"text":"130 Stat. 1584","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s926/a/33"},"text":"Pub. L. 116–283, div. A, title IX, § 926(a)(33)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3830"},"text":"134 Stat. 3830","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc32e286a-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc32e286b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc32e286c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2002 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4102"},"text":"section 4102 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 2002, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1217"},"text":"72 Stat. 1217","children":[],"tail":", related to compensation for veterans in absence of agreements with States, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/87/675/s1/a"},"text":"section 1(a) of Pub. L. 87–675","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 2002A was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4102A"},"text":"section 4102A of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc32e286d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “air, or space service” for “or air service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/315"},"text":"Pub. L. 114–315","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, substituted “in subsection (a) or (b) of section 103 of the McKinney-Vento Homeless Assistance Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11302"},"text":"42 U.S.C. 11302","children":[],"tail":")” for “in section 103(a) of the McKinney-Vento Homeless Assistance Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11302/a"},"text":"42 U.S.C. 11302(a)","children":[],"tail":")” in subsec. (a)(1), and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461/s1006/b"},"text":"Pub. L. 109–461, § 1006(b)","children":[],"tail":", provided that as of the enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/109/461"},"text":"Pub. L. 109–461","children":[],"tail":", the amendments made by "},{"tag":"ref","attrib":{"href":"/us/pl/109/444"},"text":"Pub. L. 109–444","children":[],"tail":" were deemed for all purposes not to have taken effect and that "},{"tag":"ref","attrib":{"href":"/us/pl/109/444"},"text":"Pub. L. 109–444","children":[],"tail":" ceased to be in effect. See Amendment notes below and "},{"tag":"ref","attrib":{"href":"/us/pl/109/461/s1006/b"},"text":"section 1006(b) of Pub. L. 109–461","children":[],"tail":", set out as a Coordination of Provisions With "},{"tag":"ref","attrib":{"href":"/us/pl/109/444"},"text":"Pub. L. 109–444","children":[],"tail":" note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461/s1004/a/3"},"text":"Pub. L. 109–461, § 1004(a)(3)","children":[],"tail":", inserted closing parenthesis before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/444"},"text":"Pub. L. 109–444","children":[],"tail":", which inserted closing parenthesis before period at end, was terminated by "},{"tag":"ref","attrib":{"href":"/us/pl/109/461/s1006/b"},"text":"Pub. L. 109–461, § 1006(b)","children":[],"tail":". See Amendment notes above."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc32e286e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc32e286f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/315/tVII/s706"},"text":"Pub. L. 114–315, title VII, § 706","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1586"},"text":"130 Stat. 1586","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/315/tVII/s706"},"text":"“This subtitle [subtitle A (§§ 701–706) of title VII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/315"},"text":"Pub. L. 114–315","children":[],"tail":", amending this section and sections 5303 and 5303A of this title and enacting provisions set out as notes under this section] and the amendments made by this subtitle shall apply to individuals seeking benefits under chapter 20 of title 38, United States Code, before, on, and after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc32e2870-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/315/tVII/s705"},"text":"Pub. L. 114–315, title VII, § 705","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1585"},"text":"130 Stat. 1585","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/315/tVII/s705"},"text":"“Not later than 270 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":"], the Secretary of Veterans Affairs shall prescribe regulations, including such modifications to section 3.12 of title 38, Code of Federal Regulations (or any successor regulation), as the Secretary considers appropriate, to ensure that the Department of Veterans Affairs is in full compliance with this title [see Tables for classification] and the amendments made by this subtitle [subtitle A (§§ 701–706) of title VII of "},{"tag":"ref","attrib":{"href":"/us/pl/114/315"},"text":"Pub. L. 114–315","children":[],"tail":", amending this section and sections 5303 and 5303A of this title].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc32e2871-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Training of Personnel of the Department of Veterans Affairs and Grant Recipients","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/315/tVII/s704"},"text":"Pub. L. 114–315, title VII, § 704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1585"},"text":"130 Stat. 1585","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/315/tVII/s704"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Secretary of Veterans Affairs shall conduct a program of training and education to ensure that the following persons are aware of and implement this title [see Tables for classification] and the amendments made by this subtitle [subtitle A (§§ 701–706) of title VII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/315"},"text":"Pub. L. 114–315","children":[],"tail":", amending this section and sections 5303 and 5303A of this title]:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Personnel of the Department of Veterans Affairs who are supporting or administering a program under chapter 20 of title 38, United States Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recipients of grants or other amounts for purposes of carrying out such a program.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
