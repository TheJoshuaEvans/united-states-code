{"tag":"section","attrib":{"id":"idc4026868-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7366"},"text":null,"children":[{"tag":"num","attrib":{"value":"7366"},"text":"§ 7366.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accountability and oversight","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc4026869-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7366/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc402686a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7366/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc402686b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7366/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The records of a corporation established under this subchapter shall be available to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc402686c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7366/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of sections 404(a)(1) and 406(a)(1) of title 5, the programs and operations of such a corporation shall be considered to be programs and operations of the Department with respect to which the Inspector General of the Department has responsibilities under chapter 4 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc402686d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7366/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such a corporation shall be considered an agency for the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s716"},"text":"section 716 of title 31","children":[],"tail":" (relating to availability of information and inspection of records by the Comptroller General)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc402686e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7366/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc402686f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7366/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each corporation shall submit to the Secretary each year a report providing a detailed statement of the operations, activities, and accomplishments of the corporation during that year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4026870-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7366/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc4026871-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7366/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A corporation with revenues in excess of $500,000 for any year shall obtain an audit of the corporation for that year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4026872-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7366/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A corporation with annual revenues between $100,000 and $500,000 shall obtain an audit of the corporation at least once every three years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4026873-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7366/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any audit under this paragraph shall be performed by an independent auditor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4026874-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7366/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The corporation shall include in each report to the Secretary under paragraph (1) the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc4026875-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7366/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The most recent audit of the corporation under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4026876-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7366/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The most recent Internal Revenue Service Form 990 “Return of Organization Exempt from Income Tax” or equivalent and the applicable schedules under such form.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4026877-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7366/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each director, officer, and employee of a corporation established under this subchapter shall be subject to a conflict of interest policy adopted by that corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4026878-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7366/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall submit to the Committees on Veterans’ Affairs of the Senate and House of Representatives an annual report on the corporations established under this subchapter. The report shall set forth the following information:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4026879-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7366/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The location of each corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc402687a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7366/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amount received by each corporation during the previous year, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc402687b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7366/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount received;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc402687c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7366/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount received from governmental entities for research and the amount received from governmental entities for education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc402687d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7366/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount received from all other sources for research and the amount received from all other sources for education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc402687e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7366/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if an amount received from a source referred to in subparagraph (C) exceeded $25,000, information that identifies the source.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc402687f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7366/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amount expended by each corporation during the year, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc4026880-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7366/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount expended for salary for research staff, the amount expended for salary for education staff, and the amount expended for salary for support staff;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4026881-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7366/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount expended for direct support of research and the amount expended for direct support of education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4026882-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7366/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the amount expended with respect to any payee exceeded $50,000, information that identifies the payee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4026883-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7366/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount expended by each corporation during the year for travel conducted in conjunction with research and the amount expended for travel in conjunction with education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc4026884-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/322/tII/s204/a"},"text":"Pub. L. 100–322, title II, § 204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/511"},"text":"102 Stat. 511","children":[],"tail":", § 4166; renumbered § 7366 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV"},"text":"Pub. L. 102–40, title IV","children":[],"tail":", §§ 401(a)(4)(B), 403(a)(1), (2), "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/221"},"text":"105 Stat. 221","children":[],"tail":", 239; "},{"tag":"ref","attrib":{"href":"/us/pl/104/262/tIII/s343/c"},"text":"Pub. L. 104–262, title III, § 343(c)","children":[],"tail":"–(e), "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3207"},"text":"110 Stat. 3207","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/117/tII/s204/e"},"text":"Pub. L. 106–117, title II, § 204(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-30"},"text":"Nov. 30, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1563"},"text":"113 Stat. 1563","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/103/tV/s509/f"},"text":"Pub. L. 107–103, title V, § 509(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-27"},"text":"Dec. 27, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/997"},"text":"115 Stat. 997","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/170/tIV/s402/b"},"text":"Pub. L. 108–170, title IV, § 402(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2062"},"text":"117 Stat. 2062","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/163/tVIII/s806"},"text":"Pub. L. 111–163, title VIII, § 806","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-05-05"},"text":"May 5, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1179"},"text":"124 Stat. 1179","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/61"},"text":"Pub. L. 117–286, § 4(b)(61)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4350"},"text":"136 Stat. 4350","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc4026885-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc4026886-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc4026887-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “sections 404(a)(1) and 406(a)(1) of title 5,” for “sections 4(a)(1) and 6(a)(1) of the Inspector General Act of 1978,” and “chapter 4 of title 5.” for “such Act.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163/s806/a"},"text":"Pub. L. 111–163, § 806(a)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “Each such corporation shall submit to the Secretary an annual report providing a detailed statement of its operations, activities, and accomplishments during that year. A corporation with revenues in excess of $300,000 for any year shall obtain an audit of the corporation for that year. A corporation with annual revenues between $10,000 and $300,000 shall obtain an independent audit of the corporation at least once every three years. Any audit under the preceding sentences shall be performed by an independent auditor. The corporation shall include the most recent such audit in the corporation’s report to the Secretary for that year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163/s806/b"},"text":"Pub. L. 111–163, § 806(b)","children":[],"tail":", amended subsec. (c) generally. Prior to amendment, subsec. (c) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(c)(1) Each member of the board of directors of a corporation established under this subchapter, each employee of such a corporation, and each employee of the Department who is involved in the functions of the corporation during any year shall be subject to Federal laws and regulations applicable to Federal employees with respect to conflicts of interest in the performance of official functions.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Each corporation established under this subchapter shall each year submit to the Secretary a statement signed by the executive director of the corporation verifying that each director and employee has certified awareness of the laws and regulations referred to in paragraph (1) and of the consequences of violations of those laws and regulations in the same manner as Federal employees are required to so certify.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163/s806/c"},"text":"Pub. L. 111–163, § 806(c)","children":[],"tail":", substituted “$50,000” for “$35,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/170"},"text":"Pub. L. 108–170","children":[],"tail":" inserted “(1)” after “(c)”, substituted “any year shall be subject” for “any year—(1) shall be subject” and “functions.” for “functions; and”, added par. (2), and struck out former par. (2) which read as follows: “shall submit to the Secretary a statement signed by the executive director of the corporation certifying that each director and employee is aware of, and has complied with, such laws and regulations in the same manner as Federal employees are required to.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (d)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/103"},"text":"Pub. L. 107–103","children":[],"tail":" made technical correction to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/106/117/s204/e/3"},"text":"Pub. L. 106–117, § 204(e)(3)","children":[],"tail":". See 1999 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (d)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117/s204/e/1"},"text":"Pub. L. 106–117, § 204(e)(1)","children":[],"tail":", inserted “for research and the amount received from governmental entities for education” before the semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117/s204/e/2"},"text":"Pub. L. 106–117, § 204(e)(2)","children":[],"tail":", inserted “for research and the amount received from all other sources for education” before “; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117/s204/e/3"},"text":"Pub. L. 106–117, § 204(e)(3)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/107/103/s509/f"},"text":"Pub. L. 107–103, § 509(f)","children":[],"tail":", substituted “an amount received” for “the amount received”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117/s204/e/4"},"text":"Pub. L. 106–117, § 204(e)(4)","children":[],"tail":", substituted “, the amount expended for salary for education staff, and the amount expended” for “and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117/s204/e/5"},"text":"Pub. L. 106–117, § 204(e)(5)","children":[],"tail":", inserted “and the amount expended for direct support of education” after “research”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117/s204/e/6"},"text":"Pub. L. 106–117, § 204(e)(6)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/262/s343/c"},"text":"Pub. L. 104–262, § 343(c)","children":[],"tail":", substituted “A corporation with revenues in excess of $300,000 for any year shall obtain an audit of the corporation for that year. A corporation with annual revenues between $10,000 and $300,000 shall obtain an independent audit of the corporation at least once every three years. Any audit under the preceding sentences shall be performed by an independent auditor. The corporation shall include the most recent such audit” for “The corporation shall obtain a report of independent auditors concerning the receipts and expenditures of funds by the corporation during that year and shall include that report”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/262/s343/d"},"text":"Pub. L. 104–262, § 343(d)","children":[],"tail":", substituted “a statement signed by the executive director of the corporation certifying that each director and” for “an annual statement signed by the director or employee certifying that the director or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/262/s343/e"},"text":"Pub. L. 104–262, § 343(e)","children":[],"tail":", amended subsec. (d) generally. Prior to amendment, subsec. (d) read as follows: “The Secretary shall submit to the Committees on Veterans’ Affairs of the Senate and House of Representatives an annual report on the number and location of corporations established and the amount of the contributions made to each such corporation.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s401/a/4/B"},"text":"Pub. L. 102–40, § 401(a)(4)(B)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4166"},"text":"section 4166 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s403/a/1"},"text":"Pub. L. 102–40, § 403(a)(1)","children":[],"tail":", substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s403/a/2"},"text":"Pub. L. 102–40, § 403(a)(2)","children":[],"tail":", substituted “Department” for “Veterans’ Administration” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s403/a/1"},"text":"Pub. L. 102–40, § 403(a)(1)","children":[],"tail":", substituted “Secretary” for “Administrator” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s403/a/2"},"text":"Pub. L. 102–40, § 403(a)(2)","children":[],"tail":", substituted “Department” for “Veterans’ Administration” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s403/a/1"},"text":"Pub. L. 102–40, § 403(a)(1)","children":[],"tail":", substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s403/a/1"},"text":"Pub. L. 102–40, § 403(a)(1)","children":[],"tail":", substituted “Secretary” for “Administrator”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc4026888-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc4026889-47c4-11f1-bf59-9680b1269b87"},"text":n