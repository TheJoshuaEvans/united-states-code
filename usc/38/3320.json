{"tag":"section","attrib":{"id":"idc369d1fd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320"},"text":null,"children":[{"tag":"num","attrib":{"value":"3320"},"text":"§ 3320.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Edith Nourse Rogers STEM Scholarship","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc369d1fe-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the limitation under subsection (f), the Secretary shall provide additional benefits to eligible individuals selected by the Secretary under this section. Such benefits shall be known as the “Edith Nourse Rogers STEM Scholarship”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc369d1ff-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, an eligible individual is an individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc369d200-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is or was entitled to educational assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3311"},"text":"section 3311 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc369d201-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has used all of the educational assistance to which the individual is entitled under this chapter or will, based on the individual’s rate of usage, use all of such assistance within 180 days of applying for benefits under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc369d202-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who applies for assistance under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc369d203-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc369d204-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is an individual who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc369d205-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is enrolled in a program of education leading to a post-secondary degree that, in accordance with the guidelines of the applicable regional or national accrediting agency, requires at least the standard 120 semester (or 180 quarter) credit hours for completion in a standard, undergraduate college degree, or a dual degree program that includes such an undergraduate college degree, in—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc369d206-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/b/4/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" biological or biomedical science;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc369d207-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/b/4/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physical science;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc369d208-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/b/4/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" science technologies or technicians;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc369d209-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/b/4/A/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" computer and information science and support services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc369d20a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/b/4/A/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mathematics or statistics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc369d20b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/b/4/A/i/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engineering;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc369d20c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/b/4/A/i/VII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VII"},"text":"(VII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engineering technologies or an engineering-related field;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc369d20d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/b/4/A/i/VIII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VIII"},"text":"(VIII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a health profession or related program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc369d20e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/b/4/A/i/IX"},"text":null,"children":[{"tag":"num","attrib":{"value":"IX"},"text":"(IX)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agriculture science program or a natural resources science program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc369d20f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/b/4/A/i/X"},"text":null,"children":[{"tag":"num","attrib":{"value":"X"},"text":"(X)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other subjects and fields identified by the Secretary as meeting national needs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc369d210-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has completed at least 60 standard semester (or 90 quarter) credit hours in a field referred to in clause (i); or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc369d211-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an individual who has earned a post-secondary degree in a field referred to in subparagraph (A)(i) and is enrolled in a covered clinical training program for health care professionals or a program of education leading to a teaching certification; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc369d212-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an individual who has earned a graduate degree in a field referred to in subparagraph (A)(i) and is enrolled in a covered clinical training program for health care professionals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc369d213-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Priority","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc369d214-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the Secretary determines that there are insufficient funds available in a fiscal year to provide additional benefits under this section to all eligible individuals, the Secretary may give priority to the following eligible individuals:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc369d215-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Individuals who require the most credit hours described in subsection (b)(4).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc369d216-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Individuals who are entitled to educational assistance under this chapter by reason of paragraph (1), (2), (8), (9), (10), or (11) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3311/b"},"text":"section 3311(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc369d217-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall give priority to individuals under paragraph (1) in the following order:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc369d218-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Individuals who are enrolled in a program of education leading to an undergraduate degree in a field referred to in subsection (b)(4)(A)(i).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc369d219-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Individuals who are enrolled in a program of education leading to a teaching certificate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc369d21a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Individuals who are enrolled in a dual-degree program leading to both an undergraduate and graduate degree in a field referred to in subsection (b)(4)(A)(i).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc369d21b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Individuals who have earned an undergraduate degree and are enrolled in a covered clinical training program for health care professionals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc369d21c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Individuals who have earned a graduate degree and are enrolled in a covered clinical training program for health care professionals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc369d21d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount of Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc369d21e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall pay to each eligible individual who receives additional benefits under this section the monthly amount payable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3313"},"text":"section 3313 of this title","children":[],"tail":" for not more than 9 months of the program of education in which the individual is enrolled (adjusted with respect to the individual pursuant to section 3313(c), as appropriate), except that the aggregate amount paid to an individual under this section may not exceed $30,000."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc369d21f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not pay to such an individual an amount in addition to the amount payable under paragraph (1) by reason of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3317"},"text":"section 3317 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc369d220-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual who receives additional benefits under this section may also receive amounts payable by a college or university pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3317"},"text":"section 3317 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc369d221-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of this chapter or chapter 36 of this title, any additional benefits under this section may not be counted toward the aggregate period for which ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3695"},"text":"section 3695 of this title","children":[],"tail":" limits an individual’s receipt of allowance or assistance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc369d222-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on Transfer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual who receives additional benefits under this section may not transfer any amount of such additional benefits under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3319"},"text":"section 3319 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc369d223-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum Amount of Total Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The total amount of benefits paid to all eligible individuals under this section may not exceed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc369d224-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $25,000,000 for fiscal year 2019;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc36c4225-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $75,000,000 for each of fiscal years 2020 through 2022; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc36c4226-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000,000 for fiscal year 2023 and each subsequent fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc36c4227-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congressional Notice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary identifies a new subject or field pursuant to subsection (b)(4)(A)(i)(XI) as meeting a national need, the Secretary shall submit to Congress notice of such identification at least 90 days before conferring eligibility on any individual for purposes of this section on the basis of such identification, including any analysis of labor market supply and demand used in identifying the new subject or field, as applicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc36c4228-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3320/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Clinical Training Program Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “covered clinical training program” means any clinical training required by a health care professional to be licensed to practice in a State or locality.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc36c4229-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/48/tI/s111/a"},"text":"Pub. L. 115–48, title I, § 111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-16"},"text":"Aug. 16, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/982"},"text":"131 Stat. 982","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/36/s1"},"text":"Pub. L. 116–36, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-07-31"},"text":"July 31, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1048"},"text":"133 Stat. 1048","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/315/tI"},"text":"Pub. L. 116–315, title I","children":[],"tail":", §§ 1001, 1002(b)(4), "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4937"},"text":"134 Stat. 4937","children":[],"tail":", 4938.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc36c422a-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc36c422b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc36c422c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(4)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/s1001/a/1"},"text":"Pub. L. 116–315, § 1001(a)(1)","children":[],"tail":", inse