{"tag":"section","attrib":{"id":"idc3ece447-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7112"},"text":null,"children":[{"tag":"num","attrib":{"value":"7112"},"text":"§ 7112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedited treatment of certain claims","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3ece448-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Remanded Claims","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall take such actions as may be necessary to provide for the expeditious treatment by the Board of any claim that is remanded to the Secretary by the Court of Appeals for Veterans Claims.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3ece449-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Claims Involving Military Sexual Trauma","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board shall promptly determine whether a notice of disagreement filed with the Board is a covered case.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3ece44a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7112/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3ece44b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7112/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “covered case” means a case—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3ece44c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7112/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that concerns a claim for compensation based on military sexual trauma; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3ece44d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7112/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which the appellant has requested a hearing in the notice of disagreement filed with the Board pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7105"},"text":"section 7105 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ece44e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7112/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “military sexual trauma” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1166"},"text":"section 1166 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3ece44f-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/183/tVII/s707/b/1"},"text":"Pub. L. 108–183, title VII, § 707(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-16"},"text":"Dec. 16, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2673"},"text":"117 Stat. 2673","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/300/s2/a/1"},"text":"Pub. L. 117–300, § 2(a)(1)","children":[],"tail":", (2)(A), "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4379"},"text":"136 Stat. 4379","children":[],"tail":", 4380.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3ece450-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3ece451-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3ece452-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/300"},"text":"Pub. L. 117–300","children":[],"tail":" substituted “certain” for “remanded” in section catchline, designated existing provisions as subsec. (a) and inserted heading, and added subsecs. (b) and (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
