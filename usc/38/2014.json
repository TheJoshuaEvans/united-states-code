{"tag":"section","attrib":{"id":"idc330991d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2014"},"text":null,"children":[{"tag":"num","attrib":{"value":"2014"},"text":"§ 2014.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training and technical assistance for recipients of certain financial assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc330991e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2014/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall provide training and technical assistance to recipients of grants under sections 2011 and 2013 of this title and recipients of per diem payments under sections 2012 and 2061 of this title regarding the planning, development, and provision of services for which the grant or payment is made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc330991f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2014/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provision of Training and Technical Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may provide training and technical assistance under subsection (a) directly or through grants or contracts with such public or nonprofit private entities as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3309920-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dU/tIII/s305/b/1/B"},"text":"Pub. L. 117–328, div. U, title III, § 305(b)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5471"},"text":"136 Stat. 5471","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3309921-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3309922-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc3309923-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2014 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2016"},"text":"section 2016 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 2014 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4214"},"text":"section 4214 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 2014 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4105"},"text":"section 4105 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3309924-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3309925-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Use of Amounts","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dU/tIII/s305/b/2"},"text":"Pub. L. 117–328, div. U, title III, § 305(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5472"},"text":"136 Stat. 5472","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dU/tIII/s305/b/2"},"text":"“The Secretary of Veterans Affairs shall provide training and technical assistance under sections 2014 and 2015 of such title [meaning title 38, United States Code], as inserted by paragraph (1)(B), using amounts appropriated or otherwise made available to the Department of Veterans Affairs on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
