{"tag":"section","attrib":{"id":"idc2afd05b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1171"},"text":null,"children":[{"tag":"num","attrib":{"value":"1171"},"text":"§ 1171.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures to determine presumptions of service connection based on toxic exposure; definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2afd05c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1171/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall determine whether to establish, or to remove, presumptions of service connection based on toxic exposure pursuant to this subchapter, whereby—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2afd05d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1171/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1172"},"text":"section 1172 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2afd05e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1171/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary provides—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc2afd05f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1171/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public notice regarding what formal evaluations the Secretary plans to conduct; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc2afd060-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1171/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public an opportunity to comment on the proposed formal evaluations;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2afd061-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1171/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the working group established under subsection (b) of such section provides—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc2afd062-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1171/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advice to the Secretary on toxic-exposed veterans and cases in which veterans who, during active military, naval, air, or space service, may have experienced a toxic exposure or their dependents may have experienced a toxic exposure while the veterans were serving in the active military, naval, air, or space service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc2afd063-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1171/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations to the Secretary on corrections needed in the Individual Longitudinal Exposure Record to better reflect veterans and dependents described in clause (i); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc2afd064-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1171/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations to the Secretary regarding which cases of possible toxic exposure should be reviewed;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2afd065-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1171/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary provides for formal evaluations of such recommendations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1173"},"text":"section 1173 of this title","children":[],"tail":" and takes into account reports received by the Secretary from the National Academies of Sciences, Engineering, and Medicine under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1176"},"text":"section 1176 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2afd066-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1171/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary issues regulations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1174"},"text":"section 1174 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2afd067-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1171/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2afd068-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1171/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “illness” includes a disease or other condition affecting the health of an individual, including mental and physical health.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2afd069-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1171/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Individual Longitudinal Exposure Record” means the data system maintained under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s996"},"text":"section 996 of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2afd06a-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/168/tII/s202/a"},"text":"Pub. L. 117–168, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-10"},"text":"Aug. 10, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1767"},"text":"136 Stat. 1767","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tV/s521/b"},"text":"Pub. L. 119–60, div. A, title V, § 521(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/864"},"text":"139 Stat. 864","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2afd06b-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc2afd06c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc2afd06d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" amended par. (2) generally. Prior to amendment, par. (2) defined the term “Individual Longitudinal Exposure Record”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc2afd06e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc2afd06f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Correction of Exposure Records by Members of the Armed Forces and Veterans","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/168/tVIII/s803"},"text":"Pub. L. 117–168, title VIII, § 803","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-10"},"text":"Aug. 10, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1802"},"text":"136 Stat. 1802","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/168/tVIII/s803"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Veterans Affairs shall coordinate with the Secretary of Defense to provide a means for veterans to update their records as necessary to reflect exposures to occupational or environmental hazards by such member or veteran in the Individual Longitudinal Exposure Record.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Evidence.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provision of evidence","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To update a record under subsection (a), a veteran shall provide such evidence as the Secretary of Veterans Affairs considers necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Veterans Affairs shall prescribe by regulation the evidence considered necessary under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Individual longitudinal exposure record","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Individual Longitudinal Exposure Record’ has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1171"},"text":"section 1171 of title 38","children":[],"tail":", United States Code, as added by section 202."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Toxic exposure","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘toxic exposure’ has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of title 38","children":[],"tail":", United States Code, as amended by section 102(b).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
