{"tag":"section","attrib":{"id":"idc3e8292d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6309"},"text":null,"children":[{"tag":"num","attrib":{"value":"6309"},"text":"§ 6309.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biennial report to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3e8292e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6309/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall, not later than December 1 of every even-numbered year (beginning in 2008), submit to Congress a report on the outreach activities carried out by the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3e8292f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6309/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under this section shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3e82930-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6309/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the implementation during the preceding fiscal year of the current biennial plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s6302"},"text":"section 6302 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e82931-47c4-11f1-bf59-9680b1269b87","identifier":