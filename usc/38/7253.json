":{"href":"/us/pl/107/103/tVI/s601"},"text":"Pub. L. 107–103, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-27"},"text":"Dec. 27, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/998"},"text":"115 Stat. 998","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tI/s11043/f"},"text":"Pub. L. 107–273, div. C, title I, § 11043(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1856"},"text":"116 Stat. 1856","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/454/tVIII/s802"},"text":"Pub. L. 108–454, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-10"},"text":"Dec. 10, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3625"},"text":"118 Stat. 3625","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/233/tV/s503/15"},"text":"Pub. L. 109–233, title V, § 503(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-06-15"},"text":"June 15, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/417"},"text":"120 Stat. 417","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/389/tVI/s601"},"text":"Pub. L. 110–389, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4176"},"text":"122 Stat. 4176","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/260/tIII/s302/b"},"text":"Pub. L. 112–260, title III, § 302(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-10"},"text":"Jan. 10, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2425"},"text":"126 Stat. 2425","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/315/tII"},"text":"Pub. L. 114–315, title II","children":[],"tail":", §§ 201(a), 204(a), "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1548"},"text":"130 Stat. 1548","children":[],"tail":", 1549; "},{"tag":"ref","attrib":{"href":"/us/pl/116/159/dE/tII/s5205"},"text":"Pub. L. 116–159, div. E, title II, § 5205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-01"},"text":"Oct. 1, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/750"},"text":"134 Stat. 750","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/196/s7"},"text":"Pub. L. 118–196, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2675"},"text":"138 Stat. 2675","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3ece4b2-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3ece4b3-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc3ece4b4-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the Veterans Benefits Improvement Act of 2024, referred to in subsec. (i)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/196"},"text":"Pub. L. 118–196","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3ece4b5-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (i)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/196/s7/1"},"text":"Pub. L. 118–196, § 7(1)","children":[],"tail":", designated existing provisions as subpar. (A), substituted “Subject to paragraph (2), effective during the period beginning on "},{"tag":"date","attrib":{"date":"2009-12-31"},"text":"December 31, 2009","children":[],"tail":", and ending on the date of the enactment of the Veterans Benefits Improvement Act of 2024” for “Subject to paragraph (2), effective as of "},{"tag":"date","attrib":{"date":"2009-12-31"},"text":"December 31, 2009","children":[],"tail":"”, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/196/s7/2"},"text":"Pub. L. 118–196, § 7(2)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2028-01-01"},"text":"January 1, 2028","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2026-01-01"},"text":"January 1, 2026","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (i)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/159"},"text":"Pub. L. 116–159","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2026-01-01"},"text":"January 1, 2026","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"January 1, 2021","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (d)(1)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/315/s204/a/1"},"text":"Pub. L. 114–315, § 204(a)(1)","children":[],"tail":", added subpar. (B) and redesignated former subpar. (B) as (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/315/s204/a/2"},"text":"Pub. L. 114–315, § 204(a)(2)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “In any case in which there is no judge of the Court in regular active service who has served as a judge of the Court for at least one year, the judge of the court in regular active service who is senior in commission and has not served previously as chief judge shall act as the chief judge.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/315/s201/a"},"text":"Pub. L. 114–315, § 201(a)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"January 1, 2021","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2013-01-01"},"text":"January 1, 2013","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/260"},"text":"Pub. L. 112–260","children":[],"tail":", which directed substitution of “engaging in the practice of law, or violating "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7255/c"},"text":"section 7255(c) of this title","children":[],"tail":"” for “or engaging in the practice of law” in section 7253(f)(1), without specifying the Code title to be amended, was executed to subsec. (f)(1) of this section, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/389"},"text":"Pub. L. 110–389","children":[],"tail":" added subsec. (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (d)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/233"},"text":"Pub. L. 109–233","children":[],"tail":" substituted “Court” for “court”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/454/s802/a"},"text":"Pub. L. 108–454, § 802(a)","children":[],"tail":", inserted “The chief judge of the Court is the head of the Court.” after “(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/454/s802/b"},"text":"Pub. L. 108–454, § 802(b)","children":[],"tail":", substituted “Court” for “court” in cls. (i) and (ii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/454/s802/c"},"text":"Pub. L. 108–454, § 802(c)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2001-12-27"},"text":"December 27, 2001","children":[],"tail":",” for “the date of the enactment of this subsection”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (g)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/s11043/f/1"},"text":"Pub. L. 107–273, § 11043(f)(1)","children":[],"tail":", substituted “chapter 16” for “section 372(c)” and “such chapter” for “such section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/s11043/f/2"},"text":"Pub. L. 107–273, § 11043(f)(2)","children":[],"tail":", substituted “sections 354(b) through 360” for “paragraphs (7) through (15) of section 372(c)” and “section 354(b) or 355” for “paragraph (7) or (8) of section 372(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/s11043/f/3"},"text":"Pub. L. 107–273, § 11043(f)(3)","children":[],"tail":", substituted “361” for “372(c)(16)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsecs. (b), (c), (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/103/s601/b"},"text":"Pub. L. 107–103, § 601(b)","children":[],"tail":", inserted subsec. headings."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/103/s601/a"},"text":"Pub. L. 107–103, § 601(a)","children":[],"tail":", added subsec. (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117/s1031"},"text":"Pub. L. 106–117, § 1031","children":[],"tail":", inserted heading and amended text of subsec. (a) generally. Prior to amendment, text read as follows: “The Court of Appeals for Veterans Claims shall be composed of a chief judge and at least two and not more than six associate judges.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117/s1032/a"},"text":"Pub. L. 106–117, § 1032(a)","children":[],"tail":", inserted heading and amended text of subsec. (d) generally. Prior to amendment, text read as follows: “The chief judge is the head of the Court”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117/s1033"},"text":"Pub. L. 106–117, § 1033","children":[],"tail":", inserted heading and amended text of subsec. (e) generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(e)(1) The chief judge of the Court shall receive a salary at the same rate as is received by judges of the United States Courts of Appeals.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Each judge of the Court, other than the chief judge, shall receive a salary at the same rate as is received by judges of the United States district courts.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/s512/a/1"},"text":"Pub. L. 105–368, § 512(a)(1)","children":[],"tail":", substituted “Court of Appeals for Veterans Claims” for “Court of Veterans Appeals”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/s512/a/1"},"text":"Pub. L. 105–368, § 512(a)(1)","children":[],"tail":", substituted “Court of Appeals for Veterans Claims” for “Court of Veterans Appeals”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/s501"},"text":"Pub. L. 105–368, § 501","children":[],"tail":", inserted at end “A judge who is nominated by the President for appointment to an additional term on the Court without a break in service and whose term of office expires while that nomination is pending before the Senate may continue in office for up to 1 year while that nomination is pending.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/585"},"text":"Pub. L. 102–585","children":[],"tail":" designated existing provisions as par. (1) and added pars. (2) and (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4053"},"text":"section 4053 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/82"},"text":"Pub. L. 102–82","children":[],"tail":" added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/94"},"text":"Pub. L. 101–94","children":[],"tail":" inserted “or” before “engaging” and substituted “law” for “law, or physical or mental disability which, in the opinion of the President, prevents the proper execution of the judge’s duties”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3ece4b6-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3ece4b7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/315/tII/s204/b"},"text":"Pub. L. 114–315, title II, § 204(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1550"},"text":"130 Stat. 1550","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/315/tII/s204/b"},"text":"“The amendments made by subsection (a) [amending this section] shall apply with respect to the selection of a chief judge occurring on or after ","children":[{"tag":"date","attrib":{"date":"2020-01-01"},"text":"January 1, 2020","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3ece4b8-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/260"},"text":"Pub. L. 112–260","children":[],"tail":" effective on the date that is 180 days after "},{"tag":"date","attrib":{"date":"2013-01-10"},"text":"Jan. 10, 2013","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/260/s302/c/1"},"text":"section 302(c)(1) of Pub. L. 112–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7255"},"text":"section 7255 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/260/tIII/s302/c/2"},"text":"Pub. L. 112–260, title III, § 302(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-10"},"text":"Jan. 10, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2426"},"text":"126 Stat. 2426","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/260/tIII/s302/c/2"},"text":"“The amendment made by subsection (b) [amending this section] shall apply with respect to judges confirmed on or after ","children":[{"tag":"date","attrib":{"date":"2012-01-01"},"text":"January 1, 2012","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3ece4b9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1999 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117/tX/s1036"},"text":"Pub. L. 106–117, title X, § 1036","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-30"},"text":"Nov. 30, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1595"},"text":"113 Stat. 1595","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/117/tX/s1036"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this subtitle [subtitle C (§§ 1031–1036) of title X of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117"},"text":"Pub. L. 106–117","children":[],"tail":", amending this section and sections 7254, 7281, 7296, and 7297 of this title] shall take effect on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1999-11-30"},"text":"Nov. 30, 1999","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Savings Provision for Incumbent Chief Judge","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this subtitle shall not apply while the individual who is chief judge of the Court [United States Court of Appeals for Veterans Claims] on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1999-11-30"},"text":"Nov. 30, 1999","children":[],"tail":"] continues to serve as chief judge. If that individual, upon termination of service as chief judge, provides notice under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7257"},"text":"section 7257 of title 38","children":[],"tail":", United States Code, of availability for service in a recalled status, the rate of pay applicable to that individual under section 7296(c)(1)(A) of such title while serving in a recalled status shall be at the rate of pay applicable to that individual at the time of retirement, if greater than the rate otherwise applicable under that section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3ece4ba-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/s512/a/1"},"text":"section 512(a)(1) of Pub. L. 105–368","children":[],"tail":" effective on first day of first month beginning more than 90 days after "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/368/s513"},"text":"section 513 of Pub. L. 105–368","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7251"},"text":"section 7251 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3ece4bb-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Initial Appointment of Judges to Court of Veterans Appeals","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/687/s302"},"text":"Section 302 of Pub. L. 100–687","children":[],"tail":" prohibited President from appointing associate judges of the United States Court of Veterans Appeals under subsec. (b) of this section, until the chief judge of such Court has been appointed and that judges could be appointed after "},{"tag":"date","attrib":{"date":"1989-02-01"},"text":"Feb. 1, 1989","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
