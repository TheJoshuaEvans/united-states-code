{"tag":"section","attrib":{"id":"idc308021e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1723"},"text":null,"children":[{"tag":"num","attrib":{"value":"1723"},"text":"§ 1723.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Furnishing of clothing","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall not furnish clothing to persons who are in Department facilities, except (1) where the furnishing of such clothing to indigent persons is necessary to protect health or sanitation, and (2) where the Secretary furnishes veterans with special clothing made necessary by the wearing of prosthetic appliances.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc308021f-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1144"},"text":"72 Stat. 1144","children":[],"tail":", § 623; "},{"tag":"ref","attrib":{"href":"/us/pl/94/581/tII/s210/a/10"},"text":"Pub. L. 94–581, title II, § 210(a)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2863"},"text":"90 Stat. 2863","children":[],"tail":"; renumbered § 1723 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":", §§ 4(a)(3), (4), (b)(1), (2)(E), 5(a), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404-406"},"text":"105 Stat. 404–406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3080220-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","a