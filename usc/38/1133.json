{"tag":"section","attrib":{"id":"idc2a8a4f6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1133"},"text":null,"children":[{"tag":"num","attrib":{"value":"1133"},"text":"§ 1133.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presumptions relating to certain diseases","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2a8a4f7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1133/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1131"},"text":"section 1131 of this title","children":[],"tail":", and subject to the provisions of subsections (b) and (c) of this section, any veteran who served for six months or more and contracts a tropical disease or a resultant disorder or disease originating because of therapy administered in connection with a tropical disease, or as a preventative thereof, shall be deemed to have incurred such disability in the active military, naval, air, or space service when it is shown to exist within one year after separation from active service, or at a time when standard and accepted treatises indicate that the incubation period thereof commenced during active service."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2a8a4f8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1133/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Service-connection shall not be granted pursuant to subsection (a), in any case where the disease or disorder is shown by clear and unmistakable evidence to have had its inception before or after active military, naval, air, or space service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2a8a4f9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1133/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this section shall be construed to prevent the granting of service-connection for any disease or disorder otherwise shown by sound judgment to have been incurred in or aggravated by active military, naval, air, or space service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2a8a4fa-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1123"},"text":"72 Stat. 1123","children":[],"tail":", § 333; renumbered § 1133 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s926/a/12"},"text":"Pub. L. 116–283, div. A, title IX, § 926(a)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3830"},"text":"134 Stat. 3830","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2a8a4fb-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc2a8a4fc-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc2a8a4fd-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “air, or space service” for “or air service” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s333"},"text":"section 333 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “1131” for “331”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
