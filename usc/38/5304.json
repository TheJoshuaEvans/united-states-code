dren":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/850"},"text":"129 Stat. 850","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3d787b7-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3d787b8-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3d787b9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Pub. L. 114–92","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/454"},"text":"Pub. L. 108–454","children":[],"tail":" inserted “as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1414"},"text":"section 1414 of title 10","children":[],"tail":" or” after “Except”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/b/1"},"text":"Pub. L. 102–40, § 402(b)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3104"},"text":"section 3104 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “1521” and “1541” for “521” and “541”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/d/1"},"text":"Pub. L. 102–40, § 402(d)(1)","children":[],"tail":", substituted “5305” for “3105” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “1521(i)” for “521(i)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/1"},"text":"Pub. L. 102–83, § 4(a)(1)","children":[],"tail":", substituted “administered by the Secretary” for “administered by the Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576/s701/71/A"},"text":"Pub. L. 99–576, § 701(71)(A)","children":[],"tail":", substituted “such person’s” for “his”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576/s701/71/B/i"},"text":"Pub. L. 99–576, § 701(71)(B)(i)","children":[],"tail":", (ii), substituted “surviving spouse” for “widow” and “such person’s” for “his”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576/s701/71/B/iii"},"text":"Pub. L. 99–576, § 701(71)(B)(iii)","children":[],"tail":", substituted “such person” for “he or she”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576/s701/71/C"},"text":"Pub. L. 99–576, § 701(71)(C)","children":[],"tail":", substituted “any person’s” for “his”, “to such person” for “to any person”, and “such person” for “he”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/385"},"text":"Pub. L. 96–385","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/588"},"text":"Pub. L. 95–588","children":[],"tail":" inserted “of this subsection and in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s521/i"},"text":"section 521(i) of this title","children":[],"tail":"” after “(2) and (3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (b)(1), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/376"},"text":"Pub. L. 91–376","children":[],"tail":" inserted reference to par. (3) in par. (1) and added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1964—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/664"},"text":"Pub. L. 88–664","children":[],"tail":" inserted “or concurrently to any person based on the service of any other person” after “own service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/495"},"text":"Pub. L. 86–495","children":[],"tail":" substituted provisions prohibiting the payment or furnishing of benefits other than insurance to or on account of any child by reason of the death of more than one parent in the same parental line, and permitting the child to elect one or more times to receive benefits by reason of the death of any one of such parents, for provisions which prohibited the payment of dependency and indemnity compensation to or on account of a child by reason of the death of another parent where the child receives or there is paid by the Veterans’ Administration on account of a child dependency and indemnity compensation, or death compensation, by reason of the death of a parent."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3d787ba-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3d787bb-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment; Implementation","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Pub. L. 114–92","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2018-01-01"},"text":"Jan. 1, 2018","children":[],"tail":", with certain implementation requirements, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/s635"},"text":"section 635 of Pub. L. 114–92","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8432"},"text":"section 8432 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3d787bc-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/385"},"text":"Pub. L. 96–385","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-10-01"},"text":"Oct. 1, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/385/s601/b"},"text":"section 601(b) of Pub. L. 96–385","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1114"},"text":"section 1114 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3d787bd-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/u