":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3d787c0-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1960 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/86/495/s2"},"text":"Pub. L. 86–495, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-06-08"},"text":"June 8, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/163"},"text":"74 Stat. 163","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/86/495/s2"},"text":"“The amendment made by this Act [amending this section] shall apply only to cases where the death of a parent occurs after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1960-06-08"},"text":"June 8, 1960","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
