{"tag":"section","attrib":{"id":"idc3d787aa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5304"},"text":null,"children":[{"tag":"num","attrib":{"value":"5304"},"text":"§ 5304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition against duplication of benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3d787ab-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3d787ac-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5304/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1414"},"text":"section 1414 of title 10","children":[],"tail":" or to the extent that retirement pay is waived under other provisions of law, not more than one award of pension, compensation, emergency officers’, regular, or reserve retirement pay, or initial award of naval pension granted after "},{"tag":"date","attrib":{"date":"1943-07-13"},"text":"July 13, 1943","children":[],"tail":", shall be made concurrently to any person based on such person’s own service or concurrently to any person based on the service of any other person."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d787ad-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5304/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding the provisions of paragraph (1) of this subsection and of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5305"},"text":"section 5305 of this title","children":[],"tail":", pension under section 1521 or 1541 of this title may be paid to a person entitled to receive retired or retirement pay described in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5305"},"text":"section 5305 of this title","children":[],"tail":" concurrently with such person’s receipt of such retired or retirement pay if the annual amount of such retired or retirement pay is counted as annual income for the purposes of chapter 15 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d787ae-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3d787af-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5304/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraphs (2) and (3) of this subsection and in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1521/i"},"text":"section 1521(i) of this title","children":[],"tail":", the receipt of pension, compensation, or dependency and indemnity compensation by a surviving spouse, child, or parent on account of the death of any person, or receipt by any person of pension or compensation on account of such person’s own service, shall not bar the payment of pension, compensation, or dependency and indemnity compensation on account of the death or disability of any other person."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d787b0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5304/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Benefits other than insurance under laws administered by the Secretary may not be paid or furnished to or on account of any child by reason of the death of more than one parent in the same parental line; however, the child may elect one or more times to receive benefits by reason of the death of any one of such parents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d787b1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5304/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Benefits other than insurance under laws administered by the Secretary may not be paid to any person by reason of the death of more than one person to whom such person was married; however, the person may elect one or more times to receive benefits by reason of the death of any one spouse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d787b2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5304/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pension, compensation, or retirement pay on account of any person’s own service shall not be paid to such person for any period for which such person receives active service pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d787b3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5304/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3d787b4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5304/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other than amounts payable under section 1413a or 1414 of title 10, the amount of pension and compensation benefits payable to a person under this title shall be reduced by the amount of any lump sum payment made to such person under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1415"},"text":"section 1415 of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d787b5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5304/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall collect any reduction under paragraph (1) from amounts otherwise payable to the person under this title, including pension and compensation payable under this title, before any pension and compensation payments under this title may be paid to the person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3d787b6-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1230"},"text":"72 Stat. 1230","children":[],"tail":", § 3104; "},{"tag":"ref","attrib":{"href":"/us/pl/86/495/s1"},"text":"Pub. L. 86–495, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-06-08"},"text":"June 8, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/163"},"text":"74 Stat. 163","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/664/s9"},"text":"Pub. L. 88–664, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-10-13"},"text":"Oct. 13, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1096"},"text":"78 Stat. 1096","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/376/s6"},"text":"Pub. L. 91–376, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/790"},"text":"84 Stat. 790","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/588/tIII/s304"},"text":"Pub. L. 95–588, title III, § 304","childre