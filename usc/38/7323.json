{"tag":"section","attrib":{"id":"idc3fb3c67-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7323"},"text":null,"children":[{"tag":"num","attrib":{"value":"7323"},"text":"§ 7323.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required consultations with nurses","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Under Secretary for Health shall ensure that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3fb3c68-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7323/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the director of a geographic service area, in formulating policy relating to the provision of patient care, shall consult regularly with a senior nurse executive or senior nurse executives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fb3c69-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7323/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the director of a medical center shall include a registered nurse as a member of any committee used at that medical center to provide recommendations or decisions on medical center operations or policy affecting clinical services, clinical outcomes, budget, or resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3fb3c6a-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/419/tII/s201/b/1"},"text":"Pub. L. 106–419, title II, § 201(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1840"},"text":"114 Stat. 1840","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
