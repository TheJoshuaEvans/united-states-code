210"},"text":"105 Stat. 210","children":[],"tail":". See sections 7404, 7426, and 7453 to 7457 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3bd4867-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/56/s238/1"},"text":"Pub. L. 112–56, § 238(1)","children":[],"tail":", substituted “paragraph (1)” for “clause (1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/56/s238/2"},"text":"Pub. L. 112–56, § 238(2)","children":[],"tail":"–(4), added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/288/s5/a/1/D"},"text":"Pub. L. 107–288, § 5(a)(1)(D)","children":[],"tail":", substituted “intensive services” for “employment counseling services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/288/s5/d/1/E"},"text":"Pub. L. 107–288, § 5(d)(1)(E)","children":[],"tail":", inserted second and third sentences and struck out former second sentence which read as follows: “A full report as to the extent and reasons for any noncompliance by any such State agency during any fiscal year, together with the agency’s plan for corrective action during the succeeding year, shall be included in the annual report of the Secretary required by subsection (c) of this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/288/s4/a/3/B"},"text":"Pub. L. 107–288, § 4(a)(3)(B)","children":[],"tail":", substituted “The Secretary shall apply performance standards established under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4102A/f"},"text":"section 4102A(f) of this title","children":[],"tail":"” for “The Secretary shall establish definitive performance standards”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/288/s5/d/1/A"},"text":"Pub. L. 107–288, § 5(d)(1)(A)","children":[],"tail":", struck out “veterans of the Vietnam era,” before “disabled veterans, special” and substituted “eligible persons, recently separated veterans (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4211/6"},"text":"section 4211(6) of this title","children":[],"tail":"), and servicemembers transitioning to civilian careers who registered for assistance with, or who are identified as veterans by,” for “and eligible persons who registered for assistance with”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/288/s5/a/1/E"},"text":"Pub. L. 107–288, § 5(a)(1)(E)","children":[],"tail":", substituted “the number who received intensive services” for “the number counseled”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/288/s5/d/1/B"},"text":"Pub. L. 107–288, § 5(d)(1)(B)","children":[],"tail":", substituted “the rate of entered employment (as determined in a manner consistent with State performance measures applicable under section 136(b) of the Workforce Investment Act of 1998) for each of the categories” for “the job placement rate for each of the categories” and “such rate of entered employment (as so determined) for nonveterans” for “the job placement rate for nonveterans”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/288/s5/d/1/C"},"text":"Pub. L. 107–288, § 5(d)(1)(C)","children":[],"tail":", substituted “section 4212(d)” for “sections 4103A and 4104”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/288/s4/e/1"},"text":"Pub. L. 107–288, § 4(e)(1)","children":[],"tail":", struck out “(including the need for any changes in the formulas governing the appointment of disabled veterans’ outreach program specialists under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4103A/a/2"},"text":"section 4103A(a)(2) of this title","children":[],"tail":" and the assignment of local veterans’ employment representatives under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4104/b"},"text":"section 4104(b) of this title","children":[],"tail":" and the allocation of funds for the support of such specialists and representatives)” after “further legislative action”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/288/s5/d/1/D"},"text":"Pub. L. 107–288, § 5(d)(1)(D)","children":[],"tail":", added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2007"},"text":"section 2007 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “4106” for “2006” in par. (3), “4103A and 4104” for “2003A and 2004” in par. (4), and “4102A(b)” for “2002A(b)”, “4103A(a)(2)” for “2003A(a)(2)”, and “4104(b)” for “2004(b)” in par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323/s15/a/2"},"text":"Pub. L. 100–323, § 15(a)(2)","children":[],"tail":", struck out “of Labor” after “Secretary” in four places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323/s2/d"},"text":"Pub. L. 100–323, § 2(d)","children":[],"tail":", amended subsec. (c) generally. Prior to amendment, subsec. (c) read as follows: “The Secretary of Labor shall report annually to the Congress on the success of the Department of Labor and its affiliated State employment service agencies in carrying out the provisions of this chapter. The report shall include, by State, specification of the numbers of eligible veterans, veterans of the Vietnam era, disabled veterans, special disabled veterans, and eligible persons who registered for assistance with the public employment service system and, of each of such categories, the number referred to jobs, the number placed in permanent jobs as defined by the Secretary, the number referred to and the number placed in employment and job training programs supported by the Federal Government, the number counseled, and the number who received some reportable service. The report shall also include any determination by the Secretary under section 2004, 2006, or 2007(a) of this title and a statement of the reasons for such determination. The report shall also include a report on activities carried out under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2003A"},"text":"section 2003A of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/306"},"text":"Pub. L. 97–306","children":[],"tail":" inserted provision that the report shall also include a report on activities carried out under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2003A"},"text":"section 2003A of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466/s507/1"},"text":"Pub. L. 96–466, § 507(1)","children":[],"tail":", substituted “veterans of the Vietnam era and disabled veterans” for “those veterans who have been recently discharged or released from active duty”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466/s507/2"},"text":"Pub. L. 96–466, § 507(2)","children":[],"tail":", substituted provisions that the report include, by State, specification of the numbers of eligible veterans, veterans of the Vietnam era, disabled veterans, special disabled veterans, and eligible persons who registered for assistance with the public employment service system and, of each of such categories, the number referred to jobs, the number placed in permanent jobs, the number referred to and the number placed in employment and job training programs supported by the Federal Government, the number counseled, and the number who received some reportable service for provisions that the report include, by State, the number of recently discharged or released eligible veterans, veterans with service-connected disabilities, other eligible veterans, and eligible persons who requested assistance through the public employment service and, of these, the number placed in suitable employment or job training opportunities or who were otherwise assisted, with separate reference to occupational training and public service employment under appropriate Federal law."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/202"},"text":"Pub. L. 95–202","children":[],"tail":" directed that “2004” be substituted for “2001”. Since subsec. (c) already contained a reference to “2004” not “2001”, the amendment has been carried as a reenactment of subsec. (c) without change."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/502/s604/1"},"text":"Pub. L. 94–502, § 604(1)","children":[],"tail":", substituted “such veteran’s and eligible person’s” for “his”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/502/s604/2"},"text":"Pub. L. 94–502, § 604(2)","children":[],"tail":", (3), substituted “occupational training and public service employment” for “occupational training” and “section 2004, 2006, or 2007(a)” for “section 2004 or 2006”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/508/s401/f/1"},"text":"Pub. L. 93–508, § 401(f)(1)","children":[],"tail":", substituted “active duty and each eligible person” for “active duty”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/508/s401/f/2"},"text":"Pub. L. 93–508, § 401(f)(2)","children":[],"tail":", added subsec. (b) and redesignated former subsec. (b) as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/508/s401/f/2"},"text":"Pub. L. 93–508, § 401(f)(2)","children":[],"tail":", (3), redesignated former subsec. (b) as (c) and substituted “other eligible veterans, and eligible persons” for “and other eligible veterans”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3bd4868-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3bd4869-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/288/s4/a/3/B"},"text":"section 4(a)(3)(B) of Pub. L. 107–288","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2002-11-07"},"text":"Nov. 7, 2002","children":[],"tail":", and applicable for program and fiscal years under this chapter beginning on or after such date