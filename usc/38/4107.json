ren":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/202"},"text":"Pub. L. 95–202","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1977-11-23"},"text":"Nov. 23, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/202/s501"},"text":"section 501 of Pub. L. 95–202","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3bd486c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/502"},"text":"Pub. L. 94–502","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1976-12-01"},"text":"Dec. 1, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/502/s703/c"},"text":"section 703(c) of Pub. L. 94–502","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3693"},"text":"section 3693 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3bd486d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1974 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/508"},"text":"Pub. L. 93–508","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1974-12-03"},"text":"Dec. 3, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/508/s503"},"text":"section 503 of Pub. L. 93–508","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3452"},"text":"section 3452 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3bd486e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after ","children":[{"tag":"date","attrib":{"date":"1972-10-24"},"text":"Oct. 24, 1972","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/92/540/s601/b"},"text":"section 601(b) of Pub. L. 92–540","children":[],"tail":", set out as an Effective Date of 1972 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4101"},"text":"section 4101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3bd486f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Publication of Labor-Market Statistics Relating to Veterans Who Served in Vietnam Theatre of Operations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466/tV/s513"},"text":"Pub. L. 96–466, title V, § 513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2207"},"text":"94 Stat. 2207","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/466/tV/s513"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the Commissioner of the Bureau of Labor Statistics publishes annual labor-market statistics relating specifically to veterans who served in the Armed Forces during the Vietnam era, the Commissioner shall also publish separate labor-market statistics on the same subject matter which apply only to veterans who served in the Vietnam theatre of operations. When the Commissioner of the Bureau of Labor Statistics publishes labor-market statistics which relate specifically to veterans who served in the Armed Forces during the Vietnam era in addition to those statistics published on an annual basis to which the preceding sentence applies, the Commissioner shall also, if feasible, publish separate labor-market statistics on the same subject matter which apply only to veterans who served in the Vietnam theatre of operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of this section, veterans who during the Vietnam era served in Vietnam, in air missions over Vietnam, or in naval missions in the waters adjacent to Vietnam shall be considered to be veterans who served in the Vietnam theatre of operations.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466/tVIII/s802/e"},"text":"Pub. L. 96–466, title VIII, § 802(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2218"},"text":"94 Stat. 2218","children":[],"tail":", provided in part that the provisions of "},{"tag":"ref","attrib":{"href":"/us/pl/96/466/s513"},"text":"section 513 of Pub. L. 96–466","children":[],"tail":", set out above, shall become effective on "},{"tag":"date","attrib":{"date":"1980-10-01"},"text":"Oct. 1, 1980","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
