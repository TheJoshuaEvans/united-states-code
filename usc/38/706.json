{"tag":"section","attrib":{"id":"idc28e65b7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706"},"text":null,"children":[{"tag":"num","attrib":{"value":"706"},"text":"§ 706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional authority relating to recruitment and retention of personnel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc28e65b8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recruitment and Relocation Bonuses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may pay a recruitment or relocation bonus under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5753/e"},"text":"section 5753(e) of title 5","children":[],"tail":" without regard to any requirements for certification or approval under that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc28e65b9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retention Bonuses","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc28e65ba-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may pay a retention bonus under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5754/f"},"text":"section 5754(f) of title 5","children":[],"tail":" without regard to any requirement for certification or approval under that subsection."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28e65bb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may pay a retention bonus as specified in subsection (e)(2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5754"},"text":"section 5754 of title 5","children":[],"tail":" and may pay the bonus as a single lump-sum payment at the beginning of the full period of service required by an agreement under subsection (d) of such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc28e65bc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Merit Awards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may grant a cash award under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s4502/b"},"text":"section 4502(b) of title 5","children":[],"tail":" without regard to any requirement for certification or approval under that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc28e65bd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Incentives for Critical Skills","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc28e65be-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to the provisions of this paragraph, the Secretary may provide a critical skill incentive to an employee in a case in which the Secretary determines—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc28e65bf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee possesses a high-demand skill or skill that is at a shortage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc28e65c0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such skill is directly related to the duties and responsibilities of the employee’s position; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc28e65c1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employment of an individual with such skill in such position serves a critical mission-related need of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28e65c2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An incentive provided to an employee under paragraph (1) may not to ","children":[{"tag":"ref","attrib":{"idref":"fn002015"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002015"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “to” probably should not appear."}],"tail":" exceed 25 percent of the basic pay of the employee."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28e65c3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provision of an incentive under paragraph (1) shall be contingent on the employee entering into a written agreement to complete a period of employment with the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28e65c4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An incentive provided under paragraph (1) shall not be considered basic pay for any purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28e65c5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may prescribe conditions, including with respect to eligibility, and limitations on provision of incentive ","children":[{"tag":"ref","attrib":{"idref":"fn002016"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002016"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be preceded by “an”."}],"tail":" under paragraph (1)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28e65c6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Incentive ","children":[{"tag":"ref","attrib":{"idref":"fn002017"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002017"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. Probably should be “An incentive”."}],"tail":" provided under paragraph (1) shall not be included in the calculation of total amount of compensation under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7431/e/4"},"text":"section 7431(e)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28e65c7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc28e65c8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/d/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subparagraph (B)(ii), a critical skill incentive may not be provided under paragraph (1) to an employee of the Department employed in a Senior Executive Service position, or a position in another comparable system for senior-level Government employees, as defined by the Secretary, whose position is at the Central Office of the Department, including the Veterans Health Administration, the Veterans Benefits Administration, and the National Cemetery Administration, regardless of the actual location where the employee performs the functions of the position.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc28e65c9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/d/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc28e65ca-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/d/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A critical skill incentive provided under paragraph (1) to an employee of the Department employed in a Senior Executive Service position, or a position in another comparable system for senior-level Government employees, as defined by the Secretary, not described in subparagraph (A) of this paragraph may only be provided—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc28e65cb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/d/7/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on an individual basis and may not be provided to a group of such employees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc28e65cc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/d/7/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" upon approval of the following officers or those serving in an acting capacity:","children":[],"tail":null},{"tag":"item","attrib":{"id":"idc28e65cd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/d/7/B/i/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary for Benefits, the Under Secretary for Health, or the Under Secretary for Memorial Affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idc28e65ce-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/d/7/B/i/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary for Human Resources and Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idc28e65cf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/d/7/B/i/II/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Office of Management or the Chief Financial Officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idc28e65d0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/d/7/B/i/II/dd"},"text":null,"children":[{"tag":"num","attrib":{"value":"dd"},"text":"(dd)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary for Accountability and Whistleblower Protection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idc28e65d1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/d/7/B/i/II/ee"},"text":null,"children":[{"tag":"num","attrib":{"value":"ee"},"text":"(ee)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The General Counsel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idc28e65d2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/d/7/B/i/II/ff"},"text":null,"children":[{"tag":"num","attrib":{"value":"ff"},"text":"(ff)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other officers as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc28e65d3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/d/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of an employee of the Department employed in a Senior Executive Service position, or a position in another comparable system for senior-level Government employees, as defined by the Secretary, whose position is primarily at the Central Office of the Department, but who performs some portion of the employee’s job function at other facilities of the Department, as defined by the Secretary, not at Central ","children":[{"tag":"ref","attrib":{"idref":"fn002018"},"text":"4","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002018"},"text":null,"children":[{"tag":"num","attrib":{},"text":"4","children":[],"tail":" So in original. Probably should be preceded by “the”."}],"tail":" Office—"}],"tail":null},{"tag":"subclause","attrib":{"id":"idc28e65d4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/d/7/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee shall not be considered described in subparagraph (A) with respect to the portion of the employee’s job function that is based out of non-Central Office facilities of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc28e65d5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/d/7/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any critical skill incentive provided under paragraph (1) to the employee for the portion of the employee’s job function that is based out of facilities of the Department other than the Central Office shall be proportionate to the time spent at those Department facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc28e65d6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/d/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc28e65d7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/d/7/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than one year after the date of the enactment of the Protecting Regular Order for Veterans Act of 2025, and not less frequently than once each year thereafter, the Secretary shall submit to the Committee on Veterans’ Affairs of the Senate and the Committee on Veterans’ Affairs of the House of Representatives an annual report on the employees of the Department employed in a Senior Executive Service position, or a position in another comparable system for senior-level Government employees, as defined by the Secretary, who were provided a critical skill incentive under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc28e65d8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/d/7/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reports submitted pursuant to clause (i) may be submitted by incorporating their contents into other congressionally mandated reports to the committees described in such clause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc28e65d9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/d/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this paragraph, the term “Senior Executive Service position” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3132/a"},"text":"section 3132(a) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc28e65da-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Student Loan Repayments","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc28e65db-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to the provisions of this subsection, the Secretary may repay a student loan pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5379/b"},"text":"section 5379(b) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28e65dc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (2) of such section shall not apply to payment under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28e65dd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Payment under this subsection shall be made subject to such terms, limitations, or conditions as may be mutually agreed to by the Secretary and the employee concerned, except that the amount paid by the Secretary under this subsection may not exceed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc28e65de-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $40,000 for any employee in any calendar year; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc28e65df-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a total of $100,000 in the case of any employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc28e65e0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expedited Hiring Authority for College Graduates; Competitive Service","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc28e65e1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2) of this subsection, the Secretary may expedite hiring for college graduates under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3115"},"text":"section 3115 of title 5","children":[],"tail":" without regard to subsection (e) of such section or any regulations prescribed by the Office of Personnel Management for administration of such subsection."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28e65e2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of employees the Secretary may appoint under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3115"},"text":"section 3115 of title 5","children":[],"tail":" may not exceed the number equal to 25 percent of individuals that the Secretary appointed during the previous fiscal year to a position in the competitive service classified in a professional or administrative occupational category, at the GS–11 level, or an equivalent level, or below, under a competitive examining procedure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc28e65e3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expedited Hiring Authority for Post-secondary Students; Competitive Service","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc28e65e4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2) of this subsection, the Secretary may expedite hiring of post-secondary students under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3116"},"text":"section 3116 of title 5","children":[],"tail":", without regard to subsection (d) of such section or any regulations prescribed by the Office of Personnel Management for administration of such subsection."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28e65e5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of employees the Secretary may appoint under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3116"},"text":"section 3116 of title 5","children":[],"tail":" may not exceed the number equal to 25 percent of the number of students that the Secretary appointed during the previous fiscal year to a position at the GS–11 level, or an equivalent level, or below."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc28e65e6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pay Authority for Critical Positions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc28e65e7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to the provisions of this subsection, the Secretary may authorize the fixing of the rate of pay for a critical position in the Department consistent with the authorities and requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5377"},"text":"section 5377 of title 5","children":[],"tail":" that apply to the Office of Personnel Management."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28e65e8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may fix the rate of pay for a critical position under this subsection in excess of the limitation set forth by section 5377(d)(2) of such title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28e65e9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Basic pay may not be fixed under this subsection at a rate greater than the rate payable for the Vice President of the United States established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s104"},"text":"section 104 of title 3","children":[],"tail":", except upon written approval of the President."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28e65ea-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5377/f"},"text":"section 5377(f) of title 5","children":[],"tail":", the Secretary may authorize the exercise of authority under this subsection with respect to up to 200 positions at any time."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc28e65eb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rates of Special Pay","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc28e65ec-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may establish a rate for special pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5305/a/1"},"text":"section 5305(a)(1) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28e65ed-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In applying such section to the Secretary’s authority under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc28e65ee-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “50 percent” shall be substituted for “30 percent”; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc28e65ef-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “level II of the Executive Schedule” shall be substituted for “level IV of the Executive Schedule”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc28e65f0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver of Limitations on Certain Payments Under Pay Comparability System","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may waive the limitation in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5307"},"text":"section 5307 of title 5","children":[],"tail":" for an employee or a payment."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc28e65f1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s706/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authorities under this section shall terminate on ","children":[{"tag":"date","attrib":{"date":"2027-09-30"},"text":"September 30, 2027","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc28e65f2-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/168/tIX/s909"},"text":"Pub. L. 117–168, title IX, § 909","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-10"},"text":"Aug. 10, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1815"},"text":"136 Stat. 1815","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/33/s1/c"},"text":"Pub. L. 119–33, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-08-14"},"text":"Aug. 14, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/484"},"text":"139 Stat. 484","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc28e65f3-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc28e65f4-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc28e65f5-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the Protecting Regular Order for Veterans Act of 2025, referred to in subsec. (d)(7)(C)(i), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/33"},"text":"Pub. L. 119–33","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2025-08-14"},"text":"Aug. 14, 2025","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"GS–11, referred to in subsecs. (f)(2) and (g)(2), is contained in the General Schedule, which is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Levels II and IV of the Executive Schedule, referred to in subsec. (i)(2)(B), are set out in sections 5313 and 5315, respectively, of Title 5, Government Organization and Employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc290d5f6-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 706 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1906"},"text":"section 1906 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc290d5f7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (d)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/33"},"text":"Pub. L. 119–33","children":[],"tail":" added par. (7)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc290d5f8-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc290d5f9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Benefits for Participants in Certain Programs of the Department of Veterans Affairs","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/196/s6"},"text":"Pub. L. 118–196, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2674"},"text":"138 Stat. 2674","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/196/s6"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than one year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":"], the Secretary of Veterans Affairs shall carry out a program to furnish certain benefits to covered participants."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Benefits: Student Loan Repayment; Reimbursements.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to an agreement under paragraph (2), the Secretary shall provide to each covered attorney—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" student loan repayment benefits under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5379"},"text":"section 5379 of title 5","children":[],"tail":", United States Code, in the case of a covered attorney who is eligible for such benefits; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" reimbursement for the cost of—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enrollment in a course designed to prepare an individual for licensure to practice law in a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sitting for a bar examination in a State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annual dues required to maintain membership in the bar of any State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall enter into an agreement with a covered attorney who will receive benefits under paragraph (1). Each such agreement shall specify that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the covered attorney agrees to remain in the service of the Department for a period of not less than three years, unless involuntarily separated; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if separated involuntarily on account of misconduct, or voluntarily, before the end of the period specified in the agreement, the covered attorney shall repay to the United States the amount of any benefits received by the covered participant under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Professional Development Activities.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Mentorship","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the date on which an individual becomes a covered participant, the Secretary shall assign the covered participant a mentor who is an employee of the Department who is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, a managerial employee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outside the participant’s chain of command.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assignments","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"At the election of a covered participant who has completed at least two years of service to the Department, the Secretary shall assign such covered participant to:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Office of General Counsel, in a position—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that includes full-time legal responsibilities in order to further the professional development of the covered participant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a period of not less than 120 days and not more than 180 days, or longer at the discretion of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a covered participant who has already held a position described in subparagraph (A), an assignment described in clauses (i) and (ii) of such subparagraph with the Board of Veterans’ Appeals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other rotational assignments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may provide a covered participant one or more other short-term rotational assignments. Such an assignment shall be for a period of not less than 30 days and not more than 180 days, at the discretion of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Periodic Reports.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than three years after the date on which the Secretary begins to carry out the program under this section, and not less frequently than once every three years thereafter, the Secretary shall submit to the Committee on Veterans’ Affairs of the Senate and the Committee on Veterans’ Affairs of the House of Representatives regarding such program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report submitted under paragraph (1) shall include the following elements:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Costs to the United States to provide benefits under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rates of retention of covered participants compared to other employees of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recommendations of the Secretary regarding legislative or administrative action to improve such program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term ‘covered attorney’ means an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a covered participant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has graduated from a law school accredited by the American Bar Association; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a member in good standing of the bar of a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term ‘covered participant’ means an individual who participates in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Honors Attorney Program (or successor program) of the Office of General Counsel of the Department of Veterans Affairs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Law Clerk Program (or successor program) of the Board of Veterans’ Appeals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘State’ has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of title 38","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
