{"tag":"section","attrib":{"id":"idc3deb33e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5510"},"text":null,"children":[{"tag":"num","attrib":{"value":"5510"},"text":"§ 5510.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall include in the Annual Benefits Report of the Veterans Benefits Administration or the Secretary’s Annual Performance and Accountability Report information concerning fiduciaries who have been appointed to receive payments for beneficiaries of the Department. As part of such information, the Secretary shall separately set forth the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3deb33f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5510/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of beneficiaries in each category (veteran, surviving spouse, child, adult disabled child, or parent).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3deb340-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5510/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The types of benefit being paid (compensation, pension, dependency and indemnity compensation, death pension or benefits payable to a disabled child under chapter 18 of this title).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3deb341-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5510/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total annual amounts and average annual amounts of benefits paid to fiduciaries for each category and type of benefit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3deb342-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5510/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of fiduciaries who are the spouse, parent, legal custodian, court-appointed fiduciary, institutional fiduciary, custodian in fact, and supervised direct payees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3deb343-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5510/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of cases in which the fiduciary was changed by the Secretary because of a finding that benefits had been misused.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3deb344-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5510/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" How such cases of misuse of benefits were addressed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3deb345-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5510/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The final disposition of such cases of misuse of benefits, including the number and dollar amount of any benefits reissued to beneficiaries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3deb346-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5510/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of fiduciary cases referred to the Office of the Inspector General and the nature of the actions taken by the Inspector General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3deb347-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5510/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total amount of money recovered by the Government in cases arising from the misuse of benefits by a fiduciary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3deb348-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5510/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other information as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3deb349-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/454/tV/s505/a"},"text":"Pub. L. 108–454, title V, § 505(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-10"},"text":"Dec. 10, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3621"},"text":"118 Stat. 3621","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/275/tX/s1001"},"text":"Pub. L. 111–275, title X, § 1001","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"2010-10-13"},"text":"Oct. 13, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2897"},"text":"124 Stat. 2897","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3deb34a-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3deb34b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3deb34c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/275/s1001"},"text":"Pub. L. 111–275, § 1001","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1), substituted “following:” for “following: —” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/275/s1001"},"text":"Pub. L. 111–275, § 1001","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2), substituted “Government” for “government”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3deb34d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3deb34e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2004-12-10"},"text":"Dec. 10, 2004","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/454/s507/b/1"},"text":"section 507(b)(1) of Pub. L. 108–454","children":[],"tail":", set out as an Effective Date of 2004 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5312"},"text":"section 5312 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
