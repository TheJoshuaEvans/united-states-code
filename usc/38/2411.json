{"tag":"section","attrib":{"id":"idc34866d4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411"},"text":null,"children":[{"tag":"num","attrib":{"value":"2411"},"text":"§ 2411.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition against interment or memorialization in the National Cemetery Administration or Arlington National Cemetery of persons committing certain Federal or State crimes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc34866d5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc34866d6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of a person described in subsection (b), the appropriate Federal official may not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc34866d7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inter the remains of such person in a cemetery in the National Cemetery Administration or in Arlington National Cemetery; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc34866d8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" honor the memory of such person in a memorial area in a cemetery in the National Cemetery Administration (described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2403/a"},"text":"section 2403(a) of this title","children":[],"tail":") or in such an area in Arlington National Cemetery (described in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2409/a"},"text":"section 2409(a) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc34866d9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a person described in subsection (b)(1), (b)(2), or (b)(4), the prohibition under paragraph (1) shall not apply unless written notice of a conviction referred to in subsection (b)(1), (b)(2), or (b)(4), as the case may be, is received by the appropriate Federal official before the interment or memorialization of such person. Such written notice shall be furnished to such official by the Attorney General, in the case of a Federal crime, or by an appropriate State official, in the case of a State crime.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc34866da-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person referred to in subsection (a) is any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc34866db-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person who has been convicted of a Federal capital crime and whose conviction is final (other than a person whose sentence was commuted by the President).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc34866dc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person who has been convicted of a State capital crime and whose conviction is final (other than a person whose sentence was commuted by the Governor of a State).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc34866dd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc34866de-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is found (as provided in subsection (c)) to have committed a Federal capital crime or a State capital crime, but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc34866df-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not been convicted of such crime by reason of such person not being available for trial due to death or flight to avoid prosecution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc34866e0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc34866e1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has been convicted of a Federal or State crime causing the person to be a tier III sex offender for purposes of the Sex Offender Registration and Notification Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s20901"},"text":"34 U.S.C. 20901","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc34866e2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who, for such crime, is sentenced to a minimum of life imprisonment or to a period of 99 years or more; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc34866e3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose conviction is final (other than a person whose sentence was commuted by the President or Governor of a State, as the case may be).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc34866e4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc34866e5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is found (as provided in subsection (c)) to have committed a Federal or State crime that would cause the person to be a tier III sex offender for purposes of the Sex Offender Registration and Notification Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s20901"},"text":"34 U.S.C. 20901","children":[],"tail":" et seq.); but"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc34866e6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not been convicted of such crime by reason of such person not being available for trial due to death or flight to avoid prosecution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc34866e7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A finding under paragraph (3) or (5) of subsection (b) shall be made by the appropriate Federal official. Any such finding may only be made based upon a showing of clear and convincing evidence, after an opportunity for a hearing in a manner prescribed by the appropriate Federal official.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc34866e8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc34866e9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In a case described in subsection (e), the appropriate Federal official may reconsider a decision to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc34866ea-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inter the remains of a person in a cemetery in the National Cemetery Administration or in Arlington National Cemetery; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc34866eb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" honor the memory of a person in a memorial area in a cemetery in the National Cemetery Administration (described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2403/a"},"text":"section 2403(a) of this title","children":[],"tail":") or in such an area in Arlington National Cemetery (described in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2409/a"},"text":"section 2409(a) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc34866ec-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc34866ed-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc34866ee-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In a case described in subsection (e)(1)(A), the appropriate Federal official shall provide notice to the deceased person’s next of kin or other person authorized to arrange burial or memorialization of the deceased person of the decision of the appropriate Federal official to disinter the remains of the deceased person or to remove a memorial headstone or marker memorializing the deceased person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc34866ef-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In a case described in subsection (e)(1)(B), if the appropriate Federal official finds, based upon a showing of clear and convincing evidence and after an opportunity for a hearing in a manner prescribed by the appropriate Federal official, that the person had committed a Federal capital crime, a State capital crime, or a Federal or State crime that would cause the person to be a tier III sex offender for purposes of the Sex Offender Registration and Notification Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s20901"},"text":"34 U.S.C. 20901","children":[],"tail":" et seq.), but had not been convicted of such crime by reason of such person not being available for trial due to death or flight to avoid prosecution, the appropriate Federal official shall provide notice to the deceased person’s next of kin or other person authorized to arrange burial or memorialization of the deceased person of the decision of the appropriate Federal official to disinter the remains of the deceased person or to remove a memorial headstone or marker memorializing the deceased person."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc34866f0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notice under subparagraph (A) shall be provided by the appropriate Federal official as follows:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc34866f1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" By the Secretary in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5104"},"text":"section 5104 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc34866f2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" By the Secretary of Defense in accordance with such regulations as the Secretary of Defense shall prescribe for purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc34866f3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc34866f4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, the next of kin or other person authorized to arrange burial or memorialization of the deceased person shall be allowed a period of 60 days from the date of the notice required by paragraph (2) to file a notice of disagreement with the Federal official that provided the notice.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc34866f5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc34866f6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A notice of disagreement filed with the Secretary under subparagraph (A) shall be treated as a notice of disagreement filed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7105"},"text":"section 7105 of this title","children":[],"tail":" and shall initiate appellate review in accordance with the provisions of chapter 71 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc34866f7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A notice of disagreement filed with the Secretary of Defense under subparagraph (A) shall be decided in accordance with such regulations as the Secretary of Defense shall prescribe for purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc34866f8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When the decision of the appropriate Federal official to disinter the remains or remove a memorial headstone or marker of the deceased person becomes final either by failure to appeal the decision in accordance with paragraph (3)(A) or by final disposition of the appeal pursuant to paragraph (3)(B), the appropriate Federal official may take any of the following actions:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc34866f9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Disinter the remains of the person from the cemetery in the National Cemetery Administration or in Arlington National Cemetery and provide for the reburial or other appropriate disposition of the disinterred remains in a place other than a cemetery in the National Cemetery Administration or in Arlington National Cemetery.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc34866fa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Remove from a memorial area in a cemetery in the National Cemetery Administration or in Arlington National Cemetery any memorial headstone or marker placed to honor the memory of the person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc34866fb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc34866fc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A case described in this subsection is a case in which the appropriate Federal official receives—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc34866fd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" written notice of a conviction referred to in subsection (b)(1), (b)(2), or (b)(4) of a person described in paragraph (2); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc34866fe-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information that a person described in paragraph (2) may have committed a Federal capital crime, a State capital crime, or a Federal or State crime that would cause the person to be a tier III sex offender for purposes of the Sex Offender Registration and Notification Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s20901"},"text":"34 U.S.C. 20901","children":[],"tail":" et seq.), but was not convicted of such crime by reason of such person not being available for trial due to death or flight to avoid prosecution."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc34866ff-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person described in this paragraph is a person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3486700-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose remains have been interred in a cemetery in the National Cemetery Administration or in Arlington National Cemetery; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3486701-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose memory has been honored in a memorial area in a cemetery in the National Cemetery Administration or in such an area in Arlington National Cemetery.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3486702-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3486703-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Federal capital crime” means an offense under Federal law for which a sentence of imprisonment for life or the death penalty may be imposed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3486704-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State capital crime” means, under State law, the willful, deliberate, or premeditated unlawful killing of another human being for which a sentence of imprisonment for life or the death penalty may be imposed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3486705-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “appropriate Federal official” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3486706-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary, in the case of the National Cemetery Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3486707-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2411/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Army, in the case of Arlington National Cemetery.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3486708-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/116/s1/a"},"text":"Pub. L. 105–116, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2381"},"text":"111 Stat. 2381","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/368/tIV/s403/d/1"},"text":"Pub. L. 105–368, title IV, § 403(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3339"},"text":"112 Stat. 3339","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/330/tII/s202"},"text":"Pub. L. 107–330, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-06"},"text":"Dec. 6, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2824"},"text":"116 Stat. 2824","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tVI/s662/a"},"text":"Pub. L. 109–163, div. A, title VI, § 662(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3314"},"text":"119 Stat. 3314","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/260/tI/s105/a"},"text":"Pub. L. 112–260, title I, § 105(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2013-01-10"},"text":"Jan. 10, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2421"},"text":"126 Stat. 2421","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/65/s2/a"},"text":"Pub. L. 113–65, § 2(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2013-12-20"},"text":"Dec. 20, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/669"},"text":"127 Stat. 669","children":[],"tail":", 671; "},{"tag":"ref","attrib":{"href":"/us/pl/114/58/tVI/s601/14"},"text":"Pub. L. 114–58, title VI, § 601(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-09-30"},"text":"Sept. 30, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/539"},"text":"129 Stat. 539","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/355/s6/a"},"text":"Pub. L. 117–355, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6280"},"text":"136 Stat. 6280","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3486709-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc348670a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc348670b-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Sex Offender Registration and Notification Act, referred to in subsecs. (b)(4)(A), (5)(A), (d)(2)(A)(ii), and (e)(1)(B), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248"},"text":"Pub. L. 109–248","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/590"},"text":"120 Stat. 590","children":[],"tail":", which is classified principally to subchapter I (§ 20901 et seq.) of chapter 209 of Title 34, Crime Control and Law Enforcement. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/248/s101"},"text":"section 101 of Pub. L. 109–248","children":[],"tail":", set out as a Short Title of 2006 Act note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of Title 34","children":[],"tail":", and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc348670c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/355/s6/a/1"},"text":"Pub. L. 117–355, § 6(a)(1)","children":[],"tail":", substituted “certain Federal or State crimes” for “Federal or State capital crimes” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/355/s6/a/2/A/i"},"text":"Pub. L. 117–355, § 6(a)(2)(A)(i)","children":[],"tail":", substituted “("},{"tag":"ref","attrib":{"href":"/us/usc/t34/s20901"},"text":"34 U.S.C. 20901","children":[],"tail":" et seq.); and” for “("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s16901"},"text":"42 U.S.C. 16901","children":[],"tail":" et seq.);”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/355/s6/a/2/A/ii"},"text":"Pub. L. 117–355, § 6(a)(2)(A)(ii)","children":[],"tail":", inserted “or to a period of 99 years or more” after “life imprisonment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/355/s6/a/2/B"},"text":"Pub. L. 117–355, § 6(a)(2)(B)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/355/s6/a/3"},"text":"Pub. L. 117–355, § 6(a)(3)","children":[],"tail":", substituted “paragraph (3) or (5) of subsection (b)” for “subsection (b)(3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/355/s6/a/4"},"text":"Pub. L. 117–355, § 6(a)(4)","children":[],"tail":", substituted “, a State capital crime, or a Federal or State crime that would cause the person to be a tier III sex offender for purposes of the Sex Offender Registration and Notification Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t34/s20901"},"text":"34 U.S.C. 20901","children":[],"tail":" et seq.),” for “or a State capital crime”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/355/s6/a/5"},"text":"Pub. L. 117–355, § 6(a)(5)","children":[],"tail":", substituted “, a State capital crime, or a Federal or State crime that would cause the person to be a tier III sex offender for purposes of the Sex Offender Registration and Notification Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t34/s20901"},"text":"34 U.S.C. 20901","children":[],"tail":" et seq.),” for “or a State capital crime”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/58"},"text":"Pub. L. 114–58","children":[],"tail":" substituted “Federal official” for “federal official” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/65/s2/b"},"text":"Pub. L. 113–65, § 2(b)","children":[],"tail":", struck out “such official approves an application for” after “received by the appropriate Federal official before”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/260/s105/b"},"text":"Pub. L. 112–260, § 105(b)","children":[],"tail":", substituted “, (b)(2), or (b)(4)” for “or (b)(2)” in two places and struck out “capital” before “crime” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/260/s105/a"},"text":"Pub. L. 112–260, § 105(a)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/65/s2/a"},"text":"Pub. L. 113–65, § 2(a)","children":[],"tail":", added subsecs. (d) and (e) and redesignated former subsec. (d) as (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s662/a/1/A"},"text":"Pub. L. 109–163, § 662(a)(1)(A)","children":[],"tail":", substituted “and whose conviction is final (other than a person whose sentence was commuted by the President)” for “for which the person was sentenced to death or life imprisonment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s662/a/1/B"},"text":"Pub. L. 109–163, § 662(a)(1)(B)","children":[],"tail":", substituted “and whose conviction is final (other than a person whose sentence was commuted by the Governor of a State)” for “for which the person was sentenced to death or life imprisonment without parole”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s662/a/2/A"},"text":"Pub. L. 109–163, § 662(a)(2)(A)","children":[],"tail":", substituted “a sentence of imprisonment for life or the death penalty may be imposed” for “the death penalty or life imprisonment may be imposed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s662/a/2/B"},"text":"Pub. L. 109–163, § 662(a)(2)(B)","children":[],"tail":", substituted “a sentence of imprisonment for life or the death penalty may be imposed” for “the death penalty or life imprisonment without parole may be imposed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/330"},"text":"Pub. L. 107–330","children":[],"tail":" substituted “In the case of a person described in subsection (b)(1) or (b)(2), the prohibition” for “The prohibition” and “referred to in subsection (b)(1) or (b)(2), as the case may be,” for “or finding under subsection (b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/s403/d/1"},"text":"Pub. L. 105–368, § 403(d)(1)","children":[],"tail":", substituted “Administration” for “System” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a)(1)(A), (B), (d)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/s403/d/1"},"text":"Pub. L. 105–368, § 403(d)(1)","children":[],"tail":", substituted “Administration” for “System”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc348670d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc348670e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/65/s2/c"},"text":"Pub. L. 113–65, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-20"},"text":"Dec. 20, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/671"},"text":"127 Stat. 671","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/65/s2/c"},"text":"“The amendments made by this section [amending this section] shall apply with respect to any interment or memorialization conducted by the Secretary of Veterans Affairs or the Secretary of the Army in a cemetery in the National Cemetery Administration or in Arlington National Cemetery after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2013-12-20"},"text":"Dec. 20, 2013","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/260/tI/s105/c"},"text":"Pub. L. 112–260, title I, § 105(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-10"},"text":"Jan. 10, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2421"},"text":"126 Stat. 2421","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/260/tI/s105/c"},"text":"“The amendments made by this section [amending this section] shall apply with respect to interments and memorializations that occur on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2013-01-10"},"text":"Jan. 10, 2013","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc348670f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" applicable with respect to funerals and burials that occur on or after "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s662/e"},"text":"section 662(e) of Pub. L. 109–163","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s985"},"text":"section 985 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3486710-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/116/s1/c"},"text":"Pub. L. 105–116, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2382"},"text":"111 Stat. 2382","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/116/s1/c"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2411"},"text":"Section 2411 of title 38","children":[],"tail":", United States Code, as added by subsection (a), shall apply with respect to applications for interment or memorialization made on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3486711-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tVI/s662/d/1"},"text":"Pub. L. 109–163, div. A, title VI, § 662(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3315"},"text":"119 Stat. 3315","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/163/dA/tVI/s662/d/1"},"text":"“The Secretary of Veterans Affairs shall prescribe regulations to ensure that a person is not interred in any cemetery in the National Cemetery System unless a good faith effort has been made to determine whether such person is ineligible for such interment or honors by reason of being a person described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2411/b"},"text":"section 2411(b) of title 38","children":[],"tail":", United States Code, or is otherwise ineligible for such interment under Federal law.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
