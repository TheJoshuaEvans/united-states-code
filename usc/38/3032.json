{"tag":"section","attrib":{"id":"idc356bee3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3032"},"text":null,"children":[{"tag":"num","attrib":{"value":"3032"},"text":"§ 3032.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on educational assistance for certain individuals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc356bee4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3032/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of an individual entitled to educational assistance under this chapter who is pursuing a program of education—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc356bee5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3032/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while on active duty; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc356bee6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3032/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on less than a half-time basis,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the amount of the monthly educational assistance allowance payable to such individual under this chapter is the amount determined under subsection (b) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc356bee7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3032/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of the educational assistance allowance payable to an individual described in subsection (a) of this section is the least of the following: (1) the amount of the educational assistance allowance otherwise payable to such individual under this chapter, (2) the established charges for tuition and fees that the educational institution involved requires similarly circumstanced nonveterans enrolled in the same program to pay, or (3) the amount of the charges of the educational institution elected by the individual under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3014/b/1"},"text":"section 3014(b)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc356bee8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3032/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc356bee9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3032/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in paragraph (2) of this subsection, the amount of the monthly educational assistance allowance payable to an individual pursuing a full-time program of apprenticeship or other on-job training under this chapter is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc356beea-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3032/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each of the first six months of the individual’s pursuit of such program, 75 percent of the monthly educational assistance allowance otherwise payable to such individual under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc356beeb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3032/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each of the second six months of the individual’s pursuit of such program, 55 percent of such monthly educational assistance allowance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc356beec-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3032/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each of the months following the first 12 months of the individual’s pursuit of such program, 35 percent of such monthly educational assistance allowance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc356beed-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3032/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any month in which an individual pursuing a program of education consisting of a program of apprenticeship or other on-job training fails to complete 120 hours of training, the amount of monthly educational assistance allowance payable under this chapter to the individual shall be limited to the same proportion of the applicable rate determined under paragraph (1) of this subsection as the number of hours worked during such month, rounded to the nearest eight hours, bears to 120 hours.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc356beee-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3032/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc356beef-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3032/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subparagraph (B) of this paragraph, for each month that an individual is paid a monthly educational assistance allowance under this chapter, the individual’s entitlement under this chapter shall be charged at the rate of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc356bef0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3032/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 75 percent of a month in the case of payments made in accordance with paragraph (1)(A) of this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc356bef1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3032/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 55 percent of a month in the case of payments made in accordance with paragraph (1)(B) of this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc356bef2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3032/c/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 35 percent of a month in the case of payments made in accordance with paragraph (1)(C) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc356bef3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3032/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any such charge to the individual’s entitlement shall be reduced proportionately in accordance with the reduction in payment under paragraph (2) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc356bef4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3032/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc356bef5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3032/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc356bef6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3032/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of the educational assistance allowance payable under this chapter to an individual who enters into an agreement to pursue, and is pursuing, a program of education exclusively by correspondence is an amount equal to 55 percent of the established charge which the institution requires nonveterans to pay for the course or courses pursued by such individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc356bef7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3032/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this paragraph, the term “established charge” means the lesser of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc356bef8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3032/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the charge for the course or courses determined on the basis of the lowest extended time payment plan offered by the institution and approved by the appropriate State approving agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc356bef9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3032/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actual charge to the individual for such course or courses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc356befa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3032/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such allowance shall be paid quarterly on a pro rata basis for the lessons completed by the individual and serviced by the institution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc356befb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3032/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In each case in which the rate of payment to an individual is determined under paragraph (1) of this subsection, the period of entitlement of such individual under this chapter shall be charged at the rate of one month for each payment of educational assistance to the individual that is equal to the amount of monthly educational assistance the individual would otherwise be eligible to receive for full-time pursuit of an institutional course under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc356befc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3032/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc356befd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3032/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding subsection (a) of this section, each individual who is pursuing a program of education consisting exclusively of flight training approved as meeting the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3034/d"},"text":"section 3034(d) of this title","children":[],"tail":" shall be paid an educational assistance allowance under this chapter in the amount equal to 60 percent of the established charges for tuition and fees which similarly circumstanced nonveterans enrolled in the same flight course are required to pay."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc356befe-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3032/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No educational assistance allowance may be paid under this chapter to an individual for any month during which such individual is pursuing a program of education consisting exclusively of flight training until the Secretary has received from that individual and the institution providing such training a certification of the flight training received by the individual during that month and the tuition and other fees charged for that training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc356beff-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3032/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of months of entitlement charged in the case of any individual for a program of education described in paragraph (1) of this subsection shall be equal to the number (including any fraction) determined by dividing the total amount of educational assistance paid such individual for such program by the monthly rate of educational assistance which, except for paragraph (1) of this subsection, such individual would otherwise be paid under subsection (a)(1), (b)(1), (d), or (e)(1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3015"},"text":"section 3015 of this title","children":[],"tail":", as the case may be."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc356bf00-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3032/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of solo flying hours for which an individual may be paid an educational assistance allowance under this subsection may not exceed the minimum number of solo flying hours required by the Federal Aviation Administration for the flight rating or certification which is the goal of the individual’s flight training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc356bf01-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3032/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc356bf02-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3032/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (3), the amount of educational assistance payable under this chapter for a licensing or certification test described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3452/b"},"text":"section 3452(b) of this title","children":[],"tail":" is the lesser of $2,000 or the fee charged for the test."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc356bf03-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3032/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of months of entitlement charged in the case of any individual for such licensing or certification test is equal to the number (including any fraction) determined by dividing the total amount of educational assistance paid such individual for such test by the full-time monthly institutional rate of educational assistance which, except for paragraph (1), such individual would otherwise be paid under subsection (a)(1), (b)(1), (d), or (e)(1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3015"},"text":"section 3015 of this title","children":[],"tail":", as the case may be."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc356bf04-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3032/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In no event shall payment of educational assistance under this subsection for such a test exceed the amount of the individual’s available entitlement under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc356bf05-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3032/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc356bf06-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3032/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (3), the amount of educational assistance payable under this chapter for a national test for admission or national test providing an opportunity for course credit at institutions of higher learning described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3452/b"},"text":"section 3452(b) of this title","children":[],"tail":" is the amount of the fee charged for the test."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc356bf07-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3032/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of months of entitlement charged in the case of any individual for a test described in paragraph (1) is equal to the number (including any fraction) determined by dividing the total amount of educational assistance paid such individual for such test by the full-time monthly institutional rate of educational assistance, except for paragraph (1), such individual would otherwise be paid under subsection (a)(1), (b)(1), (d), or (e)(1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3015"},"text":"section 3015 of this title","children":[],"tail":", as the case may be."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc356bf08-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3032/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In no event shall payment of educational assistance under this subsection for a test described in paragraph (1) exceed the amount of the individual’s available entitlement under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc356bf09-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/tVII/s702/a/1"},"text":"Pub. L. 98–525, title VII, § 702(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2561"},"text":"98 Stat. 2561","children":[],"tail":", § 1432; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/576/tIII/s301/b"},"text":"Pub. L. 99–576, title III, § 301(b)","children":[],"tail":", (d)(1), "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3267"},"text":"100 Stat. 3267","children":[],"tail":", 3268; "},{"tag":"ref","attrib":{"href":"/us/pl/100/689/tI"},"text":"Pub. L. 100–689, title I","children":[],"tail":", §§ 108(a)(2), 111(a)(7)(A), (8), "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4169"},"text":"102 Stat. 4169","children":[],"tail":", 4172; "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIV/s422/a/2"},"text":"Pub. L. 101–237, title IV, § 422(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2089"},"text":"103 Stat. 2089","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/16/s10/a/3"},"text":"Pub. L. 102–16, § 10(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-03-22"},"text":"Mar. 22, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/55"},"text":"105 Stat. 55","children":[],"tail":"; renumbered § 3032 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/568/tIII/s310/a"},"text":"Pub. L. 102–568, title III, § 310(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4329"},"text":"106 Stat. 4329","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/446/tXII/s1201/d/6"},"text":"Pub. L. 103–446, title XII, § 1201(d)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4684"},"text":"108 Stat. 4684","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/275/tI/s105/a"},"text":"Pub. L. 104–275, title I, § 105(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3327"},"text":"110 Stat. 3327","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/419/tI/s122/b/1"},"text":"Pub. L. 106–419, title I, § 122(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1833"},"text":"114 Stat. 1833","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/14/s7/b/2/B"},"text":"Pub. L. 107–14, § 7(b)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-06-05"},"text":"June 5, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/32"},"text":"115 Stat. 32","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/454/tI/s106/b/1"},"text":"Pub. L. 108–454, title I, § 106(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-10"},"text":"Dec. 10, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3602"},"text":"118 Stat. 3602","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc356bf0a-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc356bf0b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc356bf0c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"ta