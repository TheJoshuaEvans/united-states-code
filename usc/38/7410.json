{"tag":"section","attrib":{"id":"idc40723e8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7410"},"text":null,"children":[{"tag":"num","attrib":{"value":"7410"},"text":"§ 7410.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional pay authorities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc40723e9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7410/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc40723ea-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7410/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may authorize the Under Secretary for Health to pay advance payments, recruitment or relocation bonuses, and retention allowances to personnel appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7306"},"text":"section 7306 of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401/4"},"text":"section 7401(4) of this title","children":[],"tail":", or personnel described in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401/1"},"text":"section 7401(1) of this title","children":[],"tail":",,"},{"tag":"ref","attrib":{"idref":"fn002114"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002114"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" or interview expenses to candidates for appointment as such personnel, in a manner consistent with the authority provided under sections 5524a, 5706b, 5753, and 5754 of title 5."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc40723eb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7410/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payments under paragraph (1) shall not be considered in calculating the limitation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7431/e/4"},"text":"section 7431(e)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc40723ec-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7410/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Incentive Pay for Department Pharmacist Executives","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc40723ed-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7410/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to recruit and retain highly qualified Department pharmacist executives, the Secretary may authorize the Under Secretary for Health to pay special incentive pay of not more than $40,000 per year to an individual of the Veterans Health Administration who is a pharmacist executive.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc40723ee-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7410/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In determining whether and how much special pay to provide to such individual, the Under Secretary shall consider the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc40723ef-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7410/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The grade and step of the position of the individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc40723f0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7410/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The scope and complexity of the position of the individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc40723f1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7410/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The personal qualifications of the individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc40723f2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7410/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The characteristics of the labor market concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc40723f3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7410/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other factors as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc40723f4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7410/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Special incentive pay under paragraph (1) for an individual is in addition to all other pay (including basic pay) and allowances to which the individual is entitled.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc40723f5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7410/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (5), special incentive pay under paragraph (1) for an individual shall be considered basic pay for all purposes, including retirement benefits under chapters 83 and 84 of title 5, and other benefits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc40993f6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7410/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Special incentive pay under paragraph (1) for an individual shall not be considered basic pay for purposes of adverse actions under subchapter V of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc40993f7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7410/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Special incentive pay under paragraph (1) may not be awarded to an individual in an amount that would result in an aggregate amount of pay (including bonuses and awards) received by such individual in a year under this title that is greater than the annual pay of the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc40993f8-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/tI/s103/a/s1"},"text":"Pub. L. 102–40, title I, § 103(a)[(1)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/198"},"text":"105 Stat. 198","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/405/tIII/s302/c/1"},"text":"Pub. L. 102–405, title III, § 302(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-09"},"text":"Oct. 9, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1984"},"text":"106 Stat. 1984","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/163/tVI/s601/e"},"text":"Pub. L. 111–163, title VI, § 601(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-05-05"},"text":"May 5, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1169"},"text":"124 Stat. 1169","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/168/tIX/s906/c/3"},"text":"Pub. L. 117–168, title IX, § 906(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-10"},"text":"Aug. 10, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1813"},"text":"136 Stat. 1813","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc40993f9-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc40993fa-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc40993fb-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/168"},"text":"Pub. L. 117–168","children":[],"tail":" designated existing provisions as par. (1), substituted “personnel appointed under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7306"},"text":"section 7306 of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401/4"},"text":"section 7401(4) of this title","children":[],"tail":", or personnel described in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401/1"},"text":"section 7401(1) of this title","children":[],"tail":",” for “the personnel described in paragraph (1) of "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401"},"text":"section 7401 of this title","children":[],"tail":"” and “in a manner consistent with” for “in the same manner, and subject to the same limitations, as in the case of”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163"},"text":"Pub. L. 111–163","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/405"},"text":"Pub. L. 102–405","children":[],"tail":" substituted “Under Secretary for Health” for “Chief Medical Director”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc40993fc-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc40993fd-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Treatment of Pay Authority Changes","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/168/tIX/s906/c/4"},"text":"Pub. L. 117–168, title IX, § 906(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-10"},"text":"Aug. 10, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1813"},"text":"136 Stat. 1813","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/168/tIX/s906/c/4"},"text":"“For the purposes of the amendments made by paragraph (3) [amending this section], the Secretary of Veterans Affairs shall treat any award or payment made by the Secretary between ","children":[{"tag":"date","attrib":{"date":"2017-01-01"},"text":"January 1, 2017","children":[],"tail":", and the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2022-08-10"},"text":"Aug. 10, 2022","children":[],"tail":"] to employees appointed under sections 7306, 7401(1), and 7401(4) of title 38, United States Code, that the Secretary has determined are of equivalent rank to a Senior Executive Service position (as such term is defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3132/a"},"text":"section 3132(a) of title 5","children":[],"tail":", United States Code), as if such amendments had been in effect at the time of such award or payment.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
