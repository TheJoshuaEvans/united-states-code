{"tag":"section","attrib":{"id":"idc27dc378-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s316"},"text":null,"children":[{"tag":"num","attrib":{"value":"316"},"text":"§ 316.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Colocation of regional offices and medical centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc27dc379-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s316/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To provide for a more economical, efficient, and effective operation of such regional offices, the Secretary shall provide for the colocation of at least three regional offices with medical centers of the Department—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc27dc37a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s316/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on real property under the jurisdiction of the Department of Veterans Affairs at such medical centers; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27dc37b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s316/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on real property that is adjacent to such a medical center and is under the jurisdiction of the Department as a result of being conveyed to the United States for the purpose of such colocation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc27dc37c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s316/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc27dc37d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s316/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out this section and notwithstanding any other provision of law, the Secretary may lease, with or without compensation and for a period of not to exceed 35 years, to another party at not more than seven locations any of the real property described in paragraph (1) or (2) of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27dc37e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s316/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such real property shall be used as the site of a facility—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc27dc37f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s316/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" constructed and owned by the lessee of such real property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc27dc380-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s316/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leased under subsection (c)(1) to the Department for such use and such other activities as the Secretary determines are appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc27dc381-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s316/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc27dc382-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s316/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may enter into a lease for the use of any facility described in subsection (b)(2) for not more than 35 years under such terms and conditions as may be in the best interests of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27dc383-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s316/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each agreement for such a lease shall provide—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc27dc384-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s316/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the obligation of the United States to make payments under the agreement is subject to the availability of appropriations for that purpose; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc27dc385-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s316/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the ownership of the facility shall vest in the United States at the end of such lease.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc27dc386-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s316/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc27dc387-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s316/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may sublease any space in such a facility to another party at a rate not less than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc27dc388-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s316/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rental rate paid by the Secretary for such space under subsection (c); plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc27dc389-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s316/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount the Secretary pays for the costs of administering such facility (including operation, maintenance, utility, and rehabilitation costs) which are attributable to such space.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27dc38a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s316/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any such sublease, the Secretary shall include such terms relating to default and nonperformance as the Secretary considers appropriate to protect the interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc27dc38b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s316/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall use the receipts of any payment for the lease of real property under subsection (b) for the payment of the lease of a facility under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc27dc38c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s316/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc27dc38d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s316/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to paragraph (3)(A), the Secretary shall, not later than ","children":[{"tag":"date","attrib":{"date":"1990-04-18"},"text":"April 18, 1990","children":[],"tail":", issue an invitation for offers with respect to three colocations to be carried out under this section. The invitation shall include, with respect to each such colocation, at least the following:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc27dc38e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s316/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Identification of the site to be developed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc27dc38f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s316/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Minimum office space requirements for regional office activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc27dc390-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s316/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Design criteria of the facility to be constructed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc27dc391-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s316/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A plan for meeting the security and parking needs for the facility and its occupants and visitors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc27dc392-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s316/f/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A statement of current and projected rents and other costs for regional office activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc27dc393-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s316/f/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The estimated cost of construction of the facility concerned, the estimated annual cost of leasing space for regional office activities in the facility, and the estimated total annual cost of leasing all space in such facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc27dc394-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s316/f/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A plan for securing appropriate licenses, easements, and rights-of-way.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc27dc395-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s316/f/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A list of terms and conditions the Secretary has approved for inclusion in the lease agreement for the facility concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27dc396-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s316/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to paragraph (3)(B), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc27dc397-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s316/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than one year after the date on which the invitation is issued under paragraph (1), enter into an agreement to carry out one colocation under this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc27dc398-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s316/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within 180 days after entering into the agreement referred to in subparagraph (A), enter into agreements to carry out two additional colocations,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"unless the Secretary determines that it is not economically feasible for the Department to undertake them, taking into consideration all of the tangible and intangible benefits associated with such colocations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27dc399-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s316/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc27dc39a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s316/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 10 days before the issuance or other publication of the invitation referred to in paragraph (1), submit a copy of the invitation to the Committees on Veterans’ Affairs of the Senate and House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc27dc39b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s316/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 30 days before entering into an agreement under paragraph (2), submit a copy to the Committees on Veterans’ Affairs of the Senate and House of Representatives of the proposals selected by the Secretary from those received in response to the invitation issued under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc27dc39c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s316/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority to enter into an agreement under this section shall expire on ","children":[{"tag":"date","attrib":{"date":"1992-09-30"},"text":"September 30, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc27dc39d-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s2/a"},"text":"Pub. L. 102–83, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/384"},"text":"105 Stat. 384","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc27dc39e-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc27dc39f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc27dc3a0-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior section 316 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1116"},"text":"section 1116 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
