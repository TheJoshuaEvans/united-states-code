{"tag":"section","attrib":{"id":"idc3e0fdcd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5706"},"text":null,"children":[{"tag":"num","attrib":{"value":"5706"},"text":"§ 5706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Veterans identification card","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3e0fdce-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5706/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Veterans Affairs shall issue an identification card described in subsection (b) to each veteran who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3e0fdcf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5706/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requests such card;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e0fdd0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5706/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" presents a copy of Department of Defense form DD–214 or other official document from the official military personnel file of the veteran that describes the service of the veteran; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e0fdd1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5706/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pays the fee under subsection (c)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3e0fdd2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5706/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Identification Card","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An identification card described in this subsection is a card issued to a veteran that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3e0fdd3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5706/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" displays a photograph of the veteran;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e0fdd4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5706/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" displays the name of the veteran;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e0fdd5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5706/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" explains that such card is not proof of any benefits to which the veteran is entitled to;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e0fdd6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5706/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains an identification number that is not a social security number; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e0fdd7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5706/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" serves as proof that such veteran—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3e0fdd8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5706/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" served in the Armed Forces; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3e0fdd9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5706/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a Department of Defense form DD–214 or other official document in the official military personnel file of the veteran that describes the service of the veteran.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3e0fdda-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5706/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Costs of Card","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3e0fddb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5706/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall charge a fee to each veteran who receives an identification card issued under this section, including a replacement identification card.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e0fddc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5706/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3e0fddd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5706/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The fee charged under paragraph (1) shall equal such amount as the Secretary determines is necessary to issue an identification card under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3e0fdde-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5706/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In determining the amount of the fee under subparagraph (A), the Secretary shall ensure that the total amount of fees collected under paragraph (1) equals an amount necessary to carry out this section, including costs related to any additional equipment or personnel required to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3e0fddf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5706/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall review and reassess the determination under subparagraph (A) during each five-year period in which the Secretary issues an identification card under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e0fde0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5706/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Amounts collected under this subsection shall be deposited in an account of the Department available to carry out this section. Amounts so deposited shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3e0fde1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5706/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" merged with amounts in such account;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3e0fde2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5706/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" available in such amounts as may be provided in appropriation Acts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3e0fde3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5706/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to the same conditions and limitations as amounts otherwise in such account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3e0fde4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5706/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of Card on Benefits","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3e0fde5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5706/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An identification card issued under this section shall not serve as proof of any benefits that the veteran may be entitled to under this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e0fde6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5706/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A veteran who is issued an identification card under this section shall not be entitled to any benefits under this title by reason of possessing such card.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3e0fde7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5706/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative Measures","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3e0fde8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5706/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall ensure that any information collected or used with respect to an identification card issued under this section is appropriately secured.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e0fde9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5706/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may determine any appropriate procedures with respect to issuing a replacement identification card.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e0fdea-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5706/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out this section, the Secretary shall coordinate with the National Personnel Records Center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e0fdeb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5706/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may conduct such outreach to advertise the identification card under this section as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3e0fdec-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5706/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall not be construed to affect identification cards otherwise provided by the Secretary to veterans enrolled in the health care system established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1705/a"},"text":"section 1705(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3e0fded-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/31/s2/b"},"text":"Pub. L. 114–31, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-07-20"},"text":"July 20, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/428"},"text":"129 Stat. 428","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3e0fdee-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3e0fdef-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3e0fdf0-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/31/s2/d"},"text":"Pub. L. 114–31, § 2(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-07-20"},"text":"July 20, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/430"},"text":"129 Stat. 430","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/31/s2/d"},"text":"“The amendments made by this Act [enacting this section] shall take effect on the date that is 60 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2015-07-20"},"text":"July 20, 2015","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3e0fdf1-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Veterans Identification Card; Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/31/s2/a"},"text":"Pub. L. 114–31, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-07-20"},"text":"July 20, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/428"},"text":"129 Stat. 428","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/31/s2/a"},"text":"\n","children":[{"tag":"p","attrib":{},"text":"“Congress makes the following findings:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Effective on the day before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2015-07-20"},"text":"July 20, 2015","children":[],"tail":"], veteran identification cards were issued to veterans who have either completed the statutory time-in-service requirement for retirement from the Armed Forces or who have received a medical-related discharge from the Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Effective on the day before the date of the enactment of this Act, a veteran who served a minimum obligated time in service, but who did not meet the criteria described in paragraph (1), did not receive a means of identifying the veteran’s status as a veteran other than using the Department of Defense form DD–214 discharge papers of the veteran.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Goods, services, and promotional activities are often offered by public and private institutions to veterans who demonstrate proof of service in the military, but it is impractical for a veteran to always carry Department of Defense form DD–214 discharge papers to demonstrate such proof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A general purpose veteran identification card made available to veterans would be useful to demonstrate the status of the veterans without having to carry and use official Department of Defense form DD–214 discharge papers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On the day before the date of the enactment of this Act, the Department of Veterans Affairs had the infrastructure in place across the United States to produce photographic identification cards and accept a small payment to cover the cost of these cards.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
