dment substantially identical to that made by "},{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":". See 2022 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" designated existing provisions as subpar. (A), substituted “(d), and (i)” for “and (d)”, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/61"},"text":"Pub. L. 116–61","children":[],"tail":" substituted “January” for “January,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/48/s112/a"},"text":"Pub. L. 115–48, § 112(a)","children":[],"tail":", substituted “individual’s entitlement—” for “individual’s entitlement expires at the end of the 15-year period beginning on the date of such individual’s last discharge or release from active duty.” and added pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/48/s112/b"},"text":"Pub. L. 115–48, § 112(b)","children":[],"tail":", inserted “of this title” after “section 3311(b)(9)”, substituted “child’s entitlement—” for “child’s entitlement expires at the end of the 15-year period beginning on the date of such child’s eighteenth birthday.”, and added subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/48/s105/c/5"},"text":"Pub. L. 115–48, § 105(c)(5)","children":[],"tail":", substituted “section 3311(b)(8)” for “section 3311(b)(9)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/48/s112/c"},"text":"Pub. L. 115–48, § 112(c)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"ta