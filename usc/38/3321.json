{"tag":"section","attrib":{"id":"idc36c4231-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3321"},"text":null,"children":[{"tag":"num","attrib":{"value":"3321"},"text":"§ 3321.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time limitation for use of and eligibility for entitlement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc36c4232-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3321/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in this section, the period during which an individual entitled to educational assistance under this chapter may use such individual’s entitlement—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc36c4233-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3321/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an individual whose last discharge or release from active duty is before ","children":[{"tag":"date","attrib":{"date":"2013-01-01"},"text":"January 1, 2013","children":[],"tail":", expires at the end of the 15-year period beginning on the date of such discharge or release; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc36c4234-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3321/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an individual whose last discharge or release from active duty is on or after ","children":[{"tag":"date","attrib":{"date":"2013-01-01"},"text":"January 1, 2013","children":[],"tail":", shall not expire."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc36c4235-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3321/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc36c4236-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3321/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of section 3031 to running of period","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc36c4237-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3321/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsections (b), (c), (d), and (i) of section 3031 shall apply with respect to the running of the 15-year period described in subsection (a) of this section in the same manner as such subsections apply under section 3031 with respect to the running of the 10-year period described in section 3031(a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc36c4238-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3321/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (i) of section 3031 shall apply with respect to the running of the 15-year period described in paragraphs (4)(A) and (5)(A) of this subsection in the same manner as such subsection applies under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3031"},"text":"section 3031 of this title","children":[],"tail":" with respect to the running of the 10-year period described in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3031/a"},"text":"section 3031(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc36c4239-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3321/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of section 3031 to termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Section 3031(f) shall apply with respect to the termination of an individual’s entitlement to educational assistance under this chapter in the same manner as such section applies to the termination of an individual’s entitlement to educational assistance under chapter 30, except that, in the administration of such section for purposes of this chapter, the reference to section 3013 shall be deemed to be a reference to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3312"},"text":"section 3312 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc36c423a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3321/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination of last discharge or release","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of subsection (a), an individual’s last discharge or release from active duty shall not include any discharge or release from a period of active duty of less than 90 days of continuous service, unless the individual is discharged or released as described in section 3311(b)(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc36c423b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3321/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability to children of deceased members","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The period during which a child entitled to educational assistance by reason of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3311/b/8"},"text":"section 3311(b)(8) of this title","children":[],"tail":" may use such child’s entitlement—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc36c423c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3321/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a child who first becomes entitled to such entitlement before ","children":[{"tag":"date","attrib":{"date":"2013-01-01"},"text":"January 1, 2013","children":[],"tail":", expires at the end of the 15-year period beginning on the date of such child’s eighteenth birthday; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc36c423d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3321/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a child who first becomes entitled to such entitlement on or after ","children":[{"tag":"date","attrib":{"date":"2013-01-01"},"text":"January 1, 2013","children":[],"tail":", shall not expire."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc36c423e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3321/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability to spouses of deceased members","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The period during which a spouse entitled to educational assistance by reason of section 3311(b)(9) ","children":[{"tag":"ref","attrib":{"idref":"fn002061"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002061"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" may use such spouse’s entitlement—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc36c423f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3321/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a spouse who first becomes entitled to such entitlement before ","children":[{"tag":"date","attrib":{"date":"2013-01-01"},"text":"January 1, 2013","children":[],"tail":", expires at the end of the 15-year period beginning on the date on which the spouse first becomes entitled to such entitlement; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc36c4240-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3321/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a spouse who first becomes entitled to such entitlement on or after ","children":[{"tag":"date","attrib":{"date":"2013-01-01"},"text":"January 1, 2013","children":[],"tail":", shall not expire."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc36c4241-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/252/tV/s5003/a/1"},"text":"Pub. L. 110–252, title V, § 5003(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-30"},"text":"June 30, 2008","ch