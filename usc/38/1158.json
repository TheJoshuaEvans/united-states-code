{"tag":"section","attrib":{"id":"idc2ad5f82-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1158"},"text":null,"children":[{"tag":"num","attrib":{"value":"1158"},"text":"§ 1158.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disappearance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Where a veteran receiving compensation under this chapter disappears, the Secretary may pay the compensation otherwise payable to the veteran to such veteran’s spouse, children, and parents. Payments made to such spouse, child, or parent under the preceding sentence shall not exceed the amounts payable to each if the veteran had died from service-connected disability.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc2ad5f83-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1125"},"text":"72 Stat. 1125","children":[],"tail":", § 358; "},{"tag":"ref","attrib":{"href":"/us/pl/86/212"},"text":"Pub. L. 86–212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-01"},"text":"Sept. 1, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/436"},"text":"73 Stat. 436","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/433/tIV/s404/21"},"text":"Pub. L. 94–433, title IV, § 404(21)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1379"},"text":"90 Stat. 1379","children":[],"tail":"; renumbered § 1158 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":", §§ 4(b)(1), (2)(E), 5(a), "},{"tag":"date","attrib":{"date":"199