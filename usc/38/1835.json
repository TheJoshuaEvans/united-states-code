{"tag":"section","attrib":{"id":"idc3165a28-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1835"},"text":null,"children":[{"tag":"num","attrib":{"value":"1835"},"text":"§ 1835.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3165a29-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1835/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall establish an advisory council on health care and benefits for covered children.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3165a2a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1835/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The advisory council established under subsection (a) shall be composed of Federal employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3165a2b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1835/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The advisory council established under subsection (a) shall solicit feedback from covered children and covered veterans on the health care and benefits provided under this chapter and communicate such feedback to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3165a2c-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/18/s1/b"},"text":"Pub. L. 118–18, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-10-06"},"text":"Oct. 6, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/103"},"text":"137 Stat. 103","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3165a2d-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3165a2e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc3165a2f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1835 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2041"},"text":"section 2041 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3165a30-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3165a31-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadline for Establishment of Advisory Council","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/18/s1/d/1"},"text":"Pub. L. 118–18, § 1(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-10-06"},"text":"Oct. 6, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/104"},"text":"137 Stat. 104","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/18/s1/d/1"},"text":"“Not later than 270 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2023-10-06"},"text":"Oct. 6, 2023","children":[],"tail":"], the Secretary of Veterans Affairs shall establish the advisory council required under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1835"},"text":"section 1835 of title 38","children":[],"tail":", United States Code, as added by subsection (b).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
