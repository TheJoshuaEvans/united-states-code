{"tag":"section","attrib":{"id":"idc3fff7fd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7334"},"text":null,"children":[{"tag":"num","attrib":{"value":"7334"},"text":"§ 7334.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3fff7fe-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7334/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Regulations prescribed by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7331"},"text":"section 7331 of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7332"},"text":"section 7332 of this title","children":[],"tail":" with respect to the confidentiality of alcohol and drug abuse medical records, and "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7333"},"text":"section 7333 of this title","children":[],"tail":" with respect to alcohol or drug abusers shall, to the maximum extent feasible consistent with other provisions of this title, make applicable the regulations described in subsection (b) to the conduct of research and to the provision of hospital care, nursing home care, domiciliary care, and medical services under this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3fff7ff-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7334/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The regulations referred to in subsection (a) are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3fff800-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7334/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulations governing human experimentation and informed consent prescribed by the Secretary of Health and Human Services, based on the recommendations of the National Commission for the Protection of Human Subjects of Biomedical and Behavioral Research, established by section 201 of the National Research Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/348"},"text":"Public Law 93–348","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/88/348"},"text":"88 Stat. 348","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fff801-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7334/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulations governing (A) the confidentiality of drug and alcohol abuse medical records, and (B) the admission of drug and alcohol abusers to private and public hospitals, prescribed pursuant to the Comprehensive Alcohol Abuse and Alcoholism Prevention, Treatment, and Rehabilitation Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4551"},"text":"42 U.S.C. 4551","children":[],"tail":" et seq.) and the Drug Abuse Office and Treatment Act of 1972 ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1101"},"text":"21 U.S.C. 1101","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3fff802-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7334/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Regulations prescribed by the Secretary under sections 7331, 7332, and 7333 of this title may contain such definitions, and may provide for such safeguards and procedures (including procedures and criteria for the issuance and scope of court orders under section 7332(b)(2)(C) ","children":[{"tag":"ref","attrib":{"idref":"fn002108"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002108"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title), as are necessary to prevent circumvention or evasion of such regulations or to facilitate compliance with such regulations."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3fff803-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7334/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In prescribing and implementing such regulations, the Secretary shall, from time to time, consult with the Secretary of Health and Human Services and, as appropriate, with the President (or the delegate of the President) in order to achieve the maximum possible coordination of the regulations, and the implementation of the regulations, which they and the Secretary prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3fff804-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/581/tI/s111/a/1"},"text":"Pub. L. 94–581, title I, § 111(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2851"},"text":"90 Stat. 2851","children":[],"tail":", § 4134; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/295/s4/87"},"text":"Pub. L. 97–295, § 4(87)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1312"},"text":"96 Stat. 1312","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/322/tI/s122/a"},"text":"Pub. L. 100–322, title I, § 122(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/504"},"text":"102 Stat. 504","children":[],"tail":"; renumbered § 7334 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV"},"text":"Pub. L. 102–40, title IV","children":[],"tail":", §§ 401(a)(4)(A), 402(d)(1), 403(a)(1), (4), "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/221"},"text":"105 Stat. 221","children":[],"tail":", 239.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3fff805-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3fff806-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc3fff807-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 201 of the National Research Act, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/348/s201"},"text":"section 201 of Pub. L. 93–348","children":[],"tail":", title II, "},{"tag":"date","attrib":{"date":"1974-07-12"},"text":"July 12, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/348"},"text":"88 Stat. 348","children":[],"tail":", which was set out as a note under section 289"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–1 of Title 42, The Public Health and Welfare, and was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/95/622/tIII/s302/b"},"text":"Pub. L. 95–622, title III, § 302(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3442"},"text":"92 Stat. 3442","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Comprehensive Alcohol Abuse and Alcoholism Prevention, Treatment, and Rehabilitation Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4551"},"text":"42 U.S.C. 4551","children":[],"tail":" et seq.), referred to in subsec. (b)(2), is "},{"tag":"ref","attrib":{"href":"/us/pl/91/616"},"text":"Pub. L. 91–616","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1848"},"text":"84 Stat. 1848","children":[],"tail":", which is classified principally to chapter 60 (§ 4541 et seq.) of Title 42. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4541"},"text":"section 4541 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Drug Abuse Office and Treatment Act of 1972, referred to in subsec. (b)(2), which was redesignated the Drug Abuse Prevention, Treatment, and Rehabilitation Act, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/255"},"text":"Pub. L. 92–255","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-03-21"},"text":"Mar. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/65"},"text":"86 Stat. 65","children":[],"tail":", which is classified principally to chapter 16 (§ 1101 et seq.) of Title 21, Food and Drugs. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1101"},"text":"section 1101 of Title 21","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7332/b/2/C"},"text":"Section 7332(b)(2)(C) of this title","children":[],"tail":", referred to in subsec. (c), was formerly a reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4132/b/2/C"},"text":"section 4132(b)(2)(C) of this title","children":[],"tail":" which was redesignated section 4132(b)(2)(D) by "},{"tag":"ref","attrib":{"href":"/us/pl/100/322/tI/s121/b/2/A"},"text":"Pub. L. 100–322, title I, § 121(b)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/502"},"text":"102 Stat. 502","children":[],"tail":", and subsequently renumbered section 7332(b)(2)(D) by "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s401/a/4/A"},"text":"Pub. L. 102–40, title IV, § 401(a)(4)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/221"},"text":"105 Stat. 221","children":[],"tail":". The reference to section 4132(b)(2)(C) in subsec. (c) was amended to reflect the renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" but not the redesignation by "},{"tag":"ref","attrib":{"href":"/us/pl/100/322"},"text":"Pub. L. 100–322","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3fff808-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s401/a/4/A"},"text":"Pub. L. 102–40, § 401(a)(4)(A)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4134"},"text":"section 4134 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s403/a/4"},"text":"Pub. L. 102–40, § 403(a)(4)","children":[],"tail":", struck out “of this section” after “subsection (b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s403/a/1"},"text":"Pub. L. 102–40, § 403(a)(1)","children":[],"tail":", substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/d/1"},"text":"Pub. L. 102–40, § 402(d)(1)","children":[],"tail":", substituted “7331” for “4131”, “7332” for “4132”, and “7333” for “4133”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s403/a/4"},"text":"Pub. L. 102–40, § 403(a)(4)","children":[],"tail":", struck out “of this section” after “subsection (a)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s403/a/1"},"text":"Pub. L. 102–40, § 403(a)(1)","children":[],"tail":", substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/d/1"},"text":"Pub. L. 102–40, § 402(d)(1)","children":[],"tail":", substituted “7331, 7332, and 7333” for “4131, 4132, and 4133” and “7332(b)(2)(C)” for “4132(b)(2)(C)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s403/a/1"},"text":"Pub. L. 102–40, § 403(a)(1)","children":[],"tail":", substituted “Secretary” for “Administrator” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/322"},"text":"Pub. L. 100–322","children":[],"tail":" amended section generally, substituting provisions consisting of subsecs. (a) to (d) for former provisions consisting of subsecs. (a) and (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295"},"text":"Pub. L. 97–295","children":[],"tail":" substituted “Health and Human Services” for “Health, Education, and Welfare” wherever appearing, and substituted “the President (or the delegate of the President)” for “the Director of the Office of Drug Abuse Policy (or any successor authority)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
