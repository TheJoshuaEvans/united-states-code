sec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" substituted “55” for “70”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466/s604"},"text":"Pub. L. 96–466, § 604","children":[],"tail":", substituted “70 percent” for “90 per centum”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466/s213/2"},"text":"Pub. L. 96–466, § 213(2)","children":[],"tail":", substituted “$342” for “$327”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466/s203/2"},"text":"Pub. L. 96–466, § 203(2)","children":[],"tail":", substituted “$327” for “$311”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/202"},"text":"Pub. L. 95–202","children":[],"tail":" substituted “$311” for “$292”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/502/s513/a/18"},"text":"Pub. L. 94–502, § 513(a)(18)","children":[],"tail":", substituted “spouse or surviving spouse” for “wife or widow” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/502"},"text":"Pub. L. 94–502","children":[],"tail":", §§ 501(1), 513(a)(18), substituted “spouse or surviving spouse” for “wife or widow” in two places and “$292” for “$270”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/502/s513/a/18"},"text":"Pub. L. 94–502, § 513(a)(18)","children":[],"tail":", substituted “spouse or surviving spouse” for “wife or widow” wherever appearing and “such veteran’s or spouse’s” for “his”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (a)(2). ","children":[{"tag"