"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding the provisions of subsection (a) of this section, any enrollment agreement entered into by an eligible veteran prior to ","children":[{"tag":"date","attrib":{"date":"1973-01-01"},"text":"January 1, 1973","children":[],"tail":", shall continue to be subject to the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1682/c"},"text":"section 1682(c) of title 38","children":[],"tail":", United States Code, prior to its repeal by section 303 of this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc394b234-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Eligibility Period","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Termination of eligibility period for a wife or widow, or an eligible person eight years from ","children":[{"tag":"date","attrib":{"date":"1972-10-24"},"text":"Oct. 24, 1972","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/92/540/s604"},"text":"section 604 of Pub. L. 92–540","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3512"},"text":"section 3512 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
