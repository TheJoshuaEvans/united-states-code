{"tag":"section","attrib":{"id":"idc28739c7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s529"},"text":null,"children":[{"tag":"num","attrib":{"value":"529"},"text":"§ 529.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report to Congress","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall submit annually, at the close of each fiscal year, a report in writing to Congress. Each such report shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc28739c8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s529/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give an account of all moneys received and disbursed by the Department for such fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28739c9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s529/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the work done during such fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28739ca-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s529/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" state the activities of the Department for such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc28739cb-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s2/a"},"text":"Pub. L. 102–83, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/391"},"text":"105 Stat. 391","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc28739cc-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc28739cd-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc28739ce-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s214"},"text":"section 214 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s2/a"},"text":"Pub. L. 102–83, § 2(a)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior section 531, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1137"},"text":"72 Stat. 1137","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/77/tI/s105"},"text":"Pub. L. 90–77, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-08-31"},"text":"Aug. 31, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/179"},"text":"81 Stat. 179","children":[],"tail":", provided for a monthly pension to widows of Mexican War veterans, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/94/169/tI/s101/2/F"},"text":"Pub. L. 94–169, title I, § 101(2)(F)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-23"},"text":"Dec. 23, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/1