{"tag":"section","attrib":{"id":"idc4322a9a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8158"},"text":null,"children":[{"tag":"num","attrib":{"value":"8158"},"text":"§ 8158.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit in escrow","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc4322a9b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8158/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To facilitate the procurement of medical equipment pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s8157"},"text":"section 8157 of this title","children":[],"tail":", the Secretary may enter into escrow agreements with institutions described in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s8153/a"},"text":"section 8153(a) of this title","children":[],"tail":". Any such agreement shall provide that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4322a9c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8158/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the institutions shall pay to the Secretary the funds necessary to make a payment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s8157/b/4"},"text":"section 8157(b)(4) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4322a9d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8158/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary, as escrow agent, shall administer those funds in an escrow account; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4322a9e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8158/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall disburse the escrowed funds to pay for such equipment upon its delivery or in accordance with the contract to procure the equipment and shall disburse all accrued interest or other earnings on the escrowed funds to the institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4322a9f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8158/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As escrow agent for funds placed in escrow pursuant to an agreement under subsection (a), the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4322aa0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8158/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" invest the escrowed funds in obligations of the Federal Government or obligations which are insured or guaranteed by the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4322aa1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8158/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retain in the escrow account interest or other earnings on such investments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4322aa2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8158/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disburse the funds pursuant to the escrow agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4322aa3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8158/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" return undisbursed funds to the institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4322aa4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8158/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4322aa5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8158/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary enters into an escrow agreement under this section, the Secretary may enter into an agreement to procure medical equipment if one-half the purchase price of the equipment is available in an appropriation or fund for the expenditure or obligation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4322aa6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8158/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds held in an escrow account under this section shall not be considered to be public funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc4322aa7-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/405/tI/s103/a/1"},"text":"Pub. L. 102–405, title I, § 103(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-09"},"text":"Oct. 9, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1974"},"text":"106 Stat. 1974","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
