{"tag":"section","attrib":{"id":"idc3b16177-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3734"},"text":null,"children":[{"tag":"num","attrib":{"value":"3734"},"text":"§ 3734.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual submission of information on the Veterans Housing Benefit Program Fund and housing programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3b16178-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3734/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the documents providing detailed information on the budget for the Department of Veterans Affairs that the Secretary submits to the Congress in conjunction with the President’s budget submission for each fiscal year pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":", the Secretary shall include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3b16179-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3734/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the operations of the Veterans Housing Benefit Program Fund during the fiscal year preceding the fiscal year in which such budget is submitted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3b1617a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3734/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the needs of such fund, if any, for appropriations for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3b1617b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3734/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fiscal year in which the budget is submitted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3b1617c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3734/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fiscal year for which the budget is submitted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3b1617d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3734/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The matters submitted under subsection (a) of this section shall include, with respect to the fund referred to in subsection (a), the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3b1617e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3734/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Information and financial data on the operations of the fund during the fiscal year before the fiscal year in which such matters are submitted and estimated financial data and related information on the operation of the fund for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3b1617f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3734/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fiscal year of the submission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3b16180-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3734/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fiscal year following the fiscal year of the submission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3b16181-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3734/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Estimates of the amount of revenues derived by the fund in the fiscal year preceding the fiscal year of the submission, in the fiscal year of the submission, and in the fiscal year following the fiscal year of the submission from each of the following sources:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3b16182-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3734/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fees collected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3729/a"},"text":"section 3729(a) of this title","children":[],"tail":" for each category of loan guaranteed, insured, or made under this chapter or collected under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3729/b"},"text":"section 3729(b) of this title","children":[],"tail":" for assumed loans."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3b16183-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3734/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Investment income.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3b16184-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3734/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sales of foreclosed properties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3b16185-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3734/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Loan asset sales.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3b16186-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3734/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each additional source of revenue.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3b16187-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3734/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information, for each fiscal year referred to in paragraph (2) of this subsection, regarding the types of dispositions made and anticipated to be made of defaults on loans guaranteed, insured, or made under this chapter, including the cost to the fund, and the numbers, of such types of dispositions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3b16188-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3734/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The information submitted under subsection (a) shall include a statement that summarizes the financial activity of each of the housing programs operated under this chapter. The statement shall be presented in a form that is simple, concise, and readily understandable, and shall not include references to financing accounts, liquidating accounts, or program accounts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","a