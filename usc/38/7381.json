{"tag":"section","attrib":{"id":"idc4026895-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7381"},"text":null,"children":[{"tag":"num","attrib":{"value":"7381"},"text":"§ 7381.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Research and Development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc4026896-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7381/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Office of Research and Development","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is in the Veterans Health Administration an Office of Research and Development (in this section referred to as the “Office”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4026897-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7381/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The function of the Office is to serve veterans through a full spectrum of research (including pre-clinical, clinical, and health systems science), technology transfer, and application.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4026898-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7381/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chief Research and Development Officer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of the Office is the Chief Research and Development Officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4026899-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7381/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Organization and Personnel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Office shall be organized in such manner, and its personnel shall perform such duties and have such titles, as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc402689a-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dU/tI/s182/a"},"text":"Pub. L. 117–328, div. U, title I, § 182(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5436"},"text":"136 Stat. 5436","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
