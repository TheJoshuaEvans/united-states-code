{"tag":"section","attrib":{"id":"idc337c4ff-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2053"},"text":null,"children":[{"tag":"num","attrib":{"value":"2053"},"text":"§ 2053.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Default","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc337c500-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2053/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall take such steps as may be necessary to obtain repayment on any loan that is in default and that is guaranteed under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc337c501-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2053/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Upon default of a loan guaranteed under this subchapter and terminated pursuant to State law, a lender may file a claim under the guarantee for an amount not to exceed the lesser of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc337c502-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2053/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maximum guarantee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc337c503-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2053/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the difference between—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc337c504-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2053/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total outstanding obligation on the loan, including principal, interest, and expenses authorized by the loan documents, through the date of the public sale (as authorized under such documents and State law); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c505-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2053/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount realized at such sale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc337c506-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/tVI/s601/a"},"text":"Pub. L. 105–368, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3344"},"text":"112 Stat. 3344","children":[],"tail":", § 3774; renumbered § 2053, "},{"tag":"ref","attrib":{"href":"/us/pl/107/95/s5/d/1"},"text":"Pub. L. 107–95, § 5(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-21"},"text":"Dec. 21, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/918"},"text":"115 Stat. 918","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc337c507-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc337c508-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc337c509-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/95"},"text":"Pub. L. 107–95","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3774"},"text":"section 3774 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc337c50a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc337c50b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/368/s602/f"},"text":"section 602(f) of Pub. L. 105–368","children":[],"tail":", set out as an Effective Date of 1998 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2106"},"text":"section 2106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
