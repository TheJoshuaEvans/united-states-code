{"tag":"section","attrib":{"id":"idc36c424c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3322"},"text":null,"children":[{"tag":"num","attrib":{"value":"3322"},"text":"§ 3322.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bar to duplication of educational assistance benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc36c424d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3322/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual entitled to educational assistance under this chapter who is also eligible for educational assistance under chapter 30, 31, 32, or 35 of this title, chapter 107, 1606, or 1607 or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s510"},"text":"section 510 of title 10","children":[],"tail":", or the provisions of the Hostage Relief Act of 1980 ("},{"tag":"ref","attrib":{"href":"/us/pl/96/449"},"text":"Public Law 96–449","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5561"},"text":"5 U.S.C. 5561","children":[],"tail":" note) may not receive assistance under two or more such programs concurrently, but shall elect (in such form and manner as the Secretary may prescribe) under which chapter or provisions to receive educational assistance."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc36c424e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3322/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability of Service Treated Under Educational Loan Repayment Programs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A period of service counted for purposes of repayment of an education loan under chapter 109 of title 10 may not be counted as a period of service for entitlement to educational assistance under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc36c424f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3322/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service in Selected Reserve","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual who serves in the Selected Reserve may receive credit for such service under only one of this chapter, chapter 30 of this title, and chapters 1606 and 1607 of title 10, and shall elect (in such form and manner as the Secretary may prescribe) under which chapter such service is to be credited.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc36c4250-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3322/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Coordination Matters","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of an individual entitled to educational assistance under chapter 30, 31, 32, or 35 of this title, chapter 107, 1606, or 1607 of title 10, or the provisions of the Hostage Relief Act of 1980, or making contributions toward entitlement to educational assistance under chapter 30 of this title, as of ","children":[{"tag":"date","attrib":{"date":"2009-08-01"},"text":"August 1, 2009","children":[],"tail":", coordination of entitlement to educational assistance under this chapter, on the one hand, and such chapters or provisions, on the other, shall be governed by the provisions of section 5003(c) of the Post-9/11 Veterans Educational Assistance Act of 2008."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc36c4251-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3322/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Bar To Concurrent Receipt of Transferred Education Benefits and Marine Gunnery Sergeant John David Fry Scholarship Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual entitled to educational assistance under both section 3319 and paragraph (8), (9), or (10) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3311"},"text":"section 3311 of this title","children":[],"tail":" may not receive assistance under both provisions concurrently, but shall elect (in such form and manner as the Secretary may prescribe) under which provision to receive educational assistance."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc36c4252-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3322/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Bar To Receipt of Compensation and Pension and Marine Gunnery Sergeant John David Fry Scholarship Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The commencement of a program of education under paragraph (8), (9), or (10) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3311"},"text":"section 3311 of this title","children":[],"tail":" shall be a bar to the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc36c4253-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3322/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsequent payments of dependency and indemnity compensation or pension based on the death of a parent to an eligible person over the age of 18 years by reason of pursuing a course in an educational institution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc36c4254-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3322/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increased rates, or additional amounts, of compensation, dependency and indemnity compensation, or pension because of such a person, whether eligibility is based upon the death of the parent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc36c4255-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3322/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Bar To Concurrent Receipt of Transferred Education Benefits","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A spouse or child who is entitled to educational assistance under this chapter based on a transfer of entitlement from more than one individual under section 3319 may not receive assistance based on transfers from more than one such individual concurrently, but shall elect (in such form and manner as the Secretary may prescribe) under which source to utilize such assistance at any one time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc36c4256-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3322/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Bar To Duplication of Eligibility Based on a Single Event or Period of Service.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc36c4257-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3322/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Active-duty service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual with qualifying service in the Armed Forces that establishes eligibility on the part of such individual for educational assistance under this chapter, chapter 30 or 32 of this title, and chapter 1606 or 1607 of title 10, shall elect (in such form and manner as the Secretary may prescribe) under which authority such service is to be credited.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc36c4258-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3322/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility for educational assistance based on parent’s service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A child of a member of the Armed Forces who, on or after ","children":[{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":", dies in the line of duty while serving on active duty, who is eligible for educational assistance under either chapter 35 or paragraph (8), (9), or (10) of "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3311"},"text":"section 3311 of this title","children":[],"tail":" based on the parent’s death may not receive such assistance under both this chapter and chapter 35 of this title, but shall elect (in such form and manner as the Secretary may prescribe) under which chapter to receive such assistance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc36c4259-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/252/tV/s5003/a/1"},"text":"Pub. L. 110–252, title V, § 5003(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-30"},"text":"June 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2373"},"text":"122 Stat. 2373","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/377/tI/s111/a"},"text":"Pub. L. 111–377, title I, § 111(a)","children":[],"tail":"–(d), title II, § 202(a), "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4120"},"text":"124 Stat. 4120","children":[],"tail":", 4121, 4124; "},{"tag":"ref","attrib":{"href":"/us/pl/115/48/tI/s105/c/6"},"text":"Pub. L. 115–48, title I, § 105(c)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-16"},"text":"Aug. 16, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/976"},"text":"131 Stat. 976","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/315/tI/s1002/b/5"},"text":"Pub. L. 116–315, title I, § 1002(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4938"},"text":"134 Stat. 4938","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc36c425a-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc36c425b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc36c425c-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Hostage Relief Act of 1980, referred to in subsecs. (a) and (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/449"},"text":"Pub. L. 96–449","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-14"},"text":"Oct. 14, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1967"},"text":"94 Stat. 1967","children":[],"tail":", which was formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5561"},"text":"section 5561 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 5003(c) of the Post-9/11 Veterans Educational Assistance Act of 2008, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/252/s5003/c"},"text":"section 5003(c) of Pub. L. 110–252","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3301"},"text":"section 3301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc36c425d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/s1002/b/5/A"},"text":"Pub. L. 116–315, § 1002(b)(5)(A)","children":[],"tail":", substituted “section 3319 and paragraph (8), (9), or (10) of "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3311"},"text":"section 3311 of this title","children":[],"tail":"” for “sections 3311(b)(8) and 3319”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/s1002/b/5/B"},"text":"Pub. L. 116–315, § 1002(b)(5)(B)","children":[],"tail":", substituted “paragraph (8), (9), or (10) of "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3311"},"text":"section 3311 of this title","children":[],"tail":"” for “section 3311(b)(8)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/s1002/b/5/C"},"text":"Pub. L. 116–315, § 1002(b)(5)(C)","children":[],"tail":", substituted “either chapter 35 or paragraph (8), (9), or (10) of section 3311” for “either section 3311(b)(8) or chapter 35”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsecs. (e), (f), (h)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/48"},"text":"Pub. L. 115–48","children":[],"tail":" substituted “3311(b)(8)” for “3311(b)(9)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/377/s202/a"},"text":"Pub. L. 111–377, § 202(a)","children":[],"tail":", inserted “or section 510” after “or 1607”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/377/s111/a"},"text":"Pub. L. 111–377, § 111(a)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/377/s111/b"},"text":"Pub. L. 111–377, § 111(b)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/377/s111/c"},"text":"Pub. L. 111–377, § 111(c)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/377/s111/d"},"text":"Pub. L. 111–377, § 111(d)","children":[],"tail":", added subsec. (h)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc36c425e-47c4-11f1-bf59-9680b1269b87"}