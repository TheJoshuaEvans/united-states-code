{"tag":"section","attrib":{"id":"idc3b161f9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3744"},"text":null,"children":[{"tag":"num","attrib":{"value":"3744"},"text":"§ 3744.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of loans by the Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3b161fa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3744/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (b) of this section, a loan may not be guaranteed under this subchapter unless, before the closing of the loan, it is submitted to the Secretary for approval and the Secretary grants approval.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3b161fb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3744/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may exempt any lender of a class of lenders listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3702/d"},"text":"section 3702(d) of this title","children":[],"tail":" from the prior approval requirement in subsection (a) of this section if the Secretary determines that the experience of such lender or class of lenders warrants such exemption."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3b161fc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3744/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may at any time upon thirty days’ notice require loans to be made by any lender or class of lenders under this subchapter to be submitted to the Secretary for prior approval. No guaranty shall exist with respect to any such loan unless evidence of the guaranty is issued by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3b161fd-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/72/tIII/s302/a"},"text":"Pub. L. 97–72, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-11-03"},"text":"Nov. 3, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1057"},"text":"95 Stat. 1057","children":[],"tail":", § 1844; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIII/s313/b/1"},"text":"Pub. L. 101–237, title III, § 313(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2077"},"text":"103 Stat. 2077","children":[],"tail":"; renumbered § 3744 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3b161fe-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3b161ff-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3b16200-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1844"},"text":"section 1844 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “3702(d)” for “1802(d)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" substituted “Secretary” for “Administrator” in section catchline and wherever appearing in text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
