{"tag":"section","attrib":{"id":"idc33c808e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2107"},"text":null,"children":[{"tag":"num","attrib":{"value":"2107"},"text":"§ 2107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of administration of benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide for the coordination of the administration of programs to provide specially adapted housing that are administered by the Under Secretary for Health and such programs that are administered by the Under Secretary for Benefits under this chapter, chapter 17, and chapter 31 of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc33c808f-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/233/tI/s101/c"},"text":"Pub. L. 109–233, title I, § 101(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-06-15"},"text":"June 15, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/399"},"text":"120 Stat. 399","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
