{"tag":"section","attrib":{"id":"idc3c92f32-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4322"},"text":null,"children":[{"tag":"num","attrib":{"value":"4322"},"text":"§ 4322.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of employment or reemployment rights","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3c92f33-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4322/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person who claims that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3c92f34-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4322/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such person is entitled under this chapter to employment or reemployment rights or benefits with respect to employment by an employer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3c92f35-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4322/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3c92f36-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4322/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such employer has failed or refused, or is about to fail or refuse, to comply with the provisions of this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3c92f37-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4322/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case that the employer is a Federal executive agency, such employer or the Office of Personnel Management has failed or refused, or is about to fail or refuse, to comply with the provisions of this chapter,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"may file a complaint with the Secretary in accordance with subsection (b), and the Secretary shall investigate such complaint.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3c92f38-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4322/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such complaint shall be in writing, be in such form as the Secretary may prescribe, include the name and address of the employer against whom the complaint is filed, and contain a summary of the allegations that form the basis for the complaint.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3c92f39-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4322/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3c92f3a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4322/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than five days after the Secretary receives a complaint submitted by a person under subsection (a), the Secretary shall notify such person in writing of his or her rights with respect to such complaint under this section and section 4323 or 4324, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3c92f3b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4322/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall, upon request, provide technical assistance to a potential claimant with respect to a complaint under this subsection, and when appropriate, to such claimant’s employer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3c92f3c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4322/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall investigate each complaint submitted pursuant to subsection (a). If the Secretary determines as a result of the investigation that the action alleged in such complaint occurred, the Secretary shall attempt to resolve the complaint by making reasonable efforts to ensure that the person or entity named in the complaint complies with the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3c92f3d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4322/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the efforts of the Secretary with respect to any complaint filed under subsection (a) do not resolve the complaint, the Secretary shall notify the person who submitted the complaint in writing of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3c92f3e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4322/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of the Secretary’s investigation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3c92f3f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4322/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the complainant’s entitlement to proceed under the enforcement of rights provisions provided under section 4323 (in the case of a person submitting a complaint against a State or private employer) or section 4324 (in the case of a person submitting a complaint against a Federal executive agency or the Office of Personnel Management).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3c92f40-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4322/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any action required by subsections (d) and (e) with respect to a complaint submitted by a person to the Secretary under subsection (a) shall be completed by the Secretary not later than 90 days after receipt of such complaint.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3c92f41-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4322/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This subchapter does not apply to any action relating to benefits to be provided under the Thrift Savings Plan under title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3c92f42-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/353/s2/a"},"text":"Pub. L. 103–353, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3164"},"text":"108 Stat. 3164","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/275/tIII/s311/9"},"text":"Pub. L. 104–275, title III, § 311(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3335"},"text":"110 Stat. 3335","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/389/tIII/s311/a"},"text":"Pub. L. 110–389, title III, § 311(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4162"},"text":"122 Stat. 4162","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3c92f43-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3c92f44-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc3c92f45-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4322 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7622"},"text":"section 7622 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3c92f46-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/389/s311/a"},"text":"Pub. L. 110–389, § 311(a)","children":[],"tail":", amended subsec. (c) generally. Prior to amendment, subsec. (c) read as follows: “The Secretary shall, upon request, provide technical assistance to a potential claimant with respect to a complaint under this subsection, and when appropriate, to such claimant’s employer.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/389/s311/b"},"text":"Pub. L. 110–389, § 311(b)","children":[],"tail":", inserted “in writing” after “submitted the complaint” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/389/s311/c"},"text":"Pub. L. 110–389, § 311(c)","children":[],"tail":", added subsec. (f) and redesignated former subsec. (f) as (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/275/s311/9/A"},"text":"Pub. L. 104–275, § 311(9)(A)","children":[],"tail":", inserted “attempt to” before “resolve”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/275/s311/9/B/i"},"text":"Pub. L. 104–275, § 311(9)(B)(i)","children":[],"tail":", substituted “with respect to any complaint filed under subsection (a) do not resolve the complaint,” for “with respect to a complaint under subsection (d) are unsuccessful,” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/275/s311/9/B/ii"},"text":"Pub. L. 104–275, § 311(9)(B)(ii)","children":[],"tail":", inserted “or the Office of Personnel Management” after “Federal executive agency”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3c92f47-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3c92f48-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/275"},"text":"Pub. L. 104–275","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/275/s313"},"text":"section 313 of Pub. L. 104–275","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4301"},"text":"section 4301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3c92f49-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective with respect to reemployments initiated on or after the first day after the 60-day period beginning ","children":[{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", with transition rules, except that provisions necessary for implementation of "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4311"},"text":"section 4311 of this title","children":[],"tail":" are effective "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/353/s8"},"text":"section 8 of Pub. L. 103–353","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4301"},"text":"section 4301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
