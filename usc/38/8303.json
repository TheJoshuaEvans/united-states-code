{"tag":"section","attrib":{"id":"idc436e63c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8303"},"text":null,"children":[{"tag":"num","attrib":{"value":"8303"},"text":"§ 8303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restricted gifts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Disbursements from the General Post Fund shall be made on orders by and within the discretion of the Secretary and in the manner prescribed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s8523"},"text":"section 8523 of this title","children":[],"tail":"; except that (1) if the testator or donor has directed or shall direct that the devise, bequest, or gift be devoted to a particular use authorized by this chapter, the same, less expenses incurred, or the net proceeds thereof, shall be used or disbursed as directed, except that a precatory direction shall be fulfilled only insofar as may be proper or practicable; and (2) if the testator or donor shall have indicated the desire that the devise, bequest, or gift shall be for the benefit of persons in hospitals or homes, or other institutions operated by the United States but under the jurisdiction of an official other than the Secretary, the same, less expenses incurred, or the net proceeds thereof which may come into possession of the Secretary, shall be disbursed by transfer to the governing authorities of such institution, or otherwise, in such manner as the Secretary may determine, for the benefit of the persons in the institution indicated by the testator or donor, for proper purposes, as nearly as practicable in conformity with such desire of the testator or donor."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc436e63d-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1255"},"text":"72 Stat. 1255","children":[],"tail":", § 5103; "},{"tag":"ref","attrib":{"href":"/us/pl/99/576/tVII/s701/91"},"text":"Pub. L. 99–576, title VII, § 701(91)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3299"},"text":"100 Stat. 3299","children":[],"tail":"; renumbered § 8303 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", (d)(1), "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":", 239; "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404"},"text":"105 Stat. 404","children":[],"tail":", 405.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc436e63e-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc436e63f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc436e640-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/b/1"},"text":"Pub. L. 102–40, § 402(b)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5103"},"text":"section 5103 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" substituted “Secretary” for “Administrator” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/d/1"},"text":"Pub. L. 102–40, § 402(d)(1)","children":[],"tail":", substituted “8523” for “5223”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576"},"text":"Pub. L. 99–576","children":[],"tail":" substituted “the” for “his” in three places."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
