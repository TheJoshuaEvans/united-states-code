{"tag":"section","attrib":{"id":"idc28c1bf4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547"},"text":null,"children":[{"tag":"num","attrib":{"value":"547"},"text":"§ 547.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Committee on Tribal and Indian Affairs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc28c1bf5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc28c1bf6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall establish an advisory committee to provide advice and guidance to the Secretary on matters relating to Indian tribes, tribal organizations, and Native American veterans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28c1bf7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The advisory committee established under paragraph (1) shall be known as the “Advisory Committee on Tribal and Indian Affairs” (in this section referred to as the “Committee”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28c1bf8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee shall facilitate, but not supplant, government-to-government consultation between the Department and Indian tribes or tribal organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28c1bf9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall consult with Indian tribes or tribal organizations in developing a charter for the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc28c1bfa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc28c1bfb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee shall be comprised of 15 voting members selected by the Secretary from among individuals nominated as specified under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28c1bfc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In selecting members under paragraph (1), the Secretary shall ensure that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc28c1bfd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least one member of each of the 12 service areas of the Indian Health Service is represented in the membership of the Committee nominated by Indian tribes or tribal organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc28c1bfe-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least one member of the Committee represents the Native Hawaiian veteran community nominated by a Native Hawaiian Organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc28c1bff-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least one member of the Committee represents urban Indian organizations nominated by a national urban Indian organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc28c1c00-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not fewer than half of the members are veterans, unless the Secretary determines that an insufficient number of qualified veterans were nominated under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28c1c01-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No member of the Committee may be an employee of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc28c1c02-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms; Vacancies","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc28c1c03-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the Committee shall be appointed for a term of two years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28c1c04-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall fill a vacancy in the Committee in the same manner as the original appointment within 180 days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc28c1c05-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Meetings","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc28c1c06-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc28c1c07-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subparagraph (B), the Committee shall meet in-person with the Secretary, or the Secretary’s designee, not less frequently than twice each year and hold monthly conference calls as necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc28c1c08-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" During a public health emergency (as defined in section 20003 of the Coronavirus Aid, Relief, and Economic Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136"},"text":"Public Law 116–136","children":[],"tail":")), meetings under subparagraph (A) may be conducted virtually."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28c1c09-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc28c1c0a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Representatives of relevant Federal agencies may attend meetings of the Committee and provide information to the Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc28c1c0b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One representative of the Office of Tribal Government Relations of the Department shall attend at each meeting of the Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc28c1c0c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Representatives attending meetings under this paragraph shall not be considered voting members of the Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc28c1c0d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A representative attending a meeting or providing information under this paragraph may not receive additional compensation for services performed with respect to the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc28c1c0e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subcommittees","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc28c1c0f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee may establish subcommittees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28c1c10-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may, in consultation with the Committee, appoint a member to a subcommittee established under paragraph (1) who is not a member of the Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28c1c11-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such subcommittees may enhance the function of the Committee, but may not supersede the authority of the Committee or provide direct advice or work products to the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc28c1c12-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The duties of the Committee are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc28c1c13-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To advise the Secretary on ways the Department can improve the programs and services of the Department to better serve Native American veterans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28c1c14-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To identify for the Department evolving issues of relevance to Indian tribes, tribal organizations, and Native American veterans relating to programs and services of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28c1c15-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To propose clarifications, recommendations, and solutions to address issues raised at tribal, regional, and national levels, especially regarding any tribal consultation reports.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28c1c16-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide a forum for Indian tribes, tribal organizations, urban Indian organizations, Native Hawaiian organizations, and the Department to discuss issues and proposals for changes to Department regulations, policies, and procedures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28c1c17-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To identify priorities and provide advice on appropriate strategies for tribal consultation and urban Indian organizations conferring on issues at the tribal, regional, or national levels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28c1c18-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To ensure that pertinent issues are brought to the attention of Indian tribes, tribal organizations, urban Indian organizations, and Native Hawaiian organizations in a timely manner, so that feedback can be obtained.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28c1c19-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/f/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To encourage the Secretary to work with other Federal agencies and Congress so that Native American veterans are not denied the full benefit of their status as both Native Americans and veterans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28c1c1a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/f/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To highlight contributions of Native American veterans in the Armed Forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28c1c1b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/f/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To make recommendations on the consultation policy of the Department on tribal matters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28c1c1c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/f/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To support a process to develop an urban Indian organization confer policy to ensure the Secretary confers, to the maximum extent practicable, with urban Indian organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28c1c1d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/f/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To conduct other duties as recommended by the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc28c1c1e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc28c1c1f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not less frequently than once each year, the Committee shall submit to the Secretary and the appropriate committees of Congress such recommendations as the Committee may have for legislative or administrative action for the upcoming year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28c1c20-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 90 days after the date on which the Secretary receives a recommendation under paragraph (1), the Secretary shall submit to the appropriate committees of Congress a written response to the recommendation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28c1c21-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not less frequently than once every two years, the Committee shall submit to the Secretary and the appropriate committees of Congress a report describing the activities of the Committee during the previous two years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28c1c22-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall make publicly available on an Internet website of the Department—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc28c1c23-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/g/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each recommendation the Secretary receives under paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc28c1c24-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/g/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each response the Secretary submits under paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc28c1c25-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/g/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each report the Secretary receives under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc28c1c26-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Committee Personnel Matters","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member of the Committee shall be allowed travel expenses, including per diem in lieu of subsistence, at rates authorized for an employee of an agency under subchapter I of chapter 57 of title 5 while away from the home or regular place of business of the member in the performance of the duties of the Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc28c1c27-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Advisory Committee Act Exemption","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Section 14 of the Federal Advisory Committee Act (5 U.S.C. App.) ","children":[{"tag":"ref","attrib":{"idref":"fn002014"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002014"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall not apply to the Committee."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc28c1c28-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc28c1c29-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “appropriate committees of Congress” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc28c1c2a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/j/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Veterans’ Affairs and the Committee on Indian Affairs of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc28c1c2b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/j/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Veterans’ Affairs and the Committee on Natural Resources of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28c1c2c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Indian tribe” has the meaning given such term in section 4 of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"25 U.S.C. 5304","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28c1c2d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “Native Hawaiian organization” means any organization that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc28c1c2e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/j/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serves the interests of Native Hawaiians;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc28c1c2f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/j/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has Native Hawaiians in substantive and policymaking positions within the organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc28c1c30-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/j/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has demonstrated experience working with Native Hawaiian veterans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc28c1c31-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/j/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include the Office of Hawaiian Affairs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28c1c32-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/j/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Native American veteran” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3765"},"text":"section 3765 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28c1c33-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/j/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Office of Hawaiian Affairs” means the Office of Hawaiian Affairs established by the constitution of the State of Hawaii.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28c1c34-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/j/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “tribal organization” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3765"},"text":"section 3765 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28c1c35-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s547/j/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “urban Indian organization” has the meaning given such term in section 4 of the Indian Health Care Improvement Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1603"},"text":"25 U.S.C. 1603","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc28c1c36-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/tVII/s7002/a/1"},"text":"Pub. L. 116–315, title VII, § 7002(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/5054"},"text":"134 Stat. 5054","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc28c1c37-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc28c1c38-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc28c1c39-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 20003 of the Coronavirus Aid, Relief, and Economic Security Act, referred to in subsec. (d)(1)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/s20003"},"text":"section 20003 of Pub. L. 116–136","children":[],"tail":", div. B, title X, "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/585"},"text":"134 Stat. 585","children":[],"tail":", which is set out as a Definition of “Public Health Emergency” note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s303"},"text":"section 303 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 14 of the Federal Advisory Committee Act, referred to in subsec. (i), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/463/s14"},"text":"section 14 of Pub. L. 92–463","children":[],"tail":", which was set out in the Appendix to Title 5, Government Organization and Employees, and was repealed and restated as "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"section 1013 of Title 5","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":", §§ 3(a), 7, "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4204"},"text":"136 Stat. 4204","children":[],"tail":", 4361."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc28c1c3a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc28c1c3b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadlines for Establishment, Initial Appointments, and Initial Meeting","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/tVII/s7002/b"},"text":"Pub. L. 116–315, title VII, § 7002(b)","children":[],"tail":"–(d), "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/5057"},"text":"134 Stat. 5057","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/315/tVII/s7002/b"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadline for Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Veterans Affairs shall establish the advisory committee required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s547"},"text":"section 547 of title 38","children":[],"tail":", United States Code, as added by subsection (a)(1), not later than 180 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadline for Initial Appointments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after the date on which the Secretary establishes the advisory committee required by such section, the Secretary shall appoint members under subsection (b)(1) of such section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Initial Meeting","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after the date on which the Secretary establishes the advisory committee required by such section, such advisory committee shall hold its first meeting.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
