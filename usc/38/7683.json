{"tag":"section","attrib":{"id":"idc417ebea-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7683"},"text":null,"children":[{"tag":"num","attrib":{"value":"7683"},"text":"§ 7683.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education debt reduction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc417ebeb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7683/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Education debt reduction payments under the Education Debt Reduction Program shall consist of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc417ebec-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7683/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payments to individuals selected to participate in the program of principal and interest on loans described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7682/a/2"},"text":"section 7682(a)(2) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc417ebed-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7683/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payments for the principal and interest on such loans of such individuals to the holders of such loans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc417ebee-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7683/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Frequency of Payment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc417ebef-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7683/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may make education debt reduction payments to or for any given participant in the Education Debt Reduction Program on a monthly or annual basis, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc417ebf0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7683/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall make such payments at the end of the period determined by the Secretary under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc417ebf1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7683/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Performance Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may make education debt reduction payments to or for a participant in the Education Debt Reduction Program for a period only if the Secretary determines that the individual maintained an acceptable level of performance in the position or positions served by the participant during the period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc417ebf2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7683/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum Annual Amount","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc417ebf3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7683/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of education debt reduction payments made to or for a participant under the Education Debt Reduction Program may not exceed $200,000 over a total of five years of participation in the Program, of which not more than $40,000 of such payments may be made in each year of participation in the Program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc417ebf4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7683/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc417ebf5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7683/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may waive the limitations under paragraph (1) in the case of a participant described in subparagraph (B). In the case of such a waiver, the total amount of education debt repayments payable to or for that participant is the total amount of the principal and the interest on the participant’s loans referred to in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc417ebf6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7683/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A participant described in this subparagraph is a participant in the Program who the Secretary determines serves in a position for which there is a shortage of qualified employees by reason of either the location or the requirements of the position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc417ebf7-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/tVIII/s803/a"},"text":"Pub. L. 105–368, title VIII, § 803(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3357"},"text":"112 Stat. 3357","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/135/tI/s102/c"},"text":"Pub. L. 107–135, title I, § 102(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-23"},"text":"Jan. 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2448"},"text":"115 Stat. 2448","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/163/tIII/s301/c"},"text":"Pub. L. 111–163, title III, § 301(c)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"2010-05-05"},"text":"May 5, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1146"},"text":"124 Stat. 1146","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/146/tIII/s302/b"},"text":"Pub. L. 113–146, title III, § 302(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-08-07"},"text":"Aug. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1788"},"text":"128 Stat. 1788","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/175/tIV/s408"},"text":"Pub. L. 113–175, title IV, § 408","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-09-26"},"text":"Sept. 26, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1906"},"text":"128 Stat. 1906","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/58/tVI/s601/24"},"text":"Pub. L. 114–58, title VI, § 601(24)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-09-30"},"text":"Sept. 30, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/539"},"text":"129 Stat. 539","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/182/tIII/s302/a"},"text":"Pub. L. 115–182, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-06"},"text":"June 6, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1463"},"text":"132 Stat. 1463","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc417ebf8-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc417ebf9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc417ebfa-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/182"},"text":"Pub. L. 115–182","children":[],"tail":" substituted “$200,000” for “$120,000” and “40,000” for “$24,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/58"},"text":"Pub. L. 114–58","children":[],"tail":" inserted period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/175/s408/1"},"text":"Pub. L. 113–175, § 408(1)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a). Prior to amendment, text read as follows: “Education debt reduction payments under the Education Debt Reduction Program shall consist of payments to individuals selected to participate in the program of amounts to reimburse such individuals for payments by such individuals of principal and interest on loans described in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7682/a/2"},"text":"section 7682(a)(2) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b)(1), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/175/s408/2"},"text":"Pub. L. 113–175, § 408(2)","children":[],"tail":", substituted “payments to or for” for “payments to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/175/s408/3/A"},"text":"Pub. L. 113–175, § 408(3)(A)","children":[],"tail":", substituted “made to or for” for “made to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/146/s302/b/1"},"text":"Pub. L. 113–146, § 302(b)(1)","children":[],"tail":", (2)(B), substituted “The amount” for “Subject to paragraph (2), the amount”, “$120,000” for “$60,000”, and “$24,000 of such payments may be made in each year of participation in the Program” for “$12,000 of such payments may be made in each of the fourth and fifth years of participation in the Program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/146/s302/b/2/A/i"},"text":"Pub. L. 113–146, § 302(b)(2)(A)(i)","children":[],"tail":", (ii), redesignated par. (3) as (2) and struck out former par. (2) which read as follows: “The total amount payable to a participant in such Program for any year may not exceed the amount of the principal and interest on loans referred to in subsection (a) that is paid by the individual during such year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/175/s408/3/B"},"text":"Pub. L. 113–175, § 408(3)(B)","children":[],"tail":", substituted “payable to or for that” for “payable to that”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/146/s302/b/2/A/iii"},"text":"Pub. L. 113–146, § 302(b)(2)(A)(iii)","children":[],"tail":", substituted “paragraph (1)” for “paragraphs (1) and (2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/146/s302/b/2/A/ii"},"text":"Pub. L. 113–146, § 302(b)(2)(A)(ii)","children":[],"tail":", redesignated par. (3) as (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163/s301/c"},"text":"Pub. L. 111–163, § 301(c)","children":[],"tail":", substituted “$60,000” for “$44,000” and “$12,000” for “$10,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163/s301/d"},"text":"Pub. L. 111–163, § 301(d)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/135"},"text":"Pub. L. 107–135","children":[],"tail":" struck out “for a year” after “a participant” and substituted “exceed $44,000 over a total of five years of participation in the Program, of which not more than $10,000 of such payments may be made in each of the fourth and fifth years of participation in the Program” for “exceed—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) $6,000 for the first year of the participant’s participation in the Program;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) $8,000 for the second year of the participant’s participation in the Program; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) $10,000 for the third year of the participant’s participation in the Program”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
