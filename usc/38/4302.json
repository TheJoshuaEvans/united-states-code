{"tag":"section","attrib":{"id":"idc3c474f5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4302"},"text":null,"children":[{"tag":"num","attrib":{"value":"4302"},"text":"§ 4302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to other law and plans or agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3c474f6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this chapter shall supersede, nullify or diminish any Federal or State law (including any local law or ordinance), contract, agreement, policy, plan, practice, or other matter that establishes a right or benefit that is more beneficial to, or is in addition to, a right or benefit provided for such person in this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3c474f7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This chapter supersedes any State law (including any local law or ordinance), contract, agreement, policy, plan, practice, or other matter that reduces, limits, or eliminates in any manner any right or benefit provided by this chapter, including the establishment of additional prerequisites to the exercise of any such right or the receipt of any such benefit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3c474f8-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/353/s2/a"},"text":"Pub. L. 103–353, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3150"},"text":"108 Stat. 3150","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3c474f9-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3c474fa-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc3c474fb-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4302, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/508/tIV/s404/a"},"text":"Pub. L. 93–508, title IV, § 404(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-12-03"},"text":"Dec. 3, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1596"},"text":"88 Stat. 1596","children":[],"tail":", § 2022; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/295/s4/71"},"text":"Pub. L. 97–295, § 4(71)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1310"},"text":"96 Stat. 1310","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/620/tIV/s402/36"},"text":"Pub. L. 98–620, title IV, § 402(36)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3360"},"text":"98 Stat. 3360","children":[],"tail":"; renumbered § 4302 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/568/tV/s506/a"},"text":"Pub. L. 102–568, title V, § 506(a)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4340"},"text":"106 Stat. 4340","children":[],"tail":", 4341, related to procedures to enforce reemployment rights, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/103/353"},"text":"Pub. L. 103–353","children":[],"tail":". This section, as in effect on the day before "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", continues to apply to reemployments initiated before the end of the 60-day period beginning "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/353/s8"},"text":"section 8 of Pub. L. 103–353","children":[],"tail":", as amended, set out as an Effective Date under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4301"},"text":"section 4301 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 4302 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7602"},"text":"section 7602 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3c474fc-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3c474fd-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective with respect to reemployments initiated on or after the first day after the 60-day period beginning ","children":[{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", with transition rules, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/353/s8"},"text":"section 8 of P