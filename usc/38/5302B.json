{"tag":"section","attrib":{"id":"idc3d51649-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5302B"},"text":null,"children":[{"tag":"num","attrib":{"value":"5302B"},"text":"§ 5302B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of debt arising from overpayment due to delay in processing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3d5164a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5302B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3d5164b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5302B/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in paragraph (2), no individual may incur a debt to the United States that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3d5164c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5302B/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arises from the participation of the individual in a program or benefit administered by the Under Secretary for Benefits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3d5164d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5302B/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is attributable to the failure of an employee or official of the Department to process information provided by or on behalf of that individual within applicable timeliness standards established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d5164e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5302B/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this section shall be construed to affect the penal and forfeiture provisions for fiduciaries set forth in chapter 61 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d5164f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5302B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3d51650-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5302B/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary determines that the Secretary has made an overpayment to an individual, the Secretary shall provide notice to the individual of the overpayment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d51651-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5302B/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notice under paragraph (1) shall include a detailed explanation of the right of the individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3d51652-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5302B/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to dispute the overpayment, including a detailed explanation of the process by which to dispute the overpayment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3d51653-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5302B/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to request a waiver of indebtedness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d51654-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5302B/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delay on Collection","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3d51655-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5302B/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2), the Secretary may not take any action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3711"},"text":"section 3711 of title 31","children":[],"tail":" regarding an overpayment described in a notice under subsection (b) of this section until the date that is 90 days after the date the Secretary issues such notice."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d51656-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5302B/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may take action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3711"},"text":"section 3711 of title 31","children":[],"tail":" regarding an overpayment described in a notice under subsection (b) of this section before the date that is 90 days after the date the Secretary issues such notice if the Secretary determines that delaying such action is—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3d51657-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5302B/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" likely to make repayment of such overpayment more difficult for an individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3d51658-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5302B/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" likely to cause an unpaid debt to be referred to the Treasury Offset Program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3d51659-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5302B/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not in the best interest of the individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3d5165a-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dU/tII/s252/a/1"},"text":"Pub. L. 117–328, div. U, title II, § 252(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5462"},"text":"136 Stat. 5462","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3d5165b-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3d5165c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3d5165d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dU/tII/s252/a/3"},"text":"Pub. L. 117–328, div. U, title II, § 252(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5463"},"text":"136 Stat. 5463","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dU/tII/s252/a/3"},"text":"“The Secretary of Veterans Affairs shall prescribe regulations to establish standards under section 5302B(a)(2) of such title, as added by subsection (a), not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
