{"tag":"section","attrib":{"id":"idc3c92fd9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4332"},"text":null,"children":[{"tag":"num","attrib":{"value":"4332"},"text":"§ 4332.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3c92fda-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4332/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report by Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, after consultation with the Attorney General and the Special Counsel referred to in section 4324(a)(1), transmit to Congress not later than July 1 each year a report on matters for the fiscal year ending in the year before the year in which such report is transmitted as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3c92fdb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4332/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of cases reviewed by the Department of Labor under this chapter during the fiscal year for which the report is made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3c92fdc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4332/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of cases reviewed by the Secretary of Defense under the National Committee for Employer Support of the Guard and Reserve of the Department of Defense during the fiscal year for which the report is made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3c92fdd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4332/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of cases referred to the Attorney General or the Special Counsel pursuant to section 4323 or 4324, respectively, during such fiscal year and the number of actions initiated by the Office of Special Counsel before the Merit Systems Protection Board pursuant to section 4324 during such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3c92fde-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4332/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of complaints filed by the Attorney General pursuant to section 4323 during such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3c92fdf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4332/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of cases reviewed by the Secretary and the Secretary of Defense through the National Committee for Employer Support of the Guard and Reserve of the Department of Defense that involve the same person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3c92fe0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4332/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to the cases reported on pursuant to paragraphs (1), (2), (3), (4), and (5)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3c92fe1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4332/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of such cases that involve a disability-related issue; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3c92fe2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4332/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of such cases that involve a person who has a service-connected disability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3c92fe3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4332/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The nature and status of each case reported on pursuant to paragraph (1), (2), (3), (4), or (5).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3c92fe4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4332/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to the cases reported on pursuant to paragraphs (1), (2), (3), (4), and (5) the number of such cases that involve persons with different occupations or persons seeking different occupations, as designated by the Standard Occupational Classification System.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3c92fe5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4332/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An indication of whether there are any apparent patterns of violation of the provisions of this chapter, together with an explanation thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3c92fe6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4332/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recommendations for administrative or legislative action that the Secretary, the Attorney General, or the Special Counsel considers necessary for the effective implementation of this chapter, including any action that could be taken to encourage mediation, before claims are filed under this chapter, between employers and persons seeking employment or reemployment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3c92fe7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4332/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Quarterly Reports.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3c92fe8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4332/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Quarterly report by secretary","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after the end of each fiscal quarter, the Secretary shall submit to Congress, the Secretary of Defense, the Attorney General, and the Special Counsel a report setting forth, for the previous full quarter, the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3c92fe9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4332/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of cases for which the Secretary did not meet the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4322/f"},"text":"section 4322(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3c92fea-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4332/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of cases for which the Secretary received a request for a referral under paragraph (1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4323/a"},"text":"section 4323(a) of this title","children":[],"tail":" but did not make such referral within the time period required by such paragraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3c92feb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4332/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Quarterly report by attorney general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days after the end of each fiscal quarter, the Attorney General shall submit to Congress, the Secretary, the Secretary of Defense, and the Special Counsel a report setting forth, for the previous full quarter, the number of cases for which the Attorney General received a referral under paragraph (1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4323/a"},"text":"section 4323(a) of this title","children":[],"tail":" but did not meet the requirements of paragraph (2) of "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4323/a"},"text":"section 4323(a) of this title","children":[],"tail":" for such referral."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3c92fec-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4332/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Quarterly report by special counsel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days after the end of each fiscal quarter, the Special Counsel shall submit to Congress, the Secretary, the Secretary of Defense, and the Attorney General a report setting forth, for the previous full quarter, the number of cases for which the Special Counsel received a referral under paragraph (1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4324/a"},"text":"section 4324(a) of this title","children":[],"tail":" but did not meet the requirements of paragraph (2)(B) of "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4324/a"},"text":"section 4324(a) of this title","children":[],"tail":" for such referral."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3c92fed-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4332/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Uniform Categorization of Data","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall coordinate with the Secretary of Defense, the Attorney General, and the Special Counsel to ensure that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3c92fee-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4332/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information in the reports required by this section is categorized in a uniform way; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3c92fef-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4332/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary, the Secretary of Defense, the Attorney General, and the Special Counsel each have electronic access to the case files reviewed under this chapter by the Secretary, the Secretary of Defense, the Attorney General, and the Special Counsel with due regard for the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3c92ff0-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/353/s2/a"},"text":"Pub. L. 103–353, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3168"},"text":"108 Stat. 3168","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/454/tII/s202"},"text":"Pub. L. 108–454, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-10"},"text":"Dec. 10, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3606"},"text":"118 Stat. 3606","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tV/s595"},"text":"Pub. L. 110–181, div. A, title V, § 595","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/139"},"text":"122 Stat. 139","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/389/tIII/s312/a"},"text":"Pub. L. 110–389, title III, § 312(a)","children":[],"tail":"–(d), "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4164"},"text":"122 Stat. 4164","children":[],"tail":", 4165.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3c92ff1-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3c92ff2-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc3c92ff3-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4332 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7632"},"text":"section 7632 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3c92ff4-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/389/s312/a"},"text":"Pub. L. 110–389, § 312(a)","children":[],"tail":", (b)(1), designated existing provisions as subsec. (a), inserted heading, and substituted “, transmit to Congress not later than July 1 each year a report on matters for the fiscal year ending in the year before the year in which such report is transmitted as follows:” for “and no later than "},{"tag":"date","attrib":{"date":"2005-02-01"},"text":"February 1, 2005","children":[],"tail":", and annually thereafter, transmit to the Congress, a report containing the following matters for the fiscal year ending before such February 1:” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" added par. (2), redesignated former pars. (2) to (6) as (3) to (7), respectively, and in par. (5) substituted “(2), (3), or (4)” for “(2), or (3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/389/s312/b/2"},"text":"Pub. L. 110–389, § 312(b)(2)","children":[],"tail":", inserted “and the number of actions initiated by the Office of Special Counsel before the Merit Systems Protection Board pursuant to section 4324 during such fiscal year” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5) to (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/389/s312/b/3"},"text":"Pub. L. 110–389, § 312(b)(3)","children":[],"tail":"–(7), added pars. (5), (6), and (8), redesignated former pars. (5), (6), and (7) as (7), (9), and (10), respectively, and in par. (7), substituted “(4), or (5)” for “or (4)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/389/s312/c"},"text":"Pub. L. 110–389, § 312(c)","children":[],"tail":", (d), added subsecs. (b) and (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/454"},"text":"Pub. L. 108–454","children":[],"tail":" substituted “no later than "},{"tag":"date","attrib":{"date":"2005-02-01"},"text":"February 1, 2005","children":[],"tail":", and annually thereafter” for “no later than "},{"tag":"date","attrib":{"date":"1996-02-01"},"text":"February 1, 1996","children":[],"tail":", and annually thereafter through 2000” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3c92ff5-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3c92ff6-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/389/tIII/s312/f"},"text":"Pub. L. 110–389, title III, § 312(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4166"},"text":"122 Stat. 4166","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/389/tIII/s312/f"},"text":"“The amendments made by this section [amending this section] shall apply with respect to each report required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4332"},"text":"section 4332 of title 38","children":[],"tail":", United States Code (as amended by this section), after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3c92ff7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective with respect to reemployments initiated on or after the first day after the 60-day period beginning ","children":[{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", with transition rules, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/353/s8"},"text":"section 8 of Pub. L. 103–353","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4301"},"text":"section 4301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
