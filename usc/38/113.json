{"tag":"section","attrib":{"id":"idc27426f9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s113"},"text":null,"children":[{"tag":"num","attrib":{"value":"113"},"text":"§ 113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain programs under sequestration procedures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc27426fa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s113/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The following programs shall be exempt from sequestration or reduction under part C of the Balanced Budget and Emergency Deficit Control Act of 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s901"},"text":"2 U.S.C. 901","children":[],"tail":" et seq.) or any other sequestration law and shall not be included in any report specifying reductions in Federal spending:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc27426fb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s113/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Benefits under chapter 21 of this title, relating to specially adapted housing and mortgage-protection life insurance for certain veterans with service-connected disabilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27426fc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s113/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Benefits under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2307"},"text":"section 2307 of this title","children":[],"tail":", relating to burial benefits for veterans who die as the result of a service-connected disability."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"