ail":null},{"tag":"chapeau","attrib":{},"text":" The following accounts of the Department shall be exempt from sequestration or reduction under part C of the Balanced Budget and Emergency Deficit Control Act of 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s901"},"text":"2 U.S.C. 901","children":[],"tail":" et seq.) or any other sequestration law and shall not be included in any report specifying reductions in Federal spending:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2742702-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s113/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The following life insurance accounts:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2742703-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s113/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Service Life Insurance Fund authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1920"},"text":"section 1920 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2742704-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s113/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Service-Disabled Veterans Insurance Fund authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1922"},"text":"section 1922 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2742705-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s113/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Veterans Special Life Insurance Fund authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1923"},"text":"section 1923 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2742706-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s113/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Veterans Reopened Insurance Fund authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1925"},"text":"section 1925 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2742707-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s113/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Government Life Insurance Fund authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1955"},"text":"section 1955 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2742708-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s113/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Veterans Insurance and Indemnity appropriation authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1919"},"text":"section 1919 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2742709-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s113/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The following revolving fund accounts:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc274270a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s113/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Veterans Affairs Special Therapeutic and Rehabilitation Activities Fund established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1718/c"},"text":"section 1718(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc274270b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s113/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Veterans’ Canteen Service revolving fund authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7804"},"text":"section 7804 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc274270c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s113/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc274270d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s113/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A benefit under section 2301, 2303, 2306, or 2308 of this title that is subject to reduction under a sequestration order or sequestration law shall be paid in accordance with the rates determined under the sequestration order or law (if any) in effect on the date of the death of the veteran concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc274270e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s113/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A benefit paid to, or on behalf of, an eligible veteran for pursuit of a program of education or training under chapter 30, 31, 34, 35, or 36 of this title that is subject to a sequestration order or a sequestration law shall be paid in accordance with the rates determined under the sequestration order or law (if any) in effect during the period of education or training for which the benefit is paid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc274270f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s113/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In implementation of a sequestration order or law with respect to each account from which a benefit described in paragraph (1) or (2) of this subsection is paid (including the making of determinations of the amounts by which such benefits are to be reduced), the total of the amounts (as estimated by the Secretary after consultation with the Director of the Congressional Budget Office) by which payments of such benefit will be reduced by reason of such paragraph after the last day of the period during which such order or law is in effect shall be deemed to be additional reductions in the payments of such benefit made, and in new budget authority for such payments, during such period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2742710-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s113/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In computing the amount of new budget authority by which a budget account of the Department is to be reduced for a fiscal year under a report of the Director of the Office of Management and Budget, or under an order of the President under part C of the Balanced Budget and Emergency Deficit Control Act of 1985, the base from which the amount of the reduction for such account is determined shall be established without regard to any amount of new budget authority in such account (determined under section 251(a)(6) ","children":[{"tag":"ref","attrib":{"idref":"fn002005"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002005"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of such Act) for any of the programs listed in subsection (a) of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2742711-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s113/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section applies without regard to any other provision of law (whether enacted before, on, or after the date of the enactment of this section) unless such Act expressly provides that it is enacted as a limitation to this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2742712-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s113/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2742713-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s113/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “sequestration” means a reduction in spending authority and loan guarantee commitments generally throughout the Government under the Balanced Budget and Emergency Deficit Control Act of 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s901"},"text":"2 U.S.C. 901","children":[],"tail":" et seq.) or any other law."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2742714-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s113/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “sequestration law” means a law enacted with respect to a sequestration under the Balanced Budget and Emergency Deficit Control Act of 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s901"},"text":"2 U.S.C. 901","children":[],"tail":" et seq.) or any other law (under the procedures specified in that Act or otherwise)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2742715-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s113/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “sequestration order” means an order of the President issued under part C of such Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2742716-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576/tVI/s601/a/1"},"text":"Pub. L. 99–576, title VI, § 601(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3287"},"text":"100 Stat. 3287","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/198/s12/a"},"text":"Pub. L. 100–198, § 12(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-21"},"text":"Dec. 21, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1325"},"text":"101 Stat. 1325","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/322/tIV/s411/b"},"text":"Pub. L. 100–322, title IV, § 411(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"