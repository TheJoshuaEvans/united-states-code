l},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576/tVI/s601/b"},"text":"Pub. L. 99–576, title VI, § 601(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3289"},"text":"100 Stat. 3289","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/576/tVI/s601/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s113"},"text":"Section 113 of title 38","children":[],"tail":", United States Code (as added by subsection (a)), shall apply with respect to a sequestration order issued, or a sequestration law enacted, for a fiscal year after fiscal year 1986.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc274271f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Restoration of Certain Revolving Funds","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/322/tIV/s411/a"},"text":"Pub. L. 100–322, title IV, § 411(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/547"},"text":"102 Stat. 547","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/322/tIV/s411/a"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding section 601(b) of the Veterans’ Benefits Improvement and Health-Care Authorization Act of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576"},"text":"Public Law 99–576","children":[],"tail":") [set out as a note above], "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s113/b/2"},"text":"section 113(b)(2) of title 38","children":[],"tail":", United States Code, shall apply with respect to a sequestration order issued, or a sequestration law enacted, for any fiscal year after fiscal year 1985."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Treasury shall take such action as is necessary to implement paragraph (1). Not later than 60 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":"], the Secretary shall submit to the Committees on Veterans’ Affairs of the Senate and House of Representatives a report on the action taken by the Secretary pursuant to that paragraph.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
