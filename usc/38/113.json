hildren":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315"},"text":"Pub. L. 116–315","children":[],"tail":" struck out “2302,” after “section 2301,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “2307” for “907”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/3"},"text":"Pub. L. 102–83, § 4(a)(3)","children":[],"tail":", (4), substituted “Department” for “Veterans’ Administration” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “1920” for “720” in subpar. (A), “1922” for “722” in subpar. (B), “1923” for “723” in subpar. (C), “1925” for “725” in subpar. (D), “1955” for “755” in subpar. (E), and “1919” for “719” in subpar. (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “1718(c)” for “618(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/2/B/i"},"text":"Pub. L. 102–83, § 4(a)(2)(B)(i)","children":[],"tail":", substituted “Department of Veterans Affairs” for “Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" substituted “7804” for “4204”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “2301, 2302, 2303, 2306, or 2308” for “901, 902, 903, 906, or 908”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/3"},"text":"Pub. L. 102–83, § 4(a)(3)","children":[],"tail":", (4), substituted “Department” for “Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/322/s411/b"},"text":"Pub. L. 100–322, § 411(b)","children":[],"tail":", struck out “(but only with respect to fiscal year 1987)” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/322/s411/c"},"text":"Pub. L. 100–322, § 411(c)","children":[],"tail":", substituted “a report of the Director of the Office of Management and Budget” for “a joint report of the Directors of the Office of Management and Budget and the Congressional Budget Office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/198/s12/a/1"},"text":"Pub. L. 100–198, § 12(a)(1)","children":[],"tail":", added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/198/s12/a/3"},"text":"Pub. L. 100–198, § 12(a)(3)","children":[],"tail":", substituted “31, 34, 35, or 36” for “34, or 36”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e) to (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/198/s12/a/2"},"text":"Pub. L. 100–198, § 12(a)(2)","children":[],"tail":", redesignated subsecs. (f) and (g) as (e) and (f), respectively, and struck out former subsec. (e) which read as follows: “If a final order issued by the President pursuant to a law providing for the cancellation of loan guarantee commitments imposes a limitation on the total amount of loans that may be guaranteed under chapter 37 of this title in any fiscal year, the Administrator shall submit to the Committees on Veterans’ Affairs of the Senate and the House of Representatives a monthly report (not later than the 10th day of each month during the remainder of such fiscal year following the issuance of such final order) providing the following information:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) The total amount of the loans for which commitments of guarantees were made under such chapter during the preceding month.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) The total amount of the loans for which commitments were made during the fiscal year through the end of such preceding month.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) The Administrator’s estimates as to the total amounts of the loans for which commitments would, in the absence of any limits on such commitments or guarantees, be made during (A) the month in which the report is required to be submitted, and (B) the succeeding months of the fiscal year.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc274271b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc274271c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/tII/s2202/d"},"text":