{"tag":"section","attrib":{"id":"idc39268cb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3683"},"text":null,"children":[{"tag":"num","attrib":{"value":"3683"},"text":"§ 3683.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflicting interests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc39268cc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3683/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Department Officers and Employees","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc39268cd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3683/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An officer or employee of the Department shall receive corrective action or disciplinary action if such officer or employee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc39268ce-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3683/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has, while serving as such an officer or employee, owned any interest in, or received any wage, salary, dividend, profit, or gift from, any educational institution operated for profit; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc39268cf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3683/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has, while serving as a covered officer or employee of the Department, received any service from any educational institution operated for profit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc39268d0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3683/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this subsection, the term “covered officer or employee of the Department” means an officer or employee of the Department who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc39268d1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3683/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" works on the administration of benefits under chapter 30, 31, 32, 33, 34, 35, or 36 of this title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc39268d2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3683/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a potential conflict of interest involving an educational institution operated for profit, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc39268d3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3683/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State Approving Agency Employees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary finds that any person who is an officer or employee of a State approving agency has, while such person was such an officer or employee, owned any interest in, or received any wage, salary, dividend, profit, or gift from, an educational institution operated for profit, the Secretary shall discontinue making payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3674"},"text":"section 3674 of this title","children":[],"tail":" to such State approving agency unless such agency shall, without delay, take such steps as may be necessary to provide corrective action or disciplinary action with respect to such person and such payments shall not be resumed until the completion of such corrective action or disciplinary action."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc39268d4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3683/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disapproval of Courses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A State approving agency shall not approve any course offered by an educational institution operated for profit, and, if any such course has been approved, shall disapprove each such course, if it finds that any officer or employee of the Department or the State approving agency owns an interest in, or receives any wage, salary, dividend, profit, or gift from, such institution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc39268d5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3683/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver Authority","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc39268d6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3683/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may waive in writing the application of this section in the case of any officer or employee of the Department or of a State approving agency, if the Secretary finds that no detriment will result to the United States or to eligible persons or veterans by reasons of such interest or connection of such officer or employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc39268d7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3683/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall provide public notice of any waiver granted under this subsection by not later than 30 days after the date on which such waiver is granted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc39268d8-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/358/s3/b"},"text":"Pub. L. 89–358, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-03-03"},"text":"Mar. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/22"},"text":"80 Stat. 22","children":[],"tail":", § 1783; amended "},{"tag":"ref","attrib":{"href":"/us/pl/92/540/tIV/s403/10"},"text":"Pub. L. 92–540, title IV, § 403(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-24"},"text":"Oct. 24, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1090"},"text":"86 Stat. 1090","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/502/tV/s513/a/14"},"text":"Pub. L. 94–502, title V, § 513(a)(14)","children":[],"tail":"–(16), "},{"tag":"date","attrib":{"date":"1976-10-15"},"text":"Oct. 15, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2403"},"text":"90 Stat. 2403","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/295/s4/54"},"text":"Pub. L. 97–295, § 4(54)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1309"},"text":"96 Stat. 1309","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIV/s423/b/1"},"text":"Pub. L. 101–237, title IV, § 423(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2092"},"text":"103 Stat. 2092","children":[],"tail":"; renumbered § 3683 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/251/tIII/s302/a"},"text":"Pub. L. 115–251, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-29"},"text":"Sept. 29, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3178"},"text":"132 Stat. 3178","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/61/s6/5"},"text":"Pub. L. 116–61, § 6(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-09-30"},"text":"Sept. 30, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1117"},"text":"133 Stat. 1117","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc39268d9-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc39268da-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc39268db-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those comprising this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1190"},"text":"72 Stat. 1190","children":[],"tail":", 1201, which was classified to former sections 1664 and 1764 of this title, prior to repeal by sections 4(a) and 3(a)(3) of "},{"tag":"ref","attrib":{"href":"/us/pl/89/358"},"text":"Pub. L. 89–358","children":[],"tail":", respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc39268dc-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/61"},"text":"Pub. L. 116–61","children":[],"tail":" substituted “(b)” for “(b) (b)”, “(c)” for “(c) (c)”, and “(d)” for “(d) (d)” in subsec. designations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/251/s302/a/1"},"text":"Pub. L. 115–251, § 302(a)(1)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a) which read as follows: “Every officer or employee of the Department of Veterans Affairs who has, while such an officer or employee, owned any interest in, or received any wages, salary, dividends, profits, gratuities, or services from, any educational institution operated for profit in which an eligible person or veteran was pursuing a program of education or course under this chapter or chapter 34 or 35 of this title shall be immediately dismissed from such officer’s or employee’s office or employment.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/251/s302/a/2"},"text":"Pub. L. 115–251, § 302(a)(2)","children":[],"tail":", inserted second subsec. (b) designation and heading, substituted “wage, salary, dividend, profit, or gift” for “wages, salary, dividends, profits, gratuities, or services”, “provide corrective action or disciplinary action with respect to” for “terminate the employment of”, and “until the completion of such corrective action or disciplinary action” for “while such person is an officer or employee of the State approving agency, or State department of veterans’ affairs or State department of education”, and struck out “in which an eligible person or veteran was pursuing a program of education or course under this chapter or chapter 34 or 35 of this title” after “operated for profit”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/251/s302/a/3"},"text":"Pub. L. 115–251, § 302(a)(3)","children":[],"tail":", inserted second subsec. (c) designation and heading, struck out “of Veterans Affairs” after “of the Department”, and substituted “wage, salary, dividend, profit, or gift” for “wages, salary, dividends, profits, gratuities, or services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/251/s302/a/4"},"text":"Pub. L. 115–251, § 302(a)(4)","children":[],"tail":", inserted second subsec. (d) designation and heading, designated existing provisions as par. (1), struck out “, after reasonable notice and public hearings,” after “The Secretary may” and “of Veterans Affairs” after “of the Department”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1783"},"text":"section 1783 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “3674” for “1774”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" substituted “Secretary” and “Department of Veterans Affairs” for “Administrator” and “Veterans’ Administration”, respectively, wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295"},"text":"Pub. L. 97–295","children":[],"tail":" inserted “of this title” after “34 or 35”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/502/s513/a/14"},"text":"Pub. L. 94–502, § 513(a)(14)","children":[],"tail":", substituted “such officer’s or employee’s” for “his”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/502/s513/a/15"},"text":"Pub. L. 94–502, § 513(a)(15)","children":[],"tail":", substituted “while such person was” for “while he was” and “the Administrator shall discontinue” for “he shall discontinue”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/502/s513/a/16"},"text":"Pub. L. 94–502, § 513(a)(16)","children":[],"tail":", substituted “if the Administrator finds” for “if he finds”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/540"},"text":"Pub. L. 92–540","children":[],"tail":" inserted “this chapter or” before “chapter 34 or 35” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc394b1cd-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc394b1ce-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/251/tIII/s302/b"},"text":"Pub. L. 115–251, title III, § 302(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-29"},"text":"Sept. 29, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3179"},"text":"132 Stat. 3179","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/251/tIII/s302/b"},"text":"“The amendments made by subsection (a) [amending this section] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-09-29"},"text":"Sept. 29, 2018","children":[],"tail":"] and shall apply with respect to conflicts of interest that occur on or after that date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc394b1cf-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/502"},"text":"Pub. L. 94–502","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1976-10-15"},"text":"Oct. 15, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/502/s703/b"},"text":"section 703(b) of Pub. L. 94–502","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3693"},"text":"section 3693 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
