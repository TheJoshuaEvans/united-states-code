attrib":{"href":"/us/stat/96/1445"},"text":"96 Stat. 1445","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/306/tIV/s407/b"},"text":"“The amendments made by subsection (a) [amending this section] shall apply only with respect to notifications of indebtedness that are made by the Administrator of Veterans’ Affairs after ","children":[{"tag":"date","attrib":{"date":"1983-03-31"},"text":"March 31, 1983","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3d5163b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466"},"text":"Pub. L. 96–466","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-10-01"},"text":"Oct. 1, 1980","children":[],"tail":", except as otherwise specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/96/466/s802/f"},"text":"section 802(f) of Pub. L. 96–466","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5314"},"text":"section 5314 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3d5163c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1972 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/328"},"text":"Pub. L. 92–328","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1972-06-30"},"text":"June 30, 1972","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/92/328/s301/c"},"text":"section 301(c) of Pub. L. 92–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3713"},"text":"section 3713 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3d5163d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Applicability of Waiver Authority to Improper Payments, Overpayments, and Indebtedness Established by the Administrator Prior to Effective Date of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/328"},"text":"Pub. L. 92–328","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/92/328/tII/s202/b"},"text":"Pub. L. 92–328, title II, § 202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-30"},"text":"June 30, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/397"},"text":"86 Stat. 397","children":[],"tail":", provided that the waiver authority under subsec. (a) of this section is applicable to improper payments, overpayments, and indebtedness established by the Administrator prior to the effective date of "},{"tag":"ref","attrib":{"href":"/us/pl/92/328"},"text":"Pub. L. 92–328","children":[],"tail":" if application for relief was pending on "},{"tag":"date","attrib":{"date":"1972-06-30"},"text":"June 30, 1972","children":[],"tail":", or such an application was made within two years from "},{"tag":"date","attrib":{"date":"1972-06-30"},"text":"June 30, 1972","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For effective date of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/328"},"text":"Pub. L. 92–328","children":[],"tail":", see Effective Date of 1972 Amendment notes set out under sections 1114, 1134, and 3713 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
