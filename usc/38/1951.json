{"tag":"section","attrib":{"id":"idc31fd016-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1951"},"text":null,"children":[{"tag":"num","attrib":{"value":"1951"},"text":"§ 1951.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of insurance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"United States Government life insurance, except as provided in this subchapter, shall be payable in two hundred and forty equal monthly installments. When the amount of an individual monthly payment is less than $5, such amount may in the discretion of the Secretary be allowed to accumulate without interest and be disbursed annually.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc31fd017-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1161"},"text":"72 Stat. 1161","children":[],"tail":", § 751; renumbered § 1951 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":", §§ 4(b)(1), (2)(E), 5(a), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404-406"},"text":"105 Stat. 404–406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc31fd018-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc31fd019-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc31fd01a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s751"},"text":"section 751 of this title","children":[],"tail":" as this section and substituted “Secretary” for “Administrator”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
