{"tag":"section","attrib":{"id":"idc41a35f2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7807"},"text":null,"children":[{"tag":"num","attrib":{"value":"7807"},"text":"§ 7807.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit of accounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Service shall maintain a set of accounts which shall be audited by the Comptroller General in accordance with the provisions of chapter 35 of title 31.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc41a35f3-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1250"},"text":"72 Stat. 1250","children":[],"tail":", § 4207; "},{"tag":"ref","attrib":{"href":"/us/pl/93/604/tVII/s704"},"text":"Pub. L. 93–604, title VII, § 704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-02"},"text":"Jan. 2, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1964"},"text":"88 Stat. 1964","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/295/s4/89"},"text":"Pub. L. 97–295, § 4(89)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1312"},"text":"96 Stat. 1312","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/452/s2/e/3"},"text":"Pub. L. 97–452, § 2(e)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2479"},"text":"96 Stat. 2479","children":[],"tail":"; renumbered § 7807 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/a"},"text":"Pub. L. 102–40, title IV, § 402(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc41a35f4-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc41a35f5-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc41a35f6-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4207"},"text":"section 4207 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/452"},"text":"Pub. L. 97–452","children":[],"tail":" substituted “chapter 35 of title 31” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3523"},"text":"section 3523 of title 31","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295"},"text":"Pub. L. 97–295","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3523"},"text":"section 3523 of title 31","children":[],"tail":"” for “the Accounting and Auditing Act of 1950”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/604"},"text":"Pub. L. 93–604","children":[],"tail":" substituted provisions that the Service maintain a set of accounts which shall be audited by the Comptroller General in accordance with the provisions of the Accounting and Auditing Act of 1950 for provisions that the Service maintain an integral set of accounts which shall be audited annually by the General Accounting Office in accordance with the principles and procedures applicable to commercial transactions as provided by sections 841–869 of Title 31 and that no other audit shall be required."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
