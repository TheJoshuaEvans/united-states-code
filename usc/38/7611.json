{"tag":"section","attrib":{"id":"idc4130a64-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7611"},"text":null,"children":[{"tag":"num","attrib":{"value":"7611"},"text":"§ 7611.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority for program","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As part of the Educational Assistance Program, the Secretary shall carry out a scholarship program under this subchapter. The program shall be known as the Department of Veterans Affairs Health Professional Scholarship Program (hereinafter in this chapter referred to as the “Scholarship Program”).","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc4130a65-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/322/tII/s216/b"},"text":"Pub. L. 100–322, title II, § 216(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/520"},"text":"102 Stat. 520","children":[],"tail":", § 4311; renumbered § 7611, "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/2/B/vi"},"text":"Pub. L. 102–83, § 4(a)(2)(B)(vi)","children":[],"tail":", (b)(1), (2)(E), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/403-405"},"text":"105 Stat. 403–405","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc4130a66-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc4130a67-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc4130a68-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4311"},"text":"section 4311 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" substituted “Secretary” for “Administrator” and “Department of Veterans Affairs” for “Veterans’ Administration”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc4130a69-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc4130a6a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Expansion of Health Professional Scholarship Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dV/tI/s104/a"},"text":"Pub. L. 117–328, div. V, title I, § 104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5500"},"text":"136 Stat. 5500","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dV/tI/s104/a"},"text":"“Beginning in academic year 2022, the Secretary of Veterans Affairs shall include not fewer than an additional (as compared to academic year 2021) 50 awards per academic year under the Department of Veterans Affairs Health Professional Scholarship Program under subchapter II of chapter 76 of title 38, United States Code, for applicants otherwise eligible for such program who are pursuing degrees or training in mental health disciplines, including advanced practice nursing (with a focus on mental health or substance use disorder), psychology, and social work.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc4130a6b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Submission of Overdue Report","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/114/tII/s207/b"},"text":"Pub. L. 105–114, title II, § 207(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2289"},"text":"111 Stat. 2289","children":[],"tail":", required the Secretary of Veterans Affairs to submit to Congress, not later than 180 days after "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", the report evaluating the operation of the health professional scholarship program that was required to be submitted not later than "},{"tag":"date","attrib":{"date":"1997-03-31"},"text":"Mar. 31, 1997","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc4130a6c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Health Professional Scholarship Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/110/tII/s202/b"},"text":"Pub. L. 104–110, title II, § 202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-13"},"text":"Feb. 13, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/770"},"text":"110 Stat. 770","children":[],"tail":", provided that the Secretary was to submit to Congress, not later than "},{"tag":"date","attrib":{"date":"1997-03-31"},"text":"Mar. 31, 1997","children":[],"tail":", a report setting forth the results of a study evaluating the operation of the health professional scholarship program under this subchapter and provided that the study was to evaluate the efficacy of the program with respect to recruitment and retention of health care personnel for the Department of Veterans Affairs and was to compare the costs and benefits of the program with the costs and benefits of alternative methods of ensuring adequate recruitment and retention of such personnel."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
