{"tag":"section","attrib":{"id":"idc30cbd53-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1730A"},"text":null,"children":[{"tag":"num","attrib":{"value":"1730A"},"text":"§ 1730A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on collection of copayments from certain veterans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc30cbd54-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1730A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subsections (f) and (g) of section 1710 and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1722A/a"},"text":"section 1722A(a) of this title","children":[],"tail":" or any other provision of law, the Secretary may not require a covered veteran to make any copayment for the receipt of hospital care or medical services under the laws administered by the Secretary."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc30cbd55-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1730A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Veteran Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “covered veteran” means a veteran who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc30cbd56-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1730A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is catastrophically disabled, as defined by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30cbd57-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1730A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an Indian or urban Indian (as those terms are defined in section 4 of the Indian Health Care Improvement Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1603"},"text":"25 U.S.C. 1603","children":[],"tail":"))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc30cbd58-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163/tV/s511/a"},"text":"Pub. L. 111–163, title V, § 511(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-05-05"},"text":"May 5, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1164"},"text":"124 Stat. 1164","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/315/tIII/s3002/a"},"text":"Pub. L. 116–315, title III, § 3002(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4990"},"text":"134 Stat. 4990","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc30cbd59-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc30cbd5a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc30cbd5b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315"},"text":"Pub. L. 116–315","children":[],"tail":" substituted “certain” for “catastrophically disabled” in section catchline, designated existing provisions as subsec. (a) and inserted heading, substituted “a covered veteran” for “a veteran who is catastrophically disabled, as defined by the Secretary,”, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc30cbd5c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc30cbd5d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/tIII/s3002/c"},"text":"Pub. L. 116–315, title III, § 3002(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4991"},"text":"134 Stat. 4991","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/315/tIII/s3002/c"},"text":"“The amendments made by this section [amending this section] shall take effect on the day that is one year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
