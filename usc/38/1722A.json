. 114–223","children":[],"tail":" amended subsec. (a) identically, adding par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (a)(3)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/170"},"text":"Pub. L. 108–170","children":[],"tail":" added subpar. (B) and redesignated former subpar. (B) as (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/s113/c/1"},"text":"Pub. L. 108–7, § 113(c)(1)","children":[],"tail":", substituted “under this section” for “under subsection (a)” in first sentence and struck out second sentence which read as follows: “Amounts collected through use of the authority under subsection (b) shall be deposited in the Department of Veterans Affairs Health Services Improvement Fund.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/s113/c/2"},"text":"Pub. L. 108–7, § 113(c)(2)","children":[],"tail":", struck out subsec. (d) which read as follows: “The provisions of subsection (a) expire on "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"September 30, 2002","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117/s201/a/1"},"text":"Pub. L. 106–117, § 201(a)(1)","children":[],"tail":", (2), added subsec. (b). Former subsec. (b) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117/s201/a/1"},"text":"Pub. L. 106–117, § 201(a)(1)","children":[],"tail":", (3), redesignated subsec. (b) as (c), substituted “subsection (a)” for “this section”, and inserted at end “Amounts collected through use of the authority under subsection (b) shall be deposited in the Department of Veterans Affairs Health Services Improvement Fund.” Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Su