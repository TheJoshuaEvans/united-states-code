{"tag":"section","attrib":{"id":"idc30801f9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1722A"},"text":null,"children":[{"tag":"num","attrib":{"value":"1722A"},"text":"§ 1722A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Copayment for medications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc30801fa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1722A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc30801fb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1722A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2), the Secretary shall require a veteran to pay the United States $2 for each 30-day supply of medication furnished such veteran under this chapter on an outpatient basis for the treatment of a non-service-connected disability or condition. If the amount supplied is less than a 30-day supply, the amount of the charge may not be reduced.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30801fc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1722A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not require a veteran to pay an amount in excess of the cost to the Secretary for medication described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30801fd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1722A/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Paragraph (1) does not apply—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc30801fe-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1722A/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a veteran with a service-connected disability rated 50 percent or more;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc30801ff-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1722A/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a veteran who is a former prisoner of war;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3080200-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1722A/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a veteran whose annual income (as determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1503"},"text":"section 1503 of this title","children":[],"tail":") does not exceed the maximum annual rate of pension which would be payable to such veteran if such veteran were eligible for pension under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1521"},"text":"section 1521 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3080201-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1722A/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a veteran who was awarded the medal of honor under section 7271, 8291, or 9271 of title 10 or section 491 ","children":[{"tag":"ref","attrib":{"idref":"fn002037"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002037"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 14."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3080202-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1722A/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (1) does not apply to opioid antagonists furnished under this chapter to a veteran who is at high risk for overdose of a specific medication or substance in order to reverse the effect of such an overdose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3080203-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1722A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary, pursuant to regulations which the Secretary shall prescribe, may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3080204-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1722A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the copayment amount in effect under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3080205-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1722A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a maximum monthly and a maximum annual pharmaceutical copayment amount under subsection (a) for veterans who have multiple outpatient prescriptions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3080206-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1722A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts collected under this section shall be deposited in the Department of Veterans Affairs Medical Care Collections Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3080207-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/tVIII/s8012/a/1"},"text":"Pub. L. 101–508, title VIII, § 8012(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-345"},"text":"104 Stat. 1388–345","children":[],"tail":", § 622A; renumbered § 1722A, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/139/tV/s518/a"},"text":"Pub. L. 102–139, title V, § 518(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/779"},"text":"105 Stat. 779","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/229/tI"},"text":"Pub. L. 102–229, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-12"},"text":"Dec. 12, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1709"},"text":"105 Stat. 1709","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/568/tVI"},"text":"Pub. L. 102–568, title VI","children":[],"tail":", §§ 605(a), 606(a), "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4343"},"text":"106 Stat. 4343","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/