{"tag":"section","attrib":{"id":"idc4157a9b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7614"},"text":null,"children":[{"tag":"num","attrib":{"value":"7614"},"text":"§ 7614.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Part-time students","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In the case of a participant who is a part-time student—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4157a9c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7614/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maximum amount of the stipend payable to the participant shall be reduced in accordance with the proportion that the number of credit hours carried by such participant bears to the number of credit hours required to be carried by a full-time student in the course of education or training being pursued by the participant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4157a9d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7614/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a stipend may not be paid for any month during which the participant is not actually attending the course of training in which the participant is enrolled; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4157a9e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7614/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary may extend the period for which a scholarship may be awarded to the participant to a maximum of six school years if the Secretary determines that the extension would be in the best interest of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc4157a9f-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/322/tII/s216/b"},"text":"Pub. L. 100–322, title II, § 216(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/522"},"text":"102 Stat. 522","children":[],"tail":", § 4314; renumbered § 7614, "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404"},"text":"105 Stat. 404","children":[],"tail":", 405.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc4157aa0-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc4157aa1-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc4157aa2-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4314"},"text":"section 4314 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" substituted “Secretary” for “Administrator” in two places."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
