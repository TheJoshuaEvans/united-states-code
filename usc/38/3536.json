{"tag":"section","attrib":{"id":"idc37ce465-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3536"},"text":null,"children":[{"tag":"num","attrib":{"value":"3536"},"text":"§ 3536.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specialized vocational training courses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may approve a specialized course of vocational training leading to a predetermined vocational objective for the enrollment of an eligible person under this subchapter if the Secretary finds that such course, either alone or when combined with other courses, constitutes a program of education which is suitable for that person and is required because of a mental or physical handicap.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc37ce466-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1199"},"text":"72 Stat. 1199","children":[],"tail":", § 1737; "},{"tag":"ref","attrib":{"href":"/us/pl/88/126/s4"},"text":"Pub. L. 88–126, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-09-23"},"text":"Sept. 23, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/162"},"text":"77 Stat. 162","children":[],"tail":"; renumbered § 1736, "},{"tag":"ref","attrib":{"href":"/us/pl/92/540/tIV/s402/3"},"text":"Pub. L. 92–540, title IV, § 402(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-24"},"text":"Oct. 24, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1090"},"text":"86 Stat. 1090","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/502/tIII/s310/20"},"text":"Pub. L. 94–502, title III, § 310(20)","ch