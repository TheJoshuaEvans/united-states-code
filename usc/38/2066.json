{"tag":"section","attrib":{"id":"idc337c568-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066"},"text":null,"children":[{"tag":"num","attrib":{"value":"2066"},"text":"§ 2066.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Committee on Homeless Veterans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc337c569-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc337c56a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is established in the Department the Advisory Committee on Homeless Veterans (hereinafter in this section referred to as the “Committee”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc337c56b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Committee shall consist of not more than 15 members appointed by the Secretary from among the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc337c56c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Veterans service organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c56d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advocates of homeless veterans and other homeless individuals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c56e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Community-based providers of services to homeless individuals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c56f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Previously homeless veterans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c570-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State veterans affairs officials.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c571-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Experts in the treatment of individuals with mental illness.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c572-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Experts in the treatment of substance use disorders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c573-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Experts in the development of permanent housing alternatives for lower income populations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c574-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/a/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Experts in vocational rehabilitation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c575-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/a/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other organizations or groups as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc337c576-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Committee shall include, as ex officio members, the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc337c577-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Labor (or a representative of the Secretary selected after consultation with the Assistant Secretary of Labor for Veterans’ Employment).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c578-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense (or a representative of the Secretary).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c579-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Health and Human Services (or a representative of the Secretary).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c57a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Housing and Urban Development (or a representative of the Secretary).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c57b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Executive Director of the Interagency Council on Homelessness (or a representative of the Executive Director).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c57c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary for Health (or a representative of the Under Secretary after consultation with the Director of the Office of Homeless Veterans Programs).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c57d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/a/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary for Benefits (or a representative of the Under Secretary after consultation with the Director of the Office of Homeless Veterans Programs).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc337c57e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc337c57f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall determine the terms of service and allowances of the members of the Committee, except that a term of service may not exceed three years. The Secretary may reappoint any member for additional terms of service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c580-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Committee shall serve without pay. Members may receive travel expenses, including per diem in lieu of subsistence for travel in connection with their duties as members of the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc337c581-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc337c582-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall consult with and seek the advice of the Committee on a regular basis with respect to the provision by the Department of benefits and services to homeless veterans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc337c583-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In providing advice to the Secretary under this subsection, the Committee shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc337c584-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assemble and review information relating to the needs of homeless veterans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c585-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an on-going assessment of the effectiveness of the policies, organizational structures, and services of the Department in assisting homeless veterans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c586-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide on-going advice on the most appropriate means of providing assistance to homeless veterans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc337c587-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Committee shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc337c588-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the continuum of services provided by the Department directly or by contract in order to define cross-cutting issues and to improve coordination of all services with the Department that are involved in addressing the special needs of homeless veterans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c589-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify (through the annual assessments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2034"},"text":"section 2034 of this title","children":[],"tail":" and other available resources) gaps in programs of the Department in serving homeless veterans, including identification of geographic areas with unmet needs, and provide recommendations to address those gaps;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c58a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify gaps in existing information systems on homeless veterans, both within and outside the Department, and provide recommendations about redressing problems in data collection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c58b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify barriers under existing laws and policies to effective coordination by the Department with other Federal agencies and with State and local agencies addressing homeless populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c58c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify opportunities for increased liaison by the Department with nongovernmental organizations and individual groups providing services to homeless populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c58d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with appropriate officials of the Department designated by the Secretary, participate with the Interagency Council on the Homeless under title II of the McKinney-Vento Homeless Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11311"},"text":"42 U.S.C. 11311","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c58e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/b/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend appropriate funding levels for specialized programs for homeless veterans provided or funded by the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c58f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/b/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend appropriate placement options for veterans who, because of advanced age, frailty, or severe mental illness, may not be appropriate candidates for vocational rehabilitation or independent living; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c590-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/b/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform such other functions as the Secretary may direct.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc337c591-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc337c592-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than March 31 of each year, the Committee shall submit to the Secretary a report on the programs and activities of the Department that relate to homeless veterans. Each such report shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc337c593-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the needs of homeless veterans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c594-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of the programs and activities of the Department designed to meet such needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c595-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of the activities of the Committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c596-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such recommendations (including recommendations for administrative and legislative action) as the Committee considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc337c597-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 90 days after the receipt of a report under paragraph (1), the Secretary shall transmit to the Committees on Veterans’ Affairs of the Senate and House of Representatives a copy of the report, together with any comments and recommendations concerning the report that the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc337c598-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee may also submit to the Secretary such other reports and recommendations as the Committee considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc337c599-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall submit with each annual report submitted to the Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s529"},"text":"section 529 of this title","children":[],"tail":" a summary of all reports and recommendations of the Committee submitted to the Secretary since the previous annual report of the Secretary submitted pursuant to that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc337c59a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2066/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee shall cease to exist ","children":[{"tag":"date","attrib":{"date":"2026-09-30"},"text":"September 30, 2026","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc337c59b-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/95/s5/a/1"},"text":"Pub. L. 107–95, § 5(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-21"},"text":"Dec. 21, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/916"},"text":"115 Stat. 916","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/444/s2/e"},"text":"Pub.