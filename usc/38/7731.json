{"tag":"section","attrib":{"id":"idc41a3582-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7731"},"text":null,"children":[{"tag":"num","attrib":{"value":"7731"},"text":"§ 7731.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc41a3583-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7731/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall carry out a quality assurance program in the Veterans Benefits Administration. The program may be carried out through a single quality assurance division in the Administration or through separate quality assurance entities for each of the principal organizational elements (known as “services”) of the Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc41a3584-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7731/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall ensure that any quality assurance entity established and operated under subsection (a) is established and operated so as to meet generally applicable governmental standards for independence and internal controls for the performance of quality reviews of Government performance and results.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc41a3585-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7731/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc41a3586-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7731/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall enter into a contract with an independent third-party entity to conduct, during the three-year period beginning on the date of the enactment of the Veterans’ Benefits Improvement Act of 2008, an assessment of the quality assurance program carried out under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc41a3587-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7731/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The assessment conducted under paragraph (1) shall evaluate the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc41a3588-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7731/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The quality and accuracy of the work of employees of the Veterans Benefits Administration, using a statistically valid sample of such employees and a statistically valid sample of such work.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc41a3589-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7731/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The performance of each regional office of the Veterans Benefits Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc41a358a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7731/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The accuracy of the disability ratings assigned under the schedule for rating disabilities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1155"},"text":"section 1155 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc41a358b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7731/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The consistency of disability ratings among regional offices of the Veterans Benefits Administration, based on a sample of specific disabilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc41a358c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7731/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The performance of employees and managers of the Veterans Benefits Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc41a358d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7731/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall develop a mechanism for the automated gathering and producing of data that can be used to monitor and assess trends relating to the items described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc41a358e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7731/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc41a358f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7731/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Beginning on the date that is six months after the date of the enactment of the Veterans’ Benefits Improvement Act of 2008, the Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc41a3590-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7731/c/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each claim for disability compensation under laws administered by the Secretary submitted to the Secretary on or after such date, retain, monitor, and store in an accessible format the data described in subparagraph (B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc41a3591-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7731/c/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a demographic baseline for the data retained, monitored, and stored under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc41a3592-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7731/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The data described in this subparagraph includes the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc41a3593-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7731/c/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For each claim for disability compensation under laws administered by the Secretary submitted by a claimant—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc41a3594-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7731/c/4/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State in which the claimant resided when the claim was submitted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc41a3595-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7731/c/4/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the decision of the Secretary with respect to the claim and each issue claimed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc41a3596-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7731/c/4/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the regional office and individual employee of the Department responsible for rating the claim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc41a3597-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7731/c/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The State in which the claimant currently resides.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc41a3598-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7731/c/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other data as the Secretary determines is appropriate for monitoring the accuracy and consistency of decisions with respect to such claims.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc41a3599-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7731/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this subsection shall be construed to require the Secretary to replace the quality assurance program under subsection (a) that was in effect on the day before the date of the enactment of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc41a359a-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117/s801/a/1"},"text":"Pub. L. 106–117, § 801(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-30"},"text":"Nov. 30, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1585"},"text":"113 Stat. 1585","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/389/tII/s224/a"},"text":"Pub. L. 110–389, title II, § 224(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4157"},"text":"122 Stat. 4157","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc41a359b-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc41a359c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc41a359d-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the Veterans’ Benefits Improvement Act of 2008 and the date of the enactment of this subsection, referred to in subsec. (c)(1), (4)(A), (5), mean the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/389"},"text":"Pub. L. 110–389","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc41a359e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/389"},"text":"Pub. L. 110–389","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc41a359f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc41a35a0-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117/tVIII/s801/b"},"text":"Pub. L. 106–117, title VIII, § 801(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-30"},"text":"Nov. 30, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1586"},"text":"113 Stat. 1586","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/117/tVIII/s801/b"},"text":"“Subchapter III [now Subchapter II] of chapter 77 of title 38, United States Code, as added by subsection (a), shall take effect at the end of the 60-day period beginning on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1999-11-30"},"text":"Nov. 30, 1999","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
