{"tag":"section","attrib":{"id":"idc3f41008-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7306"},"text":null,"children":[{"tag":"num","attrib":{"value":"7306"},"text":"§ 7306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of the Under Secretary for Health","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3f41009-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Office of the Under Secretary for Health shall consist of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3f4100a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7306/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Deputy Under Secretary for Health, who shall be the principal assistant of the Under Secretary for Health and who shall be a qualified doctor of medicine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f4100b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7306/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Associate Deputy Under Secretary for Health, who shall be an assistant to the Under Secretary for Health and the Deputy Under Secretary for Health and who shall be a qualified doctor of medicine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f4100c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7306/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not to exceed eight Assistant Under Secretaries for Health.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f4100d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7306/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such Medical Directors as may be appointed to suit the needs of the Department, who shall be either a qualified doctor of medicine or a qualified doctor of dental surgery or dental medicine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f4100e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7306/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Director of Nursing Service, who shall be a qualified registered nurse and who shall be responsible to, and report directly to, the Under Secretary for Health for the operation of the Nursing Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f4100f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7306/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Director of Pharmacy Service, a Director of Dietetic Service, and a Director of Optometric Service, who shall be responsible to the Under Secretary for Health for the operation of their respective Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f41010-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7306/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such directors of such other professional or auxiliary services as may be appointed to suit the needs of the Department, who shall be responsible to the Under Secretary for Health for the operation of their respective services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f41011-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7306/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the National Center for Preventive Health, who shall be responsible to the Under Secretary for Health for the operation of the Center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f41012-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7306/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Director of Physician Assistant Services, who shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3f41013-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7306/a/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve in a full-time capacity at the Central Office of the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3f41014-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7306/a/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a qualified physician assistant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3f41015-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7306/a/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be responsible and report directly to the Chief Patient Care Services Officer of the Veterans Health Administration on all matters relating to the education and training, employment, appropriate use, and optimal participation of physician assistants within the programs and initiatives of the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f41016-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7306/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Podiatric Medical Director, who shall be a qualified doctor of podiatric medicine and who shall be responsible to the Under Secretary for Health for the operation of the Podiatric Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f41017-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7306/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief Officer of Women’s Health.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f41018-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7306/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other personnel as may be authorized by this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3f41019-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Appointments under subsection (a) shall be made by the Secretary. In the case of appointments under paragraphs (1), (2), (3), (4), (8), and (10) of that subsection, such appointments shall be made upon the recommendation of the Under Secretary for Health.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3f4101a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7306/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subsection (d)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3f4101b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7306/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any appointment under this section shall be for a period of four years, with reappointment permissible for successive like periods,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f4101c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7306/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any such appointment or reappointment may be extended by the Secretary for a period not in excess of three years, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f4101d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7306/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person so appointed or reappointed or whose appointment or reappointment is extended shall be subject to removal by the Secretary for cause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3f4101e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7306/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3f4101f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7306/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may designate a member of the Chaplain Service of the Department as Director, Chaplain Service, for a period of two years, subject to removal by the Secretary for cause. Redesignation under this subsection may be made for successive like periods or for any period not exceeding two years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f41020-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7306/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person designated as Director, Chaplain Service, shall at the end of such person’s period of service as Director revert to the position, grade, and status which such person held immediately before being designated Director, Chaplain Service, and all service as Director, Chaplain Service, shall be creditable as service in the former position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3f41021-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7306/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In organizing the Office and appointing persons to positions in the Office, the Under Secretary shall ensure that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3f41022-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7306/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Office is staffed so as to provide the Under Secretary, through a designated clinician in the appropriate discipline in each instance, with expertise and direct policy guidance on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3f41023-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7306/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unique programs operated by the Administration to provide for the specialized treatment and rehabilitation of disabled veterans (including blind rehabilitation, care of spinal cord dysfunction, mental illness, and long-term care); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3f41024-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7306/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the programs established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1712A"},"text":"section 1712A of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f41025-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7306/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the programs established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1712A"},"text":"section 1712A of this title","children":[],"tail":", a clinician with appropriate expertise in those programs is responsible to the Under Secretary for the management of those programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3f41026-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7306/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of applying any provision of chapter 74 of this title, including sections 7404, 7410, and 7421, or any other provision of law, the Secretary may treat any appointment for a position under this chapter to be an appointment under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3f41027-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s401/a/3"},"text":"Pub. L. 102–40, title IV, § 401(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/212"},"text":"105 Stat. 212","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/405/tII/s205"},"text":"Pub. L. 102–405, title II, § 205","children":[],"tail":", title III, § 302(c)(1), "},{"tag":"date","attrib":{"date":"1992-10-09"},"text":"Oct. 9, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1983"},"text":"106 Stat. 1983","children":[],"tail":", 1984; "},{"tag":"ref","attrib":{"href":"/us/pl/102/585/tV/s511/b"},"text":"Pub. L. 102–585, title V, § 511(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4956"},"text":"106 Stat. 4956","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/446/tXII/s1201/c/3"},"text":"Pub. L. 103–446, title XII, § 1201(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4683"},"text":"108 Stat. 4683","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/262/tIII/s344"},"text":"Pub. L. 104–262, title III, § 344","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3207"},"text":"110 Stat. 3207","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/419/tII/s206"},"text":"Pub. L. 106–419, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1842"},"text":"114 Stat. 1842","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/135/tI/s131"},"text":"Pub. L. 107–135, title I, § 131","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-23"},"text":"Jan. 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2454"},"text":"115 Stat. 2454","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/163/tV/s514/a"},"text":"Pub. L. 111–163, title V, § 514(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-05-05"},"text":"May 5, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1165"},"text":"124 Stat. 1165","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/315/tV/s5101/a"},"text":"Pub. L. 116–315, title V, § 5101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/5022"},"text":"134 Stat. 5022","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/96/s1/a"},"text":"Pub. L. 117–96, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-14"},"text":"Mar. 14, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/34"},"text":"136 Stat. 34","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/168/tIX/s906/d"},"text":"Pub. L. 117–168, title IX, § 906(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-10"},"text":"Aug. 10, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1813"},"text":"136 Stat. 1813","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/210/tI/s141"},"text":"Pub. L. 118–210, title I, § 141","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-02"},"text":"Jan. 2, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2744"},"text":"138 Stat. 2744","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3f41028-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3f41029-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3f4102a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/210"},"text":"Pub. L. 118–210","children":[],"tail":" redesignated subsecs. (c) to (g) as (b) to (f), respectively, substituted “subsection (d)” for “subsection (e)” in introductory provisions of subsec. (c), and struck out former subsec. (b) which related to the Assistant Under Secretaries for Health appointed under subsec. (a)(3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/96/s1/a/1/A"},"text":"Pub. L. 117–96, § 1(a)(1)(A)","children":[],"tail":", struck out “a Director of Podiatric Service,” after “a Director of Dietetic Service,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(10), (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/96/s1/a/1/B"},"text":"Pub. L. 117–96, § 1(a)(1)(B)","children":[],"tail":", (C), added par. (10) and redesignated former par. (10), relating to Chief Officer of Women’s Health, as (11). Another par. (11), relating to such other personnel as may be authorized by this chapter, subsequently redesignated (12)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/168/s906/d/1"},"text":"Pub. L. 117–168, § 906(d)(1)","children":[],"tail":", redesignated par. (11) relating to such other personnel as may be authorized by this chapter as (12)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/96/s1/a/2"},"text":"Pub. L. 117–96, § 1(a)(2)","children":[],"tail":", inserted “podiatric medicine,” after “doctors of medicine,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/96/s1/a/3"},"text":"Pub. L. 117–96, § 1(a)(3)","children":[],"tail":", substituted “(8), and (10)” for “and (8)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/168/s906/d/2"},"text":"Pub. L. 117–168, § 906(d)(2)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(10), (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315"},"text":"Pub. L. 116–315","children":[],"tail":" added par. (10) and redesignated former par. (10) as (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163"},"text":"Pub. L. 111–163","children":[],"tail":" added par. (9) and struck out former par. (9) which read as follows: “The Advisor on Physician Assistants, who shall be a physician assistant with appropriate experience and who shall advise the Under Secretary for Health on all matters relating to the utilization and employment of physician assistants in the Administration.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/135"},"text":"Pub. L. 107–135","children":[],"tail":" inserted “, and report directly to,” after “responsible to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(9), (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/419"},"text":"Pub. L. 106–419","children":[],"tail":" added par. (9) and redesignated former par. (9) as (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/262"},"text":"Pub. L. 104–262","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446/s1201/c/3/A/i"},"text":"Pub. L. 103–446, § 1201(c)(3)(A)(i)","children":[],"tail":", substituted “Assistant Under Secretaries for Health” for “Assistant Chief Medical Directors”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (7) to (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446/s1201/c/3/A/ii"},"text":"Pub. L. 103–446, § 1201(c)(3)(A)(ii)","children":[],"tail":"–(iv), redesignated par. (8), relating to such directors, as (7), par. (7) as (8), and par. (8), relating to such other personnel, as (9), and in par. (8), as so redesignated, substituted “Under Secretary for Health” for “Chief Medical Director”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446/s1201/c/3/B"},"text":"Pub. L. 103–446, § 1201(c)(3)(B)","children":[],"tail":", substituted “Assistant Under Secretaries for Health” for “Assistant Chief Medical Directors”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446/s1201/c/3/C"},"text":"Pub. L. 103–446, § 1201(c)(3)(C)","children":[],"tail":", substituted “and (8)” for “and (7)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/405/s302/c/1"},"text":"Pub. L. 102–405, § 302(c)(1)","children":[],"tail":", substituted “Under Secretary for Health” for “Chief Medical Director” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/405/s302/c/1"},"text":"Pub. L. 102–405, § 302(c)(1)","children":[],"tail":", substituted “Under Secretary for Health” for “Chief Medical Director” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sub