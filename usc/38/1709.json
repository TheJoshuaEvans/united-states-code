{"tag":"section","attrib":{"id":"idc2df6c7f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709"},"text":null,"children":[{"tag":"num","attrib":{"value":"1709"},"text":"§ 1709.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive policy on reporting and tracking sexual assault incidents and other safety incidents","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2df6c80-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Policy Required","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2df6c81-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"2012-09-30"},"text":"September 30, 2012","children":[],"tail":", the Secretary shall develop and implement a centralized and comprehensive policy on the reporting and tracking of sexual assault incidents and other safety incidents that occur at each medical facility of the Department, including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2df6c82-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspected, alleged, attempted, or confirmed cases of sexual assault, regardless of whether such assaults lead to prosecution or conviction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2df6c83-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" criminal and purposefully unsafe acts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2df6c84-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alcohol or substance abuse related acts (including by employees of the Department); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2df6c85-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any kind of event involving alleged or suspected abuse of a patient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2df6c86-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In developing and implementing a policy under paragraph (1), the Secretary shall consider the effects of such policy on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2df6c87-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use by veterans of mental health care and substance abuse treatments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2df6c88-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of the Department to refer veterans to such care or treatment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2df6c89-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The policy required by subsection (a) shall cover each of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2df6c8a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of reporting and tracking sexual assault incidents and other safety incidents, definitions of the terms—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2df6c8b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “safety incident”;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2df6c8c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “sexual assault”; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2df6c8d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “sexual assault incident”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2df6c8e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2df6c8f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The development and use of specific risk-assessment tools to examine any risks related to sexual assault that a veteran may pose while being treated at a medical facility of the Department, including clear and consistent guidance on the collection of information related to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc2df6c90-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the legal history of the veteran; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc2df6c91-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the medical record of the veteran.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2df6c92-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In developing and using tools under subparagraph (A), the Secretary shall consider the effects of using such tools on the use by veterans of health care furnished by the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2df6c93-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The mandatory training of employees of the Department on security issues, including awareness, preparedness, precautions, and police assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2df6c94-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The mandatory implementation, use, and regular testing of appropriate physical security precautions and equipment, including surveillance camera systems, computer-based panic alarm systems, stationary panic alarms, and electronic portable personal panic alarms.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2df6c95-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Clear, consistent, and comprehensive criteria and guidance with respect to an employee of the Department communicating and reporting sexual assault incidents and other safety incidents to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2df6c96-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" supervisory personnel of the employee at—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc2df6c97-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/b/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a medical facility of the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc2df6c98-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/b/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an office of a Veterans Integrated Service Network; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc2df6c99-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/b/5/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the central office of the Veterans Health Administration; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2df6c9a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a law enforcement official of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2df6c9b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Clear and consistent criteria and guidelines with respect to an employee of the Department referring and reporting to the Office of Inspector General of the Department sexual assault incidents and other safety incidents that meet the regulatory criminal threshold prescribed under sections 901 and 902 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2df6c9c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An accountable oversight system within the Veterans Health Administration that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2df6c9d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" systematic information sharing of reported sexual assault incidents and other safety incidents among officials of the Administration who have programmatic responsibility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2df6c9e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a centralized reporting, tracking, and monitoring system for such incidents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2df6c9f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Consistent procedures and systems for law enforcement officials of the Department with respect to investigating, tracking, and closing reported sexual assault incidents and other safety incidents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2df6ca0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Clear and consistent guidance for the clinical management of the treatment of sexual assaults that are reported more than 72 hours after the assault.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2df6ca1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Updates to Policy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall review and revise the policy required by subsection (a) on a periodic basis as the Secretary considers appropriate and in accordance with best practices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2df6ca2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2df6ca3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 60 days after the date on which the Secretary develops the policy required by subsection (a) and not later than October 1 of each year thereafter, the Secretary shall submit to the Committee on Veterans’ Affairs of the Senate and the Committee on Veterans’ Affairs of the House of Representatives a report on the implementation of the policy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2df6ca4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The report required by paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2df6ca5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and type of sexual assault incidents and other safety incidents reported by each medical facility of the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2df6ca6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed description of the implementation of the policy required by subsection (a), including any revisions made to such policy from the previous year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2df6ca7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of such policy on improving the safety and security of the medical facilities of the Department, including the performance measures used to evaluate such effectiveness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2df6ca8-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/154/tI/s106/a"},"text":"Pub. L. 112–154, title I, § 106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1171"},"text":"126 Stat. 1171","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
