{"tag":"section","attrib":{"id":"idc290d656-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714"},"text":null,"children":[{"tag":"num","attrib":{"value":"714"},"text":"§ 714.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employees: removal, demotion, or suspension based on performance or misconduct","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc290d657-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc290d658-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may remove, demote, or suspend a covered individual who is an employee of the Department if the Secretary determines the performance or misconduct of the covered individual warrants such removal, demotion, or suspension.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc290d659-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the Secretary so removes, demotes, or suspends such a covered individual, the Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc290d65a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remove the covered individual from the civil service (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2101"},"text":"section 2101 of title 5","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc290d65b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demote the covered individual by means of a reduction in grade for which the covered individual is qualified, that the Secretary determines is appropriate, and that reduces the annual rate of pay of the covered individual; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc290d65c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspend the covered individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc290d65d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pay of Certain Demoted Individuals","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc290d65e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, any covered individual subject to a demotion under subsection (a)(2) shall, beginning on the date of such demotion, receive the annual rate of pay applicable to such grade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc290d65f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc290d660-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A covered individual so demoted may not be placed on administrative leave during the period during which an appeal (if any) under this section is ongoing, and may only receive pay if the covered individual reports for duty or is approved to use accrued unused annual, sick, family medical, military, or court leave.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc290d661-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a covered individual so demoted does not report for duty or receive approval to use accrued unused leave, such covered individual shall not receive pay or other benefits pursuant to subsection (d)(5).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc290d662-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedure","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc290d663-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc290d664-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The aggregate period for notice, response, and final decision in a removal, demotion, or suspension under this section may not exceed 15 business days.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc290d665-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The period for the response of a covered individual to a notice of a proposed removal, demotion, or suspension under this section shall be 7 business days.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc290d666-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (3) of subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7513"},"text":"section 7513 of title 5","children":[],"tail":" shall apply with respect to a removal, demotion, or suspension under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc290d667-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The procedures in this subsection shall supersede any collective bargaining agreement to the extent that such agreement is inconsistent with such procedures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc290d668-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall issue a final decision with respect to a removal, demotion, or suspension under this section not later than 15 business days after the Secretary provides notice, including a file containing all the evidence in support of the proposed action, to the covered individual of the removal, demotion, or suspension. The decision shall be in writing and shall include the specific reasons therefor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc290d669-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The procedures under chapter 43 of title 5 shall not apply to a removal, demotion, or suspension under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc290d66a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc290d66b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subparagraph (B) and subsection (d), any removal or demotion under this section, and any suspension of more than 14 days under this section, may be appealed to the Merit Systems Protection Board, which shall refer such appeal to an administrative judge pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7701/b/1"},"text":"section 7701(b)(1) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc290d66c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An appeal under subparagraph (A) of a removal, demotion, or suspension may only be made if such appeal is made not later than 10 business days after the date of such removal, demotion, or suspension.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc290d66d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expedited Review","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc290d66e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon receipt of an appeal under subsection (c)(4)(A), the administrative judge shall expedite any such appeal under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7701/b/1"},"text":"section 7701(b)(1) of title 5","children":[],"tail":" and, in any such case, shall issue a final and complete decision not later than 180 days after the date of the appeal."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc290d66f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc290d670-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7701/c/1/B"},"text":"section 7701(c)(1)(B) of title 5","children":[],"tail":", the administrative judge shall uphold the decision of the Secretary to remove, demote, or suspend an employee under subsection (a) if the decision is supported by substantial evidence."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc290d671-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding title 5 or any other provision of law, if the decision of the Secretary is supported by substantial evidence, the administrative judge shall not mitigate the penalty prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc290d672-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc290d673-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The decision of the administrative judge under paragraph (1) may be appealed to the Merit Systems Protection Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc290d674-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7701/c/1/B"},"text":"section 7701(c)(1)(B) of title 5","children":[],"tail":", the Merit Systems Protection Board shall uphold the decision of the Secretary to remove, demote, or suspend an employee under subsection (a) if the decision is supported by substantial evidence."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc290d675-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding title 5 or any other provision of law, if the decision of the Secretary is supported by substantial evidence, the Merit Systems Protection Board shall not mitigate the penalty prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc290d676-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any case in which the administrative judge cannot issue a decision in accordance with the 180-day requirement under paragraph (1), the Merit Systems Protection Board shall, not later than 14 business days after the expiration of the 180-day period, submit to the Committee on Veterans’ Affairs of the Senate and the Committee on Veterans’ Affairs of the House of Representatives a report that explains the reasons why a decision was not issued in accordance with such requirement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc290d677-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc290d678-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A decision of the Merit Systems Protection Board under paragraph (3) may be appealed to the United States Court of Appeals for the Federal Circuit pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7703"},"text":"section 7703 of title 5","children":[],"tail":" or to any court of appeals of competent jurisdiction pursuant to subsection (b)(1)(B) of such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc290d679-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any decision by such Court shall be in compliance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7462/f/2"},"text":"section 7462(f)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc290d67a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Merit Systems Protection Board may not stay any removal or demotion under this section, except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1214/b"},"text":"section 1214(b) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc290d67b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" During the period beginning on the date on which a covered individual appeals a removal from the civil service under subsection (c) and ending on the date that the United States Court of Appeals for the Federal Circuit issues a final decision on such appeal, such covered individual may not receive any pay, awards, bonuses, incentives, allowances, differentials, student loan repayments, special payments, or benefits related to the employment of the individual by the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc290d67c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the maximum extent practicable, the Secretary shall provide to the Merit Systems Protection Board such information and assistance as may be necessary to ensure an appeal under this subsection is expedited.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc290d67d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If an employee prevails on appeal under this section, the employee shall be entitled to backpay (as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5596"},"text":"section 5596 of title 5","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc290d67e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/d/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If an employee who is subject to a collective bargaining agreement chooses to grieve an action taken under this section through a grievance procedure provided under the collective bargaining agreement, the timelines and procedures set forth in subsection (c) and this subsection shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc290d67f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Whistleblower Protection","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc290d680-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a covered individual seeking corrective action (or on behalf of whom corrective action is sought) from the Office of Special Counsel based on an alleged prohibited personnel practice described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2302/b"},"text":"section 2302(b) of title 5","children":[],"tail":", the Secretary may not remove, demote, or suspend such covered individual under subsection (a) without the approval of the Special Counsel under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1214/f"},"text":"section 1214(f) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc290d681-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of a covered individual who has made a whistleblower disclosure to the Assistant Secretary for Accountability and Whistleblower Protection, the Secretary may not remove, demote, or suspend such covered individual under subsection (a) until—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc290d682-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case in which the Assistant Secretary determines to refer the whistleblower disclosure under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s323/c/1/D"},"text":"section 323(c)(1)(D) of this title","children":[],"tail":" to an office or other investigative entity, a final decision with respect to the whistleblower disclosure has been made by such office or other investigative entity; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc290d683-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case in which the Assistant Secretary determines not to refer the whistleblower disclosure under such section, the Assistant Secretary makes such determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc290d684-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Investigations by Office of Special Counsel","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc290d685-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, the Special Counsel (established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1211"},"text":"section 1211 of title 5","children":[],"tail":") may terminate an investigation of a prohibited personnel practice alleged by an employee or former employee of the Department after the Special Counsel provides to the employee or former employee a written statement of the reasons for the termination of the investigation."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc290d686-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such statement may not be admissible as evidence in any judicial or administrative proceeding without the consent of such employee or former employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc290d687-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vacancies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of a covered individual who is removed or demoted under subsection (a), to the maximum extent feasible, the Secretary shall fill the vacancy arising as a result of such removal or demotion.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc290d688-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc290d689-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “covered individual” means an individual occupying a position at the Department, but does not include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc290d68a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual occupying a senior executive position (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s713/d"},"text":"section 713(d) of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc290d68b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual appointed pursuant to sections 7306, 7401(1), 7401(4), or 7405 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc290d68c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/h/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual who has not completed a probationary or trial period; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc290d68d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/h/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a political appointee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc290d68e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “suspend” means the placing of an employee, for disciplinary reasons, in a temporary status without duties and pay for a period in excess of 14 days.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc290d68f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “grade” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7511/a"},"text":"section 7511(a) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc290d690-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “misconduct” includes neglect of duty, malfeasance, or failure to accept a directed reassignment or to accompany a position in a transfer of function.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc290d691-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/h/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “political appointee” means an individual who is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc290d692-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/h/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employed in a position described under sections 5312 through 5316 of title 5 (relating to the Executive Schedule);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc290d693-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/h/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a limited term appointee, limited emergency appointee, or noncareer appointee in the Senior Executive Service, as defined under paragraphs (5), (6), and (7), respectively, of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3132/a"},"text":"section 3132(a) of title 5","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc290d694-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/h/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employed in a position of a confidential or policy-determining character under schedule C of subpart C of part 213 of title 5, Code of Federal Regulations, or successor regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc290d695-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s714/h/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “whistleblower disclosure” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s323/g"},"text":"section 323(g) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc290d696-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/41/tII/s202/a"},"text":"Pub. L. 115–41, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-06-23"},"text":"June 23, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/869"},"text":"131 Stat. 869","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/61/s6/1"},"text":"Pub. L. 116–61, § 6(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-09-30"},"text":"Sept. 30, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1116"},"text":"133 Stat. 1116","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc290d697-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc290d698-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc290d699-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 714 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1914"},"text":"section 1914 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc290d69a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (e)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/61"},"text":"Pub. L. 116–61","children":[],"tail":" substituted “to refer” for “to the refer”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
