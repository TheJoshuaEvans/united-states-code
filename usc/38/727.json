{"tag":"section","attrib":{"id":"idc293210a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s727"},"text":null,"children":[{"tag":"num","attrib":{"value":"727"},"text":"§ 727.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reassignment of senior executives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc293210b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s727/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approval of Reassignments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No individual employed in a senior executive position at the Department may be reassigned to another such position at the Department unless such reassignment is approved in writing and signed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc293210c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s727/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Semiannual Reports Required","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc293210d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s727/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than June 30 and December 31 of each year, the Secretary shall submit to Congress a report on the reassignment of individuals employed in senior executive positions at the Department to other such positions at the Department during the period covered by the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc293210e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s727/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each report submitted under paragraph (1) shall describe the purpose of each reassignment and the costs associated with such reassignment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc293210f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s727/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of paragraph (2), costs associated with a reassignment may only include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2932110-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s727/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A salary increase.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2932111-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s727/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Temporary travel expenses for the individual or the family of the individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2932112-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s727/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Moving expenses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2932113-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s727/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A paid incentive.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2932114-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s727/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Senior Executive Position Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “senior executive position” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s713/d"},"text":"section 713(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2932115-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/188/s2/a"},"text":"Pub. L. 115–188, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-21"},"text":"June 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1490"},"text":"132 Stat. 1490","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
