{"tag":"section","attrib":{"id":"idc3d9d1ae-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5321"},"text":null,"children":[{"tag":"num","attrib":{"value":"5321"},"text":"§ 5321.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefits helpline","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3d9d1af-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5321/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall maintain a toll-free telephone helpline that a covered individual may call in order to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3d9d1b0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5321/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain information about any service or benefit provided under the laws administered by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d9d1b1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5321/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be directed to an appropriate office of the Department regarding such a service or benefit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d9d1b2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5321/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contract for Direction of Calls Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may enter into a contract with a third party to direct calls made to the helpline to an appropriate office under subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d9d1b3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5321/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Live Individual Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall ensure that a covered individual who calls the helpline has the option to speak with a live individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d9d1b4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5321/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3d9d1b5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5321/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “covered individual” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3d9d1b6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5321/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a veteran;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3d9d1b7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5321/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual acting on behalf of a veteran; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3d9d1b8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5321/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual other than a veteran who is eligible to receive a benefit or service under a law administered by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d9d1b9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5321/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “veteran” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2002/b"},"text":"section 2002(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3d9d1ba-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dE/tL/s5002/a"},"text":"Pub. L. 118–159, div. E, title L, § 5002(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2408"},"text":"138 Stat. 2408","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
