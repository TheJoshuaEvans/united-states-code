{"tag":"section","attrib":{"id":"idc40c0524-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7432"},"text":null,"children":[{"tag":"num","attrib":{"value":"7432"},"text":"§ 7432.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pay of Under Secretary for Health","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc40c0525-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7432/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Base Pay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The base pay of the Under Secretary for Health shall be the annual rate of basic pay for positions at Level III of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc40c0526-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7432/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Market Pay","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc40c0527-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7432/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an Under Secretary for Health who is also a physician, podiatrist, optometrist, or dentist, in addition to the base pay specified in subsection (a) the Under Secretary for Health may also be paid the market pay element of pay of physicians and dentists under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7431/c"},"text":"section 7431(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc40c0528-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7432/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of market pay of the Under Secretary for Health under this subsection shall be established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc40c0529-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7432/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In establishing the amount of market pay of the Under Secretary for Health under this subsection, the Secretary shall utilize an appropriate health care labor market selected by the Secretary for purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc40c052a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7432/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of Pay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Pay under this section shall be considered pay for all purposes, including retirement benefits under chapters 83 and 84 of title 5 and other benefits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc40c052b-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/445/s3/b"},"text":"Pub. L. 108–445, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-03"},"text":"Dec. 3, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2640"},"text":"118 Stat. 2640","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/210/tI/s142/a/3/A"},"text":"Pub. L. 118–210, title I, § 142(a)(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-02"},"text":"Jan. 2, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2746"},"text":"138 Stat. 2746","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc40c052c-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc40c052d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc40c052e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7432, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/tI/s102"},"text":"Pub. L. 102–40, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/189"},"text":"105 Stat. 189","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/405/tIII/s302/c/1"},"text":"Pub. L. 102–405, title III, § 302(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-09"},"text":"Oct. 9, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1984"},"text":"106 Stat. 1984","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/262/tIII/s346"},"text":"Pub. L. 104–262, title III, § 346","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3208"},"text":"110 Stat. 3208","children":[],"tail":", related to written agreements for special pay, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/108/445"},"text":"Pub. L. 108–445","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc40c052f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/210"},"text":"Pub. L. 118–210","children":[],"tail":" inserted “, podiatrist, optometrist,” after “physician”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc40c0530-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc40c0531-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/210"},"text":"Pub. L. 118–210","children":[],"tail":" applicable to any pay period of the Department of Veterans Affairs beginning on or after the date that is 180 days after "},{"tag":"date","attrib":{"date":"2025-01-02"},"text":"Jan. 2, 2025","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/118/210/s142/a/5"},"text":"section 142(a)(5) of Pub. L. 118–210","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7431"},"text":"section 7431 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
