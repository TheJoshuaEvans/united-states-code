{"tag":"section","attrib":{"id":"idc337c5b2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2069"},"text":null,"children":[{"tag":"num","attrib":{"value":"2069"},"text":"§ 2069.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to telehealth services","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"To the extent practicable, the Secretary shall ensure that veterans participating in or receiving services from a program under this chapter have access to telehealth services to which such veterans are eligible under the laws administered by the Secretary, including by ensuring that telehealth capabilities are available to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc337c5b3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2069/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such veterans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc337c5b4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2069/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" case managers of the Department of programs for homeless veterans authorized under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc337c5b5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2069/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community-based service providers for homeless veterans receiving funds from the Department through grants or contracts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc337c5b6-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/210/tIV/s404/a"},"text":"Pub. L. 118–210, title IV, § 404(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-02"},"text":"Jan. 2, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2797"},"text":"138 Stat. 2797","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc337c5b7-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc337c5b8-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc337c5b9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/210/s404/a"},"text":"Section 404(a) of Pub. L. 118–210","children":[],"tail":", which directed the addition of this section at the end of subtitle VII of this chapter, was executed by adding this section at the end of subchapter VII of this chapter, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
