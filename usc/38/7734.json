{"tag":"section","attrib":{"id":"idc41a35b0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7734"},"text":null,"children":[{"tag":"num","attrib":{"value":"7734"},"text":"§ 7734.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report to Congress","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall include in the annual report to the Congress required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s529"},"text":"section 529 of this title","children":[],"tail":" a report on the quality assurance activities carried out under this subchapter. Each such report shall include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc41a35b1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7734/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an appraisal of the quality of services provided by the Veterans Benefits Administration, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc41a35b2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7734/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of decisions reviewed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc41a35b3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7734/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the findings on the decisions reviewed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc41a35b4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7734/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of full-time equivalent employees assigned to quality assurance in each division or entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc41a35b5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7734/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specific documentation of compliance with the standards for independence and internal control required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7731/b"},"text":"section 7731(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc41a35b6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7734/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actions taken to improve the quality of services provided and the results obtained;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc41a35b7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7734/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information with respect to the accuracy of decisions, including trends in that information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc41a35b8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7734/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc41a35b9-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117/s801/a/1"},"text":"Pub. L. 106–117, § 801(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-30"},"text":"Nov. 30, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1585"},"text":"113 Stat. 1585","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
