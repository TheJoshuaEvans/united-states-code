{"tag":"section","attrib":{"id":"idc2c2e2a0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1534"},"text":null,"children":[{"tag":"num","attrib":{"value":"1534"},"text":"§ 1534.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surviving spouses of Indian War veterans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2c2e2a1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1534/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall pay to the surviving spouse of each Indian War veteran who met the service requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1511"},"text":"section 1511 of this title","children":[],"tail":" a pension at the following monthly rate:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2c2e2a2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1534/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $40.64 if such surviving spouse is below seventy years of age; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2c2e2a3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1534/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $70 if such surviving spouse is seventy years of age or older.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2c2e2a4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1534/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If there is a child of the veteran, the rate of pension paid to the surviving spouse under subsection (a) shall be increased by $8.13 per month for each such child.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2c2e2a5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1534/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No pension shall be paid to a surviving spouse of a veteran under this section unless such surviving spouse was married to such veteran—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2c2e2a6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1534/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before ","children":[{"tag":"date","attrib":{"date":"1917-03-04"},"text":"March 4, 1917","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2c2e2a7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1534/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for one year or more; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2c2e2a8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1534/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any period of time if a child was born of the marriage, or was born to them before the marriage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2c2e2a9-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1137"},"text":"72 Stat. 1137","children":[],"tail":", § 534; "},{"tag":"ref","attrib":{"href":"/us/pl/90/77/tI"},"text":"Pub. L. 90–77, title I","children":[],"tail":", §§ 101(a), 105, "},{"tag":"date","attrib":{"date":"1967-08-31"},"text":"Aug. 31, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/178"},"text":"81 Stat. 178","children":[],"tail":", 179; "},{"tag":"ref","attrib":{"href":"/us/pl/94/169/tI/s106/26"},"text":"Pub. L. 94–169, title I, § 106(26)","children":[],"tail":"–(29), "},{"tag":"date","attrib":{"date":"1975-12-23"},"text":"Dec. 23, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/1018"},"text":"89 Stat. 1018","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/54/s14/b/7"},"text":"Pub. L. 102–54, § 14(b)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-06-13"},"text":"June 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/283"},"text":"105 Stat. 283","children":[],"tail":"; renumbered § 1534 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":", §§ 4(b)(1), (2)(E), 5(a), (c)(1), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404-406"},"text":"105 Stat. 404–406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2c2e2aa-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc2c2e2ab-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc2c2e2ac-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s534"},"text":"section 534 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “1511” for “511” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/54"},"text":"Pub. L. 102–54","children":[],"tail":" substituted a period for semicolon at end of par. (2) and struck out at end “; unless such surviving spouse was the spouse of the veteran during such veteran’s service in one of the Indian Wars, in which case the monthly rate shall be $75.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/169/s106/29"},"text":"Pub. L. 94–169, § 106(29)","children":[],"tail":", substituted “Surviving spouses” for “Widows” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/169/s106/26"},"text":"Pub. L. 94–169, § 106(26)","children":[],"tail":", substituted “pay to a surviving spouse” for “paid to a widow”, “unless such surviving spouse” for “she” wherever appearing, “was the spouse” for “was the wife” and “such veteran’s” for “his”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/169/s106/27"},"text":"Pub. L. 94–169, § 106(27)","children":[],"tail":", substituted “surviving spouse” for “widow”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/169/s106/28"},"text":"Pub. L. 94–169, § 106(28)","children":[],"tail":", substituted “paid to a surviving spouse” for “paid to a widow”, “unless such surviving spouse” for “unless she” and “such veteran” for “him”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/77/s105"},"text":"Pub. L. 90–77, § 105","children":[],"tail":", substituted “$70” for “$65”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/77/s101/a"},"text":"Pub. L. 90–77, § 101(a)","children":[],"tail":", qualified widow of a veteran for a pension by reducing in par. (2) the requisite marriage period from five years to one year and by making her eligible for benefits in par. (3) in event of antenuptial birth."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc2c2e2ad-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc2c2e2ae-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1975 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/169/tI/s106"},"text":"Pub. L. 94–169, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-23"},"text":"Dec. 23, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/1017"},"text":"89 Stat. 1017","children":[],"tail":", provided that the amendment made by that section is effective "},{"tag":"date","attrib":{"date":"1976-01-01"},"text":"Jan. 1, 1976","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc2c2e2af-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1967 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/77"},"text":"Pub. L. 90–77","children":[],"tail":" effective first day of first calendar month which begins more than ten days after "},{"tag":"date","attrib":{"date":"1967-08-31"},"text":"Aug. 31, 1967","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/77/s405"},"text":"section 405 of Pub. L. 90–77","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
