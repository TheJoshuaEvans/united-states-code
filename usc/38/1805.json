{"tag":"section","attrib":{"id":"idc313e974-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1805"},"text":null,"children":[{"tag":"num","attrib":{"value":"1805"},"text":"§ 1805.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monetary allowance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc313e975-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1805/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall pay a monthly allowance under this section to any child of a Vietnam veteran for any disability resulting from spina bifida suffered by such child.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc313e976-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1805/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc313e977-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1805/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of the allowance paid to a child under this section shall be based on the degree of disability suffered by the child, as determined in accordance with such schedule for rating disabilities resulting from spina bifida as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc313e978-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1805/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall, in prescribing the rating schedule for the purposes of this section, establish three levels of disability upon which the amount of the allowance provided by this section shall be based.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc313e979-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1805/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amounts of the allowance shall be $200 per month for the lowest level of disability prescribed, $700 per month for the intermediate level of disability prescribed, and $1,200 per month for the highest level of disability prescribed. Such amounts are subject to adjustment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5312"},"text":"section 5312 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc313e97a-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/204/tIV/s421/b/1"},"text":"Pub. L. 104–204, title IV, § 421(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-26"},"text":"Sept. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2925"},"text":"110 Stat. 2925","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/419/tIV/s401/c/2"},"text":"Pub. L. 106–419, title IV, § 401(c)(2)","children":[],"tail":", (e)(2), "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1860"},"text":"114 Stat. 1860","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc313e97b-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc313e97c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc313e97d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1805 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3705"},"text":"section 3705 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc313e97e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/419/s401/e/2"},"text":"Pub. L. 106–419, § 401(e)(2)","children":[],"tail":", substituted “this section” for “this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/419/s401/c/2"},"text":"Pub. L. 106–419, § 401(c)(2)","children":[],"tail":", struck out subsecs. (c) and (d) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(c) Notwithstanding any other provision of law, receipt by a child of an allowance under this section shall not impair, infringe, or otherwise affect the right of the child to receive any other benefit to which the child may otherwise be entitled under any law administered by the Secretary, nor shall receipt of such an allowance impair, infringe, or otherwise affect the right of any individual to receive any benefit to which the individual is entitled under any law administered by the Secretary that is based on the child’s relationship to the individual.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(d) Notwithstanding any other provision of law, the allowance paid to a child under this section shall not be considered income or resources in determining eligibility for or the amount of benefits under any Federal or federally assisted program.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc313e97f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc313e980-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/419"},"text":"Pub. L. 106–419","children":[],"tail":" effective on the first day of the first month beginning more than one year after "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/419/s401/g"},"text":"section 401(g) of Pub. L. 106–419","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1811"},"text":"section 1811 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
