[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/183/tV/s502/b"},"text":"Pub. L. 108–183, title V, § 502(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-16"},"text":"Dec. 16, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2667"},"text":"117 Stat. 2667","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/183/tV/s502/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply with respect to deaths occurring on or after ","children":[{"tag":"date","attrib":{"date":"2000-01-01"},"text":"January 1, 2000","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc343abf7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/419/s331/a"},"text":"section 331(a) of Pub. L. 106–419","children":[],"tail":" applicable with respect to deaths occurring on or after "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/419/s331/c"},"text":"section 331(c) of Pub. L. 106–419","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s107"},"text":"section 107 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc343abf8-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Criteria for Interment at Arlington National Cemetery","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tV/s598"},"text":"Pub. L. 115–232, div. A, title V, § 598","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1791"},"text":"132 Stat. 1791","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/232/dA/tV/s598"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criteria","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army, in consultation with the Secretary of Defense, shall prescribe revised criteria for interment at Arlington National Cemetery that preserve Arlington National Cemetery as an active burial ground ‘well into the future,’ as that term is used in the report submitted by the Secretary of the Army to the Committees on Veterans’ Affairs and the Committees on Armed Services of the House of Representatives and the Senate, dated ","children":[{"tag":"date","attrib":{"date":"2017-02-14"},"text":"February 14, 2017","children":[],"tail":", and titled ‘The Future of Arlington National Cemetery: Report on the Cemetery’s Interment and Inurnment Capacity 2017’."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadline","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army shall establish the criteria under subsection (a) not later than ","children":[{"tag":"date","attrib":{"date":"2019-09-30"},"text":"September 30, 2019","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc343abf9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Identification of Unclaimed or Abandoned Human Remains","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/260/tI/s104/a"},"text":"Pub. L. 112–260, title I, § 104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-10"},"text":"Jan. 10, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2420"},"text":"126 Stat. 2420","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/260/tI/s104/a"},"text":"“The Secretary of Veterans Affairs shall cooperate with veterans service organizations to assist entities in possession of unclaimed or abandoned human remains in determining if any such remains are the remains of veterans or other individuals eligible for burial in a national cemetery under the jurisdiction of the Secretary.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc343abfa-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Guidance Required","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/275/tV/s502/c"},"text":"Pub. L. 111–275, title V, § 502(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-13"},"text":"Oct. 13, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2882"},"text":"124 Stat. 2882","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/275/tV/s502/c"},"text":"“The Secretary of Veterans Affairs, in consultation with the Secretary of Defense, shall develop guidance under which the parent of a person described in paragraph (9)(B) of subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2402"},"text":"section 2402 of title 38","children":[],"tail":", United States Code, as added by subsection (b), may be designated for interment in a national cemetery under that section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc343abfb-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Eligibility of Former Prisoners of War for Burial in Arlington National Cemetery","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tXI/s1176"},"text":"Pub. L. 103–160, div. A, title XI, § 1176","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1768"},"text":"107 Stat. 1768","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/160/dA/tXI/s1176"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility for Burial","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Former prisoners of war described in subsection (b) are eligible for burial in Arlington National Cemetery, Arlington, Virginia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Former POWs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A former prisoner of war referred to in subsection (a) is a former prisoner of war—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who dies on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who, while a prisoner of war, served honorably in the active military, naval, or air service, as determined under regulations prescribed by the Secretary of the military department concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Savings Provision","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section may not be construed to make ineligible for burial in Arlington National Cemetery a former prisoner of war who is eligible to be buried in that cemetery under another provision of law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall be carried out under regulations prescribed by the Secretary of the Army. Those regulations may prescribe a minimum period of internment as a prisoner of war for purposes of eligibility under this section for burial in Arlington National Cemetery.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘former prisoner of war’ has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s101/32"},"text":"section 101(32) of title 38","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘active military, naval, or air service’ has the meaning given such term in section 101(24) of such title.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
