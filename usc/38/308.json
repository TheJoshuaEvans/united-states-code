{"tag":"section","attrib":{"id":"idc27b52d6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s308"},"text":null,"children":[{"tag":"num","attrib":{"value":"308"},"text":"§ 308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistant Secretaries; Deputy Assistant Secretaries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc27b52d7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s308/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc27b52d8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s308/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There shall be in the Department not more than seven Assistant Secretaries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27b52d9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s308/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (3), each Assistant Secretary appointed under paragraph (1) shall be appointed by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27b52da-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s308/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The following Assistant Secretaries may be appointed without the advice and consent of the Senate:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc27b52db-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s308/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary for Management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc27b52dc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s308/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary for Human Resources and Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc27b52dd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s308/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary for Public and Intergovernmental Affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc27b52de-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s308/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary for Operations, Security, and Preparedness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc27b52df-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s308/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall assign to the Assistant Secretaries responsibility for the administration of such functions and duties as the Secretary considers appropriate, including the following functions:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc27b52e0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s308/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Budgetary and financial functions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27b52e1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s308/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Personnel management and labor relations functions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27b52e2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s308/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Planning, studies, and evaluations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27b52e3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s308/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Management, productivity, and logistic support functions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27b52e4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s308/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information management functions as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3506"},"text":"section 3506 of title 44","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27b52e5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s308/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Capital facilities and real property program functions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27b52e6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s308/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Equal opportunity functions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27b52e7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s308/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Functions regarding the investigation of complaints of employment discrimination within the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27b52e8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s308/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Functions regarding intergovernmental, public, and consumer information and affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27b52e9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s308/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Procurement functions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27b52ea-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s308/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Operations, preparedness, security, and law enforcement functions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27b52eb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s308/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The functions set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s323/c"},"text":"section 323(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc27b52ec-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s308/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever the President nominates an individual for appointment as an Assistant Secretary, the President shall include in the communication to the Senate of the nomination a statement of the particular functions of the Department specified in subsection (b), and any other functions of the Department, the individual will exercise upon taking office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc27b52ed-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s308/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc27b52ee-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s308/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There shall be in the Department such number of Deputy Assistant Secretaries, not exceeding 19, as the Secretary may determine. Each Deputy Assistant Secretary shall be appointed by the Secretary and shall perform such functions as the Secretary prescribes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27b52ef-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s308/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" At least two-thirds of the number of positions established and filled under paragraph (1) shall be filled by individuals who have at least five years of continuous service in the Federal civil service in the executive branch immediately preceding their appointment as a Deputy Assistant Secretary. For purposes of determining such continuous service of an individual, there shall be excluded any service by such individual in a position—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc27b52f0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s308/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of a confidential, policy-determining, policy-making, or policy-advocating character;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc27b52f1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s308/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which such individual served as a noncareer appointee in the Senior Executive Service, as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3132/a/7"},"text":"section 3132(a)(7) of title 5","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc27b52f2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s308/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to which such individual was appointed by the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc27b52f3-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s2/a"},"text":"Pub. L. 102–83, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/381"},"text":"105 Stat. 381","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/287/s5/a"},"text":"Pub. L. 107–287, § 5(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"2002-11-07"},"text":"Nov. 7, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2030"},"text":"116 Stat. 2030","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/166/s2/m"},"text":"Pub. L. 112–166, § 2(m)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1287"},"text":"126 Stat. 1287","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/41/tI/s101/b"},"text":"Pub. L. 115–41, title I, § 101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-06-23"},"text":"June 23, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/865"},"text":"131 Stat. 865","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc27b52f4-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc27b52f5-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc27b52f6-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in sections 4(a), (b), (e) and 5 of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/527"},"text":"Pub. L. 100–527","children":[],"tail":", known as the Department of Veterans Affairs Act, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s3/3"},"text":"Pub. L. 102–83, § 3(3)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc27b52f7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (b)(12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/41"},"text":"Pub. L. 115–41","children":[],"tail":" added par. (12)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/166"},"text":"Pub. L. 112–166","children":[],"tail":" designated existing provisions as par. (1), struck out at end of par. (1) “Each Assistant Secretary shall be appointed by the President, by and with the advice and consent of the Senate.”, and added pars. (2) and (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/287/s5/a"},"text":"Pub. L. 107–287, § 5(a)","children":[],"tail":", substituted “seven” for “six” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/287/s5/b"},"text":"Pub. L. 107–287, § 5(b)","children":[],"tail":", added par. (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/287/s5/c"},"text":"Pub. L. 107–287, § 5(c)","children":[],"tail":", substituted “19” for “18”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc27b52f8-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc27b52f9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/166"},"text":"Pub. L. 112–166","children":[],"tail":" effective 60 days after "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", and applicable to appointments made on and after that effective date, including any nomination pending in the Senate on that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/112/166/s6/a"},"text":"section 6(a) of Pub. L. 112–166","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s113"},"text":"section 113 of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
