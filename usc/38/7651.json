{"tag":"section","attrib":{"id":"idc417eb53-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7651"},"text":null,"children":[{"tag":"num","attrib":{"value":"7651"},"text":"§ 7651.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority for program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc417eb54-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7651/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As part of the Educational Assistance Program, the Secretary of Veterans Affairs may select qualified individuals to receive assistance under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc417eb55-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7651/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To be eligible to receive assistance under this subchapter, an individual must be accepted for enrollment or be enrolled as a full-time student at a qualifying educational institution in a course of education or training that is approved by the Secretary and that leads toward completion of a degree in a health profession involving direct patient care or care incident to direct patient care.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc417eb56-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/366/tII/s205/a/1"},"text":"Pub. L. 101–366, title II, § 205(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-15"},"text":"Aug. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/439"},"text":"104 Stat. 439","children":[],"tail":", § 4351; renumbered § 7651, "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc417eb57-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc417eb58-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc417eb59-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4351"},"text":"section 4351 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
