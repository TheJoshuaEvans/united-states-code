{"tag":"section","attrib":{"id":"idc2827ef6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s515"},"text":null,"children":[{"tag":"num","attrib":{"value":"515"},"text":"§ 515.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative settlement of tort claims","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2827ef7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s515/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2827ef8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s515/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding the limitations contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2672"},"text":"section 2672 of title 28","children":[],"tail":", the Secretary may settle a claim for money damages against the United States cognizable under section 1346(b) or 2672 of title 28 or "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7316"},"text":"section 7316 of this title","children":[],"tail":" to the extent the authority to do so is delegated to the Secretary by the Attorney General. Such delegation may not exceed the authority delegated by the Attorney General to United States attorneys to settle claims for money damages against the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2827ef9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s515/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this subsection, the term “settle”, with respect to a claim, means consider, ascertain, adjust, determine, and dispose of the claim, whether by full or partial allowance or by disallowance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2827efa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s515/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may pay tort claims, in the manner authorized in the first paragraph of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2672"},"text":"section 2672 of title 28","children":[],"tail":", when such claims arise in foreign countries in connection with Department operations abroad. A claim may not be allowed under this subsection unless it is presented in writing to the Secretary within two years after the claim accrues."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2827efb-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s2/a"},"text":"Pub. L. 102–83, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/389"},"text":"105 Stat. 389","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2827efc-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc2827efd-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc2827efe-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in sections 224 and 236 of this title prior to repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s2/a"},"text":"Pub. L. 102–83, § 2(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc2827eff-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc2827f00-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Department of Veterans Affairs Requirement To Provide Certain Notice to Persons Filing Claims for Damage, Injury, or Death on Standard Form 95","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/tVII/s7010"},"text":"Pub. L. 116–315, title VII, § 7010","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/5061"},"text":"134 Stat. 5061","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/315/tVII/s7010"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Not later than 90 days after the date on which a person submits to the Secretary of Veterans Affairs a claim for damage, injury, or death on Standard Form 95, or any successor form, the Secretary shall provide to such person notice of each of the following:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The benefit of obtaining legal advice concerning such claim.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The employment status of any individual listed on the form.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the claim involves a contractor that entered into an agreement with the Secretary, the importance of obtaining legal advice as to the statute of limitations regarding the claim in the State in which the claim arose.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
