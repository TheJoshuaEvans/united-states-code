{"tag":"section","attrib":{"id":"idc3f681b0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310"},"text":null,"children":[{"tag":"num","attrib":{"value":"7310"},"text":"§ 7310.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Women’s Health","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3f681b1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3f681b2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary for Health shall establish and operate in the Veterans Health Administration the Office of Women’s Health (in this section referred to as the “Office”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f681b3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office shall be located at the Central Office of the Department of Veterans Affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f681b4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3f681b5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of the Office is the Chief Officer of Women’s Health (in this section referred to as the “Chief Officer”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3f681b6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief Officer shall report to the Under Secretary for Health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f681b7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary for Health shall provide the Office with such staff and other support as may be necessary for the Office to carry out effectively the functions of the Office under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f681b8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary for Health may reorganize existing offices within the Veterans Health Administration as of the date of the enactment of this section in order to avoid duplication with the functions of the Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3f681b9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Functions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The functions of the Office include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3f681ba-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide a central office for monitoring and encouraging the activities of the Veterans Health Administration with respect to the provision, evaluation, and improvement of health care services provided to women veterans by the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f681bb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To develop and implement standards of care for the provision of health care for women veterans by the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f681bc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To monitor and identify deficiencies in standards of care for the provision of health care for women veterans by the Department, to provide technical assistance to medical facilities of the Department to address and remedy deficiencies, and to perform oversight of implementation of such standards of care.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f681bd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To monitor and identify deficiencies in standards of care for the provision of health care for women veterans provided through the community pursuant to this title and to provide recommendations to the appropriate office to address and remedy any deficiencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f681be-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To oversee distribution of resources and information related to health programming for women veterans under this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f681bf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To promote the expansion and improvement of clinical, research, and educational activities of the Veterans Health Administration with respect to the health care of women veterans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f681c0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide, as part of the annual budgeting process, recommendations with respect to the amounts to be requested for furnishing hospital care and medical services to women veterans pursuant to chapter 17 of this title, including, at a minimum, recommendations that ensure that such amounts either reflect or exceed the proportion of veterans enrolled in the system of patient enrollment of the Department established and operated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1705/a"},"text":"section 1705(a) of this title","children":[],"tail":" who are women."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f681c1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide recommendations to the Under Secretary for Health with respect to modifying the Veterans Equitable Resource Allocation system, or successor system, to ensure that resource allocations under such system, or successor system, reflect the health care needs of women veterans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f681c2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To carry out such other duties as the Under Secretary for Health may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3f681c3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recommendations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3f681c4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Under Secretary for Health determines not to implement any recommendation made by the Chief Officer with respect to the allocation of resources to address the health care needs of women veterans, the Secretary shall notify the appropriate congressional committees of such determination by not later than 30 days after the date on which the Under Secretary for Health receives the recommendation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f681c5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each notification under paragraph (1) relating to a determination with respect to a recommendation shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3f681c6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The reasoning of the Under Secretary for Health in making the determination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3f681c7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An alternative, if one is selected, to the recommendation that the Under Secretary for Health will carry out to fulfill the health care needs of women veterans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3f681c8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standards of Care","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of carrying out the functions of the Office under this section, the standards of care for the provision of health care for women veterans from the Department shall include, at a minimum, the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3f681c9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A requirement for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3f681ca-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least one designated women’s health primary care provider at each medical center of the Department whose duties include, to the extent practicable, providing training to other health care providers of the Department with respect to the needs of women veterans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3f681cb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least one designated women’s health primary care provider at each community-based outpatient clinic of the Department who may serve women patients as a percentage of the total duties of the provider.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f681cc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other requirements as determined by the Under Secretary for Health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3f681cd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Outreach","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chief Officer shall ensure that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3f681ce-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less frequently than biannually, each medical facility of the Department holds a public forum for women veterans that occurs outside of regular business hours; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f681cf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less frequently than quarterly, each medical facility of the Department convenes a focus group of women veterans that includes a discussion of harassment occurring at such facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3f681d0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3f681d1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “appropriate congressional committees” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7310A/h"},"text":"section 7310A(h) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f681d2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “facility of the Department” has the meaning given the term “facilities of the Department” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1701/3"},"text":"section 1701(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f681d3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Veterans Equitable Resource Allocation system” means the resource allocation system established pursuant to section 429 of the Departments of Veterans Affairs and Housing and Urban Development, and Independent Agencies Appropriations Act, 1997 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/204"},"text":"Public Law 104–204","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/110/2929"},"text":"110 Stat. 2929","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3f681d4-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/tV/s5101/b/1"},"text":"Pub. L. 116–315, title V, § 5101(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/5022"},"text":"134 Stat. 5022","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3f681d5-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3f681d6-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc3f681d7-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsec. (a)(5), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315"},"text":"Pub. L. 116–315","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 429 of the Departments of Veterans Affairs and Housing and Urban Development, and Independent Agencies Appropriations Act, 1997, referred to in subsec. (f)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/204/tIV/s429"},"text":"section 429 of title IV of Pub. L. 104–204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-26"},"text":"Sept. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2929"},"text":"110 Stat. 2929","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3f681d8-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3f681d9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References to Health Care and Services","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/tV/s5101/b/2"},"text":"Pub. L. 116–315, title V, § 5101(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/5026"},"text":"134 Stat. 5026","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/315/tV/s5101/b/2"},"text":"“The references to health care and the references to services in sections 7310 and 7310A of title 38, United States Code, as added by paragraph (1), are references to the health care and services included in the medical benefits package provided by the Department as in effect on the day before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
