{"tag":"section","attrib":{"id":"idc41a3550-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699B"},"text":null,"children":[{"tag":"num","attrib":{"value":"7699B"},"text":"§ 7699B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Breach of agreement: liability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc41a3551-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Liquidated Damages","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc41a3552-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699B/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A participant in the Program (other than a participant described in subsection (b)) who fails to accept payment, or instructs the educational institution in which the participant is enrolled not to accept payment, in whole or in part, of a scholarship under the agreement entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7604"},"text":"section 7604 of this title","children":[],"tail":" shall be liable to the United States for liquidated damages in the amount of $1,500."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc41a3553-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699B/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Liability under paragraph (1) is in addition to any period of obligated service or other obligation or liability under such agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc41a3554-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Liability During Program of Study","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc41a3555-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699B/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subsection (d), a participant in the Program shall be liable to the United States for the amount which has been paid to or on behalf of the participant under the agreement if any of the following occurs:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc41a3556-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699B/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The participant fails to maintain an acceptable level of academic standing in the educational institution in which the participant is enrolled (as determined by the educational institution under regulations prescribed by the Secretary).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc41a3557-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699B/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The participant is dismissed from such educational institution for disciplinary reasons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc41a3558-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699B/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The participant voluntarily terminates the program of study in such educational institution before the completion of such program of study.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc41a3559-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699B/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Liability under this subsection is in lieu of any service obligation arising under the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc41a355a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699B/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Liability During Period of Obligated Service","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc41a355b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699B/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (d), if a participant in the Program does not complete the period of obligated service of the participant, the United States shall be entitled to recover from the participant an amount determined in accordance with the following formula: A = 3Φ (t−s/t).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc41a355c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699B/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the formula in paragraph (1):","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc41a355d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699B/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “A” is the amount the United States is entitled to recover.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc41a355e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699B/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “Φ” is the sum of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc41a355f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699B/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts paid under this subchapter to or on behalf of the participant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc41a3560-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699B/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interest on such amounts which would be payable if at the time the amounts were paid they were loans bearing interest at the maximum legal prevailing rate, as determined by the Treasurer of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc41a3561-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699B/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “t” is the total number of months in the period of obligated service of the participant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc41a3562-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699B/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “s” is the number of months of such period served by the participant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc41a3563-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699B/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Liability for Reductions-in-force","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Liability shall not arise under subsection (c) if the participant fails to maintain employment as a Department employee due to a staffing adjustment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc41a3564-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699B/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Period for Payment of Damages","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any amount of damages that the United States is entitled to recover under this section shall be paid to the United States within the one-year period beginning on the date of the breach of the agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc41a3565-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/171/tV/s502/a"},"text":"Pub. L. 116–171, title V, § 502(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-17"},"text":"Oct. 17, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/816"},"text":"134 Stat. 816","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc41a3566-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc41a3567-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc41a3568-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Secretary of Veterans Affairs to begin awarding scholarships under this subchapter for programs of study beginning no later than one year after ","children":[{"tag":"date","attrib":{"date":"2020-10-17"},"text":"Oct. 17, 2020","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/171/s502/c"},"text":"section 502(c) of Pub. L. 116–171","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7698"},"text":"section 7698 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
