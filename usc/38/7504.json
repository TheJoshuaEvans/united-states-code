{"tag":"section","attrib":{"id":"idc4130a0f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7504"},"text":null,"children":[{"tag":"num","attrib":{"value":"7504"},"text":"§ 7504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"An agreement between the Secretary and a participant in the scholarship program under this chapter shall be in writing, shall be signed by the participant, and shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4130a10-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7504/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary’s agreement to provide the participant with financial assistance as authorized under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4130a11-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7504/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the participant’s agreement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc4130a12-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7504/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to accept such financial assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4130a13-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7504/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain enrollment and attendance in the program of study described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7501/a/1"},"text":"section 7501(a)(1) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4130a14-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7504/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while enrolled in such program, to maintain an acceptable level of academic standing (as determined by the educational institution offering such program under regulations prescribed by the Secretary); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4130a15-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7504/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after completion of the program, to serve as a full-time employee in the Department for a period of three years, to be served within the first six years after the participant has completed such program and received a degree or certificate described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7501/a/1"},"text":"section 7501(a)(1) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4130a16-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7504/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other terms and conditions that the Secretary considers appropriate for carrying out this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc4130a17-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163/tIII/s302/a"},"text":"Pub. L. 111–163, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-05-05"},"text":"May 5, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1148"},"text":"124 Stat. 1148","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
