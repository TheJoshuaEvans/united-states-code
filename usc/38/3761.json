{"tag":"section","attrib":{"id":"idc3b3ab21-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3761"},"text":null,"children":[{"tag":"num","attrib":{"value":"3761"},"text":"§ 3761.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct housing loans to Native American veterans; program authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3b3ab22-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3761/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall make direct housing loans to Native American veterans. The purpose of such loans is to permit such veterans to purchase, construct, or improve dwellings on trust land. The Secretary shall make such loans in accordance with the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3b3ab23-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3761/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall, to the extent practicable, make direct housing loans to Native American veterans who are located in a variety of geographic areas and in areas experiencing a variety of economic circumstances.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3b3ab24-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3761/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall prescribe such regulations as may be necessary to carry out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3b3ab25-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/547/s8/a"},"text":"Pub. L. 102–547, § 8(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3636"},"text":"106 Stat. 3636","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/114/tII/s201/a"},"text":"Pub. L. 105–114, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2282"},"text":"111 Stat. 2282","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/103/tIV/s402/a"},"text":"Pub. L. 107–103, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-27"},"text":"Dec. 27, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/993"},"text":"115 Stat. 993","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/454/tIV/s407"},"text":"Pub. L. 108–454, title IV, § 407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-10"},"text":"Dec. 10, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3617"},"text":"118 Stat. 3617","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/233/tI/s103/a"},"text":"Pub. L. 109–233, title I, § 103(a)","children":[],"tail":", (f)(2), "},{"tag":"date","attrib":{"date":"2006-06-15"},"text":"June 15, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/399"},"text":"120 Stat. 399","children":[],"tail":", 400; "},{"tag":"ref","attrib":{"href":"/us/pl/118/210/tII/s231/g"},"text":"Pub. L. 118–210, title II, § 231(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-02"},"text":"Jan. 2, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2787"},"text":"138 Stat. 2787","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3b3ab26-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3b3ab27-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3b3ab28-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/210"},"text":"Pub. L. 118–210","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/233/s103/f/2"},"text":"Pub. L. 109–233, § 103(f)(2)","children":[],"tail":", amended section catchline generally, substituting “Direct housing loans to Native American veterans; program authority” for “Pilot program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/233/s103/a/1"},"text":"Pub. L. 109–233, § 103(a)(1)","children":[],"tail":", struck out “establish and implement a pilot program under which the Secretary may” before “make direct housing loans” and substituted “shall make such loans” for “shall establish and implement the pilot program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/233/s103/a/2"},"text":"Pub. L. 109–233, § 103(a)(2)","children":[],"tail":", substituted “The” for “In carrying out the pilot program under this subchapter, the”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/233/s103/a/3"},"text":"Pub. L. 109–233, § 103(a)(3)","children":[],"tail":", struck out subsec. (c) which read as follows: “No loans may be made under this subchapter after "},{"tag":"date","attrib"