{"tag":"section","attrib":{"id":"idc3fdaca0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7326"},"text":null,"children":[{"tag":"num","attrib":{"value":"7326"},"text":"§ 7326.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education and training programs on medical response to consequences of terrorist activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3fdaca1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7326/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Education Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall carry out a program to develop and disseminate a series of model education and training programs on the medical responses to the consequences of terrorist activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3fdaca2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7326/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementing Official","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The program shall be carried out through the Under Secretary for Health, in consultation with the Assistant Secretary of Veterans Affairs with responsibility for operations, preparedness, security, and law enforcement functions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3fdaca3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7326/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content of Programs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The education and training programs developed under the program shall be modelled after programs established at the F. Edward Hebért School of Medicine of the Uniformed Services University of the Health Sciences and shall include, at a minimum, training for health care professionals in the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3fdaca4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7326/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recognition of chemical, biological, radiological, incendiary, or other explosive agents, weapons, or devices that may be used in terrorist activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fdaca5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7326/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Identification of the potential symptoms of exposure to those agents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fdaca6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7326/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Understanding of the potential long-term health consequences, including psychological effects, resulting from exposure to those agents, weapons, or devices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fdaca7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7326/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Emergency treatment for exposure to those agents, weapons, or devices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fdaca8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7326/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An appropriate course of followup treatment, supportive care, and referral.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fdaca9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7326/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Actions that can be taken while providing care for exposure to those agents, weapons, or devices to protect against contamination, injury, or other hazards from such exposure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fdacaa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7326/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information on how to seek consultative support and to report suspected or actual use of those agents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3fdacab-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7326/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Potential Trainees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In designing the education and training programs under this section, the Secretary shall ensure that different programs are designed for health-care professionals in Department medical centers. The programs shall be designed to be disseminated to health professions students, graduate health and medical education trainees, and health practitioners in a variety of fields.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3fdacac-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7326/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In establishing education and training programs under this section, the Secretary shall consult with appropriate representatives of accrediting, certifying, and coordinating organizations in the field of health professions education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3fdacad-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/287/s3/a/1"},"text":"Pub. L. 107–287, § 3(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-07"},"text":"Nov. 7, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2027"},"text":"116 Stat. 2027","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3fdacae-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3fdacaf-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3fdacb0-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/287/s3/b"},"text":"Pub. L. 107–287, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-07"},"text":"Nov. 7, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2028"},"text":"116 Stat. 2028","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/287/s3/b"},"text":"“The Secretary of Veterans Affairs shall implement ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7326"},"text":"section 7326 of title 38","children":[],"tail":", United States Code, as added by subsection (a), not later than the end of the 90-day period beginning on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2002-11-07"},"text":"Nov. 7, 2002","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
