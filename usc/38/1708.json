{"tag":"section","attrib":{"id":"idc2df6c6b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1708"},"text":null,"children":[{"tag":"num","attrib":{"value":"1708"},"text":"§ 1708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary lodging","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2df6c6c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1708/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may furnish persons described in subsection (b) with temporary lodging in a Fisher house or other appropriate facility in connection with the examination, treatment, or care of a veteran under this chapter or, as provided for under subsection (e)(5), in connection with benefits administered under this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2df6c6d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1708/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Persons to whom the Secretary may provide lodging under subsection (a) are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2df6c6e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1708/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A veteran who must travel a significant distance to receive care or services under this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2df6c6f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1708/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the family of a veteran and others who accompany a veteran and provide the equivalent of familial support for such veteran.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2df6c70-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1708/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section, the term “Fisher house” means a housing facility that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2df6c71-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1708/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is located at, or in proximity to, a Department medical facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2df6c72-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1708/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is available for residential use on a temporary basis by patients of that facility and others described in subsection (b)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2df6c73-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1708/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is constructed by, and donated to the Secretary by, the Zachary and Elizabeth M. Fisher Armed Services Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2df6c74-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1708/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may establish charges for providing lodging under this section. The proceeds from such charges shall be credited to the medical services account and shall be available until expended for the purposes of providing such lodging.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2df6c75-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1708/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall prescribe regulations to carry out this section. Such regulations shall include provisions—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2df6c76-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1708/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limiting the duration of lodging provided under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2df6c77-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1708/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing standards and criteria under which charges are established for such lodging under subsection (d);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2df6c78-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1708/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing criteria for persons considered to be accompanying a veteran under subsection (b)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2df6c79-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1708/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing criteria for the use of the premises of temporary lodging facilities under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2df6c7a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1708/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing any other limitations, conditions, and priorities that the Secretary considers appropriate with respect to lodging under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2df6c7b-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/419/tII/s221/a"},"text":"Pub. L. 106–419, title II, § 221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1844"},"text":"114 Stat. 1844","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/387/tIX/s901/a/8"},"text":"Pub. L. 110–387, title IX, § 901(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4142"},"text":"122 Stat. 4142","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2df6c7c-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc2df6c7d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc2df6c7e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/387"},"text":"Pub. L. 110–387","children":[],"tail":" substituted “medical services account” for “medical care account”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
