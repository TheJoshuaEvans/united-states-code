{"tag":"section","attrib":{"id":"idc3b16217-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3749"},"text":null,"children":[{"tag":"num","attrib":{"value":"3749"},"text":"§ 3749.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revolving fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3b16218-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3749/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is established in the Treasury a revolving fund to be known as the “Department of Veterans Affairs Small Business Loan Revolving Fund” (hereinafter in this section referred to as the “fund”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3b16219-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3749/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts in the fund shall be available to the Secretary without fiscal year limitation for all loan guaranty and direct loan operations under this subchapter other than administrative expenses and may not be used for any other purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3b1621a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3749/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3b1621b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3749/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is authorized to be appropriated to the fund a total of $25,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3b1621c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3749/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There shall be deposited into the fund all amounts received by the Secretary derived from loan operations under this subchapter, including all collection of principal and interest and the proceeds from the use of property held or of property sold.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3b1621d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3749/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall determine annually whether there has developed in the fund a surplus which, in the Secretary’s judgment, is more than necessary to meet the needs of the fund. Any such surplus shall immediately be transferred into the general fund of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3b1621e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3749/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than two years after the termination of the authority of the Secretary to make new commitments for financial assistance under this subchapter, the Secretary shall transfer into the general fund of the Treasury all amounts in the fund except those that the Secretary determines may be required for the liquidation of obligations under this subchapter. All amounts received thereafter derived from loan operations under this subchapter, except so much thereof as the Secretary may determine to be necessary for liquidating outstanding obligations under this subchapter, shall also be so deposited.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3b1621f-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/72/tIII/s302/a"},"text":"Pub. L. 97–72, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-11-03"},"text":"Nov. 3, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1058"},"text":"95 Stat. 1058","children":[],"tail":", § 1849; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/576/tVII/s702/11"},"text":"Pub. L. 99–576, title VII, § 702(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3302"},"text":"100 Stat. 3302","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIII/s313/b/1"},"text":"Pub. L. 101–237, title III, § 313(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2077"},"text":"103 Stat. 2077","children":[],"tail":"; renumbered § 3749 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":", §§ 4(a)(2)(B)(v), 5(a), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/403"},"text":"105 Stat. 403","children":[],"tail":", 406.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3b16220-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3b16221-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3b16222-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1849"},"text":"section 1849 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/2/B/v"},"text":"Pub. L. 102–83, § 4(a)(2)(B)(v)","children":[],"tail":", substituted “Department of Veterans Affairs” for “Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsecs. (b) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" substituted “Secretary” and “Secretary’s” for “Administrator” and “Administrator’s”, respectively, wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576"},"text":"Pub. L. 99–576","children":[],"tail":" substituted “There” for “Effective for fiscal year 1982 and fiscal years thereafter, there”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
