{"tag":"section","attrib":{"id":"idc3544e3d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3019"},"text":null,"children":[{"tag":"num","attrib":{"value":"3019"},"text":"§ 3019.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tutorial assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3544e3e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3019/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual entitled to an educational assistance allowance under this chapter shall also be entitled to benefits provided an eligible veteran under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3492"},"text":"section 3492 of this title","children":[],"tail":", subject to the conditions applicable to an eligible veteran under such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3544e3f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3019/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of such benefits payable under this section may not exceed $100 per month, for a maximum of twelve months, or until a maximum of $1,200 is utilized. This amount is in addition to the amount of educational assistance allowance payable to the individual under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3544e40-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3019/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3544e41-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3019/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual’s period of entitlement to educational assistance under this chapter shall be charged only with respect to the amount of tutorial assistance paid to the individual under this section in excess of $600.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3544e42-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3019/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual’s period of entitlement to educational assistance under this chapter shall be charged at the rate of one month for each amount of assistance paid to the individual under this section in excess of $600 that is equal to the amount of the monthly educational assistance allowance which the individual is otherwise eligible to receive for full-time pursuit of an institutional course under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3544e43-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/689/tI/s107/a/1"},"text":"Pub. L. 100–689, title I, § 107(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4167"},"text":"102 Stat. 4167","children":[],"tail":", § 1419; renumbered § 3019 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3544e44-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3544e45-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3544e46-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1419"},"text":"section 1419 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “3492” for “1692”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
