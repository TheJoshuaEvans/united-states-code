{"tag":"section","attrib":{"id":"idc394b1f8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3684A"},"text":null,"children":[{"tag":"num","attrib":{"value":"3684A"},"text":"§ 3684A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures relating to computer matching program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc394b1f9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3684A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc394b1fa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3684A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a/p"},"text":"section 552a(p) of title 5","children":[],"tail":" and subject to paragraph (2) of this subsection, the Secretary may suspend, terminate, reduce, or make a final denial of any financial assistance or payment under an educational assistance program provided for in chapter 30 or 32 of this title or in chapter 106 of title 10 in the case of any individual, or take other adverse action against such individual, based on information produced by a matching program with the Department of Defense."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc394b1fb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3684A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may not take any action referred to in paragraph (1) of this subsection until—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc394b1fc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3684A/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual concerned has been provided a written notice containing a statement of the findings of the Secretary based on the matching program, a description of the proposed action, and notice of the individual’s right to contest such findings within 10 days after the date of the notice; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc394b1fd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3684A/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 10-day period referred to in subparagraph (A) of this paragraph has expired.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc394b1fe-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3684A/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In computing the 10-day period referred to in paragraph (2) of this subsection, Saturdays, Sundays, and Federal holidays shall be excluded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc394b1ff-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3684A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of subsection (q) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of title 5","children":[],"tail":", compliance with the provisions of subsection (a) of this section shall be considered compliance with the provisions of subsection (p) of such section 552a."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc394b200-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3684A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this section, the term “matching program” has the same meaning provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a/a/8"},"text":"section 552a(a)(8) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc394b201-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/366/tII/s206/a"},"text":"Pub. L. 101–366, title II, § 206(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-15"},"text":"Aug. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/441"},"text":"104 Stat. 441","children":[],"tail":", § 1784A; renumbered § 3684A, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc394b202-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc394b203-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc394b204-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1784A"},"text":"section 1784A of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
