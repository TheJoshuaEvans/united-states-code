{"tag":"section","attrib":{"id":"idc417eb6b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7655"},"text":null,"children":[{"tag":"num","attrib":{"value":"7655"},"text":"§ 7655.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Breach of agreement; liability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc417eb6c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7655/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc417eb6d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7655/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2), an individual who is receiving or has received a reserve member stipend under this subchapter and who fails to perform the service for which the individual is obligated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7654"},"text":"section 7654 of this title","children":[],"tail":" shall be liable to the United States in an amount determined in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7617/c/1"},"text":"section 7617(c)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc417eb6e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7655/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual who, as a result of performing active duty (including active duty for training), is unable to perform the service for which the individual is obligated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7654"},"text":"section 7654 of this title","children":[],"tail":" shall be permitted to perform that service upon completion of the active duty service (or active duty for training). The Secretary may, by regulation, waive the requirement for the performance of the service for which the individual is obligated under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7654"},"text":"section 7654 of this title","children":[],"tail":" in any case in which the Secretary determines that the individual is unable to perform the service for reasons beyond the control of the individual or in any case in which the waiver would be in the best interest of the individual and the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc417eb6f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7655/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any amount owed the United States under subsection (a) of this section shall be paid to the United States during the one-year period beginning on the date of the breach of the agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc417eb70-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/366/tII/s205/a/1"},"text":"Pub. L. 101–366, title II, § 205(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-15"},"text":"Aug. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/440"},"text":"104 Stat. 440","children":[],"tail":", § 4355; renumbered § 7655 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", (d)(1), "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":", 239.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc417eb71-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc417eb72-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc417eb73-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/b/1"},"text":"Pub. L. 102–40, § 402(b)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4355"},"text":"section 4355 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/d/1"},"text":"Pub. L. 102–40, § 402(d)(1)","children":[],"tail":", substituted “7654” for “4354” and “7617(c)(1)” for “4317(c)(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/d/1"},"text":"Pub. L. 102–40, § 402(d)(1)","children":[],"tail":", substituted “7654” for “4354” in two places."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
