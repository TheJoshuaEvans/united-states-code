{"tag":"section","attrib":{"id":"idc3e36eb7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5901"},"text":null,"children":[{"tag":"num","attrib":{"value":"5901"},"text":"§ 5901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition against acting as claims agent or attorney","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3e36eb8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5901/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s500"},"text":"section 500 of title 5","children":[],"tail":", no individual may act as an agent or attorney in the preparation, presentation, or prosecution of any claim under laws administered by the Secretary unless such individual has been recognized for such purposes by the Secretary."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3e36eb9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5901/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Warnings About Potential Predatory Practices","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3e36eba-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5901/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall ensure that, each time a claimant under a law administered by the Secretary logs in to a website or online tool of the Department, such website or online tool issues to the claimant, in plain language—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3e36ebb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5901/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a warning about individuals who seek to act in violation of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3e36ebc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5901/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a link to an online tool of the Department through which the claimant may report such an individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3e36ebd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5901/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a link to an online tool of the Department through which the claimant may search for a recognized agent, attorney, or other entity recognized by the Secretary for the preparation, presentation, or prosecution of any claim under laws administered by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3e36ebe-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5901/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a link to a website or an online tool of the Department providing final decisions on discipline of agents, attorneys, and entities, described in subparagraph (C), by the Secretary for violations of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e36ebf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5901/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall provide all information under paragraph (1) in the following languages:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3e36ec0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5901/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" English.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3e36ec1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5901/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Spanish.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3e36ec2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5901/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tagalog.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3e36ec3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5901/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The seven other languages most commonly spoken in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3e36ec4-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1238"},"text":"72 Stat. 1238","children":[],"tail":", § 3401; "},{"tag":"ref","attrib":{"href":"/us/pl