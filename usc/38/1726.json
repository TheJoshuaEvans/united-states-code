{"tag":"section","attrib":{"id":"idc30a73a9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1726"},"text":null,"children":[{"tag":"num","attrib":{"value":"1726"},"text":"§ 1726.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement for loss of personal effects by natural disaster","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall, under regulations which the Secretary shall prescribe, reimburse veterans in Department hospitals and domiciliaries for any loss of personal effects sustained by fire, earthquake, or other natural disaster while such effects were stored in designated locations in Department hospitals or domiciliaries.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc30a73aa-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1144"},"text":"72 Stat. 1144","children":[],"tail":", § 627; "},{"tag":"ref","attrib":{"href":"/us/pl/93/82/tI/s105"},"text":"Pub. L. 93–82, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-08-02"},"text":"Aug. 2, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/183"},"text":"87 Stat. 183","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/581/tII/s210/a/12"},"text":"Pub. L. 94–581, title II, § 210(a)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2863"},"text":"90 Stat. 2863","children":[],"tail":"; renumbered § 1726 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":", §§ 4(a)(3), (4), (b)(1), (2)(E), 5(a)