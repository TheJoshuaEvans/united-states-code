{"tag":"section","attrib":{"id":"idc3bf930f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4115"},"text":null,"children":[{"tag":"num","attrib":{"value":"4115"},"text":"§ 4115.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Longitudinal study of job counseling, training, and placement service for veterans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3bf9310-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4115/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Study Required","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3bf9311-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4115/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall enter into a contract with a non-government entity to conduct a longitudinal study of a statistically valid sample of each of the groups of individuals described in paragraph (2). The contract shall provide for the study of each such group over a period of at least 5 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3bf9312-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4115/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The groups of individuals described in this paragraph are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3bf9313-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4115/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Veterans who have received intensive services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bf9314-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4115/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Veterans who did not receive intensive services but who otherwise received services under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bf9315-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4115/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Veterans who did not seek or receive services under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3bf9316-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4115/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The study required by this subsection shall include the collection of the following information for each individual who participates in the study:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3bf9317-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4115/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The average number of months such individual served on active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bf9318-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4115/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The disability ratings of such individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bf9319-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4115/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any unemployment benefits received by such individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bf931a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4115/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The average number of months such individual was employed during the year covered by the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bf931b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4115/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The average annual starting and ending salaries of any such individual who was employed during the year covered by the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bf931c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4115/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The average annual income of such individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bf931d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4115/a/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The average total household income of such individual for the year covered by the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bf931e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4115/a/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The percentage of such individuals who own their principal residences.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bf931f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4115/a/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The employment status of such individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bf9320-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4115/a/3/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of such an individual who received services under this chapter, whether the individual believes that any service provided by a disabled veterans’ outreach program specialist or local veterans’ employment representative helped the individual to become employed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bf9321-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4115/a/3/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of such an individual who believes such a service helped the individual to become employed, whether—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc3bf9322-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4115/a/3/K/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual retained the position of employment for a period of 1 year or longer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3bf9323-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4115/a/3/K/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual believes such a service helped the individual to secure a higher wage or salary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bf9324-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4115/a/3/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The conditions under which such individual was discharged or released from the Armed Forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bf9325-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4115/a/3/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether such individual has used any educational assistance to which the individual is entitled under this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bf9326-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4115/a/3/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether such individual has participated in a rehabilitation program under chapter 31 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bf9327-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4115/a/3/O"},"text":null,"children":[{"tag":"num","attrib":{"value":"O"},"text":"(O)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether such individual had contact with a One-Stop Career Center employee while attending a workshop or job fair under the Transition GPS Program of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bf9328-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4115/a/3/P"},"text":null,"children":[{"tag":"num","attrib":{"value":"P"},"text":"(P)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Demographic information about such individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bf9329-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4115/a/3/Q"},"text":null,"children":[{"tag":"num","attrib":{"value":"Q"},"text":"(Q)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other information as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3bf932a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4115/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3bf932b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4115/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" By not later than July 1 of each year covered by the study required under subsection (a), the Secretary shall submit to the Committee on Veterans’ Affairs of the Senate and the Committee on Veterans’ Affairs of the House of Representatives a report on the outcomes of the study during the preceding year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3bf932c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4115/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall include in each report submitted under paragraph (1) the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3bf932d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4115/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Information with respect to job fairs attended by One-Stop Career Center employees at which the employees had contact with a veteran, including, for the year preceding the year in which the report is submitted, the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc3bf932e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4115/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of job fairs attended by One-Stop Career Center employees at which the employees had contact with a veteran.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3bf932f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4115/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of veterans contacted at each such job fair.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bf9330-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4115/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such information as the Secretary determines is necessary to determine the long-term outcomes of the individuals in the groups described in subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3bf9331-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/315/tV/s502/a"},"text":"Pub. L. 114–315, title V, § 502(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1566"},"text":"130 Stat. 1566","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
