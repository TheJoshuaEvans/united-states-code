{"tag":"section","attrib":{"id":"idc2827edd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s511"},"text":null,"children":[{"tag":"num","attrib":{"value":"511"},"text":"§ 511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decisions of the Secretary; finality","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2827ede-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s511/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall decide all questions of law and fact necessary to a decision by the Secretary under a law that affects the provision of benefits by the Secretary to veterans or the dependents or survivors of veterans. Subject to subsection (b), the decision of the Secretary as to any such question shall be final and conclusive and may not be reviewed by any other official or by any court, whether by an action in the nature of mandamus or otherwise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2827edf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s511/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The second sentence of subsection (a) does not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2827ee0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s511/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" matters subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s502"},"text":"section 502 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2827ee1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s511/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" matters covered by sections 1975 and 1984 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2827ee2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s511/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" matters arising under chapter 37 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2827ee3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s511/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" matters covered by chapter 72 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2827ee4-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s2/a"},"text":"Pub. L. 102–83, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/388"},"text":"105 Stat. 388","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2827ee5-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc2827ee6-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc2827ee7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior section 511 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1511"},"text":"section 1511 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s211/a"},"text":"section 211(a) of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s2/a"},"text":"Pub. L. 102–83, § 2(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"courtRules","id":"idc2827ee8-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Court Rules","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc2827ee9-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Federal Rules of Civil Procedure","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Writ of mandamus abolished in United States district courts, but relief available by appropriate action or motion, see rule 81, Title 28, Appendix, Judiciary and Judicial Procedure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
