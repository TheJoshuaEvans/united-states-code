{"tag":"section","attrib":{"id":"idc436e5e7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8214"},"text":null,"children":[{"tag":"num","attrib":{"value":"8214"},"text":"§ 8214.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may not use the authority under this subchapter to assist in the establishment of more than eight new medical schools. Such schools shall be located in geographically dispersed areas of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc436e5e8-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/541/s2/a"},"text":"Pub. L. 92–541, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-24"},"text":"Oct. 24, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1104"},"text":"86 Stat. 1104","children":[],"tail":", § 5074; renumbered § 8214, "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/2/B"},"text":"Pub. L. 102–40, title IV, § 402(b)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/239"},"text":"105 Stat. 239","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404"},"text":"105 Stat. 404","children":[],"tail":", 405.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc436e5e9-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc436e5ea-47c4-11f1-bf59-9680b1269b87"},"text":null,"c