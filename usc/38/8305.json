{"tag":"section","attrib":{"id":"idc436e646-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8305"},"text":null,"children":[{"tag":"num","attrib":{"value":"8305"},"text":"§ 8305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings provision","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc436e647-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing contained in this chapter shall be construed to repeal or modify any law authorizing the acceptance of devises, bequests, or gifts to the United States for their own use and benefit or for any particular purpose specified by the donors or testators.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc436e648-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever the United States receives property and it appears that it is, or shall have been, the intention of the testator or donor that such devise, bequest, or gift be for the benefit of those persons described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s8301"},"text":"section 8301 of this title","children":[],"tail":", or any particular hospital or other institution operated primarily for their benefit, such property or the proceeds thereof shall be credited to the General Post Fund, and shall be used or disbursed in accordance with the provisions of this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc436e649-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],