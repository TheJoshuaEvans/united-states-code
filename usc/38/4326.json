{"tag":"section","attrib":{"id":"idc3c92fb0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4326"},"text":null,"children":[{"tag":"num","attrib":{"value":"4326"},"text":"§ 4326.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conduct of investigation; subpoenas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3c92fb1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4326/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out any investigation under this chapter, the Secretary’s duly authorized representatives shall, at all reasonable times, have reasonable access to and the right to interview persons with information relevant to the investigation and shall have reasonable access to, for purposes of examination, and the right to copy and receive, any documents of any person or employer that the Secretary considers relevant to the investigation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3c92fb2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4326/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out any investigation under this chapter, the Secretary may require by subpoena the attendance and testimony of witnesses and the production of documents relating to any matter under investigation. In case of disobedience of the subpoena or contumacy and on request of the Secretary, the Attorney General may apply to any district court of the United States in whose jurisdiction such disobedience or contumacy occurs for an order enforcing the subpoena.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3c92fb3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4326/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon application, the district courts of the United States shall have jurisdiction to issue writs commanding any person or employer to comply with the subpoena of the Secretary or to comply with any order of the Secretary made pursuant to a lawful investigation under this chapter and the district courts shall have jurisdiction to punish failure to obey a subpoena or other lawful order of the Secretary as a contempt of court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3c92fb4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4326/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsections (b) and (c) shall not apply to the legislative branch or the judicial branch of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3c92fb5-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/353/s2/a"},"text":"Pub. L. 103–353, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3167"},"text":"108 Stat. 3167","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/275/tIII/s311/13"},"text":"Pub. L. 104–275, title III, § 311(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3336"},"text":"110 Stat. 3336","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3c92fb6-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3c92fb7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3c92fb8-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/275"},"text":"Pub. L. 104–275","children":[],"tail":" inserted “have reasonable access to and the right to interview persons with information relevant to the investigation and shall” after “at all reasonable times,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3c92fb9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3c92fba-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/275"},"text":"Pub. L. 104–275","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/275/s313"},"text":"section 313 of Pub. L. 104–275","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4301"},"text":"section 4301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3c92fbb-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", and applicable to any matter pending with Secretary of Labor under former "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4305"},"text":"section 4305 of this title","children":[],"tail":" as of that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/353/s8/e"},"text":"section 8(e) of Pub. L. 103–353","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4301"},"text":"section 4301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
