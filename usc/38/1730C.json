{"tag":"section","attrib":{"id":"idc30cbd72-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1730C"},"text":null,"children":[{"tag":"num","attrib":{"value":"1730C"},"text":"§ 1730C.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Licensure of health care professionals providing treatment via telemedicine","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc30cbd73-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1730C/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any provision of law regarding the licensure of health care professionals, a covered health care professional may practice the health care profession of the health care professional at any location in any State or any of the Freely Associated States (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1724/f"},"text":"section 1724(f) of this title","children":[],"tail":"), regardless of where the covered health care professional or the patient is located, if the covered health care professional is using telemedicine to provide treatment to an individual under this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc30cbd74-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1730C/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Health Care Professionals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, a covered health care professional is any of the following individuals:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc30cbd75-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1730C/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A health care professional who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc30cbd76-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1730C/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an employee of the Department appointed under section 7306, 7401, 7405, 7406, or 7408 of this title or under title 5;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc30cbd77-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1730C/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is authorized by the Secretary to provide health care under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc30cbd78-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1730C/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is required to adhere to all standards for quality relating to the provision of health care in accordance with applicable policies of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc30cbd79-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1730C/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc30cbd7a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1730C/b/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has an active, current, full, and unrestricted license, registration, or certification in a State to practice the health care profession of the health care professional; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc30cbd7b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1730C/b/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a health care profession listed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7402/b"},"text":"section 7402(b) of this title","children":[],"tail":", has the qualifications for such profession as set forth by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30cbd7c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1730C/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A postgraduate health care employee who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc30cbd7d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1730C/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is appointed under section 7401(1), 7401(3), or 7405 of this title or title 5 for any category of personnel described in paragraph (1) or (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401"},"text":"section 7401 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc30cbd7e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1730C/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" must obtain an active, current, full, and unrestricted license, registration, or certification or meet qualification standards set forth by the Secretary within a specified time frame; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc30cbd7f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1730C/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is under the clinical supervision of a health care professional described in paragraph (1); or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30cbd80-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1730C/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A health professions trainee who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc30cbd81-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1730C/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is appointed under section 7405 or 7406 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc30cbd82-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1730C/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is under the clinical supervision of a health care professional described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc30cbd83-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1730C/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Property of Federal Government","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) shall apply to a covered health care professional providing treatment to a patient regardless of whether the covered health care professional or patient is located in a facility owned by the Federal Government during such treatment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc30cbd84-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1730C/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relation to State Law","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc30cbd85-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1730C/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of this section shall supersede any provisions of the law of any State to the extent that such provision of State law are inconsistent with this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30cbd86-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1730C/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No State shall deny or revoke the license, registration, or certification of a covered health care professional who otherwise meets the qualifications of the State for holding the license, registration, or certification on the basis that the covered health care professional has engaged or intends to engage in activity covered by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc30cbd87-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1730C/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section may be construed to remove, limit, or otherwise affect any obligation of a covered health care professional under the Controlled Substances Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s801"},"text":"21 U.S.C. 801","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc30cbd88-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1730C/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “State” means a State, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s101/20"},"text":"section 101(20) of this title","children":[],"tail":", or a political subdivision of a State."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc30cbd89-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/182/tI/s151/a"},"text":"Pub. L. 115–182, title I, § 151(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-06"},"text":"June 6, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1430"},"text":"132 Stat. 1430","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dH/tXCI/s9101"},"text":"Pub. L. 116–283, div. H, title XCI, § 9101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4780"},"text":"134 Stat. 4780","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/42/dG/tII/s209/a/4/B"},"text":"Pub. L. 118–42, div. G, title II, § 209(a)(4)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-03-09"},"text":"Mar. 9, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/441"},"text":"138 Stat. 441","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc30cbd8a-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc30cbd8b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc30cbd8c-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Controlled Substances Act, referred to in subsec. (e), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513"},"text":"Pub. L. 91–513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1242"},"text":"84 Stat. 1242","children":[],"tail":", which is classified principally to subchapter I (§ 801 et seq.) of chapter 13 of Title 21, Food and Drugs. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s801"},"text":"section 801 of Title 21","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc30cbd8d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/42"},"text":"Pub. L. 118–42","children":[],"tail":" substituted “any State or any of the Freely Associated States (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1724/f"},"text":"section 1724(f) of this title","children":[],"tail":")” for “any State”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, subsec. (b) related to who were considered covered health care professionals."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
