{"tag":"section","attrib":{"id":"idc436e5bd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8211"},"text":null,"children":[{"tag":"num","attrib":{"value":"8211"},"text":"§ 8211.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Declaration of purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The purpose of this subchapter is to authorize the Secretary to implement a pilot program under which the Secretary may provide assistance in the establishment of new State medical schools at colleges or universities which are primarily supported by the States in which they are located if such schools are located in proximity to, and operated in conjunction with, Department medical facilities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc436e5be-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/541/s2/a"},"text":"Pub. L. 92–541, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-24"},"text":"Oct. 24, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1102"},"text":"86 Stat. 1102","children":[],"tail":", § 5071; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/581/tII/s210/f/2"},"text":"Pub. L. 94–581, title II, § 210(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2865"},"text":"90 Stat. 2865","children":[],"tail":"; renumbered § 8211, "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/2/B"},"text":"Pub. L. 102–40, title IV, § 402(b)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/239"},"text":"105 Stat. 239","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/3"},"text":"Pu