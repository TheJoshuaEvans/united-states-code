{"tag":"section","attrib":{"id":"idc33554c5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2051"},"text":null,"children":[{"tag":"num","attrib":{"value":"2051"},"text":"§ 2051.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc33554c6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2051/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may guarantee the full or partial repayment of a loan that meets the requirements of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc33554c7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2051/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc33554c8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2051/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than 15 loans may be guaranteed under subsection (a), of which not more than five such loans may be guaranteed during the 3-year period beginning on the date of the enactment of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc33554c9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2051/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A guarantee of a loan under subsection (a) shall be in an amount that is not less than the amount necessary to sell the loan in a commercial market.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc33554ca-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2051/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than an aggregate amount of $100,000,000 in loans may be guaranteed under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc33554cb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2051/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A loan may not be guaranteed under this subchapter unless, before closing such loan, the Secretary has approved the loan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc33554cc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2051/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc33554cd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2051/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall enter into contracts with a qualified nonprofit organization, or other qualified organization, that has experience in underwriting transitional housing projects to obtain advice in carrying out this subchapter, including advice on the terms and conditions necessary for a loan that meets the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2052"},"text":"section 2052 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc33554ce-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2051/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of paragraph (1), a nonprofit organization is an organization that is described in paragraph (3) or (4) of subsection (c) of section 501 of the Internal Revenue Code of 1986 and is exempt from tax under subsection (a) of such section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc33554cf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2051/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may carry out this subchapter in advance of the issuance of regulations for such purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc33554d0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2051/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may guarantee loans under this subchapter notwithstanding any requirement for prior appropriations for such purpose under any provision of law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc33554d1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2051/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, a multifamily transitional housing project that is funded by a loan guaranteed under this subchapter may accept uncompensated voluntary services performed by any eligible entity (as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2011/d"},"text":"section 2011(d) of this title","children":[],"tail":") in connection with the construction, alteration, or repair of such project."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc33554d2-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/tVI/s601/a"},"text":"Pub. L. 105–368, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3342"},"text":"112 Stat. 3342","children":[],"tail":", § 3772; renumbered § 2051 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/95/s5/d/1"},"text":"Pub. L. 107–95, § 5(d)(1)","children":[],"tail":", (2)(B), "},{"tag":"date","attrib":{"date":"2001-12-21"},"text":"Dec. 21, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/918"},"text":"115 Stat. 918","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/454/tIV/s402/a"},"text":"Pub. L. 108–454, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-10"},"text":"Dec. 10, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3615"},"text":"118 Stat. 3615","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc33554d3-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc33554d4-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc33554d5-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this subchapter, referred to in subsec. (b)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368"},"text":"Pub. L. 105–368","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 501 of the Internal Revenue Code of 1986, referred to in subsec. (d)(2), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501"},"text":"section 501 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc33554d6-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/454"},"text":"Pub. L. 108–454","children":[],"tail":" added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/95/s5/d/1"},"text":"Pub. L. 107–95, § 5(d)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3772"},"text":"section 3772 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/95/s5/d/2/B"},"text":"Pub. L. 107–95, § 5(d)(2)(B)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2052"},"text":"section 2052 of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3773"},"text":"section 3773 of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc33554d7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc33554d8-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/368/s602/f"},"text":"section 602(f) of Pub. L. 105–368","children":[],"tail":", set out as an Effective Date of 1998 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2106"},"text":"section 2106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
