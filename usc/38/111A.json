{"tag":"section","attrib":{"id":"idc271dcea-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s111A"},"text":null,"children":[{"tag":"num","attrib":{"value":"111A"},"text":"§ 111A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation of individuals to and from Department facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc271dceb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s111A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transportation by Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc271dcec-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s111A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may transport any person to or from a Department facility or other place in connection with vocational rehabilitation, counseling required by the Secretary pursuant to chapter 34 or 35 of this title, or for the purpose of examination, treatment, or care.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc271dced-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s111A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority granted by paragraph (1) shall expire on ","children":[{"tag":"date","attrib":{"date":"2026-09-30"},"text":"September 30, 2026","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc271dcee-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s111A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transportation by Third-parties","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc271dcef-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s111A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary, in consultation and coordination with the Secretary of Transportation and appropriate representatives of veterans’ service organizations, shall take all appropriate steps to facilitate the establishment and maintenance of a program under which such organizations, or individuals who are volunteering their services to the Department, would take responsibility for the transportation, without reimbursement from the Department, to Department facilities of veterans (primarily those residing in areas which are geographically accessible to such facilities) who seek services or benefits from the Department under chapter 17 or other provisions of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc271dcf0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s111A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc271dcf1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s111A/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 90 days after the date of the enactment of the Johnny Isakson and David P. Roe, M.D. Veterans Health Care and Benefits Improvement Act of 2020, the Secretary shall develop and establish a national protocol for the administration of medical examinations for volunteer drivers to participate in the program described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc271dcf2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s111A/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In developing the protocol required by subparagraph (A), the Secretary shall consult with such persons as the Secretary determines have an interest in the program described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc271dcf3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s111A/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc271dcf4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s111A/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall implement the protocol by first conducting a one-year pilot program using the protocol.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc271dcf5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s111A/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After conducting the pilot program required by clause (i), the Secretary shall assess the pilot program and make such changes to the protocol as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc271dcf6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s111A/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After making changes to the protocol under clause (ii), the Secretary shall implement the protocol in phases during the course of one year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc271dcf7-47c4-11f1-bf59-9680b1269b87"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/260/tII/s202/a"},"text":"Pub. L. 112–260, title II, § 202(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2013-01-10"},"text":"Jan. 10, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2423"},"text":"126 Stat. 2423","children":[],"tail":", 2424; "},{"tag":"ref","attrib":{"href":"/us/pl/113/59/s6"},"text":"Pub. L. 113–59, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-20"},"text":"Dec. 20, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/662"},"text":"127 Stat. 662","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/175/tIV/s401"},"text":"Pub. L. 113–175, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-09-26"},"text":"Sept. 26, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1905"},"text":"128 Stat. 1905","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/58/tIV/s401"},"text":"Pub. L. 114–58, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-09-30"},"text":"Sept. 30, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/534"},"text":"129 Stat. 534","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/228/tIV/s401"},"text":"Pub. L. 114–228, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-09-29"},"text":"Sept. 29, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/939"},"text":"130 Stat. 939","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/62/tIV/s401"},"text":"Pub. L. 115–62, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-09-29"},"text":"Sept. 29, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1164"