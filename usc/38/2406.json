{"tag":"section","attrib":{"id":"idc345f632-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2406"},"text":null,"children":[{"tag":"num","attrib":{"value":"2406"},"text":"§ 2406.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of lands","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc345f633-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2406/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As additional lands are needed for national cemeteries, they may be acquired by the Secretary by purchase, gift (including donations from States or political subdivisions thereof), condemnation, transfer from other Federal agencies, exchange, or otherwise, as the Secretary determines to be in the best interest of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc345f634-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2406/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of Department of the Interior Land for Use as a National Cemetery","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding section 204(d) of the Federal Land Policy and Management Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1714/d"},"text":"43 U.S.C. 1714(d)","children":[],"tail":"), if the Secretary and the Secretary of the Interior agree to a transfer under subsection (a) of any land for use by the Department as a national cemetery, the land shall be—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc345f635-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2406/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" withdrawn from all forms of appropriation under the public land laws, including the mining laws, the mineral leasing laws, and the geothermal leasing laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc345f636-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2406/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to valid existing rights;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc345f637-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2406/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transferred to the administrative jurisdiction of the Secretary of Veterans Affairs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc345f638-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2406/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deemed to be property (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s102/9"},"text":"section 102(9) of title 40","children":[],"tail":") for as long as the land remains under the administrative jurisdiction of the Secretary of Veterans Affairs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc345f639-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/43/s2/a"},"text":"Pub. L. 93–43, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-06-18"},"text":"June 18, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/78"},"text":"87 Stat. 78","children":[],"tail":", § 1006; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/576/tVII/s701/57"},"text":"Pub. L. 99–576, title VII, § 701(57)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3295"},"text":"100 Stat. 3295","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIII/s313/b/1"},"text":"Pub. L. 101–237, title III, § 313(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2077"},"text":"103 Stat. 2077","children":[],"tail":"; renumbered § 2406, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/454/tVI/s603"},"text":"Pub. L. 108–454, title VI, § 603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-10"},"text":"Dec. 10, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3624"},"text":"118 Stat. 3624","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/355/s5"},"text":"Pub. L. 117–355, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6279"},"text":"136 Stat. 6279","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc345f63a-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc345f63b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc345f63c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/355"},"text":"Pub. L. 117–355","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Pub. L. 108—454 inserted “exchange,” after “agencies,”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1006"},"text":"section 1006 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" substituted “Secretary” for “Administrator” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576"},"text":"Pub. L. 99–576","children":[],"tail":" substituted “the Administrator” for “he”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
