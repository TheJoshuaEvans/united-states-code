{"tag":"section","attrib":{"id":"idc3676130-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3315"},"text":null,"children":[{"tag":"num","attrib":{"value":"3315"},"text":"§ 3315.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Licensure and certification tests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3676131-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3315/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual entitled to educational assistance under this chapter shall also be entitled to payment for licensing or certification tests described in section 3452(b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3676132-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3315/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Amount","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount payable under subsection (a) for a licensing or certification test may not exceed the lesser of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3676133-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3315/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3676134-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3315/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fee charged for the test; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3676135-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3315/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of entitlement available to the individual under this chapter at the time of payment for the test under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3676136-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3315/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Charge Against Entitlement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The charge against an individual’s entitlement under this chapter for payment for a licensing or certification test shall be pro-rated based on the actual amount of the fee charged for the test relative to the rate for 1 month payable—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3676137-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3315/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the academic year beginning on ","children":[{"tag":"date","attrib":{"date":"2011-08-01"},"text":"August 1, 2011","children":[],"tail":", $1,460; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3676138-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3315/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for an academic year beginning on any subsequent August 1, the amount for the previous academic year beginning on August 1 under this subsection, as increased by the percentage increase equal to the most recent percentage increase determined under section 3015(h).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3676139-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/252/tV/s5003/a/1"},"text":"Pub. L. 110–252, title V, § 5003(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-30"},"text":"June 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2367"},"text":"122 Stat. 2367","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/377/tI/s107/a"},"text":"Pub. L. 111–377, title I, § 107(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4118"},"text":"124 Stat. 4118","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/48/tI/s108/a"},"text":"Pub. L. 115–48, title I, § 108(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-16"},"text":"Aug. 16, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/978"},"text":"131 Stat. 978","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc367613a-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc367613b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc367613c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/48"},"text":"Pub. L. 115–48","children":[],"tail":", in introductory provisions, substituted “shall be pro-rated based on the actual amount of the fee charged for the test relative to the rate for 1 month payable” for “shall be determined at the rate of one month (rounded to the nearest whole month) for each amount paid that equals”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/377/s107/a"},"text":"Pub. L. 111–377, § 107(a)","children":[],"tail":", substituted “licensing or certification tests” for “one licensing or certification test”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/377/s107/b/2"},"text":"Pub. L. 111–377, § 107(b)(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/377/s107/b/1"},"text":"Pub. L. 111–377, § 107(b)(1)","children":[],"tail":", amended subsec. (c) generally. Prior to amendment, text read as follows: “Any amount paid an individual under subsection (a) is in addition to any other educational assistance benefits provided the individual under this chapter.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc367613d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc367613e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/48/tI/s108/d"},"text":"Pub. L. 115–48, title I, § 108(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-16"},"text":"Aug. 16, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/978"},"text":"131 Stat. 978","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/48/tI/s108/d"},"text":"“The amendments made by this Act [probably should be “this section”, amending this section and sections 3315A and 3452 of this title] shall apply to a test taken on or after ","children":[{"tag":"date","attrib":{"date":"2018-08-01"},"text":"August 1, 2018","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc367613f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/377/tI/s107/c"},"text":"Pub. L. 111–377, title I, § 107(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4118"},"text":"124 Stat. 4118","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/377/tI/s107/c"},"text":"“The amendments made by this section [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2011-08-01"},"text":"August 1, 2011","children":[],"tail":", and shall apply with respect to licensure and certification tests taken on or after that date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3676140-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2009-08-01"},"text":"Aug. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/252/s5003/d"},"text":"section 5003(d) of Pub. L. 110–252","children":[],"tail":", set out as an Effective Date of 2008 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s16163"},"text":"section 16163 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
