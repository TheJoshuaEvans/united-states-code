{"tag":"section","attrib":{"id":"idc3cdea69-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5103"},"text":null,"children":[{"tag":"num","attrib":{"value":"5103"},"text":"§ 5103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to claimants of required information and evidence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3cdea6a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required Information and Evidence","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3cdea6b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (3), the Secretary shall provide to the claimant and the claimant’s representative, if any, by the most effective means available, including electronic communication or notification in writing, notice of any information, and any medical or lay evidence, not previously provided to the Secretary that is necessary to substantiate the claim. As part of that notice, the Secretary shall indicate which portion of that information and evidence, if any, is to be provided by the claimant and which portion, if any, the Secretary, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5103A"},"text":"section 5103A of this title","children":[],"tail":" and any other applicable provisions of law, will attempt to obtain on behalf of the claimant."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3cdea6c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3cdea6d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5103/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall prescribe in regulations requirements relating to the contents of notice to be provided under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3cdea6e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5103/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The regulations required by this paragraph—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc3cdea6f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5103/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall specify different contents for notice based on whether the claim concerned is an original claim or a supplemental claim;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3cdea70-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5103/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide that the contents for such notice be appropriate to the type of benefits or services sought under the claim;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3cdea71-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5103/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall specify for each type of claim for benefits the general information and evidence required to substantiate the basic elements of such type of claim; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3cdea72-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5103/a/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall specify the time period limitations required pursuant to subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3cdea73-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5103/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The requirement to provide notice under paragraph (1) shall not apply with respect to a supplemental claim that is filed within the timeframe set forth in subparagraphs (B) and (D) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5110/a/2"},"text":"section 5110(a)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3cdea74-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3cdea75-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of information or evidence that the claimant is notified under subsection (a) is to be provided by the claimant, such information or evidence must be received by the Secretary within one year from the date such notice is sent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3cdea76-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This subsection shall not apply to any application or claim for Government life insurance benefits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3cdea77-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5103/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in paragraph (1) shall be construed to prohibit the Secretary from making a decision on a claim before the expiration of the period referred to in that subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3cdea78-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5103/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Nothing in this section shall require the Secretary to provide notice for a subsequent claim that is filed while a previous claim is pending if the notice previously provided for such pending claim—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3cdea79-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5103/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides sufficient notice of the information and evidence necessary to substantiate such subsequent claim; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3cdea7a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5103/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was sent within one year of the date on which the subsequent claim was filed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3cdea7b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5103/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3cdea7c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5103/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall not apply to any claim or issue where the Secretary may award the maximum benefit in accordance with this title based on the evidence of record.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3cdea7d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5103/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this paragraph, the term “maximum benefit” means the highest evaluation assignable in accordance with the evidence of record, as long as such evidence is adequate for rating purposes and sufficient to grant the earliest possible effective date in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5110"},"text":"section 5110 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3cdea7e-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/475/s3/a"},"text":"Pub. L. 106–475, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2096"},"text":"114 Stat. 2096","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/14/s8/a/12"},"text":"Pub. L. 107–14, § 8(a)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-06-05"},"text":"June 5, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/35"},"text":"115 Stat. 35","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/183/tVII/s701/b"},"text":"Pub. L. 108–183, title VII, § 701(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-16"},"text":"Dec. 16, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2670"},"text":"117 Stat. 2670","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/389/tI/s101/a"},"text":"Pub. L. 110–389, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4147"},"text":"122 Stat. 4147","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/154/tV/s504/a"},"text":"Pub. L. 112–154, title V, § 504(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1191"},"text":"126 Stat. 1191","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/55/s2/b"},"text":"Pub. L. 115–55, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-23"},"text":"Aug. 23, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1105"},"text":"131 Stat. 1105","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3d05b7f-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3d05b80-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc3d05b81-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5103, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1225"},"text":"72 Stat. 1225","children":[],"tail":", § 3003; "},{"tag":"ref","attrib":{"href":"/us/pl/99/570/tXI/s11007/a/1"},"text":"Pub. L. 99–570, title XI, § 11007(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-170"},"text":"100 Stat. 3207–170","children":[],"tail":"; renumbered § 5103, "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/1"},"text":"Pub. L. 102–83, § 4(a)(1)","children":[],"tail":", (b)(1), (2)(E), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/403-405"},"text":"105 Stat. 403–405","children":[],"tail":", related to incomplete applications, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/106/475/s3/a"},"text":"Pub. L. 106–475, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2096"},"text":"114 Stat. 2096","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 5103 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s8303"},"text":"section 8303 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3d05b82-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/55/s2/b/1"},"text":"Pub. L. 115–55, § 2(b)(1)","children":[],"tail":", substituted “Except as provided in paragraph (3), the” for “The”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/55/s2/b/2"},"text":"Pub. L. 115–55, § 2(b)(2)","children":[],"tail":", substituted “or a supplemental claim;” for “, a claim for reopening a prior decision on a claim, or a claim for an increase in benefits;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/55/s2/b/3"},"text":"Pub. L. 115–55, § 2(b)(3)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/154/s504/a/1"},"text":"Pub. L. 112–154, § 504(a)(1)","children":[],"tail":", substituted “The” for “Upon receipt of a complete or substantially complete application, the” and “provide to” for “notify” and inserted “by the most effective means available, including electronic communication or notification in writing, notice” before “of any information”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/154/s504/a/2"},"text":"Pub. L. 112–154, § 504(a)(2)","children":[],"tail":", added pars. (4) and (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/389"},"text":"Pub. L. 110–389","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/183/s701/b/1"},"text":"Pub. L. 108–183, § 701(b)(1)","children":[],"tail":", substituted “such information or evidence must be received by the Secretary within one year from the date such notice is sent” for “if such information or evidence is not received by the Secretary within one year from the date of such notification, no benefit may be paid or furnished by reason of the claimant’s application”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/183/s701/b/2"},"text":"Pub. L. 108–183, § 701(b)(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/14"},"text":"Pub. L. 107–14","children":[],"tail":" substituted “one year” for “1 year”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3d05b83-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3d05b84-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/55"},"text":"Pub. L. 115–55","children":[],"tail":" applicable to all claims for which the Secretary of Veterans Affairs provides notice of a decision under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5104"},"text":"section 5104 of this title","children":[],"tail":" on or after the later of 540 days after "},{"tag":"date","attrib":{"date":"2017-08-23"},"text":"Aug. 23, 2017","children":[],"tail":", or 30 days after the date on which the Secretary submits to Congress a certification of certain capabilities of the Department of Veterans Affairs to carry out the new appeals system established by "},{"tag":"ref","attrib":{"href":"/us/pl/115/55"},"text":"Pub. L. 115–55","children":[],"tail":" and to address appeals of decisions on legacy claims, with provision for early applicability of the new appeals system to certain claims, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/55/s2/x"},"text":"section 2(x) of Pub. L. 115–55","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of this title","children":[],"tail":", and bracketed note thereunder."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3d05b85-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/154/tV/s504/c"},"text":"Pub. L. 112–154, title V, § 504(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1192"},"text":"126 Stat. 1192","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/154/tV/s504/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by subsection (a) [amending this section] shall take effect on the date that is 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":"] and shall apply with respect to notification obligations of the Secretary of Veterans Affairs on or after such date."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction regarding applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section [amending this section and enacting provisions set out as a note below] or the amendments made by this section shall be construed to require the Secretary to carry out notification procedures in accordance with requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5103"},"text":"section 5103 of title 38","children":[],"tail":", United States Code, as in effect on the day before the effective date established in paragraph (1) on or after such effective date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3d05b86-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment effective as if enacted ","children":[{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", immediately after the enactment of the Veterans Claims Assistance Act of 2000, "},{"tag":"ref","attrib":{"href":"/us/pl/106/475"},"text":"Pub. L. 106–475","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/183/s701/c"},"text":"section 701(c) of Pub. L. 108–183","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5102"},"text":"section 5102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3d05b87-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/154/tV/s504/b"},"text":"Pub. L. 112–154, title V, § 504(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1192"},"text":"126 Stat. 1192","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/154/tV/s504/b"},"text":"“Nothing in the amendments made by subsection (a) [amending this section] shall be construed as eliminating any requirement with respect to the contents of a notice under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5103"},"text":"section 5103 of title 38","children":[],"tail":", United States Code, that is required under regulations prescribed pursuant to subsection (a)(2) of such section as of the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3d05b88-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Applicability of Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/389/tI/s101/b"},"text":"Pub. L. 110–389, title I, § 101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4148"},"text":"122 Stat. 4148","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/389/tI/s101/b"},"text":"“The regulations required by paragraph (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5103/a"},"text":"section 5103(a) of title 38","children":[],"tail":", United States Code (as amended by subsection (a) of this section), shall apply with respect to notices provided to claimants on or after the effective date of such regulations.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3d05b89-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Readjudication of Certain Claims; Notice","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/183/tVII/s701/d"},"text":"Pub. L. 108–183, title VII, § 701(d)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"2003-12-16"},"text":"Dec. 16, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2670"},"text":"117 Stat. 2670","children":[],"tail":", 2671, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/183/tVII/s701/d"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures for Readjudication of Certain Claims","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Veterans Affairs shall readjudicate a claim of a qualified claimant if the request for such readjudication is received not later than the end of the one-year period that begins on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2003-12-16"},"text":"Dec. 16, 2003","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this subsection, a claimant is qualified within the meaning of paragraph (1) if the claimant—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" received notice under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5103/a"},"text":"section 5103(a) of title 38","children":[],"tail":", United States Code, requesting information or evidence to substantiate a claim;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" did not submit such information or evidence within a year after the date such notice was sent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" did not file a timely appeal to the Board of Veterans’ Appeals or the United States Court of Appeals for Veterans Claims; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits such information or evidence during the one-year period referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the decision of the Secretary on a readjudication under this subsection is in favor of the qualified claimant, the award of the grant shall take effect as if the prior decision by the Secretary on the claim had not been made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Nothing in this subsection shall be construed to establish a duty on the part of the Secretary to identify or readjudicate any claim that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not submitted during the one-year period referred to in paragraph (1); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been the subject of a timely appeal to the Board of Veterans’ Appeals or the United States Court of Appeals for Veterans Claims.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction on Providing Renotification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5102"},"text":"section 5102 of this title","children":[],"tail":" and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5102"},"text":"section 5102 of this title","children":[],"tail":"], or the amendments made by this section, shall be construed to require the Secretary of Veterans Affairs—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide notice under section 5103(a) of such title with respect to a claim insofar as the Secretary has previously provided such notice; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide for a special notice with respect to this section and the amendments made by this section.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
