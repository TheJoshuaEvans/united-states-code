{"tag":"section","attrib":{"id":"idc3d9d195-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5318"},"text":null,"children":[{"tag":"num","attrib":{"value":"5318"},"text":"§ 5318.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of Social Security Administration death information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3d9d196-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5318/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall periodically compare Department of Veterans Affairs information regarding persons to or for whom compensation or pension is being paid with information in the records of the Social Security Administration relating to persons who have died for the purposes of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3d9d197-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5318/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determining whether any such persons to whom compensation and pension is being paid are deceased;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d9d198-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5318/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring that such payments to or for any such persons who are deceased are terminated in a timely manner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d9d199-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5318/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring that collection of overpayments of such benefits resulting from payments after the death of such persons is initiated in a timely manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d9d19a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5318/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Social Security Administration death information referred to in subsection (a) of this section is death information available to the Secretary from or through the Commissioner of Social Security, including death information available to the Commissioner from a State, pursuant to a memorandum of understanding entered into by the Secretary and the Commissioner. Any such memorandum of understanding shall include safeguards to assure that information made available under it is not used for unauthorized purposes or improperly disclosed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3d9d19b-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/tVIII/s8053/b/1"},"text":"Pub. L. 101–508, title VIII, § 8053(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-352"},"text":"104 Stat. 1388–352","children":[],"tail":", § 3118; renumbered § 5318, "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/183/tVII/s708/c/4/A"},"text":"Pub. L. 108–183, title VII, § 708(c)(4)(A)","children":[],"tail":", (B)(i), "},{"tag":"date","attrib":{"date":"2003-12-16"},"text":"Dec. 16, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2674"},"text":"117 Stat. 2674","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3d9d19c-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3d9d19d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3d9d19e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/183/s708/c/4/B/i"},"text":"Pub. L. 108–183, § 708(c)(4)(B)(i)","children":[],"tail":", substituted “Social Security Administration” for “Department of Health and Human Services” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/183/s708/c/4/A/i"},"text":"Pub. L. 108–183, § 708(c)(4)(A)(i)","children":[],"tail":", substituted “Social Security Administration” for “Department of Health and Human Services” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/183/s708/c/4/A/ii"},"text":"Pub. L. 108–183, § 708(c)(4)(A)(ii)","children":[],"tail":", substituted “Social Security Administration” for “Department of Health and Human Services”, “Commissioner of Social Security” for “Secretary of Health and Human Services” after “through the”, “Commissioner” for “Secretary of Health and Human Services” after “available to the”, and “the Secretary and the Commissioner” for “such Secretaries”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3118"},"text":"section 3118 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
