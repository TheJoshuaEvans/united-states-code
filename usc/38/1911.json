{"tag":"section","attrib":{"id":"idc3165aa0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1911"},"text":null,"children":[{"tag":"num","attrib":{"value":"1911"},"text":"§ 1911.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forfeiture","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person guilty of mutiny, treason, spying, or desertion, or who, because of conscientious objections, refuses to perform service in the Armed Forces of the United States or refuses to wear the uniform of such force, shall forfeit all rights to National Service Life Insurance. No insurance shall be payable for death inflicted as a lawful punishment for crime or for military or naval offense, except when inflicted by an enemy of the United States; but the cash surrender value, if any, of such insurance on the date of such death shall be paid to the designated beneficiary, if living, or otherwise to the beneficiary or beneficiaries within the permitted class in accordance with the order specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1916/b"},"text":"section 1916(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc3165aa1-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1150"},"text":"72 Stat. 1150","children":[],"tail":", § 711; renumbered § 1911 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3165aa2-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3165aa3-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3165aa4-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s711"},"text":"section 711 of this title","children":[],"tail":" as this section and substituted “1916(b)” for “716(b)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
