{"tag":"section","attrib":{"id":"idc38b3bda-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3674A"},"text":null,"children":[{"tag":"num","attrib":{"value":"3674A"},"text":"§ 3674A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations of agency performance; qualifications and performance of agency personnel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc38b3bdb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3674A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc38b3bdc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3674A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc38b3bdd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3674A/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct, in conjunction with State approving agencies, an annual evaluation of each State approving agency on the basis of standards developed by the Secretary in conjunction with the State approving agencies, and (B) provide each such agency an opportunity to comment on the evaluation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc38b3bde-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3674A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into account the results of annual evaluations carried out under paragraph (1) when negotiating the terms and conditions of a contract or agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3674"},"text":"section 3674 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc38b3bdf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3674A/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperate with State approving agencies in developing and implementing a uniform national curriculum, to the extent practicable, for training new employees and for continuing the training of employees of such agencies, and sponsor, with the agencies, such training and continuation of training; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc38b3be0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3674A/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe prototype qualification and performance standards, developed in conjunction with State approving agencies, for use by such agencies in the development of qualification and performance standards for State approving agency personnel carrying out approval responsibilities under a contract or agreement entered into under section 3674(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc38b3be1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3674A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc38b3be2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3674A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each State approving agency carrying out a contract or agreement with the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3674/a"},"text":"section 3674(a) of this title","children":[],"tail":" shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc38b3be3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3674A/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apply qualification and performance standards based on the standards developed under subsection (a)(4); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc38b3be4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3674A/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available to any person, upon request, the criteria used to carry out its functions under a contract or agreement entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3674/a"},"text":"section 3674(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc38b3be5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3674A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In developing and applying standards described in subsection (a)(4), the State approving agency may take into consideration the State’s merit system requirements and other local requirements and conditions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc38b3be6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3674A/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall provide assistance in developing such standards to a State approving agency that requests it.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc38b3be7-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323/s13/b/1/A"},"text":"Pub. L. 100–323, § 13(b)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/572"},"text":"102 Stat. 572","children":[],"tail":", § 1774A; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIV/s423/b/1/A"},"text":"Pub. L. 101–237, title IV, § 423(b)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2092"},"text":"103 Stat. 2092","children":[],"tail":"; renumbered § 3674A and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/446/tVI/s606/c"},"text":"Pub. L. 103–446, title VI, § 606(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4672"},"text":"108 Stat. 4672","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/368/tX/s1005/b/8"},"text":"Pub. L. 105–368, title X, § 1005(b)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3365"},"text":"112 Stat. 3365","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/14/s8/a/8"},"text":"Pub. L. 107–14, § 8(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-06-05"},"text":"June 5, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/35"},"text":"115 Stat. 35","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc38b3be8-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc38b3be9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc38b3bea-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/14"},"text":"Pub. L. 107–14","children":[],"tail":" substituted “paragraph (1)” for “clause (1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368"},"text":"Pub. L. 105–368","children":[],"tail":" struck out “after the 18-month period beginning on the date of the enactment of this section” after “"},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3674/a"},"text":"section 3674(a) of this title","children":[],"tail":"” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(3) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446/s606/c/1"},"text":"Pub. L. 103–446, § 606(c)(1)","children":[],"tail":", redesignated pars. (4) and (5) as (3) and (4), respectively, and struck out former par. (3) which read as follows: “supervise functionally the provision of course-approval services by State approving agencies under this subchapter;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446/s606/c/2/A"},"text":"Pub. L. 103–446, § 606(c)(2)(A)","children":[],"tail":", substituted “subsection (a)(4)” for “subsection (a)(5) of this section” in pars. (1)(A) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446/s606/c/2/B"},"text":"Pub. L. 103–446, § 606(c)(2)(B)","children":[],"tail":", inserted “of this title” after “section 3674(a)” in introductory provisions and subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1774A"},"text":"section 1774A of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “3674” for “1774” in par. (2) and “3674(a)” for “1774(a)” in par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “3674(a)” for “1774(a)” in introductory provisions and in subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" substituted “Secretary” for “Administrator” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc38b3beb-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc38b3bec-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323/s13/b/2"},"text":"Pub. L. 100–323, § 13(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/573"},"text":"102 Stat. 573","children":[],"tail":", directed Administrator, for purposes of implementing amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/100/323/s13/b/1"},"text":"section 13(b)(1) of Pub. L. 100–323","children":[],"tail":", and within 120 days after "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", to publish prototype standards developed under subsec. (a)(5) of this section, directed each State approving agency, within 1 year after Administrator published the standards, to submit to Administrator a copy of the standards to be implemented by such agency under subsec. (b)(1)(A) of this section, and provided that Administrator could comment on consistency of the State’s standards and prototype standards."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc38b3bed-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Applicability of Qualification Standards to Persons Employed on ","children":[{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323/s13/b/3"},"text":"Pub. L. 100–323, § 13(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/573"},"text":"102 Stat. 573","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/323/s13/b/3"},"text":"“None of the qualification standards implemented pursuant to the amendments made by paragraph (1) [enacting this section] shall apply to any person employed by a State approving agency on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":"] as long as such person remains in the position in which the person is employed on such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
