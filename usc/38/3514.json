{"tag":"section","attrib":{"id":"idc37a72c4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3514"},"text":null,"children":[{"tag":"num","attrib":{"value":"3514"},"text":"§ 3514.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Processing of applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc37a72c5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3514/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Further processing of an application for educational assistance and the award of such assistance shall be pursuant to the requirements of subchapters III and IV of this chapter unless the parent or guardian requests special restorative training for the eligible person, in which case the application will be processed under subchapter V of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc37a72c6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3514/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the request for special restorative training is approved, educational assistance will be afforded pursuant to the terms of subchapter V of this chapter. If the request for special restorative training is disapproved, or if approved the restorative training is completed or discontinued, any educational assistance subsequently afforded will be in accordance with subchapters III and IV of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc37a72c7-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1195"},"text":"72 Stat. 1195","children":[],"tail":", § 1714; renumbered § 3514, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc37a72c8-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc37a72c9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc37a72ca-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1714"},"text":"section 1714 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
