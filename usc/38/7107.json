{"tag":"section","attrib":{"id":"idc3ea9b13-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7107"},"text":null,"children":[{"tag":"num","attrib":{"value":"7107"},"text":"§ 7107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeals: dockets; hearings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3ea9b14-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Dockets","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3ea9b15-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7107/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2), the Board shall maintain at least two separate dockets.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ea9b16-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7107/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board may not maintain more than two separate dockets unless the Board notifies the Committee on Veterans’ Affairs of the Senate and the Committee on Veterans’ Affairs of the House of Representatives of any additional docket, including a justification for maintaining such additional docket.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ea9b17-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7107/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3ea9b18-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7107/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board may assign to each docket maintained under paragraph (1) such cases as the Board considers appropriate, except that cases described in clause (i) of subparagraph (B) may not be assigned to any docket to which cases described in clause (ii) of such paragraph are assigned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3ea9b19-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7107/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Cases described in this paragraph are the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc3ea9b1a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7107/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cases in which no Board hearing is requested.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3ea9b1b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7107/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cases in which a Board hearing is requested in the notice of disagreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ea9b1c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7107/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (b), each case before the Board will be decided in regular order according to its respective place on the docket to which it is assigned by the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3ea9b1d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advancement on the Docket","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3ea9b1e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7107/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A case on one of the dockets of the Board maintained under subsection (a) may, for cause shown, be advanced on motion for earlier consideration and determination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ea9b1f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7107/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any such motion shall set forth succinctly the grounds upon which the motion is based.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ea9b20-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7107/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such a motion may be granted only—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3ea9b21-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7107/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the case involves interpretation of law of general application affecting other claims;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3ea9b22-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7107/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the appellant is seriously ill or is under severe financial hardship; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3ea9b23-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7107/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for other sufficient cause shown.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3ea9b24-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7107/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Manner and Scheduling of Hearings for Cases on a Docket That May Include a Hearing","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3ea9b25-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7107/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For cases on a docket maintained by the Board under subsection (a) that may include a hearing, in which a hearing is requested in the notice of disagreement, the Board shall notify the appellant whether a Board hearing will be held—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3ea9b26-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7107/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at its principal location; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3ea9b27-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7107/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by picture and voice transmission at a facility of the Department where the Secretary has provided suitable facilities and equipment to conduct such hearings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ea9b28-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7107/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3ea9b29-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7107/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon notification of a Board hearing at the Board’s principal location as described in subparagraph (A) of paragraph (1), the appellant may alternatively request a hearing as described in subparagraph (B) of such paragraph or subparagraph (C) of this paragraph. If so requested, the Board shall grant such request.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3ea9b2a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7107/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon notification of a Board hearing by picture and voice transmission as described in subparagraph (B) of paragraph (1), the appellant may alternatively request a hearing as described in subparagraph (A) of such paragraph or subparagraph (C) of this paragraph. If so requested, the Board shall grant such request.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3ea9b2b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7107/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc3ea9b2c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7107/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Upon notification of a Board hearing under subparagraph (A) or (B) of paragraph (1), the appellant may alternatively request a hearing by picture and voice transmission—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc3ea9b2d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7107/c/2/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at a location selected by the appellant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc3ea9b2e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7107/c/2/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" via a secure internet platform established and maintained by the Secretary that protects sensitive personal information from a data breach.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3ea9b2f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7107/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If an appellant makes a request under clause (i), the Board shall grant such request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3ea9b30-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7107/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Screening of Cases","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section shall be construed to preclude the screening of cases for purposes of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3ea9b31-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7107/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determining the adequacy of the record for decisional purposes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ea9b32-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7107/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development, or attempted development, of a record found to be inadequate for decisional purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3ea9b33-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7107/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Policy on Changing Dockets","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall develop and implement a policy allowing an appellant to move the appellant’s case from one docket to another docket.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3ea9b34-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1242"},"text":"72 Stat. 1242","children":[],"tail":", § 4006; renumbered § 4007, "},{"tag":"ref","attrib":{"href":"/us/pl/87/666/s1"},"text":"Pub. L. 87–666, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-19"},"text":"Sept. 19, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/553"},"text":"76 Stat. 553","children":[],"tail":"; renumbered § 7107, "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/271/s7/a/1"},"text":"Pub. L. 103–271, § 7(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-01"},"text":"July 1, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/742"},"text":"108 Stat. 742","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/446/tIII/s303"},"text":"Pub. L. 103–446, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4658"},"text":"108 Stat. 4658","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/368/tX/s1003"},"text":"Pub. L. 105–368, title X, § 1003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3363"},"text":"112 Stat. 3363","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/315/tI/s102"},"text":"Pub. L. 114–315, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1540"},"text":"130 Stat. 1540","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/55/s2/t"},"text":"Pub. L. 115–55, § 2(t)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-23"},"text":"Aug. 23, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1112"},"text":"131 Stat. 1112","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/137/s2/a"},"text":"Pub. L. 116–137, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-04-10"},"text":"Apr. 10, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/616"},"text":"134 Stat. 616","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3ea9b35-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3ea9b36-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3ea9b37-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/137/s2/a/1"},"text":"Pub. L. 116–137, § 2(a)(1)","children":[],"tail":", inserted “or subparagraph (C) of this paragraph” after “subparagraph (B) of such paragraph”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/137/s2/a/2"},"text":"Pub. L. 116–137, § 2(a)(2)","children":[],"tail":", inserted “or subparagraph (C) of this paragraph” after “subparagraph (A) of such paragraph”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/137/s2/a/3"},"text":"Pub. L. 116–137, § 2(a)(3)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/55"},"text":"Pub. L. 115–55","children":[],"tail":" amended section generally. Prior to amendment, section consisted of subsecs. (a) to (f) relating to order of cases, opportunity for hearing, maintenance of hearing docket and holding of hearings by the Board, location and type of hearings, hearings conducted by electronic or other means, and screening of cases, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/315/s102/1"},"text":"Pub. L. 114–315, § 102(1)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “An appellant may request that a hearing before the Board be held at its principal location or at a facility of the Department located within the area served by a regional office of the Department.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/315/s102/2"},"text":"Pub. L. 114–315, § 102(2)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “When such facilities and equipment are available, the Chairman may afford the appellant an opportunity to participate in a hearing before the Board through the use of such facilities and equipment in lieu of a hearing held by personally appearing before a Board member or panel as provided in subsection (d). Any such hearing shall be conducted in the same manner as, and shall be considered the equivalent of, a personal hearing. If the appellant declines to participate in a hearing through the use of such facilities and equipment, the opportunity of the appellant to a hearing as provided in such subsection (d) shall not be affected.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/s1003/a/1"},"text":"Pub. L. 105–368, § 1003(a)(1)","children":[],"tail":", inserted “in paragraphs (2) and (3) and” after “Except as provided”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/s1003/a/2"},"text":"Pub. L. 105–368, § 1003(a)(2)","children":[],"tail":", added second and third sentences and struck out former second sentence which read as follows: “Any such motion shall set forth succinctly the grounds upon which it is based and may not be granted unless the case involves interpretation of law of general application affecting other claims or for other sufficient cause shown.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/s1003/a/3"},"text":"Pub. L. 105–368, § 1003(a)(3)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/s1003/b/1"},"text":"Pub. L. 105–368, § 1003(b)(1)","children":[],"tail":", substituted “in accordance with the place of the case on the docket under subsection (a) relative to other cases on the docket for which hearings are scheduled to be held within that area.” for “in the order in which requests for hearings within that area are received by the Department.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/s1003/b/2"},"text":"Pub. L. 105–368, § 1003(b)(2)","children":[],"tail":", added par. (3) and struck out former par. (3) which read as follows: “In a case in which the Secretary is aware that the appellant is seriously ill or is under severe financial hardship, a hearing may be scheduled at a time earlier than would be provided for under paragraph (2).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446"},"text":"Pub. L. 103–446","children":[],"tail":" substituted “Except as provided in subsection (f), each case” for “Each case” in subsec. (a)(1) and added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/271"},"text":"Pub. L. 103–271","children":[],"tail":" amended section generally. Prior to amendment, text read as follows: “All cases received pursuant to application for review on appeal shall be considered and decided in regular order according to their places upon the docket; however, for cause shown a case may be advanced on motion for earlier consideration and determination. Every such motion shall set forth succinctly the grounds upon which it is based. No such motion shall be granted except in cases involving interpretation of law of general application affecting other claims, or for other sufficient cause shown.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4007"},"text":"section 4007 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/666"},"text":"Pub. L. 87–666","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4006"},"text":"section 4006 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3ece428-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3ece429-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/55"},"text":"Pub. L. 115–55","children":[],"tail":" applicable to all claims for which the Secretary of Veterans Affairs provides notice of a decision under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5104"},"text":"section 5104 of this title","children":[],"tail":" on or after the later of 540 days after "},{"tag":"date","attrib":{"date":"2017-08-23"},"text":"Aug. 23, 2017","children":[],"tail":", or 30 days after the date on which the Secretary submits to Congress a certification of certain capabilities of the Department of Veterans Affairs to carry out the new appeals system established by "},{"tag":"ref","attrib":{"href":"/us/pl/115/55"},"text":"Pub. L. 115–55","children":[],"tail":" and to address appeals of decisions on legacy claims, with provision for early applicability of the new appeals system to certain claims, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/55/s2/x"},"text":"section 2(x) of Pub. L. 115–55","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of this title","children":[],"tail":", and bracketed note thereunder."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3ece42a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadline for Implementation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/137/s2/b"},"text":"Pub. L. 116–137, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-04-10"},"text":"Apr. 10, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/616"},"text":"134 Stat. 616","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/137/s2/b"},"text":"“The Secretary shall implement the amendments made by subsection (a) [amending this section] not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2020-04-10"},"text":"Apr. 10, 2020","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3ece42b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Collaboration","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/137/s2/d"},"text":"Pub. L. 116–137, § 2(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-04-10"},"text":"Apr. 10, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/617"},"text":"134 Stat. 617","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/137/s2/d"},"text":"“In developing the capacity and procedures to conduct hearings under subparagraph (C) of paragraph (2) of subsection (c) of section 7101 [probably should be “7107”] of title 38, United States Code, as added by subsection (a), the Secretary of Veterans Affairs shall collaborate with, partner with, and give weight to the advice of veterans service organizations and such other stakeholders as the Secretary considers appropriate.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
