{"tag":"section","attrib":{"id":"idc337c543-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2065"},"text":null,"children":[{"tag":"num","attrib":{"value":"2065"},"text":"§ 2065.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report on assistance to homeless veterans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc337c544-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2065/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than June 15 of each year, the Secretary shall submit to the Committees on Veterans’ Affairs of the Senate and House of Representatives a report on the activities of the Department during the calendar year preceding the report under programs of the Department under this chapter and other programs of the Department for the provision of assistance to homeless veterans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc337c545-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2065/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Contents of Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under subsection (a) shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc337c546-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2065/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of homeless veterans provided assistance under the programs referred to in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc337c547-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2065/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The cost to the Department of providing such assistance under those programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc337c548-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2065/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary’s evaluation of the effectiveness of the programs of the Department in providing assistance to homeless veterans, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc337c549-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2065/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" residential work-therapy programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c54a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2065/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs combining outreach, community-based residential treatment, and case-management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c54b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2065/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contract care programs for alcohol and drug-dependence or use disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc337c54c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2065/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary’s evaluation of the effectiveness of programs established by recipients of grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2011"},"text":"section 2011 of this title","children":[],"tail":" and a description of the experience of those recipients in applying for and receiving grants from the Secretary of Housing and Urban Development to serve primarily homeless persons who are veterans."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc337c54d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2065/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Information on the efforts of the Secretary to coordinate the delivery of housing and services to homeless veterans with other Federal departments and agencies, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc337c54e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2065/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c54f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2065/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Health and Human Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c550-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2065/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Housing and Urban Development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c551-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2065/b/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Justice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c552-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2065/b/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Labor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c553-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2065/b/5/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Interagency Council on Homelessness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c554-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2065/b/5/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Social Security Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c555-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2065/b/5/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other Federal department or agency with which the Secretary coordinates the delivery of housing and services to homeless veterans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc337c556-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2065/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other information on those programs and on the provision of such assistance that the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc337c557-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2065/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Health Care Contents of Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under subsection (a) shall include, with respect to programs of the Department addressing health care needs of homeless veterans, the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc337c558-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2065/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information about expenditures, costs, and workload under the program of the Department known as the Health Care for Homeless Veterans program (HCHV).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc337c559-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2065/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information about the veterans contacted through that program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc337c55a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2065/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information about program treatment outcomes under that program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc337c55b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2065/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information about supported housing programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc337c55c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2065/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information about the Department’s grant and per diem provider program under subchapter II of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc337c55d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2065/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The findings and conclusions of the assessments of the medical needs of homeless veterans conducted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2034/b"},"text":"section 2034(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc337c55e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2065/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other information the Secretary considers relevant in assessing those programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc337c55f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2065/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Benefits Content of Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under subsection (a) shall include, with respect to programs and activities of the Veterans Benefits Administration in processing of claims for benefits of homeless veterans during the preceding year, the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc337c560-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2065/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information on costs, expenditures, and workload of Veterans Benefits Administration claims evaluators in processing claims for benefits of homeless veterans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc337c561-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2065/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information on the filing of claims for benefits by homeless veterans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc337c562-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2065/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information on efforts undertaken to expedite the processing of claims for benefits of homeless veterans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc337c563-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2065/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other information that the Secretary considers relevant in assessing the programs and activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc337c564-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/95/s5/a/1"},"text":"Pub. L. 107–95, § 5(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-21"},"text":"Dec. 21, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/914"},"text":"115 Stat. 914","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/170/tIV/s405/b"},"text":"Pub. L. 108–170, title IV, § 405(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2063"},"text":"117 Stat. 2063","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/461/tVII/s708"},"text":"Pub. L. 109–461, title VII, § 708","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3440"},"text":"120 Stat. 3440","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/387/tIX/s901/a/2"},"text":"Pub. L. 110–387, title IX, § 901(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4142"},"text":"122 Stat. 4142","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc337c565-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc337c566-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc337c567-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/387"},"text":"Pub. L. 110–387","children":[],"tail":" struck out closing parenthesis after “disabilities”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461"},"text":"Pub. L. 109–461","children":[],"tail":" added par. (5) and redesignated former par. (5) as (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/170"},"text":"Pub. L. 108–170","children":[],"tail":" substituted “June 15 of each year” for “April 15 of each year”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
