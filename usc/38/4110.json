{"tag":"section","attrib":{"id":"idc3bd488e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110"},"text":null,"children":[{"tag":"num","attrib":{"value":"4110"},"text":"§ 4110.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Committee on Veterans Employment, Training, and Employer Outreach","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3bd488f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3bd4890-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is hereby established within the Department of Labor an advisory committee to be known as the Advisory Committee on Veterans Employment, Training, and Employer Outreach.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3bd4891-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The advisory committee shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3bd4892-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the employment and training needs of veterans and their integration into the workforce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bd4893-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the extent to which the programs and activities of the Department of Labor are meeting such needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bd4894-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist the Assistant Secretary of Labor for Veterans’ Employment and Training in carrying out outreach activities to employers with respect to the training and skills of veterans and the advantages afforded employers by hiring veterans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bd4895-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations to the Secretary, through the Assistant Secretary of Labor for Veterans’ Employment and Training, with respect to outreach activities and the employment and training of veterans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bd4896-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out such other activities that are necessary to make the reports and recommendations referred to in subsection (f) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3bd4897-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Labor shall, on a regular basis, consult with and seek the advice of the advisory committee with respect to the matters referred to in subsection (a)(2) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3bd4898-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3bd4899-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Labor shall appoint at least 12, but no more than 16, individuals to serve as members of the advisory committee as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3bd489a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Seven individuals, one each from among representatives nominated by each of the following organizations:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc3bd489b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Society of Human Resource Managers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3bd489c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Business Roundtable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3bd489d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Association of State Workforce Agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3bd489e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/c/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Chamber of Commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3bd489f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/c/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Federation of Independent Business.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3bd48a0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/c/1/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A nationally recognized labor union or organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3bd48a1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/c/1/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Governors Association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bd48a2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than five individuals from among representatives nominated by veterans service organizations that have a national employment program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bd48a3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than five individuals who are recognized authorities in the fields of business, employment, training, rehabilitation, or labor and who are not employees of the Department of Labor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3bd48a4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A vacancy in the advisory committee shall be filled in the manner in which the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3bd48a5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The following, or their representatives, shall be ex officio, nonvoting members of the advisory committee:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3bd48a6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Veterans Affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3bd48a7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3bd48a8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Office of Personnel Management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3bd48a9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary of Labor for Veterans Employment and Training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3bd48aa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary of Labor for Employment and Training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3bd48ab-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the Small Business Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3bd48ac-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3bd48ad-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The advisory committee shall meet at least quarterly.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3bd48ae-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Labor shall appoint the chairman of the advisory committee who shall serve in that position for no more than 2 consecutive years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3bd48af-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3bd48b0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the advisory committee shall serve without compensation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bd48b1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the advisory committee shall be allowed reasonable and necessary travel expenses, including per diem in lieu of subsistence, at rates authorized for persons serving intermittently in the Government service in accordance with the provisions of subchapter I of chapter 57 of title 5 while away from their homes or regular places of business in the performance of the responsibilities of the advisory committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3bd48b2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Labor shall provide staff and administrative support to the advisory committee through the Veterans Employment and Training Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3bd48b3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3bd48b4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than December 31 of each year, the advisory committee shall submit to the Secretary and to the Committees on Veterans’ Affairs of the Senate and House of Representatives a report on the employment and training needs of veterans, with special emphasis on disabled veterans, for the previous fiscal year. Each such report shall contain—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3bd48b5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the employment and training needs of veterans and their integration into the workforce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bd48b6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the outreach activities carried out by the Secretary of Labor to employers with respect to the training and skills of veterans and the advantages afforded employers by hiring veterans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bd48b7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the extent to which the programs and activities of the Department of Labor are meeting such needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bd48b8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the activities of the advisory committee during that fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bd48b9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/f/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of activities that the advisory committee proposes to undertake in the succeeding fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bd48ba-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/f/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations for legislation, administrative action, and other action that the advisory committee considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3bd48bb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to the annual reports made under paragraph (1), the advisory committee may make recommendations to the Secretary of Labor with respect to the employment and training needs of veterans at such times and in such manner as the advisory committee determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3bd48bc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Within 60 days after receiving each annual report referred to in subsection (f)(1), the Secretary of Labor shall transmit to Congress a copy of the report together with any comments concerning the report that the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3bd48bd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4110/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The advisory committee shall continue until terminated by law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3bd48be-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/306/tIII/s308/a"},"text":"Pub. L. 97–306, title III, § 308(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-14"},"text":"Oct. 14, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1441"},"text":"96 Stat. 1441","children":[],"tail":", § 2010; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/323"},"text":"Pub. L. 100–323","children":[],"tail":", §§ 10, 15(a)(2), (3), (b)(1), "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/566"},"text":"102 Stat. 566","children":[],"tail":", 574; "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIV/s423/b/8/A"},"text":"Pub. L. 101–237, title IV, § 423(b)(8)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2093"},"text":"103 Stat. 2093","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/16/s8/a"},"text":"Pub. L. 102–16, § 8(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-03-22"},"text":"Mar. 22, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/52"},"text":"105 Stat. 52","children":[],"tail":"; renumbered § 4110 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":", §§ 4(b)(1), (2)(E), 5(a), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404-406"},"text":"105 Stat. 404–406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/568/tV/s504"},"text":"Pub. L. 102–568, title V, § 504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4340"},"text":"106 Stat. 4340","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/446/tXII/s1201/a/5"},"text":"Pub. L. 103–446, title XII, § 1201(a)(5)","children":[],"tail":", (g)(3), (i)(7), "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4682"},"text":"108 Stat. 4682","children":[],"tail":", 4687, 4688; "},{"tag":"ref","attrib":{"href":"/us/pl/109/233/tII/s202/a/1"},"text":"Pub. L. 109–233, title II, § 202(a)(1)","children":[],"tail":", (2), (b)–(d), "},{"tag":"date","attrib":{"date":"2006-06-15"},"text":"June 15, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/403"},"text":"120 Stat. 403","children":[],"tail":", 404; "},{"tag":"ref","attrib":{"href":"/us/pl/109/461/tVI/s604/b"},"text":"Pub. L. 109–461, title VI, § 604(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3439"},"text":"120 Stat. 3439","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/387/tIX/s901/a/4"},"text":"Pub. L. 110–387, title IX, § 901(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4142"},"text":"122 Stat. 4142","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3bd48bf-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3bd48c0-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc3bd48c1-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior section 4110, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1246"},"text":"72 Stat. 1246","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/207"},"text":"Pub. L. 88–207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-12-17"},"text":"Dec. 17, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/402"},"text":"77 Stat. 402","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/160/tII/s205"},"text":"Pub. L. 98–160, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-11-21"},"text":"Nov. 21, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1001"},"text":"97 Stat. 1001","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/576/tVII/s701/88"},"text":"Pub. L. 99–576, title VII, § 701(88)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3299"},"text":"100 Stat. 3299","children":[],"tail":", related to disciplinary boards, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s401/a/3"},"text":"Pub. L. 102–40, title IV, § 401(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/210"},"text":"105 Stat. 210","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7464"},"text":"section 7464 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3bd48c2-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/387"},"text":"Pub. L. 110–387","children":[],"tail":" substituted “16” for “15” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/233/s202/a/2"},"text":"Pub. L. 109–233, § 202(a)(2)","children":[],"tail":", amended section catchline generally, substituting “Advisory Committee on Veterans Employment, Training, and Employer Outreach” for “Advisory Committee on Veterans Employment and Training”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/233/s202/a/1"},"text":"Pub. L. 109–233, § 202(a)(1)","children":[],"tail":", substituted “Advisory Committee on Veterans Employment, Training, and Employer Outreach” for “Advisory Committee on Veterans Employment and Training”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/233/s202/b"},"text":"Pub. L. 109–233, § 202(b)","children":[],"tail":", inserted “and their integration into the workforce” after “veterans” in subpar. (A), added subpars. (C) and (D), and redesignated former subpar. (C) as (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/233/s202/c/1"},"text":"Pub. L. 109–233, § 202(c)(1)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “The Secretary of Labor shall appoint at least 12, but no more than 18, individuals to serve as members of the advisory committee consisting of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) representatives nominated by veterans’ organizations that have a national employment program; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) not more than 6 individuals who are recognized authorities in the fields of business, employment, training, rehabilitation, or labor and who are not employees of the Department of Labor.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461"},"text":"Pub. L. 109–461","children":[],"tail":" substituted “Seven” for “Six” in introductory provisions and added cl. (vii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3) to (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/233/s202/c/2"},"text":"Pub. L. 109–233, § 202(c)(2)","children":[],"tail":", struck out pars. (3), (4), (8), and (10) to (12) which related to certain ex officio, nonvoting members of the advisory committee and redesignated pars. (5) to (7) and (9) as (3) to (6), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/233/s202/d/1"},"text":"Pub. L. 109–233, § 202(d)(1)","children":[],"tail":", substituted first sentence for former first sentence which read “Not later than July 1 of each year, the advisory committee shall submit to the Secretary of Labor a report on the employment and training needs of veterans.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/233/s202/d/2"},"text":"Pub. L. 109–233, § 202(d)(2)","children":[],"tail":", inserted “and their integration into the workforce” after “veterans”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1)(B) to (F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/233/s202/d/3"},"text":"Pub. L. 109–233, § 202(d)(3)","children":[],"tail":"–(6), added subpars. (B), (D), and (E), and redesignated former subpars. (B) and (C) as (C) and (F), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446/s1201/g/3"},"text":"Pub. L. 103–446, § 1201(g)(3)","children":[],"tail":", substituted “shall appoint” for “shall, within 90 days after the date of the enactment of this section, appoint”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446/s1201/a/5"},"text":"Pub. L. 103–446, § 1201(a)(5)","children":[],"tail":", substituted “Administrator of the Small Business Administration” for “Secretary of the Small Business Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446/s1201/i/7"},"text":"Pub. L. 103–446, § 1201(i)(7)","children":[],"tail":", struck out “, United States Code,” after “title 5” and substituted “the advisory committee” for “the Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/568"},"text":"Pub. L. 102–568","children":[],"tail":" struck out “are chartered by Federal law and” after “that”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2010"},"text":"section 2010 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/16"},"text":"Pub. L. 102–16","children":[],"tail":" amended section generally, substituting present catchline and text consisting of subsecs. (a) to (h) for former catchline which read “Secretary of Labor’s Committee on Veterans’ Employment” and former text consisting of subsecs. (a) to (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" substituted “Secretary of Veterans Affairs” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323/s15/b/1"},"text":"Pub. L. 100–323, § 15(b)(1)","children":[],"tail":", inserted “and Training” after “for Veterans’ Employment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323/s15/a/3"},"text":"Pub. L. 100–323, § 15(a)(3)","children":[],"tail":", substituted “Notwithstanding "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2002A/b"},"text":"section 2002A(b) of this title","children":[],"tail":", the” for “The”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323/s15/a/2"},"text":"Pub. L. 100–323, § 15(a)(2)","children":[],"tail":", struck out “of Labor” after “Secretary” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(D) to (I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323/s10"},"text":"Pub. L. 100–323, § 10","children":[],"tail":", added subpars. (D), (H), and (I) and redesignated former subpars. (D) to (F) as (E) to (G), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3bd48c3-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idc3bd48c4-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/233/tII/s202/a/4"},"text":"Pub. L. 109–233, title II, § 202(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-06-15"},"text":"June 15, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/403"},"text":"120 Stat. 403","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/233/tII/s202/a/4"},"text":"“Any reference to the Advisory Committee established under section 4110 of such title [this title] in any law, regulation, map, document, record, or other paper of the United States shall be considered to be a reference to the Advisory Committee on Veterans Employment, Training, and Employer Outreach.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3bd48c5-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323/s10"},"text":"section 10 of Pub. L. 100–323","children":[],"tail":" effective on 60th day after "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", and amendment by section 15(a)(2), (3), (b)(1) of "},{"tag":"ref","attrib":{"href":"/us/pl/100/323"},"text":"Pub. L. 100–323","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/323/s16/b/2"},"text":"section 16(b)(2) of Pub. L. 100–323","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3104"},"text":"section 3104 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3bd48c6-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of reporting provisions in subsec. (g) of this section, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance, and page 125 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3bd48c7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Advisory Committees","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Advisory committees established after ","children":[{"tag":"date","attrib":{"date":"1973-01-05"},"text":"Jan. 5, 1973","children":[],"tail":", to terminate not later than the expiration of the 2-year period beginning on the date of their establishment, unless, in the case of a committee established by the President or an officer of the Federal Government, such committee is renewed by appropriate action prior to the expiration of such 2-year period, or in the case of a committee established by the Congress, its duration is otherwise provided by law. See "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"section 1013 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
