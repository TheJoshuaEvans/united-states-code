{"tag":"section","attrib":{"id":"idc41a35d7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7803"},"text":null,"children":[{"tag":"num","attrib":{"value":"7803"},"text":"§ 7803.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation of Service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc41a35d8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7803/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Primary Beneficiaries","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Canteens operated by the Service shall be primarily for the use and benefit of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc41a35d9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7803/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" veterans hospitalized or domiciled at the facilities at which canteen services are provided; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc41a35da-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7803/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other veterans who are enrolled under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1705"},"text":"section 1705 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc41a35db-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7803/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Authorized Users","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Service at such canteens may also be furnished to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc41a35dc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7803/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personnel of the Department and recognized veterans’ organizations who are employed at a facility at which canteen services are provided and to other persons so employed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc41a35dd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7803/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the families of persons referred to in paragraph (1) who reside at the facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc41a35de-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7803/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relatives and other persons while visiting a person specified in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc41a35df-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1249"},"text":"72 Stat. 1249","children":[],"tail":", § 4203; renumbered § 7803 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/a"},"text":"Pub. L. 102–40, title IV, § 402(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/3"},"text":"Pub. L. 102–83, § 4(a)(3)","children":[],"tail":", (4), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404"},"text":"105 Stat. 404","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/117/tIII/s302"},"text":"Pub. L. 106–117, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-30"},"text":"Nov. 30, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1572"},"text":"113 Stat. 1572","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/422/tVI/s603"},"text":"Pub. L. 108–422, title VI, § 603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-11-30"},"text":"Nov. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2397"},"text":"118 Stat. 2397","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc41a35e0-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc41a35e1-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc41a35e2-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/422"},"text":"Pub. L. 108–422","children":[],"tail":" amended text of section generally. Prior to amendment, text read as follows: “The canteens at hospitals and homes of the Department shall be primarily for the use and benefit of veterans hospitalized or domiciled at such hospitals and homes. Service at such canteens may also be furnished to personnel of the Department and recognized veterans’ organizations employed at such hospitals and homes and to other persons so employed, to the families of all the foregoing persons who reside at the hospital or home concerned, and to relatives and other persons while visiting any of the persons named in this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117"},"text":"Pub. L. 106–117","children":[],"tail":" struck out subsec. (a) designation and substituted “in this section” for “in this subsection; however, service to any person not hospitalized, domiciled, or residing at the hospital or home shall be limited to the sale of merchandise or services for consumption or use on the premises” and struck out subsec. (b) which read as follows: “Service at canteens other than those established at hospitals and homes shall be limited to sales of merchandise and services for consumption or use on the premises, to personnel employed at such establishments, their visitors, and other persons at such establishments on official business.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4203"},"text":"section 4203 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" substituted “Department” for “Veterans’ Administration” in two places."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
