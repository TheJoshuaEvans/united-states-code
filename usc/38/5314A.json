{"tag":"section","attrib":{"id":"idc3d9d146-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5314A"},"text":null,"children":[{"tag":"num","attrib":{"value":"5314A"},"text":"§ 5314A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dispute of indebtedness","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3d9d147-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5314A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall prescribe regulations that establish an administrative process for the dispute of the existence or amount of an indebtedness described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5314/a/1"},"text":"section 5314(a)(1) of this title","children":[],"tail":" (without regard to whether the Secretary has made a deduction under such section regarding such indebtedness)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d9d148-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5314A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The process under subsection (a) shall be efficient, effective, and equitable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d9d149-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5314A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timeliness","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall ensure that each dispute under subsection (a) proceeds in accordance with standards for timeliness prescribed by the Secretary under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d9d14a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5314A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may not submit to any debt collector (as defined in section 803 of the Fair Debt Collection Practices Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1692a"},"text":"15 U.S.C. 1692a","children":[],"tail":")) any dispute pending under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d9d14b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5314A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to modify the procedures for seeking review of a decision of the agency of original jurisdiction described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5104C/a/1"},"text":"section 5104C(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3d9d14c-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dU/tII/s255/b/1"},"text":"Pub. L. 117–328, div. U, title II, § 255(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5464"},"text":"136 Stat. 5464","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3d9d14d-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3d9d14e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3d9d14f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Administrative Process for Dispute of Indebtedness and Improvements to Department Website","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dU/tII/s255/b/2"},"text":"Pub. L. 117–328, div. U, title II, § 255(b)(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5465"},"text":"136 Stat. 5465","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dU/tII/s255/b/2"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Existing administrative process","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Veterans Affairs shall carry out section 5314A of such title, as added by paragraph (1), by improving the administrative process of the Department of Veterans Affairs for the dispute of the existing or amount of an indebtedness that was in effect on the day before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Improvements to department website and notices","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out paragraph (2), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the website of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure that such website and written notices sent to a person about indebtedness described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5314/a"},"text":"section 5314(a) of title 38","children":[],"tail":", United States Code, contain all information a person needs to dispute such an indebtedness, including a description of—"}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the specific actions the person will need to take in order to dispute the indebtedness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the documentation that will be required for the dispute; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the documentation is to be submitted.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
