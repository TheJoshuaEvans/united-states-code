{"tag":"section","attrib":{"id":"idc3c93008-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4335"},"text":null,"children":[{"tag":"num","attrib":{"value":"4335"},"text":"§ 4335.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training for Federal executive agency human resources personnel on employment and reemployment rights and limitations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3c93009-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4335/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of each Federal executive agency shall provide training for the human resources personnel of such agency on the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3c9300a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4335/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rights, benefits, and obligations of members of the uniformed services under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3c9300b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4335/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The application and administration of the requirements of this chapter by such agency with respect to such members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3cba00c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4335/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The training provided under subsection (a) shall be developed and provided in consultation with the Director of the Office of Personnel Management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3cba00d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4335/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Frequency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The training under subsection (a) shall be provided with such frequency as the Director of the Office of Personnel Management shall specify in order to ensure that the human resources personnel of Federal executive agencies are kept fully and currently informed of the matters covered by the training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3cba00e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4335/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Human Resources Personnel Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “human resources personnel”, in the case of a Federal executive agency, means any personnel of the agency who are authorized to recommend, take, or approve any personnel action that is subject to the requirements of this chapter with respect to employees of the agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3cba00f-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/389/tIII/s313/a"},"text":"Pub. L. 110–389, title III, § 313(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4166"},"text":"122 Stat. 4166","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3cba010-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3cba011-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc3cba012-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 4335, 4336, and 4351 to 4355 were renumbered sections 7635, 7636, and 7651 to 7655 of this title, respectively.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 5001 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s8101"},"text":"section 8101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 5001, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1251"},"text":"72 Stat. 1251","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/450/s1"},"text":"Pub. L. 88–450, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-08-19"},"text":"Aug. 19, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/500"},"text":"78 Stat. 500","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/31