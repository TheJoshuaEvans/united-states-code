{"tag":"section","attrib":{"id":"idc2a8a4f1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1132"},"text":null,"children":[{"tag":"num","attrib":{"value":"1132"},"text":"§ 1132.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presumption of sound condition","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1131"},"text":"section 1131 of this title","children":[],"tail":", every person employed in the active military, naval, air, or space service for six months or more shall be taken to have been in sound condition when examined, accepted and enrolled for service, except as to defects, infirmities, or disorders noted at the time of the examination, acceptance and enrollment, or where evidence or medical judgment is such as to warrant a finding that the disease or injury existed before acceptance and enrollment."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc2a8a4f2-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1122"},"text":"72 Stat. 1122","children":[],"tail":", § 332; renumbered § 1132 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s926/a/11"},"text":"Pub. L. 116–283, div. A, title IX, § 926(a)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":"