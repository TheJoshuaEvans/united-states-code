{"tag":"section","attrib":{"id":"idc2df6c4f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1706A"},"text":null,"children":[{"tag":"num","attrib":{"value":"1706A"},"text":"§ 1706A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remediation of medical service lines","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2df6c50-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1706A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after determining under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1703/e/1"},"text":"section 1703(e)(1) of this title","children":[],"tail":" that a medical service line of the Department is providing hospital care, medical services, or extended care services that does not comply with the standards for quality established by the Secretary, the Secretary shall submit to Congress an assessment of the factors that led the Secretary to make such determination and a plan with specific actions, and the time to complete them, to be taken to comply with such standards for quality, including the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2df6c51-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1706A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increasing personnel or temporary personnel assistance, including mobile deployment teams.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2df6c52-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1706A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Special hiring incentives, including the Education Debt Reduction Program under subchapter VII of chapter 76 of this title and recruitment, relocation, and retention incentives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2df6c53-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1706A/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Utilizing direct hiring authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2df6c54-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1706A/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing improved training opportunities for staff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2df6c55-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1706A/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Acquiring improved equipment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2df6c56-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1706A/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Making structural modifications to the facility used by the medical service line.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2df6c57-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1706A/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other actions as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2df6c58-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1706A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsible Parties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In each assessment submitted under subsection (a) with respect to a medical service line, the Secretary shall identify the individuals at the Central Office of the Veterans Health Administration, the facility used by the medical service line, and the central office of the relevant Veterans Integrated Service Network who are responsible for overseeing the progress of that medical service line in complying with the standards for quality established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2df6c59-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1706A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interim Reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after submitting an assessment under subsection (a) with respect to a medical service line, the Secretary shall submit to Congress a report on the progress of that medical service line in complying with the standards for quality established by the Secretary and any other measures the Secretary will take to assist the medical service line in complying with such standards for quality.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2df6c5a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1706A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Reports","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not less frequently than once each year, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2df6c5b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1706A/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to Congress an analysis of the remediation actions and costs of such actions taken with respect to each medical service line with respect to which the Secretary submitted an assessment and plan under subsection (a) in the preceding year, including an update on the progress of each such medical service line in complying with the standards for quality and timeliness established by the Secretary and any other actions the Secretary is undertaking to assist the medical service line in complying with standards for quality as established by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2df6c5c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1706A/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish such analysis on the internet website of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2df6c5d-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/182/tI/s109/a"},"text":"Pub. L. 115–182, title I, § 109(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-06"},"text":"June 6, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1417"},"text":"132 Stat. 1417","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/251/tII/s211/a/6"},"text":"Pub. L. 115–251, title II, § 211(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-29"},"text":"Sept. 29, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3175"},"text":"132 Stat. 3175","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2df6c5e-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc2df6c5f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc2df6c60-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/251/s211/a/6/A"},"text":"Pub. L. 115–251, § 211(a)(6)(A)","children":[],"tail":", inserted “of this title” after “section 1703(e)(1)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/251/s211/a/6/B"},"text":"Pub. L. 115–251, § 211(a)(6)(B)","children":[],"tail":", substituted “subsection (a)” for “paragraph (1)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
