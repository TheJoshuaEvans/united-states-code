"/us/stat/134/3830"},"text":"134 Stat. 3830","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2f76027-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc2f76028-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc2f76029-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “air, or space service” for “or air service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(2)(A), (B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/275"},"text":"Pub. L. 111–275","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2010-05-05"},"text":"May 5, 2010","children":[],"tail":"” for “the date of the Caregivers and Veterans Omnibus Health Services Act of 2010” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163"},"text":"Pub. L. 111–163","children":[],"tail":" added subpars. (A) and (B) and struck out former subpars. (A) and (B) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) $4,100 in the case of medical services furnished under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1710/a/1"},"text":"section 1710(a)(1) of this title","children":[],"tail":", or for a disability described in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1710/a/2/C"},"text":"section 1710(a)(2)(C) of this title","children":[],"tail":"; or"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) $1,200 in the case of medical services furnished under any other provision of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1710/a"},"text":"section 1710(a) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289"},"text":"Pub. L. 110–289","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/114/s402/b/1"},"text":"Pub. L. 105–114, § 402(b)(1)","children":[],"tail":", substituted “treatment of the veteran” for “treatment of the veteran’s disability”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/114/s402/b/2"},"text":"Pub. L. 105–114, § 402(b)(2)","children":[],"tail":", substituted “section 1710(a)” for “section 1710(a)(2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/262/s101/d/6/A"},"text":"Pub. L. 104–262, § 101(d)(6)(A)","children":[],"tail":", substituted “section 1710(a)” for “section 1712(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/262/s101/d/6/B/i"},"text":"Pub. L. 104–262, § 101(d)(6)(B)(i)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1710/a/1"},"text":"section 1710(a)(1) of this title","children":[],"tail":", or for a disability described in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1710/a/2/C"},"text":"section 1710(a)(2)(C) of this title","children":[],"tail":"” for “paragraph (1) of "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1712/a"},"text":"section 1712(a) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/262/s101/d/6/B/ii"},"text":"Pub. L. 104–262, § 101(d)(6)(B)(ii)","children":[],"tail":", substituted “section 1710(a)(2)” for “section 1712”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/405"},"text":"Pub. L. 102–405","children":[],"tail":" substituted “$4,100” for “$2,500” in subpar. (A) and “$1,200” for “$600” in subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s617"},"text":"section 617 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “1712(a)” for “612(a)” in pars. (1) and (2)(A) and “1712” for “612” in par. (2)(B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator” wherever appearing in pars. (1) and (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “1114("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")–(p)” for “314("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")–(p)” and “1134” for “334”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. 