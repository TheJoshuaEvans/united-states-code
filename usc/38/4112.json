{"tag":"section","attrib":{"id":"idc3bf92db-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4112"},"text":null,"children":[{"tag":"num","attrib":{"value":"4112"},"text":"§ 4112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance incentive awards for quality employment, training, and placement services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3bf92dc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criteria for Performance Incentive Awards","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3bf92dd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4112/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of carrying out a program of performance incentive awards under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4102A/c/2/A/i/III"},"text":"section 4102A(c)(2)(A)(i)(III) of this title","children":[],"tail":", the Secretary, acting through the Assistant Secretary of Labor for Veterans’ Employment and Training, shall establish criteria for performance incentive awards programs to be administered by States to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3bf92de-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4112/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage the improvement and modernization of employment, training, and placement services provided under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bf92df-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4112/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recognize eligible employees and employment service offices for excellence in the provision of such services or for having made demonstrable improvements in the provision of such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3bf92e0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4112/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall establish such criteria in consultation with representatives of States, political subdivisions of States, and other providers of employment, training, and placement services under the Workforce Investment Act of 1998 ","children":[{"tag":"ref","attrib":{"idref":"fn002095"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002095"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" consistent with the performance measures established under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4102A/b/7"},"text":"section 4102A(b)(7) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3bf92e1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Form of Awards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under the criteria established by the Secretary for performance incentive awards to be administered by States, an award under such criteria may be a cash award or such other nonfinancial awards as the Secretary may specify.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3bf92e2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4112/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration and Use of Awards","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Performance incentive cash awards under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3bf92e3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4112/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be made from amounts allocated from the grant or contract amount for a State for a program year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4102A/c/7"},"text":"section 4102A(c)(7) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3bf92e4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4112/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of such an award made to an eligible employee, shall be in addition to the regular pay of the recipient; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3bf92e5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4112/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of such an award made to an employment service office, may be used by that employment service office for any purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3bf92e6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4112/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Employee Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “eligible employee” means any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3bf92e7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4112/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A disabled veterans’ outreach program specialist.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3bf92e8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4112/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A local veterans’ employment representative.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3bf92e9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4112/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual providing employment, training, and placement services to veterans under the Workforce Investment Act of 1998 ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" or through an employment service delivery system (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4101/7"},"text":"section 4101(7) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3bf92ea-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/288/s3/a"},"text":"Pub. L. 107–288, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-07"},"text":"Nov. 7, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2037"},"text":"116 Stat. 2037","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/461/tVI/s603"},"text":"Pub. L. 109–461, title VI, § 603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3437"},"text":"120 Stat. 3437","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3bf92eb-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3bf92ec-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc3bf92ed-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Workforce Investment Act of 1998, referred to in subsecs. (a)(2) and (d)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/220"},"text":"Pub. L. 105–220","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/936"},"text":"112 Stat. 936","children":[],"tail":", and was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tV"},"text":"Pub. L. 113–128, title V","children":[],"tail":", §§ 506, 511(a), "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1703"},"text":"128 Stat. 1703","children":[],"tail":", 1705, effective "},{"tag":"date","attrib":{"date":"2015-07-01"},"text":"July 1, 2015","children":[],"tail":". Pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3361/a"},"text":"section 3361(a) of Title 29","children":[],"tail":", references to a provision of the Workforce Investment Act of 1998 are deemed to refer to the corresponding provision of the Workforce Innovation and Opportunity Act, "},{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1425"},"text":"128 Stat. 1425","children":[],"tail":". For complete classification of the Workforce Investment Act of 1998 to the Code, see Tables. For complete classification of the Workforce Innovation and Opportunity Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3101"},"text":"section 3101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc3bf92ee-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4112, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1247"},"text":"72 Stat. 1247","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/785/tI/s109/a"},"text":"Pub. L. 89–785, title I, § 109(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-07"},"text":"Nov. 7, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1370"},"text":"80 Stat. 1370","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/82/tII/s205/b"},"text":"Pub. L. 93–82, title II, § 205(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-08-02"},"text":"Aug. 2, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/192"},"text":"87 Stat. 192","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/581/tI/s110/8"},"text":"Pub. L. 94–581, title I, § 110(8)","children":[],"tail":", title II, §§ 209(b)(3), 210(c)(6), "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2849"},"text":"90 Stat. 2849","children":[],"tail":", 2861, 2864; "},{"tag":"ref","attrib":{"href":"/us/pl/96/151/tIII/s305"},"text":"Pub. L. 96–151, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-12-20"},"text":"Dec. 20, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1096"},"text":"93 Stat. 1096","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/330/tI/s115"},"text":"Pub. L. 96–330, title I, § 115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-08-26"},"text":"Aug. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1039"},"text":"94 Stat. 1039","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/223/tII/s209"},"text":"Pub. L. 98–223, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-03-02"},"text":"Mar. 2, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/44"},"text":"98 Stat. 44","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/322/tII/s224"},"text":"Pub. L. 100–322, title II, § 224","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/532"},"text":"102 Stat. 532","children":[],"tail":", related to special medical advisory group and other advisory bodies, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s401/a/3"},"text":"Pub. L. 102–40, title IV, § 401(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/210"},"text":"105 Stat. 210","children":[],"tail":". See sections 7312 and 7313 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3bf92ef-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461/s603/a/1"},"text":"Pub. L. 109–461, § 603(a)(1)","children":[],"tail":", inserted “and employment service offices” after “recognize eligible employees”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461/s603/b"},"text":"Pub. L. 109–461, § 603(b)","children":[],"tail":", substituted “Administration and Use of Awards” for “Relationship of Award to Grant Program and Employee Compensation” as heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461/s603/a/2/B/i"},"text":"Pub. L. 109–461, § 603(a)(2)(B)(i)","children":[],"tail":", substituted “in the case of such an award made to an eligible employee, shall be” for “is”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461/s603/a/2/A"},"text":"Pub. L. 109–461, § 603(a)(2)(A)","children":[],"tail":", (B)(ii), (C), added par. (3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
