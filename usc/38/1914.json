{"tag":"section","attrib":{"id":"idc318cab6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1914"},"text":null,"children":[{"tag":"num","attrib":{"value":"1914"},"text":"§ 1914.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statutory total disabilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Without prejudice to any other cause of disability, the permanent loss of the use of both feet, of both hands, or of both eyes, or of one foot and one hand, or of one foot and one eye, or of one hand and one eye, or the total loss of hearing of both ears, or the organic loss of speech, shall be deemed total disability for insurance purposes.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc318cab7-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1151"},"text":"72 Stat. 1151","children":[],"tail":", § 714; renumbered § 1914, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc318cab8-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc318cab9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc318caba-47c4-11f