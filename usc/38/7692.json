{"tag":"section","attrib":{"id":"idc417ec05-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7692"},"text":null,"children":[{"tag":"num","attrib":{"value":"7692"},"text":"§ 7692.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The purpose of the Specialty Education Loan Repayment Program is to assist, through the establishment of an incentive program for certain individuals employed in the Veterans Health Administration, in meeting the staffing needs of the Veterans Health Administration for physicians in medical specialties for which the Secretary determines recruitment or retention of qualified personnel is difficult.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc417ec06-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/182/tIII/s303/a"},"text":"Pub. L. 115–182, title III, § 303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-06"},"text":"June 6, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1464"},"text":"132 Stat. 1464","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc417ec07-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc417ec08-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc417ec09-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Needs of the VHA","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/182/tIII/s303/c"},"text":"Pub. L. 115–182, title III, § 303(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-06"},"text":"June 6, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1467"},"text":"132 Stat. 1467","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/182/tIII/s303/c"},"text":"“In making determinations each year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7692"},"text":"section 7692 of title 38","children":[],"tail":", United States Code, as enacted by subsection (a), the Secretary of Veterans Affairs shall consider the anticipated needs of the Veterans Health Administration during the period 2 to 6 years in the future.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
