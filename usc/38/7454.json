{"tag":"section","attrib":{"id":"idc40e4ec7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7454"},"text":null,"children":[{"tag":"num","attrib":{"value":"7454"},"text":"§ 7454.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Physician assistants and other health care professionals: additional pay","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc40e4ec8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7454/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Physician assistants and expanded-function dental auxiliaries shall be entitled to additional pay on the same basis as provided for nurses in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7453"},"text":"section 7453 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc40e4ec9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7454/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc40e4eca-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7454/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the Secretary determines it to be necessary in order to obtain or retain the services of individuals in positions listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401/3"},"text":"section 7401(3) of this title","children":[],"tail":", the Secretary may, on a nationwide, local, or other geographic basis, pay persons employed in such positions additional pay on the same basis as provided for nurses in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7453"},"text":"section 7453 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc40e4ecb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7454/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Health care professionals employed in positions referred to in paragraph (1) shall be entitled to additional pay on the same basis as provided for nurses in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7453/c"},"text":"section 7453(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc40e4ecc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7454/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Employees appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7408"},"text":"section 7408 of this title","children":[],"tail":" performing service on a tour of duty, any part of which is within the period commencing at midnight Friday and ending at midnight Sunday, shall receive additional pay in addition to the rate of basic pay provided such employees for each hour of service on such tour at a rate equal to 25 percent of such employee’s hourly rate of basic pay."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc40e4ecd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7454/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall prescribe by regulation standards for compensation and payment under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc40e4ece-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s401/b/4"},"text":"Pub. L. 102–40, title IV, § 401(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/234"},"text":"105 Stat. 234","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/135/tI/s121/a"},"text":"Pub. L. 107–135, title I, § 121(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-23"},"text":"Jan. 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2450"},"text":"115 Stat. 2450","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/170/tIII"},"text":"Pub. L. 108–170, title III","children":[],"tail":", §§ 301(d), 303(a), "},{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2057"},"text":"117 Stat. 2057","children":[],"tail":", 2058; "},{"tag":"ref","attrib":{"href":"/us/pl/111/163/tVI/s601/k/2"},"text":"Pub. L. 111–163, title VI, § 601(k)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-05-05"},"text":"May 5, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1171"},"text":"124 Stat. 1171","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc40e4ecf-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc40e4ed0-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc40e4ed1-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4107/f"},"text":"section 4107(f) of this title","children":[],"tail":" prior to the repeal of that section as part of the complete revision of chapter 73 of this title by "},{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc410bfd2-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163"},"text":"Pub. L. 111–163","children":[],"tail":" amended par. (3) generally. Prior to amendment, par. (3) read as follows: “Employees appointed under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7408"},"text":"section 7408 of this title","children":[],"tail":" shall be entitled to additional pay on the same basis as provided for nurses in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7453/c"},"text":"section 7453(c) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/170/s301/d"},"text":"Pub. L. 108–170, § 301(d)","children":[],"tail":", substituted “individuals in positions listed in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401/3"},"text":"section 7401(3) of this title","children":[],"tail":",” for “certified or registered respiratory therapists, licensed physical therapists, licensed practical or vocational nurses, pharmacists, or occupational therapists,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/170/s303/a"},"text":"Pub. L. 108–170, § 303(a)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/135"},"text":"Pub. L. 107–135","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc410bfd3-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc410bfd4-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/170/tIII/s303/b"},"text":"Pub. L. 108–170, title III, § 303(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2058"},"text":"117 Stat. 2058","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/170/tIII/s303/b"},"text":"“The amendment made by subsection (a) [amending this section] shall take effect with respect to the first pay period beginning on or after ","children":[{"tag":"date","attrib":{"date":"2004-01-01"},"text":"January 1, 2004","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc410bfd5-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/135/tI/s121/b"},"text":"Pub. L. 107–135, title I, § 121(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-23"},"text":"Jan. 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2450"},"text":"115 Stat. 2450","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/135/tI/s121/b"},"text":"“The amendments made by subsection (a) [amending this section] shall apply with respect to pay periods beginning on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2002-01-23"},"text":"Jan. 23, 2002","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
