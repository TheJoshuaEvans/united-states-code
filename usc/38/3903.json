{"tag":"section","attrib":{"id":"idc3b61d00-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3903"},"text":null,"children":[{"tag":"num","attrib":{"value":"3903"},"text":"§ 3903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on assistance; special training courses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3b61d01-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3b61d02-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3903/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraphs (2) and (3), no eligible person shall be entitled to receive more than one automobile or other conveyance under the provisions of this chapter, and no payment shall be made under this chapter for the repair, maintenance, or replacement of an automobile or other conveyance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3b61d03-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3903/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may provide or assist in providing an eligible person with a second automobile or other conveyance under this chapter if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3b61d04-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3903/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary receives satisfactory evidence that the automobile or other conveyance previously purchased with assistance under this chapter was destroyed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc3b61d05-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3903/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a result of a natural or other disaster, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3b61d06-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3903/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through no fault of the eligible person; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3b61d07-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3903/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible person does not otherwise receive from a property insurer compensation for the loss.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3b61d08-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3903/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may provide or assist in providing an eligible person with an additional automobile or other conveyance under this chapter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3b61d09-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3903/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if more than 30 years have elapsed since the eligible person most recently received an automobile or other conveyance under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3b61d0a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3903/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" beginning on the day that is 10 years after date ","children":[{"tag":"ref","attrib":{"idref":"fn002090"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002090"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by “the”."}],"tail":" of the enactment of the Veterans Auto and Education Improvement Act of 2022, if more than 10 years have elapsed since the eligible person most recently received an automobile or other conveyance under this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3b61d0b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3b61d0c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3903/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3902"},"text":"section 3902 of this title","children":[],"tail":", no eligible person shall be provided an automobile or other conveyance under this chapter until it is established to the satisfaction of the Secretary, in accordance with regulations the Secretary shall prescribe, that the eligible person will be able to operate the automobile or other conveyance in a manner consistent with such person’s own safety and the safety of others and will satisfy the applicable standards of licensure to operate the automobile or other conveyance established by the State of such person’s residency or other proper licensing authority."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3b61d0d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3903/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall ensure that to the extent practicable an eligible person who is provided an automobile or other conveyance under this chapter is given the opportunity to make personal selections relating to such automobile or other conveyance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3b61d0e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3903/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3b61d0f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3903/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An eligible person shall not be entitled to adaptive equipment under this chapter for more than two automobiles or other conveyances at any one time or (except as provided in paragraph (2) of this subsection) during any four-year period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3b61d10-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3903/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In a case in which the four-year limitation in paragraph (1) of this subsection precludes an eligible person from being entitled to adaptive equipment under this chapter, if the Secretary determines that, due to circumstances beyond the control of such person, one of the automobiles or other conveyances for which adaptive equipment was provided to such person during the applicable four-year period is no longer available for the use of such person, the Secretary may provide adaptive equipment to such person for an additional automobile or other conveyance during such period. Provision of adaptive equipment under this paragraph is within the discretion of the Secretary. Any action to provide adaptive equipment under this paragraph shall be made pursuant to regulations which the Secretary shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3b61d11-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3903/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Adaptive equipment shall not be provided under this chapter unless it conforms to minimum standards of safety and quality prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3b61d12-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3903/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3b61d13-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3903/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall provide, directly or by contract, for the conduct of special driver training courses at every hospital and, where appropriate, at regional offices and other medical facilities, of the Department to instruct such eligible person to operate the type of automobile or other conveyance such person wishes to obtain with assistance under this chapter, and may make such courses available to any veteran, eligible for care under chapter 17 of this title or member of the Armed Forces, who is determined by the Secretary to need the special training provided in such courses even though such veteran or member is not eligible for the assistance provided under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3b61d14-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3903/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary is authorized to obtain insurance on automobiles and other conveyances used in conducting the special driver training courses provided under this subsection and to obtain, at Government expense, personal liability and property damage insurance for all persons taking such courses without regard to whether such persons are taking the course on an in-patient or out-patient basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3b61d15-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3903/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, the Secretary may obtain, by purchase, lease, gift, or otherwise, any automobile, motor vehicle, or other conveyance deemed necessary to carry out the purposes of this subsection, and may sell, assign, transfer, or convey any such automobile, vehicle, or conveyance to which the Department obtains title for such price and upon such terms as the Secretary deems appropriate; and any proceeds received from any such disposition shall be credited to the applicable Department appropriation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3b61d16-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/666/s2/a"},"text":"Pub. L. 91–666, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-11"},"text":"Jan. 11, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/2000"},"text":"84 Stat. 2000","children":[],"tail":", § 1903; amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/538/s4/a"},"text":"Pub. L. 93–538, § 4(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1974-12-22"},"text":"Dec. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1736"},"text":"88 Stat. 1736","children":[],"tail":", 1737; "},{"tag":"ref","attrib":{"href":"/us/pl/94/581/tI/s108"},"text":"Pub. L. 94–581, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2847"},"text":"90 Stat. 2847","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/66/tIII/s303"},"text":"Pub. L. 97–66, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-10-17"},"text":"Oct. 17, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1030"},"text":"95 Stat. 1030","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/543/tIII/s305/b"},"text":"Pub. L. 98–543, title III, § 305(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-24"},"text":"Oct. 24, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2748"},"text":"98 Stat. 2748","children":[],"tail":"; renumbered § 3903 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":", §§ 4(a)(3), (4), (b)(1), (2)(E), 5(a), (c)(1), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404-406"},"text":"105 Stat. 404–406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/117/tVIII/s804"},"text":"Pub. L. 106–117, title VIII, § 804","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-30"},"text":"Nov. 30, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1586"},"text":"113 Stat. 1586","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/154/tVII/s701/e"},"text":"Pub. L. 112–154, title VII, § 701(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1204"},"text":"126 Stat. 1204","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/256/s2"},"text":"Pub. L. 114–256, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-14"},"text":"Dec. 14, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1345"},"text":"130 Stat. 1345","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/333/s21"},"text":"Pub. L. 117–333, § 21","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6138"},"text":"136 Stat. 6138","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3b61d17-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3b61d18-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc3b61d19-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Date of the enactment of the Veterans Auto and Education Improvement Act of 2022, referred to in subsec. (a)(3)(B), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/333"},"text":"Pub. L. 117–333","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc3b61d1a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those comprising this section were contained in former sections 1902 and 1904 of this title prior to the general revision of this chapter by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/666"},"text":"Pub. L. 91–666","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3b61d1b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/333/s21/1"},"text":"Pub. L. 117–333, § 21(1)","children":[],"tail":", substituted “paragraphs (2) and (3)” for “paragraph (2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/333/s21/2"},"text":"Pub. L. 117–333, § 21(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/256"},"text":"Pub. L. 114–256","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/154"},"text":"Pub. L. 112–154","children":[],"tail":" designated existing provisions as par. (1), substituted “Except as provided in paragraph (2), no” for “No” and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117"},"text":"Pub. L. 106–117","children":[],"tail":" struck out “(not owned by the Government)” after “automobiles and other conveyances”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1903"},"text":"section 1903 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “3902” for “1902”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c)(2), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/3"},"text":"Pub. L. 102–83, § 4(a)(3)","children":[],"tail":", (4), substituted “Department” for “Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/3"},"text":"Pub. L. 102–83, § 4(a)(3)","children":[],"tail":", (4), substituted “Department” for “Veterans’ Administration” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/543"},"text":"Pub. L. 98–543","children":[],"tail":" designated existing provisions as par. (1), substituted “two automobiles or other conveyances at any one time or (except as provided in paragraph (2) of this subsection) during any four-year period” for “one automobile or other conveyance at any one time”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/66"},"text":"Pub. L. 97–66","children":[],"tail":" substituted “the Administrator shall prescribe” for “he shall prescribe” and “such person’s” for “his” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/581/s108/1"},"text":"Pub. L. 94–581, § 108(1)","children":[],"tail":", substituted “any veteran, eligible for care under chapter 17 of this title or member of the Armed Forces, who is determined” for “any veteran or member of the Armed Forces, eligible for care under chapter 17 of this title, who is determined”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/581/s108/2"},"text":"Pub. L. 94–581, § 108(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/538/s4/b"},"text":"Pub. L. 93–538, § 4(b)","children":[],"tail":", substituted “Limitations on assistance; special training courses” for “Limitations on assistance” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/538/s4/a"},"text":"Pub. L. 93–538, § 4(a)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3b61d1c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3b61d1d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/154"},"text":"Pub. L. 112–154","children":[],"tail":" effective on the date that is one year after "},{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/154/s701/g"},"text":"section 701(g) of Pub. L. 112–154","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2109"},"text":"section 2109 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3b61d1e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/543/tIII/s305/c"},"text":"Pub. L. 98–543, title III, § 305(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-24"},"text":"Oct. 24, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2748"},"text":"98 Stat. 2748","chil