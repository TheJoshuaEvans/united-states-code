{"tag":"section","attrib":{"id":"idc3544e9f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3022"},"text":null,"children":[{"tag":"num","attrib":{"value":"3022"},"text":"§ 3022.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of supplemental educational assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3544ea0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3022/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amount of payment of educational assistance under this chapter is subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3032"},"text":"section 3032 of this title","children":[],"tail":". Except as otherwise provided under subsection (b) of this section, supplemental educational assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3021"},"text":"section 3021 of this title","children":[],"tail":" shall be paid—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3544ea1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3022/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at a monthly rate of $300 for an approved program of education pursued on a full-time basis; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3544ea2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3022/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at an appropriately reduced rate, as determined under regulations which the Secretary shall prescribe, for an approved program of education pursued on less than a full-time basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3544ea3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3022/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a member of the Armed Forces for whom the Secretary concerned has provided for the payment of supplemental educational assistance who has a skill or specialty designated by the Secretary concerned, pursuant to regulations to be prescribed by the Secretary of Defense, as a skill or specialty in which there is a critical shortage of personnel, the Secretary concerned, pursuant to such regulations, may increase the rate of the supplemental educational assistance allowance applicable to such individual to such rate in excess of the rate prescribed under subsection (a) of this section as the Secretary concerned considers appropriate, but the amount of any such increase may not exceed $300 per month.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3544ea4-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/tVII/s702/a/1"},"text":"Pub. L. 98–525, title VII, § 702(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2559"},"text":"98 Stat. 2559","children":[],"tail":", § 1422; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/689/tI/s111/a/5/B"},"text":"Pub. L. 100–689, title I, § 111(a)(5)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4171"},"text":"102 Stat. 4171","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIV/s423/b/1/A"},"text":"Pub. L. 101–237, title IV, § 423(b)(1)(A)","children":[],"tail":", (4)(C), "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2092"},"text":"103 Stat. 2092","children":[],"tail":"; renumbered § 3022 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3544ea5-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3544ea6-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc3544ea7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior section 3022 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5122"},"text":"section 5122 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3544ea8-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1422"},"text":"section 1422 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “3032” for “1432” and “3021” for “1421” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237/s423/b/1/A"},"text":"Pub. L. 101–237, § 423(b)(1)(A)","children":[],"tail":", substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" inserted “of Defense” after third reference to “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/689"},"text":"Pub. L. 100–689","children":[],"tail":" substituted “The amount of payment of educational assistance under this chapter is subject to "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1432"},"text":"section 1432 of this title","children":[],"tail":". Except” for “Subject to "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1432"},"text":"section 1432 of this title","children":[],"tail":" and except”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3544ea9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3544eaa-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1986-07-01"},"text":"July 1, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/525/s702/b"},"text":"section 702(b) of Pub. L. 98–525","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3021"},"text":"section 3021 of this title","children":[],"tail":"."}],"tai