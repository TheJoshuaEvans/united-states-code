{"tag":"section","attrib":{"id":"idc290d69b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s715"},"text":null,"children":[{"tag":"num","attrib":{"value":"715"},"text":"§ 715.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional testimony by employees: treatment as official duty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc290d69c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s715/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congressional Testimony","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An employee of the Department is performing official duty during the period with respect to which the employee is testifying in an official capacity in front of either chamber of Congress, a committee of either chamber of Congress, or a joint or select committee of Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc290d69d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s715/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Travel Expenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall provide travel expenses, including per diem in lieu of subsistence, in accordance with applicable provisions under subchapter I of chapter 57 of title 5, to any employee of the Department of Veterans Affairs performing official duty described under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc290d69e-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/223/dA/tII/s247/b/1"},"text":"Pub. L. 114–223, div. A, title II, § 247(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-09-29"},"text":"Sept. 29, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/890"},"text":"130 Stat. 890","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc290d69f-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc290d6a0-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc290d6a1-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 715 and 716 were renumbered sections 1915 and 1916 of this title, respectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
