{"tag":"section","attrib":{"id":"idc2e1dccd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709C"},"text":null,"children":[{"tag":"num","attrib":{"value":"1709C"},"text":"§ 1709C.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance for child care for certain veterans receiving health care","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2e1dcce-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709C/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall carry out a program to provide, subject to subsection (b), assistance to qualified veterans described in subsection (c) to obtain child care so that such veterans can receive health care services described in subsection (c)(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2e1dccf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709C/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Period of Payments","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Assistance may be provided to a qualified veteran under this section for receipt of child care only during the period that the qualified veteran—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2e1dcd0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709C/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receives the types of health care services described in subsection (c)(2) at a facility of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2e1dcd1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709C/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires travel to and return from such facility for the receipt of such health care services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2e1dcd2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709C/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualified Veterans","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, a qualified veteran is a veteran who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2e1dcd3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709C/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is the primary caretaker of a child or children; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2e1dcd4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709C/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2e1dcd5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709C/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" receives from the Department—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc2e1dcd6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709C/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regular mental health care services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc2e1dcd7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709C/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intensive mental health care services; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc2e1dcd8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709C/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other intensive health care services that the Secretary determines that provision of assistance to the veteran to obtain child care would improve access to such health care services by the veteran; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2e1dcd9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709C/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in need of regular or intensive mental health care services from the Department, and but for lack of child care services, would receive such health care services from the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2e1dcda-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709C/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Locations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than five years after the date of the enactment of the Deborah Sampson Act of 2020, the Secretary shall carry out the program at each medical center of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2e1dcdb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709C/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Forms of Child Care Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2e1dcdc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709C/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Child care assistance under this section may include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2e1dcdd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709C/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Stipends for the payment of child care offered by a licensed child care center (either directly or through a voucher program) that shall be, to the extent practicable, modeled after the Department of Veterans Affairs Child Care Subsidy Program established pursuant to section 630 of the Treasury and General Government Appropriations Act, 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/67"},"text":"Public Law 107–67","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/115/552"},"text":"115 Stat. 552","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2e1dcde-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709C/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Direct provision of child care at an on-site facility of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2e1dcdf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709C/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payments to private child care agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2e1dce0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709C/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Collaboration with facilities or programs of other Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2e1dce1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709C/e/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other forms of assistance as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2e1dce2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709C/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In providing child care assistance under this section, the child care needs of the local area shall be considered and the head of each medical center may select the type of care that is most appropriate or feasible for such medical center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2e1dce3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709C/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case that child care assistance under this section is provided as a stipend under paragraph (1)(A), such stipend shall cover the full cost of such child care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2e1dce4-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/tV/s5107/a/1"},"text":"Pub. L. 116–315, title V, § 5107(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/5030"},"text":"134 Stat. 5030","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2e1dce5-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc2e1dce6-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc2e1dce7-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the Deborah Sampson Act of 2020, referred to in subsec. (d), is the date of enactment of title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315"},"text":"Pub. L. 116–315","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 630 of the Treasury and General Government Appropriations Act, 2002, referred to in subsec. (e)(1)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/67/s630"},"text":"section 630 of Pub. L. 107–67","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-12"},"text":"Nov. 12, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/552"},"text":"115 Stat. 552","children":[],"tail":", which was classified to section 490b–1 of former Title 40, Public Buildings, Property, and Works, and was repealed and restated as "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s590/g"},"text":"section 590(g) of Title 40","children":[],"tail":", Public Buildings, Property, and Works, by "},{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", §§ 1, 6(b), "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1118"},"text":"116 Stat. 1118","children":[],"tail":", 1327."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
