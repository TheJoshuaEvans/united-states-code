{"tag":"section","attrib":{"id":"idc41ca63d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7903"},"text":null,"children":[{"tag":"num","attrib":{"value":"7903"},"text":"§ 7903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education debt reduction program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc41ca63e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the availability of appropriations, the Secretary may establish an education debt reduction program under which the Secretary shall make education debt reduction payments under this section to qualified individuals eligible under subsection (b) for the purpose of reimbursing such individuals for payments by such individuals of principal and interest on loans described in paragraph (3) of that subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc41ca63f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual is eligible to participate in the program under this section if the individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc41ca640-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7903/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has completed a doctoral degree in computer science or electrical or computer engineering at an accredited institution of higher education during the five-year period preceding the date on which the individual is hired;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc41ca641-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7903/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an employee of the Department who serves in a position related to information security (as determined by the Secretary); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc41ca642-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7903/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owes any amount of principal or interest under a loan, the proceeds of which were used by or on behalf of that individual to pay costs relating to a doctoral degree in computer science or electrical or computer engineering at an accredited institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc41ca643-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7903/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount of Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc41ca644-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7903/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2), the amount of education debt reduction payments made to an individual under this section may not exceed $82,500 over a total of five years, of which not more than $16,500 of such payments may be made in each year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc41ca645-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7903/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total amount payable to an individual under this section for any year may not exceed the amount of the principal and interest on loans referred to in subsection (b)(3) that is paid by the individual during such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc41ca646-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7903/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payments","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc41ca647-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7903/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall make education debt reduction payments under this section on an annual basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc41ca648-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7903/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall make such a payment—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc41ca649-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7903/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the last day of the one-year period beginning on the date on which the individual is accepted into the program established under subsection (a); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc41ca64a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7903/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an individual who received a payment under this section for the preceding fiscal year, on the last day of the one-year period beginning on the date on which the individual last received such a payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc41ca64b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7903/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, education debt reduction payments under this section shall not be considered as income or resources in determining eligibility for, or the amount of benefits under, any Federal or federally assisted program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc41ca64c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7903/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Performance Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may make education debt reduction payments to an individual under this section for a year only if the Secretary determines that the individual maintained an acceptable level of performance in the position or positions served by the individual during the year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc41ca64d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7903/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification of Terms of Provision of Payments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall provide to an individual who receives a payment under this section notice in writing of the terms and conditions that apply to such a payment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc41ca64e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7903/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Costs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (b)(3), costs relating to a course of education or training include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc41ca64f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7903/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tuition expenses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc41ca650-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7903/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all other reasonable educational expenses, including fees, books, and laboratory expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc41ca651-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461/tIX/s903/a/1"},"text":"Pub. L. 109–461, title IX, § 903(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3462"},"text":"120 Stat. 3462","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/275/tX/s1001"},"text":"Pub. L. 111–275, title X, § 1001","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"2010-10-13"},"text":"Oct. 13, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2897"},"text":"124 Stat. 2897","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc41ca652-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc41ca653-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc41ca654-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/275"},"text":"Pub. L. 111–275","children":[],"tail":" substituted “paragraph (3)” for “paragraph (2)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
