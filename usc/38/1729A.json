{"tag":"section","attrib":{"id":"idc30a741a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1729A"},"text":null,"children":[{"tag":"num","attrib":{"value":"1729A"},"text":"§ 1729A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Veterans Affairs Medical Care Collections Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc30a741b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1729A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is in the Treasury a fund to be known as the Department of Veterans Affairs Medical Care Collections Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc30a741c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1729A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Amounts recovered or collected under any of the following provisions of law shall be deposited in the fund:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc30a741d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1729A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1710/f"},"text":"Section 1710(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30a741e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1729A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1710/g"},"text":"Section 1710(g) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30a741f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1729A/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1711"},"text":"Section 1711 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30a7420-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1729A/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1722A"},"text":"Section 1722A of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30a7421-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1729A/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1725"},"text":"Section 1725 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30a7422-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1729A/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1729"},"text":"Section 1729 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30a7423-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1729A/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1784"},"text":"Section 1784 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30a7424-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1729A/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s8165/a"},"text":"Section 8165(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30a7425-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1729A/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 113 of the Veterans Millennium Health Care and Benefits Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117"},"text":"Public Law 106–117","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s8111"},"text":"38 U.S.C. 8111","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30a7426-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1729A/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/693"},"text":"Public Law 87–693","children":[],"tail":", popularly known as the “Federal Medical Care Recovery Act” ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2651"},"text":"42 U.S.C. 2651","children":[],"tail":" et seq.), to the extent that a recovery or collection under that law is based on medical care or services furnished under this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc30a7427-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1729A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc30a7428-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1729A/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to the provisions of appropriations Acts, amounts in the fund shall be available, without fiscal year limitation, to the Secretary for the following purposes:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc30a7429-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1729A/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Furnishing medical care and services under this chapter, to be available during any fiscal year for the same purposes and subject to the same limitations (other than with respect to the period of availability for obligation) as apply to amounts appropriated from the general fund of the Treasury for that fiscal year for medical care.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc30a742a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1729A/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Expenses of the Department for the identification, billing, auditing, and collection of amounts owed the United States by reason of medical care and services furnished under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30a742b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1729A/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts available under paragraph (1) may not be used for any purpose other than a purpose set forth in subparagraph (A) or (B) of that paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc30a742c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1729A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Of the total amount recovered or collected by the Department during a fiscal year under the provisions of law referred to in subsection (b) and made available from the fund, the Secretary shall make available to each Department health care facility of the Department an amount that bears the same ratio to the total amount so made available as the amount recovered or collected by such facility during that fiscal year under such provisions of law bears to such total amount recovered or collected during that fiscal year. The Secretary shall make available to each facility the entirety of the amount specified to be made available to such facility by the preceding sentence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc30a742d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1729A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts recovered or collected under the provisions of law referred to in subsection (b) shall be treated for the purposes of sections 251 and 252 of the Balanced Budget and Emergency Deficit Control Act of 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s901"},"text":"2 U.S.C. 901","children":[],"tail":", 902) as offsets to discretionary appropriations (rather than as offsets to direct spending) to the extent that such amounts are made available for expenditure in appropriations Acts for the purposes specified in subsection (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc30a742e-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/tVIII/s8023/a/1"},"text":"Pub. L. 105–33, title VIII, § 8023(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/665"},"text":"111 Stat. 665","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/117/tI/s111/b/1"},"text":"Pub. L. 106–117, title I, § 111(b)(1)","children":[],"tail":", title II, § 203, "},{"tag":"date","attrib":{"date":"1999-11-30"},"text":"Nov. 30, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1556"},"text":"113 Stat. 1556","children":[],"tail":", 1561; "},{"tag":"ref","attrib":{"href":"/us/pl/107/135/tII/s208/e/5"},"text":"Pub. L. 107–135, title II, § 208(e)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-23"},"text":"Jan. 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2463"},"text":"115 Stat. 2463","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/7/dK/tI/s113/b"},"text":"Pub. L. 108–7, div. K, title I, § 113(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/482"},"text":"117 Stat. 482","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/183/tVII/s708/a/2"},"text":"Pub. L. 108–183, title VII, § 708(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-16"},"text":"Dec. 16, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2673"},"text":"117 Stat. 2673","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc30a742f-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc30a7430-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc30a7431-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/87/693"},"text":"Public Law 87–693","children":[],"tail":", popularly known as the Federal Medical Care Recovery Act, referred to in subsec. (b)(10), is "},{"tag":"ref","attrib":{"href":"/us/pl/87/693"},"text":"Pub. L. 87–693","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-25"},"text":"Sept. 25, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/593"},"text":"76 Stat. 593","children":[],"tail":", which is classified generally to chapter 32 (§ 2651 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc30a7432-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/183/s708/a/2/A"},"text":"Pub. L. 108–183, § 708(a)(2)(A)","children":[],"tail":", struck out “after "},{"tag":"date","attrib":{"date":"1997-06-30"},"text":"June 30, 1997","children":[],"tail":",” after “collected” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(8) to (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7"},"text":"Pub. L. 108–7","children":[],"tail":" added pars. (8) and (9) and redesignated former par. (8) as (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/183/s708/a/2/B"},"text":"Pub. L. 108–183, § 708(a)(2)(B)","children":[],"tail":", struck out par. (3) which related to duties of the Secretary for fiscal year 1998."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/183/s708/a/2/C"},"text":"Pub. L. 108–183, § 708(a)(2)(C)","children":[],"tail":", (D), redesignated subsec. (f) as (e) and struck out former subsec. (e) which required the Secretary to submit to the Committees on Veterans’ Affairs of the Senate and House of Representatives quarterly reports on the operation of the section for fiscal years 1998, 1999, and 2000 and for the first quarter of fiscal year 2001."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(7), (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/135"},"text":"Pub. L. 107–135","children":[],"tail":" added par. (7) and redesignated former par. (7) as (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (b)(5) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117/s111/b/1"},"text":"Pub. L. 106–117, § 111(b)(1)","children":[],"tail":", added par. (5) and redesignated former pars. (5) and (6) as (6) and (7), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117/s203"},"text":"Pub. L. 106–117, § 203","children":[],"tail":", struck out par. (1) designation, substituted “each Department health care facility” for “each designated health care region” and “each facility” for “each region”, substituted “such facility” for “such region” in two places, and struck out par. (2) which read as follows: “In this subsection, the term ‘designated health care regions of the Department’ means the geographic areas designated by the Secretary for purposes of the management of, and allocation of resources for, health care services provided by the Department.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc30a7433-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc30a7434-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1999 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117/s111/b/1"},"text":"section 111(b)(1) of Pub. L. 106–117","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"1999-11-30"},"text":"Nov. 30, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/117/s111/c"},"text":"section 111(c) of Pub. L. 106–117","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1725"},"text":"section 1725 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc30a7435-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1997-10-01"},"text":"Oct. 1, 1997","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/s8023/g"},"text":"section 8023(g) of Pub. L. 105–33","children":[],"tail":", set out as an Effective Date of 1997 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1710"},"text":"section 1710 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc30a7436-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Improvements for Recovery and Collection of Amounts for Department of Veterans Affairs Medical Care Collections Fund","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/154/tI/s111"},"text":"Pub. L. 112–154, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1175"},"text":"126 Stat. 1175","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/154/tI/s111"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Development and Implementation of Plan for Recovery and Collection.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 270 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":"], the Secretary of Veterans Affairs shall develop and implement a plan to ensure the recovery and collection of amounts under the provisions of law described in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1729A/b"},"text":"section 1729A(b) of title 38","children":[],"tail":", United States Code, for deposit in the Department of Veterans Affairs Medical Care Collections Fund."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan required by paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An effective process to identify billable fee claims.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Effective and practicable policies and procedures that ensure recovery and collection of amounts described in section 1729A(b) of such title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The training of employees of the Department, on or before ","children":[{"tag":"date","attrib":{"date":"2013-09-30"},"text":"September 30, 2013","children":[],"tail":", who are responsible for the recovery or collection of such amounts to enable such employees to comply with the process required by subparagraph (A) and the policies and procedures required by subparagraph (B)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fee revenue goals for the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An effective monitoring system to ensure achievement of goals described in subparagraph (D) and compliance with the policies and procedures described in subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Monitoring of Third-party Collections","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall monitor the recovery and collection of amounts from third parties (as defined in section 1729(i) of such title) for deposit in such fund.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc30cbd27-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Medical Services Accounts","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/dI/tI/s115"},"text":"Pub. L. 108–447, div. I, title I, § 115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3293"},"text":"118 Stat. 3293","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/447/dI/tI/s115"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hereafter receipts that would otherwise be credited to the accounts listed in subsection (c) shall be deposited into the Medical Care Collections Fund, and shall be transferred to and merged with the ‘Medical services’ account, in fiscal year 2005 and subsequent years, to remain available until expended, to carry out the purposes of the ‘Medical services’ account.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The unobligated balances in the accounts listed in subsection (c), shall be transferred to and merged with the ‘Medical services’ account in fiscal year 2005 and subsequent years, and remain available until expended, to carry out the purposes of the ‘Medical services’ account: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the obligated balances in these accounts may be transferred to the ‘Medical services’ account at the discretion of the Secretary of Veterans Affairs and shall remain available until expended."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Veterans Extended Care Revolving Fund; Medical Facilities Revolving Fund; Special Therapeutic and Rehabilitation Fund; Nursing Home Revolving Fund; Veterans Health Services Improvement Fund; and Parking Revolving Fund.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation act:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dG/tI/s115"},"text":"Pub. L. 108–199, div. G, title I, § 115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/370"},"text":"118 Stat. 370","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc30cbd28-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report on Implementation of Section 8023 of Pub. L. 105–33","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/tVIII/s8023/f"},"text":"Pub. L. 105–33, title VIII, § 8023(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/667"},"text":"111 Stat. 667","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/33/tVIII/s8023/f"},"text":"“Not later than ","children":[{"tag":"date","attrib":{"date":"1999-01-01"},"text":"January 1, 1999","children":[],"tail":", the Secretary of Veterans Affairs shall submit to the Committees on Veterans’ Affairs of the Senate and House of Representatives a report on the implementation of this section [enacting this section, amending sections 712, 1710, 1722A, and 1729 of this title, and enacting provisions set out as notes under sections 712 and 1729 of this title]. The report shall describe the collections under each of the provisions specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1729A/b"},"text":"section 1729A(b) of title 38","children":[],"tail":", United States Code, as added by subsection (a). Information on such collections shall be shown for each of the health service networks (known as Veterans Integrated Service Networks) and, to the extent practicable for each facility within each such network. The Secretary shall include in the report an analysis of differences among the networks with respect to (A) the market in which the networks operates, (B) the effort expended to achieve collections, (C) the efficiency of such effort, and (D) any other relevant information.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
