, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2092"},"text":"103 Stat. 2092","children":[],"tail":"; renumbered § 3481, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/233/tV/s503/8/A"},"text":"Pub. L. 109–233, title V, § 503(8)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-06-15"},"text":"June 15, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/416"},"text":"120 Stat. 416","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc370fd63-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc370fd64-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc370fd65-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those comprising subsecs. (a), (b), (d), and (e) of this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1179"},"text":"72 Stat. 1179","children":[],"tail":", which was classified to former "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1631"},"text":"section 1631 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/89/358/s4/a"},"text":"section 4(a) of Pub. L. 89–358","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc370fd66-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/233"},"text":"Pub. L. 109–233","children":[],"tail":" revised style of subsec. headings."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1681"},"text":"section 1681 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/s2003/b/4/A"},"text":"Pub. L. 97–35, § 2003(b)(4)(A)","children":[],"tail":", struck out applicability to flight training program."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/s2003/b/4/B"},"text":"Pub. L. 97–35, § 2003(b)(4)(B)","children":[],"tail":", struck out subsec. (c) which related to flight training."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/502"},"text":"Pub. L. 94–502","children":[],"tail":", §§ 210(2), 211(10), substituted “chapter 36” for “section 1780” and “the veteran’s” for “his”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/502/s210/2"},"text":"Pub. L. 94–502, § 210(2)","children":[],"tail":", substituted “chapter 36” for “section 1780”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/540"},"text":"Pub. L. 92–540","children":[],"tail":" inserted heading and provisions requiring allowances to be paid in accordance with the applicable provisions of this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1780"},"text":"section 1780 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/540"},"text":"Pub. L. 92–540","children":[],"tail":" inserted heading and substituted provisions requiring allowances of an eligible veteran pursuing a program of education, other than a program exclusively by correspondence or a program of flight training, at an educational institution to be paid as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1780"},"text":"section 1780 of this title","children":[],"tail":", for provisions requiring allowances of an eligible veteran to be paid, as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1682"},"text":"section 1682 of this title","children":[],"tail":", only for the period of his enrollment as approved by the Administrator, but limiting such payments to veterans meeting certain specified requirements while pursuing standard college degrees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/540"},"text":"Pub. L. 92–540","children":[],"tail":" inserted heading and substituted provisions relating to the payment of allowances to eligible veterans pursuing a program of education consisting exclusively of flight training, for provisions authorizing the Administrator to prescribe regulations to determine enrollment in, pursuit of, and attendance at, any program of education or course by an eligible veteran."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/540"},"text":"Pub. L. 92–540","children":[],"tail":" struck out subsec. (d) which related to certification to the Administrator from the eligible veteran as to his actual attendance or completion of lessons by correspondence, and from the educational institution that such veteran was enrolled in and pursuing a course of education during such period or completion of lessons by correspondence by the veteran and serviced by the institution."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/540"},"text":"Pub. L. 92–540","children":[],"tail":" struck out subsec. (e) which related to the prompt payment of the educational assistance allowance to the veteran."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/584"},"text":"Pub. L. 91–584","children":[],"tail":" excluded programs of apprenticeship and programs of other on-job training authorized by "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1683"},"text":"section 1683 of this title","children":[],"tail":" for educational assistance to veterans."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/219"},"text":"Pub. L. 91–219","children":[],"tail":" inserted provision that the Administrator may pay an educational assistance allowance representing the initial payment of an enrollment period, not exceeding one full month, upon receipt of a certificate of enrollment."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc370fd67-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateO