{"tag":"section","attrib":{"id":"idc370fd5f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3481"},"text":null,"children":[{"tag":"num","attrib":{"value":"3481"},"text":"§ 3481.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Educational assistance allowance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc370fd60-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3481/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall, in accordance with the applicable provisions of this section and chapter 36 of this title, pay to each eligible veteran who is pursuing a program of education under this chapter an educational assistance allowance to meet, in part, the expenses of the veteran’s subsistence, tuition, fees, supplies, books, equipment, and other educational costs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc370fd61-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3481/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Institutional Training","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The educational assistance allowance of an eligible veteran pursuing a program of education, other than a program exclusively by correspondence, at an educational institution shall be paid as provided in chapter 36 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc370fd62-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/358/s2"},"text":"Pub. L. 89–358, § 2","children":[],"tail":", "},{"