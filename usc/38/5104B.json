{"tag":"section","attrib":{"id":"idc3d05bd8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5104B"},"text":null,"children":[{"tag":"num","attrib":{"value":"5104B"},"text":"§ 5104B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Higher-level review by the agency of original jurisdiction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3d05bd9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5104B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3d05bda-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5104B/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A claimant may request a review of the decision of the agency of original jurisdiction by a higher-level adjudicator within the agency of original jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d05bdb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5104B/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall approve each request for review under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d05bdc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5104B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time and Manner of Request","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3d05bdd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5104B/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A request for higher-level review by the agency of original jurisdiction shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3d05bde-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5104B/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in writing in such form as the Secretary may prescribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3d05bdf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5104B/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made within one year of the notice of the agency of original jurisdiction’s decision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d05be0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5104B/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such request may specifically indicate whether such review is requested by a higher-level adjudicator at the same office within the agency of original jurisdiction or by an adjudicator at a different office of the agency of original jurisdiction. The Secretary shall not deny such request for review by an adjudicator at a different office of the agency of original jurisdiction without good cause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d05be1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5104B/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Decision","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notice of a higher-level review decision under this section shall be provided to the claimant (and any representative of such claimant) and shall include a general statement—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3d05be2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5104B/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reflecting whether evidence was not considered pursuant to subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d05be3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5104B/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" noting the options available to the claimant to have the evidence described in paragraph (1), if any, considered by the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d05be4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5104B/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Evidentiary Record for Review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The evidentiary record before the higher-level adjudicator shall be limited to the evidence of record in the agency of original jurisdiction decision being reviewed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d05be5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5104B/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"De Novo Review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A review of the decision of the agency of original jurisdiction by a higher-level adjudicator within the agency of original jurisdiction shall be de novo.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3d05be6-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/55/s2/g/1"},"text":"Pub. L. 115–55, § 2(g)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-23"},"text":"Aug. 23, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1107"},"text":"131 Stat. 1107","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/168/tVIII/s807/a/3"},"text":"Pub. L. 117–168, title VIII, § 807(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-10"},"text":"Aug. 10, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1806"},"text":"136 Stat. 1806","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3d05be7-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3d05be8-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3d05be9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/168"},"text":"Pub. L. 117–168","children":[],"tail":" substituted “to the claimant (and any representative of such claimant)” for “in writing” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3d05bea-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3d05beb-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to all claims for which the Secretary of Veterans Affairs provides notice of a decision under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5104"},"text":"section 5104 of this title","children":[],"tail":" on or after the later of 540 days after "},{"tag":"date","attrib":{"date":"2017-08-23"},"text":"Aug. 23, 2017","children":[],"tail":", or 30 days after the date on which the Secretary submits to Congress a certification of certain capabilities of the Department of Veterans Affairs to carry out the new appeals system established by "},{"tag":"ref","attrib":{"href":"/us/pl/115/55"},"text":"Pub. L. 115–55","children":[],"tail":" and to address appeals of decisions on legacy claims, with provision for early applicability of the new appeals system to certain claims, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/55/s2/x"},"text":"section 2(x) of Pub. L. 115–55","children":[],"tail":", set out as an Effective Date of 2017 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of this title","children":[],"tail":", and bracketed note thereunder."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3d05bec-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/168"},"text":"Pub. L. 117–168","children":[],"tail":" not to be construed to apply "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5104/a"},"text":"section 5104(a) of this title","children":[],"tail":" to decisions of the Board of Veterans’ Appeals under chapter 71 of this title, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/168/s807/b"},"text":"section 807(b) of Pub. L. 117–168","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5100"},"text":"section 5100 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
