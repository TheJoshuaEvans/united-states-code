{"tag":"section","attrib":{"id":"idc3165a0b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1832"},"text":null,"children":[{"tag":"num","attrib":{"value":"1832"},"text":"§ 1832.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of certain administrative provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3165a0c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1832/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of Certain Provisions Relating to Compensation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The provisions of this title specified in subsection (b) apply with respect to benefits and assistance under this chapter in the same manner as those provisions apply to compensation paid under chapter 11 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3165a0d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1832/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Specified Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The provisions of this title referred to in subsection (a) are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3165a0e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1832/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 5101(c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3165a0f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1832/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsections (a), (b)(3), (g), and (i) of section 5110.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3165a10-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1832/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 5111.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3165a11-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1832/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (a) and paragraphs (1), (6), (9), and (10) of subsection (b) of section 5112.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3165a12-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/419/tIV/s401/b"},"text":"Pub. L. 106–419, title IV, § 401(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1859"},"text":"114 Stat. 1859","children":[],"tail":", § 1822; renumbered § 1832, "},{"tag":"ref","attrib":{"href":"/us/pl/108/183/tI/s102/a/1"},"text":"Pub. L. 108–183, title I, § 102(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-16"},"text":"Dec. 16, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2653"},"text":"117 Stat. 2653","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/58/tVI/s601/8"},"text":"Pub. L. 114–58, title VI, § 601(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-09-30"},"text":"Sept. 30, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/538"},"text":"129 Stat. 538","