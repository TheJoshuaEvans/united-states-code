{"tag":"section","attrib":{"id":"idc3f681da-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A"},"text":null,"children":[{"tag":"num","attrib":{"value":"7310A"},"text":"§ 7310A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports on Women’s Health","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3f681db-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than December 1 of each year, the Chief Officer of Women’s Health shall submit to the appropriate congressional committees a report containing the matters under subsections (b) through (g).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3f681dc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Office of Women’s Health","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under subsection (a) shall include a description of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3f681dd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actions taken by the Office of Women’s Health established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7310"},"text":"section 7310 of this title","children":[],"tail":" in the preceding fiscal year to improve the provision of health care by the Department to women veterans;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f681de-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any identified deficiencies related to the provision of health care by the Department to women veterans and the standards of care established in such section and the plan of the Department to address such deficiencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f681df-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the funding and personnel provided to the Office and whether additional funding or personnel are needed to meet the requirements of such section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f681e0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other information that would be of interest to the appropriate congressional committees with respect to oversight of the provision of health care by the Department to women veterans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3f681e1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Access to Gender-specific Services","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3f681e2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each report under subsection (a) shall include an analysis of the access of women veterans to gender-specific services under contracts, agreements, or other arrangements with non-Department medical providers entered into by the Secretary for the provision of hospital care or medical services to veterans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f681e3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The analysis under paragraph (1) shall include data and performance measures for the availability of gender-specific services described in such paragraph, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3f681e4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average wait time between the preferred appointment date of the veteran and the date on which the appointment is completed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3f681e5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average driving time required for veterans to attend appointments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3f681e6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasons why appointments could not be scheduled with non-Department medical providers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3f681e7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Models of Care","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3f681e8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each report under subsection (a) shall include an analysis of the use by the Department of general primary care clinics, separate but shared spaces, and women’s health centers as delivery of care models for women veterans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f681e9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The analysis under paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3f681ea-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of facilities of the Department that fall into each delivery of care model described in such paragraph, disaggregated by Veterans Integrated Service Network and State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3f681eb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the criteria used by the Department to determine which such model is most appropriate for each facility of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3f681ec-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of how the Department decides to make investments to modify facilities to a different model.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3f681ed-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of what, if any, plans the Department has to modify facilities from general primary care clinics to another model.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3f681ee-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of whether any facilities could be modified to a separate but shared space for a women’s health center within planned investments under the strategic capital investment planning process of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3f681ef-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of whether any facilities could be modified to a separate or shared space or a women’s health center with minor modifications to existing plans under the strategic capital investment planning process of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3f681f0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A/d/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of whether the Department has a goal for how many facilities should fall into each such model.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3f681f1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Staffing","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under subsection (a) shall include an analysis of the staffing of the Department relating to the treatment of women, including the following, disaggregated by Veterans Integrated Service Network and State (except with respect to paragraph (4)):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3f681f2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of women’s health centers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f681f3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of patient aligned care teams of the Department relating to women’s health.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f681f4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of full- and part-time gynecologists of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f681f5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of designated women’s health care providers of the Department, disaggregated by facility of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f681f6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of health care providers of the Department who have completed a mini-residency for women’s health care through the Women Veterans Health Care Mini-Residency Program of the Department during the one-year period preceding the submittal of the report and the number of mini-residency training slots for such program that are available during the one-year period following such date.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f681f7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of designated women’s health care providers of the Department who have sufficient women patient loads or case complexities to retain their competencies and proficiencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3f681f8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accessibility and Treatment Options","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under subsection (a) shall include an analysis of the accessibility and treatment options for women veterans, including the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3f681f9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of wheelchair accessibility of women’s health centers of the Department, including, with respect to each such center, an assessment of accessibility for each kind of treatment provided at the center, including with respect to radiology and mammography, that addresses all relevant factors, including door sizes, hoists, and equipment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f681fa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The options for women veterans to access mental health providers and primary care providers who are women.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f681fb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The options for women veterans at medical facilities of the Department with respect to clothing sizes, including for gowns, drawstring pants, and pajamas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3f681fc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3f681fd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3f681fe-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations and the Committee on Veterans’ Affairs of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3f681ff-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations and the Committee on Veterans’ Affairs of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f68200-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7310A/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “gender-specific services” means mammography, obstetric care, gynecological care, and such other services as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3f68201-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/tV/s5101/b/1"},"text":"Pub. L. 116–315, title V, § 5101(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/5024"},"text":"134 Stat. 5024","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3f68202-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3f68203-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3f68204-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References to Health Care and Services","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For references to health care and services in this section as references to health care and services included in medical benefits package provided by the Department as in effect on the day before ","children":[{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/315/tV/s5101/b/2"},"text":"Pub. L. 116–315, title V, § 5101(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/5026"},"text":"134 Stat. 5026","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7310"},"text":"section 7310 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3f68205-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Initial Report","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/tV/s5101/c"},"text":"Pub. L. 116–315, title V, § 5101(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/5026"},"text":"134 Stat. 5026","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/315/tV/s5101/c"},"text":"“The Chief Officer of Women’s Health of the Department of Veterans Affairs shall submit the initial report under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7310A"},"text":"section 7310A of title 38","children":[],"tail":", United States Code, as added by subsection (b), by not later than one year after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
