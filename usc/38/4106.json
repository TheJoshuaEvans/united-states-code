ment of Medicine and Surgery, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s401/a/3"},"text":"Pub. L. 102–40, title IV, § 401(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/210"},"text":"105 Stat. 210","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7403"},"text":"section 7403 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those comprising this section were contained in former ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2005"},"text":"section 2005 of this title","children":[],"tail":" prior to the amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/92/540"},"text":"Pub. L. 92–540","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3bd484a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/288/s5/a/1/C"},"text":"Pub. L. 107–288, § 5(a)(1)(C)","children":[],"tail":", substituted “proper intensive services” for “proper counseling”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/288/s4/d/1"},"text":"Pub. L. 107–288, § 4(d)(1)","children":[],"tail":", amended last sentence generally. Prior to amendment, last sentence read as follows: “Each budget submission with respect to such funds shall include separate listings of the amount for the National Veterans’ Employment and Training Services Institute and of the proposed numbers, by State, of disabled veterans’ outreach program specialists appointed under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4103A"},"text":"section 4103A of this title","children":[],"tail":" and local veterans’ employment representatives assigned under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4104"},"text":"section 4104 of this title","children":[],"tail":", together with information demonstrating the compliance of such budget submission with the funding requirements specified in the preceding sentence.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2006"},"text":"section 2006 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “4102A(b)” for “2002A(b)”, “4109” for “2009”, “4103A” for “2003A”, and “4104” for “2004”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323/s15/a/2"},"text":"Pub. L. 100–323, § 15(a)(2)","children":[],"tail":", struck out “of Labor” after “Secretary” in first and fifth sentences."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323/s2/b"},"text":"Pub. L. 100–323, § 2(b)","children":[],"tail":", (e)(2), substituted “in all of the States for the purposes specified in paragraph (5) of "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2002A/b"},"text":"section 2002A(b) of this title","children":[],"tail":" and to fund the National Veterans’ Employment and Training Services Institute under section 2009” for “to fund the disabled veterans’ outreach program under section 2003A” and “with such sections” for “with such section” in fifth sentence, inserted after fifth sentence “Each budget submission with respect to such funds shall include separate listings of the amount for the National Veterans’ Employment and Training Services Institute and of the proposed numbers, by State, of disabled veterans’ outreach program specialists appointed under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2003A"},"text":"section 2003A of this title","children":[],"tail":" and local veterans’ employment representatives assigned under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2004"},"text":"section 2004 of this title","children":[],"tail":", together with information demonstrating the compliance of such budget submission with the funding requirements specified in the preceding sentence.”, and struck out at end “Each budget submission with respect to such funds shall include a separate listing of the proposed number, by State, for disabled veterans outreach program specialists appointed under such section. The Secretary shall carry out this subsection through the Assistant Secretary for Veterans’ Employment.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323/s2/c"},"text":"Pub. L. 100–323, § 2(c)","children":[],"tail":", struck out “, except with the approval of the Secretary of Labor, upon the recommendation of the Assistant Secretary of Labor for Veterans’ Employment, based on a demonstrated lack of need for such funds for such purposes” after “in such subsections”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/306/s306/a"},"text":"Pub. L. 97–306, § 306(a)","children":[],"tail":", inserted “and chapters 42 and 43 of this title” after “administration of this chapter”, and inserted provisions at end relating to the inclusion in estimated necessary funds of amounts necessary to fund the disabled veterans’ outreach program, inclusion in budgets of the proposed number for program specialists, and the carrying out of this subsection through the Assistant Secretary for Veterans’ Employment."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/306/s306/b"},"text":"Pub. L. 97–306, § 306(b)","children":[],"tail":", inserted “, upon the recommendation of the Assistant Secretary of Labor for Veterans’ Employment,” after “Secretary of Labor”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/502"},"text":"Pub. L. 94–502","children":[],"tail":" substituted “agencies shall each be” for “agencies shall be”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/508"},"text":"Pub. L. 93–508","children":[],"tail":" substituted “training services to eligible veterans and eligible persons” for “training services to veterans”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3bd484b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3bd484c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/288/s4/d/2"},"text":"Pub. L. 107–288, § 4(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-07"},"text":"Nov. 7, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2044"},"text":"116 Stat. 2044","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/288/s4/d/2"},"text":"“The amendment made by paragraph (1) [amending this section] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2002-11-07"},"text":"Nov. 7, 2002","childr