{"tag":"section","attrib":{"id":"idc3413a8f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2308"},"text":null,"children":[{"tag":"num","attrib":{"value":"2308"},"text":"§ 2308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation of deceased veteran to a national cemetery or a covered veterans’ cemetery","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3413a90-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2308/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may pay, in addition to any amount paid pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2303"},"text":"section 2303 of this title","children":[],"tail":" regarding veterans described in subparagraph (B) or (C) of subsection (a)(2) of such section, or pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2307"},"text":"section 2307 of this title","children":[],"tail":", the cost of transportation of the deceased veteran described in subsection (b) for burial in a national cemetery or a covered veterans’ cemetery. Such payment shall not exceed the cost of transportation to the national cemetery nearest the veteran’s last place of residence in which burial space is available."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3413a91-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2308/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deceased Veteran Described","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A deceased veteran described in this subsection is any of the following veterans:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3413a92-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2308/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A veteran who dies as the result of a service-connected disability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3413a93-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2308/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A veteran who dies while in receipt of disability compensation (or who but for the receipt of retirement pay or pension under this title, would have been entitled to compensation).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3413a94-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2308/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A veteran whom the Secretary determines is eligible for funeral expenses under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2303"},"text":"section 2303 of this title","children":[],"tail":" by virtue of the Secretary determining that the veteran has no next of kin or other person claiming the body of such veteran pursuant to subsection (a)(2)(C) of such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3413a95-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2308/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Veterans’ Cemetery Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “covered veterans’ cemetery” means a veterans’ cemetery—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3413a96-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2308/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which a deceased veteran described in subsection (b) is eligible to be buried;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3413a97-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2308/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3413a98-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2308/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is owned by a State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3413a99-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2308/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is on trust land owned by, or held in trust for, a tribal organization; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3413a9a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2308/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which the Secretary has made a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2408"},"text":"section 2408 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3413a9b-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","chil