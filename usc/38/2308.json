{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3413a9e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/s2201/c"},"text":"Pub. L. 116–315, § 2201(c)","children":[],"tail":", inserted “or a covered veterans’ cemetery” after “national cemetery” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/s2202/b/1/C/i"},"text":"Pub. L. 116–315, § 2202(b)(1)(C)(i)","children":[],"tail":", substituted “pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2303"},"text":"section 2303 of this title","children":[],"tail":" regarding veterans described in subparagraph (B) or (C) of subsection (a)(2) of such section, or pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2307"},"text":"section 2307 of this title","children":[],"tail":",” for “pursuant to section 2302 or 2307 of this title,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/s2201/a"},"text":"Pub. L. 116–315, § 2201(a)","children":[],"tail":", substituted “in a national cemetery or a covered veterans’ cemetery” for “in a national cemetery”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/s2202/b/1/C/ii"},"text":"Pub. L. 116–315, § 2202(b)(1)(C)(ii)","children":[],"tail":", substituted “section 2303” for “section 2302” and “subsection (a)(2)(C)” for “subsection (a)(2)(A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/s2201/b"},"text":"Pub. L. 116–315, § 2201(b)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/260"},"text":"Pub. L. 112–260","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, substituted “The Secretary” for “Where a veteran dies as the result of a service-connected disability, or is in receipt of (but for the receipt of retirement pay or pension under this title would have been entitled to) disability compensation, the Secretary”, inserted “described in subsection (b)” after “of the deceased veteran”, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s908"},"text":"section 908 of this title","children":[],"tail":" as this section and substituted “2302 or 2307” for “902 or 907”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" substituted “Secretary” for “Administrator”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3413a9f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3413aa0-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/tII/s2201/e"},"text":"Pub. L. 116–315, title II, § 2201(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4983"},"text":"134 Stat. 4983","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/315/tII/s2201/e"},"text":"“The amendments made by this section [amending this section] shall take effect on the date that is two years after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/s2202/b/1/C"},"text":"section 2202(b)(1)(C) of Pub. L. 116–315","children":[],"tail":" applicable to deaths that occur on or after the date that is two years after "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/315/s2202/d"},"text":"section 2202(d) of Pub. L. 116–315","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s113"},"text":"section 113 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3413aa1-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/260/tI/s104/b/3"},"text":"Pub. L. 112–260, title I, § 104(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-10"},"text":"Jan. 10, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2420"},"text":"126 Stat. 2420","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/260/tI/s104/b/3"},"text":"“The amendments made by this subsection [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2302"},"text":"section 2302 of this title","children":[],"tail":"] shall take effect on the date that is one year after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2013-01-10"},"text":"Jan. 10, 2013","children":[],"tail":"] and shall apply with respect to burials and funerals occurring on or after the date that is one year after the date of the enactment of this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3413aa2-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1976-10-01"},"text":"Oct. 1, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/433/s406"},"text":"section 406 of Pub. L. 94–433","children":[],"tail":", set out as an Effective Date of 1976 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
