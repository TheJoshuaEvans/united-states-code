{"tag":"section","attrib":{"id":"idc335546b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044"},"text":null,"children":[{"tag":"num","attrib":{"value":"2044"},"text":"§ 2044.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial assistance for supportive services for very low-income veteran families in permanent housing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc335546c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Distribution of Financial Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc335546d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall provide financial assistance to eligible entities approved under this section to provide and coordinate the provision of supportive services described in subsection (b) for very low-income veteran families occupying permanent housing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc335546e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Financial assistance under this section shall consist of grants for each such family for which an approved eligible entity is providing or coordinating the provision of supportive services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc335546f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3355470-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall provide such grants to each eligible entity that is providing or coordinating the provision of supportive services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3355471-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary is authorized to establish intervals of payment for the administration of such grants and establish a maximum amount to be awarded, in accordance with the services being provided and their duration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3355472-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In providing financial assistance under paragraph (1), the Secretary shall give preference to entities providing or coordinating the provision of supportive services for very low-income veteran families who are transitioning from homelessness to permanent housing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3355473-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall ensure that, to the extent practicable, financial assistance under this subsection is equitably distributed across geographic regions, including rural communities and tribal lands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3355474-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each entity receiving financial assistance under this section to provide supportive services to a very low-income veteran family shall notify that family that such services are being paid for, in whole or in part, by the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3355475-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may require entities receiving financial assistance under this section to submit a report to the Secretary that describes the projects carried out with such financial assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3355476-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Supportive Services","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The supportive services referred to in subsection (a) are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3355477-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Services provided by an eligible entity or a subcontractor of an eligible entity that address the needs of very low-income veteran families occupying permanent housing, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3355478-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outreach services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3355479-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" case management services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc335547a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance in obtaining any benefits from the Department which the veteran may be eligible to receive, including, but not limited to, vocational and rehabilitation counseling, employment and training service, educational assistance, and health care services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc335547b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assistance in obtaining and coordinating the provision of other public benefits provided in Federal, State, or local agencies, or any organization defined in subsection (f), including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc335547c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/b/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health care services (including obtaining health insurance);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc335547d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/b/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" daily living services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc335547e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/b/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personal financial planning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc335547f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/b/1/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transportation services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3355480-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/b/1/D/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" income support services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3355481-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/b/1/D/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fiduciary and representative payee services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3355482-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/b/1/D/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" legal services to assist the veteran family with issues that interfere with the family’s ability to obtain or retain housing or supportive services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3355483-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/b/1/D/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" child care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3355484-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/b/1/D/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" housing counseling; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3355485-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/b/1/D/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other services necessary for maintaining independent living.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3355486-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Services described in paragraph (1) that are delivered to very low-income veteran families who are homeless and who are scheduled to become residents of permanent housing within 90 days pending the location or development of housing suitable for permanent housing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3355487-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Services described in paragraph (1) for very low-income veteran families who have voluntarily chosen to seek other housing after a period of tenancy in permanent housing, that are provided, for a period of 90 days after such families exit permanent housing or until such families commence receipt of other housing services adequate to meet their current needs, but only to the extent that services under this paragraph are designed to support such families in their choice to transition into housing that is responsive to their individual needs and preferences.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3355488-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application for Financial Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3355489-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An eligible entity seeking financial assistance under subsection (a) shall submit to the Secretary an application therefor in such form, in such manner, and containing such commitments and information as the Secretary determines to be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc335548a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each application submitted by an eligible entity under paragraph (1) shall contain—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc335548b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the supportive services proposed to be provided by the eligible entity and the identified needs for those services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc335548c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the types of very low-income veteran families proposed to be provided such services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc335548d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the number of very low-income veteran families proposed to be provided such services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc335548e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evidence of the experience of the eligible entity in providing supportive services to very low-income veteran families; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc335548f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of the managerial capacity of the eligible entity—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc3355490-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/c/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coordinate the provision of supportive services with the provision of permanent housing by the eligible entity or by other organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3355491-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/c/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assess continuously the needs of very low-income veteran families for supportive services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3355492-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/c/2/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coordinate the provision of supportive services with the services of the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3355493-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/c/2/E/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to tailor supportive services to the needs of very low-income veteran families; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3355494-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/c/2/E/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to seek continuously new sources of assistance to ensure the long-term provision of supportive services to very low-income veteran families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3355495-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall establish criteria for the selection of eligible entities to be provided financial assistance under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3355496-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Technical Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3355497-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall provide training and technical assistance to participating eligible entities regarding the planning, development, and provision of supportive services to very low-income veteran families occupying permanent housing, through the Technical Assistance grants program in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2064"},"text":"section 2064 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3355498-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may provide the training described in paragraph (1) directly or through grants or contracts with appropriate public or nonprofit private entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3355499-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"From amounts appropriated to the Department for Medical Services, there shall be available to carry out subsections (a), (b), and (c) amounts as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc335549a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $15,000,000 for fiscal year 2009.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc335549b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for fiscal year 2010.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc335549c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $25,000,000 for fiscal year 2011.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc335549d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000,000 for fiscal year 2012.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc335549e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $320,000,000 for each of fiscal years 2015 through 2017.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc335549f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $340,000,000 for fiscal year 2018.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc33554a0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $380,000,000 for each of fiscal years 2019 and 2020.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc33554a1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/e/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $420,000,000 for each of fiscal years 2021 through 2025.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc33554a2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/e/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $660,000,000 for fiscal year 2026.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc33554a3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc33554a4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “consumer cooperative” has the meaning given such term in section 202 of the Housing Act of 1959 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1701q"},"text":"12 U.S.C. 1701q","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc33554a5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc33554a6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a private nonprofit organization; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc33554a7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a consumer cooperative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc33554a8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “homeless” has the meaning given that term in section 103 of the McKinney-Vento Homeless Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11302"},"text":"42 U.S.C. 11302","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc33554a9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “permanent housing” means community-based housing without a designated length of stay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc33554aa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “private nonprofit organization” means any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc33554ab-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/f/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any incorporated private institution or foundation—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc33554ac-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/f/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no part of the net earnings of which inures to the benefit of any member, founder, contributor, or individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc33554ad-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/f/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which has a governing board that is responsible for the operation of the supportive services provided under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc33554ae-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/f/5/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is approved by the Secretary as to financial responsibility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc33554af-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/f/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A for-profit limited partnership, the sole general partner of which is an organization meeting the requirements of clauses (i), (ii), and (iii) of subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc33554b0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/f/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A corporation wholly owned and controlled by an organization meeting the requirements of clauses (i), (ii), and (iii) of subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc33554b1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/f/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A tribally designated housing entity (as defined in section 4 of the Native American Housing Assistance and Self-Determination Act of 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4103"},"text":"25 U.S.C. 4103","children":[],"tail":"))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc33554b2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc33554b3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/f/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subparagraphs (B) and (C), the term “very low-income veteran family” means a veteran family whose income does not exceed 50 percent of the median income for an area specified by the Secretary for purposes of this section, as determined by the Secretary in accordance with this paragraph.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc33554b4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/f/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall make appropriate adjustments to the income requirement under subparagraph (A) based on family size.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc33554b5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/f/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may establish an income ceiling higher or lower than 50 percent of the median income for an area if the Secretary determines that such variations are necessary because the area has unusually high or low construction costs, fair market rents (as determined under section 8 of the United States Housing Act of 1937 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f"},"text":"42 U.S.C. 1437f","children":[],"tail":")), or family incomes."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc33554b6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2044/f/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “veteran family” includes a veteran who is a single person and a family in which the head of household or the spouse of the head of household is a veteran.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc33554b7-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/387/tVI/s604/b/1"},"text":"Pub. L. 110–387, title VI, § 604(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4132"},"text":"122 Stat. 4132","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/275/tX/s1001/e"},"text":"Pub. L. 111–275, title X, § 1001(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-13"},"text":"Oct. 13, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2896"},"text":"124 Stat. 2896","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/37/s12"},"text":"Pub. L. 112–37, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-10-05"},"text":"Oct. 5, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/397"},"text":"125 Stat. 397","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/154/tIII/s305/c"},"text":"Pub. L. 112–154, title III, § 305(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1187"},"text":"126 Stat. 1187","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/37/s2/f/2"},"text":"Pub. L. 113–37, § 2(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-09-30"},"text":"Sept. 30, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/524"},"text":"127 Stat. 524","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/175/tII/s206"},"text":"Pub. L. 113–175, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-