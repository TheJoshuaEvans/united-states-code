dren":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/37/s12"},"text":"Pub. L. 112–37, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-10-05"},"text":"Oct. 5, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/397"},"text":"125 Stat. 397","children":[],"tail":", which directed amendment of “section 2044” without specifying the Code title to be amended, was executed to this section, which is "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2044"},"text":"section 2044 of Title 38","children":[],"tail":", Veterans’ Benefits, to reflect the probable intent of Congress. See 2011 Amendment notes below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc33554bb-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (e)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/37"},"text":"Pub. L. 119–37","children":[],"tail":" added par. (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2024—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/83"},"text":"Pub. L. 118–83","children":[],"tail":" substituted “2025” for “2024” in subpar. (H) and redesignated subpars. (A) to (H) as pars. (1) to (8), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s305/a"},"text":"Pub. L. 117–328, § 305(a)","children":[],"tail":", struck out par. (1) designation before “From amounts” and struck out pars. (2) and (3) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Not more than $750,000 may be available under paragraph (1) in any fiscal year to provide technical assistance under subsection (d).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) There is authorized to be appropriated $1,000,000 for each of the fiscal years 2009 through 2012 to carry out the provisions of subsection (d).”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/180"},"text":"Pub. L. 117–180","children":[],"tail":" substituted “through 2024” for “and 2022”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (e)(1)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/159/s5305/1"},"text":"Pub. L. 116–159, § 5305(1)","children":[],"tail":", substituted “and 2020” for “through 2021”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/159/s5305/2"},"text":"Pub. L. 116–159, § 5305(2)","children":[],"tail":", added subpar. (H)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (e)(1)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/61"},"text":"Pub. L. 116–61","children":[],"tail":" substituted “each of fiscal years 2019 through 2021” for “fiscal year 2019”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (e)(1)(F), (G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/251"},"text":"Pub. L. 115–251","children":[],"tail":" added subpars. (F) and (G) and struck out former subpar. (F) which read as follows: “$320,000,000 for each of fiscal years 2018 through 2019.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (e)(1)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/62"},"text":"Pub. L. 115–62","children":[],"tail":" added subpar. (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (e)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/228"},"text":"Pub. L. 114–228","children":[],"tail":" amended subpar. (E) generally. Prior to amendment, subpar. (E) read as follows: “$300,000,000 for each of fiscal years 2015 through 2016.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—