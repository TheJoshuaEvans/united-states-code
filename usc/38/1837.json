{"tag":"section","attrib":{"id":"idc3165a3e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1837"},"text":null,"children":[{"tag":"num","attrib":{"value":"1837"},"text":"§ 1837.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of health care and benefits provided","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide a covered child with health care and benefits under this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3165a3f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1837/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the duration of the life of the child; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3165a40-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1837/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding any death of a parent of the child that precedes the death of the child.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3165a41-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/18/s1/b"},"text":"Pub. L. 118–18, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-10-06"},"text":"Oct. 6, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/104"},"text":"137 Stat. 104","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
