{"tag":"section","attrib":{"id":"idc3b16201-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3745"},"text":null,"children":[{"tag":"num","attrib":{"value":"3745"},"text":"§ 3745.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest on loans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3b16202-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3745/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Loans guaranteed under this subchapter shall bear interest not in excess of such rate as the Secretary may from time to time find the loan market demands. In establishing the rate of interest that shall be applicable to such loans, the Secretary shall consult with the Administrator of the Small Business Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3b16203-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3745/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rate of interest on any direct loan made by the Secretary under this subchapter may not exceed the maximum rate in effect under subsection (a) of this section at the time the direct loan is made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3b16204-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/72/tIII/s302/a"},"text":"Pub. L. 97–72, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-11-03"},"text":"Nov. 3, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1058"},"text":"95 Stat. 1058","children":[],"tail":", § 1845; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIII/s313/b/1"},"text":"Pub. L. 101–237, title III, § 313(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2077"},"text":"103 Stat. 2077","children":[],"tail":"; renumbered § 3745 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":", §§ 4(b)(1), (2)(E), 5(a), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404-406"},"text":"105 Stat. 404–406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/446/tXII/s1201/a/3"},"text":"Pub. L. 103–446, title XII, § 1201(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4682"},"text":"108 Stat. 4682","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3b16205-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3b16206-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3b16207-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446"},"text":"Pub. L. 103–446","children":[],"tail":" substituted “Administrator” for “Secretary” before “of the Small Business Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1845"},"text":"section 1845 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator” before “of the Small Business Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" substituted “Secretary” for “Administrator” wherever appearing other than third place it appears in subsec. (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
