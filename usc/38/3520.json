{"tag":"section","attrib":{"id":"idc37a72cc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3520"},"text":null,"children":[{"tag":"num","attrib":{"value":"3520"},"text":"§ 3520.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Educational and vocational counseling","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may, upon request, arrange for educational or vocational counseling for persons eligible for benefits under this chapter to assist such persons in selecting their educational, vocational, or professional objectives and in developing their programs of education.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc37a72cd-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1195"},"text":"72 Stat. 1195","children":[],"tail":", § 1720; "},{"tag":"ref","attrib":{"href":"/us/pl/90/631/s2/g"},"text":"Pub. L. 90–631, § 2(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-23"},"text":"Oct. 23, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1333"},"text":"82 Stat. 1333","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/584/s4"},"text":"Pub. L. 91–584, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1576"},"text":"84 Stat. 1576","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/540/tIII/s310"},"text":"Pub. L. 92–540, title III, § 310","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-24"},"text":"Oct. 24, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1083"},"text":"86 Stat. 1083","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/502/tIII/s310/10"},"text":"Pub. L. 94–502, title III, § 310(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-15"},"text":"Oct. 15, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2391"},"text":"90 Stat. 2391","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/466/tIII/s323/a"},"text":"Pub. L. 96–466, title III, § 323(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2196"},"text":"94 Stat. 2196","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/295/s4/45"},"text":"Pub. L. 97–295, § 4(45)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1308"},"text":"96 Stat. 1308","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/576/tIII/s314/a"},"text":"Pub. L. 99–576, title III, § 314(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3273"},"text":"100 Stat. 3273","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIV/s423/b/1/A"},"text":"Pub. L. 101–237, title IV, § 423(b)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2092"},"text":"103 Stat. 2092","children":[],"tail":"; renumbered § 3520, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc37a72ce-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc37a72cf-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc37a72d0-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1720"},"text":"section 1720 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576"},"text":"Pub. L. 99–576","children":[],"tail":" substituted “Educational and vocational counseling” for “Development of educational plan” in section catchline and amended text generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) Upon provisional approval of an application for educational assistance for a person eligible within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1701/a/1/A"},"text":"section 1701(a)(1)(A) of this title","children":[],"tail":", the Administrator may, upon request, arrange for educational or vocational counseling to assist the parent or guardian and the eligible person in selecting such person’s educational, vocational, or professional objective and in developing such person’s program of education. During, or after, such counseling, the parent or guardian shall prepare for the eligible person an educational plan which shall set forth the selected objective, the proposed program of education, a list of the educational institutions at which such program would be pursued, an estimate of the sum which would be required for tuition and fees in completion of such program, and such other information as the Administrator shall require. This educational plan shall be signed by the parent or guardian and shall become an integral part of the application for educational assistance under this chapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) The Administrator may, on request, arrange for educational counseling for persons eligible for educational assistance under section 1701(a)(1)(B), (C), or (D) of this title.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295/s4/45/A"},"text":"Pub. L. 97–295, § 4(45)(A)","children":[],"tail":", inserted “of this title” after “section 1701(a)(1)(A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295/s4/45/B"},"text":"Pub. L. 97–295, § 4(45)(B)","children":[],"tail":", substituted “of this title” for “of this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466"},"text":"Pub. L. 96–466","children":[],"tail":" substituted “the Administrator may, upon request, arrange for” for “the Administrator shall arrange for, and the eligible person shall take advantage of,” and struck out provision that educational or vocational counseling not be required where the eligible person has been accepted for, or is pursuing, courses which lead to a standard college degree, at an approved institution."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/502"},"text":"Pub. L. 94–502","children":[],"tail":" substituted “such person’s” for “his” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/540"},"text":"Pub. L. 92–540","children":[],"tail":" inserted provisions exempting the eligible person from counseling where such person has been accepted for, or is pursuing, courses which lead to a standard college degree at an approved institution."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/584"},"text":"Pub. L. 91–584","children":[],"tail":" substituted “section 1701(a)(1)(B), (C), or (D)” for “section 1701(a)(1) (B) or (C)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/631/s2/g/1"},"text":"Pub. L. 90–631, § 2(g)(1)","children":[],"tail":", (2), designated existing provisions as subsec. (a) and inserted “for a person eligible within the meaning of section 1701(a)(1)(A)” after “for educational assistance”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/631/s2/g/3"},"text":"Pub. L. 90–631, § 2(g)(3)","children":[],"tail":", added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc37a72d1-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc37a72d2-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attri