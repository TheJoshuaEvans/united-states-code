{"tag":"section","attrib":{"id":"idc4322a87-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8156"},"text":null,"children":[{"tag":"num","attrib":{"value":"8156"},"text":"§ 8156.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with health services development activities carried out under the National Health Planning and Resources Development Act of 1974","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary and the Secretary of Health and Human Services shall, to the maximum extent practicable, coordinate programs carried out under this subchapter and programs carried out under part F of title XVI of the Public Health Service Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300t"},"text":"42 U.S.C. 300t","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc4322a88-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/785/tII/s203"},"text":"Pub. L. 89–785, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-07"},"text":"Nov. 7, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1375"},"text":"80 Stat. 1375","children":[],"tail":", § 5056; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/581/tI/s115/a/2"},"text":"Pub. L. 94–581, title I, § 115(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2853"},"text":"90 Stat. 2853","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/295/s4/93"},"text":"Pub. L. 97–295, § 4(93)","children":[],"tail":", (95)(A), "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1313"},"text":"96 Stat. 1313","children":[],"tail":"; renumbered § 8156