ildren":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" substituted “The Secretary” for “The Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295/s4/95/A"},"text":"Pub. L. 97–295, § 4(95)(A)","children":[],"tail":", substituted “Health and Human Services” for “Health, Education, and Welfare”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295/s4/93"},"text":"Pub. L. 97–295, § 4(93)","children":[],"tail":", inserted “("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300t"},"text":"42 U.S.C. 300t","children":[],"tail":" et seq.)” after “part F of title XVI of the Public Health Service Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/581"},"text":"Pub. L. 94–581","children":[],"tail":" substituted “health services development activities carried out under the National Health Planning and Resources Development Act of 1974” for “programs carried out under the Heart Disease, Cancer, and Stroke Amendments of 1965” in section catchline and “part F of title XVI” for “title IX” in text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc4322a8d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc4322a8e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/9