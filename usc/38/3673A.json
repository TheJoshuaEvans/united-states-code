{"tag":"section","attrib":{"id":"idc388cba8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3673A"},"text":null,"children":[{"tag":"num","attrib":{"value":"3673A"},"text":"§ 3673A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Risk-based surveys","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc388cba9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3673A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Development Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, in partnership with State approving agencies, shall develop a risk-based survey for oversight of educational institutions with courses and programs of education approved under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc388cbaa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3673A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc388cbab-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3673A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The scope of the risk-based survey developed under subsection (a) shall be determined by the Secretary, in partnership with the State approving agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc388cbac-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3673A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" At a minimum the scope determined under paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc388cbad-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3673A/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Rapid increase in veteran enrollment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc388cbae-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3673A/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Rapid increase in tuition and fees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc388cbaf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3673A/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Complaints tracked and published with the mechanism required by section 3698(b)(2) from students pursuing programs of education with educational assistance furnished under laws administered by the Secretary, based on severity or volume of the complaints.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc388cbb0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3673A/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Compliance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3680A/d/1"},"text":"section 3680A(d)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc388cbb1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3673A/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Veteran completion rates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc388cbb2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3673A/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indicators of financial stability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc388cbb3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3673A/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Review of the advertising and recruiting practices of the educational institution, including those by third-party contractors of the educational institution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc388cbb4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3673A/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Matters for which the Federal Government or a State Government brings an action in a court of competent jurisdiction against an educational institution, including matters in cases in which the Federal Government or the State comes to a settled agreement on such matters outside of the court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc388cbb5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3673A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Database","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, in partnership with the State approving agencies under this chapter, shall establish a searchable database or use an existing system, as the Secretary considers appropriate, to serve as a central repository for information required for or collected during site visits for the risk-based survey developed under subsection (a), so as to improve future oversight of educational institutions with programs of education approved under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc388cbb6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3673A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To the maximum amount feasible, the Secretary, or a State approving agency, as applicable, shall provide not more than two business days of notice to an educational institution before conducting a targeted risk-based survey of the institution under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc388cbb7-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/tI/s1013/a/1"},"text":"Pub. L. 116–315, title I, § 1013(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4942"},"text":"134 Stat. 4942","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/16/s7/a/3"},"text":"Pub. L. 117–16, § 7(a)(3)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2021-06-08"},"text":"June 8, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/285"},"text":"135 Stat. 285","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/333/s12/a"},"text":"Pub. L. 117–333, § 12(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6134"},"text":"136 Stat. 6134","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/210/tII/s204"},"text":"Pub. L. 118–210, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-02"},"text":"Jan. 2, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2763"},"text":"138 Stat. 2763","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc388cbb8-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc388cbb9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc388cbba-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/210"},"text":"Pub. L. 118–210","children":[],"tail":" substituted “two business days” for “one business day”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2023—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/333"},"text":"Pub. L. 117–333","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/16/s7/b/1"},"text":"Pub. L. 117–16, § 7(b)(1)","children":[],"tail":", made technical correction to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/116/315/s1013/a/1"},"text":"Pub. L. 116–315, § 1013(a)(1)","children":[],"tail":", which enacted this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/16/s7/a/3/A"},"text":"Pub. L. 117–16, § 7(a)(3)(A)","children":[],"tail":", struck out “searchable” before “risk-based survey”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/16/s7/a/3/B"},"text":"Pub. L. 117–16, § 7(a)(3)(B)","children":[],"tail":", inserted “searchable” before “database”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc388cbbb-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc388cbbc-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadline for Risk-Based Surveys Database","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/210/tII/s206/d"},"text":"Pub. L. 118–210, title II, § 206(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-02"},"text":"Jan. 2, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2764"},"text":"138 Stat. 2764","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/210/tII/s206/d"},"text":"“The Secretary of Veterans Affairs shall establish the database required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3673A/c"},"text":"section 3673A(c) of title 38","children":[],"tail":", United States Code, by not later than 180 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2025-01-02"},"text":"Jan. 2, 2025","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
