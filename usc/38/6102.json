{"tag":"section","attrib":{"id":"idc3e5df4c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6102"},"text":null,"children":[{"tag":"num","attrib":{"value":"6102"},"text":"§ 6102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fraudulent acceptance of payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3e5df4d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person entitled to monetary benefits under any of the laws administered by the Secretary whose right to payment thereof ceases upon the happening of any contingency, who thereafter fraudulently accepts any such payment, shall be fined in accordance with title 18, or imprisoned not more than one year, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3e5df4e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever obtains or receives any money or check under any of the laws administered by the Secretary without being entitled to it, and with intent to defraud the United States or any beneficiary of the United States, shall be fined in accordance with title 18, or imprisoned not more than one year, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3e5df4f-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1239"},"text":"72 Stat. 1239","children":[],"tail":", § 3502; renumbered § 6102, "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/54/s14/d/7"},"text":"Pub. L. 102–54, § 14(d)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-06-13"},"text":"June 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/286"},"text":"105 Stat. 286","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/1"},"text":"Pub. L. 102–83, § 4(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/403"},"text":"105 Stat. 403","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3e5df50-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3e5df51-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3e5df52-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3502"},"text":"section 3502 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" substituted “administered by the Secretary” for “administered by the Veterans’ Administration” in subsecs. (a) and (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/54"},"text":"Pub. L. 102–54","children":[],"tail":" amended section as in effect immediately before the enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" by substituting “in accordance with title 18” for “not more than $2,000” in subsecs. (a) and (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
