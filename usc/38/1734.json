{"tag":"section","attrib":{"id":"idc30cbdbc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1734"},"text":null,"children":[{"tag":"num","attrib":{"value":"1734"},"text":"§ 1734.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hospital and nursing home care and medical services in the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc30cbdbd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1734/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall furnish hospital and nursing home care and medical services to any individual described in subsection (b) in the same manner, and subject to the same terms and conditions, as apply to the furnishing of such care and services to individuals who are veterans as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s101/2"},"text":"section 101(2) of this title","children":[],"tail":". Any disability of an individual described in subsection (b) that is a service-connected disability for purposes of this subchapter (as provided for under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1735/2"},"text":"section 1735(2) of this title","children":[],"tail":") shall be considered to be a service-connected disability for purposes of furnishing care and services under the preceding sentence."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc30cbdbe-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1734/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subsection (a) applies to any individual who is a Commonwealth Army veteran or new Philippine Scout and who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc30cbdbf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1734/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is residing in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30cbdc0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1734/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a citizen of the United States or an alien lawfully admitted to the United States for permanent residence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc30cbdc1-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/22/tI/s106/a"},"text":"Pub. L. 96–22, title I, § 106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-06-13"},"text":"June 13, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/53"},"text":"93 Stat. 53","children":[],"tail":", § 634; renumbered § 1734 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":", §§ 4(a)(3), (4), (b)(1), (2)(E), 5(a), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404-406"},"text":"105 Stat. 404–406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/377/s1/a/1/tV/s501/b"},"text":"Pub. L. 106–377, § 1(a)(1) [title V, § 501(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-27"},"text":"Oct. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1441"},"text":"114 Stat. 1441","children":[],"tail":", 1441A–57; "},{"tag":"ref","attrib":{"href":"/us/pl/108/170/tI/s103"},"text":"Pub. L. 108–170, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2044"},"text":"117 Stat. 2044","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc30cbdc2-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc30cbdc3-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc30cbdc4-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior section 1734 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3534"},"text":"section 3534 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 1734, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1199"},"text":"72 Stat. 1199","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/89/358/s4/m"},"text":"Pub. L. 89–358, § 4(m)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-03-03"},"text":"Mar. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/25"},"text":"80 Stat. 25","children":[],"tail":", related to overcharging of eligible persons by educational institutions, prior to the general amendment of this section by "},{"tag":"ref","attrib":{"href":"/us/pl/92/540/tIII/s313"},"text":"Pub. L. 92–540, title III, § 313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-24"},"text":"Oct. 24, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1084"},"text":"86 Stat. 1084","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3690"},"text":"section 3690 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc30cbdc5-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/170"},"text":"Pub. L. 108–170","children":[],"tail":" amended text generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) The Secretary, within the limits of Department facilities, may furnish hospital and nursing home care and medical services to Commonwealth Army veterans and new Philippine Scouts for the treatment of the service-connected disabilities of such veterans and scouts.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) An individual who is in receipt of benefits under subchapter II or IV of chapter 11 of this title paid by reason of service described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s107/a"},"text":"section 107(a) of this title","children":[],"tail":" who is residing in the United States and who is a citizen of, or an alien lawfully admitted for permanent residence in, the United States shall be eligible for hospital and nursing home care and medical services in the same manner as a veteran, and the disease or disability for which such benefits are paid shall be considered to be a service-connected disability for purposes of this chapter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/377"},"text":"Pub. L. 106–377","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s634"},"text":"section 634 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/3"},"text":"Pub. L. 102–83, § 4(a)(3)","children":[],"tail":", (4), substituted “Department” for “Veterans’ Administration”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc30cbdc6-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc30cbdc7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1979-10-01"},"text":"Oct. 1, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/22/s107"},"text":"section 107 of Pub. L. 96–22","children":[],"tail":", set out as an Effective Date of 1979 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1701"},"text":"section 1701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
