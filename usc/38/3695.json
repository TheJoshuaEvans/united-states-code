f":"/us/pl/117/333/s3/e/3/B/ii"},"text":"Pub. L. 117–333, § 3(e)(3)(B)(ii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6128"},"text":"136 Stat. 6128","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3996d30-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3996d31-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc3996d32-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Parts VII and VIII, Veterans Regulation numbered 1(a), referred to in subsec. (a)(1), are Parts VII and VIII as added by acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1943-03-24/ch22/s2"},"text":"Mar. 24, 1943, ch. 22, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/57/43"},"text":"57 Stat. 43","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/act/1944-06-22/ch268"},"text":"June 22, 1944, ch. 268","children":[],"tail":", title II, § 400(b), "},{"tag":"ref","attrib":{"href":"/us/stat/58/287"},"text":"58 Stat. 287","children":[],"tail":" to Veterans Regulation numbered 1(a) promulgated by Ex. Ord. No. 6156, "},{"tag":"date","attrib":{"date":"1933-06-06"},"text":"June 6, 1933","children":[],"tail":", which had been classified as parts VII and VIII of chapter 12A of former Title 38, Pensions, Bonuses, and Veterans’ Relief, and which were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/85/857/s14/67"},"text":"Pub. L. 85–857, § 14(67)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1272"},"text":"72 Stat. 1272","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Veterans’ Readjustment Assistance Act of 1952, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-07-16/ch875"},"text":"act July 16, 1952, ch. 875","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/663"},"text":"66 Stat. 663","children":[],"tail":". Title II of the Veterans’ Readjustment Assistance Act of 1952 was classified generally to subchapter II (§ 911 et seq.) of chapter 14 of former Title 38, which was repealed and the provisions thereof reenacted as chapter 33 (§ 1601 et seq.) of this title by "},{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1105"},"text":"72 Stat. 1105","children":[],"tail":". Chapter 33 of this title was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/89/358/s4/a"},"text":"Pub. L. 89–358, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-03-03"},"text":"Mar. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/23"},"text":"80 Stat. 23","children":[],"tail":". See chapter 32 (§ 3201 et seq.) of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The War Orphans’ Educational Assistance Act of 1956, referred to in subsec. (a)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-06-29/ch476"},"text":"act June 29, 1956, ch. 476","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/411"},"text":"70 Stat. 411","children":[],"tail":", which was classified generally to chapter 15 (§ 1031 et seq.) of former Title 38, which was repealed and the provisions thereof reenacted as chapter 35 of this title by "},{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1105"},"text":"72 Stat. 1105","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 903 of the Department of Defense Authorization Act, 1981, referred to in subsec. (a)(6), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/342/s903"},"text":"section 903 of Pub. L. 96–342","children":[],"tail":", title IX, "},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"Sept. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1115"},"text":"94 Stat. 1115","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2141"},"text":"section 2141 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Hostage Relief Act of 1980, referred to in subsec. (a)(7), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/449"},"text":"Pub. L. 96–449","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-14"},"text":"Oct. 14, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1967"},"text":"94 Stat. 1967","children":[],"tail":", which was formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5561"},"text":"section 5561 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Omnibus Diplomatic Security and Antiterrorism Act of 1986, referred to in subsec. (a)(8), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399"},"text":"Pub. L. 99–399","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/853"},"text":"100 Stat. 853","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4801"},"text":"section 4801 of Title 22","children":[],"tail":", Foreign Relations and Intercourse, and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3996d33-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/333"},"text":"Pub. L. 117–333","children":[],"tail":" substituted “in section 3101” for “in section 3101(5)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/154/s401/a/1"},"text":"Pub. L. 112–154, § 401(a)(1)","children":[],"tail":", struck out “35,” after “34,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/154/s401/a/2"},"text":"Pub. L. 112–154, § 401(a)(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/252"},"text":"Pub. L. 110–252","children":[],"tail":" amended par. (4) generally. Prior to amendment, par. (4) read as follows: “Chapters 30, 32, 34, 35, and 36 of this title, and the former chapter 33.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" inserted “1607,” after “1606,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/103"},"text":"Pub. L. 107–103","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" amended par. (5) identically, substituting “1611” for “1610”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" substituted “Chapters 107, 1606, and 1610” for “Chapters 106 and 107”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1795"},"text":"section 1795 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “3101(5)” for “1501(5)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237/s423/a/8/B"},"text":"Pub. L. 101–237, § 423(a)(8)(B)","children":[],"tail":", added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237/s423/b/1/A"},"text":"Pub. L. 101–237, § 423(b)(1)(A)","children":[],"tail":", substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525"},"text":"Pub. L. 98–525","children":[],"tail":" inserted reference in cl. (4) to chapter 30 of this title, and in cl. (5) to chapter 106 of title 10."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/223/s203/c/2/A"},"text":"Pub. L. 98–223, § 203(c)(2)(A)","children":[],"tail":", substituted “48 months” for “forty-eight months”, capitalized the first word in cls. (1) to (4), and added cls. (5) to (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/223/s203/c/2/B"},"text":"Pub. L. 98–223, § 203(c)(2)(B)","children":[],"tail":", substituted “subsection (a)” for “clauses (1), (2), (3), and (4)” and “48” for “forty-eight”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466"},"text":"Pub. L. 96–466","children":[],"tail":" designated existing provisions as subsec. (a), substituted in par. (4) “chapters 32, 34, 35, and 36 of this title and the former chapter 33;” for “chapters 31, 34, 35, and 36 of this title, and the former chapter 33”, in provisions following par. (4) struck out “, but this section shall not be deemed to limit the period for which assistance may be received under chapter 31 alone” after “(or the part-time equivalent thereof)”, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/540/s403/13"},"text":"Pub. L. 92–540, § 403(13)","children":[],"tail":", inserted reference to chapter 36 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3996d34-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3996d35-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/154/tIV/s401/b"},"text":"Pub. L. 112–154, title IV, § 401(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1188"},"text":"126 Stat. 1188","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/154/tIV/s401/b"},"text":"“The amendment made by subsection (a) [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2013-10-01"},"text":"October 1, 2013","children":[],"tail":", and shall not operate to revive any entitlement to assistance under chapter 35 of title 38, United States Code, or the provisions of law referred to in section 3695(a) of such title, as in effect on the day before such date, that was terminated by reason of the operation of section 3695(a) of such title, as so in effect, before such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3996d36-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/252"},"text":"Pub. L. 110–252","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-08-01"},"text":"Aug. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/252/s5003/d"},"text":"section 5003(d) of Pub. L. 110–252","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s16163"},"text":"section 16163 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3996d37-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466"},"text":"Pub. L. 96–466","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-10-01"},"text":"Oct. 1, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/466/s802/a/6"},"text":"section 802(a)(6) of Pub. L. 96–466","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3681"},"text":"section 3681 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3996d38-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective first day of second calendar month which begins after ","children":[{"tag":"date","attrib":{"date":"1968-10-23"},"text":"Oct. 23, 1968","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/631/s6/a"},"text":"section 6(a) of Pub. L. 90–631","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3500"},"text":"section 3500 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3996d39-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Revival of Entitlement Reduced by Prior Utilization of Chapter 35 Assistance","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/154/tIV/s401/c"},"text":"Pub. L. 112–154, title IV, § 401(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1188"},"text":"126 Stat. 1188","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/154/tIV/s401/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to paragraph (2), in the case of an individual whose period of entitlement to assistance under a provision of law referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3695/a"},"text":"section 3695(a) of title 38","children":[],"tail":", United States Code (other than chapter 35 of such title), as in effect on "},{"tag":"date","attrib":{"date":"2013-09-30"},"text":"September 30, 2013","children":[],"tail":", was reduced under such section 3695(a), as so in effect, by reason of the utilization of entitlement to assistance under chapter 35 of such title before "},{"tag":"date","attrib":{"date":"2013-10-01"},"text":"October 1, 2013","children":[],"tail":", the period of entitlement to assistance of such individual under such provision shall be determined without regard to any entitlement so utilized by the individual under chapter 35 of such title."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The maximum period of entitlement to assistance of an individual under paragraph (1) may not exceed 81 months.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
