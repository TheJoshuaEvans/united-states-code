{"tag":"section","attrib":{"id":"idc3996d23-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3695"},"text":null,"children":[{"tag":"num","attrib":{"value":"3695"},"text":"§ 3695.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on period of assistance under two or more programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3996d24-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3695/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The aggregate period for which any person may receive assistance under two or more of the provisions of law listed below may not exceed 48 months (or the part-time equivalent thereof):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3996d25-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3695/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Parts VII or VIII, Veterans Regulation numbered 1(a), as amended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3996d26-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3695/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Title II of the Veterans’ Readjustment Assistance Act of 1952.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3996d27-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3695/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The War Orphans’ Educational Assistance Act of 1956.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3996d28-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3695/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapters 30, 32, 33, 34, and 36.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3996d29-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3695/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapters 107, 1606, 1607, and 1611 of title 10.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3996d2a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3695/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 903 of the Department of Defense Authorization Act, 1981 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/342"},"text":"Public Law 96–342","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2141"},"text":"10 U.S.C. 2141","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3996d2b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3695/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Hostage Relief Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/449"},"text":"Public Law 96–449","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5561"},"text":"5 U.S.C. 5561","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3996d2c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3695/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Omnibus Diplomatic Security and Antiterrorism Act of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399"},"text":"Public Law 99–399","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3996d2d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3695/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No person may receive assistance under chapter 31 of this title in combination with assistance under any of the provisions of law cited in subsection (a) of this section in excess of 48 months (or the part-time equivalent thereof) unless the Secretary determines that additional months of benefits under chapter 31 of this title are necessary to accomplish the purposes of a rehabilitation program (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3101"},"text":"section 3101 of this title","children":[],"tail":") in the individual case."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3996d2e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3695/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The aggregate period for which any person may receive assistance under chapter 35 of this title, on the one hand, and any of the provisions of law referred to in subsection (a), on the other hand, may not exceed 81 months (or the part-time equivalent thereof).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3996d2f-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/631/s1/d/1"},"text":"Pub. L. 90–631, § 1(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-23"},"text":"Oct. 23, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1331"},"text":"82 Stat. 1331","children":[],"tail":", § 1791; renumbered § 1795 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/92/540/t