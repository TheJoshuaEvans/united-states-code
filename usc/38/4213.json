{"tag":"section","attrib":{"id":"idc3c20375-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4213"},"text":null,"children":[{"tag":"num","attrib":{"value":"4213"},"text":"§ 4213.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility requirements for veterans under Federal employment and training programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3c20376-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4213/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Amounts and periods of time specified in subsection (b) shall be disregarded in determining eligibility under any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3c20377-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4213/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any public service employment program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3c20378-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4213/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any emergency employment program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3c20379-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4213/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any job training program assisted under the Economic Opportunity Act of 1964.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3c2037a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4213/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any employment or training program carried out under title I of the Workforce Innovation and Opportunity Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3c2037b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4213/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other employment or training (or related) program financed in whole or in part with Federal funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3c2037c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4213/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subsection (a) applies with respect to the following amounts and periods of time:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3c2037d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4213/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any amount received as pay or allowances by any person while serving on active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3c2037e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4213/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any period of time during which such person served on active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3c2037f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4213/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any amount received under chapters 11, 13, 30, 31, 32, and 36 of this title by an eligible veteran.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3c20380-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4213/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any amount received by an eligible person under chapters 13 and 35 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3c20381-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4213/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any amount received by an eligible member under chapter 106 of title 10.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3c20382-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/540/tV/s503/a"},"text":"Pub. L. 92–540, title V, § 503(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-24"},"text":"Oct. 24, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1098"},"text":"86 Stat. 1098","children":[],"tail":", § 2013; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/466/tVIII/s801/k/1"},"text":"Pub. L. 96–466, title VIII, § 801(k)(1)","children":[],"tail":", (2)(A), "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2217"},"text":"94 Stat. 2217","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/54/s14/c/10"},"text":"Pub. L. 102–54, § 14(c)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-06-13"},"text":"June 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/285"},"text":"105 Stat. 285","children":[],"tail":"; renumbered § 4213, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/446/tVII/s702/b"},"text":"Pub. L. 103–446, title VII, § 702(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4675"},"text":"108 Stat. 4675","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/f/tVIII/s405/d/29/C"},"text":"Pub. L. 105–277, div. A, § 101(f) [title VIII, § 405(d)(29)(C), (f)(21)(C)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-337"},"text":"112 Stat. 2681–337","children":[],"tail":", 2681–424, 2681–432; "},{"tag":"ref","attrib":{"href":"/us/pl/106/419/tIV/s404/a/9"},"text":"Pub. L. 106–419, title IV, § 404(a)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1865"},"text":"114 Stat. 1865","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tV/s512/gg/5"},"text":"Pub. L. 113–128, title V, § 512(gg)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1720"},"text":"128 Stat. 1720","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3c20383-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3c20384-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc3c20385-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Economic Opportunity Act of 1964, referred to in subsec. (a)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/452"},"text":"Pub. L. 88–452","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-08-20"},"text":"Aug. 20, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/508"},"text":"78 Stat. 508","children":[],"tail":", which was classified generally to chapter 34 (§ 2701 et seq.) of Title 42, The Public Health and Welfare, prior to repeal, except for titles VIII and X, by "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s683/a"},"text":"Pub. L. 97–35, title VI, § 683(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/519"},"text":"95 Stat. 519","children":[],"tail":". Titles VIII and X of the Act are classified generally to subchapters VIII (§ 2991 et seq.) and X (§ 2996 et seq.) of chapter 34 of Title 42. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Workforce Innovation and Opportunity Act, referred to in subsec. (a)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1425"},"text":"128 Stat. 1425","children":[],"tail":". Title I of the Act is classified generally to subchapter I (§ 3111 et seq.) of chapter 32 of Title 29, Labor. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3c20386-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":" substituted “Any employment or training program carried out under title I of the Workforce Innovation and Opportunity Act” for “Any employment or training program carried out under title I of the Workforce Investment Act of 1998 ("},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2801"},"text":"29 U.S.C. 2801","children":[],"tail":" et seq.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/419"},"text":"Pub. L. 106–419","children":[],"tail":" amended text generally. Prior to amendment, text read as follows: “Any (1) amounts received as pay or allowances by any person while serving on active duty, (2) period of time during which such person served on such active duty, and (3) amounts received under chapters 11, 13, 30, 31, 35, and 36 of this title by an eligible veteran, any amounts received by an eligible person under chapters 13 and 35 of such title, and any amounts received by an eligible person under chapter 106 of title 10, shall be disregarded in determining eligibility under any public service employment program, any emergency employment program, any job training program assisted under the Economic Opportunity Act of 1964, any employment or training program carried out under title I of the Workforce Investment Act of 1998, or any other employment or training (or related) program financed in whole or in part with Federal funds.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s101/f/tVIII/s405/f/21/C"},"text":"Pub. L. 105–277, § 101(f) [title VIII, § 405(f)(21)(C)]","children":[],"tail":", struck out “the Job Training Partnership Act or” after “program carried out under”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s101/f/tVIII/s405/d/29/C"},"text":"Pub. L. 105–277, § 101(f) [title VIII, § 405(d)(29)(C)]","children":[],"tail":", substituted “program carried out under the Job Training Partnership Act or title I of the Workforce Investment Act of 1998,” for “program assisted under the Job Training Partnership Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1501"},"text":"29 U.S.C. 1501","children":[],"tail":" et seq.),”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446/s702/b/3"},"text":"Pub. L. 103–446, § 702(b)(3)","children":[],"tail":", substituted “eligibility under” for “the needs or qualifications of participants in”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446/s702/b/2"},"text":"Pub. L. 103–446, § 702(b)(2)","children":[],"tail":", which directed insertion of “and any amounts received by an eligible person under chapter 106 of title 10,” after “chapters 13 and 35 of such title, and”, was executed by making the insertion after “chapters 13 and 35 of such title,” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446/s702/b/1"},"text":"Pub. L. 103–446, § 702(b)(1)","children":[],"tail":", which directed substitution of “chapters 11, 13, 30, 31, 35, and 36 of this title by an eligible veteran,” for “chapters 11, 13, 31, 34, 35, and 36 of this title by an eligible veteran and”, was executed by making the substitution for “chapters 11, 13, 31, 34, 35, and 36 of this title by an eligible veteran, and” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2013"},"text":"section 2013 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/54"},"text":"Pub. L. 102–54","children":[],"tail":" substituted “the Job Training Partnership Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1501"},"text":"29 U.S.C. 1501","children":[],"tail":" et seq.)” for “the Comprehensive Employment and Training Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466"},"text":"Pub. L. 96–466","children":[],"tail":" substituted “Federal employment and” for “certain Federal manpower” in section catchline, and substituted “an eligible veteran” for “a veteran (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s101/2"},"text":"section 101(2) of this title","children":[],"tail":") who served on active duty for a period of more than 180 days or was discharged or released from active duty for a service-connected disability” and “any employment or training program assisted under the Comprehensive Employment and Training Act, or any other employment or” for “any manpower training program assisted under the Manpower Development and Training Act of 1962, or any other man­power” in text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3c20387-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment"