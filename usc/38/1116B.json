{"tag":"section","attrib":{"id":"idc2a63320-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1116B"},"text":null,"children":[{"tag":"num","attrib":{"value":"1116B"},"text":"§ 1116B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presumption of herbicide exposure for certain veterans who served in Korea","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2a63321-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1116B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Presumption of Service-Connection","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2a63322-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1116B/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1110"},"text":"section 1110 of this title","children":[],"tail":", and subject to "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1113"},"text":"section 1113 of this title","children":[],"tail":", a disease specified in subsection (b) that becomes manifest as specified in that subsection in a veteran described in paragraph (2) shall be considered to have been incurred or aggravated in the line of duty in the active military, naval, or air service, notwithstanding that there is no record of evidence of such disease during the period of such service."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2a63323-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1116B/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A veteran described in this paragraph is a veteran who, during active military, naval, or air service, served in or near the Korean Demilitarized Zone (DMZ), during the period beginning on ","children":[{"tag":"date","attrib":{"date":"1967-09-01"},"text":"September 1, 1967","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"1971-08-31"},"text":"August 31, 1971","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2a63324-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1116B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Diseases","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A disease specified in this subsection is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2a63325-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1116B/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a disease specified in paragraph (2) of subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1116"},"text":"section 1116 of this title","children":[],"tail":" that becomes manifest as specified in that paragraph; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2a63326-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1116B/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any additional disease that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2a63327-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1116B/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to subchapter VII of this chapter, the Secretary determines in regulations warrants a presumption of service-connection by reason of having positive association with exposure to an herbicide agent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2a63328-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1116B/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" becomes manifest within any period prescribed in such regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2a63329-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1116B/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Herbicide Agent","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, the term “herbicide agent” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1821/d"},"text":"section 1821(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2a6332a-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/23/s3/a"},"text":"Pub. L. 116–23, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-06-25"},"text":"June 25, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/969"},"text":"133 Stat. 969","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/168/tII/s202/d/2"},"text":"Pub. L. 117–168, title II, § 202(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-10"},"text":"Aug. 10, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1775"},"text":"136 Stat. 1775","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2a6332b-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc2a6332c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc2a6332d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/168"},"text":"Pub. L. 117–168","children":[],"tail":" inserted “pursuant to subchapter VII of this chapter,” before “the Secretary determines”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc2a6332e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc2a6332f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/23/s3/d"},"text":"Pub. L. 116–23, § 3(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-06-25"},"text":"June 25, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/970"},"text":"133 Stat. 970","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/23/s3/d"},"text":"“The amendments made by this section [enacting this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2020-01-01"},"text":"January 1, 2020","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc2a63330-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/23/s3/c"},"text":"Pub. L. 116–23, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-06-25"},"text":"June 25, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/970"},"text":"133 Stat. 970","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/23/s3/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding section 501 of such title, the Secretary of Veterans Affairs may issue guidance to implement ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1116B"},"text":"section 1116B of title 38","children":[],"tail":", United States Code, as added by subsection (a), before prescribing new regulations under such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Updates","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 120 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2019-06-25"},"text":"June 25, 2019","children":[],"tail":"], the Secretary shall submit a report to the Committees on Veterans’ Affairs of the House of Representatives and the Senate regarding the plans of the Secretary to respond to inquiries from veterans regarding claims for disability compensation under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1116B"},"text":"section 1116B of title 38","children":[],"tail":", United States Code, as added by subsection (a) of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On a quarterly basis during the period beginning on the date of the enactment of this Act and ending on the date on which regulations are prescribed to carry out such section 1116B, the Secretary shall submit to the Committees on Veterans’ Affairs of the House of Representatives and the Senate updates on the status of such regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pending cases.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to stay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may stay a claim described in subparagraph (B) until the date on which the Secretary commences the implementation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1116B"},"text":"section 1116B of title 38","children":[],"tail":", United States Code, as added by subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Claims described","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A claim described in this subparagraph is a claim for disability compensation—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relating to the service and diseases covered by such section 1116B; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is pending at the Veterans Benefits Administration or the Board of Veterans’ Appeals on or after the date of the enactment of this Act and before the date on which the Secretary commences the implementation of such section 1116B.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
