{"tag":"section","attrib":{"id":"idc417eb61-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7653"},"text":null,"children":[{"tag":"num","attrib":{"value":"7653"},"text":"§ 7653.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may pay to a person selected to receive assistance under this subchapter the amount of $400 (adjusted in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7631"},"text":"section 7631 of this title","children":[],"tail":") for each month of the person’s enrollment in a program of education or training covered by the agreement of the person entered into under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7603"},"text":"section 7603 of this title","children":[],"tail":". Payment of such benefits for any period shall be coordinated with any payment of benefits for the same period under chapter 106 of title 10."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc417eb62-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/366/tII/s205/a/1"},"text":"Pub. L. 101–366, title II, § 205(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-15"},"text":"Aug. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/440"},"text":"104 Stat. 440","children":[],"tail":", § 4353; renumbered § 7653 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", (d)(1), "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":", 239.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc417eb63-47c4-11f1-bf59-9680b1269b87"},"text":"\n",