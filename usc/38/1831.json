{"tag":"section","attrib":{"id":"idc313e9f1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1831"},"text":null,"children":[{"tag":"num","attrib":{"value":"1831"},"text":"§ 1831.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc313e9f2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1831/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “child” means the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc313e9f3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1831/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of subchapters I and II of this chapter, an individual, regardless of age or marital status, who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc313e9f4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1831/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is the natural child of a Vietnam veteran; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc313e9f5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1831/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was conceived after the date on which that veteran first entered the Republic of Vietnam during the Vietnam era.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc313e9f6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1831/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1821"},"text":"section 1821 of this title","children":[],"tail":", an individual, regardless of age or marital status, who—"}],"tail":null},{"tag":"clause","attrib":{"id":"idc313e9f7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1831/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is the natural child of a veteran of covered service in Korea (as determined for purposes of that section); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc313e9f8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1831/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was conceived after the date on which that veteran first entered service described in subsection (c) of that section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc313e9f9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1831/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1822"},"text":"section 1822 of this title","children":[],"tail":", an individual, regardless of age or marital status, who—"}],"tail":null},{"tag":"clause","attrib":{"id":"idc313e9fa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1831/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is the natural child of a veteran of covered service in Thailand (as determined for purposes of that section); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc313e9fb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1831/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was conceived after the date on which that veteran first entered service described in subsection (c) of that section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc313e9fc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1831/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “covered child” means a child who is eligible for health care and benefits under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc313e9fd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1831/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “covered veteran” means an individual whose children are eligible for health care and benefits under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc313e9fe-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1831/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Vietnam veteran” means an individual who performed active military, naval, or air service in the Republic of Vietnam during the Vietnam era, without regard to the characterization of that individual’s service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc313e9ff-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1831/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"ch