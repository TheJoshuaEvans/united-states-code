{"tag":"section","attrib":{"id":"idc313e9b5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1815"},"text":null,"children":[{"tag":"num","attrib":{"value":"1815"},"text":"§ 1815.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monetary allowance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc313e9b6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1815/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Monetary Allowance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall pay a monthly allowance to any eligible child for any disability resulting from the covered birth defects of that child.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc313e9b7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1815/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Schedule for Rating Disabilities","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc313e9b8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1815/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of the monthly allowance paid under this section shall be based on the degree of disability suffered by the child concerned, as determined in accordance with a schedule for rating disabilities resulting from covered birth defects that is prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc313e9b9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1815/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In prescribing a schedule for rating disabilities for the purposes of this section, the Secretary shall establish four levels of disability upon which the amount of the allowance provided by this section shall be based. The levels of disability established may take into account functional limitations, including limitations on cognition, communication, motor abilities, activities of daily living, and employability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc313e9ba-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1815/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount of Monthly Allowance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of the monthly allowance paid under this section shall be as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc313e9bb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1815/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a child suffering from the lowest level of disability prescribed in the schedule for rating disabilities under subsection (b), $100.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc313e9bc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1815/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of a child suffering from the lower intermediate level of disability prescribed in the schedule for rating disabilities under subsection (b), the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc313e9bd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1815/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $214; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc313e9be-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1815/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the monthly amount payable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1805/b/3"},"text":"section 1805(b)(3) of this title","children":[],"tail":" for the lowest level of disability prescribed for purposes of that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc313e9bf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1815/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of a child suffering from the higher intermediate level of disability prescribed in the schedule for rating disabilities under subsection (b), the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc313e9c0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1815/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $743; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc313e9c1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1815/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the monthly amount payable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1805/b/3"},"text":"section 1805(b)(3) of this title","children":[],"tail":" for the intermediate level of disability prescribed for purposes of that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc313e9c2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1815/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of a child suffering from the highest level of disability prescribed in the schedule for rating disabilities under subsection (b), the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc313e9c3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1815/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,272; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc313e9c4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1815/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the monthly amount payable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1805/b/3"},"text":"section 1805(b)(3) of this title","children":[],"tail":" for the highest level of disability prescribed for purposes of that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc313e9c5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1815/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Indexing to Social Security Benefit Increases","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts under paragraphs (1), (2)(A), (3)(A), and (4)(A) of subsection (c) shall be subject to adjustment from time to time under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5312"},"text":"section 5312 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc313e9c6-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/419/tIV/s401/a"},"text":"Pub. L. 106–419, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1858"},"text":"114 Stat. 1858","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc313e9c7-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc313e9c8-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc313e9c9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1815 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3703/a/2"},"text":"section 3703(a)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
