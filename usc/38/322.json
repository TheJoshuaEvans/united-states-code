{"tag":"section","attrib":{"id":"idc2800e07-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s322"},"text":null,"children":[{"tag":"num","attrib":{"value":"322"},"text":"§ 322.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of National Veterans Sports Programs and Special Events","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2800e08-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s322/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is in the Department an Office of National Veterans Sports Programs and Special Events. There is at the head of the Office a Director, who shall report to an appropriate official of the Veterans Health Administration, as determined by the Secretary, or to the Deputy Secretary or Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2800e09-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s322/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities of Director","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the direction of the Secretary, the Director—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2800e0a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s322/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall establish and carry out qualifying programs and events;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2800e0b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s322/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may provide for sponsorship by the Department of qualifying programs and events;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2800e0c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s322/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may provide for, facilitate, and encourage participation by disabled veterans in qualifying programs and events;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2800e0d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s322/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall, to the extent feasible, cooperate with entities with significant experience in managing large-scale adaptive sports programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2800e0e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s322/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall seek sponsorships and donations from the private sector to defray costs of carrying out the responsibilities of the Director to the maximum extent feasible; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2800e0f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s322/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may carry out such other responsibilities as the Secretary determines are appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2800e10-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s322/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualifying Program or Event","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, a qualifying program or event is a sports program or other event in which disabled veterans and disabled members of the Armed Forces participate and that is approved by the Secretary as being consistent with the goals and missions of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2800e11-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s322/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Monthly Assistance Allowance","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2800e12-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s322/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to the availability of appropriations for such purpose, the Secretary may provide a monthly assistance allowance to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2800e13-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s322/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a veteran with a disability invited by the United States Olympic & Paralympic Committee to compete for a slot on, or selected for, the Paralympic Team for any month in which the veteran is training or competing in any event sanctioned by the United States Olympic & Paralympic Committee or who is residing at a United States Olympic Committee training center; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2800e14-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s322/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a veteran with a VA service-connected disability rated as 30 percent or greater by the Department of Veterans Affairs who is selected by the United States Olympic & Paralympic Committee for the United States Olympic Team for any month in which the veteran is competing in any event sanctioned by the National Governing Bodies of the United States Olympic Sports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2800e15-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s322/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of the monthly assistance payable to a veteran under paragraph (1) shall be equal to the monthly amount of subsistence allowance that would be payable to the veteran under chapter 31 of this title if the veteran were eligible for and entitled to rehabilitation under such chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2800e16-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s322/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In providing assistance under this subsection, the Secretary shall give priority to veterans with service-connected disabilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2800e17-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s322/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" There is authorized to be appropriated to carry out this subsection the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2800e18-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s322/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For each of fiscal years 2010 through 2023, $2,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2800e19-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s322/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For each of fiscal years 2024 through 2027, $2,500,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2800e1a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s322/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability to Commonwealths and Territories of the United States","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The provisions of this subsection shall apply in the same manner and to the same degree as to the United States Olympic & Paralympic Committee to the Paralympic sport entities the Secretary considers appropriate to represent the interests of each of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2800e1b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s322/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" American Samoa.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2800e1c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s322/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Guam.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2800e1d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s322/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2800e1e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s322/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2800e1f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s322/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2800e20-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s322/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Statutory Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed as a limitation on disabled sports and special events supported by the Department as of the date of the enactment of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2800e21-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/389/tVII/s703/a"},"text":"Pub. L. 110–389, title VII, § 703(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4183"},"text":"122 Stat. 4183","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/37/s2/a"},"text":"Pub. L. 113–37, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-09-30"},"text":"Sept. 30, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/523"},"text":"127 Stat. 523","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/59/s4"},"text":"Pub. L. 113–59, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-20"},"text":"Dec. 20, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/659"},"text":"127 Stat. 659","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/58/tIV/s402"},"text":"Pub. L. 114–58, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-09-30"},"text":"Sept. 30, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/534"},"text":"129 Stat. 534","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/223/dA/tII/s249"},"text":"Pub. L. 114–223, div. A, title II, § 249","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-09-29"},"text":"Sept. 29, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/892"},"text":"130 Stat. 892","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/228/tIV/s403"},"text":"Pub. L. 114–228, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-09-29"},"text":"Sept. 29, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/940"},"text":"130 Stat. 940","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/62/tIV/s403"},"text":"Pub. L. 115–62, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-09-29"},"text":"Sept. 29, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1164"},"text":"131 Stat. 1164","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/251/tI/s163"},"text":"Pub. L. 115–251, title I, § 163","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-29"},"text":"Sept. 29, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3171"},"text":"132 Stat. 3171","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/159/dE/tIV/s5401"},"text":"Pub. L. 116–159, div. E, title IV, § 5401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-01"},"text":"Oct. 1, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/751"},"text":"134 Stat. 751","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/180/dE/tIV/s401"},"text":"Pub. L. 117–180, div. E, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-09-30"},"text":"Sept. 30, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2139"},"text":"136 Stat. 2139","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/83/dB/tIII/s334"},"text":"Pub. L. 118–83, div. B, title III, § 334","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-09-26"},"text":"Sept. 26, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1541"},"text":"138 Stat. 1541","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2800e22-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc2800e23-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc2800e24-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsec. (f), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/389"},"text":"Pub. L. 110–389","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc2800e25-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/83/s334/2"},"text":"Pub. L. 118–83, § 334(2)","children":[],"tail":", substituted “Veterans Health Administration” for “Veterans Benefits Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(A), (B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/83/s334/1"},"text":"Pub. L. 118–83, § 334(1)","children":[],"tail":", substituted “the United States Olympic & Paralympic Committee” for “the United States Olympic Committee” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/83/s334/3"},"text":"Pub. L. 118–83, § 334(3)","children":[],"tail":", amended par. (4) generally. Prior to amendment, par. (4) read as follows: “There is authorized to be appropriated to carry out this subsection $2,000,000 for each of fiscal years 2010 through 2026.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/83/s334/1"},"text":"Pub. L. 118–83, § 334(1)","children":[],"tail":", substituted “the United States Olympic & Paralympic Committee” for “the United States Olympic Committee” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/180"},"text":"Pub. L. 117–180","children":[],"tail":" substituted “2026” for “2022”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/159"},"text":"Pub. L. 116–159","children":[],"tail":" substituted “2022” for “2020”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/251"},"text":"Pub. L. 115–251","children":[],"tail":" substituted “2020” for “2019”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/62"},"text":"Pub. L. 115–62","children":[],"tail":" substituted “2019” for “2017”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/223"},"text":"Pub. L. 114–223","children":[],"tail":" substituted “allowance to—” for “allowance to”, inserted subpar. (A) designation before “a veteran with a disability”, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/228"},"text":"Pub. L. 114–228","children":[],"tail":" substituted “2017” for “2016”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/58"},"text":"Pub. L. 114–58","children":[],"tail":" substituted “2016” for “2015”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/59/s4/b"},"text":"Pub. L. 113–59, § 4(b)","children":[],"tail":", substituted “cooperate with entities with significant experience in managing large-scale adaptive sports programs;” for “cooperate with the United States Olympic Committee and its partners to promote the participation of disabled veterans and disabled members of the Armed Forces in sporting events sponsored by the United States Olympic Committee and its partners;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/37/s2/a/2"},"text":"Pub. L. 113–37, § 2(a)(2)","children":[],"tail":", substituted “United States Olympic Committee” for “United States Paralympics, Inc.,” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/37/s2/a/2"},"text":"Pub. L. 113–37, § 2(a)(2)","children":[],"tail":", substituted “United States Olympic Committee” for “United States Paralympics, Inc.,” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/59/s4/a"},"text":"Pub. L. 113–59, § 4(a)","children":[],"tail":", substituted “through 2015.” for “through 2013 and $500,000 for the period beginning "},{"tag":"date","attrib":{"date":"2013-10-01"},"text":"October 1, 2013","children":[],"tail":", and ending "},{"tag":"date","attrib":{"date":"2013-12-31"},"text":"December 31, 2013","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/37/s2/a/1"},"text":"Pub. L. 113–37, § 2(a)(1)","children":[],"tail":", inserted “and $500,000 for the period beginning "},{"tag":"date","attrib":{"date":"2013-10-01"},"text":"October 1, 2013","children":[],"tail":", and ending "},{"tag":"date","attrib":{"date":"2013-12-31"},"text":"December 31, 2013","children":[],"tail":"” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/59/s4/c"},"text":"Pub. L. 113–59, § 4(c)","children":[],"tail":", added subsec. (e) and redesignated former subsec. (e) as (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc2800e26-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idc2800e27-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"References to the United States Olympic Committee deemed to refer to the United States Olympic and Paralympic Committee, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s220502/c"},"text":"section 220502(c) of Title 36","children":[],"tail":", Patriotic and National Observances, Ceremonies, and Organizations."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc2800e28-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/37/s4"},"text":"Pub. L. 113–37, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-09-30"},"text":"Sept. 30, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/525"},"text":"127 Stat. 525","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/37/s4"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This Act [see Short Title of 2013 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of this title","children":[],"tail":"] shall take effect on "},{"tag":"date","attrib":{"date":"2013-10-01"},"text":"October 1, 2013","children":[],"tail":", except that Section [sic] 2(a) [amending this section] shall take effect on "},{"tag":"date","attrib":{"date":"2013-09-30"},"text":"September 30, 2013","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Ratification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If this Act is not enacted on or before ","children":[{"tag":"date","attrib":{"date":"2013-09-30"},"text":"September 30, 2013","children":[],"tail":", any actions undertaken by the Department of Veterans Affairs under the authorities extended by this Act during the period beginning on such date and ending on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2013-09-30"},"text":"Sept. 30, 2013","children":[],"tail":"] shall be deemed ratified.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc2800e29-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings and Purpose","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/389/tVII/s701"},"text":"Pub. L. 110–389, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4180"},"text":"122 Stat. 4180","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/389/tVII/s701"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Findings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress makes the following findings:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In 1998, Congress enacted the Olympic and Amateur Sports Act Amendments of 1998 (33 [36] U.S.C. 101 note) [see Short Title of 1998 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s101"},"text":"section 101 of Title 36","children":[],"tail":", Patriotic and National Observances, Ceremonies, and Organizations], which amended chapter 2205 of title 36, United States Code, and included a statement that the purpose of the Act was ‘to encourage and provide assistance to amateur athletic programs and competition for amateur athletes with disabilities, including, where feasible, the expansion of opportunities for meaningful participation by such amateur athletes in programs of athletic competition for able-bodied amateur athletes’."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Olympic Committee [now United States Olympic and Paralympic Committee] manages and administers the Paralympic Program for physically disabled athletes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Veterans Affairs provides health care to veterans and administers recreational activities for patients including the Golden Age Games, the National Veterans Wheelchair Games, and the Winter Sports Clinic.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In 2005, the United States Olympic Committee [now United States Olympic and Paralympic Committee] entered into a memorandum of understanding with the Secretary of Veterans Affairs to increase interest in and access to Paralympic sports programs for veterans with physical disabilities by coordinating the activities of the United States Olympic Committee with the Department of Veterans Affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Paralympic Program has a significant positive effect on the quality of life of disabled veterans and disabled members of the Armed Forces who participate in the program, including helping to improve the mobility, vitality, and physical, psychological, and social well-being of such participants and reducing the incidence of secondary medical conditions in those participants.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Because of Operation Iraqi Freedom and Operation Enduring Freedom, the number of disabled veterans and disabled members of the Armed Forces has increased substantially and it is therefore desirable to supplement the rehabilitation and recreation programs of the Department of Veterans Affairs through sports for disabled veterans and members of the Armed Forces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this title [enacting this section, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s521A"},"text":"section 521A of this title","children":[],"tail":", and provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s521A"},"text":"section 521A of this title","children":[],"tail":"] are as follows:"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To promote the lifelong health of disabled veterans and disabled members of the Armed Forces through regular participation in physical activity and sports.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To enhance the recreation activities provided by the Department of Veterans Affairs by promoting disabled sports from the local level through elite levels and by creating partnerships among organizations specializing in supporting, training, and promoting programs for disabled veterans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide training and support to national and local organizations to provide Paralympic sports training to disabled veterans and disabled members of the Armed Forces in their own communities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide support to the United States Paralympics, Inc., to increase the participation of disabled veterans and disabled members of the Armed Forces in sports.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
