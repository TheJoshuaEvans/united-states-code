{"tag":"section","attrib":{"id":"idc2e69789-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1710A"},"text":null,"children":[{"tag":"num","attrib":{"value":"1710A"},"text":"§ 1710A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required nursing home care","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2e6978a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1710A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary (subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1710/a/4"},"text":"section 1710(a)(4) of this title","children":[],"tail":") shall provide nursing home care which the Secretary determines is needed (1) to any veteran in need of such care for a service-connected disability, and (2) to any veteran who is in need of such care and who has a service-connected disability rated at 70 percent or more."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2e6978b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1710A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2e6978c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1710A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall ensure that a veteran described in subsection (a) who continues to need nursing home care is not, after placement in a Department nursing home, transferred from the facility without the consent of the veteran, or, in the event the veteran cannot provide informed consent, the representative of the veteran.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2e6978d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1710A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in subsection (a) may be construed as authorizing or requiring that a veteran who is receiving nursing home care in a Department nursing home on the date of the enactment of this section be displaced, transferred, or discharged from the facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2e6978e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1710A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall ensure that nursing home care provided under subsection (a) is provided in an age-appropriate manner.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2e6978f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1710A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of subsection (a) shall terminate on ","children":[{"tag":"date","attrib":{"date":"2026-09-30"},"text":"September 30, 2026","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2e69790-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117/tI/s101/a/1"},"text":"Pub. L. 106–117, title I, § 101(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-30"},"text":"Nov. 30, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1547"},"text":"113 Stat. 1547","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/419/tII/s224/a"},"text":"Pub. L. 106–419, title II, § 224(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1846