/s111A"},"text":"section 111A of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc2e69797-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Finding Related to Age-Appropriate Nursing Home Care","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tXVII/s1706/a"},"text":"Pub. L. 110–181, div. A, title XVII, § 1706(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/493"},"text":"122 Stat. 493","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/181/dA/tXVII/s1706/a"},"text":"“Congress finds that young veterans who are injured or disabled through military service and require long-term care should have access to age-appropriate nursing home care.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc2e69798-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report to Congressional Committees","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117/tI/s101/i"},"text":"Pub. L. 106–117, title I, § 101(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-30"},"text":"Nov. 30, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1550"},"text":"113 Stat. 1550","children":[],"tail":", required the Secretary of Veterans Affairs to submit to the Committees on Veterans’ Affairs of the Senate and House of Representatives a report on the operation of "},{"tag":"ref","attrib":{"href":"/us/pl/106/117/s101"},"text":"section 101 of Pub. L. 106–117","children":[],"tail":" not later than "},{"tag":"date","attrib":{"date":"2003-01-01"},"text":"January 1, 2003","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
