{"tag":"section","attrib":{"id":"idc332e2ac-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022A"},"text":null,"children":[{"tag":"num","attrib":{"value":"2022A"},"text":"§ 2022A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Legal services for homeless veterans and veterans at risk for homelessness","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc332e2ad-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the availability of appropriations provided for such purpose, the Secretary shall award grants to eligible entities that provide legal services to homeless veterans and veterans at risk for homelessness.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc332e2ae-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criteria","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc332e2af-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc332e2b0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022A/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish criteria and requirements for grants under this section, including criteria for entities eligible to receive such grants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc332e2b1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022A/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish such criteria and requirements in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc332e2b2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In establishing criteria and requirements under paragraph (1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc332e2b3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022A/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into consideration any criteria and requirements needed with respect to carrying out this section in rural communities, on trust lands, and in the territories and possessions of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc332e2b4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022A/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consult with organizations that have experience in providing services to homeless veterans, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc332e2b5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022A/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" veterans service organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc332e2b6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022A/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Equal Justice Works AmeriCorps Veterans Legal Corps; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc332e2b7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022A/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other organizations as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc332e2b8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Entities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may award a grant under this section to an entity applying for such a grant only if the applicant for the grant—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc332e2b9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022A/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a public or nonprofit private entity with the capacity (as determined by the Secretary) to effectively administer a grant under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc332e2ba-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022A/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates that adequate financial support will be available to carry out the services for which the grant is sought consistent with the application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc332e2bb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022A/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agrees to meet the applicable criteria and requirements established under subsection (b)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc332e2bc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022A/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has, as determined by the Secretary, demonstrated the capacity to meet such criteria and requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc332e2bd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants under this section shall be used to provide homeless veterans and veterans at risk for homelessness the following legal services:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc332e2be-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022A/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Legal services relating to housing, including eviction defense, representation in landlord-tenant cases, and representation in foreclosure cases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc332e2bf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022A/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Legal services relating to family law, including assistance in court proceedings for child support, divorce, estate planning, and family reconciliation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc332e2c0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022A/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Legal services relating to income support, including assistance in obtaining public benefits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc332e2c1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022A/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Legal services relating to criminal defense, including defense in matters symptomatic of homelessness, such as outstanding warrants, fines, and driver’s license revocation, to reduce recidivism and facilitate the overcoming of reentry obstacles in employment or housing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc332e2c2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022A/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Legal services relating to requests to upgrade the characterization of a discharge or dismissal of a former member of the Armed Forces under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1553"},"text":"section 1553 of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc332e2c3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022A/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other legal services as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc332e2c4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funds for Women Veterans","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For any fiscal year, not less than 10 percent of the amount authorized to be appropriated for grants under this section shall be used to provide legal services described in subsection (d) to women veterans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc332e2c5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022A/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Locations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent practicable, the Secretary shall award grants under this section to eligible entities in a manner that is equitably distributed across the geographic regions of the United States, including with respect to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc332e2c6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022A/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rural communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc332e2c7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022A/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" trust lands (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3765"},"text":"section 3765 of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc332e2c8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022A/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Native Americans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc332e2c9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022A/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tribal organizations (as defined in section 4 of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"25 U.S.C. 5304","children":[],"tail":"))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc332e2ca-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022A/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Biennial Reports","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc332e2cb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022A/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not less frequently than once every two years, the Secretary shall submit to the Committee on Veterans’ Affairs of the Senate and the Committee on Veterans’ Affairs of the House of Representatives a report on grants awarded under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc332e2cc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022A/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To the extent feasible, each report required by paragraph (1) shall include the following with respect to the period covered by the report:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc332e2cd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022A/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of homeless veterans and veterans at risk for homelessness assisted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc332e2ce-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022A/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the legal services provided.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc332e2cf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022A/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the legal matters addressed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc332e2d0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022A/g/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An analysis by the Secretary with respect to the operational effectiveness and cost-effectiveness of the services provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc332e2d1-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/tIV/s4202/a"},"text":"Pub. L. 116–315, title IV, § 4202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/5011"},"text":"134 Stat. 5011","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc332e2d2-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc332e2d3-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc332e2d4-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Criteria","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/tIV/s4202/c"},"text":"Pub. L. 116–315, title IV, § 4202(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/5012"},"text":"134 Stat. 5012","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/315/tIV/s4202/c"},"text":"“Not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":"], the Secretary of Veterans Affairs shall establish and publish in the Federal Register the criteria and requirements pursuant to subsection (b)(1) of "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2022A"},"text":"section 2022A of title 38","children":[],"tail":", United States Code, as added by subsection (a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
