{"tag":"section","attrib":{"id":"idc37a72bd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3513"},"text":null,"children":[{"tag":"num","attrib":{"value":"3513"},"text":"§ 3513.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The parent or guardian of a person or the eligible person if such person has attained legal majority for whom educational assistance is sought under this chapter shall submit an application to the Secretary which shall be in such form and contain such information as the Secretary shall prescribe. If the Secretary finds that the person on whose behalf the application is submitted is an eligible person, the Secretary shall approve the application provisionally. The Secretary shall notify the parent or guardian or eligible person (if the person has attained legal majority) of the provisional approval or of the disapproval of the application.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc37a72be-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1195"},"text":"72 Stat. 1195","children":[],"tail":", § 1713; "},{"tag":"ref","attrib":{"href":"/us/pl/94/502/tIII/s305"},"text":"Pub. L. 94–502, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-15"},"text":"Oct. 15, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2390"},"text":"90 Stat. 2390","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIV/s423/b/1/A"},"text":"Pub. L. 101–237, title IV, § 423(b)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2092"},"text":"103 Stat. 2092","children":[],"tail":"; renumbered § 3513, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc37a72bf-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc37a72c0-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc37a72c1-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1713"},"text":"section 1713 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" substituted “Secretary” for “Administrator” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/502"},"text":"Pub. L. 94–502","children":[],"tail":" inserted reference to eligible person who have attained legal majority and substituted “the Administrator shall approve” for “he shall approve”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc37a72c