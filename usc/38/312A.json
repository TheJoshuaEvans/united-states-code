{"tag":"section","attrib":{"id":"idc27b5347-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312A"},"text":null,"children":[{"tag":"num","attrib":{"value":"312A"},"text":"§ 312A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director of Construction and Facilities Management","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc27b5348-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc27b5349-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is in the Department a Director of Construction and Facilities Management, who shall be appointed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27b534a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The position of Director of Construction and Facilities Management is a career reserved position, as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3132/a/8"},"text":"section 3132(a)(8) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27b534b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312A/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall provide direct support to the Secretary in matters covered by the responsibilities of the Director under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27b534c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312A/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall report to the Deputy Secretary in the discharge of the responsibilities of the Director under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc27b534d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualifications","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each individual appointed as Director of Construction and Facilities Management shall be an individual who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc27b534e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" holds an undergraduate or master’s degree in architectural design or engineering; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27b534f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has substantive professional experience in the area of construction project management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc27b5350-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc27b5351-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312A/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Director of Construction and Facilities Management shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc27b5352-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312A/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be responsible for overseeing and managing the planning, design, construction, and operation of facilities and infrastructure of the Department, including major and minor construction projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc27b5353-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312A/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform such other functions as the Secretary shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27b5354-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312A/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out the oversight and management of construction and operation of facilities and infrastructure under this section, the Director shall be responsible for the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc27b5355-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312A/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Development and updating of short-range and long-range strategic capital investment strategies and plans of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc27b5356-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312A/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Planning, design, and construction of facilities for the Department, including determining architectural and engineering requirements and ensuring compliance of the Department with applicable laws relating to the construction program of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc27b5357-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312A/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Management of the short-term and long-term leasing of real property by the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc27b5358-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312A/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repair and maintenance of facilities of the Department, including custodial services, building management and administration, and maintenance of roads, grounds, and infrastructure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc27b5359-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s312A/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Management of procurement and acquisition processes relating to the construction and operation of facilities of the Department, including the award of contracts related to design, construction, furnishing, and supplies and equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc27b535a-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461/tVIII/s811/a"},"text":"Pub. L. 109–461, title VIII, § 811(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3446"},"text":"120 Stat. 3446","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
