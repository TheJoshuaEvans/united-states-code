{"tag":"section","attrib":{"id":"idc2dab0d0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703C"},"text":null,"children":[{"tag":"num","attrib":{"value":"1703C"},"text":"§ 1703C.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards for quality","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2dab0d1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703C/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2dab0d2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703C/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall establish standards for quality regarding hospital care, medical services, and extended care services furnished by the Department pursuant to this title, including through non-Department health care providers pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1703"},"text":"section 1703 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2dab0d3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703C/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2dab0d4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703C/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In establishing standards for quality under paragraph (1), the Secretary shall consider existing health quality measures that are applied to public and privately sponsored health care systems with the purpose of providing covered veterans relevant comparative information to make informed decisions regarding their health care.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2dab0d5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703C/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall ensure that the standards for quality established under paragraph (1) are comparable to industry standards to ensure there is adequate data transference between care furnished by the Department and care furnished by a non-Department provider.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2dab0d6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703C/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall collect and consider data for purposes of establishing the standards under paragraph (1). Such data collection shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2dab0d7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703C/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after consultation with veterans service organizations and other key stakeholders on survey development or modification of an existing survey, a survey of veterans who have used hospital care, medical services, or extended care services furnished by the Veterans Health Administration during the most recent 2-year period to assess the satisfaction of the veterans with service and quality of care; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2dab0d8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703C/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" datasets that include, at a minimum, elements relating to the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc2dab0d9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703C/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Timely care.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc2dab0da-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703C/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Effective care.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc2dab0db-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703C/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Safety, including, at a minimum, complications, readmissions, and deaths.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc2dab0dc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703C/a/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Efficiency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc2dab0dd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703C/a/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Outcomes relating to patient quality of life.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2dab0de-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703C/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall consult with all pertinent Federal entities (including the Department of Defense, the Department of Health and Human Services, the Centers for Medicare & Medicaid Services, and the Indian Health Service), entities in the private sector, and other non-governmental entities including Third Party Administrators in establishing standards for quality.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2dab0df-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703C/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When collecting, considering, and applying data related to patient care for purposes of establishing standards for quality under paragraph (1), the Secretary shall ensure no metric is being over or under analyzed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2dab0e0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703C/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In establishing standards for quality under paragraph (1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2dab0e1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703C/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilize the most up-to-date practices for extracting and analyzing relevant data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2dab0e2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703C/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilize all relevant data available to the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2dab0e3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703C/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure the most efficient use of time and resources related to the use of data scientists employed by the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2dab0e4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703C/a/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborate, as appropriate, with entities specified in paragraph (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2dab0e5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703C/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2dab0e6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703C/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not less frequently than once every five years, the Secretary shall update the standards for quality established under paragraph (1) pursuant to the requirements for the establishment of such standards under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2dab0e7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703C/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 30 days after any date on which the Secretary updates, pursuant to subparagraph (A), the standards for quality under paragraph (1), the Secretary shall submit to the appropriate committees of Congress a report on such updated standards for quality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2dab0e8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703C/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication and Consideration of Public Comments","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2dab0e9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703C/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not less frequently than once every three years, the Secretary shall publish the quality rating of medical facilities of the Department pursuant to standards for quality under subsection (a) in the publicly available Hospital Compare website through the Centers for Medicare & Medicaid Services for the purpose of providing veterans with information that allows them to compare performance measure information among Department and non-Department health care providers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2dab0ea-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703C/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 2 years after the date on which the Secretary establishes or updates standards for quality under subsection (a), the Secretary shall consider and solicit public comment on potential changes to the measures used in such standards to ensure that they include the most up-to-date and applicable industry measures for veterans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2dab0eb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703C/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2dab0ec-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703C/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “appropriate committees of Congress” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2dab0ed-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703C/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Veterans’ Affairs and the Committee on Appropriations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2dab0ee-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703C/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Veterans’ Affairs and the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2dab0ef-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703C/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “covered veterans” means veterans described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1703/b"},"text":"section 1703(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2dab0f0-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/182/tI/s104/a"},"text":"Pub. L. 115–182, title I, § 104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-06"},"text":"June 6, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1410"},"text":"132 Stat. 1410","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/251/tII/s211/a/4"},"text":"Pub. L. 115–251, title II, § 211(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-29"},"text":"Sept. 29, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3174"},"text":"132 Stat. 3174","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/210/tI/s104/a"},"text":"Pub. L. 118–210, title I, § 104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-02"},"text":"Jan. 2, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2711"},"text":"138 Stat. 2711","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2dab0f1-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc2dab0f2-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc2dab0f3-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/210/s104/a/1/A"},"text":"Pub. L. 118–210, § 104(a)(1)(A)","children":[],"tail":", designated existing provisions as subpar. (A) and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(B)(v). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/210/s104/a/1/B"},"text":"Pub. L. 118–210, § 104(a)(1)(B)","children":[],"tail":", added cl. (v)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/210/s104/a/1/C"},"text":"Pub. L. 118–210, § 104(a)(1)(C)","children":[],"tail":", substituted “the Centers for Medicare & Medicaid Services, and the Indian Health Service” for “and the Centers for Medicare & Medicaid Services” and “and other non-governmental entities including Third Party Administrators” for “and other nongovernmental entities”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/210/s104/a/1/D"},"text":"Pub. L. 118–210, § 104(a)(1)(D)","children":[],"tail":", added pars. (5) to (7) and struck out former par. (5) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) Not later than 270 days after the date of the enactment of the Caring for Our Veterans Act of 2018, the Secretary shall submit to the appropriate committees of Congress a report detailing the standards for quality.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B)(i) Before submitting the report required under subparagraph (A), the Secretary shall provide periodic updates to the appropriate committees of Congress to confirm the Department’s progress towards developing the standards for quality required by this section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) The first update under clause (i) shall occur no later than 120 days from the date of the enactment of the Caring for Our Veterans Act of 2018.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/210/s104/a/2/A"},"text":"Pub. L. 118–210, § 104(a)(2)(A)","children":[],"tail":", substituted “Not less frequently than once every three years” for “Not later than 1 year after the date on which the Secretary establishes standards for quality under subsection (a)” and inserted “pursuant to standards for quality under subsection (a)” after “medical facilities of the Department”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/210/s104/a/2/B"},"text":"Pub. L. 118–210, § 104(a)(2)(B)","children":[],"tail":", inserted “or updates” after “establishes”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/251"},"text":"Pub. L. 115–251","children":[],"tail":" inserted heading and introductory provisions, substituted “means” for “refers to” in par. (2), and realigned margins."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc2dab0f4-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc2dab0f5-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadline for Update","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/210/tI/s104/b"},"text":"Pub. L. 118–210, title I, § 104(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-02"},"text":"Jan. 2, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2712"},"text":"138 Stat. 2712","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/210/tI/s104/b"},"text":"“The Secretary, pursuant to paragraph (7) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1703C/a"},"text":"section 1703C(a) of title 38","children":[],"tail":", United States Code (as added by subsection (a)), shall make the first update to the standards for quality established under paragraph (1) of such section not later than the date that is five years after the date on which the Secretary submits the report under paragraph (2) of subsection (d) [of "},{"tag":"ref","attrib":{"href":"/us/pl/118/210/s104"},"text":"section 104 of Pub. L. 118–210","children":[],"tail":", set out as a note below].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc2dab0f6-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Updates to Quality Care Metrics","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/210/tI/s104/d"},"text":"Pub. L. 118–210, title I, § 104(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-02"},"text":"Jan. 2, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2712"},"text":"138 Stat. 2712","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/210/tI/s104/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Initial report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than one year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2025-01-02"},"text":"Jan. 2, 2025","children":[],"tail":"], the Secretary of Veterans Affairs shall submit to the appropriate committees of Congress [Committees on Veterans’ Affairs and Appropriations of the Senate and the House of Representatives] a report on how the Secretary plans to implement the amendments made by subsections [sic] (a) [amending this section]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadline; summary report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than two years after the date of the enactment of this Act, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement the amendments made by subsection (a), including by updating the standards for quality established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1703C"},"text":"section 1703C of title 38","children":[],"tail":", United States Code; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the appropriate committees of Congress a report detailing the standards for quality updated pursuant to such amendments.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/210/tI/s104/f"},"text":"Pub. L. 118–210, title I, § 104(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-02"},"text":"Jan. 2, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2713"},"text":"138 Stat. 2713","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/210/tI/s104/f"},"text":"“In this section [amending this section and enacting provisions set out as notes above], the term ‘appropriate committees of Congress’ has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1703C"},"text":"section 1703C of title 38","children":[],"tail":", United States Code.”"}],"tail":"\n]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
