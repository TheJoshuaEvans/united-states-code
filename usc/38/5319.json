{"tag":"section","attrib":{"id":"idc3d9d19f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5319"},"text":null,"children":[{"tag":"num","attrib":{"value":"5319"},"text":"§ 5319.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on access to financial records","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3d9d1a0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5319/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may make a request referred to in section 1113(p) of the Right to Financial Privacy Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3413/p"},"text":"12 U.S.C. 3413(p)","children":[],"tail":") only if the Secretary determines that the requested information—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3d9d1a1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5319/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is necessary in order for the Secretary to administer the provisions of law referred to in that section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d9d1a2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5319/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cannot be secured by a reasonable search of records and information of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d9d1a3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5319/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall include a certification of the determinations referred to in subsection (a) in each request presented to a financial institution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d9d1a4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5319/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information disclosed pursuant to a request referred to in subsection (a) may be used solely for the purpose of the administration of benefits programs under laws administered by the Secretary if, except for the exemption in subsection (a), the disclosure of that information would otherwise be prohibited by any provision of the Right to Financial Privacy Act of 1978.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3d9d1a5-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/568/tVI/s603/b/1"},"text":"Pub. L. 102–568, title VI, § 603(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4342"},"text":"106 Stat. 4342","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3d9d1a6-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3d9d1a7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc3d9d1a8-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Right to Financial Privacy Act of 1978, referred to in subsec. (c), is title XI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/630"},"text":"Pub. L. 95–630","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3697"},"text":"92 Stat. 3697","children":[],"tail":", which is classified generally to chapter 35 (§ 3401 et seq.) of Title 12, Banks and Banking. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s3401"},"text":"section 3401 of Title 12","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
