{"tag":"section","attrib":{"id":"idc3b3ab7f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3762A"},"text":null,"children":[{"tag":"num","attrib":{"value":"3762A"},"text":"§ 3762A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native community development financial institution relending program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3b3ab80-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3762A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may make a loan to a Native community development financial institution for the purpose of allowing the institution to relend loan amounts to qualified Native American veterans, subject to the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3b3ab81-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3762A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standards","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3b3ab82-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3762A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall establish standards to be used in evaluating whether to make a loan to a Native community development financial institution under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3b3ab83-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3762A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In establishing standards under paragraph (1), the Secretary shall ensure that a Native community development financial institution—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3b3ab84-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3762A/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is able to originate and service loans for single-family homes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3b3ab85-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3762A/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is able to operate the relending program in a manner consistent with the mission of the Department to serve veterans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3b3ab86-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3762A/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses loan amounts received under this section only for the purpose of relending, as described in subsection (c), to Native American veterans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3b3ab87-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3762A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relending Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3b3ab88-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3762A/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Native community development financial institution that receives a loan under this section shall use the loan amounts to make loans to Native American veterans residing on trust land.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3b3ab89-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3762A/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A loan to a Native American veteran made by a Native community development financial institution under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3b3ab8a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3762A/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be limited either to the purpose of purchase, construction, or improvement of a dwelling located on trust land or to the refinance of an existing mortgage loan for a dwelling on trust land, consistent with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3762/h"},"text":"section 3762(h) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3b3ab8b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3762A/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comply with such terms and conditions as the Secretary determines are necessary to protect against predatory lending, including the interest rate charged on a loan to a Native American veteran.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3b3ab8c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3762A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A loan made to a Native community development financial institution under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3b3ab8d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3762A/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be payable to the Secretary upon such terms and conditions as are prescribed in regulations pursuant to this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3b3ab8e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3762A/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bear interest at a rate of one percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3b3ab8f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3762A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Oversight","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to notice and opportunity for a hearing, whenever the Secretary finds with respect to loans made under subsection (a) or (c) that any Native community development financial institution has failed to maintain adequate loan accounting records, to demonstrate proper ability to service loans adequately, or to exercise proper credit judgment, or that such Native community development financial institution has willfully or negligently engaged in practices otherwise detrimental to the interest of veterans or of the Government, the Secretary may take such actions as the Secretary determines necessary to protect veterans or the Government, such as requiring immediate repayment of any loans made under subsection (a) and the assignment to the Secretary of loans made under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3b3ab90-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3762A/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sunset","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may not make a loan under this section after ","children":[{"tag":"date","attrib":{"date":"2027-09-30"},"text":"September 30, 2027","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3b3ab91-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/210/tII/s232/a"},"text":"Pub. L. 118–210, title II, § 232(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-02"},"text":"Jan. 2, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2787"},"text":"138 Stat. 2787","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
