{"tag":"section","attrib":{"id":"idc2932162-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741"},"text":null,"children":[{"tag":"num","attrib":{"value":"741"},"text":"§ 741.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive Management Fellowship Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2932163-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fellowship Program","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is in the Department an Executive Management Fellowship Program. The purpose of the program shall be to provide—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2932164-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible employees of the Veterans Benefits Administration and the Veterans Health Administration with training and experience in the private sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2932165-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible employees of a private-sector entity with training and experience in the Department of Veterans Affairs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2932166-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fellowship","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2932167-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A fellowship provided under this section is a 1-year fellowship during which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2932168-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a Department participant, the participant receives training and experience at a private-sector entity that is engaged in the administration and delivery of health care or other services similar to the benefits administered by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2932169-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a private-sector participant, the participant receives training and experience at the Veterans Benefits Administration or the Veterans Health Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc293216a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall enter into such agreements with private-sector entities as are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc293216b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection of Recipients","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc293216c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In August of each year, the Secretary shall select—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc293216d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not fewer than 18 and not more than 30 eligible employees of the Veterans Benefits Administration and the Veterans Health Administration to receive a fellowship under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc293216e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not fewer than 18 and not more than 30 eligible employees of private-sector entities to receive a fellowship under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc293216f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the extent practicable, the Secretary shall select eligible employees under subparagraphs (A) and (B) of paragraph (1) from among eligible employees who are veterans in a manner that is reflective of the demographics of the veteran population of the United States and that whenever practicable provides a preference to such employees who represent or service rural areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2932170-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Employees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section, an eligible employee is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2932171-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to an employee of the Veterans Benefits Administration or the Veterans Health Administration, an employee who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2932172-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is compensated at a rate of basic pay not less than the minimum rate of basic pay payable for grade GS–14 of the General Schedule and not more than either the minimum rate of basic pay payable to a member of the Senior Executive Service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5382"},"text":"section 5382 of title 5","children":[],"tail":" or the minimum rate of basic pay payable pursuant to chapter 74 of this title, as the case may be;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2932173-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enters into an agreement with the Secretary under subsection (e); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2932174-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits to the Secretary an application containing such information and assurances as the Secretary may require; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2932175-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to an employee of a private-sector entity, an employee who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2932176-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is employed in a position whose duties and responsibilities are commensurate with an employee of the Department described in paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2932177-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enters into an agreement with the Secretary under subsection (e); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2932178-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits to the Secretary an application containing such information and assurances as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2932179-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc293217a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An agreement between the Secretary and a Department participant shall be in writing, shall be signed by the participant, and shall include the following provisions:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc293217b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary’s agreement to provide the participant with a fellowship under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc293217c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The participant’s agreement—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc293217d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to accept the fellowship;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc293217e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after completion of the fellowship, to serve as a full-time employee in the Veterans Benefits Administration or the Veterans Health Administration for at least 2 years as specified in the agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc293217f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/e/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that, during the 2-year period beginning on the last day of the fellowship, the participant will not accept employment in the same industry as the industry of the private-sector entity at which the participant accepts the fellowship.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2932180-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A provision that any financial obligation of the United States arising out of an agreement entered into under this subchapter, and any obligation of the participant which is conditioned on such agreement, is contingent upon funds being appropriated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2932181-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A statement of the damages to which the United States is entitled under this subchapter for the participant’s breach of the agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2932182-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/e/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other terms as the Secretary determines are required to be included in the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2932183-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An agreement between the Secretary and a private-sector participant shall be in writing, shall be signed by the participant, and shall include the following provisions:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2932184-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary’s agreement to provide the participant with a fellowship under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2932185-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The participant’s agreement to accept the fellowship.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2932186-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other terms as the Secretary determines are required to be included in the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2932187-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of Recipients","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2932188-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Department participant shall be considered an employee of the Department for all purposes, including for purposes of receiving a salary and benefits, and shall remain eligible for all promotion and incentive programs otherwise available to such an employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2932189-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A private-sector participant shall be considered an employee of the private-sector entity that employs the participant for all purposes, including for purposes of receiving a salary and benefits, and during the fellowship shall be treated as a contractor of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc293218a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc293218b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 60 days after completing a fellowship under this section, a recipient of the fellowship shall submit to the Secretary a report on the fellowship.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc293218c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each such report shall describe the duties of the recipient during the fellowship and any recommendations of the recipient for the application by the Secretary of industry processes, technologies, and best practices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc293218d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 7 days after receiving each such report, the Secretary shall submit to the Committees on Veterans’ Affairs of the Senate and House of Representatives such report without change.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc293218e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc293218f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Department participant” means an employee of the Veterans Benefits Administration or the Veterans Health Administration who is participating in the fellowship under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2932190-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “private-sector entity” includes an entity operating under a public-private partnership.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2932191-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s741/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “private-sector participant” means an employee of a private-sector entity who is participating in the fellowship under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2932192-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/46/tII/s202/a"},"text":"Pub. L. 115–46, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-12"},"text":"Aug. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/959"},"text":"131 Stat. 959","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2932193-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc2932194-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc2932195-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Grade GS–14 of the General Schedule, referred to in subsec. (d)(1)(A), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc2932196-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc2932197-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadline for Implementation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/46/tII/s202/b"},"text":"Pub. L. 115–46, title II, § 202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-12"},"text":"Aug. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/962"},"text":"131 Stat. 962","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/46/tII/s202/b"},"text":"“Not later than 1 year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2017-08-12"},"text":"Aug. 12, 2017","children":[],"tail":"], the Secretary of Veterans Affairs shall implement the Executive Management Fellowship Program required under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s741"},"text":"section 741 of title 38","children":[],"tail":", United States Code, as added by subsection (a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
