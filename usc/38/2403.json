{"tag":"section","attrib":{"id":"idc343abfc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2403"},"text":null,"children":[{"tag":"num","attrib":{"value":"2403"},"text":"§ 2403.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Memorial areas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc343abfd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2403/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall set aside, when available, suitable areas in national cemeteries to honor the memory of members of the Armed Forces and veterans—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc343abfe-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2403/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who are missing in action;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc343abff-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2403/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose remains have not been recovered or identified;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc343ac00-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2403/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose remains were buried at sea, whether by the member’s or veteran’s own choice or otherwise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc343ac01-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2403/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose remains were donated to science; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc343ac02-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2403/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose remains were cremated and the ashes scattered without interment of any portion of the ashes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc343ac03-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2403/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under regulations prescribed by the Secretary, group memorials may be placed to honor the memory of groups of individuals referred to in subsection (a), and appropriate memorial headstones and markers may be placed to honor the memory of individuals referred to in subsection (a) and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2306/b"},"text":"section 2306(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc343ac04-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2403/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All national and other veterans’ cemeteries under the control of the National Cemetery Administration shall be considered national shrines as a tribute to our gallant dead and, notwithstanding the provisions of any other law, the Secretary is hereby authorized to permit appropriate officials to fly the flag of the United States of America at such cemeteries twenty-four hours each day.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc343ac05-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2403/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc343ac06-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2403/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to standards established by the Secretary, the Secretary shall permit the display of a Fallen Soldier Display in any national cemetery.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc343ac07-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2403/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this subsection, the term “Fallen Soldier Display” means a memorial monument in honor of fallen members of the Armed Forces that may include a replica of an inverted rifle, boots, helmets, and identification tag.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc343ac08-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/43/s2/a"},"text":"Pub. L. 93–43, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-06-18"},"text":"June 18, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/76"},"text":"87 Stat. 76","children":[],"tail":", § 1003; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/66/tVI/s603/b"},"text":"Pub. L. 97–66, title VI, § 603(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-10-17"},"text":"Oct. 17, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1034"},"text":"95 Stat. 1034","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/295/s4/34"},"text":"Pub. L. 97–295, § 4(34)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1307"},"text":"96 Stat. 1307","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIII/s313/b/1"},"text":"Pub. L. 101–237, title III, § 313(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2077"},"text":"103 Stat. 2077","children":[],"tail":"; renumbered § 2403, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/368/tIV"},"text":"Pub. L. 105–368, title IV","children":[],"tail":", §§ 401(c), 403(c)(6), "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3335"},"text":"112 Stat. 3335","children":[],"tail":", 3339; "},{"tag":"ref","attrib":{"href":"/us/pl/116/106/s2"},"text":"Pub. L. 116–106, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-07"},"text":"Jan. 7, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3291"},"text":"133 Stat. 3291","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc343ac09-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc343ac0a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc343ac0b-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For cemeteries under the control of the National Cemetery Administration, referred to in subsec. (c), see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2400/b"},"text":"section 2400(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc343ac0c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/106"},"text":"Pub. L. 116–106","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/s401/c"},"text":"Pub. L. 105–368, § 401(c)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “Under regulations prescribed by the Secretary, appropriate memorials or markers shall be erected to honor the memory of those individuals, or group of individuals, referred to in subsection (a) of this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/s403/c/6"},"text":"Pub. L. 105–368, § 403(c)(6)","children":[],"tail":", substituted “under the control of the National Cemetery Administration” for “in the National Cemetery System created by this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1003"},"text":"section 1003 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" substituted “Secretary” for “Administrator” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295"},"text":"Pub. L. 97–295","children":[],"tail":" substituted “chapter” for “Act” after “created by this”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/66"},"text":"Pub. L. 97–66","children":[],"tail":" substituted provisions relating to members of the Armed Forces and veterans, for provisions that related only to members of the Armed Forces, struck out provisions limiting the subsection to persons who died or were killed while serving in the Armed Forces, and inserted provisions relating to persons whose remains have not been recovered, whose remains were donated to science, or whose remains were cremated and the ashes scattered without interment of any portion of the ashes."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc343ac0d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc343ac0e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/66"},"text":"Pub. L. 97–66","children":[],"tail":" applicable with respect to veterans dying before, on, or after "},{"tag":"date","attrib":{"date":"1981-10-17"},"text":"Oct. 17, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/66/s701/b/6"},"text":"section 701(b)(6) of Pub. L. 97–66","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1114"},"text":"section 1114 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
