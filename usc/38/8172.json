{"tag":"section","attrib":{"id":"idc4347452-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8172"},"text":null,"children":[{"tag":"num","attrib":{"value":"8172"},"text":"§ 8172.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management of major information technology projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc4347453-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8172/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cost, Schedule, and Performance Information","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4347454-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8172/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall, acting through the Chief Information Officer of the Department, submit to the appropriate congressional committees a report containing information on the cost, schedule, and performance of each major information technology project that begins after the date of the enactment of the Joseph Maxwell Cleland and Robert Joseph Dole Memorial Veterans Benefits and Health Care Improvement Act of 2022, as generated by the business owner of the project, prior to the commencement of such project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4347455-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8172/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each report submitted under paragraph (1) for a project shall include, with respect to such project, the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc4347456-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8172/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An estimate of acquisition costs, implementation costs, and life cycle costs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4347457-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8172/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An intended implementation schedule indicating significant milestones, initial operating capability, and full operating capability or completion.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4347458-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8172/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Key business, functional, and performance objectives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4347459-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8172/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Baseline","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc434745a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8172/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall use the information on the cost, schedule, and performance of a major information technology project included in the report under subsection (a) as the baseline against which changes or variances are measured during the life cycle of such project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc434745b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8172/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc434745c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8172/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annually update the baseline of a major information technology project pursuant to subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc434745d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8172/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include such updated baseline in the documents providing detailed information on the budget for the Department that the Secretary submits to Congress in conjunction with the President’s budget submission pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc434745e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8172/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Changes and Variances","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc434745f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8172/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 60 days after the date on which the Secretary identifies a change or variance described in paragraph (2) in the cost, schedule, or performance of a major information technology project, the Secretary, acting through the Chief Information Officer, shall submit to the appropriate congressional committees a notification of such change or variance, including a description and explanation for such change or variance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4347460-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8172/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A change or variance in the cost, schedule, or performance of a major information technology project described in this paragraph is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc4347461-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8172/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the acquisition, implementation, or life cycle cost of the project, or development increment therein, a change or variance that is 10 percent or greater compared to the baseline;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4347462-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8172/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the schedule for a development increment or for achieving a significant milestone, initial operating capability, or full operating capability, or for the final completion of the project, a change or variance that is 180 days or greater compared to the baseline; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4347463-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8172/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the performance, an instance where a key business, functional, or performance objective is not attained, or is not anticipated to be attained, in whole or in part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4347464-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8172/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Management","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that each major information technology project is managed by an interdisciplinary team consisting of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4347465-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8172/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A project manager who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc4347466-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8172/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc4347467-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8172/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is certified in project management at level three by—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc4347468-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8172/d/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc4347469-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8172/d/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Acquisition Institute pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1201"},"text":"section 1201 of title 41","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc434746a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8172/d/1/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Defense pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1701a"},"text":"section 1701a of title 10","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc434746b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8172/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" holds an equivalent certification by a private sector project management certification organization, as determined appropriate by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc434746c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8172/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an employee of the Office of Information and Technology of the Department or an employee of an element of the Department at which the project originates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc434746d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8172/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A functional lead who is an employee of the element of the Department at which the project originates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc434746e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8172/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A technical lead who is an employee of the Office of Information and Technology of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc434746f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8172/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A contracting officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4347470-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8172/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sufficient other project management, functional, technical, and procurement personnel as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc4347471-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dU/tIV/s403/a"},"text":"Pub. L. 117–328, div. U, title IV, § 403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5486"},"text":"136 Stat. 5486","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc4347472-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc4347473-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc4347474-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the Joseph Maxwell Cleland and Robert Joseph Dole Memorial Veterans Benefits and Health Care Improvement Act of 2022, referred to in subsec. (a)(1), is the date of enactment of div. U of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc4347475-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc4347476-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dU/tIV/s403/c/1"},"text":"Pub. L. 117–328, div. U, title IV, § 403(c)(1)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5490"},"text":"136 Stat. 5490","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dU/tIV/s403/c/1"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Current and new major projects","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as specifically provided in subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s8172"},"text":"section 8172 of title 38","children":[],"tail":", United States Code, as added by subsection (a) of this section, such section 8172 shall apply with respect to major information technology projects that begin before, on, or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subsection [enacting this note and provisions not set out in the Code], the terms ‘appropriate congressional committees’ and ‘major information technology project’ have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s8171"},"text":"section 8171 of title 38","children":[],"tail":", United States Code, as added by subsection (a) of this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
