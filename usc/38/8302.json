{"tag":"section","attrib":{"id":"idc436e637-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8302"},"text":null,"children":[{"tag":"num","attrib":{"value":"8302"},"text":"§ 8302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Legal proceedings","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purpose of acquiring title to and possession of any property which the Secretary is by this chapter authorized to accept, the Secretary may initiate and appear in any appropriate legal proceedings, and take such steps therein or in connection therewith as in the Secretary’s discretion may be desirable and appropriate to reduce said property to possession. The Secretary may incur such expenses incident to such proceedings as the Secretary deems necessary or appropriate, which shall be paid as are other administrative expenses of the Department. All funds received by devise, bequest, gift, or otherwise, for the purposes contemplated in this chapter, including net proceeds of sales authorized by this chapter, shall be deposited with the Treasurer of the United States to the credit of the General Post Fund.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc436e638-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1254"},"text":"72 Stat. 1254","children":[],"tail":", § 5102; "},{"tag":"ref","attrib":{"href":"/us/pl/99/576/tVII/s701/90"},"text":"Pub. L. 99–576, title VII, § 701(90)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3299"},"text":"100 Stat. 3299","children":[],"tail":"; renumbered § 8302, "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/3"},"text":"Pub. L. 102–83, § 4(a)(3)","children":[],"tail":", (4), (b)(1), (2)(E), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404"},"text":"105 Stat. 404","children":[],"tail":", 405.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc436e639-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc436e63a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc436e63b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5102"},"text":"section 5102 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator” wherever appearing, “Secretary’s” for “Administrator’s”, and “Department” for “Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576"},"text":"Pub. L. 99–576","children":[],"tail":" substituted “the Administrator” for “he” in two places, “the Administrator’s” for “his”, and “The Administrator” for “He”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
