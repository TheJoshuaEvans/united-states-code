{"tag":"section","attrib":{"id":"idc345f68c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2409"},"text":null,"children":[{"tag":"num","attrib":{"value":"2409"},"text":"§ 2409.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Memorial areas in Arlington National Cemetery","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc345f68d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2409/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Army may set aside, when available, a suitable area or areas in Arlington National Cemetery, Virginia, to honor the memory of members of the Armed Forces and veterans—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc345f68e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2409/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who are missing in action;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc345f68f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2409/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose remains have not been recovered or identified;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc345f690-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2409/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose remains were buried at sea, whether by the member’s or veteran’s own choice or otherwise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc345f691-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2409/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose remains were donated to science; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc345f692-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2409/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose remains were cremated and whose ashes were scattered without interment of any portion of the ashes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3486693-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2409/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3486694-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2409/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under regulations prescribed by the Secretary of the Army and subject to paragraph (2), appropriate memorials or markers may be erected in Arlington National Cemetery to honor the memory of those individuals, or group of individuals, referred to in subsection (a) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3486695-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2409/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3486696-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2409/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except for a monument containing or marking interred remains, no monument (or similar structure, as determined by the Secretary of the Army in regulations) may be placed in Arlington National Cemetery except pursuant to the provisions of this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3486697-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2409/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A monument may be placed in Arlington National Cemetery if the monument commemorates—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc3486698-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2409/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the service in the Armed Forces of the individual, or group of individuals, whose memory is to be honored by the monument; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3486699-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2409/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a particular military event.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc348669a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2409/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No monument may be placed in Arlington National Cemetery until the end of the 25-year period beginning—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc348669b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2409/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the commemoration of service under subparagraph (B)(i), on the last day of the period of service so commemorated; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc348669c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2409/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the commemoration of a particular military event under subparagraph (B)(ii), on the last day of the period of the event.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc348669d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2409/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A monument may be placed only in those sections of Arlington National Cemetery designated by the Secretary of the Army for such placement and only on land the Secretary determines is not suitable for burial.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc348669e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2409/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A monument may only be placed in Arlington National Cemetery if an appropriate nongovernmental entity has agreed to act as a sponsoring organization to coordinate the placement of the monument and—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc348669f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2409/b/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the construction and placement of the monument are paid for only using funds from private sources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc34866a0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2409/b/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Army consults with the Commission of Fine Arts and the Advisory Committee on Arlington National Cemetery before approving the design of the monument; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc34866a1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2409/b/2/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sponsoring organization provides for an independent study on the availability and suitability of alternative locations for the proposed monument outside of Arlington National Cemetery.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc34866a2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2409/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc34866a3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2409/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Army may waive the requirement under paragraph (2)(C) in a case in which the monument would commemorate a group of individuals who the Secretary determines—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc34866a4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2409/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has made valuable contributions to the Armed Forces that have been ongoing and perpetual for longer than 25 years and are expected to continue on indefinitely; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc34866a5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2409/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has provided service that is of such a character that the failure to place a monument to the group in Arlington National Cemetery would present a manifest injustice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc34866a6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2409/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the Secretary waives such requirement under subparagraph (A), the Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc34866a7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2409/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available on an Internet website notification of the waiver and the rationale for the waiver; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc34866a8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2409/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Committee on Veterans’ Affairs and the Committee on Armed Services of the Senate and the Committee on Veterans’ Affairs and the Committee on Armed Services of the House of Representatives written notice of the waiver and the rationale for the waiver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc34866a9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2409/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Army shall provide notice to the Committee on Veterans’ Affairs and the Committee on Armed Services of the Senate and the Committee on Veterans’ Affairs and the Committee on Armed Services of the House of Representatives of any monument proposed to be placed in Arlington National Cemetery. During the 60-day period beginning on the date on which such notice is received, Congress may pass a joint resolution of disapproval of the placement of the monument. The proposed monument may not be placed in Arlington National Cemetery until the later of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc34866aa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2409/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if Congress does not pass a joint resolution of disapproval of the placement of the monument, the date that is 60 days after the date on which notice is received under this paragraph; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc34866ab-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2409/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if Congress passes a joint resolution of disapproval of the placement of the monument, and the President signs a veto of such resolution, the earlier of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc34866ac-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2409/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which either House of Congress votes and fails to override the veto of the President; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc34866ad-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2409/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date that is 30 session days after the date on which Congress received the veto and objections of the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc34866ae-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576/tIV/s413/a"},"text":"Pub. L. 99–576, title IV, § 413(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3284"},"text":"100 Stat. 3284","children":[],"tail":", § 1009; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIII/s313/b/5"},"text":"Pub. L. 101–237, title III, § 313(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2077"},"text":"103 Stat. 2077","children":[],"tail":"; renumbered § 2409, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/154/tVI/s604"},"text":"Pub. L. 112–154, title VI, § 604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1201"},"text":"126 Stat. 1201","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc34866af-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc34866b0-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc34866b1-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/154"},"text":"Pub. L. 112–154","children":[],"tail":" designated existing provisions as par. (1), inserted “and subject to paragraph (2)” after “Secretary of the Army”, and added pars. (2) to (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1009"},"text":"section 1009 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" inserted “of the Army” after “Secretary”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc34866b2-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc34866b3-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Updates and Preservation of Memorials to Chaplains at Arlington National Cemetery","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tX/s1092"},"text":"Pub. L. 119–60, div. A, title X, § 1092","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1064"},"text":"139 Stat. 1064","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dA/tX/s1092"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Updates and Preservation of Memorials.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Protestant chaplains memorial","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Army shall permit NCMAF—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to modify the memorial to Protestant chaplains located on Chaplains Hill to include a granite, marble, or other stone base for the bronze plaque of the memorial;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide an updated bronze plaque that includes the name of each chaplain, verified as described in subsection (b), who died while serving on active duty in the Armed Forces after the date on which the original memorial was placed and before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make such other updates and corrections to the memorial that the Secretary determines necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Catholic chaplain memorials","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Army shall permit NCMAF—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to update the Catholic chaplains memorial to include the name of each chaplain, verified under subsection (b), who died while serving on active duty in the Armed Forces after the date on which the original memorial was placed and before the date of the enactment of this Act; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make such other updates and corrections to the memorial that the Secretary determines necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Jewish chaplain memorials","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army shall permit NCMAF to update and make corrections to the Jewish chaplain memorials located on Chaplains Hill that the Secretary determines necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No cost to federal government","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The activities of NCMAF authorized by this subsection shall be carried out at no cost to the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Verification of Names","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"NCMAF may not include the name of a chaplain on a memorial on Chaplains Hill under subsection (a) unless that name has been verified by the Chief of Chaplains of the Army, Navy, or Air Force, or the Chaplain of the United States Marine Corps, depending on the Armed Force in which the chaplain served.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on Expansion of Memorials","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (a)(1)(A), this section may not be construed as authorizing the expansion of any memorial that is located on Chaplains Hill on the date of the enactment of this Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘Chaplains Hill’ means the area in Arlington National Cemetery that, as of the date of the enactment of this Act, is generally identified and recognized as Chaplains Hill.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘NCMAF’ means the National Conference on Ministry to the Armed Forces or any successor organization recognized in law for purposes of the operation of this section.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior act:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tV/s584"},"text":"Pub. L. 117–81, div. A, title V, § 584","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1758"},"text":"135 Stat. 1758","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tV/s593"},"text":"Pub. L. 117–263, div. A, title V, § 593","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2612"},"text":"136 Stat. 2612","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc34866b4-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transfer to the Secretary of the Army and Management of Parcel of Federal Land in Arlington, Virginia","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dB/tXXVIII/s2834/a"},"text":"Pub. L. 116–92, div. B, title XXVIII, § 2834(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1893"},"text":"133 Stat. 1893","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/92/dB/tXXVIII/s2834/a"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Administrative jurisdiction over the parcel of Federal land described in paragraph (2) is transferred from the Secretary of the Interior to the Secretary of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Description of land","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The parcel of Federal land referred to in paragraph (1) is the approximately 16.09-acre parcel of land in Arlington, Virginia, as depicted on the map entitled ‘Arlington National Cemetery, Memorial Ave–NPS Parcel’ and dated ","children":[{"tag":"date","attrib":{"date":"2019-02-11"},"text":"February 11, 2019","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dB/tXXVIII/s2834/e/3/A"},"text":"Pub. L. 116–92, div. B, title XXVIII, § 2834(e)(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1893"},"text":"133 Stat. 1893","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/92/dB/tXXVIII/s2834/e/3/A"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The parcel of Federal land transferred to the Secretary of the Army by subsection (a)(1) [set out above] shall be administered by the Secretary of the Army—","children":[],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as part of Arlington National Cemetery; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in accordance with applicable law, including—","children":[],"tail":null},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"“(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"“(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2409"},"text":"section 2409 of title 38","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc34866b5-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of Memorial to the Crew of the Apollo I Launch Test Accident at Arlington National Cemetery","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1087"},"text":"Pub. L. 115–91, div. A, title X, § 1087","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1604"},"text":"131 Stat. 1604","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/91/dA/tX/s1087"},"text":"“Subject to applicable requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2409/b/2/E"},"text":"section 2409(b)(2)(E) of title 38","children":[],"tail":", United States Code, the Secretary of the Army, in consultation with the Administrator of the National Aeronautics and Space Administration, the Commission of Fine Arts, and the Advisory Committee on Arlington National Cemetery, shall authorize the construction, at an appropriate place in Arlington National Cemetery, Virginia, of a memorial marker honoring the three members of the crew of the Apollo I who died during a launch rehearsal test on "},{"tag":"date","attrib":{"date":"1967-01-27"},"text":"January 27, 1967","children":[],"tail":", in Cape Canaveral, Florida. The memorial may not be constructed in a location that is otherwise suitable as an interment site.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc34866b6-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Columbia Orbiter Memorial","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/11/tIII"},"text":"Pub. L. 108–11, title III","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-04-16"},"text":"Apr. 16, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/603"},"text":"117 Stat. 603","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/11/tIII"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"301"},"text":"“SEC. 301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SHORT TITLE.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“This title may be cited as the ‘Columbia Orbiter Memorial Act’.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"302"},"text":"“SEC. 302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" CONSTRUCTION OF MEMORIAL TO CREW OF COLUMBIA ORBITER AT ARLINGTON NATIONAL CEMETERY.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army shall, in consultation with the Administrator of the National Aeronautics and Space Administration, construct at an appropriate place in Arlington National Cemetery, Virginia, a memorial marker honoring the seven members of the crew of the Columbia Orbiter who died on ","children":[{"tag":"date","attrib":{"date":"2003-02-01"},"text":"February 1, 2003","children":[],"tail":", over the State of Texas during the landing of space shuttle mission STS–107."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Of the amount appropriated or otherwise made available by title II of the Department of Defense Appropriations Act, 2003 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/248"},"text":"Public Law 107–248","children":[],"tail":") under the heading ‘Operation and Maintenance, Army’ ["},{"tag":"ref","attrib":{"href":"/us/stat/116/1521"},"text":"116 Stat. 1521","children":[],"tail":"], $500,000 shall be available for the construction of the memorial marker required by subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"303"},"text":"“SEC. 303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" DONATIONS FOR MEMORIAL FOR CREW OF COLUMBIA ORBITER.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Accept Donations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of the National Aeronautics and Space Administration may accept gifts and donations of services, money, and property (including personal, tangible, or intangible property) for the purpose of an appropriate memorial or monument to the seven members of the crew of the Columbia Orbiter who died on ","children":[{"tag":"date","attrib":{"date":"2003-02-01"},"text":"February 1, 2003","children":[],"tail":", over the State of Texas during the landing of space shuttle mission STS–107, whether such memorial or monument is constructed by the Administrator or is the memorial marker required by section 302."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator may transfer to the Secretary of the Army any services, money, or property accepted by the Administrator under subsection (a) for the purpose of the construction of the memorial marker required by section 302.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any moneys transferred to the Secretary under paragraph (1) shall be merged with amounts in the account referred to in subsection (b) of section 302, and shall be available for the purpose referred to in that subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expiration of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority of the Administrator to accept gifts and donations under subsection (a) shall expire 5 years after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2003-04-16"},"text":"Apr. 16, 2003","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc34866b7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authorization of Placement of a Memorial in Arlington National Cemetery Honoring World War II Veterans Who Fought in the Battle of the Bulge","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/330/tII/s204"},"text":"Pub. L. 107–330, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-06"},"text":"Dec. 6, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2824"},"text":"116 Stat. 2824","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/330/tII/s204"},"text":"“The Secretary of the Army is authorized to place in Arlington National Cemetery a memorial marker honoring veterans who fought in the battle in the European theater of operations during World War II known as the Battle of the Bulge.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
