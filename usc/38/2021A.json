)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/58"},"text":"Pub. L. 114–58","children":[],"tail":" substituted “2016” for “2015”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc332e287-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc332e288-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/37"},"text":"Pub. L. 119–37","children":[],"tail":" effective as if enacted on "},{"tag":"date","attrib":{"date":"2025-09-30"},"text":"Sept. 30, 2025","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/119/37/s7406"},"text":"section 7406 of Pub. L. 119–37","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s111A"},"text":"section 111A of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
