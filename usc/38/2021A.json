{"tag":"section","attrib":{"id":"idc332e278-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021A"},"text":null,"children":[{"tag":"num","attrib":{"value":"2021A"},"text":"§ 2021A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Homeless women veterans and homeless veterans with children reintegration grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc332e279-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the availability of appropriations provided for such purpose, the Secretary of Labor shall make grants to programs and facilities that the Secretary determines provide dedicated services for homeless women veterans and homeless veterans with children.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc332e27a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Grants under this section shall be used to provide job training, counseling, placement services (including job readiness and literacy and skills training) and child care services to expedite the reintegration of homeless women veterans and homeless veterans with children into the labor force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc332e27b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement To Monitor Expenditures of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc332e27c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021A/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Labor shall collect such information as that Secretary considers appropriate to monitor and evaluate the distribution and expenditure of funds appropriated to carry out this section. The information shall include data with respect to the results or outcomes of the services provided to each homeless veteran under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc332e27d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021A/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information under paragraph (1) shall be furnished in such form and manner as the Secretary of Labor may specify.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc332e27e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration Through the Assistant Secretary of Labor for Veterans’ Employment and Training","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Labor shall carry out this section through the Assistant Secretary of Labor for Veterans’ Employment and Training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc332e27f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Biennial Report to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Labor shall include as part of the report required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2021/h/1"},"text":"section 2021(h)(1) of this title","children":[],"tail":" an evaluation of the grant program under this section, which shall include an evaluation of services furnished to veterans under this section and an analysis of the information collected under subsection (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc332e280-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021A/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc332e281-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021A/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to any amount authorized to be appropriated to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2021"},"text":"section 2021 of this title","children":[],"tail":", there is authorized to be appropriated to carry out this section $1,000,000 for each of fiscal years 2011 through 2026."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc332e282-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2021A/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds appropriated to carry out this section shall remain available until expended. Funds obligated in any fiscal year to carry out this section may be expended in that fiscal year and the succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc332e283-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/275/tII/s202/a"},"text":"Pub. L. 111–275, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-13"},"text":"Oct. 13, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2873"},"text":"124 Stat. 2873","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/58/tIII/s302"},"text":"Pub. L. 114–58, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-09-30"},"text":"Sept. 30, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/534"},"text":"129 Stat. 534","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/228/tIII/s302"},"text":"Pub. L. 114–228, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-09-29"},"text":"Sept. 29, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/938"},"text":"130 Stat. 938","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/62/tIII/s302"},"text":"Pub. L. 115–62, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-09-29"},"text":"Sept. 29, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1163"},"text":"131 Stat. 1163","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/251/tI/s142"},"text":"Pub. L. 115–251, title I, § 142","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-29"},"text":"Sept. 29, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3170"},"text":"132 Stat. 3170","children":[],"tail":"; "},{"tag":"ref","attrib":{"href