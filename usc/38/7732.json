{"tag":"section","attrib":{"id":"idc41a35a1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7732"},"text":null,"children":[{"tag":"num","attrib":{"value":"7732"},"text":"§ 7732.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Under Secretary for Benefits, acting through the quality assurance entities established under section 7731(a), shall on an ongoing basis perform and oversee quality reviews of the functions of each of the principal organizational elements of the Veterans Benefits Administration.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc41a35a2-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117/s801/a/1"},"text":"Pub. L. 106–117, § 801(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-30"},"text":"Nov. 30, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1585"},"text":"113 Stat. 1585","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
