{"tag":"section","attrib":{"id":"idc2827ea9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s502"},"text":null,"children":[{"tag":"num","attrib":{"value":"502"},"text":"§ 502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review of rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"An action of the Secretary to which section 552(a)(1) or 553 of title 5 (or both) refers is subject to judicial review. Such review shall be in accordance with chapter 7 of title 5 and may be sought only in the United States Court of Appeals for the Federal Circuit. However, if such review is sought in connection with an appeal brought under the provisions of chapter 72 of this title, the provisions of that chapter shall apply rather than the provisions of chapter 7 of title 5.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc2827eaa-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s2/a"},"text":"Pub. L. 102–83, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/386"},"text":"105 Stat. 386","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/389/tI/s102"},"text":"Pub. L. 110–389, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4148"},"text":"122 Stat. 4148","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2827eab-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc2827eac-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc2827ead-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior section 502 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1502"},"text":"section 1502 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s223/c"},"text":"section 223(c) of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s2/a"},"text":"Pub. L. 102–83, § 2(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc2827eae-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/389"},"text":"Pub. L. 110–389","children":[],"tail":" struck out “(other than an action relating to the adoption or revision of the schedule of ratings for disabilities adopted under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1155"},"text":"section 1155 of this title","children":[],"tail":")” after “refers”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
