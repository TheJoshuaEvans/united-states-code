{"tag":"section","attrib":{"id":"idc4347482-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8174"},"text":null,"children":[{"tag":"num","attrib":{"value":"8174"},"text":"§ 8174.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of annual reviews of information technology","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc4347483-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8174/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, acting through the Chief Information Officer of the Department, shall submit to the appropriate congressional committees each annual review of the information technology portfolio of the Department conducted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s11319/d/3"},"text":"section 11319(d)(3) of title 40","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4347484-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8174/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"First Submission","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The first annual review submitted under subsection (a) shall include a copy of each previous annual review conducted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s11319/d/3"},"text":"section 11319(d)(3) of title 40","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc4347485-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dU/tIV/s403/a"},"text":"Pub. L. 117–328, div. U, title IV, § 403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5488"},"text":"136 Stat. 5488","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
