{"tag":"section","attrib":{"id":"idc30a73b9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1728"},"text":null,"children":[{"tag":"num","attrib":{"value":"1728"},"text":"§ 1728.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement of certain medical expenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc30a73ba-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1728/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall, under such regulations as the Secretary prescribes, reimburse veterans eligible for hospital care or medical services under this chapter for the customary and usual charges of emergency treatment (including travel and incidental expenses under the terms and conditions set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s111"},"text":"section 111 of this title","children":[],"tail":") for which such veterans have made payment, from sources other than the Department, where such emergency treatment was rendered to such veterans in need thereof for any of the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc30a73bb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1728/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An adjudicated service-connected disability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30a73bc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1728/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A non-service-connected disability associated with and held to be aggravating a service-connected disability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30a73bd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1728/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any disability of a veteran if the veteran has a total disability permanent in nature from a service-connected disability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30a73be-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1728/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any illness, injury, or dental condition of a veteran who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc30a73bf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1728/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a participant in a vocational rehabilitation program (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3101"},"text":"section 3101 of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc30a73c0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1728/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is medically determined to have been in need of care or treatment to make possible the veteran’s entrance into a course of training, or prevent interruption of a course of training, or hasten the return to a course of training which was interrupted because of such illness, injury, or dental condition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc30a73c1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1728/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In any case where reimbursement would be in order under subsection (a) of this section, the Secretary may, in lieu of reimbursing such veteran, make payment of the reasonable value of emergency treatment directly—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc30a73c2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1728/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the hospital or other health facility furnishing the emergency treatment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30a73c3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1728/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the person or organization making such expenditure on behalf of such veteran.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc30a73c4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1728/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No veteran described in subsection (a) may be held liable for payment for emergency treatment described in such subsection if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc30a73c5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1728/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a claim for direct payment was submitted by an individual or entity under subsection (b)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30a73c6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1728/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such claim was submitted after a deadline established by the Secretary for purposes of this section due to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc30a73c7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1728/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an administrative error made by the individual or entity, such as submission of the claim to the wrong Federal agency or submission of the claim after the deadline; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc30a73c8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1728/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an administrative error made by the Department, such as misplacement of a paper claim or deletion of an electronic claim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc30a73c9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1728/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this section, the term “emergency treatment” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1725/h/1"},"text":"section 1725(h)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc30a73ca-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/82/tI/s106/a"},"text":"Pub. L. 93–82, title I, § 106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-08-02"},"text":"Aug. 2, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/183"},"text":"87 Stat. 183","children":[],"tail":", § 628; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/581/tII"},"text":"Pub. L. 94–581, title II","children":[],"tail":", §§ 202(n), 210(a)(13), "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2856"},"text":"90 Stat. 2856","children":[],"tail":", 2863; "},{"tag":"ref","attrib":{"href":"/us/pl/96/151/tII/s201/d"},"text":"Pub. L. 96–151, title II, § 201(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-12-20"},"text":"Dec. 20, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1093"},"text":"93 Stat. 1093","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tII/s202/a"},"text":"Pub. L. 101–237, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2066"},"text":"103 Stat. 2066","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/54/s14/b/14"},"text":"Pub. L. 102–54, § 14(b)(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-06-13"},"text":"June 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/284"},"text":"105 Stat. 284","children":[],"tail":"; renumbered § 1728 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":", §§ 4(a)(3), (4), (b)(1), (2)(E), 5(a), (c)(1), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404-406"},"text":"105 Stat. 404–406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/387/tIV/s402/b"},"text":"Pub. L. 110–387, title IV, § 402(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4123"},"text":"122 Stat. 4123","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dU/tI/s142/b"},"text":"Pub. L. 117–328, div. U, title I, § 142(b)","children":[],"tail":", (c)(3), "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5424"},"text":"136 Stat. 5424","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/333/s3/e/3/B/i"},"text":"Pub. L. 117–333, § 3(e)(3)(B)(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6128"},"text":"136 Stat. 6128","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc30a73cb-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc30a73cc-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc30a73cd-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (a)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/333"},"text":"Pub. L. 117–333","children":[],"tail":" substituted “section 3101 of” for “section 3101(9) of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" added subsec. (c), redesignated former subsec. (c) as (d) and substituted “section 1725(h)(1)” for “section 1725(f)(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/387/s402/b/1"},"text":"Pub. L. 110–387, § 402(b)(1)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a) which authorized the Secretary to reimburse veterans entitled to hospital care or medical services for the reasonable value of such care or services for which such veterans made payment from sources other than the Department under certain conditions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/387/s402/b/2"},"text":"Pub. L. 110–387, § 402(b)(2)","children":[],"tail":", substituted “emergency treatment” for “care or services” in introductory provisions and in par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/387/s402/b/3"},"text":"Pub. L. 110–387, § 402(b)(3)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s628"},"text":"section 628 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator” in two places in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/3"},"text":"Pub. L. 102–83, § 4(a)(3)","children":[],"tail":", (4), substituted “Department” for “Veterans’ Administration” in introductory provisions and in par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “3101(9)” for “1501(9)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/54"},"text":"Pub. L. 102–54","children":[],"tail":" substituted “(i) is” for “is (i)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" substituted “(i) a participant in a vocational rehabilitation program (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1501/9"},"text":"section 1501(9) of this title","children":[],"tail":"), and (ii)” for “found to be (i) in need of vocational rehabilitation under chapter 31 of this title and for whom an objective had been selected or (ii) pursuing a course of vocational rehabilitation training and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/151"},"text":"Pub. L. 96–151","children":[],"tail":" substituted provisions relating to travel and incidental expenses for provisions relating to necessary travel."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/581"},"text":"Pub. L. 94–581","children":[],"tail":" substituted “as the Administrator shall prescribe” for “as he shall prescribe” in provisions preceding par. (1), substituted “delay” for “they” in par. (1), and substituted “make possible such veteran’s entrance” for “make possible his entrance” in par. (2)(D)(ii)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc30a73ce-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc30a73cf-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237/tII/s202/b"},"text":"Pub. L. 101–237, title II, § 202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2067"},"text":"103 Stat. 2067","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/237/tII/s202/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply with respect to hospital care and medical services received on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc30a73d0-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1979 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/151"},"text":"Pub. L. 96–151","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-01-01"},"text":"Jan. 1, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/151/s206"},"text":"section 206 of Pub. L. 96–151","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s111"},"text":"section 111 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc30a73d1-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/581"},"text":"Pub. L. 94–581","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/581/s211"},"text":"section 211 of Pub. L. 94–581","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s111"},"text":"section 111 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc30a73d2-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1971-01-01"},"text":"Jan. 1, 1971","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/82/s501"},"text":"section 501 of Pub. L. 93–82","children":[],"tail":", set out as an Effective Date of 1973 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1701"},"text":"section 1701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc30a73d3-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reimbursement of Ambulance Cost for Care for Certain Rural Veterans","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/210/tI/s143"},"text":"Pub. L. 118–210, title I, § 143","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-02"},"text":"Jan. 2, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2747"},"text":"138 Stat. 2747","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/210/tI/s143"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Veterans Affairs shall pay, or reimburse a covered veteran for, the cost of transporting the veteran by ambulance, including air ambulance, from a covered location to a provider of the Department of Veterans Affairs, a non-Department provider, or the nearest hospital that can meet the needs of the veteran (including a hospital that compacts with the Indian Health Service) for covered care.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount Covered","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The maximum cumulative amount covered under this section for a covered veteran is $46,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sunset","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall cease to be effective on ","children":[{"tag":"date","attrib":{"date":"2026-09-30"},"text":"September 30, 2026","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘covered care’ means care for a veteran eligible for care provided by the Department of Veterans Affairs under title 38, United States Code, or any other law administered by the Secretary of Veterans Affairs, even if the care associated with the transport described in subsection (a) is not authorized by the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term ‘covered location’ means a location that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a State that is 100 miles or more from the nearest medical center of the Department of Veterans Affairs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in an area rated as a 10 or higher under the rural-urban commuting areas coding system of the Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term ‘covered veteran’ means a veteran who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a service-connected disability rated by the Secretary as between 0 and 30 percent disabling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not eligible for payments or reimbursements for beneficiary travel or other transportation under the laws administered by the Secretary of Veterans Affairs, other than under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not entitled to care or services under a non-Department of Veterans Affairs health-plan contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘health-plan contract’ has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1725"},"text":"section 1725 of title 38","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘service-connected’ has the meaning given that term in section 101 of such title.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
