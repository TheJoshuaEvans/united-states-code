{"tag":"section","attrib":{"id":"idc4157b07-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7624"},"text":null,"children":[{"tag":"num","attrib":{"value":"7624"},"text":"§ 7624.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Breach of agreement: liability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc4157b08-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7624/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A participant in the Tuition Reimbursement Program who fails to maintain employment as a Department employee permanently assigned to a Department health-care facility—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4157b09-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7624/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be provided reimbursement for tuition for the course or courses in which the participant is enrolled; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4157b0a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7624/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in lieu of any service obligation arising from participation in the program, shall be liable to the United States for the amount which has been paid or is payable to or on behalf of the participant under the agreement, reduced by the proportion that the number of days served for completion of the service obligation bears to the total number of days in the participant’s period of obligated service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4157b0b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7624/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any amount of damages which the United States is entitled to recover under this section shall be paid to the United States within the one-year period beginning on the date of the breach of the agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc4157b0c-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/322/tII/s216/b"},"text":"Pub. L. 100–322, title II, § 216(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/527"},"text":"102 Stat. 527","children":[],"tail":", § 4324; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/687/dB/tXV/s1503/a/4"},"text":"Pub. L. 100–687, div. B, title XV, § 1503(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4134"},"text":"102 Stat. 4134","children":[],"tail":"; renumbered § 7624, "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/3"},"text":"Pub. L. 102–83, § 4(a)(3)","children":[],"tail":", (4), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404"},"text":"105 Stat. 404","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc4157b0d-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc4157b0e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc4157b0f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4324"},"text":"section 4324 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" substituted “Department” for “Veterans’ Administration” in two places in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/687/s1503/a/4/A"},"text":"Pub. L. 100–687, § 1503(a)(4)(A)","children":[],"tail":", substituted “participation in the program” for “completion of a course or courses in a previous semester or quarter”, inserted “or is payable” after “has been paid”, and inserted before period at end “, reduced by the proportion that the number of days served for completion of the service obligation bears to the total number of days in the participant’s period of obligated service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/687/s1503/a/4/B"},"text":"Pub. L. 100–687, § 1503(a)(4)(B)","children":[],"tail":", struck out par. (1) which related to formula to apply to recover amount from participant who breaches agreement by failing to complete period of obligated service, and struck out par. (2) designation before “Any amount”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
