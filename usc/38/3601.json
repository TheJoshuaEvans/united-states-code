{"tag":"section","attrib":{"id":"idc38659d5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3601"},"text":null,"children":[{"tag":"num","attrib":{"value":"3601"},"text":"§ 3601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of emergency situation","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter, the term “emergency situation” means a situation that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc38659d6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3601/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President declares is an emergency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc38659d7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3601/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines is an emergency for purposes of the laws administered by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc38659d8-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/333/s2/a/2"},"text":"Pub. L. 117–333, § 2(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6122"},"text":"136 Stat. 6122","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
