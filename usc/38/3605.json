{"tag":"section","attrib":{"id":"idc3865a03-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3605"},"text":null,"children":[{"tag":"num","attrib":{"value":"3605"},"text":"§ 3605.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of educational assistance in cases of withdrawal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3865a04-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3605/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of any individual who withdraws from a program of education or training, other than a program by correspondence, in an educational institution under chapter 31, 34, or 35 of this title for a covered reason during the period of an emergency situation, the Secretary shall find mitigating circumstances for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3680/a/1/C/ii"},"text":"section 3680(a)(1)(C)(ii) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3865a05-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3605/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Reason","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “covered reason” means any reason related to an emergency situation, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3865a06-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3605/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" illness, quarantine, or social distancing requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3865a07-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3605/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issues associated with accessibility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3865a08-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3605/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access or availability of childcare;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3865a09-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3605/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing care for a family member or cohabitants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3865a0a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3605/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" change of location or residence due to the emergency situation or associated school closures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3865a0b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3605/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employment changes or financial hardship; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3865a0c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3605/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issues associated with changes in format or medium of instruction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3865a0d-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/333/s2/a/2"},"text":"Pub. L. 117–333, § 2(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6125"},"text":"136 Stat. 6125","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
