lows: “This subsection shall not apply to a course of flight training that commences on or after "},{"tag":"date","attrib":{"date":"1994-10-01"},"text":"October 1, 1994","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446/s1201/d/12"},"text":"Pub. L. 103–446, § 1201(d)(12)","children":[],"tail":", struck out “1663,” after “sections”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/568/s313/a/5/A"},"text":"Pub. L. 102–568, § 313(a)(5)(A)","children":[],"tail":", struck out “3473,” after “3471,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/568/s313/a/5/B"},"text":"Pub. L. 102–568, § 313(a)(5)(B)","children":[],"tail":", substituted “3680A(b)” for “3473(b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/568/s313/a/5/A"},"text":"Pub. L. 102–568, § 313(a)(5)(A)","children":[],"tail":", struck out “3473,” after “3471,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1641"},"text":"section 1641 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “3470, 3471, 3473, 3474, 3476, 3483, 3485, and 3491(a)(1)” for “1670, 1671, 1673, 1674, 1676, 1683, 1685, and 1691(a)(1)” and “3687” for “1787”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/16/s2/b/2"},"text":"Pub. L. 102–16, § 2(b)(2)","children":[],"tail":", struck out “1663,” before “1670,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “3471” for “1671”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “3473(b)” for “1673(b)” in par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/16/s7/a/2"},"text":"Pub. L. 102–16, § 7(a)(2)","children":[],"tail":", added subsec. (b). Former subsec. (b) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “3470, 3471, 3473, 3474, 3476, 3483, and 3491(a)” for “1670, 1671, 1673, 1674, 1676, 1683, and 1691(a)” and “3687” for “1787”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/16/s7/a/1"},"text":"Pub. L. 102–16, § 7(a)(1)","children":[],"tail":", redesignated subsec. (b) as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237/s423/b/1/A"},"text":"Pub. L. 101–237, § 423(b)(1)(A)","children":[],"tail":", substituted “Secretary” for “Administrator” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237/s423/a/5/B"},"text":"Pub. L. 101–237, § 423(a)(5)(B)","children":[],"tail":", substituted “employment during and since the period of such veteran’s active military service)” for “employment)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/689/s106/b/1"},"text":"Pub. L. 100–689, § 106(b)(1)","children":[],"ta