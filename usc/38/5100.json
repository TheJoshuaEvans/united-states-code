{"tag":"section","attrib":{"id":"idc3cba021-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5100"},"text":null,"children":[{"tag":"num","attrib":{"value":"5100"},"text":"§ 5100.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3cba022-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5100/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “claimant” means any individual applying for, or submitting a claim for, any benefit under the laws administered by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3cba023-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5100/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “notice” means a communication issued through means (including electronic means) prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3cba024-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/168/tVIII/s807/a/1"},"text":"Pub. L. 117–168, title VIII, § 807(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-10"},"text":"Aug. 10, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1805"},"text":"136 Stat. 1805","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3cba025-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3cba026-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc3cba027-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5100, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/475/s2"},"text":"Pub. L. 106–475, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2096"},"text":"114 Stat. 2096","children":[],"tail":", defined “claimant”, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/117/168/tVIII/s807/a/1"},"text":"Pub. L. 117–168, title VIII, § 807(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-10"},"text":"Aug. 10, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1805"},"text":"136 Stat. 1805","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3cba028-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3cba029-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/168/tVIII/s807/b"},"text":"Pub. L. 117–168, title VIII, § 807(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-10"},"text":"Aug. 10, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1806"},"text":"136 Stat. 1806","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/168/tVIII/s807/b"},"text":"“None of the amendments made by this section [enacting this section, amending sections 5104, 5104B, 5112, 7104, 7105, 7105A, and 7266 of this title, and repealing former ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5100"},"text":"section 5100 of this title","children":[],"tail":"] shall be construed to apply section 5104(a) of such title [meaning title 38, United States Code] to decisions of the Board of Veterans’ Appeals under chapter 71 of such title.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
