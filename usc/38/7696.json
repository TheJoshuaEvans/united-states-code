{"tag":"section","attrib":{"id":"idc417ec2c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7696"},"text":null,"children":[{"tag":"num","attrib":{"value":"7696"},"text":"§ 7696.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of obligated service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc417ec2d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7696/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to any requirements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5379/c"},"text":"section 5379(c) of title 5","children":[],"tail":", a participant in the Specialty Education Loan Repayment Program must agree, in writing and before the Secretary may make any payment to or for the participant, to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc417ec2e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7696/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain a license to practice medicine in a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc417ec2f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7696/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" successfully complete post-graduate training leading to eligibility for board certification in a specialty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc417ec30-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7696/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as a full-time clinical practice employee of the Veterans Health Administration for 12 months for every $40,000 in such benefits that the employee receives, but in no case for fewer than 24 months; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc417ec31-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7696/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in subsection (b), to begin such service as a full-time practice employee by not later than 60 days after completing a residency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc417ec32-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7696/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fellowship","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of a participant who receives an accredited fellowship in a medical specialty other than a medical specialty described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7692"},"text":"section 7692 of this title","children":[],"tail":", the Secretary, on written request of the participant, may delay the term of obligated service under subsection (a) for the participant until after the participant completes the fellowship, but in no case later than 60 days after completion of such fellowship."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc417ec33-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7696/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc417ec34-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7696/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee who does not complete a period of obligated service under this section shall owe the Federal Government an amount determined in accordance with the following formula: ","children":[{"tag":"i","attrib":{},"text":"A = B ×","children":[],"tail":null},{"tag":"i","attrib":{},"text":" ((T − S) ÷","children":[],"tail":null},{"tag":"i","attrib":{},"text":" T)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc417ec35-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7696/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the formula in paragraph (1):","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc417ec36-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7696/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “","children":[{"tag":"i","attrib":{},"text":"A","children":[],"tail":"” is the amount the employee owes the Federal Government."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc417ec37-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7696/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “","children":[{"tag":"i","attrib":{},"text":"B","children":[],"tail":"” is the sum of all payments to or for the participant under the Specialty Education Loan Repayment Program."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc417ec38-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7696/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “","children":[{"tag":"i","attrib":{},"text":"T","children":[],"tail":"” is the number of months in the period of obligated service of the employee."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc417ec39-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7696/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “","children":[{"tag":"i","attrib":{},"text":"S","children":[],"tail":"” is the number of whole months of such period of obligated service served by the employee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc417ec3a-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/182/tIII/s303/a"},"text":"Pub. L. 115–182, title III, § 303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-06"},"text":"June 6, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1465"},"text":"132 Stat. 1465","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/61/s6/8"},"text":"Pub. L. 116–61, § 6(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-09-30"},"text":"Sept. 30, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1117"},"text":"133 Stat. 1117","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc417ec3b-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc417ec3c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note",