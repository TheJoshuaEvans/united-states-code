{"tag":"section","attrib":{"id":"idc37ce451-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3534"},"text":null,"children":[{"tag":"num","attrib":{"value":"3534"},"text":"§ 3534.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Apprenticeship or other on-job training; correspondence courses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc37ce452-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3534/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any eligible person shall be entitled to pursue, in a State, a program of apprenticeship or other on-job training and be paid a training assistance allowance as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3687"},"text":"section 3687 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc37ce453-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3534/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any eligible spouse or surviving spouse shall be entitled to pursue a program of education exclusively by correspondence and be paid an educational assistance allowance as provided in section 3686 (other than subsection (a)(2)) of this title and the period of such spouse’s entitlement shall be charged with one month for each $788 which is paid to the spouse as an educational assistance allowance for such course.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc37ce454-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/540/tIII/s313"},"text":"Pub. L. 92–540, title III, § 313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-24"},"text":"Oct. 24, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/8