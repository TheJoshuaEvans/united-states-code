{"tag":"section","attrib":{"id":"idc3deb316-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5506"},"text":null,"children":[{"tag":"num","attrib":{"value":"5506"},"text":"§ 5506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of “fiduciary”","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter and chapter 61 of this title, the term “fiduciary” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3deb317-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5506/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person who is a guardian, curator, conservator, committee, or person legally vested with the responsibility or care of a claimant (or a claimant’s estate) or of a beneficiary (or a beneficiary’s estate); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3deb318-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5506/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other person having been appointed in a representative capacity to receive money paid under any of the laws administered by the Secretary for the use and benefit of a minor, incompetent, or other beneficiary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3deb319-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/454/tV/s501/a/1"},"text":"Pub. L. 108–454, title V, § 501(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-10"},"text":"Dec. 10, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3617"},"text":"118 Stat. 3617","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3deb31a-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3deb31b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3deb31c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the seventh month beginning after ","children":[{"tag":"date","attrib":{"date":"2004-12-10"},"text":"Dec. 10, 2004","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/454/s507/a"},"text":"section 507(a) of Pub. L. 108–454","children":[],"tail":", set out as an Effective Date of 2004 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5312"},"text":"section 5312 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
