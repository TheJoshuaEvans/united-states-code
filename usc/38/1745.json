ion.”","children":[],"tail":"\n Final rule implementing "},{"tag":"ref","attrib":{"href":"/us/pl/115/182/s103"},"text":"section 103 of Pub. L. 115–182","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2020-01-13"},"text":"Jan. 13, 2020","children":[],"tail":", see 84 F.R. 67868."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc30f2e42-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/154"},"text":"Pub. L. 112–154","children":[],"tail":" applicable to care provided on or after the date that is 180 days after "},{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":", with certain exceptions, see "},{"tag":"ref","attrib":{"href":"/us/pl/112/154/s105/c"},"text":"section 105(c) of Pub. L. 112–154","children":[],"tail":", set out as a note under 1720 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc30f2e43-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section and amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461/s211/a/2"},"text":"section 211(a)(2) of Pub. L. 109–461","children":[],"tail":" effective 90 days after "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/461/s211/a/5"},"text":"section 211(a)(5) of Pub. L. 109–461","children":[],"tail":", set out as an Effective Date of 2006 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1710"},"text":"section 1710 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc30f2e44-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Initial Rate","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/159/s2/b"},"text":"Pub. L. 115–159, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-27"},"text":"Mar. 27, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1245"},"text":"132 Stat. 1245","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/159/s2/b"},"text":"“Before the Secretary of Veterans Affairs establishes a payment rate under subsection (d)(2)(A) of section 1745 of such title [meaning title 38, United States Code], as added by subsection (a), the Secretary shall pay to a State home that has entered into an agreement with the Secretary for medical supervision model adult day health care (as defined in subsection (d)(4) of such section) an amount equal to 65 percent of the rate the Secretary would pay under subsection (a)(2) of such section to the State home for nursing home care provided to the veteran.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
