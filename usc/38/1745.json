{"tag":"section","attrib":{"id":"idc30f2e17-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1745"},"text":null,"children":[{"tag":"num","attrib":{"value":"1745"},"text":"§ 1745.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nursing home care, adult day health care, and medications for veterans with service-connected disabilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc30f2e18-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1745/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc30f2e19-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1745/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall enter into a contract (or an agreement) with each State home for payment by the Secretary for nursing home care provided in the home, in any case in which such care is provided to any veteran as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc30f2e1a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1745/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any veteran in need of such care for a service-connected disability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc30f2e1b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1745/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any veteran who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc30f2e1c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1745/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a service-connected disability rated at 70 percent or more; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc30f2e1d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1745/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in need of such care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30f2e1e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1745/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payment under each contract (or agreement) between the Secretary and a State home under paragraph (1) shall be based on a methodology, developed by the Secretary in consultation with the State home, to adequately reimburse the State home for the care provided by the State home under the contract (or agreement).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30f2e1f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1745/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payment by the Secretary under paragraph (1) to a State home for nursing home care provided to a veteran described in that paragraph constitutes payment in full to the State home for such care furnished to that veteran.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30f2e20-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1745/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc30f2e21-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1745/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An agreement under this section may be authorized by the Secretary or any Department official authorized by the Secretary, and any such action is not an award for purposes of such laws that would otherwise require the use of competitive procedures for the furnishing of hospital care, medical services, and extended care services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc30f2e22-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1745/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc30f2e23-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1745/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in the agreement itself, in clause (ii), and unless otherwise provided in this section or regulations prescribed pursuant to this section, a State home that enters into an agreement under this section is not subject to, in the carrying out of the agreement, any provision of law to which providers of services and suppliers under the Medicare program under title XVIII of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395"},"text":"42 U.S.C. 1395","children":[],"tail":" et seq.) are not subject."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc30f2e24-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1745/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A State home that enters into an agreement under this section is subject to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc30f2e25-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1745/a/4/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all provisions of law regarding integrity, ethics, or fraud, or that subject a person to civil or criminal penalties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc30f2e26-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1745/a/4/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all provisions of law that protect against employment discrimination or that otherwise ensure equal employment opportunities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc30f2e27-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1745/a/4/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all provisions in this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc30f2e28-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1745/a/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding subparagraph (B)(ii)(I), a State home that enters into an agreement under this section may not be treated as a Federal contractor or subcontractor for purposes of chapter 67 of title 41 (known as the “McNamara-O’Hara Service Contract Act of 1965”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc30f2e29-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1745/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall furnish such drugs and medicines as may be ordered on prescription of a duly licensed physician as specific therapy in the treatment of illness or injury to any veteran as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc30f2e2a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1745/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any veteran who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc30f2e2b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1745/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not being provided nursing home care for which payment is payable under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc30f2e2c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1745/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in need of such drugs and medicines for a service-connected disability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30f2e2d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1745/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any veteran who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc30f2e2e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1745/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a service-connected disability rated at 50 percent or more;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc30f2e2f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1745/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not being provided nursing home care for which payment is payable under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc30f2e30-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1745/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in need of such drugs and medicines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30f2e31-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1745/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any veteran who has been determined by the Secretary to be catastrophically disabled, as defined in section 17.36(e) of title 38, Code of Federal Regulations, or successor regulations, and on whose behalf the Secretary is paying a per diem for nursing home or domiciliary care in a State home under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc30f2e32-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1745/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any State home that requests payment or reimbursement for services provided to a veteran under this section shall provide to the Secretary such information as the Secretary considers necessary to identify each individual veteran eligible for payment under such section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc30f2e33-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1745/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc30f2e34-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1745/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall enter into an agreement with each State home for payment by the Secretary for medical supervision model adult day health care provided to a veteran described in subsection (a)(1) on whose behalf the State home is not in receipt of payment for nursing home care from the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30f2e35-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1745/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc30f2e36-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1745/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payment under each agreement between the Secretary and a State home under paragraph (1) for each veteran who receives medical supervision model adult day health care under such agreement shall be made at a rate established through regulations prescribed by the Secretary to adequately reimburse the State home for the care provided by the State home, including necessary transportation expenses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc30f2e37-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1745/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall consult with the State homes in prescribing regulations under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc30f2e38-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1745/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rate established through regulations under subparagraph (A) shall not take effect until the date that is 30 days after the date on which those regulations are published in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30f2e39-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1745/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payment by the Secretary under paragraph (1) to a State home for medical supervision model adult day health care provided to a veteran described in that paragraph constitutes payment in full to the State home for such care furnished to that veteran.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30f2e3a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1745/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this subsection, the term “medical supervision model adult day health care” means adult day health care that includes the coordination of physician services, dental services, nursing services, the administration of drugs, and such other requirements as determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc30f2e3b-47c4-11f1-bf59-9680b1269b87"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461/tII/s211/a/1"},"text":"Pub. L. 109–461, title II, § 211(a)(1)","children":[],"tail":", (2), (b)(1), "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3418"},"text":"120 Stat. 3418","children":[],"tail":", 3419; "},{"tag":"ref","attrib":{"href":"/us/pl/112/154/tI/s105/a"},"text":"Pub. L. 112–154, title I, § 105(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1170"},"text":"126 Stat. 1170","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/159/s2/a"},"text":"Pub. L. 115–159, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-27"},"text":"Mar. 27, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1244"},"text":"132 Stat. 1244","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/182/tI/s103/a"},"text":"Pub. L. 115–182, title I, § 103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-06"},"text":"June 6, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1408"},"text":"132 Stat. 1408","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/251/tII/s211/a/9"},"text":"Pub. L. 115–251, title II, § 211(a)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-29"},"text":"Sept. 29, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3175"},"text":"132 Stat. 3175","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dU/tI/s162/b"},"text":"Pub. L. 117–328, div. U, title I, § 162(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5430"},"text":"136 Stat. 5430","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc30f2e3c-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc30f2e3d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc30f2e3e-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (a)(4)(B)(i), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Title XVIII of the Act is classified generally to subchapter XVIII (§ 1395 et seq.) of chapter 7 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc30f2e3f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/159/s2/a/2"},"text":"Pub. L. 115–159, § 2(a)(2)","children":[],"tail":", inserted “, adult day health care,” after “home care” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/182/s103/a/1"},"text":"Pub. L. 115–182, § 103(a)(1)","children":[],"tail":", substituted “(or an agreement)” for “(or agreement under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1720/c/1"},"text":"section 1720(c)(1) of this title","children":[],"tail":")” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/182/s103/a/2"},"text":"Pub. L. 115–182, § 103(a)(2)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4)(B)(ii)(III). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/251"},"text":"Pub. L. 115–251","children":[],"tail":" substituted “this subchapter” for “subchapter V of chapter 17 of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/159/s2/a/1"},"text":"Pub. L. 115–159, § 2(a)(1)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/154/s105/a/1"},"text":"Pub. L. 112–154, § 105(a)(1)","children":[],"tail":", substituted in introductory provisions “The Secretary shall enter into a contract (or agreement under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1720/c/1"},"text":"section 1720(c)(1) of this title","children":[],"tail":") with each State home for payment by the Secretary for nursing home care provided in the home” for “The Secretary shall pay each State home for nursing home care at the rate determined under paragraph (2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/154/s105/a/2"},"text":"Pub. L. 112–154, § 105(a)(2)","children":[],"tail":", added par. (2) and struck out former par. (2) which read as follows: “The rate determined under this paragraph with respect to a State home is the lesser of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the applicable or prevailing rate payable in the geographic area in which the State home is located, as determined by the Secretary, for nursing home care furnished in a non-Department nursing home (as that term is defined in ","children":[{"tag":"ref","at