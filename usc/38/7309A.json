{"tag":"section","attrib":{"id":"idc3f6818a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7309A"},"text":null,"children":[{"tag":"num","attrib":{"value":"7309A"},"text":"§ 7309A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Patient Advocacy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3f6818b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7309A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established in the Department within the Office of the Under Secretary for Health an office to be known as the “Office of Patient Advocacy” (in this section referred to as the “Office”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3f6818c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7309A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Head","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3f6818d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7309A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Office of Patient Advocacy shall be the head of the Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f6818e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7309A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Office of Patient Advocacy shall be appointed by the Under Secretary for Health from among individuals qualified to perform the duties of the position and shall report directly to the Under Secretary for Health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3f6818f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7309A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Function","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3f68190-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7309A/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The function of the Office is to carry out the Patient Advocacy Program of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f68191-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7309A/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out the Patient Advocacy Program of the Department, the Director shall ensure that patient advocates of the Department—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3f68192-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7309A/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advocate on behalf of veterans with respect to health care received and sought by veterans under the laws administered by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3f68193-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7309A/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out the responsibilities specified in subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3f68194-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7309A/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive training in patient advocacy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f68195-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7309A/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Beginning not later than 18 months after the date of the enactment of this paragraph, the Director shall establish an information technology system that will allow a veteran (or the designated representative of a veteran) to electronically—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3f68196-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7309A/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" file a complaint that will be received by the appropriate patient advocate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3f68197-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7309A/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at any time view the status of the complaint, including interim and final actions that have been taken to address the complaint.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3f68198-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7309A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Patient Advocacy Responsibilities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The responsibilities of each patient advocate at a medical facility of the Department are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3f68199-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7309A/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To resolve complaints by veterans with respect to health care furnished under the laws administered by the Secretary that cannot be resolved at the point of service or at a higher level easily accessible to the veteran.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f6819a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7309A/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To present at various meetings and to various committees the issues experienced by veterans in receiving such health care at such medical facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f6819b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7309A/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To express to veterans their rights and responsibilities as patients in receiving such health care.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f6819c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7309A/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To manage the Patient Advocate Tracking System of the Department at such medical facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f6819d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7309A/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To compile data at such medical facility of complaints made by veterans with respect to the receipt of such health care at such medical facility and the satisfaction of veterans with such health care at such medical facility to determine whether there are trends in such data.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f6819e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7309A/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To ensure that a process is in place for the distribution of the data compiled under paragraph (5) to appropriate leaders, committees, services, and staff of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f6819f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7309A/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To identify, not less frequently than quarterly, opportunities for improvements in the furnishing of such health care to veterans at such medical facility based on complaints by veterans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f681a0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7309A/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To ensure that any significant complaint by a veteran with respect to such health care is brought to the attention of appropriate staff of the Department to trigger an assessment of whether there needs to be a further analysis of the problem at the facility-wide level.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f681a1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7309A/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To support any patient advocacy programs carried out by the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f681a2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7309A/d/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To ensure that all appeals and final decisions with respect to the receipt of such health care are entered into the Patient Advocate Tracking System of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f681a3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7309A/d/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To understand all laws, directives, and other rules with respect to the rights and responsibilities of veterans in receiving such health care, including the appeals processes available to veterans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f681a4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7309A/d/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To ensure that veterans receiving mental health care, or the surrogate decision-makers for such veterans, are aware of the rights of veterans to seek representation from systems established under section 103 of the Protection and Advocacy for Mentally Ill Individuals Act of 1986 ","children":[{"tag":"ref","attrib":{"idref":"fn002104"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002104"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10803"},"text":"42 U.S.C. 10803","children":[],"tail":") to protect and advocate the rights of individuals with mental illness and to investigate incidents of abuse and neglect of such individuals."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f681a5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7309A/d/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To fulfill requirements established by the Secretary with respect to the inspection of controlled substances.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f681a6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7309A/d/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To document potentially threatening behavior and report such behavior to appropriate authorities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3f681a7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7309A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In providing training to patient advocates under subsection (c)(2)(C), the Director shall ensure that such training is consistent throughout the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3f681a8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7309A/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Controlled Substance Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “controlled substance” has the meaning given that term in section 102 of the Controlled Substances Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s802"},"text":"21 U.S.C. 802","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3f681a9-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/198/tIX/s924/a"},"text":"Pub. L. 114–198, title IX, § 924(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-22"},"text":"July 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/767"},"text":"130 Stat. 767","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/175/s2"},"text":"Pub. L. 117–175, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-09-16"},"text":"Sept. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2107"},"text":"136 Stat. 2107","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3f681aa-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3f681ab-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc3f681ac-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this paragraph, referred to in subsec. (c)(3), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/175"},"text":"Pub. L. 117–175","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2022-09-16"},"text":"Sept. 16, 2022","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Protection and Advocacy for Mentally Ill Individuals Act of 1986, referred to in subsec. (d)(12), was renamed the Protection and Advocacy for Individuals with Mental Illness Act by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310/dB/tXXXII/s3206/a"},"text":"Pub. L. 106–310, div. B, title XXXII, § 3206(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1193"},"text":"114 Stat. 1193","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3f681ad-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/175"},"text":"Pub. L. 117–175","children":[],"tail":" added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3f681ae-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3f681af-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Date Fully Operational","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/198/tIX/s924/c"},"text":"Pub. L. 114–198, title IX, § 924(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-22"},"text":"July 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/769"},"text":"130 Stat. 769","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/198/tIX/s924/c"},"text":"“The Secretary of Veterans Affairs shall ensure that the Office of Patient Advocacy established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7309A"},"text":"section 7309A of title 38","children":[],"tail":", United States Code, as added by subsection (a), is fully operational not later than the date that is one year after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2016-07-22"},"text":"July 22, 2016","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
