{"tag":"section","attrib":{"id":"idc4157ad7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7618"},"text":null,"children":[{"tag":"num","attrib":{"value":"7618"},"text":"§ 7618.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional program requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc4157ad8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7618/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Modification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any provision of this subchapter, the Secretary shall carry out this subchapter after the date of the enactment of this section by modifying the Scholarship Program in such a manner that the program and hiring processes are designed to fully employ Scholarship Program graduates as soon as possible, if not immediately, upon graduation and completion of necessary certifications, and to actively assist and monitor graduates to ensure certifications are obtained in a minimal amount of time following graduation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4157ad9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7618/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Clinical Tours","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall require participants in the Scholarship Program to perform clinical tours in assignments or locations determined by the Secretary while the participants are enrolled in the course of education or training for which the scholarship is provided.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4157ada-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7618/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Mentors","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall ensure that at the commencement of the period of obligated service of a participant in the Scholarship Program, the participant is assigned to a mentor who is employed in the same facility where the participant performs such service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc4157adb-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163/tVI/s603/c/2"},"text":"Pub. L. 111–163, title VI, § 603(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-05-05"},"text":"May 5, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1173"},"text":"124 Stat. 1173","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc4157adc-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc4157add-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc4157ade-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsec. (a), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163"},"text":"Pub. L. 111–163","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2010-05-05"},"text":"May 5, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc4157adf-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7618 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7619"},"text":"section 7619 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
