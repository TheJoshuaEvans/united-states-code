{"tag":"section","attrib":{"id":"idc289ab80-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s544"},"text":null,"children":[{"tag":"num","attrib":{"value":"544"},"text":"§ 544.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Committee on Minority Veterans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc289ab81-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s544/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc289ab82-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s544/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall establish an advisory committee to be known as the Advisory Committee on Minority Veterans (hereinafter in this section referred to as “the Committee”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc289ab83-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s544/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc289ab84-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s544/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Committee shall consist of members appointed by the Secretary from the general public, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc289ab85-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s544/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of veterans who are minority group members;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc289ab86-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s544/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals who are recognized authorities in fields pertinent to the needs of veterans who are minority group members;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc289ab87-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s544/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" veterans who are minority group members and who have experience in a military theater of operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc289ab88-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s544/a/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" veterans who are minority group members and who do not have such experience; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc289ab89-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s544/a/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" women veterans who are minority group members and are recently separated from service in the Armed Forces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc289ab8a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s544/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Committee shall include, as ex officio members, the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc289ab8b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s544/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Labor (or a representative of the Secretary of Labor designated by the Secretary after consultation with the Assistant Secretary of Labor for Veterans’ Employment).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc289ab8c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s544/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense (or a representative of the Secretary of Defense designated by the Secretary of Defense).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc289ab8d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s544/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Interior (or a representative of the Secretary of the Interior designated by the Secretary of the Interior).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc289ab8e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s544/a/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Commerce (or a representative of the Secretary of Commerce designated by the Secretary of Commerce).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc289ab8f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s544/a/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Health and Human Services (or a representative of the Secretary of Health and Human Services designated by the Secretary of Health and Human Services).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc289ab90-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s544/a/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary for Health and the Under Secretary for Benefits, or their designees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc289ab91-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s544/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may invite representatives of other departments and agencies of the United States to participate in the meetings and other activities of the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc289ab92-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s544/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall determine the number, terms of service, and pay and allowances of members of the Committee appointed by the Secretary, except that a term of service of any such member may not exceed three years. The Secretary may reappoint any such member for additional terms of service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc289ab93-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s544/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee shall meet as often as the Secretary considers necessary or appropriate, but not less often than twice each fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc289ab94-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s544/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall, on a regular basis, consult with and seek the advice of the Committee with respect to the administration of benefits by the Department for veterans who are minority group members, reports and studies pertaining to such veterans and the needs of such veterans with respect to compensation, health care, rehabilitation, outreach, and other benefits and programs administered by the Department, including the Center for Minority Veterans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc289ab95-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s544/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc289ab96-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s544/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than July 1 of every other year, the Committee shall submit to the Secretary a report on the programs and activities of the Department that pertain to veterans who are minority group members. Each such report shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc289ab97-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s544/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the needs of veterans who are minority group members with respect to compensation, health care, rehabilitation, outreach, and other benefits and programs administered by the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc289ab98-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s544/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of the programs and activities of the Department designed to meet such needs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc289ab99-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s544/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such recommendations (including recommendations for administrative and legislative action) as the Committee considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc289ab9a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s544/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall, within 60 days after receiving each report under paragraph (1), submit to Congress a copy of the report, together with any comments concerning the report that the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc289ab9b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s544/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee may also submit to the Secretary such other reports and recommendations as the Committee considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc289ab9c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s544/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall submit with each annual report submitted to the Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s529"},"text":"section 529 of this title","children":[],"tail":" a summary of all reports and recommendations of the Committee submitted to the Secretary since the previous annual report of the Secretary submitted pursuant to such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc289ab9d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s544/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section, the term “minority group member” means an individual who is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc289ab9e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s544/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Asian American;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc289ab9f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s544/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Black;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc289aba0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s544/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hispanic;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc289aba1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s544/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Native American (including American Indian, Alaskan Native, and Native Hawaiian); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc289aba2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s544/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pacific-Islander American.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc289aba3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s544/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee shall cease to exist ","children":[{"tag":"date","attrib":{"date":"2026-09-30"},"text":"September 30, 2026","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc289aba4-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446/tV/s510/a"},"text":"Pub. L. 103–446, title V, § 510(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4668"},"text":"108 Stat. 4668","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/275/tV/s501/e/2"},"text":"Pub. L. 104–275, title V, § 501(e)(2)","children":[],"tail":", (f), "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3341"},"text":"110 Stat. 3341","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/117/tVIII/s803"},"text":"Pub. L. 106–117, title VIII, § 803","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-30"},"text":"Nov. 30, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1586"},"text":"113 Stat. 1586","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/183/tVII/s703"},"text":"Pub. L. 108–183, title VII, § 703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-16"},"text":"Dec. 16, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2671"},"text":"117 Stat. 2671","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/389/tVIII/s808"},"text":"Pub. L. 110–389, title VIII, § 808","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4189"},"text":"122 Stat. 4189","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/163/tII/s204/b"},"text":"Pub. L. 111–163, title II, § 204(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-05-05"},"text":"May 5, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1144"},"text":"124 Stat. 1144","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/175/tIV/s404"},"text":"Pub. L. 113–175, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-09-26"},"text":"Sept. 26, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1905"},"text":"128 Stat. 1905","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/58/tIV/s406"},"text":"Pub. L. 114–58, title IV, § 406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-09-30"},"text":"Sept. 30, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/535"},"text":"129 Stat. 535","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/228/tIV/s406"},"text":"Pub. L. 114–228, title IV, § 406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-09-29"},"text":"Sept. 29, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/940"},"text":"130 Stat. 940","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/62/tIV/s406"},"text":"Pub. L. 115–62, title IV, § 406","children":[],"tail":", "},{"tag":"date","attrib":{"date