{"tag":"section","attrib":{"id":"idc3119f7d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1781"},"text":null,"children":[{"tag":"num","attrib":{"value":"1781"},"text":"§ 1781.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical care for survivors and dependents of certain veterans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3119f7e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1781/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary is authorized to provide medical care, in accordance with the provisions of subsection (b) of this section, for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3119f7f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1781/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the spouse or child of a veteran who has a total disability, permanent in nature, resulting from a service-connected disability,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3119f80-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1781/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the surviving spouse or child of a veteran who (A) died as a result of a service-connected disability, or (B) at the time of death had a total disability permanent in nature, resulting from a service-connected disability,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3119f81-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1781/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the surviving spouse or child of a person who died in the active military, naval, air, or space service in the line of duty and not due to such person’s own misconduct, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3119f82-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1781/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual designated as a primary provider of personal care services under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1720G/a/7/A"},"text":"section 1720G(a)(7)(A) of this title","children":[],"tail":" who is not entitled to care or services under a health-plan contract (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1725/h"},"text":"section 1725(h) of this title","children":[],"tail":"),"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"who are not otherwise eligible for medical care under chapter 55 of title 10 (CHAMPUS).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3119f83-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1781/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In order to accomplish the purposes of subsection (a) of this section, the Secretary shall provide for medical care in the same or similar manner and subject to the same or similar limitations as medical care is furnished to certain dependents and survivors of active duty and retired members of the Armed Forces under chapter 55 of title 10 (CHAMPUS), by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3119f84-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1781/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entering into an agreement with the Secretary of Defense under which that Secretary shall include coverage for such medical care under the contract, or contracts, that Secretary enters into to carry out such chapter 55, and under which the Secretary of Veterans Affairs shall fully reimburse the Secretary of Defense for all costs and expenditures made for the purposes of affording the medical care authorized pursuant to this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3119f85-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1781/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contracting in accordance with such regulations as the Secretary shall prescribe for such insurance, medical service, or health plans as the Secretary deems appropriate.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In cases in which Department medical facilities are equipped to provide the care and treatment, the Secretary is also authorized to carry out such purposes through the use of such facilities not being utilized for the care of eligible veterans. A dependent or survivor receiving care under the preceding sentence shall be eligible for the same medical services as a veteran, including services under sections 1782 and 1783 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3119f86-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1781/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of this section, a child between the ages of eighteen and twenty-three (1) who is eligible for benefits under subsection (a) of this section, (2) who is pursuing a full-time course of instruction at an educational institution approved under chapter 36 of this title, and (3) who, while pursuing such course of instruction, incurs a disabling illness or injury (including a disabling illness or injury incurred between terms, semesters, or quarters or during a vacation or holiday period) which is not the result of such child’s own willful misconduct and which results in such child’s inability to continue or resume such child’s chosen program of education at an approved educational institution shall remain eligible for benefits under this section until the end of the six-month period beginning on the date the disability is removed, the end of the two-year period beginning on the date of the onset of the disability, or the twenty-third birthday of the child, whichever occurs first.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3119f87-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1781/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3119f88-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1781/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3119f89-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1781/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual otherwise eligible for medical care under this section who is also entitled to hospital insurance benefits under part A of the medicare program is eligible for medical care under this section only if the individual is also enrolled in the supplementary medical insurance program under part B of the medicare program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3119f8a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1781/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The limitation in subparagraph (A) does not apply to an individual who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc3119f8b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1781/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has attained 65 years of age as of ","children":[{"tag":"date","attrib":{"date":"2001-06-05"},"text":"June 5, 2001","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3119f8c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1781/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not enrolled in the supplementary medical insurance program under part B of the medicare program as of that date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3119f8d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1781/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to paragraph (3), if an individual described in paragraph (1) receives medical care for which payment may be made under both this section and the medicare program, the amount payable for such medical care under this section shall be the amount by which (A) the costs for such medical care exceed (B) the sum of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc3119f8e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1781/d/2/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount payable for such medical care under the medicare program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3119f8f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1781/d/2/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount paid or payable for such medical care by third party payers other than the medicare program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3119f90-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1781/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount payable under this subsection for medical care may not exceed the total amount that would be paid under subsection (b) if payment for such medical care were made solely under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3119f91-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1781/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3119f92-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1781/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “medicare program” means the program of health insurance administered by the Secretary of Health and Human Services under title XVIII of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395"},"text":"42 U.S.C. 1395","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3119f93-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1781/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “third party” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1729/i/3"},"text":"section 1729(i)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3119f94-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1781/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payment by the Secretary under this section on behalf of a covered beneficiary for medical care shall constitute payment in full and extinguish any liability on the part of the beneficiary for that care.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3119f95-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/82/tI/s103/b"},"text":"Pub. L. 93–82, title I, § 103(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-08-02"},"text":"Aug. 2, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/181"},"text":"87 Stat. 181","children":[],"tail":", § 613; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/581/tI/s104"},"text":"Pub. L. 94–581, title I, § 104","children":[],"tail":", title II, § 210(a)(4), "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2845"},"text":"90 Stat. 2845","children":[],"tail":", 2862; "},{"tag":"ref","attrib":{"href":"/us/pl/96/151/tII/s205/a"},"text":"Pub. L. 96–151, title II, § 205(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-12-20"},"text":"Dec. 20, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1094"},"text":"93 Stat. 1094","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/72/tI/s105"},"text":"Pub. L. 97–72, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-11-03"},"text":"Nov. 3, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1050"},"text":"95 Stat. 1050","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/251/s5/a"},"text":"Pub. L. 97–251, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-08"},"text":"Sept. 8, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/716"},"text":"96 Stat. 716","children":[],"tail":"; renumbered § 1713 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":", §§ 4(a)(3), (4), (b)(1), (2)(B), (E), 5(a), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404-406"},"text":"105 Stat. 404–406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tVII/s704/b/2"},"text":"Pub. L. 102–190, div. A, title VII, § 704(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1402"},"text":"105 Stat. 1402","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/14/s3"},"text":"Pub. L. 107–14, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-06-05"},"text":"June 5, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/25"},"text":"115 Stat. 25","children":[],"tail":"; renumbered § 1781 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/135/tII/s208/c"},"text":"Pub. L. 107–135, title II, § 208(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-23"},"text":"Jan. 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2463"},"text":"115 Stat. 2463","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/330/tIII/s308/g/8"},"text":"Pub. L. 107–330, title III, § 308(g)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-06"},"text":"Dec. 6, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2829"},"text":"116 Stat. 2829","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/163/tI/s102"},"text":"Pub. L. 111–163, title I, § 102","children":[],"tail":", title V, § 503, "},{"tag":"date","attrib":{"date":"2010-05-05"},"text":"May 5, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1139"},"text":"124 Stat. 1139","children":[],"tail":", 1157; "},{"tag":"ref","attrib":{"href":"/us/pl/114/58/tVI/s601/7"},"text":"Pub. L. 114–58, title VI, § 601(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-09-30"},"text":"Sept. 30, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/538"},"text":"129 Stat. 538","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s926/a/30"},"text":"Pub. L. 116–283, div. A, title IX, § 926(a)(30)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3830"},"text":"134 Stat. 3830","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dU/tI/s142/c/4"},"text":"Pub. L. 117–328, div. U, title I, § 142(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5424"},"text":"136 Stat. 5424","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3119f96-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3119f97-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc3119f98-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (d)(4)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Title XVIII of the Act is classified generally to subchapter XVIII (§ 1395 et seq.) of chapter 7 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc3119f99-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1781 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3681"},"text":"section 3681 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3119f9a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" substituted “section 1725(h)” for “section 1725(f)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “air, or space service” for “or air service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/58"},"text":"Pub. L. 114–58","children":[],"tail":" substituted “title),” for “title);”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163/s102"},"text":"Pub. L. 111–163, § 102","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163/s503"},"text":"Pub. L. 111–163, § 503","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/135/s208/c/1"},"text":"Pub. L. 107–135, § 208(c)(1)","children":[],"tail":", (2), renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1713"},"text":"section 1713 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/135/s208/c/3"},"text":"Pub. L. 107–135, § 208(c)(3)","children":[],"tail":", inserted at end “A dependent or survivor receiving care under the preceding sentence shall be eligible for the same medical services as a veteran, including services under sections 1782 and 1783 of this title.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/330/s308/g/8/A"},"text":"Pub. L. 107–330, § 308(g)(8)(A)","children":[],"tail":", substituted “as of "},{"tag":"date","attrib":{"date":"2001-06-05"},"text":"June 5, 2001","children":[],"tail":"” for “as of the date of the enactment of the Veterans’ Survivor Benefits Improvements Act of 2001”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/330/s308/g/8/B"},"text":"Pub. L. 107–330, § 308(g)(8)(B)","children":[],"tail":", substituted “subsection” for “paragraph” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/14"},"text":"Pub. L. 107–14","children":[],"tail":" amended subsec. (d) generally. Prior to amendment, subsec. (d) read as follows: “Notwithstanding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1086/d/1"},"text":"section 1086(d)(1) of title 10","children":[],"tail":" or any other provision of law, any spouse, surviving spouse, or child who, after losing eligibility for medical care under this section by virtue of becoming entitled to hospital insurance benefits under part A of title XVIII of the Social Security Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395c"},"text":"42 U.S.C. 1395c","children":[],"tail":" et seq.), has exhausted any such benefits shall become eligible for medical care under this section and shall not thereafter lose such eligibility under this section by virtue of becoming again eligible for such hospital insurance benefits.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s613"},"text":"section 613 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/2/B"},"text":"Pub. L. 102–83, § 4(b)(2)(B)","children":[],"tail":", substituted “that Secretary” for second and third references to “the Secretary” and “the Secretary of Defense” for last reference to “the Secretary” in par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator” wherever appearing in introductory and concluding provisions and in par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/3"},"text":"Pub. L. 102–83, § 4(a)(3)","children":[],"tail":", (4), substituted “Department” for “Veterans’ Administration” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":" substituted “section 1086(d)(1)” for “the second sentence of section 1086(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/251"},"text":"Pub. L. 97–251","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/72"},"text":"Pub. L. 97–72","children":[],"tail":" substituted “equipped to provide the care and treatment” for “particularly equipped to provide the most effective care and treatment” in provisions following par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/151/s205/a/1"},"text":"Pub. L. 96–151, § 205(a)(1)","children":[],"tail":", in cl. (1) substituted reference to spouse for reference to wife, in cl. (2) substituted reference to surviving spouse for reference to widow, and added cl. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/151/s205/a/2"},"text":"Pub. L. 96–151, § 205(a)(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/581/s104"},"text":"Pub. L. 94–581, § 104","children":[],"tail":", designated existing provisions as cl. (A)