{"tag":"section","attrib":{"id":"idc3c92fca-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4331"},"text":null,"children":[{"tag":"num","attrib":{"value":"4331"},"text":"§ 4331.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3c92fcb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4331/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary (in consultation with the Secretary of Defense) may prescribe regulations implementing the provisions of this chapter with regard to the application of this chapter to States, local governments, and private employers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3c92fcc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4331/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3c92fcd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4331/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Office of Personnel Management (in consultation with the Secretary and the Secretary of Defense) may prescribe regulations implementing the provisions of this chapter with regard to the application of this chapter to Federal executive agencies (other than the agencies referred to in paragraph (2)) as employers. Such regulations shall be consistent with the regulations pertaining to the States as employers and private employers, except that employees of the Federal Government may be given greater or additional rights.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3c92fce-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4331/b/2"},"text":null,"children":