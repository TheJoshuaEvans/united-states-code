{"tag":"section","attrib":{"id":"idc3651676-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3312"},"text":null,"children":[{"tag":"num","attrib":{"value":"3312"},"text":"§ 3312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Educational assistance: duration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3651677-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3312/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to section 3695 and except as provided in subsections (b) and (c), an individual entitled to educational assistance under this chapter is entitled to a number of months of educational assistance under section 3313 equal to 36 months.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3651678-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3312/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continuing Receipt","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The receipt of educational assistance under section 3313 by an individual entitled to educational assistance under this chapter is subject to the provisions of section 3321(b)(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3651679-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3312/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Discontinuation of Education for Active Duty.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc365167a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3312/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any payment of educational assistance described in paragraph (2) shall not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc365167b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3312/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be charged against any entitlement to educational assistance of the individual concerned under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc365167c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3312/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be counted against the aggregate period for which section 3695 limits the individual’s receipt of educational assistance under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc365167d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3312/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Description of payment of educational assistance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (3), the payment of educational assistance described in this paragraph is the payment of such assistance to an individual for pursuit of a course or courses under this chapter if the Secretary finds that the individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc365167e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3312/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc365167f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3312/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an individual not serving on active duty, had to discontinue such course pursuit as a result of being called or ordered to serve on active duty under section 688, 12301(a), 12301(d), 12301(g), 12302, or 12304 of title 10; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3651680-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3312/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an individual serving on active duty, had to discontinue such course pursuit as a result of being ordered to a new duty location or assignment or to perform an increased amount of work; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3651681-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3312/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failed to receive credit or lost training time toward completion of the individual’s approved education, professional, or vocational objective as a result of having to discontinue, as described in subparagraph (A), the individual’s course pursuit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3651682-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3312/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Period for which payment not charged","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The period for which, by reason of this subsection, educational assistance is not charged against entitlement or counted toward the applicable aggregate period under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3695"},"text":"section 3695 of this title","children":[],"tail":" shall not exceed the portion of the period of enrollment in the course or courses from which the individual failed to receive credit or with respect to which the individual lost training time, as determined under paragraph (2)(B)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3651683-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/252/tV/s5003/a/1"},"text":"Pub. L. 110–252, title V, § 5003(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-30"},"text":"June 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2362"},"text":"122 Stat. 2362","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3651684-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3651685-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3651686-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2009-08-01"},"text":"Aug. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/252/s5003/d"},"text":"section 5003(d) of Pub. L. 110–252","children":[],"tail":", set out as an Effective Date of 2008 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s16163"},"text":"section 16163 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
