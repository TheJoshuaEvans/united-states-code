-10-01"},"text":"October 1, 2020","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc40994ac-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Department of Veterans Affairs: Including Military Service in Determining Family and Medical Leave Eligibility","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXI/s1114/c"},"text":"Pub. L. 118–31, div. A, title XI, § 1114(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/432"},"text":"137 Stat. 432","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/31/dA/tXI/s1114/c"},"text":"“Not later than 6 months after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":"], the Secretary of Veterans Affairs shall modify the family and medical leave program provided by operation of "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7425/c"},"text":"section 7425(c) of title 38","children":[],"tail":", United States Code, to conform with the requirements of the amendment made by subsection (a) [amending "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s6381"},"text":"section 6381 of Title 5","children":[],"tail":", Government Organization and Employees] with respect to military service in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s6381/1/B/ii"},"text":"section 6381(1)(B)(ii) of title 5","children":[],"tail":", United States Code, as added by such subsection.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
