{"tag":"section","attrib":{"id":"idc38d8676-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3678"},"text":null,"children":[{"tag":"num","attrib":{"value":"3678"},"text":"§ 3678.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of approval of courses","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The State approving agency, upon determining that an educational institution has complied with all the requirements of this chapter, will issue a letter to such institution setting forth the courses which have been approved for the purposes of this chapter, and will furnish an official copy of such letter and any subsequent amendments to the Secretary. The letter of approval shall be accompanied by a copy of the catalog or bulletin of the institution, as approved by the State approving agency, and shall contain the following information:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc38d8677-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3678/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" date of letter and effective date of approval of courses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc38d8678-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3678/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proper address and name of each educational institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc38d8679-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3678/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authority for approval and conditions of approval, referring specifically to the approved catalog or bulletin published by the educational institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc38d867a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3678/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" name of each course approved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc38d867b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3678/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where applicable, enrollment limitations such as maximum numbers authorized and student-teacher ratio;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc38d867c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3678/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" signature of responsible official of State approving agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc38d867d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3678/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other fair and reasonable provisions as are considered necessary by the appropriate State approving agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc38d867e-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/126/s1"},"text":"Pub. L. 88–126, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-09-23"},"text":"Sept. 23, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/162"},"text":"77 Stat. 162","children":[],"tail":", § 1777; renumbered § 1778, "},{"tag":"ref","attrib":{"href":"