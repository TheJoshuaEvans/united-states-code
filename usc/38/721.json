{"tag":"section","attrib":{"id":"idc29320c4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s721"},"text":null,"children":[{"tag":"num","attrib":{"value":"721"},"text":"§ 721.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recoupment of bonuses or awards paid to employees of Department","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc29320c5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s721/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary may issue an order directing an employee of the Department to repay the amount, or a portion of the amount, of any award or bonus paid to the employee under title 5, including under chapters 45 or 53 of such title, or this title if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc29320c6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s721/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that the individual engaged in misconduct or poor performance prior to payment of the award or bonus, and that such award or bonus would not have been paid, in whole or in part, had the misconduct or poor performance been known prior to payment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc29320c7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s721/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" before such repayment, the employee is afforded—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc29320c8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s721/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notice of the proposed order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc29320c9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s721/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an opportunity to respond to the proposed order by not later than 10 business days after the receipt of such notice; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc29320ca-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s721/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary issues the order—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc29320cb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s721/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a proposed order to which an individual responds under paragraph (2)(B), not later than five business days after receiving the response of the individual; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc29320cc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s721/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a proposed order to which an individual does not respond, not later than 15 business days after the Secretary provides notice to the individual under paragraph (2)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc29320cd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s721/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appeal of Order of Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc29320ce-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s721/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon the issuance of an order by the Secretary under subsection (a) with respect to an individual, the individual shall have an opportunity to appeal the order to the Director of the Office of Personnel Management before the date that is seven business days after the date of such issuance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc29320cf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s721/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall make a final decision with respect to an appeal under paragraph (1) within 30 business days after receiving such appeal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc29320d0-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/41/tII/s204/a"},"text":"Pub. L. 115–41, title II, § 204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-06-23"},"text":"June 23, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/875"},"text":"131 Stat. 875","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc29320d1-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc29320d2-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc29320d3-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 721 and 722 were renumbered sections 1921 and 1922 of this title, respectively.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc29320d4-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc29320d5-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/41/tII/s204/c"},"text":"Pub. L. 115–41, title II, § 204(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-06-23"},"text":"June 23, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/876"},"text":"131 Stat. 876","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/41/tII/s204/c"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s721"},"text":"Section 721 of title 38","children":[],"tail":", United States Code, as added by subsection (a), shall apply with respect to an award or bonus paid by the Secretary of Veterans Affairs to an employee of the Department of Veterans Affairs on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2017-06-23"},"text":"June 23, 2017","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
