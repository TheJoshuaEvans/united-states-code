{"tag":"section","attrib":{"id":"idc3676121-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3314"},"text":null,"children":[{"tag":"num","attrib":{"value":"3314"},"text":"§ 3314.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tutorial assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3676122-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3314/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subsection (b), an individual entitled to educational assistance under this chapter shall also be entitled to benefits provided an eligible veteran under section 3492.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3676123-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3314/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conditions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3676124-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3314/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The provision of benefits under subsection (a) shall be subject to the conditions applicable to an eligible veteran under section 3492.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3676125-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3314/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the conditions specified in paragraph (1), benefits may not be provided to an individual under subsection (a) unless the professor or other individual teaching, leading, or giving the course for which such benefits are provided certifies that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3676126-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3314/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such benefits are essential to correct a deficiency of the individual in such course; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3676127-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3314/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such course is required as a part of, or is prerequisite or indispensable to the satisfactory pursuit of, an approved program of education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3676128-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3314/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3676129-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3314/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of benefits described in subsection (a) that are payable under this section may not exceed $100 per month, for a maximum of 12 months, or until a maximum of $1,200 is utilized.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc367612a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3314/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"As additional assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount provided an individual under this subsection is in addition to the amounts of educational assistance paid the individual under section 3313.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc367612b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3314/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Charge Against Entitlement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any benefits provided an individual under subsection (a) are in addition to any other educational assistance benefits provided the individual under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc367612c-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/252/tV/s5003/a/1"},"text":"Pub. L. 110–252, title V, § 5003(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-30"},"text":"June 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2366"},"text":"122 Stat. 2366","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc367612d-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc367612e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc367612f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2009-08-01"},"text":"Aug. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/252/s5003/d"},"text":"section 5003(d) of Pub. L. 110–252","children":[],"tail":", set out as an Effective Date of 2008 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s16163"},"text":"section 16163 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
