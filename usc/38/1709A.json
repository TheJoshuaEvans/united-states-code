{"tag":"section","attrib":{"id":"idc2df6ca9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709A"},"text":null,"children":[{"tag":"num","attrib":{"value":"1709A"},"text":"§ 1709A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Teleconsultation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2df6caa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Teleconsultation","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2df6cab-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall carry out an initiative of teleconsultation for the provision of remote mental health and traumatic brain injury assessments in facilities of the Department that are not otherwise able to provide such assessments without contracting with third-party providers or reimbursing providers through a fee basis system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2df6cac-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall, in consultation with appropriate professional societies, promulgate technical and clinical care standards for the use of teleconsultation services within facilities of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2df6cad-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709A/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out an initiative under paragraph (1), the Secretary shall ensure that facilities of the Department are able to provide a mental health or traumatic brain injury assessment to a veteran through contracting with a third-party provider or reimbursing a provider through a fee basis system when—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2df6cae-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709A/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such facilities are not able to provide such assessment to the veteran without—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc2df6caf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709A/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such contracting or reimbursement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc2df6cb0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709A/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" teleconsultation; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2df6cb1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709A/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing such assessment with such contracting or reimbursement is more clinically appropriate for the veteran than providing such assessment with teleconsultation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2df6cb2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1709A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Teleconsultation Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “teleconsultation” means the use by a health care specialist of telecommunications to assist another health care provider in rendering a diagnosis or treatment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2df6cb3-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/154/tI/s108/a/1"},"text":"Pub. L. 112–154, title I, § 108(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1174"},"text":"126 Stat. 1174","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
