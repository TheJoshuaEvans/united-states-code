{"tag":"section","attrib":{"id":"idc36033f2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3122"},"text":null,"children":[{"tag":"num","attrib":{"value":"3122"},"text":"§ 3122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Longitudinal study of vocational rehabilitation programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc36033f3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3122/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Study Required","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc36033f4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3122/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to the availability of appropriated funds, the Secretary shall conduct a longitudinal study of a statistically valid sample of each of the groups of individuals described in paragraph (2). The Secretary shall study each such group over a period of at least 20 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc36033f5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3122/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The groups of individuals described in this paragraph are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc36033f6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3122/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Individuals who begin participating in a vocational rehabilitation program under this chapter during fiscal year 2010.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc36033f7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3122/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Individuals who begin participating in such a program during fiscal year 2012.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc36033f8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3122/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Individuals who begin participating in such a program during fiscal year 2014.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc36033f9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3122/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"By not later than July 1 of each year covered by the study required under subsection (a), the Secretary shall submit to the Committees on Veterans’ Affairs of the Senate and House of Representatives a report on the study during the preceding year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc36033fa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3122/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents of Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall include in the report required under subsection (b) any data the Secretary determines is necessary to determine the long-term outcomes of the individuals participating in the vocational rehabilitation programs under this chapter. The Secretary may add data elements from time to time as necessary. In addition, each such report shall contain the following information:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc36033fb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3122/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of individuals participating in vocational rehabilitation programs under this chapter who suspended participation in such a program during the year covered by the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc36033fc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3122/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The average number of months such individuals served on active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc36033fd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3122/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The distribution of disability ratings of such individuals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc36033fe-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3122/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The types of other benefits administered by the Secretary received by such individuals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc36033ff-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3122/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The types of social security benefits received by such individuals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3603400-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3122/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any unemployment benefits received by such individuals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3603401-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3122/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The average number of months such individuals were employed during the year covered by the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3603402-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3122/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The average annual starting and ending salaries of such individuals who were employed during the year covered by the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3603403-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3122/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of such individuals enrolled in an institution of higher learning, as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3452/f"},"text":"section 3452(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3603404-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3122/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The average number of academic credit hours, degrees, and certificates obtained by such individuals during the year covered by the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3603405-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3122/c/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The average number of visits such individuals made to Department medical facilities during the year covered by the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3603406-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3122/c/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The average number of visits such individuals made to non-Department medical facilities during the year covered by the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3603407-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3122/c/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The average annual income of such individuals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3603408-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3122/c/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The average total household income of such individuals for the year covered by the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3603409-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3122/c/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The percentage of such individuals who own their principal residences.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc360340a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3122/c/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The average number of dependents of each such veteran.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc360340b-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/389/tIII/s334/a"},"text":"Pub. L. 110–389, title III, § 334(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4172"},"text":"122 Stat. 4172","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
