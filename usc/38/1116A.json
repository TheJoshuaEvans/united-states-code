,"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc2a6331d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/23/s2/g"},"text":"Pub. L. 116–23, § 2(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-06-25"},"text":"June 25, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/969"},"text":"133 Stat. 969","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/23/s2/g"},"text":"“The amendments made by this section [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1710"},"text":"section 1710 of this title","children":[],"tail":"] shall take effect on "},{"tag":"date","attrib":{"date":"2020-01-01"},"text":"January 1, 2020","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc2a6331e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/23/s2/c"},"text":"Pub. L. 116–23, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-06-25"},"text":"June 25, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/968"},"text":"133 Stat. 968","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/23/s2/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding section 501 of such title, the Secretary of Veterans Affairs may issue guidance to implement ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1116A"},"text":"section 1116A of title 38","children":[],"tail":", United States Code, as added by subsection (a), before prescribing new regulations under such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Updates","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than 120 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2019-06-25"},"text":"June 25, 2019","children":[],"tail":"], the Secretary shall submit a report to the Committees on Veterans’ Affairs of the House of Representatives and the Senate regarding the plans of the Secretary—"}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct outreach under subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to respond to inquiries from veterans regarding claims for disability compensation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1116A"},"text":"section 1116A of title 38","children":[],"tail":", United States Code, as added by subsection (a) of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On a quarterly basis during the period beginning on the date of the enactment of this Act and ending on the date on which regulations are prescribed to carry out such section 1116A, the Secretary shall submit to the Committees on Veterans’ Affairs of the House of Representatives and the Senate updates on the status of such regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pending cases.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to stay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may stay a claim described in subparagraph (B) until the date on which the Secretary commences the implementation of such section 1116A.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Claims described","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A claim described in this subparagraph is a claim for disability compensation—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relating to the service and diseases covered by such section 1116A; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is pending at the Veterans Benefits Administration or the Board of Veterans’ Appeals on or after the date of the enactment of this Act and before the date on which the Secretary commences the implementation of such section 1116A.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc2a6331f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Outreach","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/23/s2/d"},"text":"Pub. L. 116–23, § 2(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-06-25"},"text":"June 25, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/968"},"text":"133 Stat. 968","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/23/s2/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Veterans Affairs shall conduct outreach to inform veterans described in paragraph (2) of the ability to submit a claim for disability compensation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1116A"},"text":"section 1116A of title 38","children":[],"tail":", United States Code, as added by subsection (a). Such outreach shall include the following:"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall publish on the website of the Department a notice that a veterans [sic] described in paragraph (2) may submit or resubmit a claim for disability compensation under such section 1116A.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall notify in writing the veteran service organization community of the ability of veterans described in paragraph (2) to submit or resubmit claims for disability compensation under such section 1116A.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Veteran described","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A veteran described in this paragraph is a veteran who, during active military, naval, or air service, served offshore of the Republic of Vietnam during the period beginning on ","children":[{"tag":"date","attrib":{"date":"1962-01-09"},"text":"January 9, 1962","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"1975-05-07"},"text":"May 7, 1975","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
