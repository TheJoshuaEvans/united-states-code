{"tag":"section","attrib":{"id":"idc3d515d9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5121A"},"text":null,"children":[{"tag":"num","attrib":{"value":"5121A"},"text":"§ 5121A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substitution in case of death of claimant","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3d515da-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5121A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Substitution","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3d515db-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5121A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a claimant dies while a claim for any benefit under a law administered by the Secretary, or an appeal of a decision with respect to such a claim, is pending, a living person who would be eligible to receive accrued benefits due to the claimant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5121/a"},"text":"section 5121(a) of this title","children":[],"tail":" may, not later than one year after the date of the death of such claimant, file a request to be substituted as the claimant for the purposes of processing the claim to completion."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d515dc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5121A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person seeking to be substituted for the claimant shall present evidence of the right to claim such status within such time as prescribed by the Secretary in regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d515dd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5121A/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Substitution under this subsection shall be in accordance with such regulations as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d515de-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5121A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Those who are eligible to make a claim under this section shall be determined in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5121"},"text":"section 5121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3d515df-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/389/tII/s212/a"},"text":"Pub. L. 110–389, title II, § 212(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4151"},"text":"122 Stat. 4151","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3d515e0-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3d515e1-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3d515e2-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/389/tII/s212/c"},"text":"Pub. L. 110–389, title II, § 212(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4151"},"text":"122 Stat. 4151","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/389/tII/s212/c"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5121A"},"text":"Section 5121A of title 38","children":[],"tail":", United States Code, as added by subsection (a), shall apply with respect to the claim of any claimant who dies on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
