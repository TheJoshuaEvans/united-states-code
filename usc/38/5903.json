{"tag":"section","attrib":{"id":"idc3e36edd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5903"},"text":null,"children":[{"tag":"num","attrib":{"value":"5903"},"text":"§ 5903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recognition with respect to particular claims","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3e36ede-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may recognize any individual for the preparation, presentation, and prosecution of any particular claim for benefits under any of the laws administered by the Secretary if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3e36edf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5903/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such individual has certified to the Secretary that no fee or compensation of any nature will be charged any individual for services rendered in connection with such claim; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e36ee0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5903/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such individual has filed with the Secretary a power of attorney, executed in such manner and in such form as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3e36ee1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Suspension","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual recognized under this section shall be subject to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5904/b"},"text":"section 5904(b) of this title","children":[],"tail":" on the same basis as an individual recognized under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5904/a"},"text":"section 5904(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3e36ee2-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1238"},"text":"72 Stat. 1238","children":[],"tail":", § 3403; renumbered § 5903, "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/1"},"text":"Pub. L. 102–83, § 4(a)(1)","children":[],"tail":", (b)(1), (2)(E), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/403-405"},"text":"105 Stat. 403–405","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/461/tI/s101/a/3"},"text":"Pub. L. 109–461, title I, § 101(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3407"},"text":"120 Stat. 3407","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3e36ee3-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3e36ee4-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3e36ee5-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461"},"text":"Pub. L. 109–461","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3403"},"text":"section 3403 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator” in introductory provisions and wherever appearing in pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/1"},"text":"Pub. L. 102–83, § 4(a)(1)","children":[],"tail":", substituted “administered by the Secretary” for “administered by the Veterans’ Administration” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
