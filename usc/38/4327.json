{"tag":"section","attrib":{"id":"idc3c92fbc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4327"},"text":null,"children":[{"tag":"num","attrib":{"value":"4327"},"text":"§ 4327.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncompliance of Federal officials with deadlines; inapplicability of statutes of limitations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3c92fbd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4327/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of Noncompliance of Federal Officials With Deadlines","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3c92fbe-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4327/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The inability of the Secretary, the Attorney General, or the Special Counsel to comply with a deadline applicable to such official under section 4322, 4323, or 4324 of this title—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3c92fbf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4327/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not affect the authority of the Attorney General or the Special Counsel to represent and file an action or submit a complaint on behalf of a person under section 4323 or 4324 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3c92fc0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4327/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall not affect the right of a person—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc3c92fc1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4327/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to commence an action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4323"},"text":"section 4323 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3c92fc2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4327/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to submit a complaint under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4324"},"text":"section 4324 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3c92fc3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4327/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to obtain any type of assistance or relief authorized by this chapter;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3c92fc4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4327/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not deprive a Federal court, the Merit Systems Protection Board, or a State court of jurisdiction over an action or complaint filed by the Attorney General, the Special Counsel, or a person under section 4323 or 4324 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3c92fc5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4327/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not constitute a defense, including a statute of limitations period, that any employer (including a State, a private employer, or a Federal executive agency) or the Office of Personnel Management may raise in an action filed by the Attorney General, the Special Counsel, or a person under section 4323 or 4324 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3c92fc6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4327/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary, the Attorney General, or the Special Counsel is unable to meet a deadline applicable to such official in section 4322(f), 4323(a)(1), 4323(a)(2), 4324(a)(1), or 4324(a)(2)(B) of this title, and the person agrees to an extension of time, the Secretary, the Attorney General, or the Special Counsel, as the case may be, shall complete the required action within the additional period of time agreed to by the person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3c92fc7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4327/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability of Statutes of Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If any person seeks to file a complaint or claim with the Secretary, the Merit Systems Protection Board, or a Federal or State court under this chapter alleging a violation of this chapter, there shall be no limit on the period for filing the complaint or claim.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3c92fc8-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/389/tIII/s311/f/1"},"text":"Pub. L. 110–389, title III, § 311(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4163"},"text":"122 Stat. 4163","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
