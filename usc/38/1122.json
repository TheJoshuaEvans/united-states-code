{"tag":"section","attrib":{"id":"idc2a8a4d1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1122"},"text":null,"children":[{"tag":"num","attrib":{"value":"1122"},"text":"§ 1122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rates of wartime death compensation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2a8a4d2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1122/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The monthly rates of death compensation shall be as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2a8a4d3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1122/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Surviving spouse but no child, $87;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2a8a4d4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1122/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Surviving spouse with one child, $121 (with $29 for each additional child);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2a8a4d5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1122/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No surviving spouse but one child, $67;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2a8a4d6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1122/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No surviving spouse but two children, $94 (equally divided);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2a8a4d7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1122/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No surviving spouse but three children, $122 (equally divided) (with $23 for each additional child, total amount to be equally divided);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2a8a4d8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1122/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Dependent parent, $75;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2a8a4d9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1122/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Both dependent parents, $40 each.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2a8a4da-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1122/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The monthly rate of death compensation payable to a surviving spouse or dependent parent under subsection (a) of this section shall be increased by $79 if the payee is (1) a patient in a nursing home or (2) blind, or so nearly blind or significantly disabled as to need or require the regular aid and attendance of another person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2a8a4db-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text