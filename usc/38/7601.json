{"tag":"section","attrib":{"id":"idc4130a26-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7601"},"text":null,"children":[{"tag":"num","attrib":{"value":"7601"},"text":"§ 7601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of program; purpose","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc4130a27-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7601/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" There is hereby established a program to be known as the Department of Veterans Affairs Health Professionals Educational Assistance Program (hereinafter in this chapter referred to as the “Educational Assistance Program”). The program consists of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4130a28-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7601/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the scholarship program provided for in subchapter II of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4130a29-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7601/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tuition reimbursement program provided for in subchapter III of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4130a2a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7601/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Selected Reserve member stipend program provided for under subchapter V of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4130a2b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7601/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee incentive scholarship program provided for in subchapter VI of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4130a2c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7601/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the education debt reduction program provided for in subchapter VII of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4130a2d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7601/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the specialty education loan repayment program provided for in subchapter VIII of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4130a2e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7601/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the readjustment counseling service scholarship program provided for in subchapter IX of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4130a2f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7601/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The purpose of the Educational Assistance Program is to assist in providing an adequate supply of trained health-care personnel for the Department and the Nation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc4130a30-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/322/tII/s216/b"},"text":"Pub. L. 100–322, title II, § 216(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/518"},"text":"102 Stat. 518","children":[],"tail":", § 4301; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/366/tII/s205/c/1"},"text":"Pub. L. 101–366, title II, § 205(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-15"},"text":"Aug. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/441"},"text":"104 Stat. 441","children":[],"tail":"; renumbered § 7601, "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/2/B/vi"},"text":"Pub. L. 102–83, § 4(a)(2)(B)(vi)","children":[],"tail":", (3), (4), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/403"},"text":"105 Stat. 403","children":[],"tail":", 404; "},{"tag":"ref","attrib":{"href":"/us/pl/103/446/tXII/s1201/e/25"},"text":"Pub. L. 103–446, title XII, § 1201(e)(25)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4686"},"text":"108 Stat. 4686","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/368/tVIII/s805/1"},"text":"Pub. L. 105–368, title VIII, § 805(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3358"},"text":"112 Stat. 3358","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/182/tIII/s303/b/1/A"},"text":"Pub. L. 115–182, title III, § 303(b)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-06"},"text":"June 6, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1466"},"text":"132 Stat. 1466","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/171/tV/s502/b/1/A"},"text":"Pub. L. 116–171, title V, § 502(b)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-17"},"text":"Oct. 17, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/817"},"text":"134 Stat. 817","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc4130a31-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc4130a32-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc4130a33-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/171"},"text":"Pub. L. 116–171","children":[],"tail":" added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/182"},"text":"Pub. L. 115–182","children":[],"tail":" added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368"},"text":"Pub. L. 105–368","children":[],"tail":" added pars. (4) and (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446"},"text":"Pub. L. 103–446","children":[],"tail":" substituted semicolon for comma at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4301"},"text":"section 4301 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/2/B/vi"},"text":"Pub. L. 102–83, § 4(a)(2)(B)(vi)","children":[],"tail":", substituted “Department of Veterans Affairs” for “Veterans’ Administration” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/3"},"text":"Pub. L. 102–83, § 4(a)(3)","children":[],"tail":", (4), substituted “Department” for “Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/366"},"text":"Pub. L. 101–366","children":[],"tail":" added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc4130a34-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc4130a35-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Veterans Healing Veterans Medical Access and Scholarship Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/182/tIII/s304"},"text":"Pub. L. 115–182, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-06"},"text":"June 6, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1467"},"text":"132 Stat. 1467","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/115/251/tII/s211/b/7"},"text":"Pub. L. 115–251, title II, § 211(b)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-29"},"text":"Sept. 29, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3177"},"text":"132 Stat. 3177","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/251/tII/s211/b/7"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Veterans Affairs, acting through the Office of Academic Affiliations of the Department of Veterans Affairs, shall carry out a pilot program under which the Secretary shall provide funding for the medical education of a total of 18 eligible veterans. Such funding shall be provided for two veterans enrolled in each covered medical school in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Veterans","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive funding for medical education under this section, a veteran shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have been discharged from the Armed Forces not more than 10 years before the date of application for admission to a covered medical school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not be concurrently receiving educational assistance under chapter 30, 31, 32, 33, 34, or 35 of title 38, United States Code, or chapter 1606 or 1607 of title 10, United States Code;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apply for admission to a covered medical school for the entering class of 2020;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indicate on such application for admission that the veteran would like to be considered for an award of funding under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet the minimum admissions criteria for the covered medical school to which the veteran applies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into an agreement described in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Award of Funding.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each covered medical school that opts to participate in the program under this section shall reserve two seats in the entering class of 2020 for eligible veterans who receive funding under such program. Such funding shall be awarded to the two eligible veterans with the highest admissions rankings for such class at such school.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount of funding","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each eligible veteran who receives funding under this section shall receive an amount equal to the actual cost of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tuition at the covered medical school at which the veteran enrolls for 4 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" books, fees, and technical equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fees associated with the National Residency Match Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two away rotations performed during the fourth year at a Department of Veterans Affairs medical facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a monthly stipend for the 4-year period during which the veteran is enrolled in medical school in an amount to be determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Distribution of funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the event that two or more eligible veterans do not apply for admission at one of the covered medical schools for the entering class of 2020, the Secretary shall distribute the available funding to eligible veterans who applied for admission at other covered medical schools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreement.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms of agreement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each eligible veteran who accepts funding for medical education under this section shall enter into an agreement with the Secretary that provides that the veteran agrees—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain enrollment and attendance in the medical school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while enrolled in such medical school, to maintain an acceptable level of academic standing (as determined by the medical school under regulations prescribed by the Secretary);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to complete post-graduate training leading to eligibility for board certification in a speciality applicable to the Department of Veterans Affairs, as determined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after completion of medical school, to obtain a license to practice medicine in a State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after completion of medical school and post-graduate training, to serve as a full-time clinical practice employee in the Veterans Health Administration for a period of 4 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Breach of agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If an eligible veteran who accepts funding under this section breaches the terms of the agreement described in paragraph (1), the United States shall be entitled to recover damages in an amount equal to the total amount of such funding received by the veteran.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to prevent any covered medical school from accepting more than two eligible veterans for the entering class of 2020.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2021-12-31"},"text":"December 31, 2021","children":[],"tail":", and annually thereafter for the subsequent 3 years, the Secretary shall submit to Congress a report on the pilot program under this section. Such report shall include the evaluation of the Secretary of the success of the pilot program, including the number of veterans who received funding under the program who matriculated and an evaluation of the academic progress of such veterans."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"“(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Medical Schools","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term ‘covered medical school’ means any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Teague-Cranston medical schools, consisting of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Texas A&M College of Medicine;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Quillen College of Medicine at East Tennessee State University;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Boonshoft School of Medicine at Wright State University;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Joan C. Edwards School of Medicine at Marshall University; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" University of South Carolina School of Medicine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Charles R Drew University of Medicine and Science.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Howard University College of Medicine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Meharry Medical College.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Morehouse School of Medicine.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc4130a36-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Physician Assistant Education and Training Pilot Program for Former Members of the Armed Forces","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/dJ/tII/s246"},"text":"Pub. L. 115–141, div. J, title II, § 246","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/823"},"text":"132 Stat. 823","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/141/dJ/tII/s246"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pilot Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Veterans Affairs shall carry out a pilot program to provide educational assistance to certain former members of the Armed Forces for education and training as physician assistants of the Department of Veterans Affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Individuals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual is eligible to participate in the pilot program if the individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has medical or military health experience gained while serving as a member of the Armed Forces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has received a certificate, associate degree, baccalaureate degree, master’s degree, or postbaccalaureate training in a science relating to health care; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has participated in the delivery of healthcare services or related medical services, including participation in military training relating to the identification, evaluation, treatment, and prevention of diseases and disorders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The pilot program shall be carried out during the 5-year period beginning on the date that is 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall select eligible individuals under subsection (b) to participate in the pilot program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In selecting individuals to participate in the pilot program under paragraph (1), the Secretary shall give priority to individuals who agree to be employed as a physician assistant for the Veterans Health Administration at a medical facility of the Department located in a community that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is designated as a medically underserved population under section 330(b)(3)(A) of the Public Health Service Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254b/b/3/A"},"text":"42 U.S.C. 254b(b)(3)(A)","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in a State with a per capita population of veterans of more than 5 percent according to the National Center for Veterans Analysis and Statistics and the United States Census Bureau.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Educational Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out the pilot program, the Secretary shall provide educational assistance to individuals participating in the pilot program, including through the use of scholarships, to cover the costs to such individuals of obtaining a master’s degree in physician assistant studies or a similar master’s degree.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Period of Obligated Service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall enter into an agreement with each individual participating in the pilot program in which such individual agrees to be employed as a physician assistant for the Veterans Health Administration for a period of obligated service to be determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"“(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Breach","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual who participates in the pilot program and fails to satisfy the period of obligated service under subsection (f) shall be liable to the United States, in lieu of such obligated service, for the amount that has been paid or is payable to or on behalf of the individual under the pilot program, reduced by the proportion that the number of days served for completion of the period of obligated service bears to the total number of days in the period of obligated service of such individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"“(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than one year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":"], the Secretary of Veterans Affairs, in collaboration with the Secretary of Labor, the Secretary of Defense, and the Secretary of Health and Human Services, shall submit to Congress a report on the pilot program’s effectiveness of helping to meet the shortage of physician assistants employed by the Department.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc4130a37-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Payments to Health-Care Professional Employees for Tuition Loans","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/585/tV/s523/b"},"text":"Pub. L. 102–585, title V, § 523(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4959"},"text":"106 Stat. 4959","children":[],"tail":", provided that Secretary of Veterans Affairs could not provide payments to health-care professional employees of Department of Veterans Affairs for payment of tuition loans, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/368/tVIII/s804"},"text":"Pub. L. 105–368, title VIII, § 804","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3358"},"text":"112 Stat. 3358","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc4130a38-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Tuition Loan Payment Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/389/tI"},"text":"Pub. L. 102–389, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-06"},"text":"Oct. 6, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1574"},"text":"106 Stat. 1574","children":[],"tail":", provided in part for an appropriation: "},{"tag":"quotedContent","attrib":{},"text":"“For payment of outstanding tuition loans to Department of Veterans Affairs health care professional employees (excluding physicians and dentists) who agree to remain in service for one year or more, $5,000,000, to remain available until ","children":[{"tag":"date","attrib":{"date":"1994-09-30"},"text":"September 30, 1994","children":[],"tail":": "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the Secretary, in order to recruit and retain such employees, may make such payments, not to exceed $3,000 during any calendar year, or $12,000 in total, to any such employee who has an outstanding tuition loan from an educational institution approved by the Secretary that has led to a degree in the health care occupation in which such individual is employed: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That no payment shall be made in advance: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That regulations shall be promulgated by the Secretary to implement this program.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
