{"tag":"section","attrib":{"id":"idc3ece439-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7111"},"text":null,"children":[{"tag":"num","attrib":{"value":"7111"},"text":"§ 7111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revision of decisions on grounds of clear and unmistakable error","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3ece43a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7111/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A decision by the Board is subject to revision on the grounds of clear and unmistakable error. If evidence establishes the error, the prior decision shall be reversed or revised.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3ece43b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7111/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of authorizing benefits, a rating or other adjudicative decision of the Board that constitutes a reversal or revision of a prior decision of the Board on the grounds of clear and unmistakable error has the same effect as if the decision had been made on the date of the prior decision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3ece43c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7111/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Review to determine whether clear and unmistakable error exists in a case may be instituted by the Board on the Board’s own motion or upon request of the claimant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3ece43d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7111/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A request for revision of a decision of the Board based on clear and unmistakable error may be made at any time after that decision is made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3ece43e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7111/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such a request shall be submitted directly to the Board and shall be decided by the Board on the merits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3ece43f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7111/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A claim filed with the Secretary that requests reversal or revision of a previous Board decision due to clear and unmistakable error shall be considered to be a request to the Board under this section, and the Secretary shall promptly transmit any such request to the Board for its consideration under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3ece440-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/111/s1/b/1"},"text":"Pub. L. 105–111, § 1(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2271"},"text":"111 Stat. 2271","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/55/s2/v"},"text":"Pub. L. 115–55, § 2(v)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-23"},"text":"Aug. 23, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1113"},"text":"131 Stat. 1113","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3ece441-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3ece442-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3ece443-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/55"},"text":"Pub. L. 115–55","children":[],"tail":" struck out “, without referral to any adjudicative or hearing official acting on behalf of the Secretary” after “merits”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3ece444-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3ece445-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/55"},"text":"Pub. L. 115–55","children":[],"tail":" applicable to all claims for which the Secretary of Veterans Affairs provides notice of a decision under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5104"},"text":"section 5104 of this title","children":[],"tail":" on or after the later of 540 days after "},{"tag":"date","attrib":{"date":"2017-08-23"},"text":"Aug. 23, 2017","children":[],"tail":", or 30 days after the date on which the Secretary submits to Congress a certification of certain capabilities of the Department of Veterans Affairs to carry out the new appeals system established by "},{"tag":"ref","attrib":{"href":"/us/pl/115/55"},"text":"Pub. L. 115–55","children":[],"tail":" and to address appeals of decisions on legacy claims, with provision for early applicability of the new appeals system to certain claims, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/55/s2/x"},"text":"section 2(x) of Pub. L. 115–55","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of this title","children":[],"tail":", and bracketed note thereunder."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3ece446-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to any determination made before, on, or after ","children":[{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/111/s1/c/1"},"text":"section 1(c)(1) of Pub. L. 105–111","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5109A"},"text":"section 5109A of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
