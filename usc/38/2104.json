{"tag":"section","attrib":{"id":"idc33c805d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2104"},"text":null,"children":[{"tag":"num","attrib":{"value":"2104"},"text":"§ 2104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefits additional to benefits under other laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc33c805e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any individual who accepts the benefits of this chapter shall not by reason thereof be denied the benefits of chapter 37 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc33c805f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual eligible for assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2101/b"},"text":"section 2101(b) of this title","children":[],"tail":" shall not by reason of such eligibility be denied benefits for which such individual becomes eligible under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2101/a"},"text":"section 2101(a) of this title","children":[],"tail":" or benefits relating to home health services under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1717/a/2"},"text":"section 1717(a)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc33c8060-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not provide assistance to a veteran under this chapter if the Secretary determines such assistance would result in a dupl