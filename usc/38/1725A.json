{"tag":"section","attrib":{"id":"idc30a7390-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725A"},"text":null,"children":[{"tag":"num","attrib":{"value":"1725A"},"text":"§ 1725A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to walk-in care","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc30a7391-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures To Ensure Access to Walk-In Care","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall develop procedures to ensure that eligible veterans are able to access walk-in care from qualifying non-Department entities or providers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc30a7392-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Veterans","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, an eligible veteran is any individual who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc30a7393-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is enrolled in the health care system established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1705/a"},"text":"section 1705(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30a7394-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has received care under this chapter within the 24-month period preceding the furnishing of walk-in care under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc30a7395-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualifying Non-Department Entities or Providers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, a qualifying non-Department entity or provider is a non-Department entity or provider that has entered into a contract, agreement, or other arrangement with the Secretary to furnish services under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc30a7396-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federally-Qualified Health Centers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whenever practicable, the Secretary may use a Federally-qualified health center (as defined in section 1905(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2)(B) of the Social Security Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396d"},"text":"42 U.S.C. 1396d","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2)(B))) to carry out this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc30a7397-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continuity of Care","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall ensure continuity of care for those eligible veterans who receive walk-in care services under this section, including through the establishment of a mechanism to receive medical records from walk-in care providers and provide pertinent patient medical records to providers of walk-in care.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc30a7398-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725A/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Copayments","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc30a7399-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725A/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc30a739a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725A/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may require an eligible veteran to pay the United States a copayment for each episode of hospital care or medical services provided under this section if the eligible veteran would be required to pay a copayment under this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc30a739b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725A/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An eligible veteran not required to pay a copayment under this title may access walk-in care without a copayment for the first two visits in a calendar year. For any additional visits, a copayment at an amount determined by the Secretary may be required.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc30a739c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725A/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An eligible veteran required to pay a copayment under this title may be required to pay a regular copayment for the first two walk-in care visits in a calendar year. For any additional visits, a higher copayment at an amount determined by the Secretary may be required.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30a739d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725A/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After the first two episodes of care furnished to an eligible veteran under this section, the Secretary may adjust the copayment required of the veteran under this subsection based upon the priority group of enrollment of the eligible veteran, the number of episodes of care furnished to the eligible veteran during a year, and other factors the Secretary considers appropriate under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30a739e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725A/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount or amounts of the copayments required under this subsection shall be prescribed by the Secretary by rule.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30a739f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725A/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sections 8153(c) and 1703A(j) of this title shall not apply to this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc30a73a0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725A/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date of the enactment of the Caring for Our Veterans Act of 2018, the Secretary shall promulgate regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc30a73a1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725A/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Walk-In Care Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “walk-in care” means non-emergent care provided by a qualifying non-Department entity or provider that furnishes episodic care and not longitudinal management of conditions and is otherwise defined through regulations the Secretary shall promulgate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc30a73a2-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/182/tI/s105/a"},"text":"Pub. L. 115–182, title I, § 105(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-06"},"text":"June 6, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1412"},"text":"132 Stat. 1412","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/251/tII/s211/a/7"},"text":"Pub. L. 115–251, title II, § 211(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-29"},"text":"Sept. 29, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3175"},"text":"132 Stat. 3175","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/61/s6/2"},"text":"Pub. L. 116–61, § 6(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-09-30"},"text":"Sept. 30, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1117"},"text":"133 Stat. 1117","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc30a73a3-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc30a73a4-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc30a73a5-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the Caring for Our Veterans Act of 2018, referred to in subsec. (g), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/182"},"text":"Pub. L. 115–182","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2018-06-06"},"text":"June 6, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc30a73a6-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/61"},"text":"Pub. L. 116–61","children":[],"tail":" inserted comma after “a contract”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/251/s211/a/7/A"},"text":"Pub. L. 115–251, § 211(a)(7)(A)","children":[],"tail":", substituted “agreement, or other arrangement” for “or other agreement”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/251/s211/a/7/B"},"text":"Pub. L. 115–251, § 211(a)(7)(B)","children":[],"tail":", substituted “Sections 8153(c) and 1703A(j)” for “Section 8153(c)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc30a73a7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc30a73a8-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/182/tI/s105/b"},"text":"Pub. L. 115–182, title I, § 105(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-06"},"text":"June 6, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1413"},"text":"132 Stat. 1413","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/182/tI/s105/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1725A"},"text":"Section 1725A of title 38","children":[],"tail":", United States Code, as added by subsection (a) shall take effect on the date upon which final regulations implementing such section take effect.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
