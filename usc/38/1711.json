{"tag":"section","attrib":{"id":"idc2eb791c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1711"},"text":null,"children":[{"tag":"num","attrib":{"value":"1711"},"text":"§ 1711.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Care during examinations and in emergencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2eb791d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1711/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may furnish hospital care incident to physical examinations where such examinations are necessary in carrying out the provisions of other laws administered by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"status":"repealed","id":"idc2eb791e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1711/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"[(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/135/tII/s208/d"},"text":"Pub. L. 107–135, title II, § 208(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-23"},"text":"Jan. 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2463"},"text":"115 Stat. 2463","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2eb791f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1711/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2eb7920-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1711/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may contract with any organization named in, or approved by the Secretary under, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5902"},"text":"section 5902 of this title","children":[],"tail":" to provide for the furnishing by the Secretary, on a reimbursable basis (as prescribed by the Secretary), of emergency medical services to individuals attending any national convention of such organization, except that reimbursement shall not be required for services furnished under this subsection to the extent that the individual receiving such services would otherwise be eligible under this chapter for medical services."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2eb7921-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1711/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority of the Secretary to enter into contracts under this subsection shall be effective for any fiscal year only to such extent or in such amounts as are provided in appropriation Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2eb7922-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1142"},"text":"72 Stat. 1142","children":[],"tail":", § 611; "},{"tag":"ref","attrib":{"href":"/us/pl/94/581/tII"},"text":"Pub. L. 94–581, title II","children":[],"tail":", §§ 202(e), 210(a)(2), "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2856"},"text":"90 Stat. 2856","children":[],"tail":", 2862; "},{"tag":"ref","attrib":{"href":"/us/pl/96/22/tII/s202"},"text":"Pub. L. 96–22, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-06-13"},"