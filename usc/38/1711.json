. L. 96–128","children":[],"tail":" substituted “named in, or approved by the Administrator under,” for “recognized by the Administrator for the purposes of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/581/s202/e/1"},"text":"Pub. L. 94–581, § 202(e)(1)","children":[],"tail":", substituted “Care” for “Hospitalization” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/581/s210/a/2/A"},"text":"Pub. L. 94–581, § 210(a)(2)(A)","children":[],"tail":", substituted “administered by the Administrator” for “administered by him”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/581"},"text":"Pub. L. 94–581","children":[],"tail":", §§ 202(e)(2), 210(a)(2)(B), substituted “hospital care or medical services” for “hospital care”, “the Administrator shall charge” for “he shall charge”, and “prescribed by the Administrator” for “prescribed by him”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc2eb7927-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc2eb7928-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1979 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/128"},"text":"Pub. L. 96–128","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1979-11-28"},"text":"Nov. 28, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/128/s601/b"},"text":"section 601(b) of Pub. L. 96–128