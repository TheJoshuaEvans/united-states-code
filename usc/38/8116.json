{"tag":"section","attrib":{"id":"idc4261d33-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8116"},"text":null,"children":[{"tag":"num","attrib":{"value":"8116"},"text":"§ 8116.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nursing home revolving fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc4261d34-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8116/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4261d35-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8116/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts realized from a transfer pursuant to section 8122(a)(2)(C) ","children":[{"tag":"ref","attrib":{"idref":"fn002121"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002121"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title shall be administered as a revolving fund and shall be available without fiscal year limitation."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4261d36-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8116/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The revolving fund shall be deposited in a checking account with the Treasurer of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4261d37-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8116/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4261d38-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8116/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The expenditure of funds from the revolving fund may be made only for the construction, alteration, and acquisition (including site acquisition) of nursing home facilities and may be made only as provided for in appropriation Acts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4261d39-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8116/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s8104/a/2"},"text":"section 8104(a)(2) of this title","children":[],"tail":", a bill, resolution, or amendment which provides that funds in the revolving fund may be expended for a project involving a total expenditure of more than $2,000,000 for the construction, alteration, or acquisition (including site acquisition) of a nursing home facility shall be considered to be a bill, resolution, or amendment making an appropriation which may be expended for a major medical facility project."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc4261d3a-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/322/tII/s205/a"},"text":"Pub. L. 100–322, title II, § 205(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/512"},"text":"102 Stat. 512","children":[],"tail":", § 5016; renumbered § 8116 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", (d)(1), "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":", 239.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc4261d3b-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"idc4261d3c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/422/tIV/s411/c/1"},"text":"Pub. L. 108–422, title IV, § 411(c)(1)","children":[],"tail":",(f), "},{"tag":"date","attrib":{"date":"2004-11-30"},"text":"Nov. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2389"},"text":"118 Stat. 2389","children":[],"tail":", 2390, provided that this section is repealed effective at the end of the 30-day period beginning on the date on which the Secretary of Veterans Affairs certifies to Congress that the Secretary is in compliance with "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1710B/b"},"text":"section 1710B(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc4261d3d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc4261d3e-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s8122/a/2"},"text":"Section 8122(a)(2) of this title","children":[],"tail":", referred to in subsec. (a)(1), was amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/108/422/tIV/s411/e/1"},"text":"Pub. L. 108–422, title IV, § 411(e)(