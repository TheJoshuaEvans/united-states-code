{"tag":"section","attrib":{"id":"idc305b870-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K"},"text":null,"children":[{"tag":"num","attrib":{"value":"1720K"},"text":"§ 1720K.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants or contracts to provide mental health support to family caregivers of veterans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc305b871-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may award grants or contracts to carry out, coordinate, improve, or otherwise enhance mental health counseling, treatment, or support to the family caregivers of veterans participating in the family caregiver program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc305b872-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc305b873-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To be eligible for a grant or contract under this section, an entity shall submit to the Secretary an application therefor at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc305b874-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each application submitted under paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc305b875-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A detailed plan for the use of the grant or contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc305b876-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the programs or efforts through which the entity will meet the outcome measures developed by the Secretary under subsection (f).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc305b877-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of how the entity will distribute grant or contract amounts equitably among areas with varying levels of urbanization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc305b878-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A plan for how the grant or contract will be used to meet the unique needs of veterans residing in rural areas, Native American, Native Hawaiian, or Alaska Native veterans, elderly veterans, women veterans, and veterans from other underserved communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc305b879-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Distribution","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall seek to ensure that grants and contracts awarded under this section are equitably distributed among entities located in States with varying levels of urbanization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc305b87a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Priority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prioritize awarding grants or contracts under this section that will serve the following areas:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc305b87b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Areas with high rates of veterans enrolled in the family caregiver program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc305b87c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Areas with high rates of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc305b87d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suicide among veterans; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc305b87e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" referrals to the Veterans Crisis Line.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc305b87f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required Activities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any grant or contract awarded under this section shall be used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc305b880-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to expand existing programs, activities, and services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc305b881-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish new or additional programs, activities, and services; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc305b882-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for travel and transportation to facilitate carrying out paragraph (1) or (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc305b883-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Outcome Measures","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc305b884-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall develop and provide to each entity that receives a grant or contract under this section written guidance on the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc305b885-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Outcome measures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc305b886-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Policies of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc305b887-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In developing outcome measures under paragraph (1), the Secretary shall consider the following goals:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc305b888-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increasing the utilization of mental health services among family caregivers of veterans participating in the family caregiver program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc305b889-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reducing barriers to mental health services among family caregivers of veterans participating in such program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc305b88a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tracking Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc305b88b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall establish appropriate tracking requirements with respect to the entities receiving a grant or contract under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc305b88c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not less frequently than annually, the Secretary shall submit to Congress a report on such tracking requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc305b88d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Performance Review","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc305b88e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the performance of each entity that receives a grant or contract under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc305b88f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make information regarding such performance publicly available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc305b890-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Remediation Plan","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc305b891-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an entity that receives a grant or contract under this section and does not meet the outcome measures developed by the Secretary under subsection (f), the Secretary shall require the entity to submit to the Secretary a remediation plan under which the entity shall describe how and when it plans to meet such outcome measures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc305b892-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not award a subsequent grant or contract under this section to an entity described in paragraph (1) unless the Secretary approves the remediation plan submitted by the entity under such paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc305b893-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum Amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of a grant or contract awarded under this section may not exceed 10 percent of amounts made available for grants or contracts under this section for the fiscal year in which the grant or contract is awarded.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc305b894-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Supplement, Not Supplant","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any grant or contract awarded under this section shall be used to supplement and not supplant funding that is otherwise available through the Department to provide mental health support among family caregivers of veterans participating in the family caregiver program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc305b895-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Outreach to Family Caregivers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall include, in the outreach materials regularly provided to a family caregiver who participates in the family caregiver program, notice of mental health support provided by recipients of grants or contracts under this section that are located in the relevant Veterans Integrated Service Network.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc305b896-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/m"},"text":null,"children":[{"tag":"num","attrib":{"value":"m"},"text":"(m)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc305b897-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/m/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts for the activities of the Department under this section shall be budgeted and appropriated through a separate appropriation account.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc305b898-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/m/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the budget justification materials submitted to Congress in support of the budget of the Department for any fiscal year (as submitted with the budget of the President under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":"), the Secretary shall include a separate statement of the amount requested to be appropriated for that fiscal year for the account specified in paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc305b899-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/n"},"text":null,"children":[{"tag":"num","attrib":{"value":"n"},"text":"(n)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated to the Secretary, for each of fiscal years 2025 and 2026, $10,000,000 to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc305b89a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/o"},"text":null,"children":[{"tag":"num","attrib":{"value":"o"},"text":"(o)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc305b89b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/o/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “caregiver” and “family caregiver” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1720G"},"text":"section 1720G of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc305b89c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/o/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “family caregiver program” means the program of comprehensive assistance for family caregivers under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1720G"},"text":"section 1720G of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc305b89d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720K/o/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Veterans Crisis Line” means the toll-free hotline for veterans established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1720F"},"text":"section 1720F of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc305b89e-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/210/tI/s122"},"text":"Pub. L. 118–210, title I, § 122","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-02"},"text":"Jan. 2, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2724"},"text":"138 Stat. 2724","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
