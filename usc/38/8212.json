{"tag":"section","attrib":{"id":"idc436e5c4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8212"},"text":null,"children":[{"tag":"num","attrib":{"value":"8212"},"text":"§ 8212.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc436e5c5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8212/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is authorized to be appropriated $25,000,000 for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1973-06-30"},"text":"June 30, 1973","children":[],"tail":", and a like sum for each of the six succeeding fiscal years. Sums appropriated pursuant to this section shall be used for making grants pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s8213"},"text":"section 8213 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc436e5c6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8212/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sums appropriated pursuant to subsection (a) of this section shall remain available until the end of the sixth fiscal year following the fiscal year for which they are appropriated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc436e5c7-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/541/s2/a"},"text":"Pub. L. 92–541, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-24"},"text":"Oct. 24, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1102"},"text":"86 Stat. 1102","children":[],"tail":", § 5072; renumbered § 8212 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/2/B"},"text":"Pub. L. 102–40, title IV, § 402(b)(2)(B)","children":[],"tail":", (d)(1), "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/239"},"text":"105 Stat. 239","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc436e5c8-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc436e5c9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc436e5ca-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/b/2/B"},"text":"Pub. L. 102–40, § 402(b)(2)(B)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5072"},"text":"section 5072 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/d/1"},"text":"Pub. L. 102–40, § 402(d)(1)","children":[],"tail":", substituted “8213” for “5073”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
