{"tag":"section","attrib":{"id":"idc3d9d150-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5315"},"text":null,"children":[{"tag":"num","attrib":{"value":"5315"},"text":"§ 5315.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest and administrative cost charges on delinquent payments of certain amounts due the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3d9d151-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5315/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding any other provision of this title or of any other law and subject to sections 3485(e) and 5302 of this title, interest and administrative costs (as described in subsections (b) and (c) of this section) shall be charged, under regulations which the Secretary shall prescribe, on any amount owed to the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3d9d152-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5315/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for an indebtedness resulting from a person’s participation in a benefits program administered by the Secretary other than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3d9d153-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5315/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a loan, loan-guaranty, or loan-insurance program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3d9d154-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5315/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a disability compensation program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3d9d155-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5315/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a pension program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3d9d156-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5315/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an educational assistance program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d9d157-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5315/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for an indebtedness resulting from the provision of care or services under chapter 17 of this title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d9d158-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5315/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent not precluded by the terms of the loan instruments concerned, for an indebtedness resulting from a person’s participation in a program of loans, loan guaranties, or loan insurance administered by the Secretary under this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d9d159-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5315/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3d9d15a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5315/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Interest on the amount of any indebtedness described in subsection (a) of this section shall accrue from the day on which the initial notification of the amount due is mailed to the person who owes such amount (using the most current address of such person that is available to the Secretary), but interest under this section shall not be charged (A) for any period before ","children":[{"tag":"date","attrib":{"date":"1980-10-17"},"text":"October 17, 1980","children":[],"tail":", or (B) if the amount due is paid within a reasonable period of time. The Secretary shall, in the regulations prescribed pursuant to subsection (a) of this section, prescribe what constitutes a reasonable period of time for payment of an indebtedness after the initial notification of indebtedness has been mailed."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d9d15b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5315/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rate of interest to be charged under this section shall be based on the rate of interest paid by the United States for its borrowing and shall be determined by the Secretary under such regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d9d15c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5315/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The administrative costs to be charged under this section with respect to an amount owed to the United States shall be so much of the costs incurred by the United States in collecting such amount as the Secretary determines, under such regulations, to be reasonable and appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3d9d15d-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466/tVI/s605/a/1"},"text":"Pub. L. 96–466, title VI, § 605(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2210"},"text":"94 Stat. 2210","children":[],"tail":", § 3115; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/16/s6/b/4"},"text":"Pub. L. 102–16, § 6(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-03-22"},"text":"Mar. 22, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/51"},"text":"105 Stat. 51","children":[],"tail":"; renumbered § 5315 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", (d)(1), "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":", 239; "},{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":", §§ 4(a)(1), (b)(1), (2)(E), 5(C)(1), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/403-406"},"text":"105 Stat. 403–406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/368/tX/s1005/b/17"},"text":"Pub. L. 105–368, title X, § 1005(b)(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3365"},"text":"112 Stat. 3365","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dU/tII/s253/a"},"text":"Pub. L. 117–328, div. U, title II, § 253(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5464"},"text":"136 Stat. 5464","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3d9d15e-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3d9d15f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3d9d160-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" designated existing provisions as introductory provisions, substituted “other than—” for “other than a loan, loan-guaranty, or loan-insurance program;”, and added subpars. (A) to (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368"},"text":"Pub. L. 105–368","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"October 17, 1980","children":[],"tail":",” for “the date of the enactment of this section,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/b/1"},"text":"Pub. L. 102–40, § 402(b)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3115"},"text":"section 3115 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “3485(e)” for “1685(e)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/1"},"text":"Pub. L. 102–83, § 4(a)(1)","children":[],"tail":", substituted “administered by the Secretary” for “administered by the Veterans’ Administration” in pars. (1) and (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/d/1"},"text":"Pub. L. 102–40, § 402(d)(1)","children":[],"tail":", substituted “5302” for “3102” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/16"},"text":"Pub. L. 102–16","children":[],"tail":" substituted “sections 1685(e) and 3102” for “section 3102” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3d9d161-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3d9d162-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dU/tII/s253/b"},"text":"Pub. L. 117–328, div. U, title II, § 253(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5464"},"text":"136 Stat. 5464","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dU/tII/s253/b"},"text":"“The amendments made by subsection (a) [amending this section] shall apply with respect to an indebtedness that occurs on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3d9d163-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1980-10-01"},"text":"Oct. 1, 1980","children":[],"tail":", except as otherwise specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/96/466/s802/f"},"text":"section 802(f) of Pub. L. 96–466","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5314"},"text":"section 5314 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
