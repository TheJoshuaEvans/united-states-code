{"tag":"section","attrib":{"id":"idc28e659e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s704"},"text":null,"children":[{"tag":"num","attrib":{"value":"704"},"text":"§ 704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of pay limitation for certain employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc28e659f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employees of Veterans Health Administration Impacted by Closure or Realignment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary may waive any annual premium or aggregate limitation on pay for an employee of the Veterans Health Administration for the calendar year during which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc28e65a0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s704/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the official duty station of the employee is closed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28e65a1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s704/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the office, facility, activity, or organization of the employee is realigned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc28e65a2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employees Providing Care to Veterans Exposed to Open Burn Pits.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc28e65a3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s704/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary may waive any annual premium or aggregate limitation on pay for an employee of the Department whose primary duties include providing expanded care for veterans exposed to open burn pits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28e65a4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s704/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Open burn pit defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subsection, the term “open burn pit” has the meaning given that term in section 201(c) of the Dignified Burial and Other Veterans’ Benefits Improvement Act of 2012 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/260"},"text":"Public Law 112–260","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s527"},"text":"38 U.S.C. 527","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc28e65a5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s704/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination With Office of Personnel Management","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In implementing this section, the Secretary shall coordinate with the Director of the Office of Personnel Management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc28e65a6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s704/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc28e65a7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s704/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For each quarter that the Secretary waives a limitation under this section, the Secretary shall submit to the Committee on Veterans’ Affairs of the Senate, the Committee on Veterans’ Affairs of the House of Representatives, and the Office of Personnel Management a report on the waiver or waivers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28e65a8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s704/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report submitted under paragraph (1) with respect to a waiver or waivers shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc28e65a9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s704/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Where the waiver or waivers were used, including in which component of the Department and, as the case may be, which medical center of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc28e65aa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s704/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For how many employees the waiver or waivers were used, disaggregated by component of the Department and, if applicable, medical center of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc28e65ab-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s704/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The average amount by which each payment exceeded the pay limitation that was waived, disaggregated by component of the Department and, if applicable, medical center of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc28e65ac-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s704/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employee Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “employee” means any employee regardless of the authority under which the employee was hired.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc28e65ad-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s704/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall terminate on ","children":[{"tag":"date","attrib":{"date":"2027-09-30"},"text":"September 30, 2027","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc28e65ae-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/168/tIX/s907"},"text":"Pub. L. 117–168, title IX, § 907","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-10"},"text":"Aug. 10, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1814"},"text":"136 Stat. 1814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc28e65af-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc28e65b0-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc28e65b1-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 704 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1904"},"text":"section 1904 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
