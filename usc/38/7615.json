{"tag":"section","attrib":{"id":"idc4157aa3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7615"},"text":null,"children":[{"tag":"num","attrib":{"value":"7615"},"text":"§ 7615.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status of participants","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Participants in the Scholarship Program shall not by reason of their participation in such program (1) be considered to be employees of the Federal Government, or (2) be counted against any personnel ceiling affecting the Veterans Health Administration.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc4157aa4-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/322/tII/s216/b"},"text":"Pub. L. 100–322, title II, § 216(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/522"},"text":"102 Stat. 522","children":[],"tail":", § 4315; renumbered § 7615, "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/446/tXII/s1201/b/1"},"text":"Pub. L. 103–446, title XII, § 1201(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4682"},"text":"108 Stat. 4682","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc4157aa5-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"edit