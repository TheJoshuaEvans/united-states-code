{"tag":"section","attrib":{"id":"idc369d192-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3318"},"text":null,"children":[{"tag":"num","attrib":{"value":"3318"},"text":"§ 3318.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional assistance: relocation or travel assistance for individual relocating or traveling significant distance for pursuit of a program of education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc369d193-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3318/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each individual described in subsection (b) shall be paid additional assistance under this section in the amount of $500.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc369d194-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3318/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Individuals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual described in this subsection is any individual entitled to educational assistance under this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc369d195-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3318/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who resides in a county (or similar entity utilized by the Bureau of the Census) with less than seven persons per square mile, according to the most recent decennial Census; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc369d196-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3318/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc369d197-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3318/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physically relocates a distance of at least 500 miles in order to pursue a program of education for which the individual utilizes educational assistance under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc369d198-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3318/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" travels by air to physically attend an institution of higher learning for pursuit of such a program of education because the individual cannot travel to such institution by automobile or other established form of transportation due to an absence of road or other infrastructure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc369d199-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3318/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Proof of Residence","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (b)(1), an individual may demonstrate the individual’s place of residence utilizing any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc369d19a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3318/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" DD Form 214, Certification of Release or Discharge from Active Duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc369d19b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3318/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The most recent Federal income tax return.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc369d19c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3318/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other evidence as the Secretary shall prescribe for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc369d19d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3318/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Single Payment of Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual is entitled to only one payment of additional assistance under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc369d19e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3318/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Charge Against Entitlement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any amount paid an individual under this section is in addition to any other educational assistance benefits provided the individual under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc369d19f-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/252/tV/s5003/a/1"},"text":"Pub. L. 110–252, title V, § 5003(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-30"},"text":"June 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2369"},"text":"122 Stat. 2369","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/275/tX/s1001/g/6"},"text":"Pub. L. 111–275, title X, § 1001(g)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-13"},"text":"Oct. 13, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2896"},"text":"124 Stat. 2896","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc369d1a0-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc369d1a1-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc369d1a2-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/275"},"text":"Pub. L. 111–275","children":[],"tail":" substituted “higher learning” for “higher education”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc369d1a3-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc369d1a4-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2009-08-01"},"text":"Aug. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/252/s5003/d"},"text":"section 5003(d) of Pub. L. 110–252","children":[],"tail":", set out as an Effective Date of 2008 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s16163"},"text":"section 16163 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
