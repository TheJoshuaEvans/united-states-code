{"tag":"section","attrib":{"id":"idc41a35a3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7732A"},"text":null,"children":[{"tag":"num","attrib":{"value":"7732A"},"text":"§ 7732A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee certification","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc41a35a4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7732A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Development of Certification Examination","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc41a35a5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7732A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall provide for an examination of appropriate employees and managers of the Veterans Benefits Administration who are responsible for processing claims for compensation and pension benefits under the laws administered by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc41a35a6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7732A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In developing the examination required by paragraph (1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc41a35a7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7732A/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with appropriate individuals or entities, including examination development experts, interested stakeholders, and employee representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc41a35a8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7732A/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider the data gathered and produced under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7731/c/3"},"text":"section 7731(c)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc41a35a9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7732A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employee and Manager Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall require appropriate employees and managers of the Veterans Benefits Administration who are responsible for processing claims for compensation and pension benefits under the laws administered by the Secretary to take the examination provided under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc41a35aa-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/389/tII/s225/a/1"},"text":"Pub. L. 110–389, title II, § 225(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4158"},"text":"122 Stat. 4158","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc41a35ab-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc41a35ac-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc41a35ad-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadlines for Implementation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/389/tII/s225/a/3"},"text":"Pub. L. 110–389, title II, § 225(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4158"},"text":"122 Stat. 4158","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/389/tII/s225/a/3"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Secretary of Veterans Affairs shall—","children":[],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop an updated certification examination required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7732A"},"text":"section 7732A of title 38","children":[],"tail":", United States Code, as added by subsection (a), not later than one year after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" begin administering such certification examination required under such section not later than 90 days after the date on which the development of such certification examination is complete.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
