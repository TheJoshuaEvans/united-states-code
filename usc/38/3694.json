{"tag":"section","attrib":{"id":"idc3996d19-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3694"},"text":null,"children":[{"tag":"num","attrib":{"value":"3694"},"text":"§ 3694.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of other Federal agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3996d1a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3694/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out the Secretary’s functions under this chapter or chapter 34 or 35 of this title, the Secretary may utilize the facilities and services of any other Federal department or agency. Any such utilization shall be pursuant to proper agreement with the Federal department or agency concerned; and payment to cover the cost thereof shall be made either in advance or by way of reimbursement, as may be provided in such agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3996d1b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3694/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination of Information Among the Departments of Veterans Affairs, Defense, and Labor With Respect to On-Job Training","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"At the time of a servicemember’s discharge or release from active duty service, the Secretary of Defense shall furnish to the Secretary such pertinent information concerning each registered apprenticeship pursued by the servicemember during the period of active duty service of the servicemember. The Secretary, in conjunction with the Secretary of Labor, shall encourage and assist States and private organizations to give credit to servicemembers for the registered apprenticeship program so pursued in the case of any related apprenticeship program the servicemember may pursue as a civilian.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3996d1c-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/358/s3/b"},"text":"Pub. L. 89–358, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-03-03"},"text":"Mar. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/23"},"text":"80 Stat. 23","children":[],"tail":", § 1790; renumbered § 1794, "},{"tag":"ref","attrib":{"href":"/us/pl/92/540/tIII/s316/2"},"text":"Pub. L. 92–540, title III, § 316(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-24"},"text":"Oct. 24, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1086"},"text":"86 Stat. 1086","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/502/tV/s513/a/21"},"text":"Pub. L. 94–502, title V, § 513(a)(21)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-15"},"text":"Oct. 15, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2403"},"text":"90 Stat. 2403","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIV/s423/b/1/A"},"text":"Pub. L. 101–237, title IV, § 423(b)(1)(A)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2092"},"text":"103 Stat. 2092","children":[],"tail":"; renumbered § 3694, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","at