{"tag":"section","attrib":{"id":"idc436e60b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8231"},"text":null,"children":[{"tag":"num","attrib":{"value":"8231"},"text":"§ 8231.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Declaration of purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The purpose of this subchapter is to authorize the Secretary to carry out a program of grants to provide assistance in the establishment of cooperative arrangements among universities, colleges, junior colleges, community colleges, schools of allied health professions, State and local systems of education, hospitals, and other nonprofit health manpower institutions affiliated with the Department, designed to coordinate, improve, and expand the training of professional and technical allied health and paramedical personnel, and to assist in developing and evaluating new health careers, interdisciplinary approaches and career advancement opportunities, so as to improve and expand allied and other health manpower utilization.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc436e60c-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/541/s2/a"},"text":"Pub. L. 92–541, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-24"},"text":"Oct. 24, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1105"},"text":"86 Stat. 1105","children":[],"tail":", § 5091; renumbered § 8231, "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/2/D"},"text":"Pub. L. 102–40, title IV, § 402(b)(2)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/239"},"text":"105 Stat. 239","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/3"},"text":"Pub. L. 102–83, § 4(a)(3)","children":[],"tail":", (4), (b)(1), (2)(E), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404"},"text":"105 Stat. 404","children":[],"tail":", 405.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc436e60d-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc436e60e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc436e60f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5091"},"text":"section 5091 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" substituted “Secretary” for “Administrator” and “Department” for “Veterans’ Administration”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
