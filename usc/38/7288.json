{"tag":"section","attrib":{"id":"idc3ef55b2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7288"},"text":null,"children":[{"tag":"num","attrib":{"value":"7288"},"text":"§ 7288.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3ef55b3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7288/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The chief judge of the Court shall submit to the appropriate committees of Congress each year a report summarizing the workload of the Court for the fiscal year ending during the preceding year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3ef55b4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7288/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under subsection (a) shall include, with respect to the fiscal year covered by such report, the following information:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3ef55b5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7288/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of appeals filed with the Court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ef55b6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7288/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of petitions filed with the Court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ef55b7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7288/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of applications filed with the Court under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2412"},"text":"section 2412 of title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ef55b8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7288/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The total number of dispositions by each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3ef55b9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7288/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Court as a whole.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3ef55ba-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7288/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Clerk of the Court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3ef55bb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7288/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A single judge of the Court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3ef55bc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7288/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A multi-judge panel of the Court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3ef55bd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7288/b/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The full Court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ef55be-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7288/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of each type of disposition by the Court, including settlement, affirmation, remand, vacation, dismissal, reversal, grant, and denial.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ef55bf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7288/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The median time from filing an appeal to disposition by each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3ef55c0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7288/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Court as a whole.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3ef55c1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7288/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Clerk of the Court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3ef55c2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7288/b/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A single judge of the Court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3ef55c3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7288/b/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Multiple judges of the Court (including a multi-judge panel of the Court or the full Court).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ef55c4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7288/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The median time from filing a petition to disposition by the Court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ef55c5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7288/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The median time from filing an application under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2412"},"text":"section 2412 of title 28","children":[],"tail":" to disposition by the Court."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ef55c6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7288/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The median time from the completion of briefing requirements by the parties to disposition by the Court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ef55c7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7288/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of oral arguments before the Court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ef55c8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7288/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of cases appealed to the United States Court of Appeals for the Federal Circuit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ef55c9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7288/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number and status of appeals and petitions pending with the Court and of applications described in paragraph (3) as of the end of such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ef55ca-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7288/b/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of cases pending with the Court more than 18 months as of the end of such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ef55cb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7288/b/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A summary of any service performed for the Court by a recalled retired judge of the Court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ef55cc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7288/b/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An assessment of the workload of each judge of the Court, including consideration of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3ef55cd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7288/b/15/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The time required of each judge for disposition of each type of case.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3ef55ce-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7288/b/15/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of cases reviewed by the Court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3ef55cf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7288/b/15/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The average workload of other Federal judges.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3ef55d0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7288/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriate Committees of Congress Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “appropriate committees of Congress” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3ef55d1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7288/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Veterans’ Affairs of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ef55d2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7288/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Veterans’ Affairs of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3ef55d3-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/389/tVI/s604/a"},"text":"Pub. L. 110–389, title VI, § 604(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4178"},"text":"122 Stat. 4178","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
