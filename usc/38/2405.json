{"tag":"section","attrib":{"id":"idc345f62a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2405"},"text":null,"children":[{"tag":"num","attrib":{"value":"2405"},"text":"§ 2405.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of inactive cemeteries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc345f62b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2405/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may transfer, with the consent of the agency concerned, any inactive cemetery, burial plot, memorial, or monument within the Secretary’s control to the Department of the Interior for maintenance as a national monument or park, or to any other agency of the Government. Any cemetery transferred to the Department of the Interior shall be administered by the Secretary of the Interior as a part of the National Park System, and funds appropriated to the Secretary of the Interior for such system shall be available for the management and operation of such cemetery.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc345f62c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2405/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may also transfer and convey all right, title, and interest of the United States in or to any inactive cemetery or burial plot, or portion thereon, to any State, county, municipality, or proper agency thereof, in which or in the vicinity of which such cemetery or burial plot is located, but in the event the grantee shall cease or fail to care for and maintain the cemetery or burial plot or the graves and monuments contained therein in a manner satisfactory to the Secretary, all such right, title, and interest transferred or conveyed by the United States, shall revert to the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc345f62d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2405/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a cemetery not under the control of the National Cemetery Administration has been or is to be discontinued, the Secretary may provide for the removal of remains from that cemetery to any cemetery under the control of such Administration. The Secretary may also provide for the removal of the remains of any veteran from a place of temporary interment, or from an abandoned grave or cemetery, to a national cemetery.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc345f62e-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/43/s2/a"},"text":"Pub. L. 93–43, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-06-18"},"text":"June 18, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/77"},"text":"87 Stat. 77","children":[],"tail":", § 1005; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/576/tVII/s701/56"},"text":"Pub. L. 99–576, title VII, § 701(56)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3295"},"text":"100 Stat. 3295","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIII/s313/b/1"},"text":"Pub. L. 101–237, title III, § 313(b)(1)","children":[],"tail":", (4), "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2077"},"text":"103 Stat. 2077","children":[],"tail":"; renumbered § 2405, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/368/tIV/s403/c/7"},"text":"Pub. L. 105–368, title IV, § 403(c)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3339"},"text":"112 Stat. 3339","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc345f62f-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc345f630-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc345f631-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368"},"text":"Pub. L. 105–368","children":[],"tail":", in first sentence, substituted “under the control of the National Cemetery Administration” for “within the National Cemetery System” and “under the control of such Administration” for “within such System”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1005"},"text":"section 1005 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237/s313/b/4"},"text":"Pub. L. 101–237, § 313(b)(4)","children":[],"tail":", inserted “of the Interior” after “funds appropriated to the Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237/s313/b/1"},"text":"Pub. L. 101–237, § 313(b)(1)","children":[],"tail":", substituted “Secretary may transfer” for “Administrator may transfer” and “Secretary’s” for “Administrator’s”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237/s313/b/1"},"text":"Pub. L. 101–237, § 313(b)(1)","children":[],"tail":", substituted “Secretary” for “Administrator” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576/s701/56/A"},"text":"Pub. L. 99–576, § 701(56)(A)","children":[],"tail":", substituted “the Administrator’s” for “his”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576/s701/56/B"},"text":"Pub. L. 99–576, § 701(56)(B)","children":[],"tail":", substituted “The Administrator” for “He”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
