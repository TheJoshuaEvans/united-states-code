{"tag":"section","attrib":{"id":"idc3e828e9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307"},"text":null,"children":[{"tag":"num","attrib":{"value":"6307"},"text":"§ 6307.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to States and Indian Tribes to improve outreach to veterans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3e828ea-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It is the purpose of this section to provide for assistance by the Secretary to States and Indian Tribes to carry out programs that improve covered outreach and assistance to veterans and the spouses, children, and parents of veterans, to ensure that such individuals are fully informed about, and assisted in applying for, any veterans and veterans-related benefits and programs (including veterans programs of a State or Indian Tribe) for which they may be eligible and facilitate opportunities for such individuals to receive competent, qualified services in the preparation, presentation and prosecution of veterans benefits claims.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3e828eb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may award grants to States and Indian Tribes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3e828ec-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to carry out, coordinate, improve, or otherwise enhance—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3e828ed-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" covered outreach activities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3e828ee-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities to assist in the development and submittal of claims for veterans and veterans-related benefits; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e828ef-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the number of county or Tribal veterans service officers serving in the State by hiring new, additional such officers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3e828f0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3e828f1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To be eligible for a grant under this section, a State or Indian Tribe shall submit to the Secretary an application therefor at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e828f2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each application submitted under paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3e828f3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A detailed plan for the use of the grant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3e828f4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the programs through which the State or Indian Tribe will meet the outcome measures developed by the Secretary under subsection (j).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3e828f5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of how the State or Indian Tribe will distribute grant amounts equitably among counties or Tribal lands with varying levels of urbanization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3e828f6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A plan for how the grant will be used to meet the unique needs of American Indian veterans, Alaska Native veterans, or Native Hawaiian veterans, elderly veterans, and veterans from other underserved communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3e828f7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Distribution","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall seek to ensure that grants awarded under this section are equitably distributed among States and Indian Tribes with varying levels of urbanization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3e828f8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Set-aside","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Of the amounts authorized to be appropriated or otherwise made available for grants under this section for any fiscal year, the Secretary shall ensure that not less than five percent is used to make grants to Indian Tribes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3e828f9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Priority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prioritize awarding grants under this section that will serve the following areas:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3e828fa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Areas with a critical shortage of county or Tribal veterans service officers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e828fb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Areas with high rates of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3e828fc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suicide among veterans; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3e828fd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" referrals to the Veterans Crisis Line.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3e828fe-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of County or Tribal Veterans Service Officers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State or Indian Tribe that receives a grant under this section to carry out an activity described in subsection (b)(1) shall carry out the activity through—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3e828ff-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a county or Tribal veterans service officer of the State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e82900-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the State or Indian Tribe does not have a county or Tribal veterans service officer, or if the county or Tribal veterans service officers of the State or Indian Tribe cover only a portion of that State or Indian Tribe, an appropriate entity of a State, local, or Tribal government, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3e82901-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required Activities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any grant awarded under this section shall be used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3e82902-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to expand existing programs, activities, and services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e82903-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to hire new, additional county or Tribal veterans service officers; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e82904-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for travel and transportation to facilitate carrying out paragraph (1) or (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3e82905-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized Activities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A grant under this section may be used to provide education and training, including on-the-job training, for State, county, local, and Tribal government employees who provide (or when trained will provide) covered outreach services in order for those employees to obtain accreditation in accordance with procedures approved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3e82906-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Outcome Measures","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3e82907-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall develop and provide to each State or Indian Tribe that receives a grant under this section written guidance on the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3e82908-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/j/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Outcome measures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3e82909-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/j/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Policies of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e8290a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In developing outcome measures under paragraph (1), the Secretary shall consider the following goals:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3e8290b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/j/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increasing the use of veterans and veterans-related benefits, particularly among vulnerable populations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3e8290c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/j/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increasing the number of county and Tribal veterans service officers recognized by the Secretary for the representation of veterans under chapter 59 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3e8290d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tracking Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3e8290e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to each grant awarded under this section, the Secretary shall track the use of veterans and veterans-related benefits among the population served by the grant, including the average period of time between the date on which a veteran applies for such a benefit and the date on which the veteran receives the benefit, disaggregated by type of benefit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e8290f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not less frequently than annually during the life of the grant program established under this section, the Secretary shall submit to Congress a report on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3e82910-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/k/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information tracked under paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3e82911-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/k/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the grants awarded under this section serve the unique needs of American Indian veterans, Alaska Native veterans, or Native Hawaiian veterans, elderly veterans, and veterans from other underserved communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3e82912-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/k/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other information provided by States and Indian Tribes pursuant to the grant reporting requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3e82913-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Performance Review","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3e82914-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/l/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the performance of each State or Indian Tribe that receives a grant under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e82915-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/l/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make information regarding such performance publicly available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3e82916-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/m"},"text":null,"children":[{"tag":"num","attrib":{"value":"m"},"text":"(m)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Remediation Plan","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3e82917-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/m/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a State or Indian Tribe that receives a grant under this section and does not meet the outcome measures developed by the Secretary under subsection (j), the Secretary shall require the State or Indian Tribe to submit a remediation plan under which the State shall describe how and when it plans to meet such outcome measures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e82918-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/m/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not award a subsequent grant under this section to a State or Indian Tribe described in paragraph (1) unless the Secretary approves the remediation plan submitted by the State or Indian Tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3e82919-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/n"},"text":null,"children":[{"tag":"num","attrib":{"value":"n"},"text":"(n)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3e8291a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/n/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “county or Tribal veterans service officer” includes a local equivalent veterans service officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e8291b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/n/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “covered outreach” means outreach with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3e8291c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/n/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" benefits administered by the Under Secretary for Benefits; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3e8291d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/n/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" similar benefits administered by a State or Indian Tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e8291e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/n/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Indian Tribe” has the meaning given such term in section 4 of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"25 U.S.C. 5304","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e8291f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/n/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State” includes the District of Columbia, the Commonwealth of Puerto Rico, the Commonwealth of the Northern Mariana Islands, and any territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e82920-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6307/n/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Veterans Crisis Line” means the toll-free hotline for veterans established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1720F/h"},"text":"section 1720F(h) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3e82921-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/210/tIII/s302/a/2"},"text":"Pub. L. 118–210, title III, § 302(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-02"},"text":"Jan. 2, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2789"},"text":"138 Stat. 2789","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3e82922-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3e82923-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc3e82924-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6307 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s6308"},"text":"section 6308 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
