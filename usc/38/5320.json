{"tag":"section","attrib":{"id":"idc3d9d1a9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5320"},"text":null,"children":[{"tag":"num","attrib":{"value":"5320"},"text":"§ 5320.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Threshold for reporting debts to consumer reporting agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe regulations that establish the minimum amount of a claim or debt, arising from a benefit administered by the Under Secretary for Benefits or Under Secretary for Health, that the Secretary will report to a consumer reporting agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3711"},"text":"section 3711 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc3d9d1aa-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/tII/s2007/a"},"text":"Pub. L. 116–315, title II, § 2007(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4977"},"text":"134 Stat. 4977","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3d9d1ab-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3d9d1ac-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3d9d1ad-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadline","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/tII/s2007/c"},"text":"Pub. L. 116–315, title II, § 2007(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4977"},"text":"134 Stat. 4977","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/315/tII/s2007/c"},"text":"“The Secretary of Veterans Affairs shall prescribe regulations under section 5320 of such title [title 38], as added by subsection (a), not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
