{"tag":"section","attrib":{"id":"idc394b205-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3685"},"text":null,"children":[{"tag":"num","attrib":{"value":"3685"},"text":"§ 3685.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overpayments to eligible persons or veterans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc394b206-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3685/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever the Secretary finds that an overpayment has been made to a veteran or eligible person relating to educational assistance under a law administered by the Secretary, the amount of such overpayment shall constitute a liability of such veteran or eligible person to the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc394b207-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3685/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any overpayment to a veteran or eligible person with respect to pursuit by the veteran or eligible person of a program of education at an educational institution shall constitute a liability of the educational institution to the United States if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc394b208-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3685/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary finds that the overpayment has been made as the result of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc394b209-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3685/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the willful or negligent failure of an educational institution to report, as required under this chapter or chapter 34 or 35 of this title, to the Department of Veterans Affairs excessive absences from a course, or discontinuance or interruption of a course by the veteran or eligible person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc394b20a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3685/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the willful or negligent false certification by an educational institution; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc394b20b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3685/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the benefit payment sent to an educational institution on behalf of an eligible veteran or person is made pursuant to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc394b20c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3685/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3313/h"},"text":"section 3313(h) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc394b20d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3685/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3317"},"text":"section 3317 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc394b20e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3685/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3680/d"},"text":"section 3680(d) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc394b20f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3685/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3320/d"},"text":"section 3320(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc394b210-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3685/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any overpayment referred to in subsection (a) or (b) of this section may be recovered, except as otherwise provided in the last sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3684/c"},"text":"section 3684(c) of this title","children":[],"tail":", in the same manner as any other debt due the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc394b211-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3685/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any overpayment referred to in subsection (a) or (b) of this section may be waived as to a veteran or eligible person as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5302"},"text":"section 5302 of this title","children":[],"tail":". Waiver of any such overpayment as to a veteran or eligible person shall in no way release any educational institution from liability under subsection (b) of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc394b212-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3685/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc394b213-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3685/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any amount collected from a veteran or eligible person pursuant to this section shall be reimbursed to the educational institution which is liable pursuant to subsection (b) of this section to the extent that collection was made from the educational institution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc394b214-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3685/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this section or any other provision of this title shall be construed as (A) precluding the imposition of any civil or criminal liability under this title or any other law, or (B) requiring any institution of higher learning to maintain daily attendance records for any course leading to a standard college degree.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc394b215-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/358/s3/b"},"text":"Pub. L. 89–358, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-03-03"},"text":"Mar. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/22"},"text":"80 Stat. 22","children":[],"tail":", § 1785; amended "},{"tag":"ref","attrib":{"href":"/us/pl/92/540/tIV/s403/11"},"text":"Pub. L. 92–540, title IV, § 403(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-24"},"text":"Oct. 24, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1090"},"text":"86 Stat. 1090","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/202/tIII/s304/a/2"},"text":"Pub. L. 95–202, title III, § 304(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-11-23"},"text":"Nov. 23, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1442"},"text":"91 Stat. 1442","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/466/tIII/s344"},"text":"Pub. L. 96–466, title III, § 344","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2199"},"text":"94 Stat. 2199","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIV/s423/b/1"},"text":"Pub. L. 101–237, title IV, § 423(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2092"},"text":"103 Stat. 2092","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/d/1"},"text":"Pub. L. 102–40, title IV, § 402(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/239"},"text":"105 Stat. 239","children":[],"tail":"; renumbered § 3685 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/315/tI/s1019"},"text":"Pub. L. 116–315, title I, § 1019","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4950"},"text":"134 Stat. 4950","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc394b216-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc394b217-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc394b218-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those comprising this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1191"},"text":"72 Stat. 1191","children":[],"tail":", 1202, which was classified to former sections 1666 and 1766 of this title, prior to repeal by sections 4(a) and 3(a)(3) of "},{"tag":"ref","attrib":{"href":"/us/pl/89/358"},"text":"Pub. L. 89–358","children":[],"tail":", respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc394b219-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/s1019/b"},"text":"Pub. L. 116–315, § 1019(b)","children":[],"tail":", inserted “relating to educational assistance under a law administered by the Secretary” after “made to a veteran or eligible person”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/s1019/a"},"text":"Pub. L. 116–315, § 1019(a)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “Whenever the Secretary finds that an overpayment has been made to a veteran or eligible person as the result of (1) the willful or negligent failure of an educational institution to report, as required under this chapter or chapter 34 or 35 of this title, to the Department of Veterans Affairs excessive absences from a course, or discontinuance or interruption of a course by the veteran or eligible person, or (2) the willful or negligent false certification by an educational institution, the amount of such overpayment shall constitute a liability of the educational institution to the United States.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1785"},"text":"section 1785 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “3684(c)” for “1784(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" substituted “5302” for “3102”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" substituted “Secretary” and “Department of Veterans Affairs” for “Administrator” and “Veterans’ Administration”, respectively, wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466"},"text":"Pub. L. 96–466","children":[],"tail":" designated existing provisions as subsecs. (b), (c), and (e), with minor changes in language, and added subsecs. (a) and (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/202"},"text":"Pub. L. 95–202","children":[],"tail":" inserted “, except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1784/b"},"text":"section 1784(b) of this title","children":[],"tail":",” after “recovered” in first sentence, and inserted last sentence providing that nothing in this section or any other provision of this title shall be construed as requiring any institution of higher learning to maintain daily attendance for any course leading to a standard college degree."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/540"},"text":"Pub. L. 92–540","children":[],"tail":" inserted “this chapter or” before “chapter 34 or 35”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc394b21a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc394b21b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466"},"text":"Pub. L. 96–466","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-10-01"},"text":"Oct. 1, 1980","children":[],"tail":", except as otherwise specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/96/466/s802/c"},"text":"section 802(c) of Pub. L. 96–466","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3452"},"text":"section 3452 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc394b21c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1977 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/202"},"text":"Pub. L. 95–202","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1977-11-23"},"text":"Nov. 23, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/202/s501"},"text":"section 501 of Pub. L. 95–202","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
