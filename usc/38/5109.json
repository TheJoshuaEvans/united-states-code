{"tag":"section","attrib":{"id":"idc3d05c2b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5109"},"text":null,"children":[{"tag":"num","attrib":{"value":"5109"},"text":"§ 5109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent medical opinions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3d05c2c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5109/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When, in the judgment of the Secretary, expert medical opinion, in addition to that available within the Department, is warranted by the medical complexity or controversy involved in a case being considered by the Department, the Secretary may secure an advisory medical opinion from one or more independent medical experts who are not employees of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d05c2d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5109/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall make necessary arrangements with recognized medical schools, universities, or clinics to furnish such advisory medical opinions. Any such arrangement shall provide that the actual selection of the expert or experts to give the advisory opinion in an individual case shall be made by an appropriate official of such institution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d05c2e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5109/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall furnish a claimant with notice that an advisory medical opinion has been requested under this section with respect to the claimant’s case and shall furnish the claimant with a copy of such opinion when it is received by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d05c2f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5109/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3d05c30-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5109/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board of Veterans’ Appeals shall remand a claim to direct the agency of original jurisdiction to obtain an advisory medical opinion from an independent medical expert under this section if the Board finds that the Veterans Benefits Administration should have exercised its discretion to obtain such an opinion.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d05c31-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5109/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board’s remand instructions shall include the questions to be posed to the independent medical expert providing the advisory medical opinion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3d05c32-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/687/dA/tI/s103/a/1"},"text":"Pub. L. 100–687, div. A, title I, § 103(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4107"},"text":"102 Stat. 4107","children":[],"tail":", § 3009; renumbered § 5109, "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/3"},"text":"Pub. L. 102–83, § 4(a)(3)","children":[],"tail":", (4), (b)(1), (2)(E), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404"},"text":"105 Stat. 404","children":[],"tail":", 405; "},{"tag":"ref","attrib":{"href":"/us/pl/115/55/s2/j"},"text":"Pub. L. 115–55, § 2(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-23"},"text":"Aug. 23, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1109"},"text":"131 Stat. 1109","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3d05c33-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3d05c34-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3d05c35-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/55"},"text":"Pub. L. 115–55","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3009"},"text":"section 3009 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/3"},"text":"Pub. L. 102–83, § 4(a)(3)","children":[],"tail":", (4), substituted “Department” for “Veterans’ Administration” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3d05c36-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3d05c37-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/55"},"text":"Pub. L. 115–55","children":[],"tail":" applicable to all claims for which the Secretary of Veterans Affairs provides notice of a decision under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5104"},"text":"section 5104 of this title","children":[],"tail":" on or after the later of 540 days after "},{"tag":"date","attrib":{"date":"2017-08-23"},"text":"Aug. 23, 2017","children":[],"tail":", or 30 days after the date on which the Secretary submits to Congress a certification of certain capabilities of the Department of Veterans Affairs to carry out the new appeals system established by "},{"tag":"ref","attrib":{"href":"/us/pl/115/55"},"text":"Pub. L. 115–55","children":[],"tail":" and to address appeals of decisions on legacy claims, with provision for early applicability of the new appeals system to certain claims, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/55/s2/x"},"text":"section 2(x) of Pub. L. 115–55","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of this title","children":[],"tail":", and bracketed note thereunder."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3d05c38-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1989-09-01"},"text":"Sept. 1, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/687/s401/a"},"text":"section 401(a) of Pub. L. 100–687","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7251"},"text":"section 7251 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
