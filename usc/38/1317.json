{"tag":"section","attrib":{"id":"idc2b94614-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1317"},"text":null,"children":[{"tag":"num","attrib":{"value":"1317"},"text":"§ 1317.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction on payments under this chapter","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2b94615-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1317/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (b), no person eligible for dependency and indemnity compensation by reason of any death occurring after ","children":[{"tag":"date","attrib":{"date":"1956-12-31"},"text":"December 31, 1956","children":[],"tail":", shall be eligible by reason of such death for any payments under (1) provisions of law administered by the Secretary providing for the payment of death compensation or death pension, or (2) subchapter I of chapter 81 of title 5."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2b94616-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1317/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A surviving spouse who is eligible for dependency and indemnity compensation may elect to receive death pension instead of such compensation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2b94617-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1132"},"text":"72 Stat. 1132","children":[],"tail":", § 417; "},{"tag":"ref","attrib":{"href":"/us/pl/91/291/s13/a"},"text":"Pub. L. 91–291, § 13(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1970-06-25"},"text":"June 25, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/332"},"text":"84 Stat. 332","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/197/s5"},"text":"Pub. L. 92–197, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-15"},"text":"Dec. 15, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/662"},"text":"85 Stat. 662","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/295/s4/11"},"text":"Pub. L. 97–295, § 4(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1305"},"text":"96 Stat. 1305","children":[],"tail":"; renumbered § 1317 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":", §§ 4(a)(1), 5(a), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/403"},"text":"105 Stat. 403","children":[],"tail":", 406; "},{"tag":"ref","attrib":{"href":"/us/pl/103/446/tI/s111/a"},"text":"Pub. L. 103–446, title I, § 111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4654"},"text":"108 Stat. 4654","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2b94618-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc2b94619-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc2b9461a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446"},"text":"Pub. L. 103–446","children":[],"tail":" designated existing provisions as subsec. (a), substituted “Except as provided in subsection (b), no person” for “No person”, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s417"},"text":"section 417 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/1"},"text":"Pub. L. 102–83, § 4(a)(1)","children":[],"tail":", substituted “administered by the Secretary” for “administered by the Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295"},"text":"Pub. L. 97–295","children":[],"tail":" substituted “subchapter I of chapter 81 of title 5” for “the Federal Employees’ Compensation Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1971—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/197"},"text":"Pub. L. 92–197","children":[],"tail":" struck out subsec. (a) which, among other provisions, restricted payment of dependency and indemnity compensation in certain cases where death of a veteran occurred while United States Government life insurance or National Service Life Insurance was in force under an in-service waiver of premiums continued under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s724"},"text":"section 724 of this title","children":[],"tail":", and designated subsec. (b) as entire section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/291"},"text":"Pub. L. 91–291","children":[],"tail":" designated material after “unless” in first sentence as cl. (1), added cl. (2), and in last sentence substituted “first sentence” for “preceding sentence”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc2b9461b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc2b9461c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1971 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/197"},"text":"Pub. L. 92–197","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1972-01-01"},"text":"Jan. 1, 1972","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/92/197/s10"},"text":"section 10 of Pub. L. 92–197","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1311"},"text":"section 1311 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc2b9461d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/291/s13/c"},"text":"Pub. L. 91–291, § 13(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-25"},"text":"June 25, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/332"},"text":"84 Stat. 332","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/91/291/s13/c"},"text":"“No dependency and indemnity compensation shall be payable to any person by virtue of the amendments made by subsection (a) of this section [amending this section] for any person prior to the effective date of this Act [","children":[{"tag":"date","attrib":{"date":"1970-06-25"},"text":"June 25, 1970","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/291/s14/a"},"text":"Pub. L. 91–291, § 14(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-25"},"text":"June 25, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/332"},"text":"84 Stat. 332","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/91/291/s14/a"},"text":"“The amendments made by this Act [amending this section and sections 705, 707, 745, 765, 767, 768, 769, 770, and 774 [now 1905, 1907, 1945, 1965, 1967, 1968, 1969, 1970, and 1974] of this title and enacting provisions set out as notes under this section] shall take effect as of the date of enactment [","children":[{"tag":"date","attrib":{"date":"1970-06-25"},"text":"June 25, 1970","children":[],"tail":"], except that sections 10 and 12 [amending sections 717 and 752 [now 1917 and 1952] of this title] shall take effect as of the first day of the first calendar month which begins more than six calendar months after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1970-06-25"},"text":"June 25, 1970","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc2b9461e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Dependency and Indemnity Compensation; Eligibility","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/92/197/s8"},"text":"Pub. L. 92–197, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-15"},"text":"Dec. 15, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/662"},"text":"85 Stat. 662","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/92/197/s8"},"text":"“Any person who before ","children":[{"tag":"date","attrib":{"date":"1972-01-01"},"text":"January 1, 1972","children":[],"tail":", was not eligible for dependency and indemnity compensation under such title by reason of the provisions of the prior "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s417/a"},"text":"section 417(a) of title 38","children":[],"tail":", United States Code, may elect, in such manner as the Administrator of Veterans’ Affairs shall prescribe, to receive dependency and indemnity compensation, and an election so made shall be final. A person receiving, or entitled to receive, death compensation on "},{"tag":"date","attrib":{"date":"1971-12-31"},"text":"December 31, 1971","children":[],"tail":", shall continue to receive death compensation, if otherwise eligible, in the absence of an election to receive dependency and indemnity compensation.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
