{"tag":"section","attrib":{"id":"idc298021b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1102"},"text":null,"children":[{"tag":"num","attrib":{"value":"1102"},"text":"§ 1102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special provisions relating to surviving spouses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc298021c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No compensation shall be paid to the surviving spouse of a veteran under this chapter unless such surviving spouse was married to such veteran—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc298021d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1102/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before the expiration of fifteen years after the termination of the period of service in which the injury or disease causing the death of the veteran was incurred or aggravated; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc298021e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1102/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for one year or more; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc298021f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1102/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any period of time if a child was born of the marriage, or was born to them before the marriage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2980220-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (a) shall not be applicable to any surviving spouse who, with respect to date of marriage, could have qualified as a surviving spouse for death compensation under any law administered by the Secretary in effect on ","children":[{"tag":"date","attrib":{"date":"1957-12-31"},"text":"December 31, 1957","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2980221-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1119"},"text":"72 Stat. 1119","children":[],"tail":", § 302; "},{"tag":"ref","attrib":{"href":"/us/pl/86/491"},"text":"Pub. L. 86–491","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-06-08"},"text":"June 8, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/161"},"text":"74 Stat. 161","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/77/tI/s101/a"},"text":"Pub. L. 90–77, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-08-31"},"text":"Aug. 31, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/178"},"text":"81 Stat. 178","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/433/tIV/s404/2"},"text":"Pub. L. 94–433, title IV, § 404(2)","children":[],"tail":"–(4), "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1378"},"text":"90 Stat. 1378","children":[],"tail":"; renumbered § 1102 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":", §§ 4(a)(1), 5(a), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/403"},"text":"105 Stat. 403","children":[],"tail":", 406.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2980222-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc2980223-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc2980224-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s302"},"text":"section 302 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/1"},"text":"Pub. L. 102–83, § 4(a)(1)","children":[],"tail":", substituted “administered by the Secretary” for “administered by the Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/433/s404/4"},"text":"Pub. L. 94–433, § 404(4)","children":[],"tail":", substituted “surviving spouses” for “widows” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/433/s404/2"},"text":"Pub. L. 94–433, § 404(2)","children":[],"tail":", substituted “surviving spouse of a veteran under this chapter unless such surviving spouse was married to such veteran” fo