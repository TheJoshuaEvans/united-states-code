{"tag":"section","attrib":{"id":"idc3ea9ae0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7105"},"text":null,"children":[{"tag":"num","attrib":{"value":"7105"},"text":"§ 7105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing of appeal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3ea9ae1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Appellate review shall be initiated by the filing of a notice of disagreement in the form prescribed by the Secretary. Each appellant will be accorded hearing and representation rights pursuant to the provisions of this chapter and regulations of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3ea9ae2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3ea9ae3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7105/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3ea9ae4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7105/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except in the case of simultaneously contested claims, a notice of disagreement shall be filed within one year from the date of the issuance of notice of the decision of the agency of original jurisdiction pursuant to section 5104, 5104B, or 5108 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3ea9ae5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7105/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A notice of disagreement postmarked before the expiration of the one-year period shall be accepted as timely filed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3ea9ae6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7105/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A question as to timeliness or adequacy of the notice of disagreement shall be decided by the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ea9ae7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7105/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3ea9ae8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7105/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notices of disagreement shall be in writing, shall identify the specific determination with which the claimant disagrees, and may be filed by the claimant, the claimant’s legal guardian, or such accredited representative, attorney, or authorized agent as may be selected by the claimant or legal guardian.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3ea9ae9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7105/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than one recognized organization, attorney, or agent may be recognized at any one time in the prosecution of a claim.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3ea9aea-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7105/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notices of disagreement shall be filed with the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ea9aeb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7105/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The notice of disagreement shall indicate whether the claimant requests—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3ea9aec-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7105/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a hearing before the Board, which shall include an opportunity to submit evidence in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7113/b"},"text":"section 7113(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3ea9aed-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7105/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an opportunity to submit additional evidence without a hearing before the Board, which shall include an opportunity to submit evidence in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7113/c"},"text":"section 7113(c) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3ea9aee-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7105/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review by the Board without a hearing or the submittal of additional evidence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ea9aef-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7105/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall develop a policy to permit a claimant to modify the information identified in the notice of disagreement after the notice of disagreement has been filed under this section pursuant to such requirements as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3ea9af0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If no notice of disagreement is filed in accordance with this chapter within the prescribed period, the action or decision of the agency of original jurisdiction shall become final and the claim shall not thereafter be readjudicated or allowed, except—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3ea9af1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7105/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a readjudication or allowance pursuant to a higher-level review that was requested in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5104B"},"text":"section 5104B of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ea9af2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7105/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as may otherwise be provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5108"},"text":"section 5108 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ea9af3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7105/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as may otherwise be provided in such regulations as are consistent with this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3ea9af4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7105/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board may dismiss any appeal which fails to identify the specific determination with which the claimant disagrees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3ea9af5-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/666/s1"},"text":"Pub. L. 87–666, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-19"},"text":"Sept. 19, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/553"},"text":"76 Stat. 553","children":[],"tail":", § 4005; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/576/tVII/s701/85"},"text":"Pub. L. 99–576, title VII, § 701(85)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3298"},"text":"100 Stat. 3298","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/687/dA/tII"},"text":"Pub. L. 100–687, div. A, title II","children":[],"tail":", §§ 203(b), 206, "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4111"},"text":"102 Stat. 4111","children":[],"tail":"; renumbered § 7105 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", (d)(1), "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":", 239; "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404"},"text":"105 Stat. 404","children":[],"tail":", 405; "},{"tag":"ref","attrib":{"href":"/us/pl/107/14/s8/a/16"},"text":"Pub. L. 107–14, § 8(a)(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-06-05"},"text":"June 5, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/35"},"text":"115 Stat. 35","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/154/tV/s501/a"},"text":"Pub. L. 112–154, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1190"},"text":"126 Stat. 1190","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/55/s2/q/1"},"text":"Pub. L. 115–55, § 2(q)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-23"},"text":"Aug. 23, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1111"},"text":"131 Stat. 1111","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/168/tVIII/s807/a/6"},"text":"Pub. L. 117–168, title VIII, § 807(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-10"},"text":"Aug. 10, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1806"},"text":"136 Stat. 1806","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3ea9af6-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3ea9af7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3ea9af8-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/168"},"text":"Pub. L. 117–168","children":[],"tail":" substituted “issuance” for “mailing”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/55/s2/q/1/F"},"text":"Pub. L. 115–55, § 2(q)(1)(F)","children":[],"tail":", struck out “notice of disagreement and” before “appeal” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/55/s2/q/1/A"},"text":"Pub. L. 115–55, § 2(q)(1)(A)","children":[],"tail":", substituted “Appellate review shall be initiated by the filing of a notice of disagreement in the form prescribed by the Secretary.” for “Appellate review will be initiated by a notice of disagreement and completed by a substantive appeal after a statement of the case is furnished as prescribed in this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/55/s2/q/1/B"},"text":"Pub. L. 115–55, § 2(q)(1)(B)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) Except in the case of simultaneously contested claims, notice of disagreement shall be filed within one year from the date of mailing of notice of the result of initial review or determination. Such notice, and appeals, must be in writing and be filed with the activity which entered the determination with which disagreement is expressed (hereinafter referred to as the “agency of original jurisdiction”). A notice of disagreement postmarked before the expiration of the one-year period will be accepted as timely filed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Notices of disagreement, and appeals, must be in writing and may be filed by the claimant, the claimant’s legal guardian, or such accredited representative, attorney, or authorized agent as may be selected by the claimant or legal guardian. Not more than one recognized organization, attorney, or agent will be recognized at any one time in the prosecution of a claim.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/55/s2/q/1/C"},"text":"Pub. L. 115–55, § 2(q)(1)(C)","children":[],"tail":", amended subsec. (c) generally. Prior to amendment, subsec. (c) read as follows: “If no notice of disagreement is filed in accordance with this chapter within the prescribed period, the action or determination shall become final and the claim will not thereafter be reopened or allowed, except as may otherwise be provided by regulations not inconsistent with this title.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/55/s2/q/1/D"},"text":"Pub. L. 115–55, § 2(q)(1)(D)","children":[],"tail":", added subsec. (d) and struck out former subsec. (d) which related to development and review actions, statement of the case, and dismissal of appeal."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/55/s2/q/1/E"},"text":"Pub. L. 115–55, § 2(q)(1)(E)","children":[],"tail":", struck out subsec. (e) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) If, either at the time or after the agency of original jurisdiction receives a substantive appeal, the claimant or the claimant’s representative, if any, submits evidence to either the agency of original jurisdiction or the Board of Veterans’ Appeals for consideration in connection with the issue or issues with which disagreement has been expressed, such evidence shall be subject to initial review by the Board unless the claimant or the claimant’s representative, as the case may be, requests in writing that the agency of original jurisdiction initially review such evidence.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) A request for review of evidence under paragraph (1) shall accompany the submittal of the evidence.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/154"},"text":"Pub. L. 112–154","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/14"},"text":"Pub. L. 107–14","children":[],"tail":" substituted “hereinafter” for “hereafter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/b/1"},"text":"Pub. L. 102–40, § 402(b)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4005"},"text":"section 4005 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/d/1"},"text":"Pub. L. 102–40, § 402(d)(1)","children":[],"tail":", substituted “5701” for “3301”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/687/s206/a"},"text":"Pub. L. 100–687, § 206(a)","children":[],"tail":", substituted “shall prepare a statement of the case. A statement of the case shall include the following:” for “will prepare a statement of the case consisting of—”, added subpars. (A) to (C), and struck out former subpars. (A) to (C) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) A summary of the evidence in the case pertinent to the issue or issues with which disagreement has been expressed;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) A citation or discussion of the pertinent law, regulations, and, where applicable, the provisions of the Schedule for Rating Disabilities;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) The decision on such issue or issues and a summary of the reasons therefor.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/687/s206/b"},"text":"Pub. L. 100–687, § 206(b)","children":[],"tail":", amended par. (4) generally. Prior to amendment, par. (4) read as follows: “The appellant will be presumed to be in agreement with any statement of fact contained in the statement of the case to which no exception is taken.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/687/s203/b"},"text":"Pub. L. 100–687, § 203(b)","children":[],"tail":", struck out “will base its decision on the entire record and” after “of Veterans’ Appeals”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576/s701/85"},"text":"Pub. L. 99–576, § 701(85)","children":[],"tail":", substituted “the claimant’s” for “his” and “the claimant or legal guardian” for “him”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576/s701/85/A"},"text":"Pub. L. 99–576, § 701(85)(A)","children":[],"tail":", substituted “the claimant’s” for “his”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3ea9af9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3ea9afa-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/55"},"text":"Pub. L. 115–55","children":[],"tail":" applicable to all claims for which the Secretary of Veterans Affairs provides notice of a decision under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5104"},"text":"section 5104 of this title","children":[],"tail":" on or after the later of 540 days after "},{"tag":"date","attrib":{"date":"2017-08-23"},"text":"Aug. 23, 2017","children":[],"tail":", or 30 days after the date on which the Secretary submits to Congress a certification of certain capabilities of the Department of Veterans Affairs to carry out the new appeals system established by "},{"tag":"ref","attrib":{"href":"/us/pl/115/55"},"text":"Pub. L. 115–55","children":[],"tail":" and to address appeals of decisions on legacy claims, with provision for early applicability of the new appeals system to certain claims, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/55/s2/x"},"text":"section 2(x) of Pub. L. 115–55","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of this title","children":[],"tail":", and bracketed note thereunder."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3ea9afb-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/154/tV/s501/b"},"text":"Pub. L. 112–154, title V, § 501(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1190"},"text":"126 Stat. 1190","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/154/tV/s501/b"},"text":"“Subsection (e) of such section [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7105/e"},"text":"38 U.S.C. 7105(e)","children":[],"tail":"], as added by subsection (a), shall take effect on the date that is 180 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":"], and shall apply with respect to claims for which a substantive appeal is filed on or after the date that is 180 days after the date of the enactment of this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3ea9afc-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/687"},"text":"Pub. L. 100–687","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1989-01-01"},"text":"Jan. 1, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/687/s401/d"},"text":"section 401(d) of Pub. L. 100–687","children":[],"tail":" set out as an Effective Date note unde