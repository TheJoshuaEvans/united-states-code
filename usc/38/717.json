{"tag":"section","attrib":{"id":"idc290d6a2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s717"},"text":null,"children":[{"tag":"num","attrib":{"value":"717"},"text":"§ 717.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on administrative leave","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc290d6a3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s717/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), the Secretary may not place any covered individual on administrative leave, or any other type of paid non-duty status without charge to leave, for more than a total of 14 days during any 365-day period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc290d6a4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s717/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may waive the limitation under subsection (a) and extend the administrative leave or other paid non-duty status without charge to leave of a covered individual placed on such leave or status under subsection (a) if the Secretary submits to the Committees on Veterans’ Affairs of the Senate and House of Representatives a detailed explanation of the reasons the individual was placed on administrative leave or other paid non-duty status without charge to leave and the reasons for the extension of such leave or status. Such explanation shall include the job title and grade of the covered individual and the location where the individual is employed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc290d6a5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s717/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Individual","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “covered individual” means an employee of the Department—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc290d6a6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s717/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is subject to an investigation for purposes of determining whether such individual should be subject to any disciplinary action under this title or title 5; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc290d6a7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s717/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" against whom any disciplinary action is proposed or initiated under this title or title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc290d6a8-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/315/tV/s503/a/1"},"text":"Pub. L. 114–315, title V, § 503(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1568"},"text":"130 Stat. 1568","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc290d6a9-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc290d6aa-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc290d6ab-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 717 and 718 were renumbered sections 1917 and 1918 of this title, respectively.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc290d6ac-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc290d6ad-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/315/tV/s503/b"},"text":"Pub. L. 114–315, title V, § 503(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1568"},"text":"130 Stat. 1568","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/315/tV/s503/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s717"},"text":"Section 717 of title 38","children":[],"tail":", United States Code, as added by subsection (a)(1), shall apply with respect to any 365-day period beginning on or after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
