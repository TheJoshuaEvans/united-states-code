{"tag":"section","attrib":{"id":"idc41ca67c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8102"},"text":null,"children":[{"tag":"num","attrib":{"value":"8102"},"text":"§ 8102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of medical facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc41ca67d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall provide medical facilities for veterans entitled to hospital, nursing home, or domiciliary care or medical services under this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc41ca67e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No medical facility may be constructed or otherwise acquired or altered except in accordance with the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc41ca67f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out this subchapter, the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc41ca680-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8102/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide for the construction and acquisition of medical facilities in a manner that results in the equitable distribution of such facilities throughout the United States, taking into consideration the comparative urgency of the need for the services to be provided in the case of each particular facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc41ca681-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8102/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall give due consideration to excellence of architecture and design.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc41ca682-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8102/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In considering the need for any project for the construction, alteration, or acquisition (other than by exchange) of a medical facility which is expected to involve a total expenditure of more than $2,000,000, the Secretary shall give consideration to the sharing of health-care resources with the Department of Defense under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s8111"},"text":"section 8111 of this title","children":[],"tail":" as an alternative to all or part of such project."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc41ca683-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/22/tIII/s301/a"},"text":"Pub. L. 96–22, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-06-13"},"text":"June 13, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/55"},"text":"93 Stat. 55","children":[],"tail":", § 5002; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/576/tII/s221/a"},"text":"Pub. L. 99–576, title II, § 221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3259"},"text":"100 Stat. 3259","children":[],"tail":"; renumbered § 8102 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", (d)(1), "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":", 239; "},{"tag":"ref","attrib":{"href":"/us/pl/102/54/s14/f/2"},"text":"Pub. L. 102–54, § 14(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-06-13"},"text":"June 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/287"},"text":"105 Stat. 287","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404"},"text":"105 Stat. 404","children":[],"tail":", 405.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc41ca684-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc41ca685-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc41ca686-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/b/1"},"text":"Pub. L. 102–40, § 402(b)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5002"},"text":"section 5002 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/54"},"text":"Pub. L. 102–54","children":[],"tail":" amended subsec. (d) as in effect immediately before the enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" by substituting “section 5011” for “section 5001”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/d/1"},"text":"Pub. L. 102–40, § 402(d)(1)","children":[],"tail":", amended subsec. (d), as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/102/54"},"text":"Pub. L. 102–54","children":[],"tail":", by substituting “8111” for “5011”. See above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576"},"text":"Pub. L. 99–576","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc41ca687-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc41ca688-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1979-10-01"},"text":"Oct. 1, 1979","children":[],"tail":", but not applicable with respect to the acquisition, construction, or alteration of any medical facilities if the acquisition, construction, or alteration (not including exchange) was approved by the President before "},{"tag":"date","attrib":{"date":"1979-10-01"},"text":"Oct. 1, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/22/s302"},"text":"section 302 of Pub. L. 96–22","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s8101"},"text":"section 8101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
