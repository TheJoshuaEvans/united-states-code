{"tag":"section","attrib":{"id":"idc313e9a4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1813"},"text":null,"children":[{"tag":"num","attrib":{"value":"1813"},"text":"§ 1813.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health care","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc313e9a5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1813/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Needed Care","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall provide an eligible child such health care as the Secretary determines is needed by the child for that child’s covered birth defects or any disability that is associated with those birth defects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc313e9a6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1813/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority for Care To Be Provided Directly or by Contract","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may provide health care under this section directly or by contract or other arrangement with a health care provider.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc313e9a7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1813/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the definitions in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1803/c"},"text":"section 1803(c) of this title","children":[],"tail":" shall apply with respect to the provision of health care under this section, except that for such purposes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc313e9a8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1813/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reference to “specialized spina bifida clinic” in paragraph (2) of that section shall be treated as a reference to a specialized clinic treating the birth defect concerned under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc313e9a9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1813/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reference to “vocational training under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1804"},"text":"section 1804 of this title","children":[],"tail":"” in paragraph (8) of that section shall be treated as a reference to vocational training under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1814"},"text":"section 1814 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc313e9aa-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/419/tIV/s401/a"},"text":"Pub. L. 106–419, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1857"},"text":"114 Stat. 1857","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc313e9ab-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc313e9ac-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc313e9ad-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1813 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3713"},"text":"section 3713 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 1813, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1211"},"text":"72 Stat. 1211","children":[],"tail":", automatically guaranteed loans made to a veteran if made for the purpose of purchasing business property, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/93/569/s7/a"},"text":"Pub. L. 93–569, § 7(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-12-31"},"text":"Dec. 31, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1866"},"text":"88 Stat. 1866","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
