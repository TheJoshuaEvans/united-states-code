{"tag":"section","attrib":{"id":"idc31d86c0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1928"},"text":null,"children":[{"tag":"num","attrib":{"value":"1928"},"text":"§ 1928.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority for payment of interest on settlements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc31d86c1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1928/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subsection (b) of this section, the Secretary may pay interest on the proceeds of a participating National Service Life Insurance, Veterans’ Special Life Insurance, and Veterans Reopened Insurance policy from the date the policy matures to the date of payment of the proceeds to the beneficiary or, in the case of an endowment policy, to the policyholder.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc31d86c2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1928/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc31d86c3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1928/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may pay interest under subsection (a) of this section only if the Secretary determines that the payment of such interest is administratively and actuarially sound for the settlement option involved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc31d86c4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1928/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Interest paid under subsection (a) of this section shall be at the rate that is established by the Secretary for dividends held on credit or deposit in policyholders’ accounts under the insurance program involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc31d86c5-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/687/dB/tXIV/s1401/a/1"},"text":"Pub. L. 100–687, div. B, title XIV, § 1401(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4128"},"text":"102 Stat. 4128","children":[],"tail":", § 728; renumbered § 1928 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":", §§ 4(b)(1), (2)(E), 5(a), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404-406"},"text":"105 Stat. 404–406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc31d86c6-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc31d86c7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc31d86c8-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s728"},"text":"section 728 of this title","children":[],"tail":" as this section and substituted “Secretary” for “Administrator” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc31d86c9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc31d86ca-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/687/dB/tXIV/s1401/a/3"},"text":"Pub. L. 100–687, div. B, title XIV, § 1401(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4129"},"text":"102 Stat. 4129","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/687/dB/tXIV/s1401/a/3"},"text":"“The amendments made by this subsection [enacting this section and section 763 [now 1963] of this title] shall take effect with respect to insurance policies maturing after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
