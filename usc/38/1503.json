 Former par. (3) redesignated (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/588/s102/a/4"},"text":"Pub. L. 95–588, § 102(a)(4)","children":[],"tail":", (6), added par. (4) and struck out former par. (4) which related to payments under servicemen’s life insurance or servicemen’s indemnity."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/588/s102/a/4"},"text":"Pub. L. 95–588, § 102(a)(4)","children":[],"tail":", (7), redesignated par. (8) as (5) and struck out former par. (5) which related to lump sum death payments."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/588/s102/a/4"},"text":"Pub. L. 95–588, § 102(a)(4)","children":[],"tail":", (9), redesignated par. (10) as (6) and struck out former par. (6) which related to the ten per cent exclusion for individuals under public or private retirement, annuity, endowment, or similar programs."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/588/s102/a/11"},"text":"Pub. L. 95–588, § 102(a)(11)","children":[],"tail":", redesignated par. (15) as (7). Former par. (7) redesignated (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/588/s102/a/13"},"text":"Pub. L. 95–588, § 102(a)(13)","children":[],"tail":", added par. (8). Former par. (8) redesignated (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/588/s102/a/8"},"text":"Pub. L. 95–588, § 102(a)(8)","children":[],"tail":", (13), added par. (9) and struck out former par. (9) which related to payments for final illness and burial."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/588/s102/a/13"},"text":"Pub. L. 95–588, § 102(a)(13)","children":[],"tail":", added par. (10). Former subsec. (10) redesignated (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(11) to (14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/588/s102/a/10"},"text":"Pub. L. 95–588, § 102(a)(10)","children":[],"tail":", struck out pars. (11) to (14) which related to payments for discharge of jury duty, educational assistance allowances, bonuses based on service in the Armed Forces, and indebtednesses secured by mortgages, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(15). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/588/s102/a/11"},"text":"Pub. L. 95–588, § 102(a)(11)","children":[],"tail":", redesignated par. (15) as (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(16), (17). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/588/s102/a/12"},"text":"Pub. L. 95–588, § 102(a)(12)","children":[],"tail":", struck out pars. (16) and (17) which related to payments received by retired persons and payments of annuities, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/588/s102/b"},"text":"Pub. L. 95–588, § 102(b)","children":[],"tail":", struck out former subsec. (c) which related to the power of the Administrator to exclude from income amounts paid by a veteran, surviving spouse, or child for unusual medical expenses."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/169/s106/3"},"text":"Pub. L. 94–169, § 106(3)","children":[],"tail":", (4), substituted “spouse” for “wife”, “such veteran’s” for “his” and “surviving spouse” for “widow” in introductory clause and “such veteran’s” for “his” in subcls. (A), (B) and (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/169/s106/5"},"text":"Pub. L. 94–169, § 106(5)","children":[],"tail":", substituted “such veteran’s” for “his” in subcl. (A) and “surviving spouse” and “spouse” for “widow” and “wife”, respectively, in subcl. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/169/s106/6"},"text":"Pub. L. 94–169, § 106(6)","children":[],"tail":", substituted “such veteran’s surviving spouse” for “his widow”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(16). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/169"},"text":"Pub. L. 94–169","children":[],"tail":", §§ 101(2)(A), 106(7), inserted “and” after “as amended;”, and substituted “such employee’s” for “his”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/169/s106/8"},"text":"Pub. L. 94–169, § 106(8)","children":[],"tail":", substituted “surviving spouse” for “widow”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Par. (17). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/425"},"text":"Pub. L. 92–425","children":[],"tail":" substituted “subchapter I of chapter 73 of title 10” for “chapter 73 of title 10”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1971—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/198"},"text":"Pub. L. 92–198","children":[],"tail":" designated existing provisions as subsec. (a) and added subsecs. (b) and (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/588/s7/1"},"text":"Pub. L. 91–588, § 7(1)","children":[],"tail":", inserted reference to servicemen’s group life insurance."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (14) to (17). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/588/s7/3"},"text":"Pub. L. 91–588, § 7(3)","children":[],"tail":", added pars. (14) to (17)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—Par. (7). ","children":[{"tag":"ref","at