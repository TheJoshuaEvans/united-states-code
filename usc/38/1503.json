"href":"/us/stat/129/538"},"text":"129 Stat. 538","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2bbb794-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc2bbb795-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc2bbb796-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 2, 6012(a), and 7703 of the Internal Revenue Code of 1986, referred to in subsec. (a)(10)(A), are classified to sections 2, 6012(a), and 7703 of Title 26, Internal Revenue Code, respectively.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc2bbb797-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior section 1503 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3103"},"text":"section 3103 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 1503, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/138/s1"},"text":"Pub. L. 89–138, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-08-26"},"text":"Aug. 26, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/577"},"text":"79 Stat. 577","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/91/24/s8"},"text":"Pub. L. 91–24, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-06-11"},"text":"June 11, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"