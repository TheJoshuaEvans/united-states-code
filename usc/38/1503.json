{"tag":"section","attrib":{"id":"idc2bbb77a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1503"},"text":null,"children":[{"tag":"num","attrib":{"value":"1503"},"text":"§ 1503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations with respect to annual income","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2bbb77b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In determining annual income under this chapter, all payments of any kind or from any source (including salary, retirement or annuity payments, or similar income, which has been waived, irrespective of whether the waiver was made pursuant to statute, contract, or otherwise) shall be included except—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2bbb77c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1503/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" donations from public or private relief or welfare organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2bbb77d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1503/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payments under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2bbb77e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1503/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" amounts equal to amounts paid by a spouse of a veteran for the expenses of such veteran’s last illness, and by a surviving spouse or child of a deceased veteran for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2bbb77f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1503/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such veteran’s just debts,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2bbb780-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1503/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expenses of such veteran’s last illness, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2bbb781-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1503/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expenses of such veteran’s burial to the extent such expenses are not reimbursed under chapter 23 of this title;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2bbb782-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1503/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" amounts equal to amounts paid—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2bbb783-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1503/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by a veteran for the last illness and burial of such veteran’s deceased spouse or child, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2bbb784-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1503/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the spouse of a living veteran or the surviving spouse of a deceased veteran for the last illness and burial of a child of such veteran;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2bbb785-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1503/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" payments regarding reimbursements of any kind (including insurance settlement payments) for expenses related to the repayment, replacement, or repair of equipment, vehicles, items, money, or property resulting from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2bbb786-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1503/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any accident (as defined by the Secretary), but the amount excluded under this subparagraph shall not exceed the greater of the fair market value or reasonable replacement value of the equipment or vehicle involved at the time immediately preceding the accident;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2bbb787-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1503/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any theft or loss (as defined by the Secretary), but the amount excluded under this subparagraph shall not exceed the greater of the fair market value or reasonable replacement value of the item or the amount of the money (including legal tender of the United States or of a foreign country) involved at the time immediately preceding the theft or loss; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2bbb788-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1503/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any casualty loss (as defined by the Secretary), but the amount excluded under this subparagraph shall not exceed the greater of the fair market value or reasonable replacement value of the property involved at the time immediately preceding the casualty loss;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2bbb789-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1503/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" profit realized from the disposition of real or personal property other than in the course of a business;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2bbb78a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1503/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts in joint accounts in banks and similar institutions acquired by reason of death of other joint owner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2bbb78b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1503/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts equal to amounts paid by a veteran, veterans’ spouse, or surviving spouse or by or on behalf of a veteran’s child for unreimbursed medical expenses, to the extent that such amounts exceed 5 percent of the maximum annual rate of pension (including any amount of increased pension payable on account of family members but not including any amount of pension payable because a person is in need of regular aid and attendance or because a person is permanently house­bound) payable to such veteran, surviving spouse, or child;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2bbb78c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1503/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a veteran or surviving spouse pursuing a course of education or vocational rehabilitation or training, amounts equal to amounts paid by such veteran or surviving spouse for such course of education or vocational rehabilitation or training, including (A) amounts paid for tuition, fees, books, and materials, and (B) in the case of such a veteran or surviving spouse in need of regular aid and attendance, unreimbursed amounts paid for unusual transportation expenses in connection with the pursuit of such course of education or vocational rehabilitation or training, to the extent that such amounts exceed the reasonable expenses which would have been incurred by a nondisabled person using an appropriate means of transportation (public transportation, if reasonably available);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2bbb78d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1503/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a child, any current-work income received during the year, to the extent that the total amount of such income does not exceed an amount equal to the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2bbb78e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1503/a/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lowest amount of gross income for which an income tax return is required under section 6012(a) of the Internal Revenue Code of 1986, to be filed by an individual who is not married (as determined under section 7703 of such Code), is not a surviving spouse (as defined in section 2(a) of such Code), and is not a head of household (as defined in section 2(b) of such Code); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2bbb78f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1503/a/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the child is pursuing a course of postsecondary education or vocational rehabilitation or training, the amount paid by such child for such course of education or vocational rehabilitation or training, including the amount paid for tuition, fees, books, and materials;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2bbb790-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1503/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment of a monetary amount of up to $5,000 to a veteran from a State or municipality that is paid as a veterans’ benefit due to injury or disease; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2bbb791-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1503/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lump-sum proceeds of any life insurance policy on a veteran, for purposes of pension under subchapter III of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2bbb792-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Where a fraction of a dollar is involved, annual income shall be fixed at the next lower dollar.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2bbb793-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1134"},"text":"72 Stat. 1134","children":[],"tail":", § 503; "},{"tag":"ref","attrib":{"href":"/us/pl/86/211/s2/a"},"text":"Pub. L. 86–211, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-08-29"},"text":"Aug. 29, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/432"},"text":"73 Stat. 432","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/268/s1/b"},"text":"Pub. L. 87–268, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-21"},"text":"Sept. 21, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/566"},"text":"75 Stat. 566","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/664/s1"},"text":"Pub. L. 88–664, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-10-13"},"text":"Oct. 13, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1094"},"text":"78 Stat. 1094","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/77/tI/s103"},"text":"Pub. L. 90–77, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-08-31"},"text":"Aug. 31, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/178"},"text":"81 Stat. 178","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/588/s7"},"text":"Pub. L. 91–588, § 7","children":[],"tail":", "