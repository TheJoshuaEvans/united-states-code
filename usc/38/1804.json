{"tag":"section","attrib":{"id":"idc313e95b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1804"},"text":null,"children":[{"tag":"num","attrib":{"value":"1804"},"text":"§ 1804.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vocational training and rehabilitation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc313e95c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1804/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pursuant to such regulations as the Secretary may prescribe, the Secretary may provide vocational training under this section to a child of a Vietnam veteran who is suffering from spina bifida if the Secretary determines that the achievement of a vocational goal by such child is reasonably feasible.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc313e95d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1804/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any program of vocational training for a child under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc313e95e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1804/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be designed in consultation with the child in order to meet the child’s individual needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc313e95f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1804/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be set forth in an individualized written plan of vocational rehabilitation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc313e960-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1804/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be designed and developed before the date specified in subsection (d)(3) so as to permit the beginning of the program as of the date specified in that subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc313e961-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1804/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc313e962-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1804/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A vocational training program for a child under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc313e963-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1804/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall consist of such vocationally oriented services and assistance, including such placement and post-placement services and personal and work adjustment training, as the Secretary determines are necessary to enable the child to prepare for and participate in vocational training or employment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc313e964-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1804/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include a program of education at an institution of higher learning if the Secretary determines that the program of education is predominantly vocational in content.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc313e965-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1804/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A vocational training program under this section may not include the provision of any loan or subsistence allowance or any automobile adaptive equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc313e966-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1804/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc313e967-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1804/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2) and subject to subsection (e)(2), a vocational training program under this section may not exceed 24 months.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc313e968-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1804/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may grant an extension of a vocational training program for a child under this section for up to 24 additional months if the Secretary determines that the extension is necessary in order for the child to achieve a vocational goal identified (before the end of the first 24 months of such program) in the written plan of vocational rehabilitation formulated for the child pursuant to subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc313e969-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1804/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A vocational training program under this section may begin on the child’s 18th birthday, or on the successful completion of the child’s secondary schooling, whichever first occurs, except that, if the child is above the age of compulsory school attendance under applicable State law and the Secretary determines that the child’s best interests will be served thereby, the vocational training program may begin before the child’s 18th birthday.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc313e96a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1804/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc313e96b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1804/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A child who is pursuing a program of vocational training under this section and is also eligible for assistance under a program under chapter 35 of this title may not receive assistance under both such programs concurrently. The child shall elect (in such form and manner as the Secretary may prescribe) the program under which the child is to receive assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc313e96c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1804/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The aggregate period for which a child may receive assistance under this section and chapter 35 of this title may not exceed 48 months (or the part-time equivalent thereof).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc313e96d-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/204/tIV/s421/b/1"},"text":"Pub. L. 104–204, title IV, § 421(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-26"},"text":"Sept. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2924"},"text":"110 Stat. 2924","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/114/tIV/s404/c"},"text":"Pub. L. 105–114, title IV, § 404(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2295"},"text":"111 Stat. 2295","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/183/tVII/s708/a/3"},"text":"Pub. L. 108–183, title VII, § 708(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-16"},"text":"Dec. 16, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2673"},"text":"117 Stat. 2673","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc313e96e-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc313e96f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc313e970-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1804 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3704"},"text":"section 3704 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc313e971-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/183"},"text":"Pub. L. 108–183","children":[],"tail":" substituted “section” for “subsection”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/114/s404/c/1"},"text":"Pub. L. 105–114, § 404(c)(1)","children":[],"tail":", substituted “shall—” for “shall be designed in consultation with the child in order to meet the child’s individual needs and shall be set forth in an individualized written plan of vocational rehabilitation.” and added pars. (1) to (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/114/s404/c/2"},"text":"Pub. L. 105–114, § 404(c)(2)","children":[],"tail":", substituted “higher learning” for “higher education”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/114/s404/c/3"},"text":"Pub. L. 105–114, § 404(c)(3)","children":[],"tail":", added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc313e972-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc313e973-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/114/tIV/s404/d"},"text":"Pub. L. 105–114, title IV, § 404(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2295"},"text":"111 Stat. 2295","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/114/tIV/s404/d"},"text":"“The amendments made by this section [amending this section and sections 1801 and 1806 of this title] shall take effect as of ","children":[{"tag":"date","attrib":{"date":"1997-10-01"},"text":"October 1, 1997","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
