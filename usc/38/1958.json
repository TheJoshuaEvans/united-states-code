{"tag":"section","attrib":{"id":"idc31fd055-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1958"},"text":null,"children":[{"tag":"num","attrib":{"value":"1958"},"text":"§ 1958.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statutory total permanent disability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Without prejudice to any other cause of disability, the permanent loss of the use of both feet, of both hands, or of both eyes, or of one foot and one hand, or of one foot and one eye, or of one hand and one eye, or the loss of hearing of both ears, or the organic loss of speech, shall be deemed total permanent disability for insurance purposes. This section shall be deemed to be in effect on and after ","children":[{"tag":"date","attrib":{"date":"1917-04-06"},"text":"April 6, 1917","children":[],"tail":", and shall apply only to automatic insurance, yearly renewable term insurance, and United States Government life insurance issued prior to "},{"tag":"date","attrib":{"date":"1936-12-15"},"text":"December 15, 1936","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc31fd056-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1163"},"text":"72 Stat. 1163","children":[],"tail":", § 758; renumbered § 1958, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc31fd057-47c4-11f1-bf59-9680b1