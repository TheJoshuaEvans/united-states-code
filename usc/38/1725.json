{"tag":"section","attrib":{"id":"idc308024b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725"},"text":null,"children":[{"tag":"num","attrib":{"value":"1725"},"text":"§ 1725.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement for emergency treatment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc308024c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc308024d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subsections (c) and (d), the Secretary shall reimburse a veteran described in subsection (b) for the reasonable value of emergency treatment furnished the veteran in a non-Department facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc308024e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In any case in which reimbursement is authorized under subsection (a)(1), the Secretary, in the Secretary’s discretion, may, in lieu of reimbursing the veteran, make payment of the reasonable value of the furnished emergency treatment directly—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc308024f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a hospital or other health care provider that furnished the treatment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3080250-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the person or organization that paid for such treatment on behalf of the veteran.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3080251-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3080252-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A veteran referred to in subsection (a)(1) is an individual who is an active Department health-care participant who is personally liable for emergency treatment furnished the veteran in a non-Department facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3080253-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A veteran is an active Department health-care participant if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3080254-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the veteran is enrolled in the health care system established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1705/a"},"text":"section 1705(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3080255-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the veteran received care under this chapter within the 24-month period preceding the furnishing of such emergency treatment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3080256-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A veteran is personally liable for emergency treatment furnished the veteran in a non-Department facility if the veteran—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3080257-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is financially liable to the provider of emergency treatment for that treatment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3080258-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has no entitlement to care or services under a health-plan contract (determined, in the case of a health-plan contract as defined in subsection (h)(2)(B) or (h)(2)(C), without regard to any requirement or limitation relating to eligibility for care or services from any department or agency of the United States);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3080259-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has no other contractual or legal recourse against a third party that would, in whole, extinguish such liability to the provider; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc308025a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not eligible for reimbursement for medical care or services under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1728"},"text":"section 1728 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc308025b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations on Reimbursement","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc308025c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary, in accordance with regulations prescribed by the Secretary, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc308025d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish the maximum amount payable under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc308025e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" delineate the circumstances under which such payments may be made, to include such requirements on requesting reimbursement as the Secretary shall establish; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc308025f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that in no event may a payment under that subsection include any amount for which the veteran is not personally liable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3080260-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (1), the Secretary may provide reimbursement under this section only after the veteran or the provider of emergency treatment has exhausted without success all claims and remedies reasonably available to the veteran or provider against a third party for payment of such treatment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3080261-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payment by the Secretary under this section on behalf of a veteran to a provider of emergency treatment shall, unless rejected and refunded by the provider within 30 days of receipt, extinguish any liability on the part of the veteran for that treatment. Neither the absence of a contract or agreement between the Secretary and the provider nor any provision of a contract, agreement, or assignment to the contrary shall operate to modify, limit, or negate the requirement in the preceding sentence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3080262-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3080263-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the veteran has contractual or legal recourse against a third party that would only, in part, extinguish the veteran’s liability to the provider of the emergency treatment, and payment for the treatment may be made both under subsection (a) and by the third party, the amount payable for such treatment under such subsection shall be the amount by which the costs for the emergency treatment exceed the amount payable or paid by the third party, except that the amount payable may not exceed the maximum amount payable established under paragraph (1)(A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3080264-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any case in which a third party is financially responsible for part of the veteran’s emergency treatment expenses, the Secretary shall be the secondary payer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3080265-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A payment in the amount payable under subparagraph (A) shall be considered payment in full and shall extinguish the veteran’s liability to the provider.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3080266-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not reimburse a veteran under this section for any copayment or similar payment that the veteran owes the third party or for which the veteran is responsible under a health-plan contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3080267-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Independent Right of Recovery","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3080268-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In accordance with regulations prescribed by the Secretary, the United States shall have the independent right to recover any amount paid under this section when, and to the extent that, a third party subsequently makes a payment for the same emergency treatment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3080269-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any amount paid by the United States to the veteran (or the veteran’s personal representative, successor, dependents, or survivors) or to any other person or organization paying for such treatment shall constitute a lien in favor of the United States against any recovery the payee subsequently receives from a third party for the same treatment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc308026a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any amount paid by the United States to the provider that furnished the veteran’s emergency treatment shall constitute a lien against any subsequent amount the provider receives from a third party for the same emergency treatment for which the United States made payment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc308026b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The veteran (or the veteran’s personal representative, successor, dependents, or survivors) shall ensure that the Secretary is promptly notified of any payment received from any third party for emergency treatment furnished to the veteran. The veteran (or the veteran’s personal representative, successor, dependents, or survivors) shall immediately forward all documents relating to such payment, cooperate with the Secretary in the investigation of such payment, and assist the Secretary in enforcing the United States right to recover any payment made under subsection (c)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc308026c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, in the Secretary’s discretion, may waive recovery of a payment made to a veteran under this section that is otherwise required by subsection (d)(1) when the Secretary determines that such waiver would be in the best interest of the United States, as defined by regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc308026d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submittal of Claims for Direct Payment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual or entity seeking payment under subsection (a)(2) for treatment provided to a veteran in lieu of reimbursement to the veteran shall submit a claim for such payment not later than 180 days after the latest date on which such treatment was provided.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc308026e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Hold Harmless","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"No veteran described in subsection (b) may be held liable for payment for emergency treatment described in such subsection if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc308026f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a claim for direct payment was submitted by an individual or entity under subsection (f); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3080270-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such claim was submitted after the deadline established by such subsection due to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3080271-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an administrative error made by the individual or entity, such as submission of the claim to the wrong Federal agency, under the wrong reimbursement authority (such as ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1728"},"text":"section 1728 of this title","children":[],"tail":"), or submission of the claim after the deadline; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3080272-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an administrative error made by the Department, such as misplacement of a paper claim or deletion of an electronic claim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3080273-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3080274-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “emergency treatment” means medical care or services furnished, in the judgment of the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3080275-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when Department or other Federal facilities are not feasibly available and an attempt to use them beforehand would not be reasonable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3080276-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when such care or services are rendered in a medical emergency of such nature that a prudent layperson reasonably expects that delay in seeking immediate medical attention would be hazardous to life or health; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3080277-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/h/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" until—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc3080278-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/h/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such time as the veteran can be transferred safely to a Department facility or other Federal facility and such facility is capable of accepting such transfer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3080279-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/h/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such time as a Department facility or other Federal facility accepts such transfer if—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc308027a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/h/1/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the time the veteran could have been transferred safely to a Department facility or other Federal facility, no Department facility or other Federal facility agreed to accept such transfer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc308027b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/h/1/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the non-Department facility in which such medical care or services was furnished made and documented reasonable attempts to transfer the veteran to a Department facility or other Federal facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc308027c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “health-plan contract” includes any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc308027d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An insurance policy or contract, medical or hospital service agreement, membership or subscription contract, or similar arrangement under which health services for individuals are provided or the expenses of such services are paid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc308027e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An insurance program described in section 1811 of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395c"},"text":"42 U.S.C. 1395c","children":[],"tail":") or established by section 1831 of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395j"},"text":"42 U.S.C. 1395j","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc308027f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State plan for medical assistance approved under title XIX of such Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396"},"text":"42 U.S.C. 1396","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3080280-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/h/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A workers’ compensation law or plan described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1729/a/2/A"},"text":"section 1729(a)(2)(A) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3080281-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “third party” means any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3080282-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/h/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Federal entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3080283-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/h/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State or political subdivision of a State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3080284-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/h/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employer or an employer’s insurance carrier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3080285-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/h/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An automobile accident reparations insurance carrier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3080286-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1725/h/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person or entity obligated to provide, or to pay the expenses of, health services under a health-plan contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3080287-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117/tI/s111/a"},"text":"Pub. L. 106–117, title I, § 111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-30"},"text":"Nov. 30, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1553"},"text":"113 Stat. 1553","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/387/tIV/s402/a"},"text":"Pub. L. 110–387, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4123"},"text":"122 Stat. 4123","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/137/s1/a"},"text":"Pub. L. 111–137, § 1(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2010-02-01"},"text":"Feb. 1, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/3495"},"text":"123 Stat. 3495","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dU/tI/s142/a/1"},"text":"Pub. L. 117–328, div. U, title I, § 142(a)(1)","children":[],"tail":", (c)(2), "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5423"},"text":"136 Stat. 5423","children":[],"tail":", 5424.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3080288-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3080289-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc308028a-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (h)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Title XIX of the Act is classified generally to subchapter XIX (§ 1396 et seq.) of chapter 7 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc308028b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s142/c/2"},"text":"Pub. L. 117–328, § 142(c)(2)","children":[],"tail":", substituted “subsection (h)(2)(B) or (h)(2)(C)” for “subsection (f)(2)(B) or (f)(2)(C)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f) to (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s142/a"},"text":"Pub. L. 117–328, § 142(a)","children":[],"tail":", added subsecs. (f) and (g) and redesignated former subsec. (f) as (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (b)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/137/s1/a/1"},"text":"Pub. L. 111–137, § 1(a)(1)","children":[],"tail":", struck out “or in part” after “in whole”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/137/s1/b"},"text":"Pub. L. 111–137, § 1(b)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/137/s1/a/2"},"text":"Pub. L. 111–137, § 1(a)(2)","children":[],"tail":", struck out subpar. (E) which read as follows: “A law of a State or political subdivision described in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1729/a/2/B"},"text":"section 1729(a)(2)(B) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/387/s402/a/1"},"text":"Pub. L. 110–387, § 402(a)(1)","children":[],"tail":", substituted “shall reimburse” for “may reimburse”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/387/s402/a/2"},"text":"Pub. L. 110–387, § 402(a)(2)","children":[],"tail":", added subpar. (C) and struck out former subpar. (C) which read as follows: “until such time as the veteran can be transferred safely to a Department facility or other Federal facility”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc308028c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc308028d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/137/s1/c"},"text":"Pub. L. 111–137, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-02-01"},"text":"Feb. 1, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/3495"},"text":"123 Stat. 3495","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/137/s1/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by subsections (a) and (b) [amending this section] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2010-02-01"},"text":"Feb. 1, 2010","children":[],"tail":"], and shall apply with respect to emergency treatment furnished on or after the date of the enactment of this Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement for treatment provided before effective date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may provide reimbursement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1725"},"text":"section 1725 of title 38","children":[],"tail":", United States Code, as amended by subsections (a) and (b), for emergency treatment furnished to a veteran before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2010-02-01"},"text":"Feb. 1, 2010","children":[],"tail":"], if the Secretary determines that, under the circumstances applicable with respect to the veteran, it is appropriate to do so.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc308028e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117/tI/s111/c"},"text":"Pub. L. 106–117, title I, § 111(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-30"},"text":"Nov. 30, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1556"},"text":"113 Stat. 1556","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/117/tI/s111/c"},"text":"“The amendments made by this section [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1729A"},"text":"section 1729A of this title","children":[],"tail":"] shall take effect 180 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1999-11-30"},"text":"Nov. 30, 1999","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc308028f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation Reports","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117/tI/s111/d"},"text":"Pub. L. 106–117, title I, § 111(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-30"},"text":"Nov. 30, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1556"},"text":"113 Stat. 1556","children":[],"tail":", required the Secretary of Veterans Affairs to include with the budget justification materials submitted to Congress in support of the Department of Veterans Affairs budget for fiscal years 2002 and 2003 a report on the implementation of this section, including information on the experience of the Department under that section and the costs incurred."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
