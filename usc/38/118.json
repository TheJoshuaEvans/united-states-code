{"tag":"section","attrib":{"id":"idc2769764-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s118"},"text":null,"children":[{"tag":"num","attrib":{"value":"118"},"text":"§ 118.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of reports to Congress in electronic form","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2769765-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s118/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whenever the Secretary or any other official of the Department is required by law to submit to Congress (or any committee of either chamber of Congress) a report, the Secretary or other official shall submit to Congress (or such committee) a copy of the report in an electronic format.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2769766-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s118/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The submission of a copy of a report in accordance with this section shall be treated as meeting any requirement of law to submit such report to Congress (or any committee of either chamber of Congress).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2769767-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s118/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, the term “report” includes any certification, notification, or other communication in writing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2769768-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163/tX/s1003/a"},"text":"Pub. L. 111–163, title X, § 1003(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-05-05"},"text":"May 5, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1182"},"text":"124 Stat. 1182","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
