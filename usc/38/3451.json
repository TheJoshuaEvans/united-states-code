{"tag":"section","attrib":{"id":"idc36c42d0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3451"},"text":null,"children":[{"tag":"num","attrib":{"value":"3451"},"text":"§ 3451.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Congress of the United States hereby declares that the education program created by this chapter is for the purpose of (1) enhancing and making more attractive service in the Armed Forces of the United States, (2) extending the benefits of a higher education to qualified and deserving young persons who might not otherwise be able to afford such an education, (3) providing vocational readjustment and restoring lost educational opportunities to those service men and women whose careers have been interrupted or impeded by reason of active duty after ","children":[{"tag":"date","attrib":{"date":"1955-01-31"},"text":"January 31, 1955","children":[],"tail":", and (4) aiding such persons in attaining the vocational and educational status which they might normally have aspired to and obtained had they not served their country."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc36c42d1-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/358/s2"},"text":"Pub. L. 89–358, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-03-03"},"text":"Mar. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/12"},"text":"80 Stat. 12","children":[],"tail":", § 1651; renumbered § 3451, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc36c42d2-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc36c42d3-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc36c42d4-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those comprising clauses (3) and (4) of this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1175"},"text":"72 Stat. 1175","children":[],"tail":", which was classified to former "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1601/c"},"text":"section 1601(c) of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/89/358/s4/a"},"text":"section 4(a) of Pub. L. 89–358","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc36c42d5-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1651"},"text":"section 1651 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc36c42d6-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc36c42d7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/358/s12/a"},"text":"Pub. L. 89–358, § 12(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-03-03"},"text":"Mar. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/28"},"text":"80 Stat. 28","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/89/358/s12/a"},"text":"“Except as otherwise specifically provided, the provisions of this Act [see Tables for classification] shall take effect on the date of its enactment [","children":[{"tag":"date","attrib":{"date":"1966-03-03"},"text":"Mar. 3, 1966","children":[],"tail":"], but no educational assistance allowance shall be payable under chapter 34 of title 38, United States Code, as added by section 2 of this Act, for any period before "},{"tag":"date","attrib":{"date":"1966-06-01"},"text":"June 1, 1966","children":[],"tail":", nor for the month of June 1966, unless (1) the eligible veteran commenced the pursuit of the course of education on or after "},{"tag":"date","attrib":{"date":"1966-06-01"},"text":"June 1, 1966","children":[],"tail":", or (2) the pursuit of such course continued through "},{"tag":"date","attrib":{"date":"1966-06-30"},"text":"June 30, 1966","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"idc36c42d8-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/358/s4/b"},"text":"Pub. L. 89–358, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-03-03"},"text":"Mar. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/23"},"text":"80 Stat. 23","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/89/358/s4/b"},"text":"“Nothing in this Act or any amendment or repeal made by it [see Tables for classification], shall affect any right or liability (civil or criminal) which matured under chapter 33 of this title 38 before the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1966-03-03"},"text":"Mar. 3, 1966","children":[],"tail":"]: and all offenses committed, and all penalties and forfeitures incurred, under any provision of law amended or repealed by this Act, may be punished or recovered, as the case may be, in the same manner and with the same effect as if such amendments or repeals had not been made.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
