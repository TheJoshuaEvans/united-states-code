{"tag":"section","attrib":{"id":"idc41309fc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7502"},"text":null,"children":[{"tag":"num","attrib":{"value":"7502"},"text":"§ 7502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application and acceptance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc41309fd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc41309fe-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7502/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To apply and participate in the scholarship program under this chapter, an individual shall submit to the Secretary an application for such participation together with an agreement described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7504"},"text":"section 7504 of this title","children":[],"tail":" under which the participant agrees to serve a period of obligated service in the Department as provided in the agreement in return for payment of educational assistance as provided in the agreement."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc41309ff-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7502/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In distributing application forms and agreement forms to individuals desiring to participate in the scholarship program, the Secretary shall include with such forms the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc4130a00-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7502/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A fair summary of the rights and liabilities of an individual whose application is approved (and whose agreement is accepted) by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4130a01-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7502/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A full description of the terms and conditions that apply to participation in the scholarship program and service in the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4130a02-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approval","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4130a03-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7502/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon the Secretary’s approval of an individual’s participation in the scholarship program, the Secretary shall, in writing, promptly notify the individual of that acceptance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4130a04-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7502/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual becomes a participant in the scholarship program upon such approval by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc4130a05-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163/tIII/s302/a"},"text":"Pub. L. 111–163, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-05-05"},"text":"May 5, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1147"},"text":"124 Stat. 1147","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
