Indian tribe (as defined in section 4 of the Indian Self-Determination and Education Assistance Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"25 U.S.C. 5304","children":[],"tail":")) but” before “does not”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/262"},"text":"Pub. L. 104–262","children":[],"tail":" inserted “adult day health,” before “or hospital care”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5031"},"text":"section 5031 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576"},"text":"Pub. L. 99–576","children":[],"tail":" redesignated pars. (a) to (d) as pars. (1) to (4), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Par. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/62/s3/1"},"text":"Pub. L. 95–62, § 3(1)","children":[],"tail":", inserted construction of new domiciliary buildings, expansion, remodeling, or alteration of existing domiciliary and hospital buildings, and provision of initial equipment for any such buildings to definition of “construction”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/62/s3/2"},"text":"Pub. L. 95–62, § 3(2)","children":[],"tail":", struck out provisions which had limited definition of “cost of construction” to the cost of construction of nursing home facilities."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Par. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/581"},"text":"Pub. L. 94–581","children":[],"tail":" substituted “veteran” for “war veteran”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc42d48a9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc42d48aa-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576/tII/s224/e"},"text":"Pub. L. 99–576, title II, § 224(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3263"},"text":"100 Stat. 3263","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/576/tII/s224/e"},"text":"“The amendments made by this section [amending this section and sections 5033 and 5035 [now 8133 and 8135] of this title] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1987-07-01"},"text":"July 1, 1987","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc42d48ab-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1977 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/62/s5"},"text":"Pub. L. 95–62, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-07-05"},"text":"July 5, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/263"},"text":"91 Stat. 263","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/62/s5"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (b) of this section, the amendments made by this Act [amending this section and sections 5032 to 5036 [now 8132 to 8136] of this title and repealing ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s644"},"text":"section 644 of this title","children":[],"tail":"] shall be effective "},{"tag":"date","attrib":{"date":"1977-10-01"},"text":"October 1, 1977","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms and conditions of any grant made prior to ","children":[{"tag":"date","attrib":{"date":"1977-10-01"},"text":"October 1, 1977","children":[],"tail":", under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s644"},"text":"section 644 of title 38","children":[],"tail":", United States Code [former "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s644"},"text":"section 644 of this title","children":[],"tail":"], and regulations prescribed thereunder, shall remain in full force and effect unless modified, by the mutual agreement of the parties, in accordance with the provisions of subchapter III of chapter 81 of such title, and regulations prescribed thereunder, in effect after "},{"tag":"date","attrib":{"date":"1977-09-30"},"text":"September 30, 1977","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to any grant made prior to ","children":[{"tag":"date","attrib":{"date":"1977-10-01"},"text":"October 1, 1977","children":[],"tail":", under subchapter III of chapter 81 of such title, the Administrator of Veterans’ Affairs shall, upon application of a grantee, modify the terms and conditions of such grant to comply with the provisions of such subchapter as amended by this Act, and regulations prescribed thereunder, and shall promptly notify each such grantee of the grantee’s right to request such modification.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc42d48ac-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/581"},"text":"Pub. L. 94–581","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/581/s211"},"text":"section 211 of Pub. L. 94–581","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s111"},"text":"section 111 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idc42d48ad-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1977 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For short title of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/62"},"text":"Pub. L. 95–62","children":[],"tail":" as the “State Veterans’ Home Assistance Improvement Act of 1977”, see "},{"tag":"ref","attrib":{"href":"/us/pl/95/62/s1"},"text":"section 1 of Pub. L. 95–62","children":[],"tail":", set out as a Short Title of 1977 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
