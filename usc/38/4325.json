{"tag":"section","attrib":{"id":"idc3c92f9f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4325"},"text":null,"children":[{"tag":"num","attrib":{"value":"4325"},"text":"§ 4325.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of rights with respect to certain Federal agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3c92fa0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4325/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This section applies to any person who alleges that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3c92fa1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4325/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reemployment of such person by an agency referred to in subsection (a) of section 4315 was not in accordance with procedures for the reemployment of such person under subsection (b) of such section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3c92fa2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4325/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the failure of such agency to reemploy the person under such section was otherwise wrongful.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3c92fa3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4325/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person referred to in subsection (a) may submit a claim relating to an allegation referred to in that subsection to the inspector general of the agency which is the subject of the allegation. The inspector general shall investigate and resolve the allegation pursuant to procedures prescribed by the head of the agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3c92fa4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4325/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In prescribing procedures for the investigation and resolution of allegations under subsection (b), the head of an agency shall ensure, to the maximum extent practicable, that the procedures are similar to the procedures for investigating and resolving complaints utilized by the Secretary under section 4322(d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3c92fa5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4325/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This section may not be construed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3c92fa6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4325/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as prohibiting an employee of an agency referred to in subsection (a) from seeking information from the Secretary regarding assistance in seeking reemployment from the agency under this chapter or information relating to the rights and obligations of employees and Federal agencies under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3c92fa7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4325/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as prohibiting such an agency from voluntarily cooperating with or seeking assistance in or of clarification from the Secretary or the Director of the Office of Personnel Management of any matter arising under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3c92fa8-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/353/s2/a"},"text":"Pub. L. 103–353, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3167"},"text":"108 Stat. 3167","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/275/tIII/s311/12"},"text":"Pub. L. 104–275, title III, § 311(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3336"},"text":"110 Stat. 3336","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3c92fa9-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3c92faa-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc3c92fab-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4325 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7625"},"text":"section 7625 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3c92fac-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/275"},"text":"Pub. L. 104–275","children":[],"tail":" struck out “, alternative employment in the Federal Government under this chapter,” before “or information relating to the rights and obligations” and substituted “employees and” for “employee and”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3c92fad-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3c92fae-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/275"},"text":"Pub. L. 104–275","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/275/s313"},"text":"section 313 of Pub. L. 104–275","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4301"},"text":"section 4301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3c92faf-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective with respect to reemployments initiated on or after the first day after the 60-day period beginning ","children":[{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", with transition rules, except that provisions necessary for implementation of "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4311"},"text":"section 4311 of this title","children":[],"tail":" are effective "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/353/s8"},"text":"section 8 of Pub. L. 103–353","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4301"},"text":"section 4301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
