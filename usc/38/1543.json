{"tag":"section","attrib":{"id":"idc2c2e30c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1543"},"text":null,"children":[{"tag":"num","attrib":{"value":"1543"},"text":"§ 1543.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Net worth limitation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2c2e30d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1543/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2c2e30e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1543/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall deny or discontinue payment of pension to a surviving spouse under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1541"},"text":"section 1541 of this title","children":[],"tail":" when the corpus of the estate of the surviving spouse is such that under all the circumstances, including consideration of the income of the surviving spouse and the income of any child from whom the surviving spouse is receiving increased pension, it is reasonable that some part of the corpus of such estate be consumed for the surviving spouse’s maintenance."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2c2e30f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1543/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall deny or discontinue the payment of increased pension under subsection (c), (d), or (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1541"},"text":"section 1541 of this title","children":[],"tail":" on account of a child when the corpus of such child’s estate is such that under all the circumstances, including consideration of the income of the surviving spouse and such child and the income of any other child for whom the surviving spouse is receiving increased pension, it is reasonable that some part of the corpus of the child’s estate be consumed for the child’s maintenance. During the period such denial or discontinuance remains in effect, such child shall not be considered as the surviving spouse’s child for purposes of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2c55410-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1543/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall deny or discontinue payment of pension to a child under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1542"},"text":"section 1542 of this title","children":[],"tail":" when the corpus of the estate of the child is such that under all the circumstances, including consideration of the income of the child, the income of any person with whom such child is residing who is legally responsible for such child’s support, and the corpus of the estate of such person, it is reasonable that some part of the corpus of such estates be consumed for the child’s maintenance."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2c55411-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1138"},"text":"72 Stat. 1138","children":[],"tail":", § 543; "},{"tag":"ref","attrib":{"href":"/us/pl/86/211/s4"},"text":"Pub. L. 86–211, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-08-29"},"text":"Aug. 29, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/435"},"text":"73 Stat. 435","chil