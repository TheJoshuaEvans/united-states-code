). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “1541” for “541” in pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator” in pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “1542” for “542”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/588"},"text":"Pub. L. 95–588","children":[],"tail":" designated existing provisions relating to denial or discontinuance of pension payments to surviving spouses as subsec. (a), expanded existing provisions relating to denial or discontinuance of pension payments to children of veterans, and designated such expanded provisions as subsecs. (a)(2) and (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/169"},"text":"Pub. L. 94–169","children":[],"tail":" substituted “surviving spouse” for “widow”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1959—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/211"},"text":"Pub. L. 86–211","children":[],"tail":" substituted provisions requiring the denial or discontinuance of payment of pension to a widow or child when the corpus of the estate of the survivor concerned is such that under all the circumstances, including consideration of income, it is reasonable that some part of the corpus be consumed 