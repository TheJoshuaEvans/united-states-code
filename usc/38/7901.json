{"tag":"section","attrib":{"id":"idc41a3614-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7901"},"text":null,"children":[{"tag":"num","attrib":{"value":"7901"},"text":"§ 7901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs; purpose","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc41a3615-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7901/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To encourage the recruitment and retention of Department personnel who have the information security skills necessary to meet Department requirements, the Secretary may carry out programs in accordance with this chapter to provide financial support for education in computer science and electrical and computer engineering at accredited institutions of higher education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc41a3616-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7901/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Types of Programs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The programs authorized under this chapter are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc41a3617-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7901/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Scholarships for pursuit of doctoral degrees in computer science and electrical and computer engineering at accredited institutions of higher education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc41a3618-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7901/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Education debt reduction for Department personnel who hold doctoral degrees in computer science and electrical and computer engineering at accredited institutions of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc41a3619-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461/tIX/s903/a/1"},"text":"Pub. L. 109–461, title IX, § 903(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3460"},"text":"120 Stat. 3460","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
