{"tag":"section","attrib":{"id":"idc40723db-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7409"},"text":null,"children":[{"tag":"num","attrib":{"value":"7409"},"text":"§ 7409.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts for scarce medical specialist services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc40723dc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7409/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may enter into contracts with institutions and persons described in subsection (b) to provide scarce medical specialist services at Department facilities. Such services may include the services of physicians, dentists, podiatrists, optometrists, chiropractors, nurses, physician assistants, expanded-function dental auxiliaries, technicians, and other medical support personnel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc40723dd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7409/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Institutions and persons with whom the Secretary may enter into contracts under subsection (a) are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc40723de-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7409/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Schools and colleges of medicine, osteopathy, dentistry, podiatry, optometry, and nursing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc40723df-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7409/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Clinics.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc40723e0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7409/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other group or individual capable of furnishing such scarce medical specialist services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc40723e1-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s401/b/2"},"text":"Pub. L. 102–40, title IV, § 401(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/229"},"text":"105 Stat. 229","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/170/tIII/s302/f"},"text":"Pub. L. 108–170, title III, § 302(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2058"},"text":"117 Stat. 2058","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc40723e2-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc40723e3-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc40723e4-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{