ext":"Pub. L. 90–77, title III, § 304(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-08-31"},"text":"Aug. 31, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/186"},"text":"81 Stat. 186","children":[],"tail":"; and former section 1736, "},{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1199"},"text":"72 Stat. 1199","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/126/s2"},"text":"Pub. L. 88–126, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-09-23"},"text":"Sept. 23, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/162"},"text":"77 Stat. 162","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/358/s4"},"text":"Pub. L. 89–358, § 4","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1966-03-03"},"text":"Mar. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/25"},"text":"80 Stat. 25","children":[],"tail":"; provisions similar to those comprising subsec. (c) were contained in former section 1786, as added by "},{"tag":"ref","attrib":{"href":"/us/pl/89/358/s3/b"},"text":"Pub. L. 89–358, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-03-03"},"text":"Mar. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/23"},"text":"80 Stat. 23","children":[],"tail":"; and provisions similar to those comprising subsec. (d) were contained in former section 1787, as added by "},{"tag":"ref","attrib":{"href":"/us/pl/89/358/s3/b"},"text":"Pub. L. 89–358, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-03-03"},"text":"Mar. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/23"},"