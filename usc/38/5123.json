{"tag":"section","attrib":{"id":"idc3d515e8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5123"},"text":null,"children":[{"tag":"num","attrib":{"value":"5123"},"text":"§ 5123.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rounding down of pension rates","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The monthly or other periodic rate of pension payable to an individual under section 1521, 1541, or 1542 of this title or under section 306(a) of the Veterans’ and Survivors’ Pension Improvement Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/588"},"text":"Public Law 95–588","children":[],"tail":"), if not a multiple of $1, shall be rounded down to the nearest dollar."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc3d515e9-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/253/tIV/s403/a/1"},"text":"Pub. L. 97–253, title IV, § 403(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-08"},"text":"Sept. 8, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/802"},"text":"96 Stat. 802","children":[],"tail":", § 3023; renumbered § 5123, "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3d515ea-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3d515eb-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc3d515ec-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 306(a) of the Veterans’ and Survivors’ Pension Improvement Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/588"},"text":"Public Law 95–588","children":[],"tail":"), referred to in text, is "},{"tag":"ref","attrib":{"href":"/us/pl/95/588/s306/a"},"text":"section 306(a) of Pub. L. 95–588","children":[],"tail":", title III, "},{"tag":"date","attrib":{"date":"1978-11-04"},"text":"Nov. 4, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2508"},"text":"92 Stat. 2508","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1521"},"text":"section 1521 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc3d515ed-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 5201 to 5228 were renumbered sections 8501 to 8528 of this title, respectively.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3d515ee-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3023"},"text":"section 3023 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" substituted “1521, 1541, or 1542” for “521, 541, or 542”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3d515ef-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3d515f0-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/253/s403/b"},"text":"Section 403(b) of Pub. L. 97–253","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/98/21/tI/s111/e"},"text":"Pub. L. 98–21, title I, § 111(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-04-20"},"text":"Apr. 20, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/73"},"text":"97 Stat. 73","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dB/tVI/s2662/j"},"text":"Pub. L. 98–369, div. B, title VI, § 2662(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1160"},"text":"98 Stat. 1160","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/369/dB/tVI/s2662/j"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), the amendment made by subsection (a)(1) [enacting this section] shall apply with respect to amounts payable for periods beginning after ","children":[{"tag":"date","attrib":{"date":"1983-05-31"},"text":"May 31, 1983","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the cases of individuals to whom pension is payable under sections 521, 541, and 542 [now 1521, 1541, and 1542] of title 38, United States Code, the amendment made by subsection (a)(1) shall take effect on the first day after ","children":[{"tag":"date","attrib":{"date":"1983-05-31"},"text":"May 31, 1983","children":[],"tail":", that an increase is made in maximum annual rates of pension pursuant to section 3112 [now 5312] of title 38, United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
