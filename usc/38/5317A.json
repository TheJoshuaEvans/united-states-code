{"tag":"section","attrib":{"id":"idc3d9d187-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5317A"},"text":null,"children":[{"tag":"num","attrib":{"value":"5317A"},"text":"§ 5317A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of income information from other agencies: independent verification required before termination or reduction of certain benefits and services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3d9d188-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5317A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Independent Verification Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may terminate, deny, suspend, or reduce any benefit or service specified in section 5317(c), with respect to an individual under age 65 who is an applicant for or recipient of such a benefit or service, by reason of information obtained from the Secretary of Health and Human Services under section 453(j)(11) of the Social Security Act, only if the Secretary takes appropriate steps to verify independently information relating to the individual’s employment and income from employment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d9d189-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5317A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Opportunity to Contest Findings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall inform each individual for whom the Secretary terminates, denies, suspends, or reduces any benefit or service under subsection (a) of the findings made by the Secretary under such subsection on the basis of verified information and shall provide to the individual an opportunity to contest such findings in the same manner as applies to other information and findings relating to eligibility for the benefit or service involved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d9d18a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5317A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Source of Funds for Reimbursement to Secretary of Health and Human Services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall pay the expense of reimbursing the Secretary of Health and Human Services in accordance with section 453(j)(11)(E) of the Social Security Act, for the cost incurred by the Secretary of Health and Human Services in furnishing information requested by the Secretary under section 453(j)(11) of such Act, from amounts available to the Department for the payment of compensation and pensions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d9d18b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5317A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expiration of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The authority under this section shall be in effect as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3d9d18c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5317A/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" During the period beginning on ","children":[{"tag":"date","attrib":{"date":"2007-12-26"},"text":"December 26, 2007","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2011-11-18"},"text":"November 18, 2011","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d9d18d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5317A/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" During the period beginning on the date of the enactment of the Department of Veterans Affairs Expiring Authorities Act of 2013 and ending 180 days after that date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3d9d18e-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/157/tIII/s301/b/1"},"text":"Pub. L. 110–157, title III, § 301(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1835"},"text":"121 Stat. 1835","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/37/s17/a"},"text":"Pub. L. 112–37, § 17(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-10-05"},"text":"Oct. 5, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/398"},"text":"125 Stat. 398","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/37/s3/b"},"text":"Pub. L. 113–37, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-09-30"},"text":"Sept. 30, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/525"},"text":"127 Stat. 525","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3d9d18f-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3d9d190-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc3d9d191-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 453 of the Social Security Act, referred to in subsecs. (a) and (c), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s653"},"text":"section 653 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of the enactment of the Department of Veterans Affairs Expiring Authorities Act of 2013, referred to in subsec. (d)(2), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/37"},"text":"Pub. L. 113–37","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2013-09-30"},"text":"Sept. 30, 2013","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3d9d192-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/37"},"text":"Pub. L. 113–37","children":[],"tail":" added subsec. (d) and struck out former subsec. (d). Prior to amendment, text read as follows: “The authority under this section shall expire on "},{"tag":"date","attrib":{"date":"2011-11-18"},"text":"November 18, 2011","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/37"},"text":"Pub. L. 112–37","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2011-11-18"},"text":"November 18, 2011","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2011-09-30"},"text":"September 30, 2011","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3d9d193-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3d9d194-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/37"},"text":"Pub. L. 113–37","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2013-10-01"},"text":"Oct. 1, 2013","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/113/37/s4/a"},"text":"section 4(a) of Pub. L. 113–37","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s322"},"text":"section 322 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
