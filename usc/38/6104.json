{"tag":"section","attrib":{"id":"idc3e5df60-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6104"},"text":null,"children":[{"tag":"num","attrib":{"value":"6104"},"text":"§ 6104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forfeiture for treason","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3e5df61-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person shown by evidence satisfactory to the Secretary to be guilty of mutiny, treason, sabotage, or rendering assistance to an enemy of the United States or of its allies shall forfeit all accrued or future gratuitous benefits under laws administered by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3e5df62-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary, in the Secretary’s discretion, may apportion and pay any part of benefits forfeited under subsection (a) to the dependents of the person forfeiting such benefits. No dependent of any person shall receive benefits by reason of this subsection in excess of the amount to which the dependent would be entitled if such person were dead.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3e5df63-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of any forfeiture under this section there shall be no authority after ","children":[{"tag":"date","attrib":{"date":"1959-09-01"},"text":"September 1, 1959","children":[],"tail":" (1) to make an apportionment award pursuant to subsection (b) or (2) to make an award to any person of gratuitous benefits based on any period of military, naval, air, or space service commencing before the date of commission of the offense."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3e5df64-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1240"},"text":"72 Stat. 1240","children":[],"tail":", § 3504; "},{"tag":"ref","attrib":{"href":"/us/pl/86/222/s2"},"text":"Pub. L. 86–222, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-01"},"text":"Sept. 1, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/452"},"text":"73 Stat. 452","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/24/s13/b"},"text":"Pub. L. 91–24, § 13(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-06-11"},"text":"June 11, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/34"},"text":"83 Stat. 34","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/295/s4/78"},"text":"Pub. L. 97–295, § 4(78)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1311"},"text":"96 Stat. 1311","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/576/tVII/s701/84"},"text":"Pub. L. 99–576, title VII, § 701(84)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3298"},"text":"100 Stat. 3298","children":[],"tail":"; renumbered § 6104, "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/1"},"text":"Pub. L. 102–83, § 4(a)(1)","children":[],"tail":", (b)(1), (2)(E), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/403-405"},"text":"105 Stat. 403–405","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s926/a/56"},"text":"Pub. L. 116–283, div. A, title IX, § 926(a)(56)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3830"},"text":"134 Stat. 3830","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3e5df65-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3e5df66-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3e5df67-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “air, or space service” for “or air service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3504"},"text":"section 3504 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/1"},"text":"Pub. L. 102–83, § 4(a)(1)","children":[],"tail":", substituted “administered by the Secretary” for “administered by the Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator” and “Secretary’s” for “Administrator’s”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576"},"text":"Pub. L. 99–576","children":[],"tail":" substituted “the Administrator’s” for “his” and “the dependent” for “he”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295"},"text":"Pub. L. 97–295","children":[],"tail":" inserted “to” before “be guilty”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/24"},"text":"Pub. L. 91–24","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1959-09-01"},"text":"September 1, 1959","children":[],"tail":"” for “the date of enactment of this subsection”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1959—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/222"},"text":"Pub. L. 86–222","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
