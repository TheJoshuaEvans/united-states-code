{"tag":"section","attrib":{"id":"idc3034838-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J"},"text":null,"children":[{"tag":"num","attrib":{"value":"1720J"},"text":"§ 1720J.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergent suicide care","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3034839-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Emergent Suicide Care","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Pursuant to this section, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc303483a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furnish emergent suicide care to an eligible individual at a medical facility of the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc303483b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay for emergent suicide care provided to an eligible individual at a non-Department facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc303483c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reimburse an eligible individual for emergent suicide care provided to the eligible individual at a non-Department facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc303483d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual is eligible for emergent suicide care under subsection (a) if the individual is in an acute suicidal crisis and is either of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc303483e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A veteran (as defined in section 101).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc303483f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1720I/b"},"text":"section 1720I(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3034840-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Period of Care","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3034841-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Emergent suicide care provided under subsection (a) shall be furnished to an eligible individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3034842-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through inpatient or crisis residential care, for a period not to exceed 30 days; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3034843-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if care under subparagraph (A) is unavailable, or if such care is not clinically appropriate, as outpatient care for a period not to exceed 90 days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3034844-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If, upon the expiration of a period under paragraph (1), the Secretary determines that the eligible individual remains in an acute suicidal crisis, the Secretary may extend such period as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3034845-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An eligible individual who receives emergent suicide care under subsection (a) at a non-Department facility (or a person acting on behalf of the individual) shall notify the Secretary of such care within seven days of admission to such facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3034846-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Outreach","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"During any period when an eligible individual is receiving emergent suicide care under subsection (a), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3034847-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3034848-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an eligible individual whom the Veterans Crisis Line recommends to seek emergent suicide care at a medical facility of the Department, the Veterans Crisis Line notifies the Suicide Prevention Coordinator of such medical facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc305b849-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an eligible individual who presents at a medical facility of the Department in an acute suicidal crisis without a recommendation by the Veterans Crisis Line, the Secretary notifies the Suicide Prevention Coordinator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc305b84a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an eligible individual whom the Veterans Crisis Line recommends to seek treatment at a non-Department facility, the Veterans Crisis Line notifies the Suicide Prevention Coordinator and the Office of Community Care at the medical facility of the Department located nearest to the eligible individual; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc305b84b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an eligible individual who presents at a non-Department facility in an acute suicidal crisis without a recommendation by the Veterans Crisis Line and for whom the Secretary receives a notification under subsection (d), the Secretary notifies the Suicide Prevention Coordinator and the Office of Community Care at the medical facility of the Department located nearest to the eligible individual;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc305b84c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the eligibility of the eligible individual for other programs and benefits under the laws administered by the Secretary (or shall make such determination as soon as practicable following the period of such emergent suicide care); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc305b84d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make referrals for care following the period of such emergent suicide care, as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc305b84e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on Charge","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc305b84f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the Secretary provides emergent suicide care to an eligible individual under subsection (a), the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc305b850-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not charge the eligible individual for any cost of such emergent suicide care; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc305b851-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall pay for any costs of emergency transportation to a facility for such emergent suicide care (as such costs are determined pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1725"},"text":"section 1725 of this title","children":[],"tail":", to the extent practicable)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc305b852-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc305b853-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to the requirements of paragraph (1), if the Secretary pays for emergent suicide care provided under subsection (a) to an eligible individual at a non-Department facility, the Secretary shall reimburse the facility for the reasonable value of such emergent suicide care.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc305b854-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc305b855-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out subparagraph (A), the Secretary may determine the amount to reimburse a non-Department facility in a similar manner to the manner in which the Secretary determines reimbursement amounts for that non-Department facility for medical care and services provided under another provision of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc305b856-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1725/c/3"},"text":"section 1725(c)(3) of this title","children":[],"tail":" shall apply with respect to payments made under subparagraph (A) of this paragraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc305b857-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an eligible individual who receives emergent suicide care under this section and who is entitled to emergent suicide care (or payment for emergent suicide care) under a health-plan contract, the Secretary may recover the costs of such emergent suicide care provided under this section, other than for such care for a service-connected disability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc305b858-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out subsection (d), the Secretary may not charge an eligible individual for any cost of emergent suicide care provided under subsection (a) solely by reason of the Secretary not having been notified of such care pursuant to such subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc305b859-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not less than once each year, the Secretary shall submit to the Committees on Veterans’ Affairs of the Senate and the House of Representatives a report on emergent suicide care provided under subsection (a). Each such report shall include, for the year covered by the report—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc305b85a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of eligible individuals who received emergent suicide care under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc305b85b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demographic information regarding eligible individuals described in paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc305b85c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types of care furnished or paid for this section; ","children":[{"tag":"ref","attrib":{"idref":"fn002035"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002035"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “under this section;”."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc305b85d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total cost of providing care under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc305b85e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc305b85f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “acute suicidal crisis” means that an individual was determined to be at imminent risk of self-harm by a trained crisis responder or health care provider.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc305b860-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “crisis residential care” means crisis stabilization care provided—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc305b861-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a residential setting; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc305b862-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a facility other than a hospital.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc305b863-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “crisis stabilization care” includes, with respect to an individual in acute suicidal crisis, care that ensures, to the extent practicable, immediate safety and reduces—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc305b864-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/h/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the severity of distress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc305b865-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/h/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need for urgent care; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc305b866-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/h/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the likelihood that the distress under subparagraph (A) or need under subparagraph (B) will increase during the transfer of that individual from a facility at which the individual has received care for that acute suicidal crisis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc305b867-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “emergent suicide care” means crisis stabilization care provided to an eligible individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc305b868-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/h/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to a recommendation of the eligible individual from the Veterans Crisis Line; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc305b869-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/h/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who presents at a medical facility in an acute suicidal crisis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc305b86a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/h/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “health-plan contract” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1725"},"text":"section 1725 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc305b86b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720J/h/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Veterans Crisis Line” means the hotline under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1720F/h"},"text":"section 1720F(h) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc305b86c-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/214/tII/s201/a"},"text":"Pub. L. 116–214, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-05"},"text":"Dec. 5, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1030"},"text":"134 Stat. 1030","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc305b86d-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc305b86e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc305b86f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/214/tII/s201/c"},"text":"Pub. L. 116–214, title II, § 201(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-05"},"text":"Dec. 5, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1033"},"text":"134 Stat. 1033","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/214/tII/s201/c"},"text":"“The Secretary shall furnish or pay for emergent suicide care under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1720J"},"text":"section 1720J of title 38","children":[],"tail":", United States Code, as added by subsection (a), beginning on the date that is 270 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2020-12-05"},"text":"Dec. 5, 2020","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
