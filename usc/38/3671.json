{"tag":"section","attrib":{"id":"idc3865a1b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3671"},"text":null,"children":[{"tag":"num","attrib":{"value":"3671"},"text":"§ 3671.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3865a1c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3671/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Unless otherwise established by the law of the State concerned, the chief executive of each State is requested to create or designate a State department or agency as the “State approving agency” for such State for the purposes of this chapter and chapters 34 and 35 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3865a1d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3671/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3865a1e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3671/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If any State fails or declines to create or designate a State approving agency, or fails to enter into an agreement under section 3674(a), the provisions of this chapter which refer to the State approving agency shall, with respect to such State, be deemed to refer to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3865a1f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3671/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided in this chapter, in the case of courses subject to approval by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3672"},"text":"section 3672 of this title","children":[],"tail":", the provisions of this chapter which refer to a State approving agency shall be deemed to refer to the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3865a20-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3671/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not recognize a State department or agency as the State approving agency for a State for purposes of this chapter if such department or agency is administered at, or colocated with, a university or university system that offers courses or programs of education that are subject to approval under this chapter by the State approving agency for that State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3865a21-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/126/s1"},"text":"Pub. L. 88–126, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-09-23"},"text":"Sept. 23, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/158"},"text":"77 Stat. 158","children":[],"tail":", § 1771; amended "},{"tag":"ref","attrib":{"href":"/us/pl/89/358/s3/a/6"},"text":"Pub. L. 89–358, § 3(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-03-03"},"text":"Mar. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/20"},"text":"80 Stat. 20","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/540/tIV/s403/2"},"text":"Pub. L. 92–540, title IV, § 403(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-24"},"text":"Oct. 24, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1090"},"text":"86 Stat. 1090","childre