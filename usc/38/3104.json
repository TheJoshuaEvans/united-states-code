{"tag":"section","attrib":{"id":"idc3592fcb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3104"},"text":null,"children":[{"tag":"num","attrib":{"value":"3104"},"text":"§ 3104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of services and assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3592fcc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Services and assistance which the Secretary may provide under this chapter, pursuant to regulations which the Secretary shall prescribe, include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3592fcd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3104/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Evaluation, including periodic reevaluations as appropriate with respect to a veteran participating in a rehabilitation program, of the potential for rehabilitation of a veteran, including diagnostic and related services (A) to determine whether the veteran has an employment handicap or a serious employment handicap and whether a vocational goal is reasonably feasible for such veteran, and (B) to provide a basis for planning a suitable vocational rehabilitation program or a program of services and assistance to improve the vocational rehabilitation potential or independent living status of such veteran, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3592fce-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3104/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Educational, vocational, psychological, employment, and personal adjustment counseling.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3592fcf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3104/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An allowance and other appropriate assistance, as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3108"},"text":"section 3108 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3592fd0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3104/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A work-study allowance as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3485"},"text":"section 3485 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3592fd1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3104/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Placement services to effect suitable placement in employment, and postplacement services to attempt to insure satisfactory adjustment in employment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3592fd2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3104/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Personal adjustment and work adjustment training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3592fd3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3104/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3592fd4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3104/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Vocational and other training services and assistance, including individualized tutorial assistance, tuition, fees, books, supplies, handling charges, licensing fees, and equipment and other training materials determined by the Secretary to be necessary to accomplish the purposes of the rehabilitation program in the individual case.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3592fd5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3104/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payment for the services and assistance provided under subparagraph (A) of this paragraph shall be made from funds available for the payment of readjustment benefits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3592fd6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3104/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Loans as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3112"},"text":"section 3112 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3592fd7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3104/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Treatment, care, and services described in chapter 17 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3592fd8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3104/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prosthetic appliances, eyeglasses, and other corrective and assistive devices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3592fd9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3104/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Services to a veteran’s family as necessary for the effective rehabilitation of such veteran.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3592fda-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3104/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such license fees and essential equipment, supplies, and minimum stocks of materials as the Secretary determines to be necessary for a veteran to begin self-employment and are within the criteria and cost limitations that the Secretary shall prescribe in regulations for the furnishing of such fees, equipment, supplies, and stocks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3592fdb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3104/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Travel and incidental expenses under the terms and conditions set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s111"},"text":"section 111 of this title","children":[],"tail":", plus, in the case of a veteran who because of such veteran’s disability has transportation expenses in addition to those incurred by persons not so disabled, a special transportation allowance to defray such additional expenses during rehabilitation, job seeking, and the initial employment stage."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3592fdc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3104/a/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Special services (including services related to blindness and deafness) including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3592fdd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3104/a/14/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" language training, speech and voice correction, training in ambulation, and one-hand typewriting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3592fde-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3104/a/14/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" orientation, adjustment, mobility, reader, interpreter, and related services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3592fdf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3104/a/14/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" telecommunications, sensory, and other technical aids and devices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3592fe0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3104/a/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Services necessary to enable a veteran to achieve maximum independence in daily living.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3592fe1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3104/a/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other incidental goods and services determined by the Secretary to be necessary to accomplish the purposes of a rehabilitation program in an individual case.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3592fe2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A rehabilitation program (including individual courses) to be pursued by a veteran shall be subject to the approval of the Secretary. To the maximum extent practicable, a course of education or training may be pursued by a veteran as part of a rehabilitation program under this chapter only if the course is approved for purposes of chapter 30 or 33 of this title. The Secretary may waive the requirement under the preceding sentence to the extent the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3592fe3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3592fe4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3104/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall have the authority to administer this chapter by prioritizing the provision of services under this chapter based on need, as determined by the Secretary, including with respect to providing priority for services under subsection (a)(12) to veterans with the most severe service-connected disabilities who require homebound training or self-employment, or both homebound training and self-employment. In evaluating need for purposes of this subsection, the Secretary shall consider disability ratings, the severity of employment handicaps, qualification for a program of independent living, income, and any other factor the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3592fe5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3104/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 90 days before making any changes to the prioritization of the provision of services under this chapter as authorized under paragraph (1), the Secretary shall submit to the Committees on Veterans’ Affairs of the Senate and House of Representatives a plan describing such changes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3592fe6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3104/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not assist a veteran in acquiring adaptations to the residence of the veteran under this chapter. Any such assistance may be furnished only under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2102B"},"text":"section 2102B of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3592fe7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3104/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of any veteran whom the Secretary determines is satisfactorily following a program of employment services provided under subsection (a)(5) during the period of an emergency situation, the Secretary may pay the veteran a subsistence allowance, as prescribed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3108"},"text":"section 3108 of this title","children":[],"tail":" for full-time training for the type of program that the veteran was pursuing, for two additional months, if the Secretary determines that the veteran is negatively affected by the emergency situation."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3592fe8-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466/tI/s101/a"},"text":"Pub. L. 96–466, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2174"},"text":"94 Stat. 2174","children":[],"tail":", § 1504; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/323/s11/a/3/A"},"text":"Pub. L. 100–323, § 11(a)(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/568"},"text":"102 Stat. 568","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIV/s423/b/1/A"},"text":"Pub. L. 101–237, title IV, § 423(b)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2092"},"text":"103 Stat. 2092","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/16/s3/b/1"},"text":"Pub. L. 102–16, § 3(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-03-22"},"text":"Mar. 22, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/49"},"text":"105 Stat. 49","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/54/s14/c/3"},"text":"Pub. L. 102–54, § 14(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-06-13"},"text":"June 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/285"},"text":"105 Stat. 285","children":[],"tail":"; renumbered § 3104 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/275/tI/s101/d"},"text":"Pub. L. 104–275, title I, § 101(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3324"},"text":"110 Stat. 3324","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/315/tIV"},"text":"Pub. L. 114–315, title IV","children":[],"tail":", §§ 402(a), 403, "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1553"},"text":"130 Stat. 1553","children":[],"tail":", 1554; "},{"tag":"ref","attrib":{"href":"/us/pl/115/177/s1/c/1"},"text":"Pub. L. 115–177, § 1(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-01"},"text":"June 1, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1377"},"text":"132 Stat. 1377","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/333"},"text":"Pub. L. 117–333","children":[],"tail":", §§ 4(a), 14(a), (b), "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6128"},"text":"136 Stat. 6128","children":[],"tail":", 6135.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3592fe9-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3592fea-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc3592feb-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior section 3104 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5304"},"text":"section 5304 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3592fec-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (a)(12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/333/s14/a"},"text":"Pub. L. 117–333, § 14(a)","children":[],"tail":", amended par. (12) generally. Prior to amendment, par. (12) read as follows: “For veterans with the most severe service-connected disabilities who require homebound training or self-employment, or both homebound training and self-employment, such license fees and essential equipment, supplies, and minimum stocks of materials as the Secretary determines to be necessary for such a veteran to begin employment and are within the criteria and cost limitations that the Secretary shall prescribe in regulations for the furnishing of such fees, equipment, supplies, and stocks.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/333/s14/b"},"text":"Pub. L. 117–333, § 14(b)","children":[],"tail":", inserted “, including with respect to providing priority for services under subsection (a)(12) to veterans with the most severe service-connected disabilities who require homebound training or self-employment, or both homebound training and self-employment” after “determined by the Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/333/s4/a"},"text":"Pub. L. 117–333, § 4(a)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/177"},"text":"Pub. L. 115–177","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/315/s402/a"},"text":"Pub. L. 114–315, § 402(a)","children":[],"tail":", inserted at end “To the maximum extent practicable, a course of education or training may be pursued by a veteran as part of a rehabilitation program under this chapter only if the course is approved for purposes of chapter 30 or 33 of this title. The Secretary may waive the requirement under the preceding sentence to the extent the Secretary determines appropriate.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/315/s403"},"text":"Pub. L. 114–315, § 403","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/275/s101/d/1/A"},"text":"Pub. L. 104–275, § 101(d)(1)(A)","children":[],"tail":", substituted “the veteran has an employment handicap or” for “such veteran’s disability or disabilities cause” and inserted “reasonably” after “goal is”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/275/s101/d/1/B"},"text":"Pub. L. 104–275, § 101(d)(1)(B)","children":[],"tail":", struck out “(i)” after “assistance, including” and “, and (ii) job-readiness skills development and counseling under section 14(a)(2) of the Veterans’ Job Training Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1721"},"text":"29 U.S.C. 1721","children":[],"tail":" note) for a participant in a program of training under such Act” after “individual case”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/275/s101/d/1/C"},"text":"Pub. L. 104–275, § 101(d)(1)(C)","children":[],"tail":", substituted “For veterans with the most severe service-connected disabilities who require” for “For the most severely disabled veterans requiring”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/275/s101/d/2"},"text":"Pub. L. 104–275, § 101(d)(2)","children":[],"tail":", redesignated subsec. (c) as (b) and struck out former subsec. (b) which read as follows: “A program of independent living services and assistance may include the types of services and assistance described in section 702 of the Rehabilitation Act of 1973 ("},{"tag":"ref","attrib":{"href":"/us/usc/t29/s796a"},"text":"29 U.S.C. 796a","children":[],"tail":").”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1504"},"text":"section 1504 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “3108” for “1508”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “3485” for “1685”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/16"},"text":"Pub. L. 102–16","children":[],"tail":" designated existing provisions as subpar. (A), redesignated former cls. (A) and (B) as cls. (i) and (ii), respectively, substituted “handling charges, licensing” for “and licensing”, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “3112” for “1512”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/54"},"text":"Pub. L. 102–54","children":[],"tail":" substituted “("},{"tag":"ref","attrib":{"href":"/us/usc/t29/s796a"},"text":"29 U.S.C. 796a","children":[],"tail":")” for “("},{"tag":"ref","attrib":{"href":"/us/usc/t29/s796"},"text":"29 U.S.C. 796","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsecs. (a), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" substituted “Secretary” for “Administrator” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323"},"text":"Pub. L. 100–323","children":[],"tail":" designated existing provisions as subpar. (A) and added subpar. (B)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc35b79dd-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc35b79de-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/315/tIV/s402/b"},"text":"Pub. L. 114–315, title IV, § 402(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1554"},"text":"130 Stat. 1554","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/315/tIV/s402/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply with respect to a course of education or training pursued by a veteran who first begins a program of rehabilitation under chapter 31 of title 38, United States Code, on or after the date that is 1 year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc35b79df-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/275"},"text":"Pub. L. 104–275","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", with amendment by section 101(d)(1)(C), (2) of "},{"tag":"ref","attrib":{"href":"/us/pl/104/275"},"text":"Pub. L. 104–275","children":[],"tail":" only applicable with respect to claims of eligibility or entitlement to services and assistance (including claims for extension of such services and assistance) under this chapter received by the Secretary of Veterans Affairs on or after "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", including those claims based on original applications, and applications seeking to reopen, revise, reconsider, or otherwise adjudicate or readjudicate on any basis claims for services and assistance under this chapter, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/275/s101/j"},"text":"section 101(j) of Pub. L. 104–275","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc35b79e0-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/16/s3/b/2"},"text":"Pub. L. 102–16, § 3(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-03-22"},"text":"Mar. 22, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/49"},"text":"105 Stat. 49","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/16/s3/b/2"},"text":"“The amendments made by this subsection [amending this section] shall apply only to payments made on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1991-03-22"},"text":"Mar. 22, 1991","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc35b79e1-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323/s16"},"text":"Pub. L. 100–323, § 16","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/575"},"text":"102 Stat. 575","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/323/s16"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), the provisions of and amendments made by this Act [see Tables for classification] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The following provisions of or amendments made by this Act shall take effect for all of fiscal year 1988 and subsequent fiscal years:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Clause (5) of subsection (b) of section 2002A [now 4102A] of title 38, United States Code, as added by section 2(a)(2) of this Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (a) of section 2003A [now 4103A] of such title, as amended by section 2(e)(1)(A) of this Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraphs (1), (2), and (3) of section 2004(a) [now 4104(a)] of such title, as amended by section 3(a) of this Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraphs (2) through (5) of section 1774(a) [now 3674(a)] of such title, as added by section 13(a)(1) of this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of and amendments made by sections 4 through 11 [see Tables for classification] shall take effect on the 60th day after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc35b79e2-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-04-01"},"text":"Apr. 1, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/466/s802/a/1"},"text":"section 802(a)(1) of Pub. L. 96–466","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3100"},"text":"section 3100 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc35b79e3-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Blind Rehabilitation Outpatient Specialists","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461/tII/s207"},"text":"Pub. L. 109–461, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3412"},"text":"120 Stat. 3412","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/461/tII/s207"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Findings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress makes the following findings:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are approximately 135,000 blind veterans throughout the United States, including approximately 35,000 who are enrolled with the Department of Veterans Affairs. An aging veteran population and injuries incurred in Operation Iraqi Freedom and Operation Enduring Freedom are increasing the number of blind veterans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Since 1996, when the Department of Veterans Affairs hired its first 14 blind rehabilitation outpatient specialists (referred to in this section as ‘Specialists’), Specialists have been a critical part of the continuum of care for blind and visually impaired veterans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Veterans Affairs operates 10 residential blind rehabilitation centers that are considered among the best in the world. These centers have had long waiting lists, with as many as 1,500 blind veterans waiting for openings in 2004.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Specialists provide—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" critically needed services to veterans who are unable to attend residential centers or are waiting to enter a residential center program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a range of services for blind veterans, including training with living skills, mobility, and adaptation of manual skills; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pre-admission screening and follow-up care for blind rehabilitation centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are not enough Specialist positions to meet the increased numbers and needs of blind veterans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Additional Specialist Positions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 months after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":"], the Secretary of Veterans Affairs shall establish an additional Specialist position at not fewer than 35 additional facilities of the Department of Veterans Affairs."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection of Facilities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In identifying the most appropriate facilities to receive a Specialist position under this section, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give priority to facilities with large numbers of enrolled legally blind veterans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that each facility does not have such a position; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that each facility is in need of the services of a Specialist.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall coordinate the provision of blind rehabilitation services for veterans with services for the care of the visually impaired offered by State and local agencies, especially to the extent to which such State and local agencies can provide necessary services to blind veterans in settings located closer to the residences of such veterans at similar quality and cost to the veteran.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There are authorized to be appropriated for the Department of Veterans Affairs to carry out this section $3,500,000 for each of fiscal years 2007 through 2012.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc35b79e4-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Veterans Pursuing Program of Vocational Rehabilitation Under Former Section 1504 of This Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"During the period beginning on ","children":[{"tag":"date","attrib":{"date":"1980-10-01"},"text":"Oct. 1, 1980","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"1981-03-31"},"text":"Mar. 31, 1981","children":[],"tail":", the provisions of section 3108 [formerly 1508] of this title, as added by "},{"tag":"ref","attrib":{"href":"/us/pl/96/466/tI/s101/a"},"text":"Pub. L. 96–466, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2178"},"text":"94 Stat. 2178","children":[],"tail":", shall apply to veterans pursuing a program of vocational rehabilitation training under this chapter in the same manner as former "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1504"},"text":"section 1504 of this title","children":[],"tail":" applied to veterans pursuing such a program under this chapter on "},{"tag":"date","attrib":{"date":"1980-09-30"},"text":"Sept. 30, 1980","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/pl/96/466/s802/a/4"},"text":"section 802(a)(4) of Pub. L. 96–466","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3100"},"text":"section 3100 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
