-30"},"text":"September 30, 2022","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2020-09-30"},"text":"September 30, 2020","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/251"},"text":"Pub. L. 115–251","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2020-09-30"},"text":"September 30, 2020","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/37"},"text":"Pub. L. 112–37","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":"” for “the date that is seven years after the date of the enactment of this section”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc4261d85-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc4261d86-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/37"},"text":"Pub. L. 119–37","children":[],"tail":" effective as if enacted on "},{"tag":"date","attrib":{"date":"2025-09-30"},"text":"Sept. 30, 2025","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/119/37/s7406"},"text":"section 7406 of Pub. L. 119–37","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s111A"},"text":"section 111A of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc4261d87-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transfer of Unobligated Balances to Capital Asset Fund","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/422/tIV/s411/d"},"text":"Pub. L. 108–422, title IV, § 411(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-11-30"},"text":"Nov. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2389"},"text":"118 Stat. 2389","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/422/tIV/s411/d"},"text":"“Any unobligated balances in the nursing home revolving fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s8116"},"text":"section 8116 of title 38","children":[],"tail":", United States Code, as of the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2004-11-30"},"text":"Nov. 30, 2004","children":[],"tail":"] shall be deposited in the Department of Veterans Affairs Capital Asset Fund established under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s8118"},"text":"section 8118 of title 38","children":[],"tail":", United States Code (as added by subsection (a)).”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/422/s411/d"},"text":"Section 411(d) of Pub. L. 108–422","children":[],"tail":", set out above, is effective at the end of the 30-day period beginning on the date on which the Secretary of Veterans Affairs certifies to Congress that the Secretary is in compliance with "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1710B/b"},"text":"section 1710B(b) of this title","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/422/s411/f"},"text":"section 411(f) of Pub. L. 108–422","children":[],"tail":", set out as an Effective Date of 2004 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1710B"},"text":"section 1710B of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
