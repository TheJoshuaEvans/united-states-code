{"tag":"section","attrib":{"id":"idc41a3536-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699"},"text":null,"children":[{"tag":"num","attrib":{"value":"7699"},"text":"§ 7699.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility; agreement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc41a3537-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual is eligible to participate in the Program, as determined by the Readjustment Counseling Service of the Department, if the individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc41a3538-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is accepted for enrollment or enrolled (as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7602"},"text":"section 7602 of this title","children":[],"tail":") in a program of study at an accredited educational institution, school, or training program leading to a terminal degree in psychology, social work, marriage and family therapy, or mental health counseling that would meet the education requirements for appointment to a position under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7402/b"},"text":"section 7402(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc41a3539-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enters into an agreement with the Secretary under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc41a353a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Priority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting individuals to participate in the Program, the Secretary shall give priority to the following individuals:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc41a353b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An individual who agrees to be employed by a Vet Center located in a community that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc41a353c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designated as a medically underserved population under section 330(b)(3) of the Public Health Service Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254b/b/3"},"text":"42 U.S.C. 254b(b)(3)","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc41a353d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a State with a per capita population of veterans of more than five percent according to the National Center for Veterans Analysis and Statistics and the Bureau of the Census.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc41a353e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual who is a veteran.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc41a353f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An agreement between the Secretary and a participant in the Program shall (in addition to the requirements set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7604"},"text":"section 7604 of this title","children":[],"tail":") include the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc41a3540-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An agreement by the Secretary to provide the participant with a scholarship under the Program for a specified number of school years during which the participant pursues a program of study described in subsection (a)(1) that meets the requirements set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7602/a"},"text":"section 7602(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc41a3541-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An agreement by the participant to serve as a full-time employee of the Department at a Vet Center for a six-year period following the completion by the participant of such program of study (in this subchapter referred to as the “period of obligated service”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc41a3542-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vet Center Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “Vet Center” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1712A/h"},"text":"section 1712A(h) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc41a3543-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/171/tV/s502/a"},"text":"Pub. L. 116–171, title V, § 502(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-17"},"text":"Oct. 17, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/815"},"text":"134 Stat. 815","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc41a3544-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc41a3545-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc41a3546-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Secretary of Veterans Affairs to begin awarding scholarships under this subchapter for programs of study beginning no later than one year after ","children":[{"tag":"date","attrib":{"date":"2020-10-17"},"text":"Oct. 17, 2020","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/171/s502/c"},"text":"section 502(c) of Pub. L. 116–171","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7698"},"text":"section 7698 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
