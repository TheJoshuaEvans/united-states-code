{"tag":"section","attrib":{"id":"idc3d05c39-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5109A"},"text":null,"children":[{"tag":"num","attrib":{"value":"5109A"},"text":"§ 5109A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revision of decisions on grounds of clear and unmistakable error","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3d05c3a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5109A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A decision by the Secretary under this chapter is subject to revision on the grounds of clear and unmistakable error. If evidence establishes the error, the prior decision shall be reversed or revised.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d05c3b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5109A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of authorizing benefits, a rating or other adjudicative decision that constitutes a reversal or revision of a prior decision on the grounds of clear and unmistakable error has the same effect as if the decision had been made on the date of the prior decision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d05c3c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5109A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Review to determine whether clear and unmistakable error exists in a case may be instituted by the Secretary on the Secretary’s own motion or upon request of the claimant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d05c3d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5109A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A request for revision of a decision of the Secretary based on clear and unmistakable error may be made at any time after that decision is made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d05c3e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5109A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such a request shall be submitted to the Secretary and shall be decided in the same manner as any other claim.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3d05c3f-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/111/s1/a/1"},"text":"Pub. L. 105–111, § 1(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2271"},"text":"111 Stat. 2271","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3d05c40-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3d05c41-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3d05c42-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/111/s1/c/1"},"text":"Pub. L. 105–111, § 1(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2272"},"text":"111 Stat. 2272","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/111/s1/c/1"},"text":"“Sections 5109A and 7111 of title 38, United States Code, as added by this section, apply to any determination made before, on, or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
