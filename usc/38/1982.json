{"tag":"section","attrib":{"id":"idc32bde2d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1982"},"text":null,"children":[{"tag":"num","attrib":{"value":"1982"},"text":"§ 1982.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative cost","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as provided in sections 1920(c), 1923(d), and 1955(c) of this title, the United States shall bear the cost of administration in connection with this chapter, including expenses for medical examinations, inspections when necessary, printing and binding, and for such other expenditures as are necessary in the discretion of the Secretary.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc32bde2e-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1165"},"text":"72 Stat. 1165","children":[],"tail":", § 782; renumbered § 1982 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":", §§ 4(b)(1), (2)(E), 5(a), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404-406"},"text":"105 Stat. 404–406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/99/tII/s201/b"},"text":"Pub. L. 104–99, title II, § 201(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-01-26"},"text":"Jan. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/36"},"text":"110 Stat. 36","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc32bde2f-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib"