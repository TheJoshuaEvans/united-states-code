{"tag":"section","attrib":{"id":"idc41a3547-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699A"},"text":null,"children":[{"tag":"num","attrib":{"value":"7699A"},"text":"§ 7699A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obligated service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc41a3548-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each participant in the Program shall provide service as a full-time employee of the Department at a Vet Center (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7699/d"},"text":"section 7699(d) of this title","children":[],"tail":") for the period of obligated service set forth in the agreement of the participant entered into under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7604"},"text":"section 7604 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc41a3549-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination of Service Commencement Date","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc41a354a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 60 days before the service commencement date of a participant, the Secretary shall notify the participant of that service commencement date.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc41a354b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7699A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The date specified in paragraph (1) with respect to a participant is the date for the beginning of the period of obligated service of the participant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc41a354c-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/171/tV/s502/a"},"text":"Pub. L. 116–171, title V, § 502(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-17"},"text":"Oct. 17, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/816"},"text":"134 Stat. 816","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc41a354d-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc41a354e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc41a354f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Secretary of Veterans Affairs to begin awarding scholarships under this subchapter for programs of study beginning no later than one year after ","children":[{"tag":"date","attrib":{"date":"2020-10-17"},"text":"Oct. 17, 2020","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/171/s502/c"},"text":"section 502(c) of Pub. L. 116–171","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7698"},"text":"section 7698 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
