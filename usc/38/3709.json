{"tag":"section","attrib":{"id":"idc3a309f5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3709"},"text":null,"children":[{"tag":"num","attrib":{"value":"3709"},"text":"§ 3709.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refinancing of housing loans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3a309f6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3709/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fee Recoupment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (d) and notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3703"},"text":"section 3703 of this title","children":[],"tail":" or any other provision of law, a loan to a veteran for a purpose specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3710"},"text":"section 3710 of this title","children":[],"tail":" that is being refinanced may not be guaranteed or insured under this chapter unless—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3a309f7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3709/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issuer of the refinanced loan provides the Secretary with a certification of the recoupment period for fees, closing costs, and any expenses (other than taxes, amounts held in escrow, and fees paid under this chapter) that would be incurred by the borrower in the refinancing of the loan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3a309f8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3709/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all of the fees and incurred costs are scheduled to be recouped on or before the date that is 36 months after the date of loan issuance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3a309f9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3709/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recoupment is calculated through lower regular monthly payments (other than taxes, amounts held in escrow, and fees paid under this chapter) as a result of the refinanced loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3a309fa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3709/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Net Tangible Benefit Test","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (d) and notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3703"},"text":"section 3703 of this title","children":[],"tail":" or any other provision of law, a loan to a veteran for a purpose specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3710"},"text":"section 3710 of this title","children":[],"tail":" that is refinanced may not be guaranteed or insured under this chapter unless—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3a309fb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3709/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issuer of the refinanced loan provides the borrower with a net tangible benefit test;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3a309fc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3709/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a case in which the original loan had a fixed rate mortgage interest rate and the refinanced loan will have a fixed rate mortgage interest rate, the refinanced loan has a mortgage interest rate that is not less than 50 basis points less than the previous loan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3a309fd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3709/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a case in which the original loan had a fixed rate mortgage interest rate and the refinanced loan will have an adjustable rate mortgage interest rate, the refinanced loan has a mortgage interest rate that is not less than 200 basis points less than the previous loan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3a309fe-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3709/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the lower interest rate is not produced solely from discount points, unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3a309ff-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3709/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such points are paid at closing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3a30a00-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3709/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such points are not added to the principal loan amount, unless—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc3a30a01-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3709/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for discount point amounts that are less than or equal to one discount point, the resulting loan balance after any fees and expenses allows the property with respect to which the loan was issued to maintain a loan to value ratio of 100 percent or less; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3a30a02-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3709/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for discount point amounts that are greater than one discount point, the resulting loan balance after any fees and expenses allows the property with respect to which the loan was issued to maintain a loan to value ratio of 90 percent or less.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3a30a03-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3709/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Loan Seasoning","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (d) and notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3703"},"text":"section 3703 of this title","children":[],"tail":" or any other provision of law, a loan to a veteran for a purpose specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3710"},"text":"section 3710 of this title","children":[],"tail":" that is a refinance may not be guaranteed or insured under this chapter until the date that is the later of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3a57b04-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3709/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the borrower has made at least six consecutive monthly payments on the loan being refinanced; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3a57b05-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3709/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date that is 210 days after the first payment due date of the loan being refinanced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3a57b06-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3709/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cash-out Refinances","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3a57b07-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3709/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsections (a) through (c) shall not apply in a case of a loan refinancing in which the amount of the principal for the new loan to be guaranteed or insured under this chapter is larger than the payoff amount of the refinanced loan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3a57b08-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3709/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 180 days after the date of the enactment of this section, the Secretary shall promulgate such rules as the Secretary considers appropriate with respect to refinancing described in paragraph (1) to ensure that such refinancing is in the financial interest of the borrower, including rules relating to recoupment, seasoning, and net tangible benefits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3a57b09-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174/tIII/s309/a/1"},"text":"Pub. L. 115–174, title III, § 309(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1348"},"text":"132 Stat. 1348","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/33/s2/b"},"text":"Pub. L. 116–33, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-07-25"},"text":"July 25, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1038"},"text":"133 Stat. 1038","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3a57b0a-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3a57b0b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc3a57b0c-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsec. (d)(2), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174"},"text":"Pub. L. 115–174","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3a57b0d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/33"},"text":"Pub. L. 116–33","children":[],"tail":" substituted “is a refinance” for “is refinanced” in introductory provisions, added pars. (1) and (2), and struck out former pars. (1) and (2) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) the date that is 210 days after the date on which the first monthly payment is made on the loan; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the date on which the sixth monthly payment is made on the loan.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3a57b0e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3a57b0f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174/tIII/s309/a/2"},"text":"Pub. L. 115–174, title III, § 309(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1349"},"text":"132 Stat. 1349","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/174/tIII/s309/a/2"},"text":"\n","children":[{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In prescribing any regulation to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3709"},"text":"section 3709 of title 38","children":[],"tail":", United States Code, as added by paragraph (1), the Secretary of Veterans Affairs may waive the requirements of sections 551 through 559 of title 5, United States Code, if—"}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that urgent or compelling circumstances make compliance with such requirements impracticable or contrary to the public interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary submits to the Committee on Veterans’ Affairs of the Senate and the Committee on Veterans’ Affairs of the House of Representatives, and publishes in the Federal Register, notice of such waiver, including a description of the determination made under clause (i); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a period of 10 days elapses following the notification under clause (ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public notice and comment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a regulation prescribed pursuant to a waiver made under subparagraph (A) is in effect for a period exceeding 1 year, the Secretary shall provide the public an opportunity for notice and comment regarding such regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This paragraph shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authorities under this paragraph shall terminate on the date that is 1 year after the date of the enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3a57b10-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/33"},"text":"Pub. L. 116–33","children":[],"tail":" not to be construed to restrict or otherwise modify the authorities of the Government National Mortgage Association, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/33/s2/c"},"text":"section 2(c) of Pub. L. 116–33","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1721"},"text":"section 1721 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
