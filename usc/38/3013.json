{"tag":"section","attrib":{"id":"idc34f931f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3013"},"text":null,"children":[{"tag":"num","attrib":{"value":"3013"},"text":"§ 3013.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of basic educational assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc34f9320-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3013/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc34f9321-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3013/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3695"},"text":"section 3695 of this title","children":[],"tail":" and except as provided in paragraph (2) of this subsection, each individual entitled to basic educational assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3011"},"text":"section 3011 of this title","children":[],"tail":" is entitled to 36 months of educational assistance benefits under this chapter (or the equivalent thereof in part-time educational assistance)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc34f9322-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3013/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3695"},"text":"section 3695 of this title","children":[],"tail":" and subsection (d) of this section, in the case of an individual described in section 3011(a)(1)(A)(ii)(I) or (III) of this title who is not also described in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3011/a/1/A/i"},"text":"section 3011(a)(1)(A)(i) of this title","children":[],"tail":" or an individual described in section 3011(a)(1)(B)(ii)(I) or (III) of this title who is not also described in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3011/a/1/B/i"},"text":"section 3011(a)(1)(B)(i) of this title","children":[],"tail":", the individual is entitled to one month of educational assistance benefits under this chapter for each month of continuous active duty served by such individual after "},{"tag":"date","attrib":{"date":"1985-06-30"},"text":"June 30, 1985","children":[],"tail":", as part of the obligated period of active duty on which such entitlement is based in the case of an individual described in section 3011(a)(1)(A)(ii)(I) or (III) of this title, or in the case of an individual described in section 3011(a)(1)(B)(ii)(I) or (III) of this title, after "},{"tag":"date","attrib":{"date":"1985-06-30"},"text":"June 30, 1985","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc34f9323-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3013/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3695"},"text":"section 3695 of this title","children":[],"tail":" and subsection (d) of this section, each individual entitled to basic educational assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3012"},"text":"section 3012 of this title","children":[],"tail":" is entitled to (1) one month of educational assistance benefits under this chapter for each month of continuous active duty served by such individual after "},{"tag":"date","attrib":{"date":"1985-06-30"},"text":"June 30, 1985","children":[],"tail":", as part of the obligated period of active duty on which such entitlement is based in the case of an individual described in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3012/a/1/A"},"text":"section 3012(a)(1)(A) of this title","children":[],"tail":", or in the case of an individual described in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3012/a/1/B"},"text":"section 3012(a)(1)(B) of this title","children":[],"tail":", after "},{"tag":"date","attrib":{"date":"1985-06-30"},"text":"June 30, 1985","children":[],"tail":", and (2) one month of educational assistance benefits under this chapter for each four months served by such individual in the Selected Reserve after the applicable date specified in clause (1) of this subsection (other than any month in which the individual served on active duty)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc34f9324-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3013/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc34f9325-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3013/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3695"},"text":"section 3695 of this title","children":[],"tail":" and except as provided in paragraphs (2) and (3) of this subsection, each individual entitled to basic educational assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3018"},"text":"section 3018 of this title","children":[],"tail":" is entitled to 36 months of educational assistance under this chapter (or the equivalent thereof in part-time educational assistance)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc34f9326-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3013/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3695"},"text":"section 3695 of this title","children":[],"tail":", an individual described in clause (B) or (C) of "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3018/b/3"},"text":"section 3018(b)(3) of this title","children":[],"tail":" whose discharge or release from active duty prevents the reduction of the basic pay of such individual by $1,200 is entitled to the number of months of assistance under this chapter that is equal to the lesser of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc34f9327-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3013/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 36 multiplied by a fraction the numerator of which is the amount by which the basic pay of the individual has been reduced under section 3018(c) and the denominator of which is $1,200; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc34f9328-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3013/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of months the individual has served on continuous active duty after ","children":[{"tag":"date","attrib":{"date":"1985-06-30"},"text":"June 30, 1985","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc34f9329-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3013/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3695"},"text":"section 3695 of this title","children":[],"tail":" and subsection (d) of this section, an individual described in clause (B) or (C)(ii) of "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3018/b/3"},"text":"section 3018(b)(3) of this title","children":[],"tail":" (other than an individual described in paragraph (2) of this subsection) is entitled to the number of months of educational assistance under this chapter that is equal to the number of months the individual has served on continuous active duty after "},{"tag":"date","attrib":{"date":"1985-06-30"},"text":"June 30, 1985","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc34f932a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3013/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3695"},"text":"section 3695 of this title","children":[],"tail":", each individual entitled to educational benefits under section 3018A, 3018B, or 3018C of this title is entitled to the lesser of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc34f932b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3013/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 36 months of educational assistance under this chapter (or the equivalent thereof in part-time educational assistance); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc34f932c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3013/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of months of such educational assistance (or such equivalent thereof) that is equal to the number of months served by such individual on active duty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc34f932d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3013/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No individual may receive basic educational assistance benefits under this chapter for a period in excess of 36 months (or the equivalent thereof in part-time educational assistance).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc34f932e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3013/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc34f932f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3013/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding any other provision of this chapter or chapter 36 of this title, any payment of an educational assistance allowance described in paragraph (2) shall not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc34f9330-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3013/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be charged against any entitlement of any individual under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc34f9331-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3013/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be counted toward the aggregate period for which ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3695"},"text":"section 3695 of this title","children":[],"tail":" limits an individual’s receipt of assistance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc34f9332-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3013/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to paragraph (3), the payment of the educational assistance allowance referred to in paragraph (1) is the payment of such an allowance to an individual for pursuit of a course or courses under this chapter if the Secretary finds that the individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc34f9333-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3013/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a person not serving on active duty, had to discontinue such course pursuit as a result of being ordered to serve on active duty under section 688, 12301(a), 12301(d), 12301(g), 12302, or 12304 of title 10; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc34f9334-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3013/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a person serving on active duty, had to discontinue such course pursuit as a result of being ordered to a new duty location or assignment or to perform an increased amount of work; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc34f9335-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3013/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failed to receive credit or lost training time toward completion of the individual’s approved education, professional, or vocational objective as a result of having to discontinue, as described in subparagraph (A) or (B), his or her course pursuit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc34f9336-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3013/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The period for which, by reason of this subsection, an educational assistance allowance is not charged against entitlement or counted toward the applicable aggregate period under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3695"},"text":"section 3695 of this title","children":[],"tail":" shall not exceed the portion of the period of enrollment in the course or courses for which the individual failed to receive credit or with respect to which the individual lost training time, as determined under paragraph (2)(C) of this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc34f9337-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/tVII/s702/a/1"},"text":"Pub. L. 98–525, title VII, § 702(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2557"},"text":"98 Stat. 2557","children":[],"tail":", § 1413; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/576/tIII/s321/3"},"text":"Pub. L. 99–576, title III, § 321(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3277"},"text":"100 Stat. 3277","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/689/tI"},"text":"Pub. L. 100–689, title I","children":[],"tail":", §§ 102(b)(2), 103(b)(2), 111(a)(4), "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4163"},"text":"102 Stat. 4163","children":[],"tail":", 4165, 4171; "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIV/s423/a/2"},"text":"Pub. L. 101–237, title IV, § 423(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2091"},"text":"103 Stat. 2091","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tV/s561/b/1"},"text":"Pub. L. 101–510, div. A, title V, § 561(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1573"},"text":"104 Stat. 1573","children":[],"tail":"; renumbered § 3013 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/127/s2/a"},"text":"Pub. L. 102–127, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-10"},"text":"Oct. 10, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/619"},"text":"105 Stat. 619","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dD/tXLIV/s4404/b/2"},"text":"Pub. L. 102–484, div. D, title XLIV, § 4404(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2706"},"text":"106 Stat. 2706","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/275/tI/s106/b/2"},"text":"Pub. L. 104–275, title I, § 106(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3329"},"text":"110 Stat. 3329","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/419/tI/s103/c"},"text":"Pu