:[],"tail":", substituted “section 1710(a)(2)(G)” for “section 1710(a)(1)(I)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/262/s101/d/9/B"},"text":"Pub. L. 104–262, § 101(d)(9)(B)","children":[],"tail":", struck out “or 1712(f)” before “of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s622"},"text":"section 622 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “1710(a)(1)(I)” for “610(a)(1)(I)” in introductory provisions and “1521” for “521” in par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" substituted “5312(a)” for “3112(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “1522” for “522”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “1521” for “521” in par. (1) and “1710(a) or 1712(f)” for “610(a) or 612(f)” in par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “1724(c)” for “624(c)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/1"},"text":"Pub. L. 102–83, § 4(a)(1)","children":[],"tail":", substituted “administered by the Secretary” for “administered by the Veterans’ Administration” in par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s8013/c/1"},"text":"Pub. L. 101–508, § 8013(c)(1)","children":[],"tail":", designated par. (1) as entire subsec. (a), redesignated cls. (A) to (C) as pars. (1) to (3), respectively, substituted “amount set forth in subsection (b)” for “Category A threshold” in par. (3), and struck out former par. (2) which read as follows: “For the purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s610/a/2/A"},"text":"section 610(a)(2)(A) of this title","children":[],"tail":", a veteran’s income level is described in this paragraph if the veteran’s attributable income is not greater than the Category B threshold.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s8013/c/2"},"text":"Pub. L. 101–508, § 8013(c)(2)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “For the purposes of this section:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) The Category A threshold—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) for the calendar year beginning on ","children":[{"tag":"date","attrib":{"date":"1986-01-01"},"text":"January 1, 1986","children":[],"tail":", is—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) $15,000 in the case of a veteran with no dependents; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) $18,000 in the case of a veteran with one dependent, plus $1,000 for each additional dependent; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) for a calendar year beginning after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":", is the amount in effect for purposes of this paragraph for the preceding calendar year as adjusted under subsection (c) of this subsection."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) The Category B threshold—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) for the calendar year beginning on ","children":[{"tag":"date","attrib":{"date":"1986-01-01"},"text":"January 1, 1986","children":[],"tail":", is—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) $20,000 in the case of a veteran with no dependents; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) $25,000 in the case of a veteran with one dependent, plus $1,000 for each additional dependent; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) for a calendar year beginning after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":", is the amount in effect for purposes of this paragraph for the preceding calendar year as adjusted under subsection (c) of this subsection.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s8013/c/3"},"text":"Pub. L. 101–508, § 8013(c)(3)","children":[],"tail":", struck out “paragraphs (1) and (2) of” before “subsection (b) of this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s8013/c/4"},"text":"Pub. L. 101–508, § 8013(c)(4)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “A determination described in this paragraph is a determination—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) that for the purposes of subsection (a)(1)(C) of this section a veteran’s attributable income is not greater than the Category A threshold; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) that for the purposes of subsection (a)(2) of this section a veteran’s attributable income is not greater than the Category B threshold.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s8013/c/5/A"},"text":"Pub. L. 101–508, § 8013(c)(5)(A)","children":[],"tail":", substituted “the amount determined under subsection (b) of this section” for “the Category A threshold or the Category B threshold, as appropriate”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s8013/c/5/B"},"text":"Pub. L. 101–508, § 8013(c)(5)(B)","children":[],"tail":", added par. (2) and struck out former par. (2) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) A veteran is described in this paragraph for the purposes of subsection (a)(1) of this section if—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) the veteran has an attributable income greater than the Category A threshold; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) the current projections of such veteran’s income for the current year are that the veteran’s income for such year will be substantially below such threshold.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) A veteran is described in this paragraph for the purposes of subsection (a)(2) of this section if—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) the veteran has an attributable income greater than the Category B threshold; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) the current projections of such veteran’s income for the current year are that the veteran’s income for such year will be substantially below such threshold.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/322"},"text":"Pub. L. 100–322","children":[],"tail":" substituted “section” for “sections 610(b)(2) and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272"},"text":"Pub. L. 99–272","children":[],"tail":" amended section generally, revising and restating existing provisions as subsec. (g) and adding subsecs. (a) to (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/330"},"text":"Pub. L. 96–330","children":[],"tail":" substituted provisions relating to the facts that will be accepted as sufficient evidence of an individual’s inability to defray necessary expenses for provisions relating to the use of statements under oath to establish the inability to defray necessary expenses."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/581/s202/k"},"text":"Pub. L. 94–581, § 202(k)","children":[],"tail":", substituted “610(a)(1)(B)” for “610(a)(1)” and “632(a)(2)” for “632(b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/581/s210/a/9"},"text":"Pub. L. 94–581, § 210(a)(9)","children":[],"tail":", substituted “such veteran’s inability” for “his inability”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/500"},"text":"Pub. L. 91–500","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text"