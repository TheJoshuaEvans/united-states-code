{"tag":"section","attrib":{"id":"idc29320d6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s723"},"text":null,"children":[{"tag":"num","attrib":{"value":"723"},"text":"§ 723.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recoupment of relocation expenses paid on behalf of employees of Department","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc29320d7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s723/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary may issue an order directing an employee of the Department to repay the amount, or a portion of the amount, paid to or on behalf of the employee under title 5 for relocation expenses, including any expenses under section 5724 or 5724a of such title, or this title if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc29320d8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s723/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that relocation expenses were paid following an act of fraud or malfeasance that influenced the authorization of the relocation expenses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc29320d9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s723/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" before such repayment, the employee is afforded—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc29320da-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s723/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notice of the proposed order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc29320db-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s723/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an opportunity to respond to the proposed order not later than ten business days following the receipt of such notice; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc29320dc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s723/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary issues the order—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc29320dd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s723/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a proposed order to which an individual responds under paragraph (2)(B), not later than five business days after receiving the response of the individual; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc29320de-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s723/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a proposed order to which an individual does not respond, not later than 15 business days after the Secretary provides notice to the individual under paragraph (2)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc29320df-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s723/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appeal of Order of Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc29320e0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s723/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon the issuance of an order by the Secretary under subsection (a) with respect to an individual, the individual shall have an opportunity to appeal the order to the Director of the Office of Personnel Management before the date that is seven business days after the date of such issuance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc29320e1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s723/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall make a final decision with respect to an appeal under paragraph (1) within 30 days after receiving such appeal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc29320e2-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/41/tII/s205/a"},"text":"Pub. L. 115–41, title II, § 205(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-06-23"},"text":"June 23, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/876"},"text":"131 Stat. 876","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc29320e3-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc29320e4-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc29320e5-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 723 to 729 were renumbered sections 1923 to 1929 of this title, respectively.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc29320e6-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc29320e7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/41/tII/s205/c"},"text":"Pub. L. 115–41, title II, § 205(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-06-23"},"text":"June 23, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/877"},"text":"131 Stat. 877","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/41/tII/s205/c"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s723"},"text":"Section 723 of title 38","children":[],"tail":", United States Code, as added by subsection (a), shall apply with respect to an amount paid by the Secretary of Veterans Affairs to or on behalf of an employee of the Department of Veterans Affairs for relocation expenses on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2017-06-23"},"text":"June 23, 2017","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
