{"tag":"section","attrib":{"id":"idc2be2812-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1513"},"text":null,"children":[{"tag":"num","attrib":{"value":"1513"},"text":"§ 1513.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Veterans 65 years of age and older","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2be2813-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1513/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall pay to each veteran of a period of war who is 65 years of age or older and who meets the service requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1521"},"text":"section 1521 of this title","children":[],"tail":" (as prescribed in subsection (j) of that section) pension at the rates prescribed by "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1521"},"text":"section 1521 of this title","children":[],"tail":" and under the conditions (other than the permanent and total disability requirement) applicable to pension paid under that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2be2814-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1513/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a veteran is eligible for pension under both this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1521"},"text":"section 1521 of this title","children":[],"tail":", pension shall be paid to the veteran only under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1521"},"text":"section 1521 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2be2815-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/103/tII/s207/a/1"},"text":"Pub. L. 1