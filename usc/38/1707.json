{"tag":"section","attrib":{"id":"idc2df6c61-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1707"},"text":null,"children":[{"tag":"num","attrib":{"value":"1707"},"text":"§ 1707.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2df6c62-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1707/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds appropriated to carry out this chapter may not be used for purposes that are inconsistent with the Assisted Suicide Funding Restriction Act of 1997 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14401"},"text":"42 U.S.C. 14401","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2df6c63-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1707/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may furnish sensori-neural aids only in accordance with guidelines prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2df6c64-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/12/s9/i/1"},"text":"Pub. L. 105–12, § 9(i)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-04-30"},"text":"Apr. 30, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/27"},"text":"111 Stat. 27","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/135/tII/s208/a/2"},"text":"Pub. L. 107–135, title II, § 208(a)(2)","children":[],"tail":", (f)(2), "},{"tag":"date","attrib":{"date":"2002-01-23"},"text":"Jan. 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2462"},"text":"115 Stat. 2462","childre