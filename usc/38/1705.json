{"tag":"section","attrib":{"id":"idc2dd2210-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1705"},"text":null,"children":[{"tag":"num","attrib":{"value":"1705"},"text":"§ 1705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management of health care: patient enrollment system","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2dd2211-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1705/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In managing the provision of hospital care and medical services under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1710/a"},"text":"section 1710(a) of this title","children":[],"tail":", the Secretary, in accordance with regulations the Secretary shall prescribe, shall establish and operate a system of annual patient enrollment. The Secretary shall manage the enrollment of veterans in accordance with the following priorities, in the order listed:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2dd2212-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1705/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Veterans with service-connected disabilities rated 50 percent or greater and veterans who were awarded the medal of honor under section 7271, 8291, or 9271 of title 10 or section 491 ","children":[{"tag":"ref","attrib":{"idref":"fn002032"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002032"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 14."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2dd2213-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1705/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Veterans with service-connected disabilities rated 30 percent or 40 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2dd2214-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1705/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Veterans who are former prisoners of war or who were awarded the Purple Heart, veterans with service-connected disabilities rated 10 percent or 20 percent, and veterans described in subparagraphs (B) and (C) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1710/a/2"},"text":"section 1710(a)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2dd2215-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1705/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Veterans who are in receipt of increased pension based on a need of regular aid and attendance or by reason of being permanently housebound and other veterans who are catastrophically disabled.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2dd2216-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1705/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Veterans not covered by paragraphs (1) through (4) who are unable to defray the expenses of necessary care as determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1722/a"},"text":"section 1722(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2dd2217-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1705/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All other veterans eligible for hospital care, medical services, and nursing home care under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1710/a/2"},"text":"section 1710(a)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2dd2218-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1705/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Veterans described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1710/a/3"},"text":"section 1710(a)(3) of this title","children":[],"tail":" who are eligible for treatment as a low-income family under section 3(b) of the United States Housing Act of 1937 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437a/b"},"text":"42 U.S.C. 1437a(b)","children":[],"tail":") for the area in which such veterans reside, regardless of whether such veterans are treated as single person families under paragraph (3)(A) of such section 3(b) or as families under paragraph (3)(B) of such section 3(b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2dd2219-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1705/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Veterans described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1710/a/3"},"text":"section 1710(a)(3) of this title","children":[],"tail":" who are not covered by paragraph (7)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2dd221a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1705/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the design of an enrollment system under subsection (a), the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2dd221b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1705/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall ensure that the system will be managed in a manner to ensure that the provision of care to enrollees is timely and acceptable in quality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2dd221c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1705/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may establish additional priorities within each priority group specified in subsection (a), as the Secretary determines necessary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2dd221d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1705/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may provide for exceptions to the specified priorities where dictated by compelling medical reasons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2dd221e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1705/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2dd221f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1705/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not provide hospital care or medical services to a veteran under paragraph (2) or (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1710/a"},"text":"section 1710(a) of this title","children":[],"tail":" unless the veteran enrolls in the system of patient enrollment established by the Secretary under subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2dd2220-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1705/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall provide hospital care and medical services under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1710/a/1"},"text":"section 1710(a)(1) of this title","children":[],"tail":", and under subparagraph (B) of "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1710/a/2"},"text":"section 1710(a)(2) of this title","children":[],"tail":", for the 12-month period following such veteran’s discharge or release from service, to any veteran referred to in such sections for a disability specified in the applicable subparagraph of such section, notwithstanding the failure of the veteran to enroll in the system of patient enrollment referred to in subsection (a) of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2dd2221-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/262/tI/s104/a/1"},"text":"Pub. L. 104–262, title I, § 104(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3182"},"text":"110 Stat. 3182","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/117/tI/s112/2"},"text":"Pub. L. 106–117, title I, § 112(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-30"},"text":"Nov. 30, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1556"},"text":"113 Stat. 1556","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/135/tII/s202/a"},"text":"Pub. L. 107–135, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-23"},"text":"Jan. 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2457"},"text":"115 Stat. 2457","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/330/tIII/s308/g/4"},"text":"Pub. L. 107–330, title III, § 308(g)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-06"},"text":"Dec. 6, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2828"},"text":"116 Stat. 2828","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/163/tV/s512"},"text":"Pub. L. 111–163, title V, § 512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-05-05"},"text":"May 5, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1164"},"text":"124 Stat. 1164","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/315/tVI/s603/a/1"},"text":"Pub. L. 114–315, title VI, § 603(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1570"},"text":"130 Stat. 1570","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s809/n/1/A"},"text":"Pub. L. 115–232, div. A, title VIII, § 809(n)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1843"},"text":"132 Stat. 1843","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2dd2222-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc2dd2223-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc2dd2224-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s491"},"text":"Section 491 of title 14","children":[],"tail":", referred to in subsec. (a)(1), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s2732"},"text":"section 2732 of title 14","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s116/b"},"text":"Pub. L. 115–282, title I, § 116(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4226"},"text":"132 Stat. 4226","children":[],"tail":", and references to "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s491"},"text":"section 491 of title 14","children":[],"tail":" deemed to refer to such redesignated section, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/1"},"text":"section 123(b)(1) of Pub. L. 115–282","children":[],"tail":", set out as a References to Redesignated Sections of Title 14 note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s101"},"text":"section 101 of Title 14","children":[],"tail":", Coast Guard."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc2dd2225-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “section 7271, 8291, or 9271 of title 10” for “section 3741, 6241, or 8741 of title 10”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/315/s603/a/1/A"},"text":"Pub. L. 114–315, § 603(a)(1)(A)","children":[],"tail":", inserted “and veterans who were awarded the medal of honor under section 3741, 6241, or 8741 of title 10 or "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s491"},"text":"section 491 of title 14","children":[],"tail":"” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/315/s603/a/1/B"},"text":"Pub. L. 114–315, § 603(a)(1)(B)","children":[],"tail":", struck out “veterans who were awarded the medal of honor under section 3741, 6241, or 8741 of title 10 or "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s491"},"text":"section 491 of title 14","children":[],"tail":",” after “awarded the Purple Heart,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163"},"text":"Pub. L. 111–163","children":[],"tail":" inserted “veterans who were awarded the medal of honor under section 3741, 6241, or 8741 of title 10 or "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s491"},"text":"section 491 of title 14","children":[],"tail":",” after “the Purple Heart,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(7), (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/135"},"text":"Pub. L. 107–135","children":[],"tail":" added pars. (7) and (8) and struck out former par. (7) which read as follows: “Veterans described in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1710/a/3"},"text":"section 1710(a)(3) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/330"},"text":"Pub. L. 107–330","children":[],"tail":" substituted “The Secretary” for “Effective on "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"October 1, 1998","children":[],"tail":", the Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117"},"text":"Pub. L. 106–117","children":[],"tail":" inserted “or who were awarded the Purple Heart” after “former prisoners of war”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc2dd2226-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc2dd2227-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc2dd2228-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/135/tII/s202/c"},"text":"Pub. L. 107–135, title II, § 202(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-23"},"text":"Jan. 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2457"},"text":"115 Stat. 2457","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/135/tII/s202/c"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1710"},"text":"section 1710 of this title","children":[],"tail":"] shall take effect on "},{"tag":"date","attrib":{"date":"2002-10-01"},"text":"October 1, 2002","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc2dd2229-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Application","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/315/tVI/s603/a/2"},"text":"Pub. L. 114–315, title VI, § 603(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1570"},"text":"130 Stat. 1570","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/315/tVI/s603/a/2"},"text":"“The priority of enrollment of medal of honor recipients in the system of annual patient enrollment established and operated under section 1705(a) of such title [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1705/a"},"text":"38 U.S.C. 1705(a)","children":[],"tail":"], as amended by paragraph (1), shall apply to each such recipient, regardless of the date on which the medal is awarded.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc2dd222a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Assessment of Implementation and Operation of Amendments by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/262"},"text":"Pub. L. 104–262","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/262/tI/s106"},"text":"Pub. L. 104–262, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3184"},"text":"110 Stat. 3184","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/262/tI/s106"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assessment Systems","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Veterans Affairs shall establish information systems to assess the experience of the Department of Veterans Affairs in implementing sections 101, 103, and 104 [enacting this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1706"},"text":"section 1706 of this title","children":[],"tail":", amending sections 1525, 1701, 1703, 1710, 1712, 1712A, 1717, 1718, 1720, 1722, 1729, 2104, 5317, 8110, and 8111A of this title, and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1701"},"text":"section 1701 of this title","children":[],"tail":"], including the amendments made by those sections, during fiscal year 1997. The Secretary shall establish those information systems in time to include assessments under such systems in the report required under subsection (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1998-03-01"},"text":"March 1, 1998","children":[],"tail":", the Secretary shall submit to the Committees on Veterans’ Affairs of the Senate and House of Representatives a report reflecting the experience of the Department during fiscal year 1997 on—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect of implementation of, and provision and management of care under, sections 101, 103, and 104 (including the amendments made by those sections) on demand for health care services from the Department of Veterans Affairs by veterans described in paragraphs (1), (2), and (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1710/a"},"text":"section 1710(a) of title 38","children":[],"tail":", United States Code, as amended by section 101;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any differing patterns of demand on the part of such veterans relating to such factors as relative distance from Department facilities and prior experience, or lack of experience, as recipients of care from the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the Department has met such demand for care; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" changes in health-care delivery patterns in Department facilities and the fiscal impact of such changes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Matters To Be Included","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report under subsection (b) shall include detailed information with respect to fiscal year 1997 regarding the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of veterans enrolled for care at each Department medical facility and, of such veterans, the number enrolled at each such facility who had not received care from the Department during the preceding three fiscal years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to the veterans who had not received care from the Department during the three preceding fiscal years, the total cost of providing care to such veterans, shown in total and separately (A) by level of care, and (B) by reference to whether care was furnished in Department facilities or under contract arrangements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to the number of veterans described in paragraphs (1), (2), and (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1710/a"},"text":"section 1710(a) of title 38","children":[],"tail":", United States Code, as amended by section 101, who applied for health care from the Department during fiscal year 1997—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number who applied for care (shown in total and separately by facility);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number who were denied enrollment (shown in total and separately by facility); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number who were denied care which was considered to be medically necessary but not of an emergency nature (shown in total and separately by facility).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The numbers and characteristics of, and the type and extent of health care furnished to, veterans enrolled for care (shown in total and separately by facility).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The numbers and characteristics of, and the type and extent of health care furnished to, veterans not enrolled for care (shown separately by reference to each class of eligibility, both in total and separately by facility).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The specific fiscal impact (shown in total and by geographic health-care delivery areas) of changes in delivery patterns instituted under the amendments made by this title [enacting this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1706"},"text":"section 1706 of this title","children":[],"tail":" and amending sections 1525, 1701, 1703, 1710, 1712, 1712A, 1717, 1718, 1720, 1722, 1729, 2104, 5317, 8110, and 8111A of this title].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
