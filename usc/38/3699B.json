{"tag":"section","attrib":{"id":"idc39e4f86-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699B"},"text":null,"children":[{"tag":"num","attrib":{"value":"3699B"},"text":"§ 3699B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain for-profit educational institutions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc39e4f87-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of any for-profit educational institution that is converted to a nonprofit educational institution, the State approving agency or the Secretary when acting as a State approving agency shall conduct annual risk-based surveys of the institution during the three-year period beginning on the date on which the educational institution is so converted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc39e4f88-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Risk-based Survey Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “risk-based survey” means the risk-based survey developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3673A"},"text":"section 3673A of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc39e4f89-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/tI/s1022/a"},"text":"Pub. L. 116–315, title I, § 1022(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4959"},"text":"134 Stat. 4959","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc39e4f8a-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc39e4f8b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc39e4f8c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/tI/s1022/c"},"text":"Pub. L. 116–315, title I, § 1022(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4959"},"text":"134 Stat. 4959","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/16/s5/a"},"text":"Pub. L. 117–16, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-06-08"},"text":"June 8, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/283"},"text":"135 Stat. 283","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/16/s5/a"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3699B"},"text":"Section 3699B of title 38","children":[],"tail":", United States Code, as added by subsection (a), shall apply with respect to the conversion of a for-profit educational institution to a nonprofit educational institution, or the conversion of a for-profit educational institution to a public educational institution, that occurs on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/16/s5/b"},"text":"Pub. L. 117–16, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-06-08"},"text":"June 8, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/283"},"text":"135 Stat. 283","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/16/s5/b"},"text":"“The amendment made by subsection (a) [amending ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/s1022/c"},"text":"section 1022(c) of Pub. L. 116–315","children":[],"tail":", set out above] shall apply as if included in the enactment of the Johnny Isakson and David P. Roe, M.D. Veterans Health Care and Benefits Improvement Act of 2020 ("},{"tag":"ref","attrib":{"href":"/us/pl/116/315"},"text":"Public Law 116–315","children":[],"tail":").”"}],"tail":"\n]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
