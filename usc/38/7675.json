{"tag":"section","attrib":{"id":"idc417ebb1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7675"},"text":null,"children":[{"tag":"num","attrib":{"value":"7675"},"text":"§ 7675.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Breach of agreement: liability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc417ebb2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7675/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Liquidated Damages","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A participant in the Program (other than a participant described in subsection (b)) who fails to accept payment, or instructs the educational institution in which the participant is enrolled not to accept payment, in whole or in part, of a scholarship under the agreement entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7603"},"text":"section 7603 of this title","children":[],"tail":" shall be liable to the United States for liquidated damages in the amount of $1,500. Such liability is in addition to any period of obligated service or other obligation or liability under the agreement."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc417ebb3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7675/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Liability During Course of Education or Training","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc417ebb4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7675/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subsection (d), a participant in the Program shall be liable to the United States for the amount which has been paid to or on behalf of the participant under the agreement if any of the following occurs:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc417ebb5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7675/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The participant fails to maintain an acceptable level of academic standing in the educational institution in which the participant is enrolled (as determined by the educational institution under regulations prescribed by the Secretary).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc417ebb6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7675/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The participant is dismissed from such educational institution for disciplinary reasons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc417ebb7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7675/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The participant voluntarily terminates the course of education or training in such educational institution before the completion of such course of education or training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc417ebb8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7675/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The participant fails to become licensed to practice medicine, osteopathy, dentistry, podiatry, or optometry in a State, fails to become licensed as a registered nurse in a State, or fails to meet any applicable licensure requirement in the case of any other health-care personnel who provide either direct patient-care services or services incident to direct patient-care services, during a period of time determined under regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc417ebb9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7675/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The participant fails to maintain employment, while enrolled in the course of training being pursued by the participant, as a Department employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc417ebba-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7675/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Liability under this subsection is in lieu of any service obligation arising under a participant’s agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc417ebbb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7675/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Liability During Period of Obligated Service","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc417ebbc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7675/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (d), if a participant in the Program breaches the agreement by failing for any reason to complete such participant’s period of obligated service, the United States shall be entitled to recover from the participant an amount determined in accordance with the following formula:","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"    t−s","children":[],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"A=3Φ  ( —— )","children":[],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"     t","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc417ebbd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7675/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In such formula:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc417ebbe-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7675/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “A” is the amount the United States is entitled to recover.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc417ebbf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7675/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “Φ” is the sum of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc417ebc0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7675/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts paid under this subchapter to or on behalf of the participant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc417ebc1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7675/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interest on such amounts which would be payable if at the time the amounts were paid they were loans bearing interest at the maximum legal prevailing rate, as determined by the Treasurer of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc417ebc2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7675/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “t” is the total number of months in the participant’s period of obligated service, including any additional period of obligated service in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7673/c/2"},"text":"section 7673(c)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc417ebc3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7675/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “s” is the number of months of such period served by the participant in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7673"},"text":"section 7673 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc417ebc4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7675/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Liability for Reductions-in-Force","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Liability shall not arise under subsection (b)(1)(E) or (c) in the case of a participant otherwise covered by the subsection concerned if the participant fails to maintain employment as a Department employee due to a staffing adjustment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc417ebc5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7675/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Period for Payment of Damages","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any amount of damages which the United States is entitled to recover under this section shall be paid to the United States within the 1-year period beginning on the date of the breach of the agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc417ebc6-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/tVIII/s802/a"},"text":"Pub. L. 105–368, title VIII, § 802(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3355"},"text":"112 Stat. 3355","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/315/tVI/s616"},"text":"Pub. L. 114–315, title VI, § 616","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1577"},"text":"130 Stat. 1577","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc417ebc7-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc417ebc8-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc417ebc9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/315"},"text":"Pub. L. 114–315","children":[],"tail":" substituted “The” for “In the case of a participant who is a part-time student, the”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
