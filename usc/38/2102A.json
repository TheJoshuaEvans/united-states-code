{"tag":"section","attrib":{"id":"idc33c8038-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2102A"},"text":null,"children":[{"tag":"num","attrib":{"value":"2102A"},"text":"§ 2102A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance for individuals residing temporarily in housing owned by a family member","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc33c8039-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2102A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provision of Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of a disabled individual who is described in subsection (a)(2) or (b)(2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2101"},"text":"section 2101 of this title","children":[],"tail":" and who is residing, but does not intend to permanently reside, in a residence owned by a member of such individual’s family, the Secretary may assist the individual in acquiring such adaptations to such residence as are determined by the Secretary to be reasonably necessary because of the individual’s disability."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc33c803a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2102A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount of Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc33c803b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2102A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The assistance authorized under subsection (a) may not exceed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc33c803c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2102A/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $28,000, in the case of an individual described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2101/a/2"},"text":"section 2101(a)(2) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc33c803d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2102A/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000, in the case of an individual described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2101/b/2"},"text":"section 2101(b)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc33c803e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2102A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Effective on October 1 of each year (beginning in 2012), the Secretary shall use the same percentage calculated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2102/e"},"text":"section 2102(e) of this title","children":[],"tail":" to increase the amounts described in paragraph (1) of this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc33c803f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2102A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The assistance authorized by subsection (a) shall be limited in the case of any individual to one residence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc33c8040-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2102A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Assistance under this section shall be provided in accordance with such regulations as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc33c8041-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2102A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No assistance may be provided under this section after ","children":[{"tag":"date","attrib":{"date":"2026-09-30"},"text":"September 30, 2026","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc33c8042-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/233/tI/s101/a"},"text":"Pub. L. 109–233, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-06-15"},"text":"June 15, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/398"},"text":"120 Stat. 398","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dB/tVI"},"text":"Pub. L. 110–289, div. B, title VI","children":[],"tail":", §§ 2602(b)(3), (7)(B), 2604, "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref",