02(b)(3)(A)","children":[],"tail":", substituted “individual” for “veteran”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/s2604"},"text":"Pub. L. 110–289, § 2604","children":[],"tail":", substituted “after "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"December 31, 2011","children":[],"tail":"” for “after the end of the five-year period that begins on the date of the enactment of the Veterans’ Housing Opportunity and Benefits Improvement Act of 2006”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc33c8046-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc33c8047-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/37"},"text":"Pub. L. 119–37","children":[],"tail":" effective as if enacted on "},{"tag":"date","attrib":{"date":"2025-09-30"},"text":"Sept. 30, 2025","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/119/37/s7406"},"text":"section 7406 of Pub. L. 119–37","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s111A"},"text":"section 111A of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc33c8048-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/154/tII/s205/d"},"text":"Pub. L. 112–154, title II, § 205(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1178"},"text":"126 Stat. 1178","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/154/tII/s205/d"},"text":"“The amendments made by this section [amending this section] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":"] and shall apply with respect to assistance furnished in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2102A"},"text":"section 2102A of title 38","children":[],"tail":", United States Code, on or after that date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
