inning with fiscal year 1988,” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/14/s8/a/10/A/ii"},"text":"Pub. L. 107–14, § 8(a)(10)(A)(ii)","children":[],"tail":", substituted “subparagraph (A)” for “clause (A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/14/s8/a/10/A/iii"},"text":"Pub. L. 107–14, § 8(a)(10)(A)(iii)","children":[],"tail":", substituted “subparagraphs (A) and (B)” for “clauses (A) and (B)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/14/s8/a/10/B"},"text":"Pub. L. 107–14, § 8(a)(10)(B)","children":[],"tail":", struck out “on or after "},{"tag":"date","attrib":{"date":"1988-07-01"},"text":"July 1, 1988","children":[],"tail":"” after “local veterans’ employment representatives”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/14/s8/a/10/C/i"},"text":"Pub. L. 107–14, § 8(a)(10)(C)(i)","children":[],"tail":", substituted “shall perform the following functions:” for “shall—” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1) to (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/14/s8/a/10/C/ii"},"text":"Pub. L. 107–14, § 8(a)(10)(C)(ii)","children":[],"tail":", (iii), capitalized the first letter of the first word and substituted a period for the semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/95/s9/b/1"},"text":"Pub. L. 107–95, § 9(b)(1)","children":[],"tail":", which directed that “and” be struck out at end, could not be executed because of the intervening amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/107/14/s8/a/10/C/iv"},"text":"Pub. L. 107–14, § 8(a)(10)(C)(iv)","children":[],"tail":". See below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/14/s8/a/10/C/ii"},"text":"Pub. L. 107–14, § 8(a)(10)(C)(ii)","children":[],"tail":", (iv), capitalized the first letter of the first word and substituted a period for “; and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/95/s9/b/2"},"text":"Pub. L. 107–95, § 9(b)(2)","children":[],"tail":", substituted “; and” for period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/14/s8/a/10/C/ii"},"text":"Pub. L. 107–14, § 8(a)(10)(C)(ii)","children":[],"tail":", capitalized the first letter of the first word."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/95/s9/b/3"},"text":"Pub. L. 107–95, § 9(b)(3)","children":[],"tail":", added par. (13)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2004"},"text":"section 2004 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “4102A(b)(5)(A)(ii)” for “2002A(b)(5)(A)(ii)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/16/s10/a/8/A"},"text":"Pub. L. 102–16, § 10(a)(8)(A)","children":[],"tail":", (B), substituted “appointment” for “assignment” in two places in introductory provisions and in subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/16/s10/a/8/C"},"text":"Pub. L. 102–16, § 10(a)(8)(C)","children":[],"tail":", substituted “appointment” for “assigning”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “4212” for “2012”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “1712A” for “612A”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/16/s10/a/8/D"},"text":"Pub. L. 102–16, § 10(a)(8)(D)","children":[],"tail":", struck out subsec. (d) which read as follows: “Local veterans’ employment representatives shall be assigned, in accordance with this section, by the administrative head of the employment service in each State after consultation with the Director for Veterans’ Employment and Training.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" substituted “Department of Veterans Affairs” for “Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323"},"text":"Pub. L. 100–323","children":[],"tail":" substituted “Local veterans’ employment representatives” for “Employees of local offices” as section catchline and amended section generally. Prior to amendment, section read as follows: “Except as may be determined by the Secretary of Labor based on a demonstrated lack of need for such services, there shall be assigned by the administrative head of the employment service in each State one or more employees, preferably eligible veterans or eligible persons, on the staffs of local employment service offices, whose services shall be fully devoted to discharging the duties prescribed for the veterans’ employment representative and such representative’s assistants.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/502"},"text":"Pub. L. 94–502","children":[],"tail":" substituted “eligible veterans or eligible persons” for “eligible veterans” and “such representative’s” for “his”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/540"},"text":"Pub. L. 92–540","children":[],"tail":" substituted provisions relating to the assignment of employees of local offices for provisions relating to the cooperation of other Federal agencies. See "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2005"},"text":"section 2005 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/358"},"text":"Pub. L. 89–358","children":[],"tail":" inserted “or of service after "},{"tag":"date","attrib":{"date":"1955-01-31"},"text":"January 31, 1955","children":[],"tail":"” after “veterans of any war”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3bad804-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3bad805-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsec. (d) of this section as amended by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461"},"text":"Pub. L. 109–461","children":[],"tail":" applicable with respect to pay periods beginning after the date that is 180 days after "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/461/s602/c"},"text":"section 602(c) of Pub. L. 109–461","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4103A"},"text":"section 4103A of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3bad806-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/288"},"text":"Pub. L. 107–288","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2002-11-07"},"text":"Nov. 7, 2002","children":[],"tail":", and applicable for program years under this chapter beginning on or after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/288/s4/b/3"},"text":"section 4(b)(3) of Pub. L. 107–288","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4103A"},"text":"section 4103A of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3bad807-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323"},"text":"Pub. L. 100–323","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", except that subsec. (a)(1) to (3) effective for all of fiscal year 1988 and subsequent fiscal years, see section 16(a), (b)(1)(C) of "},{"tag":"ref","attrib":{"href":"/us/pl/100/323"},"text":"Pub. L. 100–323","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3104"},"text":"section 3104 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3bad808-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/502"},"text":"Pub. L. 94–502","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1976-12-01"},"text":"Dec. 1, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/502/s703/c"},"text":"section 703(c) of Pub. L. 94–502","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3693"},"text":"section 3693 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3bad809-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1972 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/540"},"text":"Pub. L. 92–540","children":[],"tail":" effective 90 days after "},{"tag":"date","attrib":{"date":"1972-10-24"},"text":"Oct. 24, 1972","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/92/540/s601/b"},"text":"section 601(b) of Pub. L. 92–540","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4101"},"text":"section 4101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3bad80a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Pilot Program To Integrate and Streamline Functions of Local Veterans’ Employment Representatives","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/275/tIII/s303"},"text":"Pub. L. 104–275, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3332"},"text":"110 Stat. 3332","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/105/368/tX/s1005/c/1"},"text":"Pub. L. 105–368, title X, § 1005(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3366"},"text":"112 Stat. 3366","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/368/tX/s1005/c/1"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Conduct Pilot Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In order to assess the effects on the timeliness and quality of services to veterans resulting from re-focusing the staff resources of local veterans’ employment representatives, the Secretary of Labor may conduct a pilot program under which the primary responsibilities of local veterans’ employment representatives will be case management and the provision and facilitation of direct employment and training services to veterans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorities Under Chapter","children":[],"tail":" 41.—"}],"tail":null},{"tag":"content","attrib":{},"text":"To implement the pilot program, the Secretary of Labor may suspend or limit application of those provisions of chapter 41 of title 38, United States Code (other than subsections (b)(1) and (c) of section 4104) that pertain to the Local Veterans’ Employment Representative Program in States designated by the Secretary under subsection (d), except that the Secretary may use the authority of such chapter, as the Secretary may determine, in conjunction with the authority of this section, to carry out the pilot program. The Secretary may collect such data as the Secretary considers necessary for assessment of the pilot program. The Secretary shall measure and evaluate on a continuing basis the effectiveness of the pilot program in achieving its stated goals in general, and in achieving such goals in relation to their cost, their effect on related programs, and their structure and mechanisms for delivery of services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Targeted Veterans","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Within the pilot program, eligible veterans who are among groups most in need of intensive services, including disabled veterans, economically disadvantaged veterans, and veterans separated within the previous four years from active military, naval, or air service shall be given priority for service by local veterans’ employment representatives. Priority for the provision of service shall be given first to disabled veterans and then to the other categories of veterans most in need of intensive services in accordance with priorities determined by the Secretary of Labor in consultation with appropriate State labor authorities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"States Designated","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The pilot program shall be limited to not more than five States to be designated by the Secretary of Labor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than one year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":"], the Secretary of Labor shall submit to the Committees on Veterans’ Affairs of the Senate and the House of Representatives an interim report describing in detail the development and implementation of the pilot program on a State by State basis."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 120 days after the expiration of this section under subsection (h), the Secretary of Labor shall submit to the Committees on Veterans’ Affairs of the Senate and the House of Representatives a final report evaluating the results of the pilot program and make recommendations based on the evaluation, which may include legislative recommendations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘veteran’ has the meaning given such term by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s101/2"},"text":"section 101(2) of title 38","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘disabled veteran’ has the meaning given such term by section 4211(3) of such title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘active military, naval, or air service’ has the meaning given such term by section 101(24) of such title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"“(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allocation of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any amount otherwise available for fiscal year 1997, 1998, or 1999 to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4102A/b/5"},"text":"section 4102A(b)(5) of title 38","children":[],"tail":", United States Code, with respect to a State designated by the Secretary of Labor pursuant to subsection (d) shall be available to carry out the pilot program during that fiscal year with respect to that State."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"“(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expiration Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority to carry out the pilot program under this section shall expire on ","children":[{"tag":"date","attrib":{"date":"1999-10-01"},"text":"October 1, 1999","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
