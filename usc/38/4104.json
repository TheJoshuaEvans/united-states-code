{"tag":"section","attrib":{"id":"idc3bad7f1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104"},"text":null,"children":[{"tag":"num","attrib":{"value":"4104"},"text":"§ 4104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local veterans’ employment representatives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3bad7f2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement for Employment by States of a Sufficient Number of Representatives","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to approval by the Secretary, a State shall employ such full- and part-time local veterans’ employment representatives as the State determines appropriate and efficient to carry out employment, training, and placement services under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3bad7f3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Principal Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"As principal duties, local veterans’ employment representatives shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3bad7f4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct outreach to employers in the area to assist veterans in gaining employment, including conducting seminars for employers and, in conjunction with employers, conducting job search workshops and establishing job search groups; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3bad7f5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate employment, training, and placement services furnished to veterans in a State under the applicable State employment service delivery systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3bad7f6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement for Qualified Veterans and Eligible Persons","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State shall, to the maximum extent practicable, employ qualified veterans or eligible persons to carry out the services referred to in subsection (a). Preference shall be accorded in the following order:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3bad7f7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To qualified service-connected disabled veterans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3bad7f8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If no veteran described in paragraph (1) is available, to qualified eligible veterans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3bad7f9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If no veteran described in paragraph (1) or (2) is available, then to qualified eligible persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3bad7fa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Part-Time Employees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A part-time local veterans’ employment representative shall perform the functions of a local veterans’ employment representative under this section on a half-time basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3bad7fb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Requirements for Full-time Employees","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3bad7fc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A full-time local veterans’ employment representative shall perform only duties related to the employment, training, and placement services under this chapter, and shall not perform other non-veteran-related duties that detract from the representative’s ability to perform the representative’s duties related to employment, training, and placement services under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3bad7fd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall conduct regular audits to ensure compliance with paragraph (1). If, on the basis of such an audit, the Secretary determines that a State is not in compliance with paragraph (1), the Secretary may reduce the amount of a grant made to the State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4102A/b/5"},"text":"section 4102A(b)(5) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3bad7fe-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4104/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each local veterans’ employment representative shall be administratively responsible to the manager of the employment service delivery system and shall provide reports, not less frequently than quarterly, to the manager of such office and to the Director for Veterans’ Employment and Training for the State regarding compliance with Federal law and regulations with respect to special services and priorities for eligible veterans and eligible persons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3bad7ff-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1219"},"text":"72 Stat. 1219","children":[],"ta