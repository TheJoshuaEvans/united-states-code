{"tag":"section","attrib":{"id":"idc29321ac-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902"},"text":null,"children":[{"tag":"num","attrib":{"value":"902"},"text":"§ 902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement and arrest authority of Department police officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc29321ad-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc29321ae-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Employees of the Department who are Department police officers shall, with respect to acts occurring on Department property—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc29321af-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enforce Federal laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc29321b0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enforce the rules prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s901"},"text":"section 901 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc29321b1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enforce traffic and motor vehicle laws of a State or local government (by issuance of a citation for violation of such laws) within the jurisdiction of which such Department property is located as authorized by an express grant of authority under applicable State or local law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc29591b2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry the appropriate Department-issued weapons, including firearms, while off Department property in an official capacity or while in an official travel status;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc29591b3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct investigations, on and off Department property, of offenses that may have been committed on property under the original jurisdiction of Department, consistent with agreements or other consultation with affected Federal, State, or local law enforcement agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc29591b4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out, as needed and appropriate, the duties described in subparagraphs (A) through (E) when engaged in duties authorized by other Federal statutes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc29591b5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to regulations prescribed under subsection (b), a Department police officer may make arrests on Department property for a violation of a Federal law or any rule prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s901/a"},"text":"section 901(a) of this title","children":[],"tail":", and on any arrest warrant issued by competent judicial authority."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc29591b6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Beginning not later than 180 days after the date of the enactment of the Joseph Maxwell Cleland and Robert Joseph Dole Memorial Veterans Benefits and Health Care Improvement Act of 2022, the Secretary shall require Department police officers to use cameras worn on the individual police officer’s person that record and store audio and video (commonly known as “body worn cameras”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc29591b7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall prescribe regulations with respect to Department police officers. Such regulations shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc29591b8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" policies with respect to the exercise by Department police officers of the enforcement and arrest authorities provided by this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc29591b9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the scope and duration of training that is required for Department police officers, with particular emphasis on dealing with situations involving patients; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc29591ba-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rules limiting the carrying and use of weapons by Department police officers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc29591bb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The powers granted to Department police officers designated under this section shall be exercised in accordance with guidelines approved by the Secretary and the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc29591bc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Rates of basic pay for Department police officers may be increased by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7455"},"text":"section 7455 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc29591bd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc29591be-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall publish on the internet website of each facility of the Department the following information with respect to the facility:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc29591bf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Summaries and statistics covering the previous five-year period regarding—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc29591c0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arrests made by and tickets issued by Department police officers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc29591c1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prosecutions, ticketing, and other actions relating to such arrests;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc29591c2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/e/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of force and weapons discharge by Department police officers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc29591c3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/e/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complaints, investigations, and disciplinary actions regarding Department police officers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc29591c4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Contact information for employees of the Department and the public to directly contact the police force of the facility, including for an individual (or the representative, attorney, or authorized agent of the individual) to request information regarding the arrest, ticketing, detainment, use of force, or other police matters pertaining to that individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc29591c5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall ensure that each police force of a facility of the Department is able to provide to an individual who contacts the police force pursuant to paragraph (1)(B) the information described in such paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc29591c6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Police Incidents","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc29591c7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc29591c8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall track and analyze the following information regarding the police force of the Department:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc29591c9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/f/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Arrests made by and tickets issued by Department police officers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc29591ca-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/f/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prosecutions, ticketing, and other actions relating to such arrests.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc29591cb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/f/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The use of force and weapons discharge.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc29591cc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/f/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Complaints, investigations, and disciplinary actions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc29591cd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall carry out subparagraph (A) by implementing one or more Department-wide data systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc29591ce-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc29591cf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Beginning not later than one year after the date of the enactment of the Joseph Maxwell Cleland and Robert Joseph Dole Memorial Veterans Benefits and Health Care Improvement Act of 2022, the Secretary shall ensure that each incident described in subparagraph (C) is promptly reported to the Assistant Secretary with responsibility for operations, preparedness, security, and law enforcement functions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc29591d0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Assistant Secretary shall, in a timely manner—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc29591d1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review each incident described in subparagraph (C)(i) that is reported under subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc29591d2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investigate each incident described in subparagraph (C)(ii) that is reported under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc29591d3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An incident described in this subparagraph is either of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc29591d4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/f/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An incident, including an allegation, of the use of force by a Department police officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc29591d5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s902/f/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An incident, including an allegation, of the use of force by a Department police officer that results in any person receiving medical attention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc29591d6-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s2/a"},"text":"Pub. L. 102–83, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/397"},"text":"105 Stat. 397","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/163/tX/s1001"},"text":"Pub. L. 111–163, title X, § 1001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-05-05"},"text":"May 5, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1181"},"text":"124 Stat. 1181","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dU/tIV/s405/a"},"text":"Pub. L. 117–328, div. U, title IV, § 405(a)","children":[],"tail":", (b)(1), (c), "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5491"},"text":"136 Stat. 5491","children":[],"tail":", 5492.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc29591d7-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc29591d8-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc29591d9-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the Joseph Maxwell Cleland and Robert Joseph Dole Memorial Veterans Benefits and Health Care Improvement Act of 2022, referred to in subsecs. (a)(3) and (f)(2)(A), is the date of enactment of div. U of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc29591da-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 902 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2302"},"text":"section 2302 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/116/315"},"text":"Pub. L. 116–315","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s218/b"},"text":"section 218(b) of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s2/a"},"text":"Pub. L. 102–83, § 2(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc29591db-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s405/b/1"},"text":"Pub. L. 117–328, § 405(b)(1)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s405/a"},"text":"Pub. L. 117–328, § 405(a)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s405/c"},"text":"Pub. L. 117–328, § 405(c)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163/s1001/1/A"},"text":"Pub. L. 111–163, § 1001(1)(A)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “Employees of the Department who are Department police officers shall, with respect to acts occurring on Department property, enforce—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) Federal laws;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the rules prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s901"},"text":"section 901 of this title","children":[],"tail":"; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) subject to paragraph (2), traffic and motor vehicle laws of a State or local government within the jurisdiction of which such Department property is located.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163/s1001/1/B"},"text":"Pub. L. 111–163, § 1001(1)(B)","children":[],"tail":", (C), redesignated par. (3) as (2), inserted “, and on any arrest warrant issued by competent judicial authority” before the period, and struck out former par. (2) which read as follows: “A law described in subparagraph (C) of paragraph (1) may be enforced under such subparagraph only as authorized by an express grant of authority under applicable State or local law. Any such enforcement shall be by the issuance of a citation for violation of such law.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163/s1001/2"},"text":"Pub. L. 111–163, § 1001(2)","children":[],"tail":", amended subsec. (c) generally. Prior to amendment, subsec. (c) read as follows: “The Secretary shall consult with the Attorney General before prescribing regulations under paragraph (1) of subsection (b).”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc29591dc-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc29591dd-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Guidance on the Use of Body Worn Cameras; Consultation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dU/tIV/s405/b/2"},"text":"Pub. L. 117–328, div. U, title IV, § 405(b)(2)","children":[],"tail":", (3), (f), "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5492"},"text":"136 Stat. 5492","children":[],"tail":", 5493, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dU/tIV/s405/b/2"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than one year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":"], the Secretary of Veterans Affairs shall issue, and make publicly available, guidance on the use of body worn cameras by Department police officers pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s902/a/3"},"text":"section 902(a)(3) of title 38","children":[],"tail":", United States Code, as amended by paragraph (1)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall issue the guidance under paragraph (2) in consultation with veterans service organizations, civil rights organizations, law enforcement organizations, law enforcement accreditation organizations, privacy rights organizations, and other relevant organizations or experts.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Body worn camera","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘body worn camera’ means a camera worn on an individual police officer’s person that records and stores audio and video.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Department police officer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Department police officer’ means an employee of the Department of Veterans Affairs described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s902/a"},"text":"section 902(a) of title 38","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc29591de-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Police Crisis Intervention Training of Department of Veterans Affairs","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/214/tII/s205"},"text":"Pub. L. 116–214, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-05"},"text":"Dec. 5, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1038"},"text":"134 Stat. 1038","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/214/tII/s205"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Veterans Affairs shall provide to Department police officers an annual training on the prevention of suicide among the population served by the Department police officers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Curriculum","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (a), the Secretary shall update any similar training provided before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2020-12-05"},"text":"Dec. 5, 2020","children":[],"tail":"] to ensure that the curriculum for the training addresses, at a minimum, the following:"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Effective behavioral science procedures for suicide prevention and risk mitigation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Crisis intervention and de-escalation skills, including through the use of interactive training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information about mental health and substance abuse disorders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information about local law enforcement crisis intervention teams and other resources for veterans experiencing mental health crises available by the Department of Veterans Affairs, other elements of the Federal Government, and the community in which the police officers serve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall ensure that the annual training provided to Department police officers at a medical facility of the Department under subsection (a) is provided in consultation with law enforcement training accreditation organizations and the mental health experts at such facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plan on Community Partnerships","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that each police force of a facility of the Department develops a plan to enter into partnerships with—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local community mental health organizations and experts, local community veterans organizations, and local community criminal justice organizations and experts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local police departments, including by facilitating the sharing of training resources with crisis intervention teams of the local police departments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than one year after the date of the enactment of this Act, the Secretary shall submit to the Committees on Veterans’ Affairs of the House of Representatives and the Senate a report on the annual training under subsection (a), including—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the curriculum of such training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to the year preceding the date of the report—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of facilities of the Department that conducted such training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of Department police officers who received such training; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any barriers to ensuring that each Department police officer receives such training;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations to address the barriers identified under paragraph (2)(C); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of facilities of the Department that have entered into partnerships pursuant to subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Department Police Officer Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term ‘Department police officer’ means an employee of the Department of Veterans Affairs specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s902/a"},"text":"section 902(a) of title 38","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
