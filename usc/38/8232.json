{"tag":"section","attrib":{"id":"idc436e610-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8232"},"text":null,"children":[{"tag":"num","attrib":{"value":"8232"},"text":"§ 8232.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purpose of this subchapter, the term “eligible institution” means any nonprofit educational facility or other public or nonprofit institution, including universities, colleges, junior colleges, community colleges, schools of allied health professions, State and local systems of education, hospitals, and other nonprofit health manpower institutions for the training or education of allied health or other health personnel affiliated with the Department for the conduct of or the providing of guidance for education and training programs for health manpower.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc436e611-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/541/s2/a"},"text":"Pub. L. 92–541, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-24"},"text":"Oct. 24, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1105"},"text":"86 Stat. 1105","children":[],"tail":", § 5092; renumbered § 8232, "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/2/D"},"text":"Pub. L. 102–40, title IV, § 402(b)(2)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/239"},"text":"105 Stat. 239","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/3"},"text":"Pub. L. 102–83, § 4(a)(3)","children":[],"tail":", (4), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib