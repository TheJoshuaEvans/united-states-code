{"tag":"section","attrib":{"id":"idc3296db7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1980"},"text":null,"children":[{"tag":"num","attrib":{"value":"1980"},"text":"§ 1980.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Option to receive accelerated death benefit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3296db8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1980/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of this section, a person shall be considered to be terminally ill if the person has a medical prognosis such that the life expectancy of the person is less than a period prescribed by the Secretary. The maximum length of such period may not exceed 12 months.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3296db9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1980/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3296dba-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1980/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A terminally ill person insured under Servicemembers’ Group Life Insurance or Veterans’ Group Life Insurance may elect to receive in a lump-sum payment a portion of the face value of the insurance as an accelerated death benefit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3296dbb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1980/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall prescribe the maximum amount of the accelerated death benefit available under this section that the Secretary finds to be administratively practicable and actuarially sound, but in no event may the amount of the benefit exceed the amount equal to 50 percent of the face value of the person’s insurance in force on the date the election of the person to receive the benefit is approved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3296dbc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1980/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person making an election under this section may elect to receive an amount that is less than the maximum amount prescribed under paragraph (2). The Secretary shall prescribe the increments in which a reduced amount under this paragraph may be elected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3296dbd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1980/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The portion of the face value of insurance which is not paid in a lump sum as an accelerated death benefit under this section shall remain payable in accordance with the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3296dbe-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1980/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Deductions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1969"},"text":"section 1969 of this title","children":[],"tail":" and premiums under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1977/c"},"text":"section 1977(c) of this title","children":[],"tail":" shall be reduced, in a manner consistent with the percentage reduction in the face value of the insurance as a result of payment of an accelerated death benefit under this section, effective with respect to any amounts which would otherwise become due on or after the date of payment under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3296dbf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1980/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall prescribe regulations to carry out this section. Such regulations shall include provisions regarding—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3296dc0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1980/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the form and manner in which an application for an election under this section shall be made; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3296dc1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1980/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the procedures under which any such application shall be considered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3296dc2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1980/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3296dc3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1980/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An election to receive a benefit under this section shall be irrevocable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3296dc4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1980/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person may not make more than one election under this section, even if the election of the person is to receive less than the maximum amount of the benefit available to the person under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3296dc5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1980/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a person insured under Servicemembers’ Group Life Insurance elects to receive a benefit under this section and the person’s Servicemembers’ Group Life Insurance is thereafter converted to Veterans’ Group Life Insurance as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1968/b"},"text":"section 1968(b) of this title","children":[],"tail":", the amount of the benefit paid under this section shall reduce the amount of Veterans’ Group Life Insurance available to the person under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1977/a"},"text":"section 1977(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3296dc6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1980/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, the amount of the accelerated death benefit received by a person under this section shall not be considered income or resources for purposes of determining eligibility for or the amount of benefits under any Federal or federally-assisted program or for any other purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3296dc7-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/tIII/s302/a/1"},"text":"Pub. L. 105–368, title III, § 302(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3332"},"text":"112 Stat. 3332","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/275/tIV/s405/a"},"text":"Pub. L. 111–275, title IV, § 405(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-13"},"text":"Oct. 13, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2880"},"text":"124 Stat. 2880","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3296dc8-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3296dc9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3296dca-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/275"},"text":"Pub. L. 111–275","children":[],"tail":" struck out “reduced by an amount necessary to assure that there is no increase in the actuarial value of the benefit paid, as determined by the Secretary” after “death benefit”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3296dcb-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3296dcc-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/275/tIV/s405/b"},"text":"Pub. L. 111–275, title IV, § 405(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-13"},"text":"Oct. 13, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2880"},"text":"124 Stat. 2880","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/275/tIV/s405/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply with respect to a payment of an accelerated death benefit under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1980"},"text":"section 1980 of title 38","children":[],"tail":", United States Code, made on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2010-10-13"},"text":"Oct. 13, 2010","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3296dcd-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after ","children":[{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/368/s302/c"},"text":"section 302(c) of Pub. L. 105–368","children":[],"tail":", set out as an Effective Date of 1998 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1970"},"text":"section 1970 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
