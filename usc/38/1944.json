{"tag":"section","attrib":{"id":"idc31fcfe5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1944"},"text":null,"children":[{"tag":"num","attrib":{"value":"1944"},"text":"§ 1944.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc31fcfe6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1944/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provisions for maturity at certain ages, for continuous installments during the lifetime of the insured or beneficiaries, or both, for refund of premiums, cash, loan, paid-up and extended values, dividends from gains and savings, and such other provisions for the protection and advantage of and for alternative benefits to the insured and the beneficiaries as may be found to be reasonable and practicable may be provided for in insurance contracts or from time to time by regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc31fcfe7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1944/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All calculations on insurance shall be based upon the American Experience Table of Mortality and interest at 3½ percent per annum, except that no deduction shall be made for continuous installments during the life of the insured in case the insured’s total and permanent disability continues more than two hundred and forty months.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc31fcfe8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1944/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On and after ","children":[{"tag":"date","attrib":{"date":"1939-07-19"},"text":"July 19, 1939","children":[],"tail":", the rate of interest charged on any loan secured by a lien on insurance shall not exceed 5 percent per annum."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc31fcfe9-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1158"},"text":"72 Stat. 1158","children":[],"tail":", § 744; "},{"tag":"ref","attrib":{"href":"/us/pl/97/295/s4/26"},"text":"Pub. L. 97–295, § 4(26)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1307"},"text":"96 Stat. 1307","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/576/tVII/s701/30"},"text":"Pub. L. 99–576, title VII, § 701(30)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3293"},"text":"100 Stat. 3293","children":[],"tail":"; renumbered § 1944, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc31fcfea-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc31fcfeb-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc31fcfec-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s744"},"text":"section 744 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576"},"text":"Pub. L. 99–576","children":[],"tail":" substituted “the insured’s” for “his”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295"},"text":"Pub. L. 97–295","children":[],"tail":" substituted “percent” for “per centum”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
