{"tag":"section","attrib":{"id":"idc337c53c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2064"},"text":null,"children":[{"tag":"num","attrib":{"value":"2064"},"text":"§ 2064.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance grants for nonprofit community-based groups","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc337c53d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2064/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grant Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall carry out a program to make grants to entities or organizations with expertise in preparing grant applications. Under the program, the entities or organizations receiving grants shall provide technical assistance to nonprofit community-based groups with experience in providing assistance to homeless veterans in order to assist such groups in applying for grants under this chapter and other grants relating to addressing problems of homeless veterans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc337c53e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2064/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There are authorized to be appropriated $1,000,000 for each of fiscal years 2007 through 2012 to carry out the program under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc337c53f-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/95/s5/a/1"},"text":"Pub. L. 107–95, § 5(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-21"},"text":"Dec. 21, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/914"},"text":"115 Stat. 914","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/461/tVII/s707"},"text":"Pub. L. 109–461, title VII, § 707","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3440"},"text":"120 Stat. 3440","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc337c540-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc337c541-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc337c542-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461"},"text":"Pub. L. 109–461","children":[],"tail":" amended heading and text of subsec. (b) generally. Prior to amendment, text read as follows: “There is authorized to be appropriated $750,000 for each of fiscal years 2002 through 2005 to carry out the program under this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
