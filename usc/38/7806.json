{"tag":"section","attrib":{"id":"idc41a35ed-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7806"},"text":null,"children":[{"tag":"num","attrib":{"value":"7806"},"text":"§ 7806.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budget of Service","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Service shall prepare annually and submit a budget program as provided for wholly owned Government corporations by chapter 91 of title 31, which shall contain an estimate of the needs of the Service for the ensuing fiscal year including an estimate of the amount required to restore any impairment of the revolving fund resulting from operations of the current fiscal year.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc41a35ee-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1250"},"text":"72 Stat. 1250","children":[],"tail":", § 4206; "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s3/k/8"},"text":"Pub. L. 97–258, § 3(k)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1065"},"text":"96 Stat. 1065","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/322/tIV/s414/a/2"},"text":"Pub. L. 100–322, title IV, § 414(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/549"},"text":"102 Stat. 549","children":[],"tail":"; renumbered § 7806 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/a"},"text":"Pub. L. 102–40, title IV, § 402(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc41a35ef-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc41a35f0-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc41a35f1-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4206"},"text":"section 4206 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/322"},"text":"Pub. L. 100–322","children":[],"tail":" struck out at end “Any balance in the revolving fund at the close of the fiscal year in excess of the estimated requirements for the ensuing fiscal year shall be covered into the Treasury as miscellaneous receipts.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":" substituted “corporations by chapter 91 of title 31,” for “corporations by sections 841–869 of title 31,”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
