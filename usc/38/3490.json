{"tag":"section","attrib":{"id":"idc375b7f8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3490"},"text":null,"children":[{"tag":"num","attrib":{"value":"3490"},"text":"§ 3490.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It is the purpose of this subchapter (1) to encourage and assist veterans who have academic deficiencies to attain a high school education or its equivalent and to qualify for and pursue courses of higher education, (2) to assist eligible veterans to pursue postsecondary education through tutorial assistance where required, and (3) to encourage educational institutions to develop programs which provide special tutorial, remedial, preparatory, or other educational or supplementary assistance to such veterans.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc375b7f9-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/219/tII/s204/a/4"},"text":"Pub. L. 91–219, title II, § 204(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-03-26"},"text":"Mar. 26, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/79"},"text":"84 Stat. 79","children":[],"tail":", § 1690; renumbered § 3490, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc375b7fa-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc375b7fb-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc375b7fc-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1690"},"text":"section 1690 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
