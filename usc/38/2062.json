{"tag":"section","attrib":{"id":"idc337c52b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2062"},"text":null,"children":[{"tag":"num","attrib":{"value":"2062"},"text":"§ 2062.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dental care","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc337c52c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2062/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1712/a/1/H"},"text":"section 1712(a)(1)(H) of this title","children":[],"tail":", outpatient dental services and treatment of a dental condition or disability of a veteran described in subsection (b) shall be considered to be medically necessary, subject to subsection (c), if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc337c52d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2062/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the dental services and treatment are necessary for the veteran to successfully gain or regain employment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc337c52e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2062/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the dental services and treatment are necessary to alleviate pain; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc337c52f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2062/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the dental services and treatment are necessary for treatment of moderate, severe, or severe and complicated gingival and periodontal pathology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc337c530-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2062/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Veterans","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) applies to a veteran—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc337c531-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2062/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is enrolled for care under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1705/a"},"text":"section 1705(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc337c532-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2062/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who, for a period of 60 consecutive days, is receiving care (directly or by contract) in any of the following settings:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc337c533-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2062/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A domiciliary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1710"},"text":"section 1710 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c534-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2062/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A therapeutic residence under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2032"},"text":"section 2032 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c535-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2062/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Community residential care coordinated by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1730"},"text":"section 1730 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc337c536-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2062/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A setting for which the Secretary provides funds for a grant and per diem provider.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc337c537-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2062/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of paragraph (2), in determining whether a veteran has received treatment for a period of 60 consecutive days, the Secretary may disregard breaks in the continuity of treatment for which the veteran is not responsible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc337c538-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2062/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Dental benefits provided by reason of this section shall be a one-time course of dental care provided in the same manner as the dental benefits provided to a newly discharged veteran.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc337c539-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/95/s5/a/1"},"text":"Pub. L. 107–95, § 5(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-21"},"text":"Dec. 21, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/913"},"text":"115 Stat. 913","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
