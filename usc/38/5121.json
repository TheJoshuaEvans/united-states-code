":[{"tag":"ref","attrib":{"href":"/us/pl/108/183/s104/c/1"},"text":"Pub. L. 108–183, § 104(c)(1)","children":[],"tail":", struck out comma after “or decisions” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/183/s104/a"},"text":"Pub. L. 108–183, § 104(a)","children":[],"tail":", struck out “for a period not to exceed two years” after “unpaid” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/183/s104/c/2"},"text":"Pub. L. 108–183, § 104(c)(2)","children":[],"tail":", substituted period for semicolon at end of pars. (1) to (4) and subpars. (A) and (B) of par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/183/s104/b"},"text":"Pub. L. 108–183, § 104(b)","children":[],"tail":", added par. (5) and redesignated former par. (5) as (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/14"},"text":"Pub. L. 107–14","children":[],"tail":" substituted “hereinafter” for “hereafter” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/275"},"text":"Pub. L. 104–275","children":[],"tail":" substituted “two years” for “one year” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/b/1"},"text":"Pub. L. 102–40, § 402(b)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3021"},"text":"section 3021 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"ta