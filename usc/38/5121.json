k out reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3203/a/2/A"},"text":"section 3203(a)(2)(A) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3d515d6-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3d515d7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/183/tI/s104/d"},"text":"Pub. L. 108–183, title I, § 104(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-16"},"text":"Dec. 16, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2656"},"text":"117 Stat. 2656","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/183/tI/s104/d"},"text":"“The amendments made by subsections (a) and (b) [amending this section] shall apply with respect to deaths occurring on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2003-12-16"},"text":"Dec. 16, 2003","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3d515d8-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1972 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/328"},"text":"Pub. L. 92–328","children":[],"tail":" effective first day of second calendar month which begins after "},{"tag":"date","attrib":{"date":"1972-06-30"},"text":"June 30, 1972","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/92/328/s301/a"},"text":"section 301(a) of Pub. L. 92–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1114"},"text":"section 1114 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
