{"tag":"section","attrib":{"id":"idc332e289-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022"},"text":null,"children":[{"tag":"num","attrib":{"value":"2022"},"text":"§ 2022.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of outreach services for veterans at risk of homelessness","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc332e28a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Outreach Plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, acting through the Under Secretary for Health, shall provide for appropriate officials of the Mental Health Service and the Readjustment Counseling Service of the Veterans Health Administration to develop a coordinated plan for joint outreach by the two Services to veterans at risk of homelessness, including particularly veterans who are being discharged or released from institutions after inpatient psychiatric care, substance abuse treatment, or imprisonment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc332e28b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Matters To Be Included","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The outreach plan under subsection (a) shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc332e28c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Strategies to identify and collaborate with non-Department entities used by veterans who have not traditionally used Department services to further outreach efforts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc332e28d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Strategies to ensure that mentoring programs, recovery support groups, and other appropriate support networks are optimally available to veterans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc332e28e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Appropriate programs or referrals to family support programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc332e28f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Means to increase access to case management services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc332e290-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Plans for making additional employment services accessible to veterans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc332e291-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Appropriate referral sources for mental health and substance abuse services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc332e292-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperative Relationships","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The outreach plan under subsection (a) shall identify strategies for the Department to enter into formal cooperative relationships with entities outside the Department to facilitate making services and resources optimally available to veterans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc332e293-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review of Plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall submit the outreach plan under subsection (a) to the Advisory Committee on Homeless Veterans for its review and consultation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc332e294-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Outreach Program","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc332e295-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall carry out an outreach program to provide information to homeless veterans and veterans at risk of homelessness. The program shall include at a minimum—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc332e296-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provision of information about benefits available to eligible veterans from the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc332e297-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contact information for local Department facilities, including medical facilities, regional offices, and veterans centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc332e298-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In developing and carrying out the program under paragraph (1), the Secretary shall, to the extent practicable, consult with appropriate public and private organizations, including the Bureau of Prisons, State social service agencies, the Department of Defense, and mental health, veterans, and homeless advocates—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc332e299-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for assistance in identifying and contacting veterans who are homeless or at risk of homelessness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc332e29a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coordinate appropriate outreach activities with those organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc332e29b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coordinate services provided to veterans with services provided by those organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc332e29c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc332e29d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"2002-10-01"},"text":"October 1, 2002","children":[],"tail":", the Secretary shall submit to the Committees on Veterans’ Affairs of the Senate and House of Representatives an initial report that contains an evaluation of outreach activities carried out by the Secretary with respect to homeless veterans, including outreach regarding clinical issues and other benefits administered under this title. The Secretary shall conduct the evaluation in consultation with the Under Secretary for Benefits, the Department of Veterans Affairs central office official responsible for the administration of the Readjustment Counseling Service, the Director of Homeless Veterans Programs, and the Department of Veterans Affairs central office official responsible for the administration of the Mental Health Strategic Health Care Group."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc332e29e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"2005-12-31"},"text":"December 31, 2005","children":[],"tail":", the Secretary shall submit to the committees referred to in paragraph (1) an interim report on outreach activities carried out by the Secretary with respect to homeless veterans. The report shall include the following:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc332e29f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary’s outreach plan under subsection (a), including goals and time lines for implementation of the plan for particular facilities and service networks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc332e2a0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the implementation and operation of the outreach program under subsection (e).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc332e2a1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the implementation and operation of the program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2023"},"text":"section 2023 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc332e2a2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"2007-07-01"},"text":"July 1, 2007","children":[],"tail":", the Secretary shall submit to the committees referred to in paragraph (1) a final report on outreach activities carried out by the Secretary with respect to homeless veterans. The report shall include the following:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc332e2a3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An evaluation of the effectiveness of the outreach plan under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc332e2a4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An evaluation of the effectiveness of the outreach program under subsection (e).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc332e2a5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An evaluation of the effectiveness of the demonstration program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2023"},"text":"section 2023 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc332e2a6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2022/f/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recommendations, if any, regarding an extension or modification of such outreach plan, such outreach program, and such demonstration program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc332e2a7-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/95/s5/a/1"},"text":"Pub. L. 107–95, § 5(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-21"},"text":"Dec. 21, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/910"},"text":"115 Stat. 910","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/387/tVI/s602/d/3"},"text":"Pub. L. 110–387, title VI, § 602(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4132"},"text":"122 Stat. 4132","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc332e2a8-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc332e2a9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc332e2aa-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2022 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4302"},"text":"section 4302 of this title","children":[],"tail":" and subsequently omitted in the general amendment of chapter 43 of this title by "},{"tag":"ref","attrib":{"href":"/us/pl/103/353/s2/a"},"text":"Pub. L. 103–353, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3150"},"text":"108 Stat. 3150","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc332e2ab-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (f)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/387"},"text":"Pub. L. 110–387","children":[],"tail":" struck out “demonstration” before “program”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
