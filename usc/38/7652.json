{"tag":"section","attrib":{"id":"idc417eb5a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7652"},"text":null,"children":[{"tag":"num","attrib":{"value":"7652"},"text":"§ 7652.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility: individuals entitled to benefits under the GI Bill program for members of the Selected Reserve","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of Veterans Affairs may not approve an application under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7603"},"text":"section 7603 of this title","children":[],"tail":" of an individual applying to receive assistance under this subchapter unless—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc417eb5b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7652/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual is entitled to benefits under chapter 106 of title 10; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc417eb5c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7652/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the score of the individual on the Armed Forces Qualification Test was above the 50th percentile.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc417eb5d-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/366/tII/s205/a/1"},"text":"Pub. L. 101–366, title II, § 205(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-15"},"text":"Aug. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/440"},"text":"104 Stat. 440","children":[],"tail":", § 4352; renumbered § 7652 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", (d)(1), "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":", 239.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc417eb5e-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc417eb5f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc417eb60-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4352"},"text":"section 4352 of this title","children":[],"tail":" as this section and substituted “7603” for “4303” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
