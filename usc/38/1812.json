{"tag":"section","attrib":{"id":"idc313e996-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1812"},"text":null,"children":[{"tag":"num","attrib":{"value":"1812"},"text":"§ 1812.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered birth defects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc313e997-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1812/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Identification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall identify the birth defects of children of women Vietnam veterans that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc313e998-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1812/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are associated with the service of those veterans in the Republic of Vietnam during the Vietnam era; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc313e999-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1812/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" result in permanent physical or mental disability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc313e99a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1812/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc313e99b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1812/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The birth defects identified under subsection (a) may not include birth defects resulting from the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc313e99c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1812/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A familial disorder.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc313e99d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1812/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A birth-related injury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc313e99e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1812/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A fetal or neonatal infirmity with well-established causes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc313e99f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1812/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any case where affirmative evidence establishes that a covered birth defect of a child of a woman Vietnam veteran results from a cause other than the active military, naval, or air service of that veteran in the Republic of Vietnam during the Vietnam era, no benefits or assistance may be provided the child under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc313e9a0-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/419/tIV/s401/a"},"text":"Pub. L. 106–419, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1857"},"text":"114 Stat. 1857","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc313e9a1-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc313e9a2-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc313e9a3-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1812 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3712"},"text":"section 3712 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 1812, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1210"},"text":"72 Stat. 1210","children":[],"tail":", automatically guaranteed loans made to a veteran if made for the purpose of purchasing farms and farm equipment, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/93/569/s7/a"},"text":"Pub. L. 93–569, § 7(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-12-31"},"text":"Dec. 31, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1866"},"text":"88 Stat. 1866","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
