{"tag":"section","attrib":{"id":"idc2ad5f89-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1159"},"text":null,"children":[{"tag":"num","attrib":{"value":"1159"},"text":"§ 1159.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of service connection","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Service connection for any disability or death granted under this title which has been in force for ten or more years shall not be severed on or after ","children":[{"tag":"date","attrib":{"date":"1962-01-01"},"text":"January 1, 1962","children":[],"tail":", except upon a showing that the original grant of service connection was based on fraud or it is clearly shown from military records that the person concerned did not have the requisite service or character of discharge. The mentioned period shall be computed from the date determined by the Secretary as the date on which the status commenced for rating purposes."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc2ad5f8a-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/501/s1"},"text":"Pub. L. 86–501, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-06-10"},"text":"June 10, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/195"},"text":"74 Stat. 195","children":[],"tail":", § 359; amended "},{"tag":"ref","attrib":{"href":"/us/pl/87/825/s6"},"text":"Pub. L. 87–825, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-15"},"text":"Oct. 15, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/950"},"text":"76 Stat. 950","children":[],"tail":"; renumbered § 1159 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":", §§ 4(b)(1), (2)(E), 5(a), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404-406"},"text":"105 Stat. 404–406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2ad5f8b-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc2ad5f8c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc2ad5f8d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s359"},"text":"section 359 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/825"},"text":"Pub. L. 87–825","children":[],"tail":" provided for computation of the period from the date the administrator determines as the date the status commenced for rating purposes."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc2ad5f8e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc2ad5f8f-47c4-