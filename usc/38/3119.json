{"tag":"section","attrib":{"id":"idc35dead6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3119"},"text":null,"children":[{"tag":"num","attrib":{"value":"3119"},"text":"§ 3119.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rehabilitation research and special projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc35dead7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3119/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall carry out an ongoing program of activities for the purpose of advancing the knowledge, methods, techniques, and resources available for use in rehabilitation programs for veterans. For this purpose, the Secretary shall conduct and provide support for the development or conduct, or both the development and conduct, of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc35dead8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3119/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" studies and research concerning the psychological, educational, employment, social, vocational, industrial, and economic aspects of the rehabilitation of disabled veterans, including new methods of rehabilitation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc35dead9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3119/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects which are designed to increase the resources and potential for accomplishing the rehabilitation of disabled veterans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc35deada-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3119/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose specified in subsection (a) of this section, the Secretary is authorized to make grants to or contract with public or nonprofit agencies, including institutions of higher learning.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc35deadb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3119/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall cooperate with the Commissioner of the Rehabilitation Services Administration and the Director of the Institute of Handicapped Research in the Department of Education, the Assistant Secretary for Veterans’ Employment in the Department of Labor, and the Secretary of Health and Human Services regarding rehabilitation studies, research, and special projects of mutual programmatic concern.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc35deadc-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466/tI/s101/a"},"text":"Pub. L. 96–466, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2184"},"text":"94 Stat. 2184","children":[],"tail":", § 1519; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIV/s423/b/1/A"},"text":"Pub. L. 101–237, title IV, § 423(b)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2092"},"text":"103 Stat. 2092","children":[],"tail":"; renumbered § 3119, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc35deadd-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc35deade-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc35deadf-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1519"},"text":"section 1519 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" substituted “Secretary” for “Administrator” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc35deae0-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc35deae1-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1980-10-01"},"text":"Oct. 1, 1980","chi