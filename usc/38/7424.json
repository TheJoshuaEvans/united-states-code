{"tag":"section","attrib":{"id":"idc409948c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7424"},"text":null,"children":[{"tag":"num","attrib":{"value":"7424"},"text":"§ 7424.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses of certain employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc409948d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7424/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may pay the expenses (other than membership fees) of persons described in sections 7306 and 7401(1) of this title (including persons in positions described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401/1"},"text":"section 7401(1) of this title","children":[],"tail":" who are appointed on a temporary full-time basis or a part-time basis under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7405"},"text":"section 7405 of this title","children":[],"tail":") who are detailed by the Under Secretary for Health to attend meetings of associations for the promotion of medical and related science."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc409948e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7424/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc409948f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7424/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may prescribe regulations establishing conditions under which officers and employees of the Administration who are nationally recognized principal investigators in medical research may be permitted to accept payment, in cash or in kind, from non-Federal agencies, organizations, and individuals for travel and such reasonable subsistence expenses as are approved by the Secretary pursuant to such regulations—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc4099490-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7424/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in connection with their attendance at meetings or in performing advisory services concerned with the functions or activities of the Department; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4099491-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7424/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in connection with acceptance of significant awards or with activity related thereto concerned with functions or activities of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4099492-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7424/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any such payment may be retained by such officers and employees to cover the cost of such expenses or shall be deposited to the credit of the appropriation from which the cost of such expenses is paid, as may be provided in such regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc4099493-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s401/b/3/B"},"text":"Pub. L. 102–40, title IV, § 401(b)(3)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/230"},"text":"105 Stat. 230","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/405/tIII/s302/c/1"},"text":"Pub. L. 102–405, title III, § 302(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-09"},"text":"Oct. 9, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1984"},"text":"106 Stat. 1984","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc4099494-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc4099495-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc4099496-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in sections 4108(d) and 4113 of this title prior to the repeal of those sections as part of the complete revision of chapter 73 of this title by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc4099497-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/405"},"text":"Pub. L. 102–405","children":[],"tail":" substituted “Under Secretary for Health” for “Chief Medical Director”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
