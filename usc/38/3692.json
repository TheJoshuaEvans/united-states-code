"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576/s304/1"},"text":"Pub. L. 99–576, § 304(1)","children":[],"tail":", substituted “a Veterans’ Advisory Committee on Education” for “an advisory committee”, and inserted reference to chapter 30."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576/s304/2"},"text":"Pub. L. 99–576, § 304(2)","children":[],"tail":", inserted reference to chapter 30."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466"},"text":"Pub. L. 96–466","children":[],"tail":" designated existing provisions as subsecs. (a) and (b), substituted reference to furnishing education to eligible veterans or persons enrolled under chapter 32, 34, or 35 of this title for reference to furnishing vocational rehabilitation under chapter 31 of this title or education to eligible persons or veterans enrolled under chapter 34 or 35 of this title, reference to the Assistant Secretary of Education for Postsecondary Education or other comparable official and the Assistant Secretary of Labor for Veterans’ Employment, for reference to the Commissioner of Education and the Administrator, Manpower Administration, Department of Labor, and reference to seeking the advice of the committee with respect to the administration of this chapter and chapters 32, 34, and 35 of this title for reference to advising the committee with respect to the administration of this chapter and chapters 31, 34, and 35 of this title, and inserted provision that the committee include veterans representative of the post-Vietnam era, and added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/540/s316/3"},"text":"Pub. L. 92–540, § 316(3)","children":[],"tail":", inserted provisions that the Committee also include veterans representative of World War II, the Korean conflict era, the post-Korean conflict era and the Vietnam era."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3996d00-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3996d01-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/252"},"text":"Pub. L. 110–252","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-08-01"},"text":"Aug. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/252/s5003/d"},"text":"section 5003(d) of Pub. L. 110–252","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s16163"},"text":"section 16163 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3996d02-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466"},"text":"Pub. L. 96–466","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-10-01"},"text":"Oct. 1, 1980","children":[],"tail":", except as otherwise specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/96/466/s802/c"},"text":"section 802(c) of Pub. L. 96–466","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3452"},"text":"section 3452 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3996d03-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Advisory Committees","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Advisory committees in existence on ","children":[{"tag":"date","attrib":{"date":"1973-01-05"},"text":"Jan. 5, 1973","children":[],"tail":", to terminate not later than the expiration of the 2-year period following "},{"tag":"date","attrib":{"date":"1973-01-05"},"text":"Jan. 5, 1973","children":[],"tail":", unless, in the case of a committee established by the President or an officer of the Federal Government, such committee is renewed by appropriate action prior to the expiration of such 2-year period, or in the case of a committee established by the Congress, its duration is otherwise provided by law. See "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"section 1013 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3996d04-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Commission To Assess Veterans’ Education Policy","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576/tIII/s320"},"text":"Pub. L. 99–576, title III, § 320","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3275"},"text":"100 Stat. 3275","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/323/s14"},"text":"Pub. L. 100–323, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/574"},"text":"102 Stat. 574","children":[],"tail":", provided for establishment of a Commission on Veterans’ Education Policy, provided for appointment of members of Commission not later than "},{"tag":"date","attrib":{"date":"1987-03-01"},"text":"Mar. 1, 1987","children":[],"tail":", directed Commission to submit a report, not later than 18 months after at least 8 members had been appointed, to Committees on Veterans’ Affairs of Senate and House of Representatives, containing the Commission’s findings and recommendations on various matters relating to veterans’ education, directed Administrator of Veterans Affairs to file interim and final reports, not later than 2 years after Commission’s report, to those Committees responding to Commission’s report, and provided for termination of Commission 90 days after Administrator submitted final report."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3996d05-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study of Educational Assistance Programs for Veterans, Survivors, and Dependents; Submission to Congress and President by ","children":[{"tag":"date","attrib":{"date":"1979-09-30"},"text":"September 30, 1979","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/202/tIII/s304/b"},"text":"Pub. L. 95–202, title III, § 304(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-11-23"},"text":"Nov. 23, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1442"},"text":"91 Stat. 1442","children":[],"tail":", directed Administrator of Veterans’ Affairs, in consultation with Advisory Committee formed pursuant to this section, to conduct a study respecting operation of programs of educational assistance carried out under this chapter and chapter 34 of this title and that a report concerning such study be submitted to Congress not later than "},{"tag":"date","attrib":{"date":"1979-09-30"},"text":"Sept. 30, 1979","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3996d06-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study of Operation of Post-Korean Conflict Programs of Educational Assistance","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/92/540/tIV/s413"},"text":"Pub. L. 92–540, title IV, § 413","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-24"},"text":"Oct. 24, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1093"},"text":"86 Stat. 1093","children":[],"tail":", provided for a comparative study of operation of post-Korean conflict program of educational assistance with similar prior programs available to veterans of World War II and Korean conflict, the results of such study and recommendations for improvement to be transmitted to President and Congress within six months of "},{"tag":"date","attrib":{"date":"1972-10-24"},"text":"Oct. 24, 1972","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
