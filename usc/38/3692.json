{"tag":"section","attrib":{"id":"idc3996cf7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3692"},"text":null,"children":[{"tag":"num","attrib":{"value":"3692"},"text":"§ 3692.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3996cf8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3692/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There shall be a Veterans’ Advisory Committee on Education formed by the Secretary which shall be composed of persons who are eminent in their respective fields of education, labor, and management and of representatives of institutions and establishments furnishing education to eligible veterans or persons enrolled under chapter 30, 32, 33, or 35 of this title and chapter 1606 of title 10. The committee shall also, to the maximum extent practicable, include a representative sample of veterans and other individuals who have used, or may in the future use, educational assistance benefits administered by the Secretary. The Assistant Secretary of Education for Postsecondary Education (or such other comparable official of the Department of Education as the Secretary of Education may designate) and the Assistant Secretary of Labor for Veterans’ Employment and Training shall be ex officio members of the advisory committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3996cf9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3692/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall consult with and seek the advice of the committee from time to time with respect to the administration of this chapter, chapters 30, 32, 33, and 35 of this title, and chapter 1606 of title 10. The committee may make such reports and recommendations as it considers desirable to the Secretary and the Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3996cfa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3692/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The committee shall remain in existence until ","children":[{"tag":"date","attrib":{"date":"2026-12-31"},"text":"December 31, 2026","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3996cfb-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/358/s3/b"},"text":"Pub. L. 89–358, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-03-03"},"text":"Mar. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/23"},"text":"80 Stat. 23","children":[],"tail":", § 1788; renumbered § 1792 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/92/540/tIII/s316/2"},"text":"Pub. L. 92–540, title III, § 316(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"1972-10-24"},"text":"Oct. 24, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1086"},"text":"86 Stat. 1086","children":[],"tail":", 1089; "},{"tag":"ref","attrib":{"href":"/us/pl/96/466/tIII/s346"},"text":"Pub. L. 96–466, title III, § 346","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2200"},"text":"94 Stat. 2200","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/576/tIII/s304"},"text":"Pub. L. 99–576, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3269"},"text":"100 Stat. 3269","children":[],"tail"