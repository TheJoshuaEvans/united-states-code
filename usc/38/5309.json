{"tag":"section","attrib":{"id":"idc3d787e2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5309"},"text":null,"children":[{"tag":"num","attrib":{"value":"5309"},"text":"§ 5309.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of certain withheld benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3d787e3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5309/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person who, but for ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5308"},"text":"section 5308 of this title","children":[],"tail":", was entitled to benefits under any of the laws administered by the Secretary, whose award of benefits was terminated under such section, or whose benefits were not paid pursuant to sections 3329 and 3330 of title 31, and who was not guilty of mutiny, treason, sabotage, or rendering assistance to an enemy of the United States or its allies, shall be paid the full amount of any benefits not paid because of such section 5308, or withheld (including the amount of any checks covered on such person’s account into the Treasury as miscellaneous receipts together with any amount to such person’s credit in the special-deposit account) pursuant to sections 3329 and 3330 of title 31. The Secretary shall certify to the Secretary of the Treasury the amounts of payments which, but for this section, would have been made from the special deposit account, and the Secretary of the Treasury, as directed by the Secretary, shall reimburse the appropriations of the Department from such special deposit account, or cover into the Treasury as miscellaneous receipts the amounts so certified."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d787e4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5309/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No payments shall be made for any period before the date claim therefor is filed under this section to any person whose award was terminated, or whose benefits were not paid, before ","children":[{"tag":"date","attrib":{"date":"1954-07-01"},"text":"July 1, 1954","children":[],"tail":", because such person was a citizen or subject of Germany or Japan residing in Germany or Japan."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3d787e5-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1232"},"text":"72 Stat. 1232","children":[],"tail":", § 3109; "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s3/k/4"},"text":"Pub. L. 97–258, § 3(k)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1065"},"text":"96 Stat. 1065","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/576/tVII/s701/75"},"text":"Pub. L. 99–576, title VII, § 701(75)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3297"},"text":"100 Stat. 3297","children":[],"tail":"; renumbered § 5309 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", (d)(1), "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":", 239; "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/1"},"text":"Pub. L. 102–83, § 4(a)(1)","children":[],"tail":", (3), (4), (b)(1), (2)(E), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/403-405"},"text":"105 Stat. 403–405","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3d787e6-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3d787e7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3d787e8-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/b/1"},"text":"Pub. L. 102–40, § 402(b)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3109"},"text":"section 3109 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator” in two places in last sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/3"},"text":"Pub. L. 102–83, § 4(a)(3)","children":[],"tail":", (4), substituted “Department” for “Veterans’ Administration” in last sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/1"},"text":"Pub. L. 102–83, § 4(a)(1)","children":[],"tail":", substituted “administered by the Secretary” for “administered by the Veterans’ Administration” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/d/1"},"text":"Pub. L. 102–40, § 402(d)(1)","children":[],"tail":", substituted “5308” for “3108” in two places in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576/s701/75/A"},"text":"Pub. L. 99–576, § 701(75)(A)","children":[],"tail":", substituted “such person’s” for “his” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576/s701/75/B"},"text":"Pub. L. 99–576, § 701(75)(B)","children":[],"tail":", substituted “such person” for “he”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":" substituted “sections 3329 and 3330 of title 31” for “sections 123–128 of title 31” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
