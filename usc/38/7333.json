{"tag":"section","attrib":{"id":"idc3fff7f4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7333"},"text":null,"children":[{"tag":"num","attrib":{"value":"7333"},"text":"§ 7333.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondiscrimination against alcohol and drug abusers and persons infected with the human immunodeficiency virus","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3fff7f5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7333/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Veterans eligible for treatment under chapter 17 of this title who are alcohol or drug abusers or who are infected with the human immunodeficiency virus shall not be discriminated against in admission or treatment by any Department health-care facility solely because of their alcohol or drug abuse or dependency or because of their viral infection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3fff7f6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7333/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall prescribe regulations for the enforcement of this section. Such regulations, with respect to the admission and treatment of such veterans who are alcohol or drug abusers, shall be prescribed in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7334"},"text":"section 7334 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3fff7f7-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/581/tI/s111/a/1"},"text":"Pub. L. 94–581, title I, § 111(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2850"},"text":"90 Stat. 2850","children":[],"tail":", § 4133; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/322/tI/s122/a"},"text":"Pub. L. 100–322, title I, § 122(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/503"},"text":"102 Stat. 503","children":[],"tail":"; renumbered § 7333 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV"},"text":"Pub. L. 102–40, title IV","children":[],"tail":", §§ 401(a)(4)(A), 402(d)(1), 403(a)(1), (2), "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/221"},"text":"105 Stat. 221","children":[],"tail":", 239.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3fff7f8-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3fff7f9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3fff7fa-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s401/a/4/A"},"text":"Pub. L. 102–40, § 401(a)(4)(A)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4133"},"text":"section 4133 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s403/a/2"},"text":"Pub. L. 102–40, § 403(a)(2)","children":[],"tail":", substituted “Department” for “Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":", §§ 402(d)(1), 403(a)(1), substituted “Secretary” for “Administrator” and “7334” for “4134”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/322"},"text":"Pub. L. 100–322","children":[],"tail":" substituted “Nondiscrimination against alcohol and drug abusers and persons infected with the human immunodeficiency virus” for “Nondiscrimination in the admission of alcohol and drug abusers to Veterans’ Administration health care facilities” as section catchline, and amended text generally. Prior to amendment, text read as follows: “Veterans eligible for treatment under chapter 17 of this title who are alcohol or drug abusers and who are suffering from medical disabilities shall not be discriminated against in admission or treatment, solely because of their alcohol or drug abuse or dependence, by any Veterans’ Administration health care facility. The Administrator, pursuant to the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4134"},"text":"section 4134 of this title","children":[],"tail":", shall prescribe regulations for the enforcement of this nondiscrimination policy with respect to the admission and treatment of such eligible veterans who are alcohol or drug abusers.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3fff7fb-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3fff7fc-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Restriction on Testing for Infection With Human Immunodeficiency Virus","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/322/tI/s124"},"text":"Pub. L. 100–322, title I, § 124","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/505"},"text":"102 Stat. 505","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s6/j/3"},"text":"Pub. L. 102–83, § 6(j)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/409"},"text":"105 Stat. 409","children":[],"tail":", provided that the Secretary of Veterans Affairs could not conduct a widespread program to test for the human immunodeficiency virus unless funds for the program were appropriated, with an exception for voluntary testing, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/110/387/tIV/s407"},"text":"Pub. L. 110–387, title IV, § 407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4130"},"text":"122 Stat. 4130","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
