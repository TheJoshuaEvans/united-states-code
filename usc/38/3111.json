{"tag":"section","attrib":{"id":"idc35dea6f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3111"},"text":null,"children":[{"tag":"num","attrib":{"value":"3111"},"text":"§ 3111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations to promote satisfactory conduct and cooperation","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prescribe such rules and regulations as the Secretary determines necessary to promote satisfactory conduct and cooperation on the part of veterans who are pursuing rehabilitation programs under this chapter. In any case in which the Secretary determines that a veteran has failed to maintain satisfactory conduct or cooperation, the Secretary may, after determining that all reasonable counseling efforts have been made and are not reasonably likely to be effective, discontinue services and assistance unless the Secretary determines that mitigating circumstances exist. In any case in which such services and assistance have been discontinued, the Secretary may reinstitute such services and assistance only if the Secretary determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc35dea70-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3111/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cause of the unsatisfactory conduct or cooperation of such veteran has been removed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc35dea71-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3111/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rehabilitation program which such veteran proposes to pursue (whether the same or revised) is suitable to such veteran’s abilities, aptitudes, and interests.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc35dea72-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466/tI/s101/a"},"text":"Pub. L. 96–466, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2181"},"text":"94 Stat. 2181","children":[],"tail":", § 1511; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIV/s423/b/1/A"},"text":"Pub. L. 101–237, title IV, § 423(b)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2092"},"text":"103 Stat. 2092","children":[],"tail":"; renumbered § 3111, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc35dea73-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc35dea74-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc35dea75-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior section 3111 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5311"},"text":"section 5311 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc35dea76-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1511"},"text":"section 1511 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" substituted “Secretary” for “Administrator” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc35dea77-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc35dea78-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-04-01"},"text":"Apr. 1, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/466/s802/a/1"},"text":"section 802(a)(1) of Pub. L. 96–466","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3100"},"text":"section 3100 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
