{"tag":"section","attrib":{"id":"idc290d60e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s709"},"text":null,"children":[{"tag":"num","attrib":{"value":"709"},"text":"§ 709.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment restrictions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc290d60f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s709/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc290d610-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s709/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3134/d"},"text":"section 3134(d) of title 5","children":[],"tail":", the number of Senior Executive Service positions in the Department which are filled by noncareer appointees in any fiscal year may not at any time exceed 5 percent of the average number of senior executives employed in Senior Executive Service positions in the Department during the preceding fiscal year."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc290d611-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s709/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this subsection, the average number of senior executives employed in Senior Executive Service positions in the Department during a fiscal year shall be equal to 25 percent of the sum of the total number of senior executives employed in Senior Executive Service positions in the Department on the last day of each quarter of such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc290d612-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s709/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of positions in the Department which may be excepted from the competitive service, on a temporary or permanent basis, because of their confidential or policy-determining character may not at any time exceed the equivalent of 15 positions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc290d613-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s709/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc290d614-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s709/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Political affiliation or activity may not be taken into account in connection with the appointment of any person to any position in or to perform any service for the Department or in the assignment or advancement of any employee in the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc290d615-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s709/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Paragraph (1) shall not apply—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc290d616-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s709/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the appointment of any person by the President under this title, other than the appointment of the Under Secretary for Health, the Under Secretary for Benefits, and the Inspector General; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc290d617-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s709/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the appointment of any person to (i) a Senior Executive Service position as a noncareer appointee, or (ii) a position that is excepted from the competitive service, on a temporary or permanent basis, because of the confidential or policy-determining character of the position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc290d618-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s2/a"},"text":"Pub. L. 102–83, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/395"},"text":"105 Stat. 395","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/405/tIII/s302/c/1"},"text":"Pub. L. 102–405, title III, § 302(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-09"},"text":"Oct. 9, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1984"},"text":"106 Stat. 1984","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc290d619-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc290d61a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc290d61b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 709 and 710 were renumbered sections 1909 and 1910 of this title, respectively.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/527/s12"},"text":"section 12 of Pub. L. 100–527","children":[],"tail":", known as the Department of Veterans Affairs Act, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s3/3"},"text":"Pub. L. 102–83, § 3(3)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc290d61c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/405"},"text":"Pub. L. 102–405","children":[],"tail":" substituted “Under Secretary for Health” for “Chief Medical Director” and “Under Secretary for Benefits” for “Chief Benefits Director”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
