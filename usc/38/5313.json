{"tag":"section","attrib":{"id":"idc3d9d101-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313"},"text":null,"children":[{"tag":"num","attrib":{"value":"5313"},"text":"§ 5313.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on payment of compensation and dependency and indemnity compensation to persons incarcerated for conviction of a felony","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3d9d102-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3d9d103-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To the extent provided in subsection (d) of this section, any person who is entitled to compensation or to dependency and indemnity compensation and who is incarcerated in a Federal, State, local, or other penal institution or correctional facility for a period in excess of sixty days for conviction of a felony shall not be paid such compensation or dependency and indemnity compensation, for the period beginning on the sixty-first day of such incarceration and ending on the day such incarceration ends, in an amount that exceeds—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3d9d104-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a veteran with a service-connected disability rated at 20 percent or more, the rate of compensation payable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1114/a"},"text":"section 1114(a) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3d9d105-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a veteran with a service-connected disability not rated at 20 percent or more or in the case of a surviving spouse, parent, or child, one-half of the rate of compensation payable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1114/a"},"text":"section 1114(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d9d106-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of paragraph (1) of this subsection shall not apply with respect to any period during which a person is participating in a work-release program or is residing in a halfway house.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d9d107-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3d9d108-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All or any part of the compensation not paid to a veteran by reason of subsection (a) of this section may, as appropriate in an individual case, be apportioned under the same terms and conditions as are provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5307"},"text":"section 5307 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d9d109-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" All or any part of the dependency and indemnity compensation not paid to a surviving spouse or child by reason of subsection (a) of this section may, as appropriate in an individual case, be apportioned as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3d9d10a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of dependency and indemnity compensation not paid to a surviving spouse, any apportionment shall be to the surviving child or children.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3d9d10b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of dependency and indemnity compensation not paid to a surviving child, any apportionment shall be to the surviving spouse or other surviving children, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d9d10c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No apportionment may be made under this subsection to or on behalf of any person who is incarcerated in a Federal, State, local, or other penal institution or correctional facility for conviction of a felony.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d9d10d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall not assign to any veteran a rating of total disability based on the individual unemployability of the veteran resulting from a service-connected disability during any period during which the veteran is incarcerated in a Federal, State, local, or other penal institution or correctional facility for conviction of a felony.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d9d10e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of subsection (a) of this section shall apply (1) with respect to any period of incarceration of a person for conviction of a felony committed after ","children":[{"tag":"date","attrib":{"date":"1980-10-07"},"text":"October 7, 1980","children":[],"tail":", and (2) with respect to any period of incarceration on or after "},{"tag":"date","attrib":{"date":"1980-10-01"},"text":"October 1, 1980","children":[],"tail":", for conviction of a felony of a person who on "},{"tag":"date","attrib":{"date":"1980-10-01"},"text":"October 1, 1980","children":[],"tail":", is incarcerated for conviction of such felony and with respect to whom the action granting an award of compensation or dependency and indemnity compensation is taken on or after such date."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d9d10f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3d9d110-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “compensation” includes disability compensation payable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1151"},"text":"section 1151 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d9d111-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “dependency and indemnity compensation” means death compensation payable under section 1121 or 1141 of this title, death compensation and dependency and indemnity compensation payable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1151"},"text":"section 1151 of this title","children":[],"tail":", and any benefit payable under chapter 13 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3d9d112-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/385/tV/s504/a"},"text":"Pub. L. 96–385, title V, § 504(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-07"},"text":"Oct. 7, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1534"},"text":"94 Stat. 1534","children":[],"tail":", § 3113; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/160/tVII/s702/17"},"text":"Pub. L. 98–160, title VII, § 702(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-11-21"},"text":"Nov. 21, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1010"},"text":"97 Stat. 1010","children":[],"tail":"; renumbered § 5313 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", (d)(1), "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":", 239; "},{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":", §§ 4(b)(1), (2)(E), 5(c)(1), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404-406"},"text":"105 Stat. 404–406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/368/tX/s1005/b/16"},"text":"Pub. L. 105–368, title X, § 1005(b)(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3365"},"text":"112 Stat. 3365","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/461/tX/s1002/f"},"text":"Pub. L. 109–461, title X, § 1002(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3465"},"text":"120 Stat. 3465","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3d9d113-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3d9d114-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3d9d115-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsecs. (a)(1), (b)(3), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461"},"text":"Pub. L. 109–461","children":[],"tail":" substituted “local, or other penal institution or correctional facility” for “or local penal institution”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368"},"text":"Pub. L. 105–368","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1980-10-07"},"text":"October 7, 1980","children":[],"tail":",” for “the date of the enactment of this section,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/b/1"},"text":"Pub. L. 102–40, § 402(b)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3113"},"text":"section 3113 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “1114(a)” for “314(a)” in subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/d/1"},"text":"Pub. L. 102–40, § 402(d)(1)","children":[],"tail":", substituted “5307” for “3107”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “1151” for “351” in par. (1) and “1121”, “1141”, and “1151” for “321”, “341”, and “351”, respectively, in par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/160"},"text":"Pub. L. 98–160","children":[],"tail":" substituted “paragraph (1) of this subsection” for “paragraph (1) of this section”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3d9d116-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3d9d117-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1980-10-07"},"text":"Oct. 7, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/385/s601/d"},"text":"section 601(d) of Pub. L. 96–385","children":[],"tail":", set out as an Effective Date of 1980 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1114"},"text":"section 1114 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3d9d118-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Limitation on Payment of Compensation for Veterans Remaining Incarcerated Since ","children":[{"tag":"date","attrib":{"date":"1980-10-07"},"text":"October 7, 1980","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/103/tV/s506"},"text":"Pub. L. 107–103, title V, § 506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-27"},"text":"Dec. 27, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/996"},"text":"115 Stat. 996","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/103/tV/s506"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5313"},"text":"Section 5313 of title 38","children":[],"tail":", United States Code, other than subsection (d) of that section, shall apply with respect to the payment of compensation to or with respect to any veteran described in subsection (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Veterans","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A veteran described in this subsection is a veteran who is entitled to compensation and who—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on ","children":[{"tag":"date","attrib":{"date":"1980-10-07"},"text":"October 7, 1980","children":[],"tail":", was incarcerated in a Federal, State, or local penal institution for a felony committed before that date; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remains so incarcerated for conviction of that felony as of the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2001-12-27"},"text":"Dec. 27, 2001","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall apply with respect to the payment of compensation for months beginning on or after the end of the 90-day period beginning on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2001-12-27"},"text":"Dec. 27, 2001","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, the term ‘compensation’ has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5313"},"text":"section 5313 of title 38","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
