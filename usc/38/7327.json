{"tag":"section","attrib":{"id":"idc3fdacb1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327"},"text":null,"children":[{"tag":"num","attrib":{"value":"7327"},"text":"§ 7327.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Centers for research, education, and clinical activities on complex multi-trauma associated with combat injuries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3fdacb2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of this section is to provide for the improvement of the provision of health care services and related rehabilitation and education services to eligible veterans suffering from complex multi-trauma associated with combat injuries through—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3fdacb3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of improved models and systems for the furnishing by the Department of health care, rehabilitation, and education services to veterans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fdacb4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conduct of research to support the provision of such services in accordance with the most current evidence on multi-trauma injuries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fdacb5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the education and training of health care personnel of the Department with respect to the provision of such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3fdacb6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation of Centers","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3fdacb7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall designate an appropriate number of cooperative centers for clinical care, consultation, research, and education activities on combat injuries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fdacb8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each center designated under paragraph (1) shall function as a center for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3fdacb9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research on the long-term effects of injuries sustained as a result of combat in order to support the provision of services for such injuries in accordance with the most current evidence on complex multi-trauma;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fdacba-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of rehabilitation methodologies for treating individuals with complex multi-trauma; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fdacbb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the continuous and consistent coordination of care from the point of referral throughout the rehabilitation process and ongoing follow-up after return to home and community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fdacbc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall designate one of the centers designated under paragraph (1) as the lead center for activities referred to in that paragraph. As the lead center for such activities, such center shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3fdacbd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and provide periodic review of research priorities, and implement protocols, to ensure that projects contribute to the activities of the centers designated under paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fdacbe-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oversee the coordination of the professional and technical activities of such centers to ensure the quality and validity of the methodologies and statistical services for research project leaders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fdacbf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and ensure the deployment of an efficient and cost-effective data management system for such centers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fdacc0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and distribute educational materials and products to enhance the evaluation and care of individuals with combat injuries by medical care providers of the Department who are not specialized in the assessment and care of complex multi-trauma;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fdacc1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop educational materials for individuals suffering from combat injuries and for their families; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fdacc2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as a resource for the clinical and research infrastructure of such centers by disseminating clinical outcomes and research findings to improve clinical practice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fdacc3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall designate centers under paragraph (1) upon the recommendation of the Under Secretary for Health.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fdacc4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may designate a center under paragraph (1) only if the center meets the requirements of subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3fdacc5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements for Centers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be designated as a center under this section, a facility shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3fdacc6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a regional lead center for the care of traumatic brain injury;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fdacc7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be located at a tertiary care medical center and have on-site availability of primary and subspecialty medical services relating to complex multi-trauma;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fdacc8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have, or have the capacity to develop, the capability of managing impairments associated with combat injuries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fdacc9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be affiliated with a school of medicine;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fdacca-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have, or have experience with, participation in clinical research trials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fdaccb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide amputation care and rehabilitation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fdaccc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have pain management programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fdaccd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide comprehensive brain injury rehabilitation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fdacce-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide comprehensive general rehabilitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3fdaccf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Resources","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide each center designated under this section such resources as the Secretary determines to be required by such center to achieve adequate capability of managing individuals with complex multi-trauma, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3fdacd0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the upgrading of blind rehabilitation services by employing or securing the services of blind rehabilitation specialists;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fdacd1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employing or securing the services of occupational therapists with blind rehabilitation training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fdacd2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employing or securing the services of additional mental health services providers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fdacd3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employing or securing additional rehabilitation nursing staff to meet care needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3fdacd4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperation With Department of Defense","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3fdacd5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Veterans Affairs may assist the Secretary of Defense in the care of members of the Armed Forces with complex multi-trauma at military treatment facilities by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3fdacd6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making available, in a manner that the Secretary of Veterans Affairs considers appropriate, certified rehabilitation registered nurses of the Department of Veterans Affairs to such facilities to assess and coordinate the care of such members; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fdacd7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making available, in a manner that the Secretary of Veterans Affairs considers appropriate, blind rehabilitation specialists of the Department of Veterans Affairs to such facilities to consult with the medical staff of such facilities on the special needs of such members who have visual impairment as a consequence of combat injury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fdacd8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assistance shall be provided under this subsection through agreements for the sharing of health-care resources under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s8111"},"text":"section 8111 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3fdacd9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Award of Funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Centers designated under this section may compete for the award of funding from amounts appropriated for the Department for medical and prosthetics research.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3fdacda-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Dissemination of Information","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3fdacdb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary for Health shall ensure that information produced by the centers designated under this section that may be useful for other activities of the Veterans Health Administration is disseminated throughout the Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fdacdc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information shall be disseminated under this subsection through publications, through programs of continuing medical and related education provided through regional medical education centers under subchapter VI of chapter 74 of this title, and through other means.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3fdacdd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National Oversight","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Under Secretary for Health shall designate an appropriate officer to oversee the operation of the centers designated under this section and provide for periodic evaluation of the centers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3fdacde-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3fdacdf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" There are authorized to be appropriated to the Department of Veterans Affairs for the centers designated under this section amounts as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3fdace0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/i/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $7,000,000 for fiscal year 2005.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3fdace1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/i/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $8,000,000 for each of fiscal years 2006 through 2008.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3fdace2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7327/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to amounts authorized to be appropriated by paragraph (1) for a fiscal year, the Under Secretary for Health may allocate to each center designated under this section, from other funds authorized to be appropriated for such fiscal year for the Department generally for medical and for medical and prosthetic research, such amounts as the Under Secretary for Health determines appropriate to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3fdace3-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/422/tIII/s302/a/1"},"text":"Pub. L. 108–422, title III, § 302(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-11-30"},"text":"Nov. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2383"},"text":"118 Stat. 2383","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3fdace4-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3fdace5-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3fdace6-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Center of Excellence in the Mitigation, Treatment, and Rehabilitation of Traumatic Extremity Injuries and Amputations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title VII, § 723, "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4508"},"text":"122 Stat. 4508","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tX/s1079/d/2"},"text":"Pub. L. 114–92, div. A, title X, § 1079(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/999"},"text":"129 Stat. 999","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/92/dA/tX/s1079/d/2"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense and the Secretary of Veterans Affairs shall jointly establish a center of excellence in the mitigation, treatment, and rehabilitation of traumatic extremity injuries and amputations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Partnerships","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense and the Secretary of Veterans Affairs shall jointly ensure that the center collaborates with the Department of Defense, the Department of Veterans Affairs, institutions of higher education, and other appropriate public and private entities (including international entities) to carry out the responsibilities specified in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The center shall have the responsibilities as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To implement a comprehensive plan and strategy for the Department of Defense and the Department of Veterans Affairs for the mitigation, treatment, and rehabilitation of traumatic extremity injuries and amputations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To conduct research to develop scientific information aimed at saving injured extremities, avoiding amputations, and preserving and restoring the function of injured extremities. Such research shall address military medical needs and include the full range of scientific inquiry encompassing basic, translational, and clinical research.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To carry out such other activities to improve and enhance the efforts of the Department of Defense and the Department of Veterans Affairs for the mitigation, treatment, and rehabilitation of traumatic extremity injuries and amputations as the Secretary of Defense and the Secretary of Veterans Affairs consider appropriate.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3fdace7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Designation of Centers","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/422/tIII/s302/b"},"text":"Pub. L. 108–422, title III, § 302(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-11-30"},"text":"Nov. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2385"},"text":"118 Stat. 2385","children":[],"tail":", required the Secretary of Veterans Affairs to designate the centers required by this section not later than 120 days after "},{"tag":"date","attrib":{"date":"2004-11-30"},"text":"Nov. 30, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
