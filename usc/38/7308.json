{"tag":"section","attrib":{"id":"idc3f6814c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7308"},"text":null,"children":[{"tag":"num","attrib":{"value":"7308"},"text":"§ 7308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Rural Health","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3f6814d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7308/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established in the Department within the Office of the Under Secretary for Health an office to be known as the “Office of Rural Health” (in this section referred to as the “Office”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3f6814e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7308/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Head","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the Office of Rural Health shall be the head of the Office. The Director of the Office of Rural Health shall be appointed by the Under Secretary of Health from among individuals qualified to perform the duties of the position.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3f6814f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7308/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Functions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The functions of the Office are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3f68150-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7308/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In cooperation with the medical, rehabilitation, health services, and cooperative studies research programs in the Office of Policy and the Office of Research and Development of the Veterans Health Administration, to assist the Under Secretary for Health in conducting, coordinating, promoting, and disseminating research into issues affecting veterans living in rural areas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f68151-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7308/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To work with all personnel and offices of the Department of Veterans Affairs to develop, refine, and promulgate policies, best practices, lessons learned, and innovative and successful programs to improve care and services for veterans who reside in rural areas of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f68152-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7308/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To designate in each Veterans Integrated Service Network (VISN) an individual who shall consult on and coordinate the discharge in such Network of programs and activities of the Office for veterans who reside in rural areas of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f68153-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7308/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To perform such other functions and duties as the Secretary or the Under Secretary for Health considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3f68154-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7308/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rural Health Resource Centers","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3f68155-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7308/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are, in the Office, veterans rural health resource centers that serve as satellite offices for the Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3f68156-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7308/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The veterans rural health resource centers have purposes as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3f68157-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7308/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To improve the understanding of the Office of the challenges faced by veterans living in rural areas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3f68158-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7308/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To identify disparities in the availability of health care to veterans living in rural areas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3f68159-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7308/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To formulate practices or programs to enhance the delivery of health care to veterans living in rural areas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3f6815a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7308/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To develop special practices and products for the benefit of veterans living in rural areas and for implementation of such practices and products in the Department systemwide.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3f6815b-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461/tII/s212/a/1"},"text":"Pub. L. 109–461, title II, § 212(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3421"},"text":"120 Stat. 3421","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/154/tI/s110"},"text":"Pub. L. 112–154, title I, § 110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1175"},"text":"126 Stat. 1175","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3f6815c-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3f6815d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3f6815e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/154"},"text":"Pub. L. 112–154","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
