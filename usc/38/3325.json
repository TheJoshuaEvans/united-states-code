{"tag":"section","attrib":{"id":"idc36c427f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3325"},"text":null,"children":[{"tag":"num","attrib":{"value":"3325"},"text":"§ 3325.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc36c4280-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3325/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each academic year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc36c4281-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3325/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Defense shall submit to Congress a report on the operation of the program provided for in this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc36c4282-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3325/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall submit to Congress a report on the operation of the program provided for in this chapter and the program provided for under chapter 35 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc36c4283-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3325/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents of Secretary of Defense Reports","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall include in each report submitted under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc36c4284-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3325/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" information—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc36c4285-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3325/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indicating the extent to which the benefit levels provided under this chapter are adequate to achieve the purposes of inducing individuals to enter and remain in the Armed Forces and of providing an adequate level of financial assistance to help meet the cost of pursuing a program of education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc36c4286-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3325/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indicating whether it is necessary for the purposes of maintaining adequate levels of well-qualified active-duty personnel in the Armed Forces to continue to offer the opportunity for educational assistance under this chapter to individuals who have not yet entered active-duty service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc36c4287-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3325/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describing the efforts under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3323/b"},"text":"section 3323(b) of this title","children":[],"tail":" to inform members of the Armed Forces of the active duty service requirements for entitlement to educational assistance under this chapter and the results from such efforts; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc36c4288-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3325/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such recommendations for administrative and legislative changes regarding the provision of educational assistance to members of the Armed Forces and veterans, and their dependents, as the Secretary of Defense considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc36c4289-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3325/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents of Secretary of Veterans Affairs Reports","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall include in each report submitted under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc36c428a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3325/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information concerning the level of utilization of educational assistance and of expenditures under this chapter and under chapter 35 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc36c428b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3325/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate student outcome measures, such as the number of credit hours, certificates, degrees, and other qualifications earned by beneficiaries under this chapter and chapter 35 of this title during the academic year covered by the report;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc36c428c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3325/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information received by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3326"},"text":"section 3326 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc36c428d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3325/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such recommendations for administrative and legislative changes regarding the provision of educational assistance to members of the Armed Forces and veterans, and their dependents, as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc36c428e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3325/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No report shall be required under this section after ","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"January 1, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc36c428f-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","childre