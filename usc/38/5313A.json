{"tag":"section","attrib":{"id":"idc3d9d119-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5313A"},"text":null,"children":[{"tag":"num","attrib":{"value":"5313A"},"text":"§ 5313A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on payment of clothing allowance to incarcerated veterans","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In the case of a veteran who is incarcerated in a Federal, State, local, or other penal institution or correctional facility for a period in excess of 60 days and who is furnished clothing without charge by the institution, the amount of any annual clothing allowance payable to the veteran under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1162"},"text":"section 1162 of this title","children":[],"tail":" shall be reduced by an amount equal to "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":"⁄"},{"tag":"sub","attrib":{},"text":"365","children":[],"tail":" of the amount of the allowance otherwise payable under that section for each day on which the veteran was so incarcerated during the 12-month period preceding the date on which payment of the allowance would be due. This section shall be carried out under regulations prescribed by the Secretary."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc3d9d11a-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/275/tV/s502/a"},"text":"Pub. L. 104–275, title V, § 502(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3341"},"text":"110 Stat. 3341","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/461/tX/s1002/g"},"text":"Pub. L. 109–461, title X, § 1002(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3465"},"text":"120 Stat. 3465","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3d9d11b-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3d9d11c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3d9d11d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461"},"text":"Pub. L. 109–461","children":[],"tail":" substituted “local, or other penal institution or correctional facility” for “or local penal institution”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
