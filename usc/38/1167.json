{"tag":"section","attrib":{"id":"idc2afd035-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1167"},"text":null,"children":[{"tag":"num","attrib":{"value":"1167"},"text":"§ 1167.","children":[{"tag":"ref","attrib":{"idref":"fn002025"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002025"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" Another section 1167 is set out after section 1168."}],"tail":null}],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach pursuant to changes in presumptions of service connection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2afd036-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1167/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever a law, including through a regulation or Federal court decision or settlement, establishes or modifies a presumption of service connection, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2afd037-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1167/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify all claims for compensation under this chapter that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2afd038-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1167/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" were submitted to the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2afd039-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1167/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" were evaluated and denied by the Secretary before the date on which such provision of law went into effect; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2afd03a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1167/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" might have been evaluated differently had the establishment or modification been applicable to the claim; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2afd03b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1167/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to subsection (b), conduct outreach to the claimants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2afd03c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1167/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Outreach","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2afd03d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1167/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall conduct outreach to inform claimants identified under subsection (a) that they may submit a supplemental claim in light of the establishment or modification of a presumption of service connection described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2afd03e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1167/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Outreach under paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2afd03f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1167/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall publish on the internet website of the Department a notice that such veterans may elect to file a supplemental claim.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2afd040-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1167/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall notify, in writing or by electronic means, veterans service organizations of the ability of such veterans to file a supplemental claim.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2afd041-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1167/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall contact each claimant identified under subsection (a) in the same manner that the Department last provided notice of a decision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2afd042-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/168/tII/s203/a"},"text":"Pub. L. 117–168, title II, § 203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-10"},"text":"Aug. 10, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1775"},"text":"136 Stat. 1775","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2afd043-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc2afd044-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc2afd045-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/168/tII/s203/b"},"text":"Pub. L. 117–168, title II, § 203(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-10"},"text":"Aug. 10, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1776"},"text":"136 Stat. 1776","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/168/tII/s203/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1167"},"text":"Section 1167 of title 38","children":[],"tail":", United States Code, as added by subsection (a), shall apply with respect to presumptions of service connection established or modified on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2022-08-10"},"text":"Aug. 10, 2022","children":[],"tail":"], including pursuant to amendments made by this Act [see Short Title of 2022 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of this title","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc2afd046-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/168/tII/s203/c"},"text":"Pub. L. 117–168, title II, § 203(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-10"},"text":"Aug. 10, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1776"},"text":"136 Stat. 1776","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/168/tII/s203/c"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Nothing in this section [enacting this section and provisions set out as a note above] shall be construed as—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modifying the obligations of the Department of Veterans Affairs under Federal court decisions or settlements in effect as of the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-08-10"},"text":"Aug. 10, 2022","children":[],"tail":"]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requiring a retroactively applied effective date of a supplemental claim earlier than the date a presumption of service connection is established or modified.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
