{"tag":"section","attrib":{"id":"idc33c8090-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2108"},"text":null,"children":[{"tag":"num","attrib":{"value":"2108"},"text":"§ 2108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specially adapted housing assistive technology grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc33c8091-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2108/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to Make Grants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall make grants to encourage the development of new assistive technologies for specially adapted housing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc33c8092-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2108/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person or entity seeking a grant under this section shall submit to the Secretary an application for the grant in such form and manner as the Secretary shall specify.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc33c8093-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2108/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grant Funds","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc33c8094-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2108/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each grant awarded under this section shall be in an amount of not more than $200,000 per fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc33c8095-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2108/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For each fiscal year in which the Secretary makes a grant under this section, the Secretary shall make the grant by not later than April 1 of that year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc33c8096-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2108/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The recipient of a grant under this section shall use the grant to develop assistive technologies for use in specially adapted housing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc33c8097-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2108/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than March 1 of each fiscal year following a fiscal year in which the Secretary makes a grant, the Secretary shall submit to Congress a report containing information related to each grant awarded under this section during the preceding fiscal year, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc33c8098-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2108/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the grant recipient;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc33c8099-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2108/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the grant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc33c809a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2108/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the goal of the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc33c809b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2108/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"From amounts appropriated to the Department for readjustment benefits for each fiscal year for which the Secretary is authorized to make a grant under this section, $1,000,000 shall be available for that fiscal year for the purposes of the program under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc33c809c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2108/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority to make a grant under this section shall begin on ","children":[{"tag":"date","attrib":{"date":"2011-10-01"},"text":"October 1, 2011","children":[],"tail":", and shall terminate on "},{"tag":"date","attrib":{"date":"2026-09-30"},"text":"September 30, 2026","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc33c809d-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/275/tII/s203/a"},"text":"Pub. L. 111–275, title II, § 203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-13"},"text":"Oct. 13, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2874"},"text":"124 Stat. 2874","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/228/tIV/s409"},"text":"Pub. L. 114–228, title IV, § 409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-09-29"},"text":"Sept. 29, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/940"},"text":"130 Stat. 940","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/62/tIV/s408"},"text":"Pub. L. 115–62, title IV, § 408","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-09-29"},"text":"Sept. 29, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1164"},"text":"131 Stat. 1164","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/251/tI/s122"},"text":"Pub. L. 115–251, title I, § 122","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-29"},"text":"Sept. 29, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3169"},"text":"132 Stat. 3169","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/159/dE/tII/s5201"},"text":"Pub. L. 116–159, div. E, title II, § 5201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-01"},"text":"Oct. 1, 2020","children":[],"tail":