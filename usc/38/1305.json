{"tag":"section","attrib":{"id":"idc2b24121-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1305"},"text":null,"children":[{"tag":"num","attrib":{"value":"1305"},"text":"§ 1305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reevaluation of dependency and indemnity compensation determinations pursuant to changes in presumptions of service connection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2b24122-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reevaluation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever a law, including through a regulation or Federal court decision or settlement, establishes or modifies a presumption of service connection, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2b24123-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1305/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify all claims for dependency and indemnity compensation under this chapter that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2b24124-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1305/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" were submitted to the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2b24125-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1305/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" were evaluated and denied by the Secretary before the date on which such provision of law went into effect; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2b24126-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1305/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" might have been evaluated differently had the establishment or modification been applicable to the claim;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2b24127-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1305/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow for the reevaluation of such claims at the election of the claimant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2b24128-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1305/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5110"},"text":"section 5110 of this title","children":[],"tail":", with respect to claims approved pursuant to such reevaluation, provide compensation under this chapter effective as if the establishment or modification of the presumption of service connection had been in effect on the date of the submission of the original claim described in paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2b24129-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Outreach","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2b2412a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1305/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall conduct outreach to inform relevant claimants that they may elect to have a claim be reevaluated in light of the establishment or modification of a presumption of service connection described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2b2412b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1305/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Outreach under paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2b2412c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1305/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall publish on the internet website of the Department a notice that such claimants may elect to have a claim so reevaluated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2b2412d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1305/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall notify, in writing or by electronic means, veterans service organizations of the ability of such claimants to elect to have a claim so reevaluated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2b2412e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1305/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall contact each claimant identified under subsection (a) in the same manner that the Department last provided notice of a decision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2b2412f-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/168/tII/s204/a"},"text":"Pub. L. 117–168, title II, § 204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-10"},"text":"Aug. 10, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1776"},"text":"136 Stat. 1776","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2b24130-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc2b24131-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc2b24132-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/168/tII/s204/b"},"text":"Pub. L. 117–168, title II, § 204(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-10"},"text":"Aug. 10, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1777"},"text":"136 Stat. 1777","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/168/tII/s204/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1305"},"text":"Section 1305 of title 38","children":[],"tail":", United States Code, as added by subsection (a), shall apply with respect to presumptions of service connection established or modified on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2022-08-10"},"text":"Aug. 10, 2022","children":[],"tail":"], including pursuant to amendments made by this Act [see Short Title of 2022 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of this title","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc2b24133-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/168/tII/s204/c"},"text":"Pub. L. 117–168, title II, § 204(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-10"},"text":"Aug. 10, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1777"},"text":"136 Stat. 1777","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/168/tII/s204/c"},"text":"“Nothing in this section [enacting this section and provisions set out as a note above] shall be construed as modifying the obligations of the Department of Veterans Affairs under Federal court decisions or settlements in effect as of the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-08-10"},"text":"Aug. 10, 2022","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
