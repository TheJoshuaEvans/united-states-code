{"tag":"section","attrib":{"id":"idc436e5cb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8213"},"text":null,"children":[{"tag":"num","attrib":{"value":"8213"},"text":"§ 8213.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot program assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc436e5cc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8213/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to subsection (b) of this section, the Secretary may enter into an agreement to provide to any college or university which is primarily supported by the State in which it is located (hereinafter in this subchapter referred to as “institution”) the following assistance to enable such institution to establish a new medical school:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc436e5cd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8213/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The extension, alteration, remodeling, improvement, or repair of buildings and structures (including, as part of a lease made under paragraph (1), the provision of equipment) provided under paragraph (1) to the extent necessary to make them suitable for use as medical school facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc436e5ce-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8213/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The making of grants to assist the institution to pay the cost of the salaries of the faculty of such school during the initial 12-month period of operation of the school and the next six such 12-month periods, but payment under this paragraph may not exceed an amount equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc436e5cf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8213/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 90 percent of the cost of faculty salaries during the first 12-month period of operation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc436e5d0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8213/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 90 percent of such cost during the second such period,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc436e5d1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8213/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 90 percent of such cost during the third such period,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc436e5d2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8213/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 80 percent of such cost during the fourth such period,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc436e5d3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8213/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 70 percent of such cost during the fifth such period,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc436e5d4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8213/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 60 percent of such cost during the sixth such period, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc436e5d5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8213/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of such cost during the seventh and eighth such periods.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc436e5d6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8213/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc436e5d7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8213/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may not enter into any agreement under subsection (a) of this section unless the Secretary finds, and the agreement includes satisfactory assurances, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc436e5d8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8213/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there will be adequate State or other financial support for the proposed school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc436e5d9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8213/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the overall plans for the school meet such professional and other standards as the Secretary deems appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc436e5da-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8213/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the school will maintain such arrangements with the Department medical facility with which it is associated (including but not limited to such arrangements as may be made under subchapter IV of chapter 81 of this title) as will be mutually beneficial in the carrying out of the mission of the medical facility and the school; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc436e5db-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8213/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the basis of consultation with the appropriate accreditation body or bodies approved for such purpose by the Secretary of Education, there is reasonable assurance that, with the aid of an agreement under subsection (a) of this section, such school will meet the accreditation standards of such body or bodies within a reasonable time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc436e5dc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8213/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any agreement entered into by the Secretary under this subchapter shall contain such terms and conditions (in addition to those imposed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s8201/e"},"text":"section 8201(e) of this title","children":[],"tail":" and subsection (b)(1) of this section) as the Secretary deems necessary and appropriate to protect the interest of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc436e5dd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8213/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the Secretary, in accordance with such regulations as the Secretary shall prescribe, determines that any school established with assistance under this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc436e5de-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8213/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not accredited and fails to gain appropriate accreditation within a reasonable period of time;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc436e5df-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8213/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is accredited but fails substantially to carry out the terms of the agreement entered into under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc436e5e0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8213/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is no longer operated for the purpose for which such assistance was granted,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Secretary shall be entitled to recover from the recipient of assistance under this chapter the facilities of such school which were established with assistance under this chapter. In order to recover such facilities the Secretary may bring an action in the district court of the United States for the district in which such facilities are situated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc436e5e1-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/541/s2/a"},"text":"Pub. L. 92–541, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-24"},"text":"Oct. 24, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1102"},"text":"86 Stat. 1102","children":[],"tail":", § 5073; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/581/tI/s116/3"},"text":"Pub. L. 94–581, title I, § 116(3)","children":[],"tail":", (4), title II, § 210(f)(3), "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2854"},"text":"90 Stat. 2854","children":[],"tail":", 2865; "},{"tag":"ref","attrib":{"href":"/us/pl/97/15"},"text":"Pub. L. 97–15","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-06-17"},"text":"June 17, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/99"},"text":"95 Stat. 99","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/295/s4/95/B"},"text":"Pub. L. 97–295, § 4(95)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1313"},"text":"96 Stat. 1313","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/576/tVII/s702/16"},"text":"Pub. L. 99–576, title VII, § 702(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3302"},"text":"100 Stat. 3302","children":[],"tail":"; renumbered § 8213 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/2/B"},"text":"Pub. L. 102–40, title IV, § 402(b)(2)(B)","children":[],"tail":", (d)(1), "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/239"},"text":"105 Stat. 239","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/3"},"text":"Pub. L. 102–83, § 4(a)(3)","children":[],"tail":", (4), (b)(1), (2)(E), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404"},"text":"105 Stat. 404","children":[],"tail":", 405.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc436e5e2-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc436e5e3-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc436e5e4-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/b/2/B"},"text":"Pub. L. 102–40, § 402(b)(2)(B)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5073"},"text":"section 5073 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/3"},"text":"Pub. L. 102–83, § 4(a)(3)","children":[],"tail":", (4), substituted “Department” for “Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/d/1"},"text":"Pub. L. 102–40, § 402(d)(1)","children":[],"tail":", substituted “8201(e)” for “5070(e)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576"},"text":"Pub. L. 99–576","children":[],"tail":" substituted “12-month” for “twelve-month” wherever appearing in introductory provisions and in subpar. (A) and “percent” for “per centum” in subpars. (A) to (G)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (b)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295"},"text":"Pub. L. 97–295","children":[],"tail":" substituted “Secretary of Education” for “Commissioner of Education of the Department of Health, Education, and Welfare”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (a)(2)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/15"},"text":"Pub. L. 97–15","children":[],"tail":" substituted “seventh and eighth such periods” for “seventh such period”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/581/s116/3"},"text":"Pub. L. 94–581, § 116(3)","children":[],"tail":", redesignated pars. (2) and (3) as (1) and (2), respectively. Former par. (1), which authorized the leasing of such land, buildings, and structures under the control of the Veterans’ Administration as might be necessary for a new medical school, was struck out. See "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5070/e"},"text":"section 5070(e) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/581/s210/f/3/A"},"text":"Pub. L. 94–581, § 210(f)(3)(A)","children":[],"tail":", substituted “the Administrator” for “he” in provisions preceding subpar. (A)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/581"},"text":"Pub. L. 94–581","children":[],"tail":", §§ 116(4), 210(f)(3)(A), substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5070/e"},"text":"section 5070(e) of this title","children":[],"tail":" and subsection (b)(1) of this section” for “subsections (a)(1) and (b)(1) of this section” and “as the Administrator deems” for “as he deems”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/581/s210/f/3/B"},"text":"Pub. L. 94–581, § 210(f)(3)(B)","children":[],"tail":", substituted “the Administrator” for “he” in provisions preceding par. (1) and in provisions following par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc436e5e5-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc436e5e6-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/581"},"text":"Pub. L. 94–581","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/581/s211"},"text":"section 211 of Pub. L. 94–581","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s111"},"text":"section 111 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
