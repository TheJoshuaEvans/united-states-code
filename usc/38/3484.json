{"tag":"section","attrib":{"id":"idc3734794-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3484"},"text":null,"children":[{"tag":"num","attrib":{"value":"3484"},"text":"§ 3484.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Apprenticeship or other on-job training; correspondence courses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any eligible veteran may pursue a program of apprenticeship or other on-job training or a program of education exclusively by correspondence and be paid an educational assistance allowance or training assistance allowance, as applicable, under the provisions of section 3687 or 3686 of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc3734795-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/540/tIII/s304"},"text":"Pub. L. 92–540, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-24"},"text":"Oct. 24, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1081"},"text":"86 Stat. 1081","children":[],"tail":", § 1684; renumbered § 3484 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3734796-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3734797-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3734798-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1684"},"text":"section 1684 of this title","children":[],"tail":" as this section and substituted “3687 or 3686” for “1787 or 1786”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
