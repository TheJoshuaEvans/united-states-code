{"tag":"section","attrib":{"id":"idc332e320-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2034"},"text":null,"children":[{"tag":"num","attrib":{"value":"2034"},"text":"§ 2034.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with other agencies and organizations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc332e321-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2034/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In assisting homeless veterans, the Secretary shall coordinate with, and may provide services authorized under this title in conjunction with, State and local governments, other appropriate departments and agencies of the Federal Government, and nongovernmental organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc332e322-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2034/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc332e323-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2034/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall require the director of each medical center or the director of each regional benefits office to make an annual assessment of the needs of homeless veterans living within the area served by the medical center or regional office, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc332e324-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2034/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each such assessment shall be made in coordination with representatives of State and local governments, other appropriate departments and agencies of the Federal Government, and nongovernmental organizations that have experience working with homeless persons in that area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc332e325-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2034/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each such assessment shall identify the needs of homeless veterans with respect to the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc332e326-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2034/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Health care.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc332e327-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2034/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Education and training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc332e328-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2034/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Employment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc332e329-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2034/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Shelter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc332e32a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2034/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Counseling.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc332e32b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2034/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Outreach services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc332e32c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2034/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each assessment shall also indicate the extent to which the needs referred to in paragraph (3) are being met adequately by the programs of the Department, of other departments and agencies of the Federal Government, of State and local governments, and of nongovernmental organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc332e32d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2034/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each assessment shall be carried out in accordance with uniform procedures and guidelines prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc332e32e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2034/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall review each annual assessment under this subsection and shall consolidate the findings and conclusions of each such assessment into the next annual report submitted to Congress under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2065"},"text":"section 2065 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc332e32f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2034/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In furtherance of subsection (a), the Secretary shall require the director of each medical center and the director of each regional benefits office, in coordination with representatives of State and local governments, other Federal officials, and nongovernmental organizations that have experience working with homeless persons in the areas served by such facility or office, to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc332e330-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2034/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a list of all public and private programs that provide assistance to homeless persons or homeless veterans in the area concerned, together with a description of the services offered by those programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc332e331-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2034/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek to encourage the development by the representatives of such entities, in coordination with the director, of a plan to coordinate among such public and private programs the provision of services to homeless veterans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc332e332-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2034/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take appropriate action to meet, to the maximum extent practicable through existing programs and available resources, the needs of homeless veterans that are identified in the assessment conducted under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc332e333-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2034/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attempt to inform homeless veterans whose needs the director cannot meet under paragraph (3) of the services available to such veterans within the area served by such center or office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc332e334-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/114/tII/s202/a"},"text":"Pub. L. 105–114, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2286"},"text":"111 Stat. 2286","children":[],"tail":", § 1774; renumbered § 2034 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/95"},"text":"Pub. L. 107–95","children":[],"tail":", §§ 5(b)(1), 6(b), "},{"tag":"date","attrib":{"date":"2001-12-21"},"text":"Dec. 21, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/918"},"text":"115 Stat. 918","children":[],"tail":", 919.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc332e335-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc332e336-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc332e337-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/95/s5/b/1"},"text":"Pub. L. 107–95, § 5(b)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1774"},"text":"section 1774 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/95/s6/b/1"},"text":"Pub. L. 107–95, § 6(b)(1)","children":[],"tail":", inserted “annual” after “to make an”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/95/s6/b/2"},"text":"Pub. L. 107–95, § 6(b)(2)","children":[],"tail":", added par. (6)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
