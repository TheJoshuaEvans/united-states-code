{"tag":"section","attrib":{"id":"idc37a72d5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3521"},"text":null,"children":[{"tag":"num","attrib":{"value":"3521"},"text":"§ 3521.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of application","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall approve an application if the Secretary finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc37a72d6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3521/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proposed program of education constitutes a “program of education” as that term is defined in this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc37a72d7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3521/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible person is not already qualified, by reason of previous education or training, for the educational, professional, or vocational objective for which the program of education is offered;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc37a72d8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3521/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible person’s proposed educational institution or training establishment is in compliance with all the requirements of this chapter and chapter 36 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc37a72d9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3521/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it does not appear that the enrollment in or pursuit of such person’s program of education would violate any provisions of this chapter or chapter 36 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc37a72da-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1196"},"text":"72 Stat. 1196","children":[],"tail":", § 1721; "},{"tag":"ref","attrib":{"href":"/us/pl/94/502/tIII/s310/11"},"text":"Pub. L. 94–502, title III, § 310(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-15"},"text":"Oct. 15, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2391"},"text":"90 Stat. 2391","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/466/tIII/s324"},"text":"Pub. L. 96–466, title III, § 324","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2196"},"text":"94 Stat. 2196","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/576/tIII/s314/b/1"},"text":"Pub. L. 99–576, title III, § 314(b)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3273"},"text":"100 Stat. 3273","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIV/s423/b/1/A"},"text":"Pub. L. 101–237, title IV, § 423(b)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2092"},"text":"103 Stat. 2092","children":[],"tail":"; renumbered § 3521, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc37a72db-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc37a72dc-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc37a72dd-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1721"},"text":"section 1721 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" substituted “Secretary” for “Administrator” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576"},"text":"Pub. L. 99–576","children":[],"tail":" substituted “Approval of application” for “Final approval of application” in section catchline, struck out “finally” before “approve an application” in introductory provisions, struck out former cl. (1) which read “"},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1720"},"text":"section 1720 of this title","children":[],"tail":" has been complied with;”, and redesignated cls. (2) to (5) as cls. (1) to (4), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466"},"text":"Pub. L. 96–466","children":[],"tail":", among other changes, inserted provision conditioning approval of an application upon the educational institution’s or training establishment’s compliance with all the requirements of this chapter and chapter 36 of this title and substituted reference to the enrollment in or pursuit of such person’s program of education violating any provisions of this chapter or chapter 36 of this title for reference to the pursuit of such program violating any provision of this chapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/502"},"text":"Pub. L. 94–502","children":[],"tail":" substituted “if the Administrator finds” for “if he finds”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc37a72de-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc37a72df-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466"},"text":"Pub. L. 96–466","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-10-01"},"text":"Oct. 1, 1980","children":[],"tail":", except as otherwise specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/96/466/s802/c"},"text":"section 802(c) of Pub. L. 96–466","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3452"},"text":"section 3452 of this title","childre