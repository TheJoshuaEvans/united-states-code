{"tag":"section","attrib":{"id":"idc375b80d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3492"},"text":null,"children":[{"tag":"num","attrib":{"value":"3492"},"text":"§ 3492.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tutorial assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc375b80e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3492/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of any eligible veteran who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc375b80f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3492/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is enrolled in and pursuing a postsecondary course of education on a half-time or more basis at an educational institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc375b810-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3492/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a deficiency in a subject required as a part of, or which is prerequisite to, or which is indispensable to the satisfactory pursuit of, an approved program of education,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Secretary may approve individualized tutorial assistance for such veteran if such assistance is necessary for the veteran to complete such program successfully.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc375b811-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3492/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall pay to an eligible veteran receiving tutorial assistance pursuant to subsection (a) of this section, in addition to the educational assistance allowance provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3482"},"text":"section 3482 of this title","children":[],"tail":", the cost of such tutorial assistance in an amount not to exceed $100 per month, for a maximum of twelve months, or until a maximum of $1,200 is utilized, upon certification by the educational institution that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc375b812-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3492/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individualized tutorial assistance is essential to correct a deficiency of the eligible veteran in a subject required as a part of, or which is prerequisite to, or which is indispensable to the satisfactory pursuit of, an approved program of education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc375b813-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3492/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tutor chosen to perform such assistance is qualified and is not the eligible veteran’s parent, spouse, child (whether or not married or over eighteen years of age), brother, or sister; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc375b814-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3492/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the charges for such assistance do not exceed the customary charges for such tutorial assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc375b815-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/219/tII/s204/a/4"},"text":"Pub. L. 91–219, title II, § 204(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-03-26"},"text":"Mar. 26, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/80"},"text":"84 Stat. 80","children":[],"tail":", § 1692; amended "},{"tag":"ref","attrib":{"href":"/us/pl/92/540/tIII/s306"},"text":"Pub. L. 92–540, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-24"},"text":"Oct. 24, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1081"},"text":"86 Stat. 1081","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/508/tII/s206"},"text":"Pub. L. 93–508, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-12-03"},"text":"Dec. 3, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1583"},"text":"88 Stat. 1583","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/502/tII/s209"},"text":"Pub. L. 94–502, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-15"},"text":"Oct. 15, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2388"},"text":"90 Stat. 2388","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/202/tI/s102/5"},"text":"Pub. L. 95–202, title I, § 102(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-11-23"},"text":"Nov. 23, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1434"},"text":"91 Stat. 1434","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/466/tII"},"text":"Pub. L. 96–466, title II","children":[],"tail":", §§ 201(5), 211(5), title III, § 312, "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2188"},"text":"94 Stat. 2188","children":[],"tail":", 2190, 2195; "},{"tag":"ref","attrib":{"href":"/us/pl/98/543/tII/s202/4"},"text":"Pub. L. 98–543, title II, § 202(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-24"},"text":"Oct. 24, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2742"},"text":"98 Stat. 2742","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/689/tI/s107/c/1"},"text":"Pub. L. 100–689, title I, § 107(c)(1)","children":[],"tail":", (2)(A), "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4169"},"text":"102 Stat. 4169","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIV/s423/b/1/A"},"text":"Pub. L. 101–237, title IV, § 423(b)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2092"},"text":"103 Stat. 2092","children":[],"tail":"; renumbered § 3492 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc375b816-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc375b817-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc375b818-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendmen