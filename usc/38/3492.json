uted “$72” and “$869” for “$69” and “$828”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466/s312"},"text":"Pub. L. 96–466, § 312","children":[],"tail":", inserted “and is not the eligible veteran’s parent, spouse, child (whether or not married or over eighteen years of age), brother, or sister” after “is qualified”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/202"},"text":"Pub. L. 95–202","children":[],"tail":" substituted “$69” and “$828” for “$65” and “$780”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/502"},"text":"Pub. L. 94–502","children":[],"tail":" substituted “$65” for “$60” and “$780” for “$720”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/508"},"text":"Pub. L. 93–508","children":[],"tail":" substituted “$60 per month, for a maximum of twelve months, or until a maximum of $720” for “$50 per month, for a maximum of nine months, or until a maximum of $450”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/540/s306/1"},"text":"Pub. L. 92–540, § 306(1)","children":[],"tail":", struck out “marked” before “deficiency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/540/s306/2"},"text":"Pub. L. 92–540, § 306(2)","children":[],"tail":", inserted “or until a maximum of $450 is utilized,” after “nine months”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/540/s306/1"},"text":"Pub. L. 92–540, § 306(1)","children":[],"tail":", struck out “marked” before “deficiency”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"