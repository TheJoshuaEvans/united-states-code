{"tag":"section","attrib":{"id":"idc30cbd29-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1729B"},"text":null,"children":[{"tag":"num","attrib":{"value":"1729B"},"text":"§ 1729B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consolidated patient accounting centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc30cbd2a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1729B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than five years after the date of the enactment of this section, the Secretary of Veterans Affairs shall establish not more than seven consolidated patient accounting centers for conducting industry-modeled regionalized billing and collection activities of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc30cbd2b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1729B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Functions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The centers shall carry out the following functions:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc30cbd2c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1729B/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reengineer and integrate all business processes of the revenue cycle of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30cbd2d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1729B/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Standardize and coordinate all activities of the Department related to the revenue cycle for all health care services furnished to veterans for non-service-connected medical conditions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30cbd2e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1729B/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Apply commercial industry standards for measures of access, timeliness, and performance metrics with respect to revenue enhancement of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30cbd2f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1729B/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Apply other requirements with respect to such revenue cycle improvement as the Secretary may specify.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc30cbd30-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/387/tIV/s406/a"},"text":"Pub. L. 110–387, title IV, § 406(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4129"},"text":"122 Stat. 4129","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc30cbd31-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc30cbd32-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc30cbd33-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsec. (a), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/387"},"text":"Pub. L. 110–387","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc30cbd34-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1729B, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117/tII/s202/a"},"text":"Pub. L. 106–117, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-30"},"text":"Nov. 30, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1561"},"text":"113 Stat. 1561","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/103/tV/s509/c"},"text":"Pub. L. 107–103, title V, § 509(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-27"},"text":"Dec. 27, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/997"},"text":"115 Stat. 997","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/330/tIII/s308/g/7"},"text":"Pub. L. 107–330, title III, § 308(g)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-06"},"text":"Dec. 6, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2829"},"text":"116 Stat. 2829","children":[],"tail":", related to the Department of Veterans Affairs Health 