{"tag":"section","attrib":{"id":"idc2afd091-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1173"},"text":null,"children":[{"tag":"num","attrib":{"value":"1173"},"text":"§ 1173.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Formal evaluation of recommendations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2afd092-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1173/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Formal Evaluations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall establish a process to conduct a formal evaluation with respect to each recommendation made by the Working Group under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1172"},"text":"section 1172 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2afd093-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1173/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Evidence, Data, and Factors","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that each formal evaluation under subsection (a) covers the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2afd094-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1173/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Scientific evidence, based on the review of available scientific literature, including human, toxicological, animal, and methodological studies, and other factors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2afd095-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1173/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Claims data, based on the review of claim rate, grant rate, and service connection prevalence, and other factors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2afd096-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1173/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Other factors the Secretary determines appropriate, such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2afd097-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1173/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the level of disability and mortality caused by the health effects related to the case of toxic exposure being evaluated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2afd098-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1173/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity and quality of the information available and reviewed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2afd099-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1173/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the feasibility of and period for generating relevant information and evidence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2afd09a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1173/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether such health effects are combat- or deployment-related;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2afd09b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1173/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ubiquity or rarity of the health effects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2afd09c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1173/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any time frame during which a health effect must become manifest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2afd09d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1173/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conduct of Evaluations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2afd09e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1173/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall ensure that each formal evaluation under subsection (a)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2afd09f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1173/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" reviews scientific evidence in a manner that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc2afd0a0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1173/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conforms to principles of scientific and data integrity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc2afd0a1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1173/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is free from suppression or distortion of scientific or technological findings, data, information, conclusions, or technical results; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2afd0a2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1173/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc2afd0a3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1173/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluates the likelihood that a positive association exists between an illness and a toxic exposure while serving in the active military, naval, air, or space service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc2afd0a4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1173/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assesses the toxic exposures and illnesses and determines whether the evidence supports a finding of a positive association between the toxic exposure and the illness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2afd0a5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1173/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out paragraph (1)(B)(ii), a formal evaluation under subsection (a) shall include reviewing all relevant data to determine the strength of evidence for a positive association based on the following four categories:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2afd0a6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1173/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The “sufficient” category, where the evidence is sufficient to conclude that a positive association exists.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2afd0a7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1173/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The “equipoise and above” category, where the evidence is sufficient to conclude that a positive association is at least as likely as not, but not sufficient to conclude that a positive association exists.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2afd0a8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1173/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The “below equipoise” category, where the evidence is not sufficient to conclude that a positive association is at least as likely as not, or is not sufficient to make a scientifically informed judgment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2afd0a9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1173/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The “against” category, where the evidence suggests the lack of a positive association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2afd0aa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1173/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recommendation for Establishing a Presumption of Service Connection","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 120 days after the date on which a formal evaluation is commenced, the element of the Department that conducts the evaluation shall submit to the Secretary a recommendation with respect to establishing a presumption of service connection for the toxic exposure and illness, or modifying an existing presumption of service connection, covered by the evaluation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2afd0ab-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/168/tII/s202/a"},"text":"Pub. L. 117–168, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-10"},"text":"Aug. 10, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1769"},"text":"136 Stat. 1769","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
