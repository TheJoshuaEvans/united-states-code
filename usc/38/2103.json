{"tag":"section","attrib":{"id":"idc33c8055-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2103"},"text":null,"children":[{"tag":"num","attrib":{"value":"2103"},"text":"§ 2103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Furnishing of plans and specifications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc33c8056-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plans and Specifications","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary is authorized to furnish to individuals eligible for assistance under this chapter, without cost to the individuals, model plans and specifications of suitable housing units.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc33c8057-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Handbook for Design","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall make available to veterans eligible for assistance under this chapter, without cost to the veterans, a handbook containing appropriate designs for specially adapted housing. The Secretary shall update such handbook at least once every six years to take into account any new or unique disabilities, including vision impairments, impairments specific to the upper limbs, and burn injuries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc33c8058-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", 