{"tag":"section","attrib":{"id":"idc30347f3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720H"},"text":null,"children":[{"tag":"num","attrib":{"value":"1720H"},"text":"§ 1720H.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mental health treatment for veterans and members of the reserve components of the Armed Forces who served in classified missions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc30347f4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720H/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Standards","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc30347f5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720H/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall establish standards and procedures to ensure that each eligible individual may access mental health care furnished by the Secretary in a manner that fully accommodates the obligation of the individual to not improperly disclose classified information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30347f6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720H/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In establishing standards and procedures under paragraph (1), the Secretary shall consult with the Secretary of Defense to ensure that such standards and procedures are consistent with the policies on classified information of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30347f7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720H/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall disseminate guidance to employees of the Veterans Health Administration, including mental health professionals, on the standards and procedures established under paragraph (1) and how to best engage eligible individuals during the course of mental health treatment with respect to classified information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc30347f8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720H/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Identification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out this section, the Secretary shall ensure that an individual may elect to identify as an eligible individual on an appropriate form.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc30347f9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720H/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc30347fa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720H/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “classified information” means any information or material that has been determined by an official of the United States pursuant to law to require protection against unauthorized disclosure for reasons of national security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30347fb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720H/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “eligible individual” means a veteran or a member of the reserve components of the Armed Forces who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc30347fc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720H/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is eligible to receive health care furnished by the Department under this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc30347fd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720H/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is seeking mental health treatment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc30347fe-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720H/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the course of serving in the Armed Forces, participated in a sensitive mission or served in a sensitive unit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc30347ff-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720H/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “sensitive mission” means a mission of the Armed Forces that, at the time at which an eligible individual seeks treatment, is classified.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3034800-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720H/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “sensitive unit” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s130b/c/4"},"text":"section 130b(c)(4) of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3034801-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/315/tVI/s605/b"},"text":"Pub. L. 114–315, title VI, § 605(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1571"},"text":"130 Stat. 1571","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tVII/s764/b/1"},"text":"Pub. L. 116–283, div. A, title VII, § 764(b)(1)","children":[],"tail":", (2)(A), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3727"},"text":"134 Stat. 3727","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3034802-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3034803-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3034804-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s764/b/2/A"},"text":"Pub. L. 116–283, § 764(b)(2)(A)","children":[],"tail":", inserted “and members of the reserve components of the Armed Forces” after “veterans” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s764/b/1/A/i"},"text":"Pub. L. 116–283, § 764(b)(1)(A)(i)","children":[],"tail":", substituted “eligible individual” for “eligible veteran” and “the individual” for “the veteran”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s764/b/1/A/ii"},"text":"Pub. L. 116–283, § 764(b)(1)(A)(ii)","children":[],"tail":", substituted “eligible individuals” for “eligible veterans”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s764/b/1/B"},"text":"Pub. L. 116–283, § 764(b)(1)(B)","children":[],"tail":", substituted “an individual” for “a veteran” and “eligible individual” for “eligible veteran”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s764/b/1/C/i"},"text":"Pub. L. 116–283, § 764(b)(1)(C)(i)","children":[],"tail":", substituted “The term ‘eligible individual’ means a veteran or a member of the reserve components of the Armed Forces” for “The term ‘eligible veteran’ means a veteran” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s764/b/1/C/ii"},"text":"Pub. L. 116–283, § 764(b)(1)(C)(ii)","children":[],"tail":", substituted “eligible individual” for “eligible veteran”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
