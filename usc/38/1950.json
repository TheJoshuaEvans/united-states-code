{"tag":"section","attrib":{"id":"idc31fd011-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1950"},"text":null,"children":[{"tag":"num","attrib":{"value":"1950"},"text":"§ 1950.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment to estates","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If no beneficiary of insurance is designated by the insured, either while alive or by last will, or if the designated beneficiary does not survive the insured, then there shall be paid to the estate of the insured the present value of the remaining unpaid monthly installments. If the designated beneficiary survives the insured and dies before receiving all of the installments of insurance payable and applicable, then there shall be paid to the estate of such beneficiary the present value of the remaining unpaid monthly installments. No payments shall be made to any estate which under the laws of the residence of the insured or the beneficiary, as the case may be, would escheat, but same shall escheat to the United States and be credited to the United States Government Life Insurance Fund.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc31fd012-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1160"},"text":"72 Stat. 1160","children":[],"tail":", § 750; "},{"tag":"ref","attrib":{"href":"/us/pl/99/576/tVII/s701/31"},"text":"Pub. L. 99–576, title VII, § 701(31)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3293"},"text":"100 Stat. 3293","children":[],"tail":"; renumbered § 1950, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc31fd013-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc31fd014-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc31fd015-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s750"},"text":"section 750 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576"},"text":"Pub. L. 99–576","children":[],"tail":" substituted “while alive or by last will” for “in his lifetime or by his last will and testament”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
