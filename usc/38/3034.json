,"attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4671"},"text":"108 Stat. 4671","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/446/tVI/s601/d"},"text":"“The amendments made by this section [amending this section, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3241"},"text":"section 3241 of this title","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s16136"},"text":"section 16136 of Title 10","children":[],"tail":", Armed Forces] shall take effect as of "},{"tag":"date","attrib":{"date":"1994-10-01"},"text":"October 1, 1994","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc356bf39-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237/s422/a/1"},"text":"section 422(a)(1) of Pub. L. 101–237","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1990-09-30"},"text":"Sept. 30, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/s422/d"},"text":"section 422(d) of Pub. L. 101–237","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s16131"},"text":"section 16131 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc356bf3a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/689/tI/s106/d"},"text":"Pub. L. 100–689, title I, § 106(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4167"},"text":"102 Stat. 4167","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/689/tI/s106/d"},"text":"“The amendments made by this section [amending this section and sections 1641 and 1733 [now 3241 and 3533] of this title] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1989-08-15"},"text":"August 15, 1989","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"idc356bf3b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/586"},"text":"Pub. L. 102–586","children":[],"tail":" not applicable to any person receiving educational assistance for pursuit of an independent study program in which the person was enrolled on "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", for as long as such person is continuously thereafter so enrolled and meets requirements of eligibility for such assistance, see "},{"tag":"ref","attrib":{"href":"/us/pl/102/568/s313/b"},"text":"section 313(b) of Pub. L. 102–568","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s16136"},"text":"section 16136 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc356bf3c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Ratification","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/366/tII/s206/b"},"text":"Pub. L. 101–366, title II, § 206(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-15"},"text":"Aug. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/442"},"text":"104 Stat. 442","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/366/tII/s206/b"},"text":"“Any use by the Department of Veterans Affairs, during the period beginning on ","children":[{"tag":"date","attrib":{"date":"1990-07-02"},"text":"July 2, 1990","children":[],"tail":", and ending on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1990-08-15"},"text":"Aug. 15, 1990","children":[],"tail":"], of any category of information provided by the Department of Defense or the Department of Transportation for making determinations described in section 413(b) of the Veterans’ Benefits Amendments of 1989 ("},{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Public Law 101–237","children":[],"tail":") [set out below] is hereby ratified.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc356bf3d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Continued Use of Categories of Information Used Prior to ","children":[{"tag":"date","attrib":{"date":"1989-12-18"},"text":"December 18, 1989","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIV/s413/b"},"text":"Pub. L. 101–237, title IV, § 413(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2085"},"text":"103 Stat. 2085","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/237/tIV/s413/b"},"text":"“Through ","children":[{"tag":"date","attrib":{"date":"1990-07-01"},"text":"July 1, 1990","children":[],"tail":", no provision of law shall preclude the Department of Veterans Affairs, in making determinations of the active-duty or Selected Reserve status, or the character of service, of individuals receiving benefits under chapter 30 or 32 of title 38, United States Code, or chapter 106 of title 10, United States Code, from continuing to use any category of information provided by the Department of Defense or Department of Transportation that the Department of Veterans Affairs was using prior to the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":"], if the Secretary of Veterans Affairs determines that the information has proven to be sufficiently reliable in making such determinations.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc356bf3e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Evaluation of Providing Assistance for Flight Training","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIV/s422/c"},"text":"Pub. L. 101–237, title IV, § 422(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2090"},"text":"103 Stat. 2090","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/237/tIV/s422/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Veterans Affairs shall conduct an evaluation of paying educational assistance for flight training under chapter 30 of title 38, United States Code, and chapter 106 of title 10, United States Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The evaluation required by subparagraph (A) shall be designed to determine the effectiveness of the provision of educational assistance referred to in such subparagraph in preparing the recipients of such assistance for recognized vocational objectives in the field of aviation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"1994-01-31"},"text":"January 31, 1994","children":[],"tail":", the Secretary shall submit to the Committees on Veterans’ Affairs of the Senate and the House of Representatives a report on the evaluation required by paragraph (1). Such report shall include—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" information, separately as to payments made under chapter 30 of title 38, United States Code, and payments made under chapter 106 of title 10, United States Code, regarding—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of recipients paid educational assistance allowances for flight training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of such assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount paid by the recipients for such training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"“(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vocational objectives of the recipients; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"“(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the training (I) assists the recipients in achieving employment in the field of aviation, or (II) was used only or primarily for recreational or avocational purposes; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations for legislation that the Secretary considers appropriate to include in the report.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
