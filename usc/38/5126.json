{"tag":"section","attrib":{"id":"idc3d51600-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5126"},"text":null,"children":[{"tag":"num","attrib":{"value":"5126"},"text":"§ 5126.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefits not to be denied based on lack of mailing address","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Benefits under laws administered by the Secretary may not be denied a claimant on the basis that the claimant does not have a mailing address.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc3d51601-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/475/s3/b"},"text":"Pub. L. 106–475, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2098"},"text":"114 Stat. 2098","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
