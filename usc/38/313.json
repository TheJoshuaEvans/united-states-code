{"tag":"section","attrib":{"id":"idc27b535b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s313"},"text":null,"children":[{"tag":"num","attrib":{"value":"313"},"text":"§ 313.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc27b535c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s313/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds appropriated to the Department may remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc27b535d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s313/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Funds appropriated to the Department may not be used for a settlement of more than $1,000,000 on a construction contract unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc27b535e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s313/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the settlement is audited by an entity outside the Department for reasonableness and appropriateness of expenditures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc27b535f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s313/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the settlement is provided for specifically in an appropriation law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc27b5360-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s2/a"},"text":"Pub. L. 102–83, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/383"},"text":"105 Stat. 383","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc27b5361-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc27b5362-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc27b5363-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior section 313 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1113"},"text":"section 1113 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s203"},"text":"section 203 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s2/a"},"text":"Pub. L. 102–83, § 2(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc27b5364-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc27b5365-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Recurring Expenses Transformational Fund","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dJ/tII/s243"},"text":"Pub. L. 114–113, div. J, title II, § 243","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2701"},"text":"129 Stat. 2701","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/113/dJ/tII/s243"},"text":"“There is hereby established in the Treasury of the United States a fund to be known as the ‘Recurring Expenses Transformational Fund’ (the Fund): ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That unobligated balances of expired discretionary funds appropriated in this or any succeeding fiscal year from the General Fund of the Treasury to the Department of Veterans Affairs by this or any other Act may be transferred (at the end of the fifth fiscal year after the last fiscal year for which such funds are available for the purposes for which appropriated) into the Fund: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That amounts deposited in the Fund shall be available until expended, and in addition to such other funds as may be available for such purposes, for facilities infrastructure improvements, including nonrecurring maintenance, at existing hospitals and clinics of the Veterans Health Administration, and information technology systems improvements and sustainment, subject to approval by the Office of Management and Budget: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That prior to obligation of any amounts in the Fund, the Secretary of Veterans Affairs shall request from the Committees on Appropriations of both Houses of Congress the authority to make such obligation and such Committees issue an approval, or absent a response, a period of 30 days has elapsed.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
