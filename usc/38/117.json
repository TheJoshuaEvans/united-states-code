{"tag":"section","attrib":{"id":"idc274274e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s117"},"text":null,"children":[{"tag":"num","attrib":{"value":"117"},"text":"§ 117.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advance appropriations for certain accounts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc274274f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s117/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each fiscal year, new budget authority provided in an appropriations Act for the covered accounts of the Department shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2742750-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s117/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be made available for that fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2742751-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s117/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include, for each such account, advance new budget authority that first becomes available for the first fiscal year after the budget year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2742752-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s117/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Estimates Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall include in documents submitted to Congress in support of the President’s budget submitted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":", United States Code, detailed estimates of the funds necessary for the covered accounts of the Department for the fiscal year following the fiscal year for which the budget is submitted."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2742753-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s117/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Accounts of the Department","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “covered accounts of the Department” means the following accounts of the Department of Veterans Affairs account:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2742754-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s117/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Veterans Benefits Administration, Compensation and Pensions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2742755-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s117/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Veterans Benefits Administration, Readjustment Benefits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2742756-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s117/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Veterans Benefits Administration, Veterans Insurance and Indemnities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2742757-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s117/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Veterans Health Administration, Medical Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2742758-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s117/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Veterans Health Administration, Medical Support and Compliance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2742759-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s117/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Veterans Health Administration, Medical Facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc274275a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s117/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Veterans Health Administration, Medical Community Care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc274275b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s117/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than July 31 of each year, the Secretary shall submit to Congress an annual report on the sufficiency of the Department’s resources for the next fiscal year beginning after the date of the submittal of the report for the provision of medical care. Such report shall also include estimates of the workload and demand data for that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc274275c-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/81/s3/a"},"text":"Pub. L. 111–81, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-22"},"text":"Oct. 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2137"},"text":"123 Stat. 2137","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dI/tII/s244/a"},"text":"Pub. L. 113–235, div. I, title II, § 244(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2568"},"text":"128 Stat. 2568","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/315/tVI/s601/a"},"text":"Pub. L. 114–315, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1569"},"text":"130 Stat. 1569","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc274275d-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc274275e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc274275f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (c)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/315"},"text":"Pub. L. 114–315","children":[],"tail":" added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s244/a/4"},"text":"Pub. L. 113–235, § 244(a)(4)","children":[],"tail":", substituted “certain accounts” for “certain medical care accounts” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s244/a/2"},"text":"Pub. L. 113–235, § 244(a)(2)","children":[],"tail":", struck out “beginning with fiscal year 2011,” after “each fiscal year,” in introductory provisions and “discretionary” before “new budget authority” in introductory provisions and par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s244/a/1"},"text":"Pub. L. 113–235, § 244(a)(1)","children":[],"tail":", substituted “covered accounts of the Department” for “medical care accounts of the Department” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s244/a/1"},"text":"Pub. L. 113–235, § 244(a)(1)","children":[],"tail":", substituted “covered accounts of the Department” for “medical care accounts of the Department”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s244/a/1"},"text":"Pub. L. 113–235, § 244(a)(1)","children":[],"tail":", (3)(A), (G), in heading, substituted “Covered Accounts of the Department” for “Medical Care Accounts” and, in introductory provisions, substituted “covered accounts of the Department” for “medical care accounts of the Department” and “accounts of the Department of Veterans Affairs account” for “medical care accounts of the Veterans Health Administration, Department of Veterans Affairs account”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s244/a/3/B"},"text":"Pub. L. 113–235, § 244(a)(3)(B)","children":[],"tail":"–(F), inserted “Veterans Health Administration,” after enumerators for pars. (1) to (3), redesignated pars. (1) to (3) as (4) to (6), respectively, and added pars. (1) to (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc2742760-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc2742761-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/315"},"text":"Pub. L. 114–315","children":[],"tail":" applicable to fiscal years beginning on and after "},{"tag":"date","attrib":{"date":"2017-10-01"},"text":"Oct. 1, 2017","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/315/s601/c"},"text":"section 601(c) of Pub. L. 114–315","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of Title 31","children":[],"tail":", Money and Finance."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc2742762-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/dI/tII/s244/b"},"text":"Pub. L. 113–235, div. I, title II, § 244(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2569"},"text":"128 Stat. 2569","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/235/dI/tII/s244/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s117"},"text":"Section 117 of title 38","children":[],"tail":", United States Code, shall apply as follows:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to an account described in paragraph (4), (5), or (6) of subsection (c) of such section, as redesignated by subsection (a) of this section, for each fiscal year beginning with fiscal year 2011.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to an account described in paragraph (1), (2), or (3) of such subsection (c), as added by subsection (a) of this section, for each fiscal year beginning with 2017.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc2742763-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Comptroller General Review of the Accuracy of VA Medical Care Budget Submission in Relation to Baseline Health Care Model Projection","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/81/s4"},"text":"Pub. L. 111–81, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-22"},"text":"Oct. 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2138"},"text":"123 Stat. 2138","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/81/s4"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review of Accuracy of Medical Care Budget Submission","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Comptroller General shall conduct a review of each budget of the President for a fiscal year that is submitted to Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":" in order to assess whether or not the relevant components of the amounts requested in such budget for such fiscal year for the medical care accounts of the Department of Veterans Affairs specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s117/c"},"text":"section 117(c) of title 38","children":[],"tail":", United States Code, as added by section 3, are consistent with estimates of the resources required by the Department for the provision of medical care and services in such fiscal year, as forecast using the Enrollee Health Care Projection Model, or other methodologies used by the Department."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 120 days after the date of each year in 2011, 2012, and 2013, on which the President submits the budget request for the next fiscal year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":", United States Code, the Comptroller General shall submit to the Committees on Veterans’ Affairs, Appropriations, and the Budget of the Senate and the Committees on Veterans’ Affairs, Appropriations, and the Budget of the House of Representatives and to the Secretary a report on the review conducted under subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under this paragraph shall include, for the fiscal year beginning in the year in which such report is submitted, the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of the review conducted under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The basis for such assessment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such additional information as the Comptroller General determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability to the public","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each report submitted under this subsection shall also be made available to the public.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
