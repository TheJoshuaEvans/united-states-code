{"tag":"section","attrib":{"id":"idc3e5dfa6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6301"},"text":null,"children":[{"tag":"num","attrib":{"value":"6301"},"text":"§ 6301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose; definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3e5dfa7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress declares that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3e5dfa8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6301/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the outreach services program authorized by this subchapter is for the purpose of ensuring that all veterans (especially those who have been recently discharged or released from active military, naval, air, or space service, or from a reserve component, and those who are eligible for readjustment or other benefits and services under laws administered by the Department) are provided timely and appropriate assistance to aid and encourage them in applying for and obtaining such benefits and services in order that they may achieve a rapid social and economic readjustment to civilian life and obtain a higher standard of living for themselves and their dependents; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e5dfa9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6301/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the outreach services program authorized by this subchapter is for the purpose of charging the Department with the affirmative duty of seeking out eligible veterans and eligible dependents and providing them with such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3e5dfaa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3e5dfab-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6301/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “outreach” means the act or process of reaching out in a systematic manner to proactively provide information, services, and benefits counseling to veterans, and to the spouses, children, and parents of veterans who may be eligible to receive benefits under the laws administered by the Secretary, to ensure that such individuals are fully informed about, and receive assistance in applying for, such benefits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e5dfac-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6301/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “other governmental programs” includes all programs under State or local laws as well as all programs under Federal law other than those authorized by this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e5dfad-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6301/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “eligible dependent” means a spouse, surviving spouse, child, or dependent parent of a person who served in the active military, naval, air, or space service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3e5dfae-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/233/tIV/s402/a"},"text":"Pub. L. 109–233, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-06-15"},"text":"June 15, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/407"},"text":"120 Stat. 407","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tXVII/s1710"},"text":"Pub. L. 110–181, div. A, title XVII, § 1710","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/494"},"text":"122 Stat. 494","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s926/a/58"},"text":"Pub. L. 116–283, div. A, title IX, § 926(a)(58)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3830"},"text":"134 Stat. 3830","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/205/s2/b/2"},"text":"Pub. L. 117–205, § 2(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-10-17"},"text":"Oct. 17, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2233"},"text":"136 Stat. 2233","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3e5dfaf-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3e5dfb0-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc3e5dfb1-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7721"},"text":"section 7721 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/109/233"},"text":"Pub. L. 109–233","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3e5dfb2-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/205"},"text":"Pub. L. 117–205","children":[],"tail":" substituted “this subchapter” for “this chapter” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsecs. (a)(1), (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" “air, or space service” for “or air service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s1710/a"},"text":"Pub. L. 110–181, § 1710(a)","children":[],"tail":", inserted “, or from a reserve component,” after ”active military, naval, or air service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s1710/b"},"text":"Pub. L. 110–181, § 1710(b)","children":[],"tail":", added par. (1) and redesignated former pars. (1) and (2) as (2) and (3), respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
