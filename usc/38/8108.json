{"tag":"section","attrib":{"id":"idc41f184e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8108"},"text":null,"children":[{"tag":"num","attrib":{"value":"8108"},"text":"§ 8108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contributions to local authorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may make contributions to local authorities toward, or for, the construction of traffic controls, road improvements, or other devices adjacent to a medical facility if considered necessary for safe ingress or egress.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc41f184f-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/22/tIII/s301/a"},"text":"Pub. L. 96–22, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-06-13"},"text":"June 13, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/58"},"text":"93 Stat. 58","children":[],"tail":", § 5008; renumbered § 8108, "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404"},"text":"105 Stat. 404","children":[],"tail":", 405.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc41f1850-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc41f1851-