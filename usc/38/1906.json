{"tag":"section","attrib":{"id":"idc3165a7f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1906"},"text":null,"children":[{"tag":"num","attrib":{"value":"1906"},"text":"§ 1906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Provisions for cash, loan, paid-up, and extended values, dividends from gains and savings, refund of unearned premiums, and such other provisions as may be found to be reasonable and practicable may be provided for in the policy of insurance from time to time by regulations promulgated by the Secretary.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc3165a80-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1149"},"text":"72 Stat. 1149","children":[],"tail":", § 706; renumbered § 1906 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":", §§ 4(b)(1), (2)(E), 5(a), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404-406"},"text":"105 Stat. 404–406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3165a81-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3165a82-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3165a83-47c4-11f1-bf59-9680b1269b8