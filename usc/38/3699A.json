{"tag":"section","attrib":{"id":"idc39e4f7f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699A"},"text":null,"children":[{"tag":"num","attrib":{"value":"3699A"},"text":"§ 3699A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of certain information to educational institutions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc39e4f80-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For each veteran or other individual pursuing a course of education that has been approved under this chapter using educational assistance to which the veteran or other individual is entitled under chapter 30, 32, 33, or 35 of this title, the Secretary shall make available to the educational institution offering the course information about the amount of such educational assistance to which the veteran or other individual is entitled. Such information shall be provided to such educational institution through a secure information technology system accessible by the educational institution and shall be regularly updated to reflect any amounts used by the veteran or other individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc39e4f81-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Election","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A veteran or other individual pursuing a course of education described in subsection (a) may elect not to provide the information described in such subsection to an educational institution in a manner prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc39e4f82-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/48/tIII/s308/a"},"text":"Pub. L. 115–48, title III, § 308(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-16"},"text":"Aug. 16, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/994"},"text":"131 Stat. 994","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc39e4f83-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc39e4f84-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc39e4f85-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/48/tIII/s308/c"},"text":"Pub. L. 115–48, title III, § 308(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-16"},"text":"Aug. 16, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/994"},"text":"131 Stat. 994","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/48/tIII/s308/c"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3699A"},"text":"Section 3699A of title 38","children":[],"tail":", United States Code, as added by this section, shall take effect on "},{"tag":"date","attrib":{"date":"2018-08-01"},"text":"August 1, 2018","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
