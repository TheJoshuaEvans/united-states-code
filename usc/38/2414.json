{"tag":"section","attrib":{"id":"idc3486754-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2414"},"text":null,"children":[{"tag":"num","attrib":{"value":"2414"},"text":"§ 2414.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Communication between Department of Veterans Affairs and medical examiners and funeral directors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3486755-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2414/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required Information","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to each deceased veteran described in subsection (b) who is transported to a national cemetery for burial, the Secretary shall ensure that the local medical examiner, funeral director, county service group, or other entity responsible for the body of the deceased veteran before such transportation submits to the Secretary the following information:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3486756-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2414/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether the deceased veteran was cremated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3486757-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2414/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The steps taken to ensure that the deceased veteran has no next of kin.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3486758-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2414/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deceased Veteran Described","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A deceased veteran described in this subsection is a deceased veteran—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3486759-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2414/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to whom the Secretary determines that there is no next of kin or other person claiming the body of the deceased veteran; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc348675a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2414/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who does not have sufficient resources for the furnishing of a casket or urn for the burial of the deceased veteran in a national cemetery, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc348675b-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/260/tI/s103/a"},"text":"Pub. L. 112–260, title I, § 103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-10"},"text":"Jan. 10, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2419"},"text":"126 Stat. 2419","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc348675c-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc348675d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc348675e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/260/tI/s103/c"},"text":"Pub. L. 112–260, title I, § 103(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-10"},"text":"Jan. 10, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2420"},"text":"126 Stat. 2420","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/260/tI/s103/c"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2414"},"text":"Section 2414 of title 38","children":[],"tail":", United States Code, as added by subsection (a), shall take effect on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2013-01-10"},"text":"Jan. 10, 2013","children":[],"tail":"] and shall apply with respect to deaths occurring on or after the date that is 180 days after the date of the enactment of this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
