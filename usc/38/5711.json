{"tag":"section","attrib":{"id":"idc3e0fdf3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5711"},"text":null,"children":[{"tag":"num","attrib":{"value":"5711"},"text":"§ 5711.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to issue subpoenas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3e0fdf4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5711/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purposes of the laws administered by the Secretary, the Secretary, and those employees to whom the Secretary may delegate such authority, to the extent of the authority so delegated, shall have the power to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3e0fdf5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5711/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue subpoenas for and compel the attendance of witnesses within a radius of 100 miles from the place of hearing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e0fdf6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5711/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the production of books, papers, documents, and other evidence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e0fdf7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5711/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take affidavits and administer oaths and affirmations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e0fdf8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5711/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aid claimants in the preparation and presentation of claims; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3e0fdf9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5711/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make investigations and examine witnesses upon any matter within the jurisdiction of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3e0fdfa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5711/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person required by such subpoena to attend as a witness shall be allowed and paid the same fees and mileage as are paid witnesses in the district courts of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3e0fdfb-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1237"},"text":"72 Stat. 1237","children":[],"tail":", § 3311; renumbered § 5711, "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/54/s14/d/5/A"},"text":"Pub. L. 102–54, § 14(d)(5)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-06-13"},"text":"June 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/286"},"text":"105 Stat. 286","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3e0fdfc-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3e0fdfd-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3e0fdfe-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3311"},"text":"section 3311 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/54"},"text":"Pub. L. 102–54","children":[],"tail":" amended section as in effect immediately before the enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" by substituting “subpoenas” for “subpenas” in section catchline and amending text generally. Prior to amendment, text read as follows: “For the purposes of the laws administered by the Veterans’ Administration, the Administrator, and those employees to whom the Administrator may delegate such authority, to the extent of the authority so delegated, shall have the power to issue subpenas for and compel the attendance of witnesses within a radius of one hundred miles from the place of hearing, to require the production of books, papers, documents, and other evidence, to take affidavits, to administer oaths and affirmations, to aid claimants in the preparation and presentation of claims, and to make investigations and examine witnesses upon any matter within the jurisdiction of the Veterans’ Administration. Any person required by such subpena to attend as a witness shall be allowed and paid the same fees and mileage as are paid witnesses in the district courts of the United States.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
