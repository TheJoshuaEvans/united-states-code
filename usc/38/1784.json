{"tag":"section","attrib":{"id":"idc3119fbd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1784"},"text":null,"children":[{"tag":"num","attrib":{"value":"1784"},"text":"§ 1784.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Humanitarian care","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may furnish hospital care or medical services as a humanitarian service in emergency cases, but the Secretary shall charge for such care and services at rates prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc3119fbe-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/135/tII/s208/b"},"text":"Pub. L. 107–135, title II, § 208(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-23"},"text":"Jan. 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2463"},"text":"115 Stat. 2463","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3119fbf-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3119fc0-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc3119fc1-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior section 1784 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3684"},"text":"section 3684 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
