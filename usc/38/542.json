(D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(2)(A)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163"},"text":"Pub. L. 111–163","children":[],"tail":" added cl. (iv)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/387"},"text":"Pub. L. 110–387","children":[],"tail":" struck out “through 2008” after “year” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461/s1006/b"},"text":"Pub. L. 109–461, § 1006(b)","children":[],"tail":", provided that as of the enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/109/461"},"text":"Pub. L. 109–461","children":[],"tail":", the amendments made by "},{"tag":"ref","attrib":{"href":"/us/pl/109/444"},"text":"Pub. L. 109–444","children":[],"tail":" were deemed for all purposes not to have taken effect and that "},{"tag":"ref","attrib":{"href":"/us/pl/109/444"},"text":"Pub. L. 109–444","children":[],"tail":" ceased to be in effect. See Amendment notes below and "},{"tag":"ref","attrib":{"href":"/us/pl/109/461/s1006/b"},"text":"section 1006(b) of Pub. L. 109–461","children":[],"tail":", set out as a Coordination of Provisions With "},{"tag":"ref","attrib":{"href":"/us/pl/109/444"},"text":"Pub. L. 109–444","children":[],"tail":" note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461/s208/b"},"text":"Pub. L. 109–461, § 208(b)","children":[],"tail":", substituted “2008” for “2004” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/444"},"text":"Pub. L. 109–444","children":[],"tail":", which substituted “2008” for “2004” in introductory provisions, was terminated by "},{"tag":"ref","attrib":{"href":"/us/pl/109/461/s1006/b"},"text":"Pub. L. 109–461, § 1006(b)","children":[],"tail":". See Amendment notes above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/419"},"text":"Pub. L. 106–419","children":[],"tail":" inserted “through 2004” after “each even-numbered year” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/275"},"text":"Pub. L. 104–275","children":[],"tail":" inserted “, including the Center for Women Veterans” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(2)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/405"},"text":"Pub. L. 102–405","children":[],"tail":" substituted “Under Secretary for Health” for “Chief Medical Director” and “Under Secretary for Benefits” for “Chief Benefits Director”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc289ab66-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idc289ab67-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to Assistant Secretary of Labor for Veterans’ Employment in any law in force on ","children":[{"tag":"date","attrib":{"date":"1986-11-06"},"text":"Nov. 6, 1986","children":[],"tail":", deemed to be a reference to Assistant Secretary of Labor for Veterans’ Employment and Training, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/619/s2/b/3"},"text":"section 2(b)(3) of Pub. L. 99–619","children":[],"tail":", set out as a References in Other Laws note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s553"},"text":"section 553 of Title 29","children":[],"tail":", Labor."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc289ab68-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163/tII/s204/c"},"text":"Pub. L. 111–163, title II, § 204(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-05-05"},"text":"May 5, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1144"},"text":"124 Stat. 1144","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/163/tII/s204/c"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s544"},"text":"section 544 of this title","children":[],"tail":"] shall apply to appointments made on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2010-05-05"},"text":"May 5, 2010","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc289ab69-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Advisory Committees","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Advisory committees established after ","children":[{"tag":"date","attrib":{"date":"1973-01-05"},"text":"Jan. 5, 1973","children":[],"tail":", to terminate not later than the expiration of the 2-year period beginning on the date of their establishment, unless, in the case of a committee established by the President or an officer of the Federal Government, such committee is renewed by appropriate action prior to the expiration of such 2-year period, or in the case of a committee established by the Congress, its duration is otherwise provided by law. See "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"section 1013 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
