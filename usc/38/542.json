{"tag":"section","attrib":{"id":"idc289ab48-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s542"},"text":null,"children":[{"tag":"num","attrib":{"value":"542"},"text":"§ 542.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Committee on Women Veterans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc289ab49-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s542/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc289ab4a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s542/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall establish an advisory committee to be known as the Advisory Committee on Women Veterans (hereinafter in this section referred to as “the Committee”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc289ab4b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s542/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc289ab4c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s542/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Committee shall consist of members appointed by the Secretary from the general public, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc289ab4d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s542/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of women veterans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc289ab4e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s542/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals who are recognized authorities in fields pertinent to the needs of women veterans, including the gender-specific health-care needs of women;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc289ab4f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s542/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of both female and male veterans with service-connected disabilities, including at least one female veteran with a service-connected disability and at least one male veteran with a service-connected disability; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc289ab50-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s542/a/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" women veterans who are recently separated from service in the Armed Forces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc289ab51-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s542/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Committee shall include, as ex officio members—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc289ab52-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s542/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Labor (or a representative of the Secretary of Labor designated by the Secretary after consultation with the Assistant Secretary of Labor for Veterans’ Employment);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc289ab53-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s542/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Defense (or a representative of the Secretary of Defense designated by the Secretary of Defense after consultation with the Defense Advisory Committee on Women in the Services); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc289ab54-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s542/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Under Secretary for Health and the Under Secretary for Benefits, or their designees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc289ab55-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s542/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may invite representatives of other departments and agencies of the United States to participate in the meetings and other activities of the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc289ab56-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s542/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall determine the number, terms of service, and pay and allowances of members of the Committee appointed by the Secretary, except that a term of service of any such member may not exceed three years. The Secretary may reappoint any such member for additional terms of service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc289ab57-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s542/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall, on a regular basis, consult with and seek the advice of the Committee with respect to the administration of benefits by the Department for women veterans, reports and studies pertaining to women veterans and the needs of women veterans with respect to compensation, health care, rehabilitation, outreach, and other benefits and programs administered by the Department, including the Center for Women Veterans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc289ab58-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s542/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc289ab59-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s542/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than July 1 of each year, the Committee shall submit to the Secretary a report on the programs and activities of the Department that pertain to women veterans. Each such report shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc289ab5a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s542/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the needs of women veterans with respect to compensation, health care, rehabilitation, outreach, and other benefits and programs administered by the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc289ab5b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s542/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of the programs and activities of the Department designed to meet such needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc289ab5c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s542/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the effects of intimate partner violence on women veterans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc289ab5d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s542/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such recommendations (including recommendations for administrative and legislative action) as the Committee considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc289ab5e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s542/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall, within 60 days after receiving each report under paragraph (1), submit to the Congress a copy of the report, together with any comments concerning the report that the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc289ab5f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s542/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee may also submit to the Secretary such other reports and recommendations as the Committee considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc289ab60-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s542/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall submit with each annual report submitted to the Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s529"},"text":"section 529 of this title","children":[],"tail":" a summary of all reports and recommendations of the Committee submitted to the Secretary since the previous annual report of the Secretary submitted pursuant to such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc289ab61-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s2/a"},"text":"Pub. L. 102–83, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/393"},"text":"105 Stat. 393","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/405/tIII/s302/c/1"},"text":"Pub. L. 102–405, title III, § 302(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-09"},"text":"Oct. 9, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1984"},"text":"106 Stat. 1984","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/275/tV/s501/e/1"},"text":"Pub. L. 104–275, title V, § 501(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3341"},"text":"110 Stat. 3341","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/419/tIV/s403/c/3"},"text":"Pub. L. 106–419, title IV, § 403(c)(3)","children":[],"tail":", "},{"tag":"date","a