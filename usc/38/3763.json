{"tag":"section","attrib":{"id":"idc3b3ab92-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3763"},"text":null,"children":[{"tag":"num","attrib":{"value":"3763"},"text":"§ 3763.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native American Veteran Housing Loan Program Account","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3b3ab93-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3763/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is hereby established in the Treasury of the United States an account known as the “Native American Veteran Housing Loan Program Account” (hereinafter in this subchapter referred to as the “Account”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3b3ab94-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3763/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Account shall be available to the Secretary to carry out all operations relating to the making of direct housing loans to Native American veterans under this subchapter, including any administrative expenses relating to the making of such loans. Amounts in the Account shall be available without fiscal year limitation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3b3ab95-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3763/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Of amounts available in the Account, the Secretary may use for loans made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3762A"},"text":"section 3762A of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3b3ab96-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3763/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in fiscal year 2025, not more than $5,000,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3b3ab97-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3763/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any fiscal year after fiscal year 2025, an amount determined necessary by the Secretary to meet the demand for such loans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3b3ab98-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/547/s8/a"},"text":"Pub. L. 102–547, § 8(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3639"},"text":"106 Stat. 3639","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/368/tVI/s602/e/3/B"},"text":"Pub. L. 105–368, title VI, § 602(e)(3)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3347"},"text":"112 Stat. 3347","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/14/s8/a/16"},"text":"Pub. L. 107–14, § 8(a)(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-06-05"},"text":"June 5, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/35"},"text":"115 Stat. 35","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/210/tII/s232/c"},"text":"Pub. L. 118–210, title II, § 232(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-02"},"text":"Jan. 2, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2788"},"text":"138 Stat. 2788","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3b3ab99-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3b3ab9a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3b3ab9b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/210"},"text":"Pub. L. 118–210","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/14"},"text":"Pub. L. 107–14","children":[],"tail":" substituted “hereinafter” for “hereafter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368"},"text":"Pub. L. 105–368","children":[],"tail":" substituted “Native American Veteran Housing Loan Program Account” for “Housing loan program account” in section catchline."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3b3ab9c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3b3ab9d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},