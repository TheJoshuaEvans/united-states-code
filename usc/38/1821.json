{"tag":"section","attrib":{"id":"idc313e9d4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1821"},"text":null,"children":[{"tag":"num","attrib":{"value":"1821"},"text":"§ 1821.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefits for children of certain Korea service veterans born with spina bifida","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc313e9d5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1821/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Benefits Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may provide to any child of a veteran of covered service in Korea who is suffering from spina bifida the health care, vocational training and rehabilitation, and monetary allowance required to be paid to a child of a Vietnam veteran who is suffering from spina bifida under subchapter I of this chapter as if such child of a veteran of covered service in Korea were a child of a Vietnam veteran who is suffering from spina bifida under such subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc313e9d6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1821/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Spina Bifida Conditions Covered","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section applies with respect to all forms and manifestations of spina bifida, except spina bifida occulta.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc313e9d7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1821/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Veteran of Covered Service in Korea","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, a veteran of covered service in Korea is any individual, without regard to the characterization of that individual’s service, who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc313e9d8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1821/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" served in the active military, naval, or air service in or near the Korean demilitarized zone (DMZ), as determined by the Secretary in consultation with the Secretary of Defense, during the period beginning on ","children":[{"tag":"date","attrib":{"date":"1967-09-01"},"text":"September 1, 1967","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"1971-08-31"},"text":"August 31, 1971","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc313e9d9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1821/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is determined by the Secretary, in consultation with the Secretary of Defense, to have been exposed to a herbicide agent during such service in or near the Korean demilitarized zone.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc313e9da-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1821/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Herbicide Agent","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, the term “herbicide agent” means a chemical in a herbicide used in support of United States and allied military operations in or near the Korean demilitarized zone, as determined by the Secretary in consultation with the Secretary of Defense, during the period beginning on ","children":[{"tag":"date","attrib":{"date":"1967-09-01"},"text":"September 1, 1967","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"1971-08-31"},"text":"August 31, 1971","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc313e9db-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/183/tI/s102/a/2"},"text":"Pub. L. 108–183, title I, § 102(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-16"},"text":"Dec. 16, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2653"},"text":"117 Stat. 2653","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc313e9dc-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc313e9dd-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc313e9de-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1821 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1831"},"text":"section 1831 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 1821 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3721"},"text":"section 3721 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
