{"tag":"section","attrib":{"id":"idc26cfb30-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s104"},"text":null,"children":[{"tag":"num","attrib":{"value":"104"},"text":"§ 104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of educational institutions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc26cfb31-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of determining whether or not benefits are payable under this title (except chapter 35 of this title) for a child over the age of eighteen years and under the age of twenty-three years who is attending a school, college, academy, seminary, technical institute, university, or other educational institution, the Secretary may approve or disapprove such educational institutions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc26cfb32-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not approve an educational institution under this section unless such institution has agreed to report to the Secretary the termination of attendance of any child. If any educational institution fails to report any such termination promptly, the approval of the Secretary shall be withdrawn.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc26cfb33-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1110"},"text":"72 Stat. 1110","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/24/s1/c"},"text":"Pub. L. 91–24, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-06-11"},"text":"June 11, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/33"},"text":"83 Stat. 33","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/576/tVII/s701/3"},"text":"Pub. L. 99–576, title VII, § 701(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3290"},"text":"100 Stat. 3290","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404"},"text":"105 Stat. 404","children":[],"tail":", 405.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc26cfb34-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc26cfb35-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc26cfb36-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" substituted “Secretary” for “Administrator” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576"},"text":"Pub. L. 99–576","children":[],"tail":" substituted “report to the Administrator” for “report to him”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/24"},"text":"Pub. L. 91–24","children":[],"tail":" substituted “the age of twenty-three years” for “the age of twenty-one years”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
