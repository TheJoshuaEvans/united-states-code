{"tag":"section","attrib":{"id":"idc417ebff-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7691"},"text":null,"children":[{"tag":"num","attrib":{"value":"7691"},"text":"§ 7691.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As part of the Educational Assistance Program, the Secretary may carry out a student loan repayment program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5379"},"text":"section 5379 of title 5","children":[],"tail":". The program shall be known as the Department of Veterans Affairs Specialty Education Loan Repayment Program (in this chapter referred to as the “Specialty Education Loan Repayment Program”)."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc417ec00-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/182/tIII/s303/a"},"text":"Pub. L. 115–182, title III, § 303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-06"},"text":"June 6, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1464"},"text":"132 Stat. 1464","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc417ec01-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc417ec02-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc417ec03-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Offer Deadline","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/182/tIII/s303/e"},"text":"Pub. L. 115–182, title III, § 303(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-06"},"text":"June 6, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1467"},"text":"132 Stat. 1467","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/115/251/tII/s211/b/6/B"},"text":"Pub. L. 115–251, title II, § 211(b)(6)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-29"},"text":"Sept. 29, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3177"},"text":"132 Stat. 3177","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/251/tII/s211/b/6/B"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In the case of an applicant who applies before receiving a residency match and whom the Secretary of Veterans Affairs selects for participation in the Specialty Education Loan Repayment Program under subchapter VIII of chapter 76 of title 38, United States Code, as enacted by subsection (a), the Secretary shall offer participation to the applicant not later than 28 days after—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant matches with a residency in a medical specialty described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7692"},"text":"section 7692 of title 38","children":[],"tail":", United States Code, as enacted by subsection (a); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such match is published.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc417ec04-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Publicity","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/182/tIII/s303/f"},"text":"Pub. L. 115–182, title III, § 303(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-06"},"text":"June 6, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1467"},"text":"132 Stat. 1467","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/182/tIII/s303/f"},"text":"“The Secretary of Veterans Affairs shall take such steps as the Secretary determines are appropriate to publicize the Specialty Education Loan Repayment Program established under subchapter VIII of chapter 76 of title 38, United States Code, as enacted by subsection (a).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
