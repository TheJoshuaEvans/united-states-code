{"tag":"section","attrib":{"id":"idc3d787c1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5305"},"text":null,"children":[{"tag":"num","attrib":{"value":"5305"},"text":"§ 5305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of retired pay","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1414"},"text":"section 1414 of title 10","children":[],"tail":", any person who is receiving pay pursuant to any provision of law providing retired or retirement pay to persons in the Armed Forces, or as a commissioned officer of the National Oceanic and Atmospheric Administration or of the Public Health Service, and who would be eligible to receive pension or compensation under the laws administered by the Secretary if such person were not receiving such retired or retirement pay, shall be entitled to receive such pension or compensation upon the filing by such person with the department by which such retired or retirement pay is paid of a waiver of so much of such person’s retired or retirement pay as is equal in amount to such pension or compensation. To prevent duplication of payments, the department with which any such waiver is filed shall notify the Secretary of the receipt of such waiver, the amount waived, and the effective date of the reduction in retired or retirement pay."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc3d787c2-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1231"},"text":"72 Stat. 1231","children":[],"tail":", § 3105; "},{"tag":"ref","attrib":{"href":"/us/pl/91/621/s6/a/3"},"text":"Pub. L. 91–621, § 6(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1864"},"text":"84 Stat. 1864","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/576/tVII/s701/72"},"text":"Pub. L. 99–576, title VII, § 701(72)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3297"},"text":"100 Stat. 3297","children":[],"tail":"; renumbered § 5305, "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/1"},"text":"Pub. L. 102–83, § 4(a)(1)","children":[],"tail":", (2)(A)(viii), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/403"},"text":"105 Stat. 403","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/454/tIII/s308/b"},"text":"Pub. L. 108–454, title III, § 308(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-10"},"text":"Dec. 10, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3614"},"text":"118 Stat. 3614","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3d787c3-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3d787c4-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3d787c5-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/454"},"text":"Pub. L. 108–454","children":[],"tail":" substituted “Except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1414"},"text":"section 1414 of title 10","children":[],"tail":", any” for “Any” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3105"},"text":"section 3105 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/2/A/viii"},"text":"Pub. L. 102–83, § 4(a)(2)(A)(viii)","children":[],"tail":", substituted “Secretary” for “Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/1"},"text":"Pub. L. 102–83, § 4(a)(1)","children":[],"tail":", substituted “administered by the Secretary” for “administered by the Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/576"},"text":"Pub. L. 99–576","children":[],"tail":" substituted “such person” for “he” and “such person’s” for “his”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/621"},"text":"Pub. L. 91–621","children":[],"tail":" substituted “National Oceanic and Atmospheric Administration” for “Coast and Geodetic Survey”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
