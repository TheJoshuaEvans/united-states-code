{"tag":"section","attrib":{"id":"idc402680e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7361"},"text":null,"children":[{"tag":"num","attrib":{"value":"7361"},"text":"§ 7361.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to establish; status","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc402680f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7361/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may authorize the establishment at any Department medical center of a nonprofit corporation to provide a flexible funding mechanism for the conduct of approved research and education at the medical center. Such a corporation may be established to facilitate either research or education or both research and education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4026810-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7361/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4026811-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7361/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2), a corporation established under this subchapter may facilitate the conduct of research, education, or both at more than one medical center. Such a corporation shall be known as a “multi-medical center research corporation”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4026812-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7361/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The board of directors of a multi-medical center research corporation under this subsection shall include the official at each Department medical center concerned who is, or who carries out the responsibilities of, the medical center director of such center as specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7363/a/1/A/i"},"text":"section 7363(a)(1)(A)(i) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4026813-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7361/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In facilitating the conduct of research, education, or both at more than one Department medical center under this subchapter, a multi-medical center research corporation may administer receipts and expenditures relating to such research, education, or both, as applicable, performed at the Department medical centers concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4026814-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7361/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any corporation established under this subchapter shall be established in accordance with the nonprofit corporation laws of the State in which the applicable Department medical center is located and shall, to the extent not inconsistent with any Federal law, be subject to the laws of such State. In the case of any multi-medical center research corporation that facilitates the conduct of research, education, or both at Department medical centers located in different States, the corporation shall be established in accordance with the nonprofit corporation laws of the State in which one of such Department medical centers is located.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4026815-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7361/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4026816-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7361/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided in this subchapter or under regulations prescribed by the Secretary, any corporation established under this subchapter, and its officers, directors, and employees, shall be required to comply only with those Federal laws, regulations, and executive orders and directives that apply generally to private nonprofit corporations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4026817-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7361/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A corporation under this subchapter is not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc4026818-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7361/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned or controlled by the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4026819-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7361/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agency or instrumentality of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc402681a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7361/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If by the end of the four-year period beginning on the date of the establishment of a corporation under this subchapter the corporation is not recognized as an entity the income of which is exempt from taxation under section 501(c)(3) of the Internal Revenue Code of 1986, the Secretary shall dissolve the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc402681b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7361/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A corporation established under this subchapter may act as a multi-medical center research corporation under this subchapter in accordance with subsection (b) if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc402681c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7361/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the board of directors of the corporation approves a resolution permitting facilitation by the corporation of the conduct of research, education, or both at the other Department medical center or medical centers concerned; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc402681d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7361/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary approves the resolution of the corporation under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc402681e-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/322/tII/s204/a"},"text":"Pub. L. 100–322, title II, § 204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/510"},"text":"102 Stat. 510","children":[],"tail":", § 4161; renumbered § 7361 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV"},"text":"Pub. L. 102–40, title IV","children":[],"tail":", §§ 401(a)(4)(B), 403(a)(1), (2), "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/221"},"text":"105 Stat. 221","children":[],"tail":", 239; "},{"tag":"ref","attrib":{"href":"/us/pl/102/291/s3/a"},"text":"Pub. L. 102–291, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-05-20"},"text":"May 20, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/179"},"text":"106 Stat. 179","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/262/tIII/s343/b"},"text":"Pub. L. 104–262, title III, § 343(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3207"},"text":"110 Stat. 3207","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/117/tII/s204/a"},"text":"Pub. L. 106–117, title II, § 204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-30"},"text":"Nov. 30, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1562"},"text":"113 Stat. 1562","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/163/tVIII/s801/a"},"text":"Pub. L. 111–163, title VIII, § 801(a)","children":[],"tail":", (b)(1), (c), (d), "},{"tag":"date","attrib":{"date":"2010-05-05"},"text":"May 5, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1175"},"text":"124 Stat. 1175","children":[],"tail":", 1176.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc402681f-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc4026820-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc4026821-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 501(c)(3) of the Internal Revenue Code of 1986, referred to in subsec. (e), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc4026822-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163/s801/c/1"},"text":"Pub. L. 111–163, § 801(c)(1)","children":[],"tail":", struck out “Except as otherwise required in this subchapter or under regulations prescribed by the Secretary, any such corporation, and its directors and employees, shall be required to comply only with those Federal laws, regulations, and executive orders and directives which apply generally to private nonprofit corporations.” after “the medical center.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163/s801/a/1/B"},"text":"Pub. L. 111–163, § 801(a)(1)(B)","children":[],"tail":", (b)(1), (c)(2), added subsecs. (b) to (d). Former subsec. (b) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163/s801/d"},"text":"Pub. L. 111–163, § 801(d)","children":[],"tail":", inserted “section 501(c)(3) of” after “exempt from taxation under”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163/s801/a/1/A"},"text":"Pub. L. 111–163, § 801(a)(1)(A)","children":[],"tail":", redesignated subsec. (b) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163/s801/a/2"},"text":"Pub. L. 111–163, § 801(a)(2)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117"},"text":"Pub. L. 106–117","children":[],"tail":" inserted “and education” after “research” and inserted at end “Such a corporation may be established to facilitate either research or education or both research and education.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/262"},"text":"Pub. L. 104–262","children":[],"tail":" struck out “section 501(c)(3) of” before “the Internal Revenue Code of 1986”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/291"},"text":"Pub. L. 102–291","children":[],"tail":" substituted “four-year period” for “three-year period”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s401/a/4/B"},"text":"Pub. L. 102–40, § 401(a)(4)(B)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4161"},"text":"section 4161 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s403/a/2"},"text":"Pub. L. 102–40, § 403(a)(2)","children":[],"tail":", substituted “Department” for “Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s403/a/1"},"text":"Pub. L. 102–40, § 403(a)(1)","children":[],"tail":", substituted “Secretary” for “Administrator” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s403/a/1"},"text":"Pub. L. 102–40, § 403(a)(1)","children":[],"tail":", substituted “Secretary” for “Administrator”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc4026823-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc4026824-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/291/s3/c"},"text":"Pub. L. 102–291, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-05-20"},"text":"May 20, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/179"},"text":"106 Stat. 179","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/291/s3/c"},"text":"“The amendments made by subsections (a) and (b) [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7368"},"text":"section 7368 of this title","children":[],"tail":"] shall take effect as of "},{"tag":"date","attrib":{"date":"1991-10-01"},"text":"October 1, 1991","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc4026825-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Ratification of Actions of Secretary of Veterans Affairs During Lapsed Period","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/291/s3/d"},"text":"Pub. L. 102–291, § 3(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-05-20"},"text":"May 20, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/179"},"text":"106 Stat. 179","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/291/s3/d"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The following actions of the Secretary of Veterans Affairs during the period beginning on ","children":[{"tag":"date","attrib":{"date":"1991-10-01"},"text":"October 1, 1991","children":[],"tail":", and ending on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1992-05-20"},"text":"May 20, 1992","children":[],"tail":"] are hereby ratified:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A failure to dissolve a nonprofit corporation established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7361/a"},"text":"section 7361(a) of title 38","children":[],"tail":", United States Code, that, within the three-year period beginning on the date of the establishment of the corporation, was not recognized as an entity the income of which is exempt from taxation under section 501(c)(3) of the Internal Revenue Code of 1986 ["},{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"26 U.S.C. 501(c)(3)","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The establishment of a nonprofit corporation for approved research under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7361/a"},"text":"section 7361(a) of title 38","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
