{"tag":"section","attrib":{"id":"idc37ce483-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3541"},"text":null,"children":[{"tag":"num","attrib":{"value":"3541"},"text":"§ 3541.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entitlement to special restorative training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc37ce484-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3541/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary at the request of an eligible person is authorized—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc37ce485-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3541/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine whether such person is in need of special restorative training; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc37ce486-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3541/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where need is found to exist, to prescribe a course which is suitable to accomplish the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such a course, at the discretion of the Secretary, may contain elements that would contribute toward an ultimate objective of a program of education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc37ce487-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3541/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total period of educational assistance under this subchapter and other subchapters of this chapter may not exceed the amount of entitlement as established in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3511"},"text":"section 3511 of this title","children":[],"tail":", except that the Secretary may extend such period in the case of any person if the Secretary finds that additional assistance is necessary to accomplish the purpose of special restorative training as stated in subsection (a) of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc37ce488-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1200"},"text":"72 Stat. 1200","children":[],"tail":", § 1741; "},{"tag":"ref","attrib":{"href":"/us/pl/88/361/s6"},"text":"Pub. L. 88–361, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-07-07"},"text":"July 7, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/298"},"text":"78 Stat. 298","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/502/tIII/s310/21"},"text":"Pub. L. 94–502, title III, § 310(21)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-15"},"text":"Oct. 15, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2392"},"text":"90 Stat. 2392","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIV/s423/b/1/A"},"text":"Pub. L. 101–237, title IV, § 423(b)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2092"},"text":"103 Stat. 2092","children":[],"tail":"; renumbered § 3541 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", (c