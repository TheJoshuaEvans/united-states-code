{"tag":"section","attrib":{"id":"idc4261d43-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8117"},"text":null,"children":[{"tag":"num","attrib":{"value":"8117"},"text":"§ 8117.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency preparedness","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc4261d44-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8117/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Readiness of Department Medical Centers","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4261d45-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8117/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall take appropriate actions to provide for the readiness of Department medical centers to protect the patients and staff of such centers from a public health emergency (as defined in section 2801 of the Public Health Service Act) or otherwise to respond to such an emergency so as to enable such centers to fulfill their obligations as part of the Federal response to such emergencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4261d46-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8117/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Actions under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc4261d47-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8117/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of decontamination equipment and personal protection equipment at Department medical centers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4261d48-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8117/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of training in the use of such equipment to staff of such centers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4261d49-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8117/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organizing, training, and equipping the staff of such centers to support the activities carried out by the Secretary of Health and Human Services under section 2801 of the Public Health Service Act in the event of a public health emergency and incidents covered by the National Response Plan developed pursuant to section 502(6) ","children":[{"tag":"ref","attrib":{"idref":"fn002122"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002122"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Homeland Security Act of 2002, or any successor plan; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4261d4a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8117/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing medical logistical support to the National Disaster Medical System and the Secretary of Health and Human Services as necessary, on a reimbursable basis, and in coordination with other designated Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4261d4b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8117/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Security at Department Medical and Research Facilities","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4261d4c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8117/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall take appropriate actions to provide for the security of Department medical centers and research facilities, including staff and patients at such centers and facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4261d4d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8117/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In taking actions under paragraph (1), the Secretary shall take into account the results of the evaluation of the security needs at Department medical centers and research facilities required by section 154(b)(1) of the Public Health Security and Bioterrorism Preparedness and Response Act of 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/188"},"text":"Public Law 107–188","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/116/631"},"text":"116 Stat. 631","children":[],"tail":"), including the results of such evaluation relating to the following needs:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc4261d4e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8117/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Needs for the protection of patients and medical staff during emergencies, including a chemical or biological attack or other terrorist attack.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4261d4f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8117/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Needs, if any, for screening personnel engaged in research relating to biological pathogens or agents, including work associated with such research.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4261d50-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8117/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Needs for securing laboratories or other facilities engaged in research relating to biological pathogens or agents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4261d51-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8117/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tracking of Pharmaceuticals and Medical Supplies and Equipment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall develop and maintain a centralized system for tracking the current location and availability of pharmaceuticals, medical supplies, and medical equipment throughout the Department health care system in order to permit the ready identification and utilization of such pharmaceuticals, supplies, and equipment for a variety of purposes, including response to a public health emergency. The Secretary shall, through existing medical procurement contracts, and on a reimbursable basis, make available as necessary, medical supplies, equipment, and pharmaceuticals in response to a public health emergency in support of the Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4261d52-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8117/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall ensure that the Department medical centers, in consultation with the accredited medical school affiliates of such medical centers, implement curricula to train resident physicians and health care personnel in medical matters relating to public health emergencies or attacks from an incendiary or other explosive weapon consistent with section 319F(a) of the Public Health Service Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4261d53-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8117/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Participation in National Disaster Medical System","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4261d54-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8117/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall establish and maintain a training program to facilitate the participation of the staff of Department medical centers, and of the community partners of such centers, in the National Disaster Medical System established pursuant to section 2812 of the Public Health Service Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300hh–11"},"text":"42 U.S.C. 300hh–11","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4261d55-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8117/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall establish and maintain the training program under paragraph (1) in accordance with the recommendations of the working group on the prevention, preparedness, and response to public health emergencies established under section 319F of the Public Health Service Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d–6"},"text":"42 U.S.C. 247d–6","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4261d56-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8117/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall establish and maintain the training program under paragraph (1) in consultation with the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc4261d57-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8117/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4261d58-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8117/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4261d59-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8117/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the Federal Emergency Management Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4261d5a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8117/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Mental Health Counseling","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4261d5b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8117/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to activities conducted by personnel serving at Department medical centers, the Secretary shall develop and maintain various strategies for providing mental health counseling and assistance, including counseling and assistance for post-traumatic stress disorder, following a bioterrorist attack or other public health emergency to the following persons:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc4261d5c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8117/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Veterans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4261d5d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8117/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Local and community emergency response providers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4261d5e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8117/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Active duty military personnel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4261d5f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8117/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Individuals seeking care at Department medical centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4261d60-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8117/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The strategies under paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc4261d61-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8117/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Training and certification of providers of mental health counseling and assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4261d62-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8117/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Mechanisms for coordinating the provision of mental health counseling and assistance to emergency response providers referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4261d63-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8117/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall develop and maintain the strategies under paragraph (1) in consultation with the Secretary of Health and Human Services, the American Red Cross, and the working group referred to in subsection (e)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4261d64-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8117/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There are authorized to be appropriated, $155,300,000 for each of fiscal years 2019 through 2028 to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc4261d65-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/287/s6/a/1"},"text":"Pub. L. 107–287, § 6(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-07"},"text":"Nov. 7, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2030"},"text":"116 Stat. 2030","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s612/c"},"text":"Pub. L. 109–295, title VI, § 612(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1410"},"text":"120 Stat. 1410","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/417/tIII/s306"},"text":"Pub. L. 109–417, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-19"},"text":"Dec. 19, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2863"},"text":"120 Stat. 2863","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/387/tIX/s901/a/7"},"text":"Pub. L. 110–387, title IX, § 901(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4142"},"text":"122 Stat. 4142","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/275/tX/s1001/p/2"},"text":"Pub. L. 111–275, title X, § 1001(p)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-13"},"text":"Oct. 13, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2897"},"text":"124 Stat. 2897","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/5/tI/s105"},"text":"Pub. L. 113–5, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-13"},"text":"Mar. 13, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/170"},"text":"127 Stat. 170","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/22/tVII/s701/a"},"text":"Pub. L. 116–22, title VII, § 701(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-06-24"},"text":"June 24, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/961"},"text":"133 Stat. 961","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/19/s3"},"text":"Pub. L. 118–19, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-10-06"},"text":"Oct. 6, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/106"},"text":"137 Stat. 106","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc4261d66-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc4261d67-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc4261d68-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 2801 of the Public Health Service Act, referred to in subsec. (a)(1), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300hh"},"text":"section 300hh of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 502 of the Homeland Security Act of 2002, referred to in subsec. (a)(2)(C), probably means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s502"},"text":"section 502 of Pub. L. 107–296","children":[],"tail":" prior to its redesignation as section 504 by "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/s611/8"},"text":"Pub. L. 109–295, § 611(8)","children":[],"tail":", and reclassification as "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s314"},"text":"section 314 of Title 6","children":[],"tail":", Domestic Security, and not "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s506"},"text":"section 506 of Pub. L. 107–296","children":[],"tail":" which was redesignated section 502 by "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/s611/9"},"text":"Pub. L. 109–295, § 611(9)","children":[],"tail":", and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s312"},"text":"section 312 of Title 6","children":[],"tail":". Provisions relating to the National Response Plan are contained in "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s314/a/6"},"text":"section 314(a)(6) of Title 6","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 154(b)(1) of the Public Health Security and Bioterrorism Preparedness and Response Act of 2002, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/188/s154/b/1"},"text":"section 154(b)(1) of Pub. L. 107–188","children":[],"tail":", which is set out as a note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc4261d69-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/19"},"text":"Pub. L. 118–19","children":[],"tail":" substituted “2028” for “2023”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/22"},"text":"Pub. L. 116–22","children":[],"tail":" substituted “2019 through 2023” for “2014 through 2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/5"},"text":"Pub. L. 113–5","children":[],"tail":" substituted “$155,300,000 for each of fiscal years 2014 through 2018 to carry out this section” for “such sums as may be necessary to carry out this section for each of fiscal years 2007 through 2011”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/275/s1001/p/2/A"},"text":"Pub. L. 111–275, § 1001(p)(2)(A)","children":[],"tail":", substituted “("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300hh–11"},"text":"42 U.S.C. 300hh–11","children":[],"tail":")” for “("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300hh–11/b"},"text":"42 U.S.C. 300hh–11(b)","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/275/s1001/p/2/B"},"text":"Pub. L. 111–275, § 1001(p)(2)(B)","children":[],"tail":", substituted “("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d–6"},"text":"42 U.S.C. 247d–6","children":[],"tail":")” for “("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d–6/a"},"text":"42 U.S.C. 247d–6(a)","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/387"},"text":"Pub. L. 110–387","children":[],"tail":" substituted “respond to such” for “respond to such such”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/417/s306/a/1/A"},"text":"Pub. L. 109–417, § 306(a)(1)(A)","children":[],"tail":", substituted “a public health emergency (as defined in section 2801 of the Public Health Service Act)” for “chemical or biological attack”, “such an emergency” for “an attack”, and “such emergencies” for “public health emergencies”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(C), (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/417/s306/a/1/B"},"text":"Pub. L. 109–417, § 306(a)(1)(B)","children":[],"tail":", added subpars. (C) and (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/417/s306/a/2"},"text":"Pub. L. 109–417, § 306(a)(2)","children":[],"tail":", substituted “a public health emergency. The Secretary shall, through existing medical procurement contracts, and on a reimbursable basis, make available as necessary, medical supplies, equipment, and pharmaceuticals in response to a public health emergency in support of the Secretary of Health and Human Services.” for “a chemical or biological attack or other terrorist attack.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/417/s306/a/3"},"text":"Pub. L. 109–417, § 306(a)(3)","children":[],"tail":", struck out “develop and” before “implement curricula”, substituted “public health emergencies” for “biological, chemical, or radiological attacks”, and inserted “consistent with section 319F(a) of the Public Health Service Act” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/417/s306/a/4/A"},"text":"Pub. L. 109–417, § 306(a)(4)(A)","children":[],"tail":", substituted “2812” for “2811(b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/417/s306/a/4/B"},"text":"Pub. L. 109–417, § 306(a)(4)(B)","children":[],"tail":", struck out “bioterrorism and other” after “response to” and substituted “319F” for “319F(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/417/s306/b"},"text":"Pub. L. 109–417, § 306(b)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc4261d6a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idc4261d6b-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Administrator of the Federal Emergency Management Agency” substituted for “Director of the Federal Emergency Management Agency” in subsec. (e)(3)(C) on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/s612/c"},"text":"section 612(c) of Pub. L. 109–295","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s313"},"text":"section 313 of Title 6","children":[],"tail":", Domestic Security. Any reference to the Administrator of the Federal Emergency Management Agency in title VI of "},{"tag":"ref","attrib":{"href":"/us/pl/109/295"},"text":"Pub. L. 109–295","children":[],"tail":" or an amendment by title VI to be considered to refer and apply to the Director of the Federal Emergency Management Agency until "},{"tag":"date","attrib":{"date":"2007-03-31"},"text":"Mar. 31, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/s612/f/2"},"text":"section 612(f)(2) of Pub. L. 109–295","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s313"},"text":"section 313 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idc4261d6c-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions, personnel, assets, and liabilities of the National Disaster Medical System, including the functions of the Secretary of Homeland Security and the Under Secretary for Emergency Preparedness and Response relating thereto, to the Secretary of Health and Human Services, see title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295"},"text":"Pub. L. 109–295","children":[],"tail":", set out in part as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300hh–11"},"text":"section 300hh–11 of Title 42","children":[],"tail":", The Public Health and Welfare, and "},{"tag":"ref","attrib":{"href":"/us/pl/109/417/s301/b"},"text":"section 301(b) of Pub. L. 109–417","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300hh–11"},"text":"section 300hh–11 of Title 42","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions, personnel, assets, and liabilities of the National Disaster Medical System of the Department of Health and Human Services, including the functions of the Secretary of Health and Human Services and the Assistant Secretary for Public Health Emergency Preparedness [now Assistant Secretary for Preparedness and Response] relating thereto, to the Secretary of Homeland Security, and for treatment of related references, see former section 313(5) and sections 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc4261d6d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Enhancement of Emergency Preparedness of Department of Veterans Affairs","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/188/tI/s154"},"text":"Pub. L. 107–188, title I, § 154","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-06-12"},"text":"June 12, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/631"},"text":"116 Stat. 631","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/107/287/s6/b"},"text":"Pub. L. 107–287, § 6(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2002-11-07"},"text":"Nov. 7, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2032"},"text":"116 Stat. 2032","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/287/s6/b"},"text":"\n","children":[{"tag":"subsection","attrib":{"status":"repealed"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“[(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/287/s6/b"},"text":"Pub. L. 107–287, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-07"},"text":"Nov. 7, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2032"},"text":"116 Stat. 2032","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Security at Department Medical and Research Facilities","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2002-06-12"},"text":"June 12, 2002","children":[],"tail":"], the Secretary [of Veterans Affairs] shall carry out an evaluation of the security needs at Department medical centers and research facilities. The evaluation shall address the following needs:"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Needs for the protection of patients and medical staff during emergencies, including a chemical or biological attack or other terrorist attack.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Needs, if any, for screening personnel engaged in research relating to biological pathogens or agents, including work associated with such research.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Needs for securing laboratories or other facilities engaged in research relating to biological pathogens or agents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other needs the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"status":"repealed"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“[(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/287/s6/b"},"text":"Pub. L. 107–287, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-07"},"text":"Nov. 7, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2032"},"text":"116 Stat. 2032","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“[(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to (f) Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/287/s6/b"},"text":"Pub. L. 107–287, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-07"},"text":"Nov. 7, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2032"},"text":"116 Stat. 2032","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"“(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is hereby authorized to be appropriated for the Department of Veterans Affairs amounts as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To carry out activities required by subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s8117"},"text":"section 8117 of title 38","children":[],"tail":", United States Code—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000,000 for fiscal year 2002; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as may be necessary for each of fiscal years 2003 through 2006.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To carry out activities required by subsection (b)(1) of this section and subsections (b) through (f) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s8117"},"text":"section 8117 of title 38","children":[],"tail":", United States Code—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $33,000,000 for fiscal year 2002; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as may be necessary for each of fiscal years 2003 through 2006.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
