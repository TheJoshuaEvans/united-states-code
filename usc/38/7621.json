{"tag":"section","attrib":{"id":"idc4157ae8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7621"},"text":null,"children":[{"tag":"num","attrib":{"value":"7621"},"text":"§ 7621.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority for program","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As part of the Educational Assistance Program, the Secretary shall carry out a tuition reimbursement program under this subchapter. The program shall be known as the Department of Veterans Affairs Nurse Education Tuition Reimbursement Program (hereinafter in this chapter referred to as the “Tuition Reimbursement Program”).","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc4157ae9-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/322/tII/s216/b"},"text":"Pub. L. 100–322, title II, § 216(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/525"},"text":"102 Stat. 525","children":[],"tail":", § 4321; renumbered § 7621, "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/2/B/vi"},"text":"Pub. L. 102–83, § 4(a)(2)(B)(vi)","children":[],"tail":", (b)(1), (2)(E), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/403-405"},"text":"105 Stat. 403–405","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc4157aea-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc4157aeb-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc4157aec-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4321"},"text":"section 4321 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" substituted “Secretary” for “Administrator” and “Department of Veterans Affairs” for “Veterans’ Administration”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
