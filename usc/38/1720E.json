{"tag":"section","attrib":{"id":"idc2fc1c00-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720E"},"text":null,"children":[{"tag":"num","attrib":{"value":"1720E"},"text":"§ 1720E.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nasopharyngeal radium irradiation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2fc1c01-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720E/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may provide any veteran a medical examination, and hospital care, medical services, and nursing home care, which the Secretary determines is needed for the treatment of any cancer of the head or neck which the Secretary finds may be associated with the veteran’s receipt of nasopharyngeal radium irradiation treatments in active military, naval, air, or space service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2fc1c02-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720E/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall provide care and services to a veteran under subsection (a) only on the basis of evidence in the service records of the veteran which document nasopharyngeal radium irradiation treatment in service, except that, notwithstanding the absence of such documentation, the Secretary may provide such care to a veteran who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2fe8c03-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720E/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" served as an aviator in the active military, naval, or air service before the end of the Korean conflict; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2fe8c04-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1720E/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" underwent submarine training in active naval service before ","children":[{"tag":"date","attrib":{"date":"1965-01-01"},"text":"January 1, 1965","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2fe8c05-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/tIX/s901/a"},"text":"Pub. L. 105–368, title IX, § 901(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3360"},"text":"112 Stat. 3360","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s926/a/27"},"text":"Pub. L. 116–283, div. A, title IX, § 926(a)(27)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3830"},"text":"134 Stat. 3830","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2fe8c06-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc2fe8c07-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc2fe8c08-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “air, or space service” for “or air service”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
