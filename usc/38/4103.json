{"tag":"section","attrib":{"id":"idc3bad7c4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4103"},"text":null,"children":[{"tag":"num","attrib":{"value":"4103"},"text":"§ 4103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Directors and Assistant Directors for Veterans’ Employment and Training; additional Federal personnel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3bad7c5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Directors and Assistant Directors","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3bad7c6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall assign to each State a representative of the Veterans’ Employment and Training Service to serve as the Director for Veterans’ Employment and Training, and shall assign full-time Federal clerical or other support personnel to each such Director.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3bad7c7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3bad7c8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4103/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each Director for Veterans’ Employment and Training for a State shall, at the time of appointment, have been a bona fide resident of the State for at least two years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3bad7c9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4103/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may waive the requirement in subparagraph (A) with respect to a Director for Veterans’ Employment and Training if the Secretary determines that the waiver is in the public interest. Any such waiver shall be made on a case-by-case basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3bad7ca-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4103/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Full-time Federal clerical or other support personnel assigned to Directors for Veterans’ Employment and Training shall be appointed in accordance with the provisions of title 5 governing appointments in the competitive service and shall be paid in accordance with the provisions of chapter 51 and subchapter III of chapter 53 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3bad7cb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Federal Personnel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may also assign as supervisory personnel such representatives of the Veterans’ Employment and Training Service as the Secretary determines appropriate to carry out the employment, training, and placement services required under this chapter, including Assistant Directors for Veterans’ Employment and Training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3bad7cc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination With State Departments of Labor and Veterans Affairs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each Director for Veterans’ Employment and Training for a State shall coordinate the Director’s activities under this chapter with the State department of labor and the State department of veterans affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3bad7cd-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1218"},"text":"72 Stat. 1218","children":[],"tail":", § 2012; renumbered § 2003, "},{"tag":"ref","attrib":{"href":"/us/pl/87/675/s1/a"},"text":"Pub. L. 87–675, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-19"},"text":"Sept. 19, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/558"},"text":"76 Stat. 558","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/89/358/s6/c/1"},"text":"Pub. L. 89–358, § 6(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-03-03"},"text":"Mar. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/27"},"text":"80 Stat. 27","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/540/tV/s502/a"},"text":"Pub. L. 92–540, title V, § 502(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-24"},"text":"Oct. 24, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1094"},"text":"86 Stat