110–389","children":[],"tail":" designated existing provisions as subpar. (A) and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/288"},"text":"Pub. L. 107–288","children":[],"tail":" substituted “Directors and Assistant Directors for Veterans’ Employment and Training; additional Federal personnel” for “Directors and Assistant Directors for Veterans’ Employment and Training” in section catchline and amended text generally, substituting subsecs. (a) and (b) for former subsecs. (a) to (c) relating to Directors and Assistant Directors and their responsibilities."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/275"},"text":"Pub. L. 104–275","children":[],"tail":" substituted “full-time Federal clerical or other support personnel” for “full-time Federal clerical support” in first sentence and “Full-time Federal clerical or other support personnel” for “Full-time Federal clerical support personnel” in third sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446"},"text":"Pub. L. 103–446","children":[],"tail":" substituted “subchapter II of chapter 77” for “subchapter IV of chapter 3”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2003"},"text":"section 2003 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “4107” for “2007”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “4212” for “2012“."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “1712A” for “612A”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (c)(2), (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" substituted “Department of Veterans Affairs” for “Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323/s15/c/3/A"},"text":"Pub. L. 100–323, § 15(c)(3)(A)","children":[],"tail":", substituted “Directors and Assistant Directors” for “State and Assistant State Directors” and inserted “and Training” after “for Veterans’ Employment” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323/s15/a/2"},"text":"Pub. L. 100–323, § 15(a)(2)","children":[],"tail":", struck out “of Labor” after “The Secretary” at beginning."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323/s15/c/1"},"text":"Pub. L. 100–323, § 15(c)(1)","children":[],"tail":", substituted “Director for Veterans’ Employment and Training” for “State Director for Veterans’ Employment” in two places, “Assistant Director for Veterans’ Employment and Training” for “Assistant State Director for Veterans’ Employment”, “Assistant Directors for Veterans’ Employment and Training” for “Assistant State Directors for Veterans’ Employment”, and “Directors for Veterans’ Employment and Training” for “State Directors for Veterans’ Employment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323/s15/c/1"},"text":"Pub. L. 100–323, § 15(c)(1)","children":[],"tail":", substituted “Director for Veterans’ Employment and Training” for “State Director for Veterans’ Employment” and “Assistant Director for Veterans’ Employment and Training” for “Assistant State Director for Veterans’ Employment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323/s5/1"},"text":"Pub. L. 100–323, § 5(1)","children":[],"tail":"–(3), designated existing provisions as subpar. (A), redesignated former cls. (A) and (B) as (i) and (ii), respectively, and substituted “, except as provided in subparagraph (B) of this paragraph, be a qualified veteran” for “be an eligible veteran” in cl. (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subpar. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323/s5/4"},"text":"Pub. L. 100–323, § 5(4)","children":[],"tail":", added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323/s15/c/1"},"text":"Pub. L. 100–323, § 15(c)(1)","children":[],"tail":", substituted “Director for Veterans’ Employment and Training” for “State Director for Veterans’ Employment” and “Assistant Director for Veterans’ Employment and Training” for “Assistant State Director for Veterans’ Employment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323/s15/a/2"},"text":"Pub. L. 100–323, § 15(a)(2)","children":[],"tail":", struck out “of Labor” after “to the Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323/s15/c/1"},"text":"Pub. L. 100–323, § 15(c)(1)","children":[],"tail":", substituted “Director for Veterans’ Employment and Training” for “State Director for Veterans’ Employment” and “Assistant Directors for Veterans’ Employment and Training” for “Assistant State Directors for Veterans’ Employment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323/s7/a/1"},"text":"Pub. L. 100–323, § 7(a)(1)","children":[],"tail":", inserted “(A) functionally supervise the provision of services to eligible veterans and eligible persons by such system and such program and their staffs, and (B)” after “(1)” and “, including the program conducted under the Veterans’ Job Training Act ("},{"tag":"ref","attrib":{"href":"/us/pl/98/77"},"text":"Public Law 98–77","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1721"},"text":"29 U.S.C. 1721","children":[],"tail":" note)” after “programs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323/s7/a/2"},"text":"Pub. L. 100–323, § 7(a)(2)","children":[],"tail":", inserted “and otherwise to promote the employment of eligible veterans and eligible persons” after “opportunities”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(13) to (15). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/323/s7/a/3"},"text":"Pub. L. 100–323, § 7(a)(3)","children":[],"tail":"–(5), added cls. (13) to (15)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/306/s304/a/1"},"text":"Pub. L. 97–306, § 304(a)(1)","children":[],"tail":", struck out text that preceded cl. (1), which related to assignment, number, qualifications, pay, and administrative position of veterans’ employment representatives, and inserted in lieu thereof a revised section catchline and subsecs. (a) to (c) relating to State and Assistant State Directors for Veterans’ Employment."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295"},"text":"Pub. L. 97–295","children":[],"tail":" substituted “chapter 51 and” for “chapter 51 of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/306/s304/b"},"text":"Pub. L. 97–306, § 304(b)","children":[],"tail":", substituted provision of cl. (6) that the Director and Assistant Director promote and facilitate the participation of veterans in Federal and federally funded employment and training programs and directly monitor the implementation and operation of such programs to ensure that eligible veterans, veterans of the Vietnam era, disabled veterans, and eligible persons receive such priority or other special consideration in the provision of services as is required by law or regulation, for provision that they promote the participation of veterans in Comprehensive Employment and Training Act programs and monitor the implementation and operation of Comprehensive Employment and Training Act programs to assure that eligible veterans, disabled veterans, and veterans of the Vietnam era receive special consideration when required."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(8) to (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/306/s304/c"},"text":"Pub. L. 97–306, § 304(c)","children":[],"tail":", added cls. (8) to (12)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466"},"text":"Pub. L. 96–466","children":[],"tail":" in provisions preceding par. (1) inserted “(and shall assign full-time clerical support to each such representative)” after “to serve as the veterans’ employment representative”, struck out “, United States Code,” after “title 5”, substituted “employment and training programs” for “manpower and training programs”, inserted “system” after “public employment service” wherever appearing, and in par. (6) inserted “, disabled veterans, and veterans of the Vietnam era” after “eligible veterans”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/502"},"text":"Pub. L. 94–502","children":[],"tail":" substituted “the Secretary shall determine” for “he shall determine”, “such representative’s” for “his”, “administered by the Secretary or by prime sponsors under the Comprehensive Employment and Training Act” for “administered by the Secretary”, added cl. (6), and redesignated former cl. (6) as (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/508"},"text":"Pub. L. 93–508","children":[],"tail":" substituted “250,000 veterans and eligible persons of the State” for “250,000 veterans of the State”, and “Secretary’s veterans’ and eligible persons’ counseling and placement policies” for “Secretary’s veterans’ counseling and placement policies”, and in cls. (1), (2), (4), (5), and (6) of the fifth sentence substituted “eligible veterans and eligible persons” for “eligible veterans”, in cl. (3) substituted “eligible veteran’s or an eligible person’s” for “eligible veteran’s”, and in cl. (4) substituted “such veterans and persons” for “such veterans”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/540"},"text":"Pub. L. 92–540","children":[],"tail":" substituted provisions relating to the assignment of veterans’ employment representatives for provisions relating to the assignment of employees of local offices. See "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2004"},"text":"section 2004 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/358"},"text":"Pub. L. 89–358","children":[],"tail":" inserted “or of service after "},{"tag":"date","attrib":{"date":"1955-01-31"},"text":"January 31, 1955","children":[],"tail":"” after “veterans of any war”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3bad7d2-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiari