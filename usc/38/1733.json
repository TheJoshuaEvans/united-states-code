{"tag":"section","attrib":{"id":"idc30cbdb2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1733"},"text":null,"children":[{"tag":"num","attrib":{"value":"1733"},"text":"§ 1733.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supervision of program by the President","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President, or any officer of the United States to whom the President may delegate authority under this section, may from time to time prescribe such rules and regulations and impose such conditions on the receipt of financial aid as may be necessary to carry out this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc30cbdb3-47c4-11f1-bf59-9680b1269b87"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1146"},"text":"72 Stat. 1146","children":[],"tail":", § 633; "},{"tag":"ref","attrib":{"href":"/us/pl/94/581/tII/s210/a/15"},"text":"Pub. L. 94–581, title II, § 210(a)(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2863"},"text":"90 Stat. 2863","children":[],"tail":"; renumbered § 1733, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc30cbdb4-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc30cbdb