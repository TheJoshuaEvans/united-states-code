4","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3688"},"text":"section 3688 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc30cbdb7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s633"},"text":"section 633 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/581"},"text":"Pub. L. 94–581","children":[],"tail":" substituted “the President” for “he” and struck out “his” before “authority”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc30cbdb8-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc30cbdb9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/581"},"text":"Pub. L. 94–581","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/581/s211"},"text":"section 211 of Pub. L. 94–581","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s111"},"text":"section 111 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idc30cbdba-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"idc30cbdbb-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Ex. Ord. No. 11762. Delegation of Authority to Administrator of Veterans’ Affairs Relating to Grants-in-Aid to Republic of the Philippines for Medical Care and Treatment of Veterans","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 11762, ","children":[{"tag":"date","attrib":{"date":"1974-01-17"},"text":"Jan. 17, 1974","children":[],"tail":", 39 F.R. 2347, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"By virtue of the authority vested in me by section 633 [now 1733] of title 38 and by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of title 3","children":[],"tail":" of the United States Code, and as President of the United States of America, it is hereby ordered as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Section","children":[],"tail":" 1. (a) Subject to the provisions of subsections (b) and (c) of this section, the Administrator of Veterans’ Affairs is hereby designated and empowered to exercise, without the approval, ratification, or other action of the President, the authority vested in the President by sections 631, 632, 633, and 634 [now 1731, 1732, 1733, and 1734] of title 38 of the United States Code, as amended by section 107(a) of the Veterans Health Care Expansion Act of 1973 ("},{"tag":"ref","attrib":{"href":"/us/pl/93/82"},"text":"Public Law 93–82","children":[],"tail":"; Stat. 184)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(b) The Secretary of State shall negotiate the agreement, and any modifications thereby with the Republic of the Philippines required by the provisions of sections 631, 632, 633, and 634 [now 1731, 1732, 1733, and 1734] of title 38 of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(c) All rules and regulations prescribed by the Administrator pursuant to the authority delegated to him by this order shall be subject to prior approval by the Director of the Office of Management and Budget.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 2. Nothing in this order shall be construed as modifying or terminating any other authority heretofore delegated by the President to the Administrator of Veterans’ Affairs."}],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"Richard Nixon.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
