{"tag":"section","attrib":{"id":"idc402685a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7365"},"text":null,"children":[{"tag":"num","attrib":{"value":"7365"},"text":"§ 7365.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coverage of employees under certain Federal tort claims laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc402685b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7365/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An employee of a corporation established under this subchapter who is described by subsection (b) shall be considered an employee of the Government, or a medical care employee of the Veterans Health Administration, for purposes of the following provisions of law:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc402685c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7365/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1346/b"},"text":"Section 1346(b) of title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc402685d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7365/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 171 of title 28.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc402685e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7365/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7316"},"text":"Section 7316 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc402685f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7365/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An employee described in this subsection is an employee who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4026860-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7365/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has an appointment with the Department, whether with or without compensation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4026861-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7365/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is directly or indirectly involved or engaged in research or education and training that is approved in accordance with procedures established by the Under Secretary for Health for research or education and training; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4026862-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7365/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performs such duties under the supervision of Department personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc4026863-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/170/tIV/s402/a/1"},"text":"Pub. L. 108–170, title IV, § 402(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/u