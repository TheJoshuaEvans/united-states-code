{"tag":"section","attrib":{"id":"idc3d5163e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5302A"},"text":null,"children":[{"tag":"num","attrib":{"value":"5302A"},"text":"§ 5302A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of indebtedness: certain debts of members of the Armed Forces and veterans who die of injury incurred or aggravated in the line of duty in a combat zone","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3d5163f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5302A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may not collect all or any part of an amount owed to the United States by a member of the Armed Forces or veteran described in subsection (b) under any program under the laws administered by the Secretary, other than a program referred to in subsection (c), if the Secretary determines that termination of collection is in the best interest of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d51640-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5302A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Individuals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member of the Armed Forces or veteran described in this subsection is any member or veteran who dies as a result of an injury incurred or aggravated in the line of duty while serving in a theater of combat operations (as determined by the Secretary in consultation with the Secretary of Defense) in a war or in combat against a hostile force during a period of hostilities after ","children":[{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d51641-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5302A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability to Housing and Small Business Benefit Programs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The limitation on authority in subsection (a) shall not apply to any amounts owed the United States under any program carried out under chapter 37 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3d51642-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/252/tI/s1303/a/1"},"text":"Pub. L. 110–252, title I, § 1303(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-30"},"text":"June 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2327"},"text":"122 Stat. 2327","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/58/tVI/s601/21"},"text":"Pub. L. 114–58, title VI, § 601(21)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-09-30"},"text":"Sept. 30, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/539"},"text":"129 Stat. 539","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3d51643-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3d51644-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3d51645-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/58/s601/21/A"},"text":"Pub. L. 114–58, § 601(21)(A)","children":[],"tail":", inserted period after section number."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/58/s601/21/B"},"text":"Pub. L. 114–58, § 601(21)(B)","children":[],"tail":", struck out “(as that term is defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1712A/a/2/B"},"text":"section 1712A(a)(2)(B) of this title","children":[],"tail":")” after “hostilities”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3d51646-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3d51647-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/252/tI/s1303/c"},"text":"Pub. L. 110–252, title I, § 1303(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-30"},"text":"June 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2328"},"text":"122 Stat. 2328","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/252/tI/s1303/c"},"text":"“The amendments made by this section [enacting this section] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2008-06-30"},"text":"June 30, 2008","children":[],"tail":"], and shall apply with respect to collections of indebtedness of members of the Armed Forces and veterans who die on or after "},{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc3d51648-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Equitable Refund","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/389/tVIII/s801/b"},"text":"Pub. L. 110–389, title VIII, § 801(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4185"},"text":"122 Stat. 4185","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/389/tVIII/s801/b"},"text":"“The Secretary of Veterans Affairs may refund to the estate of such person any amount collected by the Secretary (whether before, on, or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":"]) from a person who died while serving on active duty as a member of the Armed Forces if the Secretary determines that, under the circumstances applicable with respect to the deceased person, it is appropriate to do so.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/252/tI/s1303/b"},"text":"Pub. L. 110–252, title I, § 1303(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-30"},"text":"June 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2327"},"text":"122 Stat. 2327","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/252/tI/s1303/b"},"text":"“In any case where all or any part of an indebtedness of a covered individual, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5302A/a"},"text":"section 5302A(a) of title 38","children":[],"tail":", United States Code, as added by subsection (a)(1), was collected after "},{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":", and before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2008-06-30"},"text":"June 30, 2008","children":[],"tail":"], and the Secretary of Veterans Affairs determines that such indebtedness would have been terminated had such section been in effect at such time, the Secretary may refund the amount so collected if the Secretary determines that the individual is equitably entitled to such refund.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
