{"tag":"section","attrib":{"id":"idc39e4f47-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3698A"},"text":null,"children":[{"tag":"num","attrib":{"value":"3698A"},"text":"§ 3698A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of certificates of eligibility and award letters using electronic means","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc39e4f48-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3698A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided by subsection (b), the Secretary shall provide to an individual the following documents using electronic means:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc39e4f49-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3698A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A certificate of eligibility for the entitlement of the individual to covered educational assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc39e4f4a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3698A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An award letter regarding the authorization of the individual to receive covered educational assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc39e4f4b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3698A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Election to Opt Out","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual may elect to receive the documents specified in subsection (a) by mail rather than through electronic means under subsection (a). An individual may revoke such an election at any time, by means prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc39e4f4c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3698A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Educational Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “covered educational assistance” means educational assistance under chapter 30, 33, or 35 of this title, or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3699C"},"text":"section 3699C of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc39e4f4d-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/210/tII/s210/a"},"text":"Pub. L. 118–210, title II, § 210(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-02"},"text":"Jan. 2, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2766"},"text":"138 Stat. 2766","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
