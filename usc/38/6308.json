{"tag":"section","attrib":{"id":"idc3e82925-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6308"},"text":null,"children":[{"tag":"num","attrib":{"value":"6308"},"text":"§ 6308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach for eligible dependents","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3e82926-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6308/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Needs of Dependents","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out this subchapter, the Secretary shall ensure that the needs of eligible dependents are fully addressed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3e82927-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s6308/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information as to Availability of Outreach Services for Dependents","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall ensure that the availability of outreach services and assistance for eligible dependents under this subchapter is made known through a variety of means, including the Internet, announcements in veterans publications, and announcements to the media.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3e82928-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/233/tIV/s402/a"},"text":"Pub. L. 109–233, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-06-15"},"text":"June 15, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/410"},"text":"120 Stat. 410","children":[],"tail":", § 6307; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/205/s2/b/2"},"text":"Pub. L. 117–205, § 2(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-10-17"},"text":"Oct. 17, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2233"},"text":"136 Stat. 2233","children":[],"tail":"; renumbered § 6308, "},{"tag":"ref","attrib":{"href":"/us/pl/118/210/tIII/s302/a/1"},"text":"Pub. L. 118–210, title III, § 302(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-02"},"text":"Jan. 2, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2789"},"text":"138 Stat. 2789","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3e82929-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3e8292a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc3e8292b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6308 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s6309"},"text":"section 6309 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7727"},"text":"section 7727 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/109/233"},"text":"Pub. L. 109–233","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":