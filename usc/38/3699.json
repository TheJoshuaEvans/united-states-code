{"tag":"section","attrib":{"id":"idc39e4f4e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699"},"text":null,"children":[{"tag":"num","attrib":{"value":"3699"},"text":"§ 3699.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effects of closure or disapproval of educational institution","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc39e4f4f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Closure or Disapproval","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any payment of educational assistance described in subsection (b) shall not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc39e4f50-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be charged against any entitlement to educational assistance of the individual concerned; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc39e4f51-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be counted against the aggregate period for which ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3695"},"text":"section 3695 of this title","children":[],"tail":" limits the receipt of educational assistance by such individual."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc39e4f52-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Educational Assistance Described","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (c), the payment of educational assistance described in this subsection is the payment of such assistance to an individual for pursuit of a course or program of education at an educational institution under chapter 30, 31, 32, 33, or 35 of this title, or chapter 1606 or 1607 of title 10, if the Secretary determines that the individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc39e4f53-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" was unable to complete such course or program as a result of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc39e4f54-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the closure of the educational institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc39e4f55-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the disapproval of the course or a course that is a necessary part of that program under this chapter by reason of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc39e4f56-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a provision of law enacted after the date on which the individual enrolls at such institution affecting the approval or disapproval of courses under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc39e4f57-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the date on which the individual enrolls at such institution, the Secretary prescribing or modifying regulations or policies of the Department affecting such approval or disapproval; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc39e4f58-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the temporary closure of an educational institution or training establishment or the temporary closure or termination of a course or program of education by reason of an emergency situation; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc39e4f59-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" did not receive credit or lost training time, toward completion of the program of education being so pursued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc39e4f5a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Period Not Charged","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc39e4f5b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The period for which, by reason of this subsection, educational assistance is not charged against entitlement or counted toward the applicable aggregate period under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3695"},"text":"section 3695 of this title","children":[],"tail":" shall not exceed the aggregate of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc39e4f5c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the portion of the period of enrollment in the course from which the individual did not receive credit or with respect to which the individual lost training time, as determined under subsection (b)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc39e4f5d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period by which a monthly stipend is extended under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3680/a/2/B"},"text":"section 3680(a)(2)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc39e4f5e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc39e4f5f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc39e4f60-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual described in subparagraph (B) who transfers fewer than 12 credits from a program of education that is closed or disapproved as described in subsection (b)(1) shall be deemed to be an individual who did not receive such credits, as described in subsection (b)(2), except that the period for which such individual’s entitlement is not charged shall be the entire period of the individual’s enrollment in the program of education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc39e4f61-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out clause (i), the Secretary shall—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc39e4f62-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699/c/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require an individual to certify in writing that the individual has transferred fewer than 12 credits as described in such clause;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc39e4f63-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699/c/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" require an individual who makes a certification under subclause (I) to acknowledge in writing that if the individual transfers 12 or more credits as described in such clause (i)—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idc39e4f64-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699/c/2/A/ii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual may not be deemed under such clause to be an individual who did not receive such credits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idc39e4f65-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699/c/2/A/ii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall rescind the certificate of eligibility provided under subclause (IV);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc39e4f66-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699/c/2/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept a certification under subclause (I) as proof of the individual transferring fewer than 12 credits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc39e4f67-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699/c/2/A/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to the individual who makes a certification under subclause (I) and makes the acknowledgment under subclause (II) a certificate of eligibility that the individual may provide to an educational institution as proof of the individual being covered by this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc39e4f68-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall notify individuals described in subparagraph (B) of being eligible to be covered by this paragraph.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc39e4f69-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699/c/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out this subparagraph, the Secretary, in consultation with the Secretary of Education, shall establish procedures to determine whether the individual transferred credits to a comparable course or program of education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc39e4f6a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual described in this subparagraph is an individual who is enrolled in a course or program of education closed or discontinued as described in subsection (b)(1) during the period beginning on the date that is 120 days before the date of such closure or discontinuance and ending on the date of such closure or discontinuance, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc39e4f6b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This paragraph, including clauses (ii) and (iii) of subparagraph (A), shall apply with respect to the closure or discontinuation of a course or program of education, as described in subsection (b)(1), that occurs during the period beginning on ","children":[{"tag":"date","attrib":{"date":"2021-08-01"},"text":"August 1, 2021","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2026-09-30"},"text":"September 30, 2026","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc39e4f6c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continuing Pursuit of Disapproved Courses","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc39e4f6d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may treat a course of education that is disapproved under this chapter as being approved under this chapter with respect to an individual described in paragraph (2) if the Secretary determines, on a case-by-case basis, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc39e4f6e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such disapproval is the result of an action described in clause (i) or (ii) of subsection (b)(1)(B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc39e4f6f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continuing pursuing such course is in the best interest of the individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc39e4f70-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual described in this paragraph is an individual who is pursuing a course of education at an educational institution under chapter 30, 31, 32, 33, or 35 of this title, or chapter 1606 or 1607 of title 10, as of the date on which the course is disapproved under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc39e4f71-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice of Closures","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 5 business days after the date on which the Secretary receives notice that an educational institution will close or is closed, the Secretary shall provide to each individual who is enrolled in a course or program or education at such educational institution using entitlement to educational assistance under chapter 30, 31, 32, 33, or 35 of this title, or chapter 1606 or 1607 of title 10, notice of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc39e4f72-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such closure and the date of such closure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc39e4f73-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3699/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect of such closure on the individual’s entitlement to educational assistance pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc39e4f74-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/48/tI/s109/a/1"},"text":"Pub. L. 115–48, title I, § 109(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-16"},"text":"Aug. 16, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/978"},"text":"131 Stat. 978","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/61/s6/6"},"text":"Pub. L. 116–61, § 6(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-09-30"},"text":"Sept. 30, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1117"},"text":"133 Stat. 1117","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/315/tI"},"text":"Pub. L. 116–315, title I","children":[],"tail":", §§ 1007(a), 1021(a), "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4940"},"text":"134 Stat. 4940","children":[],"tail":", 4958; "},{"tag":"ref","attrib":{"href":"/us/pl/117/297/s2"},"text":"Pub. L. 117–297, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4375"},"text":"136 Stat. 4375","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/333/s8/a"},"text":"Pub. L. 117–333, § 8(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6130"},"text":"136 Stat. 6130","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/19/s2"},"text":"Pub. L. 118–19, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-10-06"},"text":"Oct. 6, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/106"},"text":"137 Stat. 106","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/210/tII/s211"},"text":"Pub. L. 118–210, title II, § 211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-02"},"text":"Jan. 2, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2767"},"text":"138 Stat. 2767","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/37/dG/tII/s7202"},"text":"Pub. L. 119–37, div. G, title II, § 7202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-11-12"},"text":"Nov. 12, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/650"},"text":"139 Stat. 650","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc39e4f75-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc39e4f76-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc39e4f77-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3699, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/508/tIII/s301/a"},"text":"Pub. L. 93–508, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-12-03"},"text":"Dec. 3, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1591"},"text":"88 Stat. 1591","children":[],"tail":", § 1799; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/502/tV/s513/a/24"},"text":"Pub. L. 94–502, title V, § 513(a)(24)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-15"},"text":"Oct. 15, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2404"},"text":"90 Stat. 2404","children":[]