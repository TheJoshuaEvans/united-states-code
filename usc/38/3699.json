ve Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/48/tI/s109/c/1"},"text":"Pub. L. 115–48, title I, § 109(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-16"},"text":"Aug. 16, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/980"},"text":"131 Stat. 980","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/115/62/tV/s501/d"},"text":"Pub. L. 115–62, title V, § 501(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-09-29"},"text":"Sept. 29, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1166"},"text":"131 Stat. 1166","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/62/tV/s501/d"},"text":"\n","children":[{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by subsection (a) [enacting this section] shall take effect on the date that is 90 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2017-08-16"},"text":"Aug. 16, 2017","children":[],"tail":"], and shall apply with respect to courses and programs of education discontinued as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3699"},"text":"section 3699 of title 38","children":[],"tail":", United States Code, as added by subsection (a)(1), after "},{"tag":"date","attrib":{"date":"2015-01-01"},"text":"January 1, 2015","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special application.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to courses and programs of education discontinued as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3699"},"text":"section 3699 of title 38","children":[],"tail":", United States Code, as added by subsection (a)(1), during the period beginning "},{"tag":"date","attrib":{"date":"2015-01-01"},"text":"January 1, 2015","children":[],"tail":", and ending on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2017-09-29"},"text":"Sept. 29, 2017","children":[],"tail":"], an individual described in clause (ii) who does not transfer credits from such program of education shall be deemed to be an individual who did not receive such credits, as described in subsection (b)(2) of such section, except that the period for which such individual’s entitlement is not charged shall be the entire period of the individual’s enrollment in the program of education. In carrying out this subparagraph, the Secretary of Veterans Affairs, in consultation with the Secretary of Education, shall establish procedures to determine whether the individual transferred credits to a comparable course or program of education."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Individual described","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual described in this clause is an individual who is enrolled in a course or program of education discontinued as described in clause (i) during the period beginning on the date that is 120 days before the date of such discontinuance and ending on the date of such discontinuance.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc39e4f7d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prohibition of Charge to Entitlement of Students Unable To Pursue a Program of Education Due to an Emergency Situation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/tI/s1107/c"},"text":"Pub. L. 116–315, title I, § 1107(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4966"},"text":"134 Stat. 4966","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/315/tI/s1107/c"},"text":"“The subparagraph (C) temporarily added to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3699/b/1"},"text":"section 3699(b)(1) of title 38","children":[],"tail":", United States Code, by [former] section 5 of the Student Veteran Coronavirus Response Act of 2020 ("},{"tag":"ref","attrib":{"href":"/us/pl/116/140"},"text":"Public Law 116–140","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3699"},"text":"38 U.S.C. 3699","children":[],"tail":" note) [formerly set out below] is amended by inserting ‘or training establishment’ after ‘educational institution’.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/140/s5"},"text":"Pub. L. 116–140, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-04-28"},"text":"Apr. 28, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/632"},"text":"134 Stat. 632","children":[],"tail":", which temporarily added closure of educational institution or training establishment due to emergency situation as reason for payment of educational assistance not to be charged against entitlement of students, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/117/333/s8/b"},"text":"Pub. L. 117–333, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6130"},"text":"136 Stat. 6130","children":[],"tail":". See subsec. (b)(1)(C) of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc39e4f7e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Restoration of Entitlement to Rehabilitation Programs for Veterans Affected by School Closure or Disapproval","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/140/s7/a"},"text":"Pub. L. 116–140, § 7(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-04-28"},"text":"Apr. 28, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/634"},"text":"134 Stat. 634","children":[],"tail":", which provided that, during the period from "},{"tag":"date","attrib":{"date":"2020-03-01"},"text":"Mar. 1, 2020","children":[],"tail":", to "},{"tag":"date","attrib":{"date":"2020-12-21"},"text":"Dec. 21, 2020","children":[],"tail":", the Secretary of Veterans Affairs was to apply this section as if it were amended by striking “chapter 30,” each time it appeared and inserting “chapter 30, 31,”, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/116/315/tI/s1007/c"},"text":"Pub. L. 116–315, title I, § 1007(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4940"},"text":"134 Stat. 4940","children":[],"tail":". See 2021 Amendment note above."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
