{"tag":"section","attrib":{"id":"idc3c6bea5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4314"},"text":null,"children":[{"tag":"num","attrib":{"value":"4314"},"text":"§ 4314.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reemployment by the Federal Government","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3c6bea6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4314/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsections (b), (c), and (d), if a person is entitled to reemployment by the Federal Government under section 4312, such person shall be reemployed in a position of employment as described in section 4313.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3c6bea7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4314/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3c6bea8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4314/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the Director of the Office of Personnel Management makes a determination described in paragraph (2) with respect to a person who was employed by a Federal executive agency at the time the person entered the service from which the person seeks reemployment under this section, the Director shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3c6bea9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4314/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify a position of like seniority, status, and pay at another Federal executive agency that satisfies the requirements of section 4313 and for which the person is qualified; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3c6beaa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4314/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the person is offered such position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3c6beab-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4314/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Director shall carry out the duties referred to in subparagraphs (A) and (B) of paragraph (1) if the Director determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3c6beac-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4314/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal executive agency that employed the person referred to in such paragraph no longer exists and the functions of such agency have not been transferred to another Federal executive agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3c6bead-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4314/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is impossible or unreasonable for the agency to reemploy the person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3c6beae-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4314/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the employer of a person described in subsection (a) was, at the time such person entered the service from which such person seeks reemployment under this section, a part of the judicial branch or the legislative branch of the Federal Government, and such employer determines that it is impossible or unreasonable for such employer to reemploy such person, such person shall, upon application to the Director of the Office of Personnel Management, be ensured an offer of employment in an alternative position in a Federal executive agency on the basis described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3c6beaf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4314/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the adjutant general of a State determines that it is impossible or unreasonable to reemploy a person who was a National Guard technician employed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s709"},"text":"section 709 of title 32","children":[],"tail":", such person shall, upon application to the Director of the Office of Personnel Management, be ensured an offer of employment in an alternative position in a Federal executive agency on the basis described in subsection (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3c6beb0-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/353/s2/a"},"text":"Pub. L. 103–353, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3158"},"text":"108 Stat. 3158","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3c6beb1-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3c6beb2-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc3c6beb3-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4314 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7614"},"text":"section 7614 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3c6beb4-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc3c6beb5-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective with respect to reemployments initiated on or after the first day after the 60-day period beginning ","children":[{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", with transition rules, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/353/s8"},"text":"section 8 of Pub. L. 103–353","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4301"},"text":"section 4301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
