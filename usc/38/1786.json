{"tag":"section","attrib":{"id":"idc311a00b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1786"},"text":null,"children":[{"tag":"num","attrib":{"value":"1786"},"text":"§ 1786.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Care for newborn children of women veterans receiving maternity care","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc311a00c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1786/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (c), the Secretary may furnish health care services described in subsection (b) and transportation necessary to receive such services to a newborn child of a woman veteran who is receiving maternity care furnished by the Department for not more than seven days after the birth of the child if the veteran delivered the child in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc311a00d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1786/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a facility of the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc311a00e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1786/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another facility pursuant to a Department contract for services relating to such delivery; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc311a00f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1786/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another location, including a health care facility, if the veteran delivers the child before arriving at a facility described in paragraph (1) or (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc311a010-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1786/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Health Care Services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Health care services described in this subsection are all post-delivery care services, including routine care services, that a newborn child requires, including necessary health care services provided by a facility other than the facility where the newborn child was delivered (including a specialty pediatric hospital) that accepts transfer of the newborn child and responsibility for treatment of the newborn child.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc311a011-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1786/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception Based on Medical Necessity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Pursuant to such regulations as the Secretary shall prescribe to carry out this section, the Secretary may furnish more than seven days of health care services described in subsection (b), and may furnish transportation necessary to receive such services, to a newborn child based on medical necessity if the child is in need of additional care, including if the child has been discharged or released from a hospital and requires readmittance to ensure the health and welfare of the child.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc311a012-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1786/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transportation","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc311a013-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1786/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transportation furnished under subsection (a) to, from, or between care settings to meet the needs of a newborn child includes costs for either or both the newborn child and parents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc311a014-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1786/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Transportation furnished under subsection (a) includes transportation by ambulance, including air ambulance, or other appropriate medically staffed modes of transportation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc311a015-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1786/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to another health care facility (including a specialty pediatric hospital) that accepts transfer of the newborn child or otherwise provides post-delivery care services when the treating facility is not capable of furnishing the care or services required; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc311a016-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1786/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a health care facility in a medical emergency of such nature that a prudent layperson reasonably expects that delay in seeking immediate medical attention would be hazardous to life or health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc311a017-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1786/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts paid by the Department for transportation under this section shall be derived from the Medical Services appropriations account of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc311a018-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1786/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement or Payment for Health Care Services or Transportation","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc311a019-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1786/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pursuant to regulations the Secretary shall prescribe to establish rates of reimbursement and any limitations thereto under this section, the Secretary shall directly reimburse a covered entity for health care services or transportation services provided under this section, unless the cost of the services or transportation is covered by an established agreement or contract. If such an agreement or contract exists, its negotiated payment terms shall apply.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc311a01a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1786/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc311a01b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1786/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reimbursement or payment by the Secretary under this section on behalf of an individual to a covered entity shall, unless rejected and refunded by the covered entity within 30 days of receipt, extinguish any liability on the part of the individual for the health care services or transportation covered by such payment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc311a01c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1786/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Neither the absence of a contract or agreement between the Secretary and a covered entity nor any provision of a contract, agreement, or assignment to the contrary shall operate to modify, limit, or negate the requirements of subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc311a01d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1786/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this subsection, the term “covered entity” means any individual, transportation carrier, organization, or other entity that furnished or paid for health care services or transportation under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc311a01e-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163/tII/s206/a"},"text":"Pub. L. 111–163, title II, § 206(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-05-05"},"text":"May 5, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1145"},"text":"124 Stat. 1145","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dH/tXCI/s9102"},"text":"Pub. L. 116–283, div. H, title XCI, § 9102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4781"},"text":"134 Stat. 4781","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/315/tIII/s3006/a"},"text":"Pub. L. 116–315, title III, § 3006(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4994"},"text":"134 Stat. 4994","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc311a01f-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc311a020-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc311a021-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1786 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3686"},"text":"section 3686 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 1786, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/358/s3/b"},"text":"Pub. L. 89–358, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-03-03"},"text":"Mar. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/23"},"text":"80 Stat. 23","children":[],"tail":", related to the examination of records, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/92/540/s316/1"},"text":"section 316(1) of Pub. L. 92–540","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3690"},"text":"section 3690 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc311a022-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/s3006/a/1/A"},"text":"Pub. L. 116–315, § 3006(a)(1)(A)","children":[],"tail":", inserted “and transportation necessary to receive such services” after “described in subsection (b)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s9102/1"},"text":"Pub. L. 116–283, § 9102(1)","children":[],"tail":", substituted “Except as provided in subsection (c), the Secretary” for “The Secretary” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/s3006/a/1/B"},"text":"Pub. L. 116–315, § 3006(a)(1)(B)","children":[],"tail":"–(D), added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/s3006/a/2"},"text":"Pub. L. 116–315, § 3006(a)(2)","children":[],"tail":", inserted before period at end “, including necessary health care services provided by a facility other than the facility where the newborn child was delivered (including a specialty pediatric hospital) that accepts transfer of the newborn child and responsibility for treatment of the newborn child”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s9102/2"},"text":"Pub. L. 116–283, § 9102(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/s3006/a/3"},"text":"Pub. L. 116–315, § 3006(a)(3)","children":[],"tail":", added subsecs. (d) and (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc311a023-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc311a024-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Treatment of Certain Expenses Already Incurred","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/315/tIII/s3006/b"},"text":"Pub. L. 116–315, title III, § 3006(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4995"},"text":"134 Stat. 4995","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/315/tIII/s3006/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Pursuant to such regulations as the Secretary of Veterans Affairs shall prescribe, with respect to transportation furnished in order for a newborn child of a veteran to receive health care services under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1786"},"text":"section 1786 of title 38","children":[],"tail":", United States Code, during the period specified in paragraph (2), the Secretary may—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" waive a debt owed by the veteran to the Department of Veterans Affairs or reimburse expenses already paid by the veteran to the Department for such transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reimburse the veteran for expenses already paid by the veteran to a covered entity for such transportation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reimburse a covered entity for the costs of such transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Period specified","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The period specified in this paragraph is the period beginning on ","children":[{"tag":"date","attrib":{"date":"2010-05-05"},"text":"May 5, 2010","children":[],"tail":", and ending on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered entity defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subsection, the term ‘covered entity’ has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1786/e/3"},"text":"section 1786(e)(3) of title 38","children":[],"tail":", United States Code, as added by subsection (a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
