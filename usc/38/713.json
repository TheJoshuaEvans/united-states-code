{"tag":"section","attrib":{"id":"idc290d630-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s713"},"text":null,"children":[{"tag":"num","attrib":{"value":"713"},"text":"§ 713.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Senior executives: removal, demotion, or suspension based on performance or misconduct","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc290d631-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s713/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc290d632-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s713/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may, as provided in this section, reprimand or suspend, involuntarily reassign, demote, or remove a covered individual from a senior executive position at the Department if the Secretary determines that the misconduct or performance of the covered individual warrants such action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc290d633-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s713/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary so removes such an individual, the Secretary may remove the individual from the civil service (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2101"},"text":"section 2101 of title 5","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc290d634-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s713/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rights and Procedures","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc290d635-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s713/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A covered individual who is the subject of an action under subsection (a) is entitled to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc290d636-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s713/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advance notice of the action and a file containing all evidence in support of the proposed action;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc290d637-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s713/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be represented by an attorney or other representative of the covered individual’s choice; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc290d638-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s713/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grieve the action in accordance with an internal grievance process that the Secretary, in consultation with the Assistant Secretary for Accountability and Whistleblower Protection, shall establish for purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc290d639-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s713/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc290d63a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s713/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The aggregate period for notice, response, and decision on an action under subsection (a) may not exceed 15 business days.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc290d63b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s713/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The period for the response of a covered individual to a notice under paragraph (1)(A) of an action under subsection (a) shall be 7 business days.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc290d63c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s713/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A decision under this paragraph on an action under subsection (a) shall be issued not later than 15 business days after notice of the action is provided to the covered individual under paragraph (1)(A). The decision shall be in writing, and shall include the specific reasons therefor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc290d63d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s713/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall ensure that the grievance process established under paragraph (1)(C) takes fewer than 21 days.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc290d63e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s713/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A decision under paragraph (2) that is not grieved, and a grievance decision under paragraph (3), shall be final and conclusive.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc290d63f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s713/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A covered individual adversely affected by a decision under paragraph (2) that is not grieved, or by a grievance decision under paragraph (3), may obtain judicial review of such decision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc290d640-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s713/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In any case in which judicial review is sought under paragraph (5), the court shall review the record and may set aside any Department action found to be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc290d641-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s713/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arbitrary, capricious, an abuse of discretion, or otherwise not in accordance with a provision of law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc290d642-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s713/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtained without procedures required by a provision of law having been followed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc290d643-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s713/b/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unsupported by substantial evidence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc290d644-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s713/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relation to Other Provisions of Law","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3592/b/1"},"text":"Section 3592(b)(1) of title 5","children":[],"tail":" and the procedures under section 7543(b) of such title do not apply to an action under subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc290d645-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s713/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc290d646-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s713/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “covered individual” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc290d647-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s713/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a career appointee (as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3132/a/4"},"text":"section 3132(a)(4) of title 5","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc290d648-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s713/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any individual who occupies an administrative or executive position and who was appointed under section 7306(a), section 7401(1), or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401/4"},"text":"section 7401(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc290d649-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s713/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “misconduct” includes neglect of duty, malfeasance, or failure to accept a directed reassignment or to accompany a position in a transfer of function.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc290d64a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s713/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “senior executive position” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc290d64b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s713/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a career appointee (as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3132/a"},"text":"section 3132(a) of title 5","children":[],"tail":"), a Senior Executive Service position (as such term is defined in such section); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc290d64c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s713/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a covered individual appointed under section 7306(a) or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401/1"},"text":"section 7401(1) of this title","children":[],"tail":", an administrative or executive position."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc290d64d-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/146/tVII/s707/a/1"},"text":"Pub. L. 113–146, title VII, § 707(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-08-07"},"text":"Aug. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1798"},"text":"128 Stat. 1798","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/41/tII/s201/a"},"text":"Pub. L. 115–41, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-06-23"},"text":"June 23, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/868"},"text":"131 Stat. 868","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc290d64e-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc290d64f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc290d650-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 713 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1913"},"text":"section 1913 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc290d651-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/41"},"text":"Pub. L. 115–41","children":[],"tail":" amended section generally. Prior to amendment, section related to removal of senior executives based on performance or misconduct."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc290d652-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc290d653-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/146/tVII/s707/d"},"text":"Pub. L. 113–146, title VII, § 707(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-08-07"},"text":"Aug. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1801"},"text":"128 Stat. 1801","children":[],"tail":", provided a rule of construction related to appeal of a removal, transfer, or other personnel action that was pending before "},{"tag":"date","attrib":{"date":"2014-08-07"},"text":"Aug. 7, 2014","children":[],"tail":", and provided that the authority provided by former "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s713"},"text":"section 713 of this title","children":[],"tail":" would be in addition to the authority provided by section 3592 or subchapter V of chapter 75 of title 5."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc290d654-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Establishment of Expedited Review Process","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/146/tVII/s707/b"},"text":"Pub. L. 113–146, title VII, § 707(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-08-07"},"text":"Aug. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1800"},"text":"128 Stat. 1800","children":[],"tail":", related to the establishment by the Merit Systems Protection Board of a process to conduct expedited reviews in accordance with former subsec. (d) of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc290d655-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Temporary Exemption From Certain Limitation on Initiation of Removal From Senior Executive Service","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/146/tVII/s707/c"},"text":"Pub. L. 113–146, title VII, § 707(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-08-07"},"text":"Aug. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1800"},"text":"128 Stat. 1800","children":[],"tail":", provided for a 120-day exemption, starting on "},{"tag":"date","attrib":{"date":"2014-08-07"},"text":"Aug. 7, 2014","children":[],"tail":", from certain limitations on the initiation of removals from the Senior Executive Service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
