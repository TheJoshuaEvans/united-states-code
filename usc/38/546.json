{"tag":"section","attrib":{"id":"idc28c1bcf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s546"},"text":null,"children":[{"tag":"num","attrib":{"value":"546"},"text":"§ 546.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Committee on Disability Compensation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc28c1bd0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s546/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc28c1bd1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s546/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is in the Department the Advisory Committee on Disability Compensation (in this section referred to as the “Committee”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28c1bd2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s546/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Committee shall consist of not more than 18 members appointed by the Secretary from among individuals who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc28c1bd3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s546/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have experience with the provision of disability compensation by the Department; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc28c1bd4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s546/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are leading medical or scientific experts in relevant fields.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28c1bd5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s546/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc28c1bd6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s546/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subparagraph (B), the Secretary shall determine the terms of service and pay and allowances of the members of the Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc28c1bd7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s546/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A term of service may not exceed four years and shall be staggered to ensure that the dates for the termination of the members’ terms are not all the same.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc28c1bd8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s546/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may reappoint any member for one or more additional terms of service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28c1bd9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s546/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall select a Chair from among the members of the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc28c1bda-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s546/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities of Committee","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc28c1bdb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s546/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall, on a regular basis, consult with and seek the advice of the Committee with respect to the maintenance and periodic readjustment of the schedule for rating disabilities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1155"},"text":"section 1155 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28c1bdc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s546/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc28c1bdd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s546/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In providing advice to the Secretary under this subsection, the Committee shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc28c1bde-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s546/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assemble and review relevant information relating to the needs of veterans with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc28c1bdf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s546/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide information relating to the nature and character of disabilities arising from service in the Armed Forces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc28c1be0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s546/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an on-going assessment of the effectiveness of the schedule for rating disabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc28c1be1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s546/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide on-going advice on the most appropriate means of responding to the needs of veterans relating to disability compensation in the future.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc28c1be2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s546/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out its duties under subparagraph (A), the Committee shall take into special account the needs of veterans who have served in a theater of combat operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc28c1be3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s546/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Resources","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall ensure that appropriate personnel, funding, and other resources are provided to the Committee to carry out its responsibilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc28c1be4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s546/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Biennial Reports to the Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc28c1be5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s546/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"2010-10-31"},"text":"October 31, 2010","children":[],"tail":", and not less frequently than every two years thereafter, the Committee shall submit to the Secretary a report on the programs and activities of the Department that relate to the payment of disability compensation. Each such report shall include—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc28c1be6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s546/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the needs of veterans with respect to disability compensation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc28c1be7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s546/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such recommendations (including recommendations for administrative or legislative action) as the Committee considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28c1be8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s546/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee may submit to the Secretary such other reports and recommendations as the Committee considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc28c1be9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s546/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Biennial Reports to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc28c1bea-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s546/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 90 days after the receipt of a report required under subsection (d)(1), the Secretary shall transmit to the Committee on Veterans’ Affairs of the Senate and the Committee on Veterans’ Affairs of the House of Representatives a copy of such report, together with such comments and recommendations concerning such report as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28c1beb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s546/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall submit with each report required under paragraph (1) a summary of all reports and recommendations of the Committee submitted to the Secretary under subsection (d)(2) since the previous report transmitted by the Secretary under paragraph (1) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc28c1bec-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s546/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of Chapter ","children":[],"tail":"10"},{"tag":"inline","attrib":{},"text":" of Title ","children":[],"tail":"5.—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc28c1bed-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s546/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), the provisions of chapter 10 of title 5 shall apply to the activities of the Committee under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc28c1bee-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s546/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"Section 1013 of title 5","children":[],"tail":" shall not apply to the Committee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc28c1bef-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/389/tII/s214/a"},"text":"Pub. L. 110–389, title II, § 214(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4152"},"text":"122 Stat. 4152","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/218"},"text":"Pub. L. 117–286, § 4(a)(218)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4330"},"text":"136 Stat. 4330","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc28c1bf0-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc28c1bf1-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc28c1bf2-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 560 to 562 were renumbered sections 1560 to 1562 of this title, respectively.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior sections 601 to 603 and 610 to 613 were renumbered sections 1701 to 1703 and 1710 to 1713 of this title, respectively.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 613, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1143"},"text":"72 Stat. 1143","children":[],"tail":", related to fitting and training in use of prosthetic appliances, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/93/82/s103/b"},"text":"section 103(b) of Pub. L. 93–82","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1714/a"},"text":"section 1714(a) of this title","ch