,"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446/s1201/b/1"},"text":"Pub. L. 103–446, § 1201(b)(1)","children":[],"tail":", substituted “Veterans Health Administration” for “Department of Medicine and Surgery” in pars. (1)(B) and (2)(D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s402/b/1"},"text":"Pub. L. 102–40, § 402(b)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4304"},"text":"section 4304 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" substituted “Secretary” for “Administrator” and “Secretary’s” for “Administrator’s” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s403/b/3"},"text":"Pub. L. 102–40, § 403(b)(3)","children":[],"tail":", substituted “7402” for “4105” in par. (1)(B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Pars. (1)(A), (2)(D), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/366"},"text":"Pub. L. 101–366","children":[],"tail":" substituted “subchapters II, III, or V” for “subchapter II or III”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
