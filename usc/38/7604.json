{"tag":"section","attrib":{"id":"idc4130a53-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7604"},"text":null,"children":[{"tag":"num","attrib":{"value":"7604"},"text":"§ 7604.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of agreement","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"An agreement between the Secretary and a participant in the Educational Assistance Program shall be in writing, shall be signed by the participant, and shall include the following provisions:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4130a54-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7604/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary’s agreement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc4130a55-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7604/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide the participant with educational assistance as authorized in subchapter II, III, V, VI, VIII, or IX of this chapter and specified in the agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4130a56-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7604/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to afford the participant the opportunity for employment in the Veterans Health Administration (subject to the availability of appropriated funds for such purpose and other qualifications established in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7402"},"text":"section 7402 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4130a57-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7604/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The participant’s agreement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc4130a58-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7604/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to accept such educational assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4130a59-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7604/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain enrollment and attendance in the course of training until completed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4130a5a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7604/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while enrolled in such course, to maintain an acceptable level of academic standing (as determined by the educational institution offering such course of training under regulations prescribed by the Secretary); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4130a5b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7604/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after completion of the course of training, to serve as a full-time employee in the Veterans Health Administration as specified in the agreement in accordance with subchapter II, III, V, VI, VIII, or IX of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4130a5c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7604/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A provision that any financial obligation of the United States arising out of an agreement entered into under this chapter, and any obligation of the participant which is conditioned on such agreement, is contingent upon funds being appropriated for educational assistance under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4130a5d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7604/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A statement of the damages to which the United States is entitled under this chapter for the participant’s breach of the agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4130a5e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7604/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other terms as are required to be included in the agreement under subchapter II, III, V, VI, VIII, or IX of this chapter or as the Secretary may require consistent with the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc4130a5f-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/322/tII/s216/b"},"text":"Pub. L. 100–322, title II, § 216(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/519"},"text":"102 Stat. 519","children":[],"tail":", § 4304; amended "},{"tag":"ref","attrib":{"hr