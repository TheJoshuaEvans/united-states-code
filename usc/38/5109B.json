{"tag":"section","attrib":{"id":"idc3d05c43-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5109B"},"text":null,"children":[{"tag":"num","attrib":{"value":"5109B"},"text":"§ 5109B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedited treatment of returned and remanded claims","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall take such actions as may be necessary to provide for the expeditious treatment by the Veterans Benefits Administration of any claim that is returned by a higher-level adjudicator under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5104B"},"text":"section 5104B of this title","children":[],"tail":" or remanded by the Board of Veterans’ Appeals."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc3d05c44-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/183/tVII/s707/a/1"},"text":"Pub. L. 108–183, title VII, § 707(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-16"},"text":"Dec. 16, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2672"},"text":"117 Stat. 2672","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/55/s2/k/1"},"text":"Pub. L. 115–55, § 2(k)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-23"},"text":"Aug. 23, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1109"},"text":"131 Stat. 1109","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3d05c45-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3d05c46-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3d05c47-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/55/s2/k/1"},"text":"Pub. L. 115–55, § 2(k)(1)","children":[],"tail":", amended section generally. Prior to amendment, text read as follows: “The Secretary shall take such actions as may be necessary to provide for the expeditious treatment by the appropriate regional office of the Veterans Benefits Administration of any claim that is remanded to a regional office of the Veterans Benefits Administration by the Board of Veterans’ Appeals.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3d05c48-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3d05c49-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/55"},"text":"Pub. L. 115–55","children":[],"tail":" applicable to all claims for which the Secretary of Veterans Affairs provides notice of a decision under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5104"},"text":"section 5104 of this title","children":[],"tail":" on or after the later of 540 days after "},{"tag":"date","attrib":{"date":"2017-08-23"},"text":"Aug. 23, 2017","children":[],"tail":", or 30 days after the date on which the Secretary submits to Congress a certification of certain capabilities of the Department of Veterans Affairs to carry out the new appeals system established by "},{"tag":"ref","attrib":{"href":"/us/pl/115/55"},"text":"Pub. L. 115–55","children":[],"tail":" and to address appeals of decisions on legacy claims, with provision for early applicability of the new appeals system to certain claims, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/55/s2/x"},"text":"section 2(x) of Pub. L. 115–55","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of this title","children":[],"tail":", and bracketed note thereunder."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
