{"tag":"section","attrib":{"id":"idc29591f3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s905"},"text":null,"children":[{"tag":"num","attrib":{"value":"905"},"text":"§ 905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of facilities and services of other law enforcement agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"With the permission of the head of the agency concerned, the Secretary may use the facilities and services of Federal, State, and local law enforcement agencies when it is economical and in the public interest to do so.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc29591f4-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s2/a"},"text":"Pub. L. 102–83, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/399"},"text":"105 Stat. 399","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc29591f5-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc29591f6-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc29591f7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior section 905 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2305"},"text":"section 2305 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s218/e"},"text":"section 218(e) of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s2/a"},"text":"Pub. L. 102–83, § 2(a)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior sections 906 to 908 and 1000 to 1010 were renumbered sections 2306 to 2308 and 2400 to 2410 of this title, respectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
