{"tag":"section","attrib":{"id":"idc4157b44-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7635"},"text":null,"children":[{"tag":"num","attrib":{"value":"7635"},"text":"§ 7635.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service in other agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc4157b45-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7635/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary, with the consent of the participant or individual involved and the consent of the head of the department or agency involved, may permit—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4157b46-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7635/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a period of obligated service required under this chapter to be performed in the Veterans Health Administration to be performed in another Federal department or agency or in the Armed Forces in lieu of performance of such service in the Veterans Health Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc417eb47-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7635/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a period of obligated service required to be performed in another Federal department or agency or in the Armed Forces under another Federal health personnel educational assistance program to be performed in the Veterans Health Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc417eb48-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7635/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall be carried out in cooperation with the heads of other appropriate departments and agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc417eb49-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/322/tII/s216/b"},"text":"Pub. L. 100–322, title II, § 216(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-20"},"text":"May 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/529"},"text":"102 Stat. 529","children":[],"tail":", § 4335; renumbered § 7635, "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/404"},"text":"105 Stat. 404","children":[],"tail":", 405; "},{"tag":"ref","attrib":{"href":"/us/pl/103/446/tXII/s1201/b/1"},"text":"Pub. L. 103–446, title XII, § 1201(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4682"},"text":"108 Stat. 4682","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc417eb4a-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc417eb4b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attr