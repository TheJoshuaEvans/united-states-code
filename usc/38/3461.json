ildren":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1176"},"text":"72 Stat. 1176","children":[],"tail":", which was classified to former sections 1610 and 1611(a), 1611(a)(2), (3), and 1611(b) of this title, respectively, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/89/358/s4/a"},"text":"section 4(a) of Pub. L. 89–358","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc36e8bf9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/233/s503/8/A"},"text":"Pub. L. 109–233, § 503(8)(A)","children":[],"tail":", revised style of headings."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/233/s503/8/B"},"text":"Pub. L. 109–233, § 503(8)(B)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1661"},"text":"section 1661 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “3452(a)(1)(B)” for “1652(a)(1)(B)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466"},"text":"Pub. L. 96–466","children":[],"tail":" substituted “subchapter V of this chapter” for “subchapters V and VI of this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/502"},"text":"Pub. L. 94–502","children":[],"tail":", §§ 203(1), 211(2), 403(a), substituted “45 months” for “36 months”, “the veteran’s” for “his” in two places, and “the veteran” for “he”, inserted provision establishing the final date of entitlement for person serving on active duty on "},{"tag":"date","attrib":{"date":"1976-12-31"},"text":"Dec. 31, 1976","children":[],"tail":" or whose eligibility is based on "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1652/a/1/B"},"text":"section 1652(a)(1)(B) of this title","children":[],"tail":" as the date of discharge or release from active duty after "},{"tag":"date","attrib":{"date":"1976-12-31"},"text":"Dec. 31, 1976","children":[],"tail":", and struck out provision which authorized an additional number of months not exceeding nine to be used for a program leading to a standard undergraduate degree."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/502/s203/2"},"text":"Pub. L. 94–502, § 203(2)","children":[],"tail":", substituted “subsection (b)” for “subsections (a) and (b)” and “45 months” for “thirty-six months”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/508/s202/1"},"text":"Pub. L. 93–508, § 202(1)","children":[],"tail":", inserted “plus an additional number of months, not exceeding nine, as may be utilized in pursuit of a program of education leading to a standard undergraduate college degree”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/508/s202/2"},"text":"Pub. L. 93–508, § 202(2)","children":[],"tail":", inserted reference to subsec. (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/540"},"text":"Pub. L. 92–540","children":[],"tail":" inserted reference to chapter 36."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/219"},"text":"Pub. L. 91–219","children":[],"tail":" substituted “subchapters V and VI of this chapter” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1678"},"text":"section 1678 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/631/s1/b/1"},"text":"Pub. L. 90–631, § 1(b)(1)","children":[],"tail":", substituted references to subsec. (c) and the second sentence of this subsec. for reference to subsec. (b), increased from one month to one and one-half months the amount of educational assistance each eligible veteran shall receive for each month or fraction thereof of active duty service after "},{"tag":"date","attrib":{"date":"1955-01-31"},"text":"Jan. 31, 1955","children":[],"tail":", and inserted provisions that an eligible veteran who has served 18 months or more on active duty after "},{"tag":"date","attrib":{"date":"1955-01-31"},"text":"Jan. 31, 1955","children":[],"tail":", and has been released under conditions that would satisfy his active duty obligation, shall be entitled to educational assistance under this chapter for a period of 36 months."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/631/s1/b/2"},"text":"Pub. L. 90–631, § 1(b)(2)","children":[],"tail":", (3), redesignated subsec. (c) as (b). Former subsec. (b), which set forth entitlement limitations on the amount of educational assistance an eligible veteran, shall receive under this chapter, was struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/631/s1/b"},"text":"Pub. L. 90–631, § 1(b)","children":[],"tail":", (3), (4), added subsec. (c). Former subsec. (c) redesignated (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/631/s1/b/2"},"text":"Pub. L. 90–631, § 1(b)(2)","children":[],"tail":", struck out subsec. (d) which required an eligible veteran to elect either educational assistance or vocational rehabilitation when such veteran is entitled to both, or becomes entitled to vocational rehabilitation after receiving educational assistance."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/77"},"text":"Pub. L. 90–77","children":[],"tail":" inserted “and in section 1678 of this chapter” after “subsection (c)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc36e8bfa-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc36e8bfb-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466"},"text":"Pub. L. 96–466","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-10-01"},"text":"Oct. 1, 1980","children":[],"tail":", except as otherwise specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/96/466/s802/f"},"text":"section 802(f) of Pub. L. 96–466","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5314"},"text":"section 5314 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc36e8bfc-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 