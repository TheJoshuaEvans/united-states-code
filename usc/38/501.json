{"tag":"section","attrib":{"id":"idc2827e9c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s501"},"text":null,"children":[{"tag":"num","attrib":{"value":"501"},"text":"§ 501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2827e9d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary has authority to prescribe all rules and regulations which are necessary or appropriate to carry out the laws administered by the Department and are consistent with those laws, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2827e9e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s501/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulations with respect to the nature and extent of proof and evidence and the method of taking and furnishing them in order to establish the right to benefits under such laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2827e9f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s501/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the forms of application by claimants under such laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2827ea0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s501/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the methods of making investigations and medical examinations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2827ea1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s501/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manner and form of adjudications and awards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2827ea2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any rule, regulation, guideline, or other published interpretation or order (and any amendment thereto) issued pursuant to the authority granted by this section or any other provision of this title shall contain citations to the particular section or sections of statutory law or other legal authority upon which such issuance is based. The citation to the authority shall appear immediately following each substantive provision of the issuance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2827ea3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s501/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In applying ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/a/1"},"text":"section 552(a)(1) of title 5","children":[],"tail":" to the Department, the Secretary shall ensure that subparagraphs (C), (D), and (E) of that section are complied with, particularly with respect to opinions and interpretations of the General Counsel."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2827ea4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s501/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":" shall apply, without regard to subsection (a)(2) of that section, to matters relating to loans, grants, or benefits under a law administered by the Secretary."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2827ea5-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s2/a"},"text":"Pub. L. 102–83, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/386"},"text":"105 Stat. 386","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2827ea6-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc2827ea7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc2827ea8-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior section 501 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1501"},"text":"section 1501 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in sections 210(c)(1) and 223(a), (b) of this title prior to repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s2/a"},"text":"Pub. L. 102–83, § 2(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
