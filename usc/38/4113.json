{"tag":"section","attrib":{"id":"idc3bf92f0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4113"},"text":null,"children":[{"tag":"num","attrib":{"value":"4113"},"text":"§ 4113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transition Assistance Program personnel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3bf92f1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4113/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement to Contract","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1144"},"text":"section 1144 of title 10","children":[],"tail":", the Secretary shall enter into a contract with an appropriate private entity or entities to provide the functions described in subsection (b) at all locations where the program described in such section is carried out."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3bf92f2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4113/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Functions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Contractors under subsection (a) shall provide to members of the Armed Forces who are being separated from active duty (and the spouses of such members) the services described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1144/a/1"},"text":"section 1144(a)(1) of title 10","children":[],"tail":", including the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3bf92f3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s4113/b/1"},"text":null,"children":[{"tag":