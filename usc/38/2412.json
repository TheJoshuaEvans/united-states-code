{"tag":"section","attrib":{"id":"idc3486712-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2412"},"text":null,"children":[{"tag":"num","attrib":{"value":"2412"},"text":"§ 2412.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lease of land and buildings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3486713-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2412/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lease Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may lease any undeveloped land and unused or underutilized buildings, or parts or parcels thereof, belonging to the United States and part of the National Cemetery Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3486714-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2412/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Term","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term of a lease under subsection (a) may not exceed 10 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3486715-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2412/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lease to Public or Nonprofit Organizations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3486716-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2412/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A lease under subsection (a) to any public or nonprofit organization may be made without regard to the provisions of section 3709 of the Revised Statutes (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s5"},"text":"41 U.S.C. 5","children":[],"tail":")."},{"tag":"ref","attrib":{"idref":"fn002047"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002047"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3486717-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2412/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s1302"},"text":"section 1302 of title 40","children":[],"tail":" or any other provision of law, a lease under subsection (a) to any public or nonprofit organization may provide for the maintenance, protection, or restoration of the leased property by the lessee, as a part or all of the consideration for the lease."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3486718-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2412/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before entering into a lease under subsection (a), the Secretary shall give appropriate public notice of the intention of the Secretary to enter into the lease in a newspaper of general circulation in the community in which the lands or buildings concerned are located.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3486719-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2412/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National Cemetery Administration Facilities Operation Fund","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc348671a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2412/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is established on the book of the Treasury an account to be known as the “National Cemetery Administration Facilities Operation Fund” (in this section referred to as the “Fund”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc348671b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2412/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Fund shall consist of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc348671c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2412/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Proceeds from the lease of land or buildings under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc348671d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2412/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Proceeds of agricultural licenses of lands of the National Cemetery Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc348671e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2412/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other amounts appropriated to or otherwise authorized for deposit in the Fund by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc348671f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2412/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts in the Fund shall be available to cover costs incurred by the National Cemetery Administration in the operation and maintenance of property of the Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3486720-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2412/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts in the Fund shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3486721-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/454/tVI/s602/a"},"text":"Pub. L. 108–454, title VI, § 602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-10"},"text":"Dec. 10, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3623"},"text":"118 Stat. 3623","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3486722-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3486723-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc3486724-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 3709 of the Revised Statutes, referred to in subsec. (c)(1), was classified to section 5 of former Title 41, Public Contracts, and was repealed and restated in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s6101"},"text":"section 6101 of Title 41","children":[],"tail":", Public Contracts, by "},{"tag":"ref","attrib":{"href":"/us/pl/111/350"},"text":"Pub. L. 111–350","children":[],"tail":", §§ 3, 7(b), "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3677"},"text":"124 Stat. 3677","children":[],"tail":", 3855."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
