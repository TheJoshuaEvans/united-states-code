{"tag":"section","attrib":{"id":"idc3ef54f9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7261"},"text":null,"children":[{"tag":"num","attrib":{"value":"7261"},"text":"§ 7261.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3ef54fa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7261/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In any action brought under this chapter, the Court of Appeals for Veterans Claims, to the extent necessary to its decision and when presented, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3ef54fb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7261/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" decide all relevant questions of law, interpret constitutional, statutory, and regulatory provisions, and determine the meaning or applicability of the terms of an action of the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ef54fc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7261/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compel action of the Secretary unlawfully withheld or unreasonably delayed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ef54fd-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7261/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" hold unlawful and set aside decisions, findings (other than those described in clause (4) of this subsection), conclusions, rules, and regulations issued or adopted by the Secretary, the Board of Veterans’ Appeals, or the Chairman of the Board found to be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3ef54fe-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7261/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arbitrary, capricious, an abuse of discretion, or otherwise not in accordance with law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3ef54ff-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7261/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contrary to constitutional right, power, privilege, or immunity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3ef5500-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7261/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in excess of statutory jurisdiction, authority, or limitations, or in violation of a statutory right; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3ef5501-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7261/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without observance of procedure required by law; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ef5502-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7261/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a finding of material fact adverse to the claimant made in reaching a decision in a case before the Department with respect to benefits under laws administered by the Secretary, hold unlawful and set aside or reverse such finding if the finding is clearly erroneous.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3ef5503-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7261/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In making the determinations under subsection (a), the Court shall review the record of proceedings before the Secretary and the Board of Veterans’ Appeals pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7252/b"},"text":"section 7252(b) of this title","children":[],"tail":" and shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3ef5504-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7261/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take due account of the Secretary’s application of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5107/b"},"text":"section 5107(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3ef5505-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7261/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take due account of the rule of prejudicial error.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3ef5506-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7261/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In no event shall findings of fact made by the Secretary or the Board of Veterans’ Appeals be subject to trial de novo by the Court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3ef5507-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7261/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When a final decision of the Board of Veterans’ Appeals is adverse to a party and the sole stated basis for such decision is the failure of the party to comply with any applicable regulation prescribed by the Secretary, the Court shall review only questions raised as to compliance with and the validity of the regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3ef5508-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/687/dA/tIII/s301/a"},"text":"Pub. L. 100–687, div. A, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4115"},"text":"102 Stat. 4115","children":[],"tail":", § 4061; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tVI/s602/c"},"text":"Pub. L. 101–237, title VI, § 602(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2095"},"text":"103 Stat. 2095","children":[],"tail":"; renumbered § 7261, "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s402/b/1"},"text":"Pub. L. 102–40, title IV, § 402(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/238"},"text":"105 Stat. 238","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/54/s14/e/3"},"text":"Pub. L. 102–54, § 14(e)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-06-13"},"text":"June 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/287"},"text":"105 Stat. 287","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/1"},"text":"Pub. L. 102–83, § 4(a)(1)","children":[],"tail":", (3), (4), (b)(1), (2)(E), "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/403-405"},"text":"105 Stat. 403–405","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/368/tV/s512/a/1"},"text":"Pub. L. 105–368, title V, § 512(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3341"},"text":"112 Stat. 3341","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/330/tIV/s401/a"},"text":"Pub. L. 107–330, title IV, § 401(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2002-12-06"},"text":"Dec. 6, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2832"},"text":"116 Stat. 2832","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3ef5509-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3ef550a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3ef550b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/330/s401/a"},"text":"Pub. L. 107–330, § 401(a)","children":[],"tail":", inserted “adverse to the claimant” after “material fact” and “or reverse” after “and set aside”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/330/s401/b"},"text":"Pub. L. 107–330, § 401(b)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “In making the determinations under subsection (a) of this section, the Court shall take due account of the rule of prejudicial error.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368"},"text":"Pub. L. 105–368","children":[],"tail":" substituted “Court of Appeals for Veterans Claims” for “Court of Veterans Appeals” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4061"},"text":"section 4061 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1) to (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/3"},"text":"Pub. L. 102–83, § 4(a)(3)","children":[],"tail":", (4), substituted “Department” for “Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/a/1"},"text":"Pub. L. 102–83, § 4(a)(1)","children":[],"tail":", substituted “administered by the Secretary” for “administered by the Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/54"},"text":"Pub. L. 102–54","children":[],"tail":" amended subsec. (c) as in effect immediately before the enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":" by substituting “Court” for “court”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s4/b/1"},"text":"Pub. L. 102–83, § 4(b)(1)","children":[],"tail":", (2)(E), substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" inserted “or unreasonably delayed” after “withheld”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3ef550c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3ef550d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/330/tIV/s401/c"},"text":"Pub. L. 107–330, title IV, § 401(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-06"},"text":"Dec. 6, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2832"},"text":"116 Stat. 2832","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/330/tIV/s401/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), the amendments made by this section [amending this section] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2002-12-06"},"text":"Dec. 6, 2002","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments made by this section shall apply with respect to any case pending for decision before the United States Court of Appeals for Veterans Claims other than a case in which a decision has been entered before the date of the enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3ef550e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368"},"text":"Pub. L. 105–368","children":[],"tail":" effective on first day of first month beginning more than 90 days after "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/368/s513"},"text":"section 513 of Pub. L. 105–368","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7251"},"text":"section 7251 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
