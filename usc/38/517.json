{"tag":"section","attrib":{"id":"idc284ef42-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s517"},"text":null,"children":[{"tag":"num","attrib":{"value":"517"},"text":"§ 517.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quarterly reports to Congress on conferences sponsored by the Department","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc284ef43-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s517/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Quarterly Reports Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days after the end of each fiscal quarter, the Secretary shall submit to the Committee on Veterans’ Affairs of the Senate and the Committee on Veterans’ Affairs of the House of Representatives a report on covered conferences.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc284ef44-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s517/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Matters Included","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under subsection (a) shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc284ef45-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s517/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An accounting of the final costs to the Department of each covered conference occurring during the fiscal quarter preceding the date on which the report is submitted, including the costs related to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc284ef46-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s517/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transportation and parking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc284ef47-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s517/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" per diem payments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc284ef48-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s517/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lodging;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc284ef49-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s517/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rental of halls, auditoriums, or other spaces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc284ef4a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s517/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rental of equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc284ef4b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s517/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refreshments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc284ef4c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s517/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entertainment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc284ef4d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s517/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contractors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc284ef4e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s517/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" brochures or other printed media.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc284ef4f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s517/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total estimated costs to the Department for covered conferences occurring during the fiscal quarter in which the report is submitted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc284ef50-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s517/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Conference Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “covered conference” means a conference, meeting, or other similar forum that is sponsored or co-sponsored by the Department and is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc284ef51-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s517/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attended by 50 or more individuals, including one or more employees of the Department; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc284ef52-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s517/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimated to cost the Department at least $20,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc284ef53-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/154/tVII/s707/a"},"text":"Pub. L. 112–154, title VII, § 707(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":", 126 Stat.1206.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc284ef54-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc284ef55-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc284ef56-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/154/tVII/s707/c"},"text":"Pub. L. 112–154, title VII, § 707(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1207"},"text":"126 Stat. 1207","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/154/tVII/s707/c"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s517"},"text":"Section 517 of title 38","children":[],"tail":", United States Code, as added by subsection (a), shall take effect on "},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"October 1, 2012","children":[],"tail":", and shall apply with respect to the first quarter of fiscal year 2013 and each quarter thereafter.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
