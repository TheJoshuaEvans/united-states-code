{"tag":"section","attrib":{"id":"idc4072370-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405"},"text":null,"children":[{"tag":"num","attrib":{"value":"7405"},"text":"§ 7405.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary full-time appointments, part-time appointments, and without-compensation appointments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc4072371-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary, upon the recommendation of the Under Secretary for Health, may employ, without regard to civil service or classification laws, rules, or regulations, personnel as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc4072372-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" On a temporary full-time basis, part-time basis, or without compensation basis, persons in the following positions:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc4072373-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Positions listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401/1"},"text":"section 7401(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4072374-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Positions listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401/3"},"text":"section 7401(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4072375-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Librarians.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4072376-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other professional, clerical, technical, and unskilled personnel (including interns, residents, trainees, and students in medical support programs).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4072377-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" On a fee basis, persons in the following positions:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc4072378-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Positions listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401/1"},"text":"section 7401(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4072379-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Positions listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401/3"},"text":"section 7401(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc407237a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other professional and technical personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc407237b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Personnel employed under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc407237c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be in addition to personnel described in section 7306, paragraphs (1) and (3) of section 7401, and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7408"},"text":"section 7408 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc407237d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be paid such rates of pay as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc407237e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc407237f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Temporary full-time appointments under this section of persons in positions listed in paragraphs (1) and (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401"},"text":"section 7401 of this title","children":[],"tail":" may be for a period in excess of 90 days only if the Under Secretary for Health finds that circumstances render it impracticable to obtain the necessary services through appointments under that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4072380-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A temporary full-time appointment may not be made for a period in excess of two years in the case of a person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc4072381-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has successfully completed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc4072382-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a full course of nursing in a recognized school of nursing, approved by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc4072383-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a full course of training for any category of personnel described in paragraph (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401"},"text":"section 7401 of this title","children":[],"tail":", or as a physician assistant, in a recognized education or training institution approved by the Secretary; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4072384-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is pending registration or licensure in a State or certification by a national board recognized by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4072385-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc4072386-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Temporary full-time appointments of persons in positions referred to in subsection (a)(1)(D) shall not exceed three years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4072387-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Temporary full-time appointments under this paragraph may be renewed for one or more additional periods not in excess of three years each.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4072388-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Temporary full-time appointments of other personnel may not be for a period in excess of one year except as authorized in subsection (f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4072389-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A part-time appointment may not be for a period of more than one year, except for appointments of persons specified in subsection (a)(1)(A) and interns, residents, and other trainees in medical support programs and except as authorized in subsection (f).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc407238a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A student who has a temporary appointment under this section and who is pursuing a full course of nursing in a recognized school of nursing approved by the Secretary, or who is pursuing a full course of training for any category of personnel described in paragraph (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401"},"text":"section 7401 of this title","children":[],"tail":" in a recognized education or training institution approved by the Secretary, may be reappointed for a period not to exceed the duration of the student’s academic program."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc407238b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" During any period during which the Secretary is exercising the authority provided in subsections (a) and (f)(1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7403"},"text":"section 7403 of this title","children":[],"tail":" in connection with the appointment, under paragraph (3) of "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401"},"text":"section 7401 of this title","children":[],"tail":", of personnel in a category of personnel described in such paragraph—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc407238c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary may make temporary full-time appointments of personnel in such category for periods exceeding 90 days if the Under Secretary for Health finds that circumstances render it impractical to obtain the necessary services through appointments under paragraph (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401"},"text":"section 7401 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc407238d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" part-time appointments of personnel in such category may be for periods of more than one year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc407238e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc407238f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (3), employment of a registered nurse on a temporary part-time basis under subsection (a)(1) shall be for a probationary period of two years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4072390-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in paragraph (3), upon completion by a registered nurse of the probationary period described in paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc4072391-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the employment of such nurse shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc4072392-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/g/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no longer be considered temporary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc4072393-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/g/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be considered an appointment described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7403/a"},"text":"section 7403(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4072394-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nurse shall be considered to have served the probationary period required by section 7403(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc4072395-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This subsection shall not apply to appointments made on a term limited basis of less than or equal to three years of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc4072396-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nurses with a part-time appointment resulting from an academic affiliation or teaching position in a nursing academy of the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4072397-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nurses appointed as a result of a specific research proposal or grant; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc4072398-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7405/g/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nurses who are not citizens of the United States and appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7407/a"},"text":"section 7407(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc4072399-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s401/b/2"},"text":"Pub. L. 102–40, title IV, § 401(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/226"},"text":"105 Stat. 226","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/405/tIII/s302/c/1"},"text":"Pub. L. 102–405, title III, § 302(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-09"},"text":"Oct. 9, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1984"},"text":"106 Stat. 1984","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/419/tII/s204"},"text":"Pub. L. 106–419, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1842"},"text":"114 Stat. 1842","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/170/tIII/s301/c"},"text":"Pub. L. 108–170, title III, § 301(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2057"},"text":"117 Stat. 2057","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/163/tVI/s601/c"},"text":"Pub. L. 111–163, title VI, § 601(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-05-05"},"text":"May 5, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1168"},"text":"124 Stat. 1168","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc407239a-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc407239b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc407239c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4114/a"},"text":"section 4114(a) of this title","children":[],"tail":" prior to the repeal of that section as part of the complete revision of chapter 73 of this title by "},{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc407239d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/163"},"text":"Pub. L. 111–163","children":[],"tail":" added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (a)(1)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/170/s301/c/1/A"},"text":"Pub. L. 108–170, § 301(c)(1)(A)","children":[],"tail":", added subpars. (B) and (C) and struck out former subpars. (B) and (C) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) Certified or registered respiratory therapists, licensed physical therapists, licensed practical or vocational nurses, pharmacists, and occupational therapists.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) Dietitians, social workers, and librarians.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/170/s301/c/1/B"},"text":"Pub. L. 108–170, § 301(c)(1)(B)","children":[],"tail":", added subpar. (B) and struck out former subpar. (B) which read as follows: “Certified or registered respiratory therapists, licensed physical therapists, licensed practical or vocational nurses, pharmacists, and occupational therapists.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/170/s301/c/2"},"text":"Pub. L. 108–170, § 301(c)(2)","children":[],"tail":", substituted “paragraphs (1) and (3) of section 7401” for “section 7401(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/419/s204/a"},"text":"Pub. L. 106–419, § 204(a)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “Temporary full-time appointments of persons who have successfully completed a full course of nursing in a recognized school of nursing, approved by the Secretary, or who have successfully completed a full course of training for any category of personnel described in paragraph (3) of "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7401"},"text":"section 7401 of this title","children":[],"tail":" in a recognized education or training institution approved by the Secretary, and who are pending registration or licensure in a State, or certification by a national board recognized by the Secretary, shall not exceed two years.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/419/s204/b"},"text":"Pub. L. 106–419, § 204(b)","children":[],"tail":", added par. (3) and redesignated former par. (3) as (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsecs. (a), (c)(1), (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/405"},"text":"Pub. L. 102–405","children":[],"tail":" substituted “Under Secretary for Health” for “Chief Medical Director”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc407239e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc407239f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Recruitment of Mental Health Providers for Furnishing Mental Health Services on Behalf of the Department of Veterans Affairs Without Compensation From the Department","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tVII/s729"},"text":"Pub. L. 112–239, div. A, title VII, § 729","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1813"},"text":"126 Stat. 1813","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/239/dA/tVII/s729"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Veterans Affairs shall carry out a national program of outreach to societies, community organizations, nonprofit organizations, and government entities in order to recruit mental health providers who meet the quality standards and requirements of the Department of Veterans Affairs to provide mental health services for the Department on a part-time, without-compensation basis, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7405"},"text":"section 7405 of title 38","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Partnering With and Developing Community Entities and Nonprofit Organizations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out the program required by subsection (a), the Secretary may partner with a community entity or nonprofit organization or assist in the development of a community entity or nonprofit organization, including by entering into an agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s8153"},"text":"section 8153 of title 38","children":[],"tail":", United States Code, that provides strategic coordination of the societies, organizations, and government entities described in subsection (a) in order to maximize the availability and efficient delivery of mental health services to veterans by such societies, organizations, and government entities."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Military Culture Training","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out the program required by subsection (a), the Secretary shall provide training to mental health providers to ensure that clinicians who provide mental health services as described in such subsection have sufficient understanding of military-specific and service-specific culture, combat experience, and other factors that are unique to the experience of veterans who served in Operation Enduring Freedom, Operating Iraqi Freedom, or Operation New Dawn.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
