{"tag":"section","attrib":{"id":"idc2ad5f59-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1156"},"text":null,"children":[{"tag":"num","attrib":{"value":"1156"},"text":"§ 1156.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary disability ratings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc2ad5f5a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1156/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assignment of Temporary Ratings","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2ad5f5b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1156/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purpose of providing disability compensation under this chapter to veterans, the Secretary shall assign a temporary disability rating to a veteran as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2ad5f5c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1156/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To a veteran who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc2ad5f5d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1156/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was discharged or released from active duty not more than 365 days before the date such veteran submits a claim for disability compensation under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc2ad5f5e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1156/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has one or more disabilities for which a rating of total is not immediately assignable—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc2ad5f5f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1156/a/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under the regular provisions of the schedule of ratings; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc2ad5f60-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1156/a/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the basis of individual unemployability; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc2ad5f61-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1156/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has one or more—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc2ad5f62-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1156/a/1/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" severe disabilities that result in substantially gainful employment not being feasible or advisable; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc2ad5f63-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1156/a/1/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" healed, unhealed, or incompletely healed wounds or injuries that make material impairment of employability likely.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2ad5f64-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1156/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To a veteran who, as a result of a highly stressful in-service event, has a mental disorder that is severe enough to bring about the veteran’s discharge or release from active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2ad5f65-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1156/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To a veteran who has a service-connected disability that requires hospital treatment or observation in a Department of Veterans Affairs or approved hospital for a period in excess of 21 days.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2ad5f66-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1156/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To a veteran who has a service-connected disability that has required convalescent care or treatment at hospital discharge (regular discharge or release to non-bed care) or outpatient release that meets the requirements of regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2ad5f67-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1156/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to a veteran described in paragraph (1)(A), the Secretary may assign a temporary disability rating to such veteran regardless of whether such veteran has obtained a medical examination or a medical opinion concerning such veteran’s disability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2ad5f68-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1156/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to a veteran described in paragraph (1)(B), the Secretary shall schedule a medical examination for such veteran not later than six months after the separation or discharge of such veteran from active duty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2ad5f69-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1156/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Temporary Disability Ratings","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2ad5f6a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1156/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in paragraph (2), a temporary disability rating assigned to a veteran under this section shall remain in effect as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2ad5f6b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1156/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For a veteran who is assigned a temporary disability rating under subsection (a)(1)(A), until the later of the date that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc2ad5f6c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1156/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 12 months after the date of discharge or release from active duty; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc2ad5f6d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1156/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provided in regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2ad5f6e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1156/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For a veteran who is assigned a temporary disability rating under subsection (a)(1)(B), until the date on which a rating decision is issued to such veteran following the medical examination scheduled under subsection (a)(3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2ad5f6f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1156/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For a veteran who is assigned a temporary disability rating under subsection (a)(1)(C), until the later of the date that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc2ad5f70-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1156/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the last day of the month in which the veteran is discharged from the hospital as described in such subsection (a)(1)(C); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc2ad5f71-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1156/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provided in regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2ad5f72-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1156/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For a veteran who is assigned a temporary disability rating under subsection (a)(1)(D), until the date that is provided in regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2ad5f73-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1156/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may extend a temporary disability rating assigned to a veteran under subsection (a) beyond the applicable termination date under paragraph (1) if the Secretary determines that such an extension is appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2ad5f74-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1156/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall prescribe regulations to carry out the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc2ad5f75-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1156/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to preclude the Secretary from providing a temporary disability rating under an authority other than this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2ad5f76-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/389/tII/s211/a"},"text":"Pub. L. 110–389, title II, § 211(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4149"},"text":"122 Stat. 4149","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2ad5f77-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc2ad5f78-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc2ad5f79-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior to renumbering of sections 301 to 363 of this chapter as sections 1101 to 1163 by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":", section 356 of this chapter, "},{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1125"},"text":"72 Stat. 1125","children":[],"tail":", which provided for a minimum rating for veterans with arrested tuberculosis, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/90/493/s4"},"text":"Pub. L. 90–493, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-19"},"text":"Aug. 19, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/809"},"text":"82 Stat. 809","children":[],"tail":", but repeal not applicable in case of veteran who on "},{"tag":"date","attrib":{"date":"1968-08-19"},"text":"Aug. 19, 1968","children":[],"tail":", was receiving or entitled to receive compensation for tuberculosis which in the judgment of the Administrator had reached a condition of complete arrest."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc2ad5f7a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc2ad5f7b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/389/tII/s211/b"},"text":"Pub. L. 110–389, title II, § 211(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4151"},"text":"122 Stat. 4151","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/389/tII/s211/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1156/a/1"},"text":"Section 1156(a)(1) of title 38","children":[],"tail":", United States Code, as added by subsection (a), shall apply with respect to a veteran who is discharged or released from active duty (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of title 38","children":[],"tail":", United States Code) on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc2ad5f7c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Department of Veterans Affairs Automatic Processing of Certain Claims for Temporary Disability Ratings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/210/tIII/s307"},"text":"Pub. L. 118–210, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-02"},"text":"Jan. 2, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2794"},"text":"138 Stat. 2794","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/210/tIII/s307"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than one year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2025-01-02"},"text":"Jan. 2, 2025","children":[],"tail":"], the Secretary of Veterans Affairs shall modify the information technology systems of the Department of Veterans Affairs to use automation technology for claims for temporary disability ratings for veterans described in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1156/a/1/C"},"text":"section 1156(a)(1)(C) of title 38","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (a), the Secretary shall ensure that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medical evidence is obtained from the corporate data warehouse of the Department or other sources of data, the Secretary determines appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employees of the Department continue to determine whether a veteran is entitled to a temporary disability rating under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1156/a/1/C"},"text":"section 1156(a)(1)(C) of title 38","children":[],"tail":", United States Code; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" claims may be processed manually if the evidence of record is not sufficient to decide the claim or if the medical evidence is provided in a format that is not compatible with the system developed under subsection (a).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
