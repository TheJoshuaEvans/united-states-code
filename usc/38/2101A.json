{"tag":"section","attrib":{"id":"idc33a0ede-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2101A"},"text":null,"children":[{"tag":"num","attrib":{"value":"2101A"},"text":"§ 2101A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for benefits and assistance: members of the Armed Forces with service-connected disabilities; individuals residing outside the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc33a0edf-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2101A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Members With Service-Connected Disabilities","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc33a0ee0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2101A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may provide assistance under this chapter to a member of the Armed Forces serving on active duty who is suffering from a disability that meets applicable criteria for benefits under this chapter if the disability is incurred or aggravated in line of duty in the active military, naval, air, or space service. Such assistance shall be provided to the same extent as assistance is provided under this chapter to veterans eligible for assistance under this chapter and subject to the same requirements as veterans under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc33a0ee1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2101A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this chapter, any reference to a veteran or eligible individual shall be treated as a reference to a member of the Armed Forces described in subsection (a) who is similarly situated to the veteran or other eligible individual so referred to.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc33a0ee2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2101A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Benefits and Assistance for Individuals Residing Outside the United States","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc33a0ee3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2101A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2), the Secretary may, at the Secretary’s discretion, provide benefits and assistance under this chapter (other than benefits under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2106"},"text":"section 2106 of this title","children":[],"tail":") to any individual otherwise eligible for such benefits and assistance who resides outside the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc33a0ee4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2101A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may provide benefits and assistance to an individual under paragraph (1) only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc33a0ee5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2101A/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the country or political subdivision in which the housing or residence involved is or will be located permits the individual to have or acquire a beneficial property interest (as determined by the Secretary) in such housing or residence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc33a0ee6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2101A/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual has or will acquire a beneficial property interest (as so determined) in such housing or residence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc33a0ee7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2101A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subsections (a) and (b), this section shall not apply to the provision of assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2102B"},"text":"section 2102B of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc33a0ee8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s2101A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Benefits and assistance under this chapter by reason of this section shall be provided in accordance with such regulations as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc33a0ee9-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/dB/tVI/s2602/a"},"text":"Pub. L. 110–289, div. B, title VI, § 2602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2858"},"text":"122 Stat. 2858","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/177/s1/c/2"},"text":"Pub. L. 115–177, § 1(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-01"},"text":"June 1, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1377"},"text":"132 Stat. 1377","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s926/a/34"},"text":"Pub. L. 116–283, div. A, title IX, § 926(a)(34)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3830"},"text":"134 Stat. 3830","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc33a0eea-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc33a0eeb-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc33a0eec-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “air, or space service” for “or air service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/177"},"text":"Pub. L. 115–177","children":[],"tail":" added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
