{"tag":"section","attrib":{"id":"idc369d141-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3315A"},"text":null,"children":[{"tag":"num","attrib":{"value":"3315A"},"text":"§ 3315A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National tests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc369d142-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3315A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual entitled to educational assistance under this chapter shall also be entitled to educational assistance for the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc369d143-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3315A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A national test for admission to an institution of higher learning as described in the last sentence of section 3452(b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc369d144-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3315A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A national test providing an opportunity for course credit at an institution of higher learning as so described.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc369d145-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3315A/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A national test that evaluates prior learning and knowledge and provides an opportunity for course credit at an institution of higher learning as so described.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc369d146-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3315A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of educational assistance payable under this chapter for a test described in subsection (a) is the lesser of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc369d147-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3315A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fee charged for the test; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc369d148-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3315A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of entitlement available to the individual under this chapter at the time of payment for the test under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc369d149-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3315A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Charge Against Entitlement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The number of months of entitlement charged an individual under this chapter for a test described in subsection (a) shall be pro-rated based on the actual amount of the fee charged for the test relative to the rate for 1 month payable—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc369d14a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3315A/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the academic year beginning on ","children":[{"tag":"date","attrib":{"date":"2011-08-01"},"text":"August 1, 2011","children":[],"tail":", $1,460; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc369d14b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3315A/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for an academic year beginning on any subsequent August 1, the amount for the previous academic year beginning on August 1 under this subsection, as increased by the percentage increase equal to the most recent percentage increase determined under section 3015(h).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc369d14c-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/377/tI/s108/a/1"},"text":"Pub. L. 111–377, title I, § 108(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4118"},"text":"124 Stat. 4118","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/48/tI/s108/b"},"text":"Pub. L. 115–48, title I, § 108(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-16"},"text":"Aug. 16, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/978"},"text":"131 Stat. 978","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc369d14d-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc369d14e-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc369d14f-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/48/s108/b/1"},"text":"Pub. L. 115–48, § 108(b)(1)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/48/s108/b/2"},"text":"Pub. L. 115–48, § 108(b)(2)","children":[],"tail":", in introductory provisions, substituted “shall be pro-rated based on the actual amount of the fee charged for the test relative to the rate for 1 month payable” for “shall be determined at the rate of one month (rounded to the nearest whole month) for each amount paid that equals”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc369d150-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc369d151-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/48"},"text":"Pub. L. 115–48","children":[],"tail":" applicable to a test taken on or after "},{"tag":"date","attrib":{"date":"2018-08-01"},"text":"Aug. 1, 2018","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/48/s108/d"},"text":"section 108(d) of Pub. L. 115–48","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3315"},"text":"section 3315 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc369d152-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/377/tI/s108/b"},"text":"Pub. L. 111–377, title I, § 108(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4119"},"text":"124 Stat. 4119","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/377/tI/s108/b"},"text":"“The amendments made by this section [enacting this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2011-08-01"},"text":"August 1, 2011","children":[],"tail":", and shall apply with respect to national tests taken on or after that date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
