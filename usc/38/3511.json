3428, 3468; "},{"tag":"ref","attrib":{"href":"/us/pl/115/48/tII/s202"},"text":"Pub. L. 115–48, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-16"},"text":"Aug. 16, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/989"},"text":"131 Stat. 989","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc378297f-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3782980-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3782981-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/48"},"text":"Pub. L. 115–48","children":[],"tail":" substituted “chapter—” for “chapter for an aggregate period not in excess of 45 months (or to the equivalent thereof in part-time training)” and added subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461/s1006/b"},"text":"Pub. L. 109–461, § 1006(b)","children":[],"tail":", provided that as of the enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/109/461"},"text":"Pub. L. 109–461","children":[],"tail":", the amendments made by "},{"tag":"ref","attrib":{"href":"/us/pl/109/444"},"text":"Pub. L. 109–444","children":[],"tail":" were deemed for all purposes not to have taken effect and that "},{"tag":"ref","attrib":{"href":"/us/pl/109/444"},"text":"Pub. L. 109–444","children":[],"tail":" ceased to be in effect. See Amendment notes below and "},{"tag":"ref","attrib":{"href":"/us/pl/109/461/s1006/b"},"text":"section 1006(b) of Pub. L. 109–461","children":[],"tail":", set out as a Coordination of Provisions With "},{"tag":"ref","attrib":{"href":"/us/pl/109/444"},"text":"Pub. L. 109–444","children":[],"tail":" note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461/s301/b/2/A"},"text":"Pub. L. 109–461, § 301(b)(2)(A)","children":[],"tail":", substituted “Each eligible person, whether made eligible by one or more of the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3501/a/1"},"text":"section 3501(a)(1) of this title","children":[],"tail":",” for “Each eligible person” and “an aggregate period” for “a period” in first sentence and struck out second sentence, which read as follows: “In no event may the aggregate educational assistance afforded to a spouse made eligible under both sections 3501(a)(1)(D)(i) and 3501(a)(1)(D)(ii) of this title exceed 45 months.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/444/s3/b/2/A"},"text":"Pub. L. 109–444, § 3(b)(2)(A)","children":[],"tail":", which substituted “Each eligible person, whether made eligible by one or more of the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3501/a/1"},"text":"section 3501(a)(1) of this title","children":[],"tail":",” for “Each eligible person” and “an aggregate period” for “a period” in first sentence and struck out second sentence, was terminated by "},{"tag":"ref","attrib":{"href":"/us/pl/109/461/s1006/b"},"text":"Pub. L. 109–461, § 1006(b)","children":[],"tail":". See Amendment notes above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/233"},"text":"Pub. L. 109–233","children":[],"tail":" inserted “sections” after “under both”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461/s302/a"},"text":"Pub. L. 109–461, § 302(a)","children":[],"tail":", inserted “or of being involuntarily ordered to full-time National Guard duty under "},{"tag":"ref","attrib":{"href":"/us/usc/t32/s502/f"},"text":"section 502(f) of title 32","children":[],"tail":"” after “title 10”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461/s301/b/2/B/i"},"text":"Pub. L. 109–461, § 301(b)(2)(B)(i)","children":[],"tail":", substituted “section” for “the provisions of section 3501(a)(1)(A)(iii) or” and struck out “or” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/444/s3/b/2/B/i"},"text":"Pub. L. 109–444, § 3(b)(2)(B)(i)","children":[],"tail":", which substituted “section” for “the provisions of section 3501(a)(1)(A)(iii) or” and struck out “or” at end, was terminated by "},{"tag":"ref","attrib":{"href":"/us/pl/109/461/s1006/b"},"text":"Pub. L. 109–461, § 1006(b)","children":[],"tail":". See Amendment notes above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461/s301/b/2/B/ii"},"text":"Pub. L. 109–461, § 301(b)(2)(B)(ii)","children":[],"tail":", substituted “subparagraph (D) or (E) of section 3501(a)(1)” for “section 3501(a)(1)(D)” and inserted “or” after comma at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/444/s3/b/2/B/ii"},"text":"Pub. L. 109–444, § 3(b)(2)(B)(ii)","children":[],"tail":", which substituted “subparagraph (D) or (E) of section 3501(a)(1)” for “section 3501(a)(1)(D)” and inserted “or” after comma at end, was terminated by "},{"tag":"ref","attrib":{"href":"/us/pl/109/461/s1006/b"},"text":"Pub. L. 109–461, § 1006(b)","children":[],"tail":". See Amendment notes above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461/s301/b/2/B/iii"},"text":"Pub. L. 109–461, § 301(b)(2)(B)(iii)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/444/s3/b/2/B/iii"},"text":"Pub. L. 109–444, § 3(b)(2)(B)(iii)","children":[],"tail":", which added par. (4) identical to that added by "},{"tag":"ref","attrib":{"href":"/us/pl/109/461/s301/b/2/B/iii"},"text":"Pub. L. 109–461, § 301(b)(2)(B)(iii)","children":[],"tail":", was terminated by "},{"tag":"ref","attrib":{"href":"/us/pl/109/461/s1006/b"},"text":"Pub. L. 109–461, § 1006(b)","children":[],"tail":". See Amendment notes above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461/s301/b/2/C"},"text":"Pub. L. 109–461, § 301(b)(2)(C)","children":[],"tail":", struck out subsec. (c), which read as follows: “Any entitlement used by an eligible person as a result of eligibility under section 3501(a)(1)(A)(iii), 3501(a)(1)(C), or 3501(a)(1)(D)(i) of this title shall be deducted from any entitlement to which such person may subsequently be entitled under this chapter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/444/s3/b/2/C"},"text":"Pub. L. 109–444, § 3(b)(2)(C)","children":[],"tail":", which struck out subsec. (c), was terminated by "},{"tag":"ref","attrib":{"href":"/us/pl/109/461/s1006/b"},"text":"Pub. L. 109–461, § 1006(b)","children":[],"tail":". See Amendment notes above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/103/s108/c/1"},"text":"Pub. L. 107–103, § 108(c)(1)","children":[],"tail":", inserted at end “In no event may the aggregate educational assistance afforded to a spouse made eligible under both 3501(a)(1)(D)(i) and 3501(a)(1)(D)(ii) of this title exceed 45