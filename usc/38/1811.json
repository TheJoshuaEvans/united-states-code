,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1812"},"text":"section 1812 of title 38","children":[],"tail":", United States Code (as added by subsection (a) of this section), and shall prescribe the regulations required by subchapter II of chapter 18 of that title (as so added), not later than the effective date specified in paragraph (1).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
