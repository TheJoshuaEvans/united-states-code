7/296/tXVII/s1704/d"},"text":"Pub. L. 107–296, title XVII, § 1704(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2315"},"text":"116 Stat. 2315","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc35203e1-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc35203e2-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc35203e3-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(3)(B)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" substituted “of Homeland Security” for “of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/419"},"text":"Pub. L. 106–419","children":[],"tail":" amended par. (4) generally. Prior to amendment, par. (4) read as follows: “before completing such obligated period of service (i) has completed the requirements of a secondary school diploma (or an equivalency certificate), or (ii) has successfully completed (or otherwise received academic credit for) the equivalent of 12 semester hours in a program of education leading to a standard college degree; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(4)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368"},"text":"Pub. L. 105–368","children":[],"tail":" substituted “successfully completed (or otherwise received academic credit for)” for “successfully completed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (b)(3)(B)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/568"},"text":"Pub. L. 102–568","children":[],"tail":" added cl. (iv)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1418"},"text":"section 1418 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/86"},"text":"Pub. L. 102–86","children":[],"tail":" made technical amendment to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/s423/b/4/A"},"text":"Pub. L. 101–237, § 423(b)(4)(A)","children":[],"tail":". See 1989 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “3011(c)(1) or 3012(d)(1)” for “1411(c)(1) or 1412(d)(1)” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “3011(c)(1) or 3012(d)(1)” for “1411(c)(1) or 1412(d)(1)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/16"},"text":"Pub. L. 102–16","children":[],"tail":" substituted “service (i)” for “service,” and added cl. (ii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/1"},"text":"Pub. L. 102–83, § 5(c)(1)","children":[],"tail":", substituted “3011(c)(1) or 3012(d)(1)” for “1411(c)(1) or 1412(d)(1)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237/s423/b/4/A"},"text":"Pub. L. 101–237, § 423(b)(4)(A)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/102/86"},"text":"Pub. L. 102–86","children":[],"tail":", inserted “of Defense” after “Secretary” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237/s423/b/1/A"},"text":"Pub. L. 101–237, § 423(b)(1)(A)","children":[],"tail":", substituted “Secretary” for “Administrator”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc35203e4-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc35203e5-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective on the date of transfer of the Coast Guard to the Department of Homeland Security, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1704/g"},"text":"section 1704(g) of Pub. L. 107–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc35203e6-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368"},"text":"Pub. L. 105–368","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/368/s203/b"},"text":"section 203(b) of Pub. L. 105–368","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3011"},"text":"section 3011 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc35203e7-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/568/tIII/s309/b"},"text":"Pub. L. 102–568, title III, § 309(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4329"},"text":"106 Stat. 4329","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/568/tIII/s309/b"},"text":"“The amendment made by subsection (a) [amending this section] shall take effect as if enacted on ","children":[{"tag":"date","attrib":{"date":"1988-12-01"},"text":"December 1, 1988","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc35203e8-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/86/tV/s506/b"},"text":"Pub. L. 102–86, title V, § 506(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-14"},"text":"Aug. 14, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/426"},"text":"105 Stat. 426","children":[],"tail":", provided that the amendment made by section 506(b)(2) is effective as of "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
