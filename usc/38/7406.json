{"tag":"section","attrib":{"id":"idc40723a0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7406"},"text":null,"children":[{"tag":"num","attrib":{"value":"7406"},"text":"§ 7406.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Residencies and internships","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc40723a1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7406/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc40723a2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7406/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may establish residencies and internships. The Secretary may appoint qualified persons to such positions without regard to civil service or classification laws, rules, or regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc40723a3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7406/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purposes of this section:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc40723a4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7406/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “internship” includes the equivalency of an internship as determined in accordance with regulations which the Secretary shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc40723a5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7406/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “intern” means a person serving an internship.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc40723a6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7406/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may prescribe the conditions of employment of persons appointed under this section, including necessary training, and the customary amount and terms of pay for such positions during the period of such employment and training. The amount and terms of such pay may be established retroactively based on changes in such customary amount and terms.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc40723a7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7406/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc40723a8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7406/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In order to carry out more efficiently the provisions of subsection (a)(1), the Secretary may contract with one or more hospitals, medical schools, or medical installations having hospital facilities and participating with the Department in the training of interns or residents to provide, by the designation of one such institution to serve as a central administrative agency, for the central administration—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc40723a9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7406/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of stipend payments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc40723aa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7406/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provision of fringe benefits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc40723ab-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7406/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintenance of records for such interns and residents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc40723ac-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7406/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may pay to such designated agency, without regard to any other law or regulation governing the expenditure of Government moneys either in advance or in arrears, an amount to cover the cost for the period such intern or resident serves in a Department facility furnishing hospital care or medical services of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc40723ad-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7406/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stipends fixed by the Secretary pursuant to paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc40723ae-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7406/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hospitalization, medical care, and life insurance and any other employee benefits as are agreed upon by the participating institutions for the period that such intern or resident serves in a Department facility furnishing hospital care or medical services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc40723af-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7406/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tax on employers pursuant to chapter 21 of the Internal Revenue Code of 1986, where applicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc40723b0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7406/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount to cover a pro rata share of the cost of expense of such central administrative agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc40723b1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7406/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc40723b2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7406/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any amounts paid by the Secretary to such central administrative agency to cover the cost of hospitalization, medical care, or life insurance or other employee benefits shall be in lieu of any benefits of like nature to which such intern or resident may be entitled under the provisions of title 5, and the acceptance of stipends and employee benefits from the designated central administrative agency shall constitute a waiver by the recipient of any claim such recipient might have to any payment of stipends or employee benefits to which such recipient may be entitled under this title or title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc40723b3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7406/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding subparagraph (A), any period of service of any such intern or resident in a Department facility furnishing hospital care or medical services shall be deemed creditable service for the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8332"},"text":"section 8332 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc40723b4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7406/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The agreement with such central administrative agency may further provide that the designated central administrative agency shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc40723b5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7406/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make all appropriate deductions from the stipend of each intern and resident for local, State, and Federal taxes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc40723b6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7406/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain all records pertinent to such deductions and make proper deposits of such deductions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc40723b7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7406/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain all records pertinent to the leave accrued by such intern and resident for the period during which such recipient serves in a participating facility, including a Department facility furnishing hospital care or medical services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc40723b8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7406/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Leave described in paragraph (4)(C) may be pooled, and the intern or resident may be afforded leave by the facility in which such person is serving at the time the leave is to be used to the extent of such person’s total accumulated leave, whether or not earned at the facility in which such person is serving at the time the leave is to be afforded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc40723b9-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s401/b/2"},"text":"Pub. L. 102–40, title IV, § 401(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/227"},"text":"105 Stat. 227","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/262/tIII/s345"},"text":"Pub. L. 104–262, title III, § 345","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3208"},"text":"110 Stat. 3208","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc40723ba-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc40723bb-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc40723bc-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Chapter 21 of the Internal Revenue Code of 1986, referred to in subsec. (c)(2)(C), is classified to chapter 21 (§ 3101 et seq.) of Title 26, Internal Revenue Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc40723bd-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4114/b"},"text":"section 4114(b) of this title","children":[],"tail":" prior to the repeal of that section as part of the complete revision of chapter 73 of this title by "},{"tag":"ref","attrib":{"href":"/us/pl/102/40"},"text":"Pub. L. 102–40","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc40723be-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (c)(2), (3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/262/s345/1"},"text":"Pub. L. 104–262, § 345(1)","children":[],"tail":", substituted “Department facility furnishing hospital care or medical services” for “Department hospital” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/262/s345/2"},"text":"Pub. L. 104–262, § 345(2)","children":[],"tail":", substituted “participating facility” for “participating hospital”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/262/s345/1"},"text":"Pub. L. 104–262, § 345(1)","children":[],"tail":", substituted “Department facility furnishing hospital care or medical services” for “Department hospital”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/262/s345/3"},"text":"Pub. L. 104–262, § 345(3)","children":[],"tail":", substituted “facility” for “hospital” in two places."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc40723bf-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc40723c0-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Training in Telemedicine","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/154/tI/s108/b"},"text":"Pub. L. 112–154, title I, § 108(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1174"},"text":"126 Stat. 1174","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/154/tI/s108/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Veterans Affairs shall, to the extent feasible, offer medical residents opportunities in training in telemedicine for medical residency programs. The Secretary shall consult with the Accreditation Council for Graduate Medical Education and with universities with which facilities of the Department have a major affiliation to determine the feasibility and advisability of making telehealth a mandatory component of medical residency programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Telemedicine defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subsection, the term ‘telemedicine’ means the use by a health care provider of telecommunications to assist in the diagnosis or treatment of a patient’s medical condition.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
