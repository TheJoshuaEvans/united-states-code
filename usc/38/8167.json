{"tag":"section","attrib":{"id":"idc434741f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8167"},"text":null,"children":[{"tag":"num","attrib":{"value":"8167"},"text":"§ 8167.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from State and local taxes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc4347420-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8167/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Improvements and Operations Not Exempted","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The improvements and operations on land leased by a person with an enhanced-use lease from the Secretary shall be subject to all applicable provisions of Federal, State, or local law relating to taxation, fees, and assessments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc4347421-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s8167/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Underlying Fee Title Interest Exempted","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The underlying fee title interest of the United States in any land subject to an enhanced-use lease shall not be subject, directly or indirectly, to any provision of State or local law relating to taxation, fees, or assessments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc4347422-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/86/tIV/s401/a"},"text":"Pub. L. 102–86, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-14"},"text":"Aug. 14, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/421"},"text":"105 Stat. 421","children":[],"tail":"; amended Pub. L. 112—154, title II, § 211(h), "},{"tag":"date","attrib":{"date":"2012-08-06"},"text":"Aug. 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1181"},"text":"126 Stat. 1181","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc4347423-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc4347424-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc4347425-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/154"},"text":"Pub. L. 112–154","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “The interest of the United States in any property subject to an enhanced-use lease and any use by the United States of such property during such lease shall not be subject, directly or indirectly, to any State or local law relative to taxation, fees, assessments, or special assessments, except sales taxes charged in connection with any construction, alteration, repair, remodeling, or improvement project carried out under the lease.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
