{"tag":"section","attrib":{"id":"idc3592f7d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3102"},"text":null,"children":[{"tag":"num","attrib":{"value":"3102"},"text":"§ 3102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basic entitlement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3592f7e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person shall be entitled to a rehabilitation program under the terms and conditions of this chapter if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3592f7f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3102/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3592f80-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3102/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc3592f81-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3102/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a veteran who has a service-connected disability rated at 20 percent or more which was incurred or aggravated in service on or after ","children":[{"tag":"date","attrib":{"date":"1940-09-16"},"text":"September 16, 1940","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3592f82-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3102/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" hospitalized or receiving outpatient medical care, services, or treatment for a service-connected disability pending discharge from the active military, naval, air, or space service, and the Secretary determines that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc3592f83-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3102/a/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the hospital (or other medical facility) providing the hospitalization, care, services, or treatment is doing so under contract or agreement with the Secretary concerned, or is under the jurisdiction of the Secretary of Veterans Affairs or the Secretary concerned; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc3592f84-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3102/a/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person is suffering from a disability which will likely be compensable at a rate of 20 percent or more under chapter 11 of this title; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3592f85-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3102/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is determined by the Secretary to be in need of rehabilitation because of an employment handicap; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3592f86-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3102/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the person is a veteran who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3592f87-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3102/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a service-connected disability rated at 10 percent which was incurred or aggravated in service on or after ","children":[{"tag":"date","attrib":{"date":"1940-09-16"},"text":"September 16, 1940","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3592f88-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3102/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is determined by the Secretary to be in need of rehabilitation because of a serious employment handicap.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3592f89-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Rehabilitation Programs for Persons Who Have Exhausted Rights to Unemployment Benefits Under State Law","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3592f8a-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3102/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in paragraph (4), a person who has completed a rehabilitation program under this chapter shall be entitled to an additional rehabilitation program under the terms and conditions of this chapter if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3592f8b-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3102/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person is described by paragraph (1) or (2) of subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3592f8c-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3102/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the person—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc3592f8d-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3102/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has exhausted all rights to regular compensation under the State law or under Federal law with respect to a benefit year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3592f8e-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3102/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has no rights to regular compensation with respect to a week under such State or Federal law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc3592f8f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3102/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not receiving compensation with respect to such week under the unemployment compensation law of Canada; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3592f90-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3102/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" begins such additional rehabilitation program within six months of the date of such exhaustion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3592f91-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3102/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of paragraph (1)(B)(i), a person shall be considered to have exhausted such person’s rights to regular compensation under a State law when—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc3592f92-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3102/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no payments of regular compensation can be made under such law because such person has received all regular compensation available to such person based on employment or wages during such person’s base period; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc3592f93-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3102/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such person’s rights to such compensation have been terminated by reason of the expiration of the benefit year with respect to which such rights existed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3592f94-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3102/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this subsection, the terms “compensation”, “regular compensation”, “benefit year”, “State”, “State law”, and “week” have the respective meanings given such terms under section 205 of the Federal-State Extended Unemployment Compensation Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s3304"},"text":"26 U.S.C. 3304","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3592f95-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s3102/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No person shall be entitled to an additional rehabilitation program under paragraph (1) from whom the Secretary receives an application therefor after ","children":[{"tag":"date","attrib":{"date":"2014-03-31"},"text":"March 31, 2014","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3592f96-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/466/tI/s101/a"},"text":"Pub. L. 96–466, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2173"},"text":"94 Stat. 2173","children":[],"tail":", § 1502; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIV/s423/b/1/A"},"text":"Pub. L. 101–237, title IV, § 423(b)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2092"},"text":"103 Stat. 2092","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tVIII/s8021/a"},"text":"Pub. L. 101–508, title VIII, § 8021(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-347"},"text":"104 Stat. 1388–347","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/16/s3/a"},"text":"Pub. L. 102–16, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-03-22"},"text":"Mar. 22, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/49"},"text":"105 Stat. 49","children":[],"tail":"; renumbered § 3102, "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/a"},"text":"Pub. L. 102–83, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/568/tIV/s404/a"},"text":"Pub. L. 102–568, title IV, § 404(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4338"},"text":"106 Stat. 4338","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/275/tI/s101/b"},"text":"Pub. L. 104–275, title I, § 101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3323"},"text":"110 Stat. 3323","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/56/tII/s233/a/1"},"text":"Pub. L. 112–56, title II, § 233(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-11-21"},"text":"Nov. 21, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/719"},"text":"125 Stat. 719","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s926/a/41"},"text":"Pub. L. 116–283, div. A, title IX, § 926(a)(41)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3830"},"text":"134 Stat. 3830","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc3592f97-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc3592f98-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc3592f99-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 205 of the Federal-State Extended Unemployment Compensation Act of 1970, referred to in subsec. (b)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/373/s205"},"text":"section 205 of Pub. L. 91–373","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s3304"},"text":"section 3304 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc3592f9a-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior section 3102 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5302"},"text":"section 5302 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc3592f9b-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(1)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “air, or space service” for “or air service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/56"},"text":"Pub. L. 112–56","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Par. (1)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/275/s101/b/1"},"text":"Pub. L. 104–275, § 101(b)(1)","children":[],"tail":", substituted “rated at 20 percent or more” for “which is, or but for the receipt of retired pay would be, compensable at a rate of 20 percent or more under chapter 11 of this title and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/275/s101/b/2"},"text":"Pub. L. 104–275, § 101(b)(2)","children":[],"tail":", substituted “rated at 10 percent” for “which is, or but for the receipt of retired pay would be, compensable at a rate of 10 percent under chapter 11 of this title and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/275/s101/b/3"},"text":"Pub. L. 104–275, § 101(b)(3)","children":[],"tail":", amended subpar. (B) generally. Prior to amendment, subpar. (B) read as follows: “has a serious employment handicap.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/568"},"text":"Pub. L. 102–568","children":[],"tail":" amended section generally, making changes in substance and structure."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1502"},"text":"section 1502 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/16"},"text":"Pub. L. 102–16","children":[],"tail":" substituted “or receiving outpatient medical care, services, or treatment for a service-connected disability pending discharge from the active military, naval, or air service, and the Secretary determines that (i) the hospital (or other medical facility) providing the hospitalization, care, services, or treatment either is doing so under contract or agreement with the Secretary concerned or is under the jurisdiction of the Secretary of Veterans Affairs or the Secretary concerned, and (ii) the person is suffering from a disability which” for “for a service-connected disability in a hospital over which the Secretary concerned has jurisdiction pending discharge or release from active military, naval, or air service and is suffering from a disability which the Secretary determines”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" substituted “compensable at a rate of 20 percent or more” for “compensable” in cls. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237"},"text":"Pub. L. 101–237","children":[],"tail":" substituted “Secretary determines” for “Administrator determines” in par. (1)(B) and “Secretary” for “Administrator” in par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc3592f9c-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc3592f9d-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{