{"tag":"section","attrib":{"id":"idc3d515f1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5124"},"text":null,"children":[{"tag":"num","attrib":{"value":"5124"},"text":"§ 5124.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of claimant’s statement as proof of relationship","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc3d515f2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5124/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of benefits under laws administered by the Secretary, the Secretary may accept the written statement of a claimant as proof of the existence of any relationship specified in subsection (b) for the purpose of acting on such individual’s claim for benefits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d515f3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5124/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subsection (a) applies to proof of the existence of any of the following relationships between a claimant and another person:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3d515f4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5124/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Marriage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d515f5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5124/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Dissolution of a marriage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d515f6-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5124/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Birth of a child.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d515f7-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5124/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Death of any family member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc3d515f8-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5124/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may require the submission of documentation in support of the claimant’s statement if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc3d515f9-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5124/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the claimant does not reside within a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d515fa-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5124/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the statement on its face raises a question as to its validity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d515fb-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5124/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is conflicting information of record; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc3d515fc-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s5124/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is reasonable indication, in the statement or otherwise, of fraud or misrepresentation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc3d515fd-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446/tIII/s301/a"},"text":"Pub. L. 103–446, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4657"},"text":"108 Stat. 4657","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
