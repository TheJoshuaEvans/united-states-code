{"tag":"section","attrib":{"id":"idc2dd21ab-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703G"},"text":null,"children":[{"tag":"num","attrib":{"value":"1703G"},"text":"§ 1703G.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quarterly report on referrals for non-Department health care","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall submit to the Committees on Veterans’ Affairs of the Senate and the House of Representatives a quarterly report containing, with respect to referrals for non-Department health care originating from a medical facility of the Department during the quarter preceding the date of the submission of the report, a measurement of, for each such medical facility—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc2dd21ac-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703G/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the period of time between—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc2dd21ad-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703G/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which a clinician employed by the Department determines that a veteran requires care, or a veteran presents to the Department requesting care, and the date on which the referral for care is sent to a non-Department health care provider;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2dd21ae-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703G/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which such referral is sent to a non-Department health care provider and the date on which such non-Department health care provider accepts such referral;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2dd21af-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703G/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which such non-Department health care provider accepts such referral and the date on which such referral is completed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2dd21b0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703G/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which such referral is completed and the date on which an appointment with a non-Department health care provider is made; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc2dd21b1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703G/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which such an appointment is made and the date on which such appointment occurs; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc2dd21b2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1703G/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other period of time that the Secretary determines necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc2dd21b3-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/210/tI/s140/a"},"text":"Pub. L. 118–210, title I, § 140(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-02"},"text":"Jan. 2, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2743"},"text":"138 Stat. 2743","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc2dd21b4-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc2dd21b5-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc2dd21b6-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/210/tI/s140/b"},"text":"Pub. L. 118–210, title I, § 140(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-02"},"text":"Jan. 2, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2744"},"text":"138 Stat. 2744","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/210/tI/s140/b"},"text":"“The first report under section 1703G [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1703G"},"text":"38 U.S.C. 1703G","children":[],"tail":"], as added by this section, shall be due not later than 180 days after the date of the enactment of this section ["},{"tag":"date","attrib":{"date":"2025-01-02"},"text":"Jan. 2, 2025","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
