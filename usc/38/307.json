{"tag":"section","attrib":{"id":"idc27b52d0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s307"},"text":null,"children":[{"tag":"num","attrib":{"value":"307"},"text":"§ 307.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Under Secretary for Memorial Affairs","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is in the Department an Under Secretary for Memorial Affairs, who is appointed by the President, by and with the advice and consent of the Senate. The Under Secretary is the head of the National Cemetery Administration as established in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2400"},"text":"section 2400 of this title","children":[],"tail":" and shall perform such functions as may be assigned by the Secretary."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc27b52d1-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83/s2/a"},"text":"Pub. L. 102–83, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/381"},"text":"105 Stat. 381","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/368/tIV/s403/a/3"},"text":"Pub. L. 105–368, title IV, § 403(a)(3)","children":[],"tail":", (c)(1)(A), "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3338"},"text":"112 Stat. 3338","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc27b52d2-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc27b52d3-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc27b52d4-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/527/s3/d"},"text":"section 3(d) of Pub. L. 100–527","children":[],"tail":", known as the Department of Veterans Affairs Act, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s3/3"},"text":"Pub. L. 102–83, § 3(3)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc27b52d5-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/s403/c/1/A"},"text":"Pub. L. 105–368, § 403(c)(1)(A)","children":[],"tail":", substituted “Under Secretary for Memorial Affairs” for “Director of the National Cemetery System” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/s403/a/3"},"text":"Pub. L. 105–368, § 403(a)(3)","children":[],"tail":", in first sentence, substituted “an Under Secretary for Memorial Affairs” for “a Director of the National Cemetery System” and, in second sentence, substituted “The Under Secretary is the head of the National Cemetery Administration” for “The Director is the head of the National Cemetery System”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
