{"tag":"section","attrib":{"id":"idc313e9df-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1822"},"text":null,"children":[{"tag":"num","attrib":{"value":"1822"},"text":"§ 1822.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefits for children of certain Thailand service veterans born with spina bifida","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc313e9e0-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1822/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Benefits Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may provide to any child of a veteran of covered service in Thailand who is suffering from spina bifida the health care, vocational training and rehabilitation, and monetary allowance required to be paid to a child of a Vietnam veteran who is suffering from spina bifida under subchapter I of this chapter as if such child of a veteran of covered service in Thailand were a child of a Vietnam veteran who is suffering from spina bifida under such subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc313e9e1-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1822/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Spina Bifida Conditions Covered","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section applies with respect to all forms and manifestations of spina bifida, except spina bifida occulta.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc313e9e2-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1822/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Veteran of Covered Service in Thailand","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, a veteran of covered service in Thailand is any individual, without regard to the characterization of that individual’s service, who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc313e9e3-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1822/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" served in the active military, naval, or air service in Thailand, as determined by the Secretary in consultation with the Secretary of Defense, during the period beginning on ","children":[{"tag":"date","attrib":{"date":"1962-01-09"},"text":"January 9, 1962","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"1975-05-07"},"text":"May 7, 1975","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc313e9e4-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1822/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is determined by the Secretary, in consultation with the Secretary of Defense, to have been exposed to a herbicide agent during such service in Thailand.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc313e9e5-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s1822/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Herbicide Agent","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, the term “herbicide agent” means a chemical in a herbicide used in support of United States and allied military operations in Thailand, as determined by the Secretary in consultation with the Secretary of Defense, during the period beginning on ","children":[{"tag":"date","attrib":{"date":"1962-01-09"},"text":"January 9, 1962","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"1975-05-07"},"text":"May 7, 1975","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc313e9e6-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/23/s4/a"},"text":"Pub. L. 116–23, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-06-25"},"text":"June 25, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/970"},"text":"133 Stat. 970","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc313e9e7-47c4-11f1-bf59-9680b1269b87"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc313e9e8-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc313e9e9-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1822 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1832"},"text":"section 1832 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 1822, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/857"},"text":"Pub. L. 85–857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1214"},"text":"72 Stat. 1214","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/358/s5/c"},"text":"Pub. L. 89–358, § 5(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-03-03"},"text":"Mar. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/26"},"text":"88 Stat. 26","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/623/s1"},"text":"Pub. L. 89–623, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-04"},"text":"Oct. 4, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/873"},"text":"80 Stat. 873","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/301/s2/b"},"text":"Pub. L. 90–301, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-05-07"},"text":"May 7, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/113"},"text":"82 Stat. 113","children":[],"tail":", provided for bringing of an action in district court, by veteran or Attorney General, against one who knowingly participated in sale of property to a veteran for consideration in excess of reasonable value of property, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/93/569"},"text":"Pub. L. 93–569","children":[],"tail":", §§ 7(a), 10, "},{"tag":"date","attrib":{"date":"1974-12-31"},"text":"Dec. 31, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1866"},"text":"88 Stat. 1866","children":[],"tail":", 1867, effective "},{"tag":"date","attrib":{"date":"1974-12-31"},"text":"Dec. 31, 1974","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 1823 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1833"},"text":"section 1833 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 1823 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3723"},"text":"section 3723 of this title","children":[],"tail":" and subsequently repealed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 1824 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1834"},"text":"section 1834 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 1824 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3724"},"text":"section 3724 of this title","children":[],"tail":" and subsequently repealed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 1824 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3725"},"text":"section 3725 of this title","children":[],"tail":" and subsequently repealed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 1825 was renumbered 3725 of this title and subsequently repealed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior sections 1826 to 1830 were renumbered sections 3726 to 3730 of this title, respectively.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc313e9ea-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc313e9eb-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/23/s4/f"},"text":"Pub. L. 116–23, § 4(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-06-25"},"text":"June 25, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/972"},"text":"133 Stat. 972","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/23/s4/f"},"text":"“The amendments made by this section [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1831"},"text":"section 1831 of this title","children":[],"tail":"] shall take effect on "},{"tag":"date","attrib":{"date":"2020-01-01"},"text":"January 1, 2020","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc313e9ec-47c4-11f1-bf59-9680b1269b87"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/23/s4/d"},"text":"Pub. L. 116–23, § 4(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-06-25"},"text":"June 25, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/971"},"text":"133 Stat. 971","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/23/s4/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding section 501 of such title, the Secretary of Veterans Affairs may issue guidance to implement ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1822"},"text":"section 1822 of title 38","children":[],"tail":", United States Code, as added by subsection (a), before prescribing new regulations under such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Updates","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 120 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2019-06-25"},"text":"June 25, 2019","children":[],"tail":"], the Secretary shall submit a report to the Committees on Veterans’ Affairs of the House of Representatives and the Senate regarding the plans of the Secretary to respond to inquiries from veterans regarding claims for disability compensation under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1822"},"text":"section 1822 of title 38","children":[],"tail":", United States Code, as added by subsection (a) of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On a quarterly basis during the period beginning on the date of the enactment of this Act and ending on the date on which regulations are prescribed to carry out such section 1822, the Secretary shall submit to the Committees on Veterans’ Affairs of the House of Representatives and the Senate updates on the status of such regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pending cases.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to stay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may stay a claim described in subparagraph (B) until the date on which the Secretary commences the implementation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1822"},"text":"section 1822 of title 38","children":[],"tail":", United States Code, as added by subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Claims described","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A claim described in this subparagraph is a claim for benefits—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relating to the spina bifida and service covered by such section 1822; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is pending at the Veterans Benefits Administration or the Board of Veterans’ Appeals on or after the date of the enactment of this Act and before the date on which the Secretary commences the implementation of such section 1822.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
