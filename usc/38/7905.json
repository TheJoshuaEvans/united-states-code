{"tag":"section","attrib":{"id":"idc41ca65f-47c4-11f1-bf59-9680b1269b87","identifier":"/us/usc/t38/s7905"},"text":null,"children":[{"tag":"num","attrib":{"value":"7905"},"text":"§ 7905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of honorable discharge for veterans receiving assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No veteran shall receive financial assistance under this chapter unless the veteran was discharged from the Armed Forces under honorable conditions.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc41ca660-47c4-11f1-bf59-9680b1269b87"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/461/tIX/s903/a/1"},"text":"Pub. L. 109–461, title IX, § 903(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3464"},"text":"120 Stat. 3464","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
