{"tag":"section","attrib":{"id":"id6c9507e3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4105"},"text":null,"children":[{"tag":"num","attrib":{"value":"4105"},"text":"§ 4105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports on unmanned maritime systems and usage for mission of the National Oceanic and Atmospheric Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c9507e4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this chapter, the Administrator shall, not later than one year after ","children":[{"tag":"date","attrib":{"date":"2018-12-21"},"text":"December 21, 2018","children":[],"tail":", and every 4 years thereafter, submit to the appropriate committees of Congress a report on the usage of unmanned maritime systems for the mission of the Administration."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c9750d5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report submitted under subsection (a) shall include, for the period covered by the report, the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c9750d6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4105/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An inventory of current unmanned maritime systems used by programs of the Administration, a summary of the data they have returned, and the benefits realized from having such data.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9750d7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4105/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A prioritized list of data requirements of the Administration that could be met with unmanned maritime systems, and the commercially available unmanned maritime systems with the operational capabilities to collect such data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c9750d8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate committees of Congress defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “appropriate committees of Congress” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c9750d9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4105/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations, the Committee on Armed Services, and the Committee on Commerce, Science, and Transportation of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9750da-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4105/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations, the Committee on Armed Services, the Committee on Natural Resources, and the Committee on Science, Space, and Technology of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c9750db-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/394/s6"},"text":"Pub. L. 115–394, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5285"},"text":"132 Stat. 5285","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
