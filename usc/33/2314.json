{"tag":"section","attrib":{"id":"id6c4fe7f7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2314"},"text":null,"children":[{"tag":"num","attrib":{"value":"2314"},"text":"§ 2314.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Innovative technology","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c4fe7f8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2314/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, whenever feasible, seek to promote long- and short-term cost savings, increased efficiency, reliability, and safety, and improved environmental results through the use of innovative technology in all phases of water resources development projects and programs under the Secretary’s jurisdiction. To further this goal, Congress encourages the Secretary to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c4fe7f9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2314/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use procurement and contracting procedures that encourage innovative project design, construction, rehabilitation, repair, and operation and maintenance technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c4fe7fa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2314/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" frequently review technical and design criteria to remove or modify unnecessary impediments to innovation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c4fe7fb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2314/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase timely exchange of technical information with universities, private companies, government agencies, and individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c4fe7fc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2314/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foster design competition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c4fe7fd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2314/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage greater participation by non-Federal project sponsors in the development and implementation of projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c4fe7fe-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2314/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accelerated adoption of innovative technologies for management of contaminated sediments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c4fe7ff-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2314/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Test projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall approve an appropriate number of projects to test, under actual field conditions, innovative technologies for environmentally sound management of contaminated sediments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c4fe800-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2314/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may approve an appropriate number of projects to demonstrate innovative technologies that have been pilot tested under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c4fe801-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2314/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conduct of projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each pilot project under paragraph (1) and demonstration project under paragraph (2) shall be conducted by a university with proven expertise in the research and development of contaminated sediment treatment technologies and innovative applications using waste materials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c4fe802-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2314/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At least 1 of the projects under this subsection shall be conducted in New England by the University of New Hampshire.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c4fe803-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2314/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 2 years after ","children":[{"tag":"date","attrib":{"date":"1988-11-17"},"text":"November 17, 1988","children":[],"tail":", and thereafter at the Secretary’s discretion, the Secretary shall provide Congress with a report on the results of, and recommendations to increase, the development and use of innovative technology in water resources development projects under the Secretary’s jurisdiction. Such report shall also contain information regarding innovative technologies which the Secretary has considered and rejected for use in water resources development projects under the Secretary’s jurisdiction."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c4fe804-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2314/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Innovative technology” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of this section, the term “innovative technology” means designs, methods, or materials, including roller compacted concrete, geosynthetic materials, and advanced composites, that the Secretary determines are appropriate to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c4fe805-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/676/s8"},"text":"Pub. L. 100–676, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-17"},"text":"Nov. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4023"},"text":"102 Stat. 4023","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/53/tV/s503/b"},"text":"Pub. L. 106–53, title V, § 503(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-08-17"},"text":"Aug. 17, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/337"},"text":"113 Stat. 337","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/121/tIII/s3021"},"text":"Pub. L. 113–121, title III, § 3021","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1301"},"text":"128 Stat. 1301","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c4fe806-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c4fe807-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c4fe808-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 1988, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c4fe809-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121"},"text":"Pub. L. 113–121","children":[],"tail":" substituted “methods, or materials, including roller compacted concrete, geosynthetic materials, and advanced composites, that the Secretary determines are appropriate to carry out this section.” for “materials, or methods which the Secretary determines are previously undemonstrated or are too new to be considered standard practice.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/53"},"text":"Pub. L. 106–53","children":[],"tail":" added subsec. (b) and redesignated former subsecs. (b) and (c) as (c) and (d), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c4fe80a-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c4fe80b-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Design-Build Contracting","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/541/tII/s221"},"text":"Pub. L. 106–541, title II, § 221","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-11"},"text":"Dec. 11, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2596"},"text":"114 Stat. 2596","children":[],"tail":", provided that the Secretary of the Army could conduct a pilot program consisting of not more than 5 authorized projects to test the design-build method of project delivery on various authorized civil works projects of the Corps of Engineers, including levees, pumping plants, revetments, dikes, dredging, weirs, dams, retaining walls, generation facilities, mattress laying, recreation facilities, and other water resources facilities, and, not later than 4 years after "},{"tag":"date","attrib":{"date":"2000-12-11"},"text":"Dec. 11, 2000","children":[],"tail":", to transmit to Congress a report on the results of the pilot program."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c4fe80c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Review of Innovative Dredging Technologies","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/53/tV/s503/a"},"text":"Pub. L. 106–53, title V, § 503(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-08-17"},"text":"Aug. 17, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/337"},"text":"113 Stat. 337","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/53/tV/s503/a"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2001-06-01"},"text":"June 1, 2001","children":[],"tail":", the Secretary shall complete a review of innovative dredging technologies designed to minimize or eliminate contamination of a water column upon removal of contaminated sediments."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Testing.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection of technology","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After completion of the review under paragraph (1), the Secretary shall select, from among the technologies reviewed, the technology that the Secretary determines will best increase the effectiveness of removing contaminated sediments and significantly reduce contamination of the water column.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2001-12-31"},"text":"December 31, 2001","children":[],"tail":", the Secretary shall enter into an agreement with a public or private entity to test the selected technology in the vicinity of Peoria Lakes, Illinois."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated to carry out this subsection $2,000,000.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c5230fd-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Beneficial Use of Waste Tire Rubber","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/53/tV/s561"},"text":"Pub. L. 106–53, title V, § 561","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-08-17"},"text":"Aug. 17, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/355"},"text":"113 Stat. 355","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/53/tV/s561"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall, when appropriate, encourage the beneficial use of waste tire rubber (including crumb rubber and baled tire products) recycled from tires.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Included Beneficial Uses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Beneficial uses under subsection (a) may include marine pilings, underwater framing, floating docks with built-in flotation, utility poles, and other uses associated with transportation and infrastructure projects receiving Federal funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Waste Tire Rubber","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall encourage the use, when appropriate, of waste tire rubber (including crumb rubber) in projects described in subsection (b).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c5230fe-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/676/s2"},"text":"section 2 of Pub. L. 100–676","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
