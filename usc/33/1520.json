{"tag":"section","attrib":{"id":"id6c18f942-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1520"},"text":null,"children":[{"tag":"num","attrib":{"value":"1520"},"text":"§ 1520.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pipeline safety and operation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c18f943-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1520/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards and regulations for Outer Continental Shelf","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in cooperation with the Secretary of the Interior, shall establish and enforce such standards and regulations as may be necessary to assure the safe construction and operation of oil or natural gas pipelines on the Outer Continental Shelf.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c18f944-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1520/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":", (c) Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c18f945-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/627/s21"},"text":"Pub. L. 93–627, § 21","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2146"},"text":"88 Stat. 2146","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/295/tI/s106/a/3"},"text":"Pub. L. 107–295, title I, § 106(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2086"},"text":"116 Stat. 2086","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c18f946-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c18f947-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c18f948-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b) directed the Secretary to report to the Congress within 60 days after ","children":[{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", on appropriations and staffing needed to monitor pipelines on Federal lands and the Outer Continental Shelf."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c) directed the Secretary to review all laws and regulations relating to the construction, operation, and maintenance of pipelines on Federal lands and the Outer Continental Shelf and to report to Congress within 6 months after ","children":[{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", on administrative changes needed and recommendations for new legislation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c18f949-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295"},"text":"Pub. L. 107–295","children":[],"tail":" inserted “or natural gas” after “oil”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
