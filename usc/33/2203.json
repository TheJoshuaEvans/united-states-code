{"tag":"section","attrib":{"id":"id6c30c68a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2203"},"text":null,"children":[{"tag":"num","attrib":{"value":"2203"},"text":"§ 2203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of contracting policies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c30c68b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2203/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of contractual agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c30c68c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2203/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary shall complete a review of the policies, guidelines, and regulations of the Corps of Engineers for the development of contractual agreements between the Secretary and non-Federal interests and utilities associated with the construction of water resources development projects."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c30c68d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2203/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after completing the review under subsection (a)(1), the Secretary shall submit to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Environment and Public Works of the Senate, and make publicly available, a report that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c30c68e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2203/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the results of the review; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c30c68f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2203/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public guidance on best practices for a non-Federal interest to use when writing or developing contractual agreements with the Secretary and utilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c30c690-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2203/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of guidance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide the best practices guidance included under paragraph (2)(A) to non-Federal interests prior to the development of contractual agreements with such non-Federal interests.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c30c691-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2203/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of Congress that the Secretary should maximize use of nonprice tradeoff procedures in competitive acquisitions for carrying out emergency work in an area with respect to which the President has declared a major disaster under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5170"},"text":"section 5170 of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c30c692-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/tI/s136"},"text":"Pub. L. 116–260, div. AA, title I, § 136","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2649"},"text":"134 Stat. 2649","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c30c693-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c30c694-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c30c695-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 2020, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c30c696-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"