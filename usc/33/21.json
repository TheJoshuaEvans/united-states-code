{"tag":"section","attrib":{"id":"id6b0454af-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s21"},"text":null,"children":[{"tag":"num","attrib":{"value":"21"},"text":"§ 21.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bayou Cocodrie, Louisiana","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Bayou Cocodrie, from its source to its junction with Bayou Chicot, in the State of Louisiana, is declared to be not a navigable water of the United States within the meaning of the laws enacted by the Congress for the preservation and protection of such waters.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The right to alter, amend, or repeal this section is expressly reserved.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b0454b0-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1921-02-25/ch71"},"text":"Feb. 25, 1921, ch. 71","children":[],"tail":", §§ 1, 2, "},{"tag":"ref","attrib":{"href":"/us/stat/41/1145"},"text":"41 Stat. 1145","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b0454b1-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b0454b2-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b0454b3-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The first sentence hereof is section 1 and the second sentence section 2 of act ","children":[{"tag":"date","attrib":{"date":"1921-02-25"},"text":"Feb. 25, 1921","children":[],"tail":", entitled “An Act to declare Bayou Cocodrie nonnavigable from its source to its junction with Bayou Chicot”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
