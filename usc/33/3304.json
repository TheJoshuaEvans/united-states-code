{"tag":"section","attrib":{"id":"id6c81f48c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3304"},"text":null,"children":[{"tag":"num","attrib":{"value":"3304"},"text":"§ 3304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on statutory construction","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter shall be construed as—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c81f48d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3304/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creating any liability of the United States or its officers or employees for the recovery of damages caused by an action or failure to act; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c81f48e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3304/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relieving an owner or operator of a levee of a legal duty, obligation, or liability incident to the ownership or operation of a levee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c81f48f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/tIX/s9007"},"text":"Pub. L. 110–114, title IX, § 9007","children":[],"tail":", formerly § 9005, "},{"tag":"date","attrib":{"date":"2007-11-08"},"text":"Nov. 8, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1290"},"text":"121 Stat. 1290","children":[],"tail":"; renumbered § 9007, "},{"tag":"ref","attrib":{"href":"/us/pl/113/121/tIII/s3016/e/1"},"text":"Pub. L. 113–121, title III, § 3016(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1293"},"text":"128 Stat. 1293","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
