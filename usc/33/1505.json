{"tag":"section","attrib":{"id":"id6c143eb3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1505"},"text":null,"children":[{"tag":"num","attrib":{"value":"1505"},"text":"§ 1505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental review criteria","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c143eb4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in accordance with the recommendations of the Administrator of the Environmental Protection Agency and the Administrator of the National Oceanic and Atmospheric Administration and after consultation with any other Federal departments and agencies having jurisdiction over any aspect of the construction or operation of a deepwater port, shall establish, as soon as practicable after ","children":[{"tag":"date","attrib":{"date":"1975-01-03"},"text":"January 3, 1975","children":[],"tail":", environmental review criteria consistent with the National Environmental Policy Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.]. Such criteria shall be used to evaluate a deepwater port as proposed in an application, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c143eb5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1505/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect on the marine environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c143eb6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1505/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect on oceanographic currents and wave patterns;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c143eb7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1505/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect on alternate uses of the oceans and navigable waters, such as scientific study, fishing, and exploitation of other living and nonliving resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c143eb8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1505/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential dangers to a deepwater port from waves, winds, weather, and geological conditions, and the steps which can be taken to protect against or minimize such dangers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c143eb9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1505/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effects of land-based developments related to deepwater port development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c16aeba-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1505/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect on human health and welfare; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c16aebb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1505/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other considerations as the Secretary deems necessary or appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c16aebc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and revision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall periodically review and, whenever necessary, revise in the same manner as originally developed, criteria established pursuant to subsection (a) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c16aebd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1505/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The criteria established pursuant to this section shall be developed concurrently with the regulations promulgated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1504/a"},"text":"section 1504(a) of this title","children":[],"tail":" and in accordance with that section and in accordance with the provisions of that subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c16aebe-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/627/s6"},"text":"Pub. L. 93–627, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2135"},"text":"88 Stat. 2135","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dC/tXXXV/s3514/k/5"},"text":"Pub. L. 118–31, div. C, title XXXV, § 3514(k)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/818"},"text":"137 Stat. 818","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c16aebf-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c16aec0-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c16aec1-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act, referred to in subsec. (a), probably means the National Environmental Policy Act of 1969, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c16aec2-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s3514/k/5/A"},"text":"Pub. L. 118–31, § 3514(k)(5)(A)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s3514/k/5/B"},"text":"Pub. L. 118–31, § 3514(k)(5)(B)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s3514/k/5/C"},"text":"Pub. L. 118–31, § 3514(k)(5)(C)","children":[],"tail":", inserted heading and, in text, substituted “The criteria” for “Criteria” and “concurrently with the regulations promulgated pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1504/a"},"text":"section 1504(a) of this title","children":[],"tail":" and in accordance with that section” for “concurrently with the regulations in subsection (a) of "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1504"},"text":"section 1504 of this title","children":[],"tail":" and in accordance with the provisions of that subsection”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
