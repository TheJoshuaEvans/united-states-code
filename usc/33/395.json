{"tag":"section","attrib":{"id":"id6b1c497b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s395"},"text":null,"children":[{"tag":"num","attrib":{"value":"395"},"text":"§ 395.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limit of sentence","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It shall not be lawful for the court to sentence any person convicted in such trial to any greater punishment than imprisonment in jail for one year, or to a fine exceeding $500, or both, in its discretion, in those cases where the laws of the United States authorize such imprisonment and fine.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b1c497c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(R.S. § 4304.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b1c497d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b1c497e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b1c497f-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 4304 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1864-06-11/ch121/s5"},"text":"act June 11, 1864, ch. 121, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/13/125"},"text":"13 Stat. 125","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
