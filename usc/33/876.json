{"tag":"section","attrib":{"id":"id6b747c3c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s876"},"text":null,"children":[{"tag":"num","attrib":{"value":"876"},"text":"§ 876.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees for notarial acts; prima facie evidence of authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No fee of any kind shall be paid to any officer for the performance of any notarial act authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s875"},"text":"section 875 of this title","children":[],"tail":". The signature without seal together with indication of grade of any officer performing any notarial act shall be prima facie evidence of his authority."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b747c3d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-03/ch932/s2"},"text":"Aug. 3, 1956, ch. 932, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/988"},"text":"70 Stat. 988","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
