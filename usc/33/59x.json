{"tag":"section","attrib":{"id":"id6b103bd2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59x"},"text":null,"children":[{"tag":"num","attrib":{"value":"59x"},"text":"§ 59x.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from General Bridge Act of 1946","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b103bd3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59x/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waters declared nonnavigable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The waters described in subsection (b) are declared to be nonnavigable waters of the United States for purposes of the General Bridge Act of 1946 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s525"},"text":"33 U.S.C. 525","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b103bd4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59x/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waters described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The waters referred to in subsection (a) are a drainage canal which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b103bd5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59x/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an unnamed tributary of the creek known as Newton Creek, located at block 641 (formerly designated as block 860) in the city of Camden, New Jersey;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b103bd6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59x/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" originates at the north bank of Newton Creek approximately 1,200 feet east of the confluence of Newton Creek and the Delaware River; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b103bd7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59x/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terminates at drainage culverts on the west side of Interstate Highway 676.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b103bd8-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/448/s16"},"text":"Pub. L. 100–448, § 16","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-28"},"text":"Sept. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1845"},"text":"102 Stat. 1845","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/457/tIII/s325"},"text":"Pub. L. 100–457, title III, § 325","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-30"},"text":"Sept. 30, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2150"},"text":"102 Stat. 2150","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b103bd9-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b103bda-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6b103bdb-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The General Bridge Act of 1946, referred to in subsec. (a), is title V of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-02/ch753"},"text":"act Aug. 2, 1946, ch. 753","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/847"},"text":"60 Stat. 847","children":[],"tail":", which is classified generally to subchapter III (§ 525 et seq.) of chapter 11 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s525"},"text":"section 525 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b103bdc-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/448"},"text":"Pub. L. 100–448","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/100/457"},"text":"Pub. L. 100–457","children":[],"tail":" enacted identical sections."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
