{"tag":"section","attrib":{"id":"id6c6089dc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2347c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2347c"},"text":"§ 2347c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small water storage projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c6089dd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2347c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out a program to study and construct new, or enlarge existing, small water storage projects, in partnership with a non-Federal interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c6089de-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2347c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to participate in the program under this section, a small water storage project shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c6089df-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2347c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a new small water storage project, have a water storage capacity of not less than 2,000 acre-feet and not more than 30,000 acre-feet;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c6089e0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2347c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an enlargement of an existing small water storage project, be for an enlargement of not less than 1,000 acre-feet and not more than 30,000 acre-feet;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c6089e1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2347c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c6089e2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2347c/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" flood risk management benefits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c6089e3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2347c/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ecological benefits; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c6089e4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2347c/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water management, water conservation, or water supply; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c6089e5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2347c/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c6089e6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2347c/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" economically justified, environmentally acceptable, and technically feasible; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c6089e7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2347c/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a project providing ecological benefits, cost-effective with respect to such benefits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c6089e8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2347c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the program under this section, the Secretary shall give preference to a small water storage project located in a State with a population of less than 1,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c6089e9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2347c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedited projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the 10-year period beginning on ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary shall expedite small water storage projects under this section for which applicable Federal permitting requirements have been completed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c6089ea-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2347c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of data","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting a study under this section, to the maximum extent practicable, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c6089eb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2347c/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as the Secretary determines appropriate, consider and utilize any applicable hydrologic, economic, or environmental data that is prepared for a small water storage project under State law as the documentation, or part of the documentation, required to complete State water plans or other State planning documents relating to water resources management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c6089ec-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2347c/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider information developed by the non-Federal interest in relation to another study, to the extent the Secretary determines such information is applicable, appropriate, or otherwise authorized by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c6089ed-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2347c/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost share","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c6089ee-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2347c/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal share of the cost of a study conducted under this section shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c6089ef-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2347c/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 100 percent for costs not to exceed $100,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c6089f0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2347c/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent for any costs above $100,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c6089f1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2347c/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A small water storage project carried out under this section shall be subject to the cost-sharing requirements applicable to projects under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2213"},"text":"section 2213 of this title","children":[],"tail":", including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c6089f2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2347c/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" municipal and industrial water supply: 100 percent non-Federal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c6089f3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2347c/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agricultural water supply: 35 percent non-Federal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c6089f4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2347c/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recreation, including recreational navigation: 50 percent of separable costs and, in the case of any harbor or inland harbor or channel project, 50 percent of joint and separable costs allocated to recreational navigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c6089f5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2347c/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" OMRRR responsibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The costs of operation, maintenance, repair, and replacement and rehabilitation for a small water storage project constructed under this section shall be the responsibility of the non-Federal interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c6089f6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2347c/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individual project limit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than $65,000,000 in Federal funds may be made available to a small water storage project under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c6089f7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2347c/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $130,000,000 annually through fiscal year 2030.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c6089f8-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/tI/s155"},"text":"Pub. L. 116–260, div. AA, title I, § 155","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2660"},"text":"134 Stat. 2660","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c6089f9-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c6089fa-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c6089fb-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 2020, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c6089fc-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c6089fd-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/s2"},"text":"section 2 of div. AA of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
