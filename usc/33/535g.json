{"tag":"section","attrib":{"id":"id6b3d8d77-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s535g"},"text":null,"children":[{"tag":"num","attrib":{"value":"535g"},"text":"§ 535g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal navigable waters and commerce jurisdiction unaffected","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to affect, impair, or diminish any right, power, or jurisdiction of the United States over or in regard to any navigable water or any interstate or foreign commerce.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b3d8d78-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/434/s10"},"text":"Pub. L. 92–434, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-09-26"},"text":"Sept. 26, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/733"},"text":"86 Stat. 733","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
