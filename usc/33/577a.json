{"tag":"section","attrib":{"id":"id6b472a2d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s577a"},"text":null,"children":[{"tag":"num","attrib":{"value":"577a"},"text":"§ 577a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small-boat navigation projects; charter fishing craft","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Chief of Engineers, for the purpose of determining Federal and non-Federal cost sharing, relating to proposed construction of small-boat navigation projects, shall consider charter fishing craft as commercial vessels.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b472a2e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/611/tI/s119"},"text":"Pub. L. 91–611, title I, § 119","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1822"},"text":"84 Stat. 1822","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
