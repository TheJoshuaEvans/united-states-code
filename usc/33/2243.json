{"tag":"section","attrib":{"id":"id6c3f1e2c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2243"},"text":null,"children":[{"tag":"num","attrib":{"value":"2243"},"text":"§ 2243.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Arctic deep draft port development partnerships","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c3f1e2d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2243/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide technical assistance to non-Federal public entities, including Indian tribes (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":") and a Native village, Regional Corporation, or Village Corporation (as those terms are defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1602"},"text":"section 1602 of title 43","children":[],"tail":" "},{"tag":"ref","attrib":{"idref":"fn002104"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002104"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a closing parenthesis."}],"tail":", for the development, construction, operation, and maintenance of channels, harbors, and related infrastructure associated with deep draft ports for purposes of dealing with Arctic development and security needs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c3f1e2e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2243/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to accept and expend funds provided by non-Federal public entities, including Indian tribes (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":") and a Native village, Regional Corporation, or Village Corporation (as those terms are defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1602"},"text":"section 1602 of title 43","children":[],"tail":" "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":", to carry out the technical assistance activities described in subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c3f1e2f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2243/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No assistance may be provided under this section until after the date on which the entity to which that assistance is to be provided enters into a written agreement with the Secretary that includes such terms and conditions as the Secretary determines to be appropriate and in the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c3f1e30-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2243/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prioritize technical assistance provided under this section for Arctic deep draft ports identified by the Secretary, the Secretary of the department in which the Coast Guard is operating, and the Secretary of Defense as important for Arctic development and security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c3f1e31-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2243/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of national security interests","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out a study of the feasibility of an Arctic deep draft port, the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c3f1e32-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2243/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall consult with the Secretary of the department in which the Coast Guard is operating to identify benefits in carrying out the missions specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s468"},"text":"section 468 of title 6","children":[],"tail":" associated with an Arctic deep draft port;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3f1e33-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2243/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall consult with the Secretary of Defense to identify national security benefits associated with an Arctic deep draft port; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3f1e34-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2243/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may consider such benefits in determining whether an Arctic deep draft port is feasible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c3f1e35-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/tII/s2105"},"text":"Pub. L. 113–121, title II, § 2105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1279"},"text":"128 Stat. 1279","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tI/s1202/c"},"text":"Pub. L. 114–322, title I, § 1202(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1684"},"text":"130 Stat. 1684","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c3f1e36-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c3f1e37-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c3f1e38-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Reform and Development Act of 2014, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c3f1e39-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1202/c/1"},"text":"Pub. L. 114–322, § 1202(c)(1)","children":[],"tail":", inserted “and a Native village, Regional Corporation, or Village Corporation (as those terms are defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1602"},"text":"section 1602 of title 43","children":[],"tail":"” after “title 25)” and made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1202/c/2"},"text":"Pub. L. 114–322, § 1202(c)(2)","children":[],"tail":", substituted “the Secretary of the department in which the Coast Guard is operating” for “the Secretary of Homeland Security”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1202/c/3"},"text":"Pub. L. 114–322, § 1202(c)(3)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c3f1e3a-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c3f1e3b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s2"},"text":"section 2 of Pub. L. 113–121","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
