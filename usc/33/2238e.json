{"tag":"section","attrib":{"id":"id6c3cd4dd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238e"},"text":null,"children":[{"tag":"num","attrib":{"value":"2238e"},"text":"§ 2238e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional projects for underserved community harbors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c3cd4de-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations designated by statute as being for the purpose of carrying out this section, the Secretary may carry out projects for underserved community harbors for purposes of sustaining water-dependent commercial and recreational activities at such harbors and for purposes of contributing to ecosystem restoration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c3cd4df-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Beneficial use","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c3cd4e0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Justification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may carry out a project under this section involving a disposal option for the beneficial use of dredged material that is not the least cost disposal option if the Secretary determines that the incremental cost of the disposal option is reasonable pursuant to the standard described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2326/d/1"},"text":"section 2326(d)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3cd4e1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal share of the incremental cost of a project carried out under this section involving a disposal option for the beneficial use of dredged material that is not the least cost disposal option shall be determined as provided under subsections (a) through (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2213"},"text":"section 2213 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c3cd4e2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prioritize carrying out projects using funds made available under this section based on an assessment of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c3cd4e3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the local or regional economic benefits of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3cd4e4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the environmental benefits of the project, including the benefits to the aquatic environment to be derived from the creation of wetland and control of shoreline erosion; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3cd4e5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238e/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other social effects of the project, including protection against loss of life and contributions to local or regional cultural heritage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c3cd4e6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clarification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not require the non-Federal interest for a project carried out under this section to perform additional operation and maintenance activities at the beneficial use placement site or the disposal site for such project as a condition of receiving assistance under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c3cd4e7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal participation limit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of a project under this section shall not exceed $10,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c3cd4e8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238e/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statutory construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Projects carried out under this section shall be in addition to operation and maintenance activities otherwise carried out by the Secretary for underserved community harbors using funds appropriated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2238"},"text":"section 2238 of this title","children":[],"tail":" or section 102(a) of the Water Resources Development Act of 2020 ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2238"},"text":"33 U.S.C. 2238","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c3cd4e9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238e/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c3cd4ea-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238e/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “project” means a single cycle of maintenance dredging of an underserved community harbor and any associated placement of dredged material at a beneficial use placement site or disposal site.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3cd4eb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238e/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Underserved community harbor","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “underserved community harbor” means an emerging harbor (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2238/f"},"text":"section 2238(f) of this title","children":[],"tail":"), a harbor where passenger or freight service is provided to island communities dependent on that service, or a marina or berthing area that is located adjacent to, or is accessible by, a Federal navigation project, for which—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c3cd4ec-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238e/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no Federal funds have been obligated for maintenance dredging in the current fiscal year or in any of the 4 preceding fiscal years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3cd4ed-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238e/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and local investments in infrastructure have been made during any of the 4 preceding fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c3cd4ee-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238e/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c3cd4ef-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238e/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $50,000,000 from the General Fund of the Treasury for each of fiscal years 2023 through 2029, to be deposited into the “","children":[{"tag":"inline","attrib":{},"text":"corps of engineers—civil—operation and maintenance","children":[],"tail":"” account."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3cd4f0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238e/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 35 percent of the amounts made available to carry out this section for each fiscal year shall be used for projects involving the beneficial use of dredged material.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c3cd4f1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238e/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects for marina or berthing areas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may carry out not more than 10 projects under this section that are projects for an underserved community harbor that is a marina or berthing area described in subsection (g)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c3cd4f2-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dH/tLXXXI/s8132"},"text":"Pub. L. 117–263, div. H, title LXXXI, § 8132","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3719"},"text":"136 Stat. 3719","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dA/tIII/s1356"},"text":"Pub. L. 118–272, div. A, title III, § 1356","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3161"},"text":"138 Stat. 3161","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c3cd4f3-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c3cd4f4-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c3cd4f5-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 102(a) of the Water Resources Development Act of 2020, referred to in subsec. (f), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/s102/a"},"text":"section 102(a) of div. AA of Pub. L. 116–260","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2238"},"text":"section 2238 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c3cd4f6-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 2022, and also as part of the James M. Inhofe National Defense Authorization Act for Fiscal Year 2023, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c3cd4f7-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1356/1"},"text":"Pub. L. 118–272, § 1356(1)","children":[],"tail":", inserted “and for purposes of contributing to ecosystem restoration” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1356/2"},"text":"Pub. L. 118–272, § 1356(2)","children":[],"tail":", in introductory provisions, inserted “, a harbor where passenger or freight service is provided to island communities dependent on that service, or a marina or berthing area that is located adjacent to, or is accessible by, a Federal navigation project,” before “for which”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1356/3"},"text":"Pub. L. 118–272, § 1356(3)","children":[],"tail":", substituted “2029” for “2026”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1356/4"},"text":"Pub. L. 118–272, § 1356(4)","children":[],"tail":", added subsec. (i)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c3cd4f8-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c3cd4f9-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s8002"},"text":"section 8002 of Pub. L. 117–263","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
