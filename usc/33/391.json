{"tag":"section","attrib":{"id":"id6b1c4963-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s391"},"text":null,"children":[{"tag":"num","attrib":{"value":"391"},"text":"§ 391.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Summary trials authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever a complaint shall be made against any master, officer, or seaman of any vessel belonging, in whole or in part, to any citizen of the United States, of the commission of any offense, not capital or otherwise infamous, against any law of the United States made for the protection of persons or property engaged in commerce or navigation, it shall be the duty of the United States attorney to investigate the same, and the general nature thereof, and if, in his opinion, the case is such as should be summarily tried, he shall report the same to the district judge, and the judge shall forthwith, or as soon as the ordinary business of the court will permit, proceed to try the cause, and for that purpose may, if necessary, hold a special session of the court, either in term time or vacation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b1c4964-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(R.S. § 4300; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646/s1"},"text":"June 25, 1948, ch. 646, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/909"},"text":"62 Stat. 909","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b1c4965-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b1c4966-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b1c4967-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 4300 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1864-06-11/ch121/s2"},"text":"act June 11, 1864, ch. 121, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/13/124"},"text":"13 Stat. 124","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b1c4968-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id6b1c4969-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1948-06-25"},"text":"June 25, 1948","children":[],"tail":", eff. "},{"tag":"date","attrib":{"date":"1948-09-01"},"text":"Sept. 1, 1948","children":[],"tail":", substituted “United States attorney” for “district attorney”. See "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s541"},"text":"section 541 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure, and Historical and Revision Notes set out thereunder."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
