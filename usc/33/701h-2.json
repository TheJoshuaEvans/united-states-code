{"tag":"section","attrib":{"id":"id6b5ef7f4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701h–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"701h–2"},"text":"§ 701h–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No adverse effect on processes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In implementing any provision of law that authorizes a non-Federal interest to provide, advance, or contribute funds to the Secretary for the development or implementation of a water resources development project (including sections 2231 and 2232 of this title, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s701h"},"text":"section 701h of this title","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s701h–1"},"text":"section 701h–1 of this title","children":[],"tail":"), the Secretary shall ensure, to the maximum extent practicable, that the use by a non-Federal interest of such authorities does not adversely affect—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b5ef7f5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701h–2/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the process or timeline for development and implementation of other water resources development projects by other non-Federal entities that do not use such authorities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b5ef7f6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701h–2/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the process for including such projects in the President’s annual budget submission to Congress under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b5ef7f7-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/tI/s1166/b"},"text":"Pub. L. 115–270, title I, § 1166(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3797"},"text":"132 Stat. 3797","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b5ef7f8-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b5ef7f9-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b5ef7fa-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/s102"},"text":"section 102 of Pub. L. 115–270","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
