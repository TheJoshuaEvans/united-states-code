{"tag":"section","attrib":{"id":"id6b5a3d6f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–16"},"text":null,"children":[{"tag":"num","attrib":{"value":"701b–16"},"text":"§ 701b–16.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management of flood risk reduction projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b5a3d70-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–16/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If 2 or more flood control projects are located within the same geographic area, the Secretary shall, at the request of the non-Federal interests for the affected projects, consider those projects as a single program for budgetary or project management purposes, if the Secretary determines that doing so would not be incompatible with the authorized project purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b5a3d71-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–16/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost share","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b5a3d72-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–16/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any work on a project to which subsection (a) applies is required solely because of impacts to that project from a navigation project, the cost of carrying out that work shall be shared in accordance with the cost-sharing requirements for the navigation project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b5a3d73-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–16/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Work described in paragraph (1) may be carried out using amounts made available under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b5a3d74-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/tIII/s3012"},"text":"Pub. L. 113–121, title III, § 3012","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1284"},"text":"128 Stat. 1284","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b5a3d75-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b5a3d76-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b5a3d77-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s2"},"text":"section 2 of Pub. L. 113–121","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
