{"tag":"section","attrib":{"id":"id6b0454b6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s23"},"text":null,"children":[{"tag":"num","attrib":{"value":"23"},"text":"§ 23.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bear Creek, Mississippi","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Bear Creek in Humphreys, Leflore, and Sunflower Counties, in the State of Mississippi, is declared to be a nonnavigable stream within the meaning of the Constitution and the laws of the United States.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The right of Congress to alter, amend, or repeal this section is expressly reserved.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b0454b7-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1923-03-03/ch229"},"text":"Mar. 3, 1923, ch. 229","children":[],"tail":", §§ 1, 2, "},{"tag":"ref","attrib":{"href":"/us/stat/42/1442"},"text":"42 Stat. 1442","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b0454b8-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b0454b9-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b0454ba-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The first sentence hereof is section 1 and the last sentence section 2 of act ","children":[{"tag":"date","attrib":{"date":"1923-03-03"},"text":"Mar. 3, 1923","children":[],"tail":", entitled “An Act declaring Bear Creek in Humphreys, Leflore, and Sunflower counties, Mississippi, to be a nonnavigable stream”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
