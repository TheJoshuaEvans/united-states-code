{"tag":"section","attrib":{"id":"id6c595dfa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328"},"text":null,"children":[{"tag":"num","attrib":{"value":"2328"},"text":"§ 2328.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Challenge cost-sharing program for management of recreation facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c595dfb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to develop and implement a program to share the cost of managing recreation facilities and natural resources at water resource development projects under the Secretary’s jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c595dfc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c595dfd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To implement the program under this section, the Secretary is authorized to enter into cooperative agreements with non-Federal public entities and private nonprofit entities to provide for operation and management of recreation facilities and natural resources at civil works projects under the Secretary’s jurisdiction where such facilities and resources are being maintained at complete Federal expense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595dfe-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before entering into an agreement under paragraph (1), the Secretary shall ensure that the non-Federal public entity or private nonprofit entity has the authority and capability—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c595dff-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out the terms of the agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c595e00-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pay damages, if necessary, in the event of a failure to perform.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c595e01-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" User fees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c595e02-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of fees","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c595e03-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may allow a non-Federal public entity or private nonprofit entity that has entered into an agreement pursuant to subsection (b) to collect user fees for the use of developed recreation sites and facilities, whether developed or constructed by the non-Federal public entity or private nonprofit entity or the Department of the Army.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c595e04-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of visitor reservation services","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c595e05-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A non-Federal public entity or a private nonprofit entity described in subparagraph (A) may use, to manage fee collections and reservations under this section, any visitor reservation service that the Secretary has provided for by contract or interagency agreement, subject to such terms and conditions as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c595e06-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may transfer, or cause to be transferred by another Federal agency, to a non-Federal public entity or a private nonprofit entity described in subparagraph (A) user fees received by the Secretary or other Federal agency under a visitor reservation service described in clause (i) for recreation facilities and natural resources managed by the non-Federal public entity or private nonprofit entity pursuant to a cooperative agreement entered into under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595e07-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of fees","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c595e08-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A non-Federal public entity or private nonprofit entity that collects a user fee under paragraph (1)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c595e09-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may retain up to 100 percent of the fees collected, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c595e0a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460d–3/b/4"},"text":"section 460d–3(b)(4) of title 16","children":[],"tail":", shall use any retained amounts for operation, maintenance, and management activities relating to recreation and natural resources at any recreation site or facility that is located at the civil works project at which the fee is collected."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c595e0b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The use by a non-Federal public entity or private nonprofit entity of user fees collected under paragraph (1)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c595e0c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall remain subject to the direction and oversight of the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c595e0d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not affect any existing third-party property interest, lease, or agreement with the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595e0e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority of a non-Federal public entity or private nonprofit entity under this subsection shall be subject to such terms and conditions as the Secretary determines to be necessary to protect the interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c595e0f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contributions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c595e10-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of carrying out this section the Secretary may accept contributions of funds, materials, and services from non-Federal public entities, private nonprofit entities, and other private entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595e11-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any funds received by the Secretary under this subsection shall be deposited into the account in the Treasury of the United States entitled “Contributions and Advances, Rivers and Harbors, Corps of Engineers (8862)” and shall be available until expended to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c595e12-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c595e13-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal public entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “non-Federal public entity” means a non-Federal public entity as defined in the memorandum issued by the Corp of Engineers on ","children":[{"tag":"date","attrib":{"date":"2018-04-04"},"text":"April 4, 2018","children":[],"tail":", and titled “Implementation Guidance for Section 1155, Management of Recreation Facilities, of the Water Resources Development Act (WRDA) of 2016, "},{"tag":"ref","attrib":{"href":"/us/pl/114/322"},"text":"Public Law 114–322","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595e14-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private nonprofit entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “private nonprofit entity” means an organization that is described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c"},"text":"section 501(c) of title 26","children":[],"tail":" and exempt from taxation under section 501(a) of that title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c595e15-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/580/tII/s225"},"text":"Pub. L. 102–580, title II, § 225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-31"},"text":"Oct. 31, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4838"},"text":"106 Stat. 4838","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/303/tII/s236/b"},"text":"Pub. L. 104–303, title II, § 236(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3705"},"text":"110 Stat. 3705","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tI/s1155"},"text":"Pub. L. 114–322, title I, § 1155","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1663"},"text":"130 Stat. 1663","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dA/tI/s1153"},"text":"Pub. L. 118–272, div. A, title I, § 1153","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3043"},"text":"138 Stat. 3043","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/74/dB/tI/s109"},"text":"Pub. L. 119–74, div. B, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-01-23"},"text":"Jan. 23, 2026","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/140/70"},"text":"140 Stat. 70","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c595e16-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c595e17-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c595e18-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 1992, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c595e19-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2026—Subsec. (c)(2)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/74"},"text":"Pub. L. 119–74","children":[],"tail":" substituted “at any recreation site or facility that is located at the civil works project at which the fee is collected” for “at recreation site at which the fee is collected”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2025—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1153/1"},"text":"Pub. L. 118–272, § 1153(1)","children":[],"tail":", designated existing provisions as par. (1) and inserted heading, substituted “non-Federal public entities and private nonprofit entities” for “non-Federal public and private entities”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1153/2"},"text":"Pub. L. 118–272, § 1153(2)","children":[],"tail":", added subsec. (c) and struck out former subsec. (c) which related to user fees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1153/3"},"text":"Pub. L. 118–272, § 1153(3)","children":[],"tail":", designated first sentence of existing provisions as par. (1), inserted heading, and substituted “non-Federal public entities, private nonprofit entities, and other private entities” for “non-Federal public and private entities” and designated second sentence of existing provisions as par. (2), inserted heading, and substituted “under this subsection” for “under this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1153/4"},"text":"Pub. L. 118–272, § 1153(4)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322"},"text":"Pub. L. 114–322","children":[],"tail":" added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/303"},"text":"Pub. L. 104–303","children":[],"tail":" substituted “(8862)” for “(8662)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c595e1a-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Recreation Partnership Initiative","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/303/tV/s519"},"text":"Pub. L. 104–303, title V, § 519","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3765"},"text":"110 Stat. 3765","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/106/53/tIII/s350/a"},"text":"Pub. L. 106–53, title III, § 350(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-08-17"},"text":"Aug. 17, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/310"},"text":"113 Stat. 310","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/53/tIII/s350/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall promote Federal, non-Federal, and private sector cooperation in creating public recreation opportunities and developing the necessary supporting infrastructure at water resources projects of the Corps of Engineers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Infrastructure Improvements.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recreation infrastructure improvements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In determining the feasibility of the public-private cooperative under subsection (a), the Secretary shall provide such infrastructure improvements as are necessary to support a potential private recreational development at the Raystown Lake Project, Pennsylvania, generally in accordance with the Master Plan Update (1994) for the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall enter into an agreement with an appropriate non-Federal public entity to ensure that the infrastructure improvements constructed by the Secretary on non-project lands pursuant to paragraph (1) are transferred to and operated and maintained by the non-Federal public entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Engineering and design services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may perform engineering and design services for project infrastructure expected to be associated with the development of the site at Raystown Lake, Hesston, Pennsylvania.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated to carry out this subsection $3,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1998-12-31"},"text":"December 31, 1998","children":[],"tail":", the Secretary shall transmit to Congress a report on the results of the cooperative efforts carried out under this section, including the improvements required by subsection (b).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c595e1b-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c595e1c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/580/s3"},"text":"section 3 of Pub. L. 102–580","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
