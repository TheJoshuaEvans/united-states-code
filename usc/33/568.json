{"tag":"section","attrib":{"id":"id6b44b991-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s568"},"text":null,"children":[{"tag":"num","attrib":{"value":"568"},"text":"§ 568.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on power of committee of Congress to consider projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No project shall be considered by any committee of Congress with a view to its adoption, except with a view to a survey, if five years have elapsed since a report upon a survey of such project has been submitted to Congress pursuant to law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b44b992-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-22/ch427/s9"},"text":"Sept. 22, 1922, ch. 427, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/1043"},"text":"42 Stat. 1043","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b44b993-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b44b994-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b44b995-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from act ","children":[{"tag":"date","attrib":{"date":"1922-09-22"},"text":"Sept. 22, 1922","children":[],"tail":", popularly known as the “Rivers and Harbors Appropriation Act of 1918”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
