{"tag":"section","attrib":{"id":"id6b0b8160-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59e"},"text":null,"children":[{"tag":"num","attrib":{"value":"59e"},"text":"§ 59e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bayou Lafourche, Louisiana","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Bayou Lafourche, in the State of Louisiana, between Canal Boulevard, city of Thibodaux, Parish of Lafourche, State of Louisiana, and the head of the bayou at its junction with the Mississippi River levee at the city of Donaldsonville, Parish of Ascension, State of Louisiana, is hereby declared to be a nonnavigable waterway of the United States within the meaning of the laws of the United States. The existing project for Bayou Lafourche, Louisiana, authorized by the Acts of ","children":[{"tag":"date","attrib":{"date":"1935-08-30"},"text":"August 30, 1935","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/49/1028"},"text":"49 Stat. 1028","children":[],"tail":") and "},{"tag":"date","attrib":{"date":"1960-07-14"},"text":"July 14, 1960","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/74/480"},"text":"74 Stat. 480","children":[],"tail":") is hereby deauthorized in the reach of Bayou Lafourche herein declared nonnavigable."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The right to alter, amend, or repeal this section is hereby expressly reserved.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b0b8161-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/149"},"text":"Pub. L. 90–149","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-11-22"},"text":"Nov. 22, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/507"},"text":"81 Stat. 507","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b0b8162-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b0b8163-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6b0b8164-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The provisions of the Acts of ","children":[{"tag":"date","attrib":{"date":"1935-08-30"},"text":"August 30, 1935","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/49/1028"},"text":"49 Stat. 1028","children":[],"tail":") and "},{"tag":"date","attrib":{"date":"1960-07-14"},"text":"July 14, 1960","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/74/480"},"text":"74 Stat. 480","children":[],"tail":"), referred to in text, authorizing the Bayou Lafourche, Louisiana, project, are not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b0b8165-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b0b8166-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Portion of Bayou Lafourche Declared To Be Navigable Waterway","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/595/tIII/s314"},"text":"Pub. L. 101–595, title III, § 314","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2987"},"text":"104 Stat. 2987","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/595/tIII/s314"},"text":"“Bayou Lafourche, in the State of Louisiana, between the Percy Brown Road (Hwy 648), city of Thibodaux, parish of Lafourche, and the Southern Pacific Railroad bridge crossing the bayou, city of Thibodaux, parish of Lafourche, is declared to be navigable waterway of the United States under chapter 11 of title 33, United States Code.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
