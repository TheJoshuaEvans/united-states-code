{"tag":"section","attrib":{"id":"id6b3b43f4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s521"},"text":null,"children":[{"tag":"num","attrib":{"value":"521"},"text":"§ 521.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations and orders","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to prescribe such rules and regulations, and to make and issue such orders, as may be necessary or appropriate for carrying out the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b3b43f5-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-06-21/ch409/s11"},"text":"June 21, 1940, ch. 409, § 11","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/501"},"text":"54 Stat. 501","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
