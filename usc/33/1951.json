{"tag":"section","attrib":{"id":"id6c22964c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1951"},"text":null,"children":[{"tag":"num","attrib":{"value":"1951"},"text":"§ 1951.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The purpose of this chapter is to address the adverse impacts of marine debris on the United States economy, the marine environment (including waters in the jurisdiction of the United States, the high seas, and waters in the jurisdiction of other countries), and navigation safety through the identification, determination of sources, assessment, prevention, reduction, and removal of marine debris.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6c22964d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/449/s2"},"text":"Pub. L. 109–449, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3333"},"text":"120 Stat. 3333","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/213/tVI/s603"},"text":"Pub. L. 112–213, title VI, § 603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-20"},"text":"Dec. 20, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1576"},"text":"126 Stat. 1576","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/224/tI/s101/1"},"text":"Pub. L. 116–224, title I, § 101(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-18"},"text":"Dec. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1074"},"text":"134 Stat. 1074","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/65/s6/a"},"text":"Pub. L. 119–65, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-26"},"text":"Dec. 26, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1990"},"text":"139 Stat. 1990","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c22964e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c22964f-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c229650-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/65"},"text":"Pub. L. 119–65","children":[],"tail":", which directed amendment of this section by substituting “Under Secretary” for “Administrator”, could not be executed because the word “Administrator” did not appear."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/224"},"text":"Pub. L. 116–224","children":[],"tail":" substituted “marine environment (including waters in the jurisdiction of the United States, the high seas, and waters in the jurisdiction of other countries),” for “marine environment,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213"},"text":"Pub. L. 112–213","children":[],"tail":" amended section generally. Prior to amendment, text read as follows: “The purposes of this chapter are—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) to help identify, determine sources of, assess, reduce, and prevent marine debris and its adverse impacts on the marine environment and navigation safety;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) to reactivate the Interagency Marine Debris Coordinating Committee; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) to develop a Federal marine debris information clearinghouse.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c229651-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id6c229652-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/65/s1"},"text":"Pub. L. 119–65, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-26"},"text":"Dec. 26, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1986"},"text":"139 Stat. 1986","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/65/s1"},"text":"“This Act [see Tables for classification] may be cited as the ‘Save Our Seas 2.0 Amendments Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id6c229653-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213/tVI/s601"},"text":"Pub. L. 112–213, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-20"},"text":"Dec. 20, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1576"},"text":"126 Stat. 1576","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/213/tVI/s601"},"text":"“This title [amending this section and sections 1952 to 1956 of this title, transferring ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1914"},"text":"section 1914 of this title","children":[],"tail":" to "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1954"},"text":"section 1954 of this title","children":[],"tail":", repealing sections 1915 and 1954 of this title, and amending provisions set out as a note under this section] may be cited as the ‘Marine Debris Act Amendments of 2012’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id6c229654-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/449/s1"},"text":"Pub. L. 109–449, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3333"},"text":"120 Stat. 3333","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/112/213/tVI/s602/a"},"text":"Pub. L. 112–213, title VI, § 602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-20"},"text":"Dec. 20, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1576"},"text":"126 Stat. 1576","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/65/s6/a"},"text":"Pub. L. 119–65, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-26"},"text":"Dec. 26, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1990"},"text":"139 Stat. 1990","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/65/s6/a"},"text":"“This Act [enacting and amending this chapter] may be cited as the ‘Marine Debris Act’.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/65/s6/a"},"text":"section 6(a) of Pub. L. 119–65","children":[],"tail":" substituting “Under Secretary” for “Administrator” in "},{"tag":"ref","attrib":{"href":"/us/pl/109/449/s1"},"text":"section 1 of Pub. L. 109–449","children":[],"tail":", set out above, could not be executed because the word “Administrator” did not appear.]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
