{"tag":"section","attrib":{"id":"id6c52314b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317"},"text":null,"children":[{"tag":"num","attrib":{"value":"2317"},"text":"§ 2317.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wetlands","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c52314c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals and action plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c52314d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established, as part of the Corps of Engineers water resources development program, an interim goal of no overall net loss of the Nation’s remaining wetlands base, as defined by acreage and function, and a long-term goal to increase the quality and quantity of the Nation’s wetlands, as defined by acreage and function.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c52314e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of authorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall utilize all appropriate authorities, including those to restore and create wetlands, in meeting the interim and long-term goals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c52314f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action plan","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c523150-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop, in consultation with the Environmental Protection Agency, the Fish and Wildlife Service, and other appropriate Federal agencies, a wetlands action plan to achieve the goals established by this subsection as soon as possible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c523151-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The plan shall include and identify actions to be taken by the Secretary in achieving the goals and any new authorities which may be necessary to accelerate attainment of the goals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c523152-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Completion deadline","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall complete the plan not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c523153-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Constructed wetlands for Mud Creek, Arkansas","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary is authorized and directed to establish and carry out a research and pilot project to evaluate and demonstrate—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c523154-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of constructed wetlands for wastewater treatment, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c523155-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" methods by which such projects contribute—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c523156-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to meeting the objective of the Federal Water Pollution Control Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251"},"text":"33 U.S.C. 1251","children":[],"tail":" et seq.] to restore and maintain the physical, chemical, and biological integrity of the Nation’s waters, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c523157-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to attaining the goals established by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The project under this subsection shall be carried out to improve the quality of effluent discharged from publicly owned treatment works operated by the city of Fayetteville, Arkansas, into Mud Creek or its tributaries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c523158-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the project conducted under subsection (b), the non-Federal interest shall agree—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c523159-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide, without cost to the United States, all lands, easements, rights-of-way, relocations, and dredged material disposal areas necessary for construction and subsequent research and demonstration work;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c52315a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to hold and save the United States free from damages due to construction, operation, and maintenance of the project, except damages due to the fault or negligence of the United States or its contractors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c52315b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to operate and maintain the restored or constructed wetlands in accordance with good management practices; except that nothing in this paragraph shall be construed as precluding a Federal agency from agreeing to operate and maintain the restored or reconstructed wetlands.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The value of the non-Federal lands, easements, rights-of-way, relocations, and dredged material disposal areas provided by the non-Federal interest shall be credited toward the non-Federal share of project design and construction costs. The non-Federal share of project design and construction costs shall be 25 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c52315c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wetlands restoration and enhancement demonstration program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c52315d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Administrator, is authorized to establish and implement a demonstration program for the purpose of determining the feasibility of wetlands restoration, enhancement, and creation as a means of contributing to the goals established by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c52315e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The goal of the program under this subsection shall be to establish a limited number of demonstration wetlands restoration, enhancement, and creation areas in districts of the Corps of Engineers for the purpose of evaluating the technical and scientific long-term feasibility of such areas as a means of contributing to the attainment of the goals established by subsection (a). Federal and State land-owning agencies and private parties may contribute to such areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c52315f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors to consider","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In establishing the demonstration program under this subsection, the Secretary shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c523160-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" past experience with wetlands restoration, enhancement, and creation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c523161-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate means of measuring benefits of compensatory mitigation activities, including enhancement or restoration of existing wetlands or creation of wetlands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c523162-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate geographic scope for which wetlands loss may be offset by restoration, enhancement, and creation efforts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c523163-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the technical feasibility and scientific likelihood that wetlands can be successfully restored, enhanced, and created;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c523164-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317/d/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means of establishing liability for, and long-term ownership of, wetlands restoration, enhancement, and creation areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c523165-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317/d/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" responsibilities for short- and long-term project monitoring.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c523166-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c523167-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" To the Chief of Engineers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The district engineer for each district of the Corps of Engineers in which a wetlands restoration, enhancement, and creation area is established under this subsection shall transmit annual reports to the Chief of Engineers describing the amount and value of wetlands restored, enhanced, and created for the area and a summary of whether the area is contributing to the goal established in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c523168-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" To Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":", the Secretary shall transmit to Congress a report evaluating the use of wetlands restoration, enhancement, and creation areas in fulfilling the goal established by paragraph (2), together with recommendations on whether or not to continue use of such areas as a means of meeting the goals established by subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c523169-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection affects any requirements under section 404 of the Federal Water Pollution Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1344"},"text":"33 U.S.C. 1344","children":[],"tail":") or "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s403"},"text":"section 403 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c52316a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training and certification of delineators","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c52316b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to establish a program for the training and certification of individuals as wetlands delineators. As part of such program, the Secretary shall carry out demonstration projects in districts of the Corps of Engineers. The program shall include training and certification of delineators and procedures for expediting consideration and acceptance of delineations performed by certified delineators.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c52316c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall transmit to Congress periodic reports concerning the status of the program and any recommendations on improving the content and implementation of the Federal Manual for Identifying and Delineating Jurisdictional Wetlands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c52316d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/640/tIII/s307"},"text":"Pub. L. 101–640, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4635"},"text":"104 Stat. 4635","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c52316e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c52316f-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c523170-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Water Pollution Control Act, referred to in subsec. (b)(2)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"act June 30, 1948, ch. 758","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/92/500/s2"},"text":"Pub. L. 92–500, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-18"},"text":"Oct. 18, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/816"},"text":"86 Stat. 816","children":[],"tail":", which is classified generally to chapter 26 (§ 1251 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251"},"text":"section 1251 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c523171-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 1990, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c523172-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c523173-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions of law requiring submittal to Congress of any annual, semiannual, or other regular periodic report listed in House Document No. 103–7 (in which a report required under subsec. (e)(2) of this section is listed on page 70), see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c523174-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wetlands Enhancement Opportunities","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/640/tIV/s409"},"text":"Pub. L. 101–640, title IV, § 409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4648"},"text":"104 Stat. 4648","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/640/tIV/s409"},"text":"“Not later than ","children":[{"tag":"date","attrib":{"date":"1992-01-20"},"text":"January 20, 1992","children":[],"tail":", the Secretary shall transmit to Congress a list which specifically identifies opportunities of enhancing wetlands in connection with construction and operation of water resource projects.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c523175-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/640/s2"},"text":"section 2 of Pub. L. 101–640","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
