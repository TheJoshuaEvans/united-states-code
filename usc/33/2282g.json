{"tag":"section","attrib":{"id":"id6c48bca4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282g"},"text":null,"children":[{"tag":"num","attrib":{"value":"2282g"},"text":"§ 2282g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of feasibility studies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c48bca5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Flood risk management or hurricane and storm damage risk reduction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out a feasibility study for a project for flood risk management or hurricane and storm damage risk reduction, the Secretary, at the request of the non-Federal interest for the study, shall formulate alternatives to maximize the net benefits from the reduction of the comprehensive flood risk within the geographic scope of the study from the isolated and compound effects of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c48bca6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282g/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a riverine discharge of any magnitude or frequency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c48bca7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282g/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inundation, wave attack, and erosion coinciding with a hurricane or coastal storm;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c48bca8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282g/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" flooding associated with tidally influenced portions of rivers, bays, and estuaries that are hydrologically connected to the coastal water body;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c48bca9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282g/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a rainfall event of any magnitude or frequency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c48bcaa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282g/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a tide of any magnitude or frequency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c48bcab-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282g/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seasonal variation in water levels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c48bcac-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282g/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" groundwater emergence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c48bcad-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282g/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sea level rise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c48bcae-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282g/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsidence; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c48bcaf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282g/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other driver of flood risk affecting the area within the geographic scope of the study.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c48bcb0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water supply, water conservation, and drought risk reduction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out a feasibility study for any purpose, the Secretary, at the request of the non-Federal interest for the study, shall formulate alternatives—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c48bcb1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282g/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maximize combined net benefits for the primary purpose of the study and for the purposes of water supply or water conservation (including the use of water supply conservation measures described in section 1116 of the Water Resources Development Act of 2016 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/130/1639"},"text":"130 Stat. 1639","children":[],"tail":")); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c48bcb2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282g/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to include 1 or more measures for the purposes of water supply or water conservation if the Secretary determines that such measures may reduce potential adverse impacts of extreme weather events, including drought, on water resources within the geographic scope of the study.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c48bcb3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All costs to carry out a feasibility study in accordance with this section shall be shared in accordance with the cost share requirements otherwise applicable to the study.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c48bcb4-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dH/tLXXXI/s8106"},"text":"Pub. L. 117–263, div. H, title LXXXI, § 8106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3699"},"text":"136 Stat. 3699","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c48bcb5-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c48bcb6-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c48bcb7-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 1116 of the Water Resources Development Act of 2016, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1116"},"text":"section 1116 of Pub. L. 114–322","children":[],"tail":", title I, "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1639"},"text":"130 Stat. 1639","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c48bcb8-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 2022, and also as part of the James M. Inhofe National Defense Authorization Act for Fiscal Year 2023, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c48bcb9-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c48bcba-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s8002"},"text":"section 8002 of Pub. L. 117–263","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
