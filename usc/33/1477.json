{"tag":"section","attrib":{"id":"id6c0f83a9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1477"},"text":null,"children":[{"tag":"num","attrib":{"value":"1477"},"text":"§ 1477.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reasonable measures; considerations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c0f83aa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1477/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Measures directed or conducted under this chapter shall be proportionate to the damage, actual or threatened, to the coastline or related interests of the United States and may not go beyond what is reasonably necessary to prevent, mitigate, or eliminate that damage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c0f83ab-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1477/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In considering whether measures are proportionate to the damage the Secretary shall, among other things, consider—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c0f83ac-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1477/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent and probability of imminent damage if those measures are not taken;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0f83ad-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1477/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the likelihood of effectiveness of those measures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0f83ae-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1477/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent of the damage which may be caused by those measures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c0f83af-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/248/s8"},"text":"Pub. L. 93–248, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-02-05"},"text":"Feb. 5, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/9"},"text":"88 Stat. 9","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
