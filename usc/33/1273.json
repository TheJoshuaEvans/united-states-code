{"tag":"section","attrib":{"id":"id6bb4dfdf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1273"},"text":null,"children":[{"tag":"num","attrib":{"value":"1273"},"text":"§ 1273.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lake Pontchartrain Basin","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6bb4dfe0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1273/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of restoration program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall establish within the Environmental Protection Agency the Lake Pontchartrain Basin Restoration Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bb4dfe1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1273/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of the program shall be to restore the ecological health of the Basin by developing and funding restoration projects and related scientific and public education projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bb4dfe2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1273/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program, the Administrator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bb4dfe3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1273/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide administrative and technical assistance to a management conference convened for the Basin under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1330"},"text":"section 1330 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4dfe4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1273/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist and support the activities of the management conference, including the implementation of recommendations of the management conference;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4dfe5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1273/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support environmental monitoring of the Basin and research to provide necessary technical and scientific information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4dfe6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1273/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a comprehensive research plan to address the technical needs of the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4dfe7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1273/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate the grant, research, and planning programs authorized under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4dfe8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1273/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect and make available to the public publications, and other forms of information the management conference determines to be appropriate, relating to the environmental quality of the Basin; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4dfe9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1273/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the comprehensive conservation and management plan approved for the Basin under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1330"},"text":"section 1330 of this title","children":[],"tail":" is reviewed and revised in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1330"},"text":"section 1330 of this title","children":[],"tail":" not less often than once every 5 years, beginning on "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bb4dfea-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1273/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may make grants to pay not more than 75 percent of the costs—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bb4dfeb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1273/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for restoration projects and studies identified in the comprehensive conservation and management plan approved for the Basin under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1330"},"text":"section 1330 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4dfec-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1273/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for public education projects recommended by the management conference.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bb4dfed-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1273/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bb4dfee-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1273/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basin","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Basin” means the Lake Pontchartrain Basin, a 10,000 square mile watershed encompassing 16 parishes in the State of Louisiana and 4 counties in the State of Mississippi.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4dfef-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1273/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “program” means the Lake Pontchartrain Basin Restoration Program established under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bb4dff0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1273/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bb4dff1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1273/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $20,000,000 for each of fiscal years 2001 through 2012 and the amount appropriated for fiscal year 2009 for each of fiscal years 2013 through 2017. Such sums shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4dff2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1273/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public education projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 15 percent of the amount appropriated pursuant to paragraph (1) in a fiscal year may be expended on grants for public education projects under subsection (d)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4dff3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1273/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 5 percent of the amounts appropriated to carry out this section may be used for administrative expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6bb4dff4-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"June 30, 1948, ch. 758","children":[],"tail":", title I, § 121, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/457/tV/s502"},"text":"Pub. L. 106–457, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-07"},"text":"Nov. 7, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1973"},"text":"114 Stat. 1973","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/392/s1"},"text":"Pub. L. 109–392, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-12"},"text":"Dec. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2703"},"text":"120 Stat. 2703","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/237/s1"},"text":"Pub. L. 112–237, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-28"},"text":"Dec. 28, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1628"},"text":"126 Stat. 1628","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dH/tLXXXV/s8501/c"},"text":"Pub. L. 117–263, div. H, title LXXXV, § 8501(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3856"},"text":"136 Stat. 3856","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6bb4dff5-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6bb4dff6-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6bb4dff7-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Another section 121 of act ","children":[{"tag":"date","attrib":{"date":"1948-06-30"},"text":"June 30, 1948","children":[],"tail":", was renumbered section 122 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1274"},"text":"section 1274 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6bb4dff8-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s8501/c/1/A"},"text":"Pub. L. 117–263, § 8501(c)(1)(A)","children":[],"tail":", added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s8501/c/1/B"},"text":"Pub. L. 117–263, § 8501(c)(1)(B)","children":[],"tail":", substituted “identified in the comprehensive conservation and management plan approved for the Basin under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1330"},"text":"section 1330 of this title","children":[],"tail":"” for “recommended by a management conference convened for the Basin under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1330"},"text":"section 1330 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s8501/c/2"},"text":"Pub. L. 117–263, § 8501(c)(2)","children":[],"tail":", substituted “10,000 square mile” for “5,000 square mile”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s8501/c/3"},"text":"Pub. L. 117–263, § 8501(c)(3)","children":[],"tail":", added par (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/237/s1/1"},"text":"Pub. L. 112–237, § 1(1)","children":[],"tail":", inserted “to pay not more than 75 percent of the costs” after “make grants” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/237/s1/2"},"text":"Pub. L. 112–237, § 1(2)","children":[],"tail":", substituted “2012 and the amount appropriated for fiscal year 2009 for each of fiscal years 2013 through 2017” for “2011”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/392"},"text":"Pub. L. 109–392","children":[],"tail":" substituted “2011” for “2005”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6bb4dff9-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6bb4dffa-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Management Conference","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/tV/s5084"},"text":"Pub. L. 110–114, title V, § 5084","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-11-08"},"text":"Nov. 8, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1228"},"text":"121 Stat. 1228","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/114/tV/s5084"},"text":"“For purposes of carrying out section 121 of the Federal Water Pollution Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1273"},"text":"33 U.S.C. 1273","children":[],"tail":"), the Lake Pontchartrain, Louisiana, basin stakeholders conference convened by the Environmental Protection Agency, National Oceanic and Atmospheric Administration, and United States Geological Survey on "},{"tag":"date","attrib":{"date":"2002-02-25"},"text":"February 25, 2002","children":[],"tail":", shall be treated as being a management conference convened under section 320 of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1330"},"text":"33 U.S.C. 1330","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
