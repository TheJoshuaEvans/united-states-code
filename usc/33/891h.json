{"tag":"section","attrib":{"id":"id6b76c65b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891h"},"text":null,"children":[{"tag":"num","attrib":{"value":"891h"},"text":"§ 891h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b76c65c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary $93,000,000 for the period of fiscal years 2025 through 2026 to carry out this subchapter and section 302 of the Fisheries Survey Vessel Authorization Act of 2000 (title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/450"},"text":"Public Law 106–450","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/114/1945"},"text":"114 Stat. 1945","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s891b"},"text":"33 U.S.C. 891b","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b76c65d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on fleet modernization activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All NOAA fleet modernization, shipbuilding, and conversion shall be conducted in accordance with this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b79365e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/567/tVI/s610"},"text":"Pub. L. 102–567, title VI, § 610","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4303"},"text":"106 Stat. 4303","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dH/tLXXXIV/s8402/a/5"},"text":"Pub. L. 119–60, div. H, title LXXXIV, § 8402(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1910"},"text":"139 Stat. 1910","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b79365f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b793660-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b793661-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8402/a/5/A"},"text":"Pub. L. 119–60, § 8402(a)(5)(A)","children":[],"tail":", substituted “$93,000,000 for the period of fiscal years 2025 through 2026 to carry out this subchapter and section 302 of the Fisheries Survey Vessel Authorization Act of 2000 (title III of "},{"tag":"ref","attrib":{"href":"/us/pl/106/450"},"text":"Public Law 106–450","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/114/1945"},"text":"114 Stat. 1945","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s891b"},"text":"33 U.S.C. 891b","children":[],"tail":" note).” for “carrying out this subchapter—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) $50,000,000 for fiscal year 1993;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) $100,000,000 for fiscal year 1994; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) such sums as are necessary for each of the fiscal years 1995, 1996, and 1997.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8402/a/5/B"},"text":"Pub. L. 119–60, § 8402(a)(5)(B)","children":[],"tail":", substituted “NOAA fleet modernization,” for “National Oceanic and Atmospheric Administration fleet modernization”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
