{"tag":"section","attrib":{"id":"id6bc33842-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1289"},"text":null,"children":[{"tag":"num","attrib":{"value":"1289"},"text":"§ 1289.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basin planning","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6bc33843-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1289/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preparation of Level B plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President, acting through the Water Resources Council, shall, as soon as practicable, prepare a Level B plan under the Water Resources Planning Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1962"},"text":"42 U.S.C. 1962","children":[],"tail":" et seq.] for all basins in the United States. All such plans shall be completed not later than "},{"tag":"date","attrib":{"date":"1980-01-01"},"text":"January 1, 1980","children":[],"tail":", except that priority in the preparation of such plans shall be given to those basins and portions thereof which are within those areas designated under paragraphs (2), (3), and (4) of subsection (a) of "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1288"},"text":"section 1288 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bc33844-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1289/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President, acting through the Water Resources Council, shall report annually to Congress on progress being made in carrying out this section. The first such report shall be submitted not later than ","children":[{"tag":"date","attrib":{"date":"1973-01-31"},"text":"January 31, 1973","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bc33845-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1289/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section not to exceed $200,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6bc33846-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"June 30, 1948, ch. 758","children":[],"tail":", title II, § 209, as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/500/s2"},"text":"Pub. L. 92–500, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-18"},"text":"Oct. 18, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/843"},"text":"86 Stat. 843","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6bc33847-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6bc33848-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6bc33849-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Water Resources Planning Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/80"},"text":"Pub. L. 89–80","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-22"},"text":"July 22, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/244"},"text":"79 Stat. 244","children":[],"tail":", which is classified generally to chapter 19B (§ 1962 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1962"},"text":"section 1962 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
