{"tag":"section","attrib":{"id":"id6be47baf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1321c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1321c"},"text":"§ 1321c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International efforts on enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the department in which the Coast Guard is operating, in consultation with the heads of other appropriate Federal agencies, shall ensure that the Coast Guard pursues stronger enforcement in the International Maritime Organization of agreements related to oil discharges, including joint enforcement operations, training, and stronger compliance mechanisms.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6be47bb0-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/tVII/s709"},"text":"Pub. L. 111–281, title VII, § 709","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2986"},"text":"124 Stat. 2986","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6be47bb1-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6be47bb2-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6be47bb3-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Coast Guard Authorization Act of 2010, and not as part of the Federal Water Pollution Control Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
