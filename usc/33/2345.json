{"tag":"section","attrib":{"id":"id6c5e1970-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2345"},"text":null,"children":[{"tag":"num","attrib":{"value":"2345"},"text":"§ 2345.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electronic submission and tracking of permit applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c5e1971-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2345/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of electronic system","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c5e1972-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2345/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall research, develop, and implement an electronic system to allow the electronic preparation and submission of applications for permits and requests for jurisdictional determinations under the jurisdiction of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5e1973-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2345/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The electronic system required under paragraph (1) shall address—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c5e1974-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2345/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applications for standard individual permits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c5e1975-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2345/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applications for letters of permission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c5e1976-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2345/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" joint applications with States for State and Federal permits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c5e1977-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2345/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applications for emergency permits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c5e1978-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2345/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applications or requests for jurisdictional determinations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c5e1979-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2345/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preconstruction notification submissions, when required for a nationwide or other general permit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5e197a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2345/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improving existing data systems","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall seek to incorporate the electronic system required under paragraph (1) into existing systems and databases of the Corps of Engineers to the maximum extent practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5e197b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2345/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The electronic system required under paragraph (1) shall provide for the protection of personal, private, privileged, confidential, and proprietary information, and information the disclosure of which is otherwise prohibited by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5e197c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2345/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" System requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The electronic system required under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c5e197d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2345/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enable an applicant or requester to prepare electronically an application for a permit or request;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5e197e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2345/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enable an applicant or requester to submit to the Secretary, by email or other means through the Internet, the completed application form or request;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5e197f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2345/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enable an applicant or requester to submit to the Secretary, by email or other means through the Internet, data and other information in support of the permit application or request;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5e1980-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2345/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an online interactive guide to provide assistance to an applicant or requester at any time while filling out the permit application or request; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5e1981-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2345/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" enable an applicant or requester (or a designated agent) to track the status of a permit application or request in a manner that will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c5e1982-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2345/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow the applicant or requester to determine whether the application is pending or final and the disposition of the request;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c5e1983-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2345/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow the applicant or requester to research previously submitted permit applications and requests within a given geographic area and the results of such applications or requests; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c5e1984-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2345/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow identification and display of the location of the activities subject to a permit or request through a map-based interface.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5e1985-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2345/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Documentation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All permit decisions and jurisdictional determinations made by the Secretary shall be in writing and include documentation supporting the basis for the decision or determination. The Secretary shall prescribe means for documenting all decisions or determinations to be made by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5e1986-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2345/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Record of determinations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c5e1987-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2345/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall maintain, for a minimum of 5 years, a record of each permit decision and jurisdictional determination made by the Secretary, including documentation supporting the basis of the decision or determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5e1988-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2345/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Archiving of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall explore and implement an appropriate mechanism for archiving records of permit decisions and jurisdictional determinations, including documentation supporting the basis of the decisions and determinations, after the 5-year maintenance period described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5e1989-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2345/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of determinations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c5e198a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2345/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make the records of all permit decisions and jurisdictional determinations made by the Secretary available to the public for review and reproduction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5e198b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2345/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide for the protection of personal, private, privileged, confidential, and proprietary information, and information the disclosure of which is prohibited by law, which may be excluded from disclosure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5e198c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2345/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline for electronic system implementation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c5e198d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2345/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop and implement, to the maximum extent practicable, the electronic system required under subsection (a) not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5e198e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2345/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Update on electronic system implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall submit to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Environment and Public Works of the Senate a quarterly update describing the status of the implementation of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5e198f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2345/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements described in subsections (c), (d), and (e) shall apply to permit applications and requests for jurisdictional determinations submitted to the Secretary after ","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5e1990-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2345/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not preclude the submission to the Secretary, acting through the Chief of Engineers, of a physical copy of a permit application or a request for a jurisdictional determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c5e1991-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/tII/s2040"},"text":"Pub. L. 110–114, title II, § 2040","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-11-08"},"text":"Nov. 8, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1100"},"text":"121 Stat. 1100","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tI/s1134/a"},"text":"Pub. L. 114–322, title I, § 1134(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1654"},"text":"130 Stat. 1654","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dH/tLXXXI/s8226"},"text":"Pub. L. 117–263, div. H, title LXXXI, § 8226","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3764"},"text":"136 Stat. 3764","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c5e1992-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c5e1993-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c5e1994-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 2007, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c5e1995-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s8226/1"},"text":"Pub. L. 117–263, § 8226(1)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s8226/2"},"text":"Pub. L. 117–263, § 8226(2)","children":[],"tail":", added par. (2) and struck out former par. (2). Prior to amendment, text read as follows: “Not later than 180 days after the expiration of the deadline under paragraph (1), the Secretary shall submit to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Environment and Public Works of the Senate a report describing the measures implemented and barriers faced in carrying out this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322"},"text":"Pub. L. 114–322","children":[],"tail":" amended section generally. Prior to amendment, section related to electronic submission of permit applications."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c5e1996-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c5e1997-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s2"},"text":"section 2 of Pub. L. 110–114","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
