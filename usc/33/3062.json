{"tag":"section","attrib":{"id":"id6c785758-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3062"},"text":null,"children":[{"tag":"num","attrib":{"value":"3062"},"text":"§ 3062.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relative rank of officers when serving with Army, Navy, or Air Force","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When serving with the Army, Navy, or Air Force, an officer of the Administration shall rank with and after officers of corresponding grade in the Army, Navy, or Air Force of the same length of service in grade. Nothing in this subchapter shall be construed to affect or alter an officer’s rates of pay and allowances when not assigned to military duty.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6c785759-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372/tII/s252"},"text":"Pub. L. 107–372, title II, § 252","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3091"},"text":"116 Stat. 3091","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c78575a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c78575b-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6c78575c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref"