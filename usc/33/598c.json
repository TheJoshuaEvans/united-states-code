{"tag":"section","attrib":{"id":"id6b4be566-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s598c"},"text":null,"children":[{"tag":"num","attrib":{"value":"598c"},"text":"§ 598c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Easements for hurricane and storm damage reduction projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b4be567-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s598c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to a project for hurricane and storm damage reduction for which the Secretary is requiring a perpetual easement, the Secretary shall, upon request by the non-Federal interest for the project, certify real estate availability and proceed to construction of such project with a nonperpetual easement if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b4be568-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s598c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such certification and construction are in compliance with the terms of the report of the Chief of Engineers for the project and the applicable project partnership agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b4be569-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s598c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary provides the non-Federal interest with formal notice that, in the event in which the nonperpetual easement expires and is not extended, the Secretary will be unable to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b4be56a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s598c/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fulfill the Federal responsibility with respect to the project or carry out any required nourishment of the project under the existing project authorization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b4be56b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s598c/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out repair and rehabilitation of the project under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s701n"},"text":"section 701n of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b4be56c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s598c/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide any other relevant Federal assistance with respect to the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b4be56d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s598c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For any project for hurricane storm damage risk reduction, or a proposal to modify such a project, that is authorized after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", for which a perpetual easement is required for Federal participation in the project, the Secretary shall include in the report of the Chief of Engineers for the project a disclosure of such requirement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b4be56e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s598c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent practicable, the Secretary shall, at the request of the non-Federal interest for a project for hurricane storm damage risk reduction, identify and accept the minimum real estate interests necessary to carry out the project, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s598b"},"text":"section 598b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b4be56f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s598c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hurricane and storm damage reduction project implementation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b4be570-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s598c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During the 2-year period beginning on ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", notwithstanding any requirement of the Secretary for a covered project to comply with the memorandum of the Corps of Engineers entitled “Standard Estates – Perpetual Beach Nourishment and Perpetual Restrictive Dune Easement” and dated "},{"tag":"date","attrib":{"date":"1995-08-04"},"text":"August 4, 1995","children":[],"tail":", the Secretary shall carry out each covered project in a manner consistent with the previously completed initial construction and periodic nourishments of the project, including repair and restoration work on the project under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s701n/a"},"text":"section 701n(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b4be571-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s598c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered project defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “covered project” means an authorized project for hurricane and storm damage reduction in any one of the following locations:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b4be572-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s598c/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Brevard County, Canaveral Harbor, Florida – Mid Reach.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b4be573-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s598c/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Brevard County, Canaveral Harbor, Florida – North Reach.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b4be574-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s598c/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Brev