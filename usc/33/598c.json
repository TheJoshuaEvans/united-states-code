da – Jupiter/Carlin Segment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b4be581-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s598c/d/2/P"},"text":null,"children":[{"tag":"num","attrib":{"value":"P"},"text":"(P)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Palm Beach County, Florida – Delray Segment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b4be582-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s598c/d/2/Q"},"text":null,"children":[{"tag":"num","attrib":{"value":"Q"},"text":"(Q)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Palm Beach County, Florida – Mid Town.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b4be583-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s598c/d/2/R"},"text":null,"children":[{"tag":"num","attrib":{"value":"R"},"text":"(R)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Palm Beach County, Florida – North Boca.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b4be584-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s598c/d/2/S"},"text":null,"children":[{"tag":"num","attrib":{"value":"S"},"text":"(S)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Palm Beach County, Florida – Ocean Ridge.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b4be585-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s598c/d/2/T"},"text":null,"children":[{"tag":"num","attrib":{"value":"T"},"text":"(T)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Panama City Beaches, Florida.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b4be586-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s598c/d/2/U"},"text":null,"children":[{"tag":"num","attrib":{"value":"U"},"text":"(U)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pinellas County, Florida – Long Key.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b4be587-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s598c/d/2/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pinellas County, Florida – Sand Key Segment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b4be588-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s598c/d/2/W"},"text":null,"children":[{"tag":"num","attrib":{"value":"W"},"text":"(W)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pinellas County, Florida –Treasure Island.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b4be589-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s598c/d/2/X"},"text":null,"children":[{"tag":"num","attrib":{"value":"X"},"text":"(X)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sarasota, Lido Key, Florida.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b4be58a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s598c/d/2/Y"},"text":null,"children":[{"tag":"num","attrib":{"value":"Y"},"text":"(Y)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sarasota County, Florida – Venice Beach.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b4be58b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s598c/d/2/Z"},"text":null,"children":[{"tag":"num","attrib":{"value":"Z"},"text":"(Z)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" St. Johns County, Florida – St. Augustine Beach.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b4be58c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s598c/d/2/AA"},"text":null,"children":[{"tag":"num","attrib":{"value":"AA"},"text":"(AA)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" St. Johns County, Florida – Vilano Segment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b4be58d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s598c/d/2/BB"},"text":null,"children":[{"tag":"num","attrib":{"value":"BB"},"text":"(BB)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" St. Lucie County, Florida – Hutchinson Island.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b4be58e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s598c/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of Congress that, for the purpose of constructing and maintaining a project for hurricane and storm damage risk reduction, the minimum estate necessary for easements may not exceed the life of the project nor be less than 50 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b4be58f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s598c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings clause","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section may be construed to affect the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2213/d"},"text":"section 2213(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b4be590-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/dA/tI/s1145"},"text":"Pub. L. 118–272, div. A, title I, § 1145","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3035"},"text":"138 Stat. 3035","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b4be591-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b4be592-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b4be593-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/dA/s1002"},"text":"section 1002 of div. A of Pub. L. 118–272","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
