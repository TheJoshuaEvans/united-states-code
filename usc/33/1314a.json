{"tag":"section","attrib":{"id":"id6bcf1ecd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1314a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1314a"},"text":"§ 1314a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wastewater technology clearinghouse","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6bcf1ece-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1314a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bcf1ecf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1314a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator of the Environmental Protection Agency shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6bcf1ed0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1314a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each of the programs described in paragraph (2), update the information for those programs to include information on cost-effective and alternative wastewater recycling and treatment technologies, including onsite and decentralized systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bcf1ed1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1314a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminate to units of local government and nonprofit organizations seeking Federal funds for wastewater technology information on the cost effectiveness of alternative wastewater treatment and recycling technologies, including onsite and decentralized systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bcf1ed2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1314a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The programs referred to in paragraph (1)(A) are programs that provide technical assistance for wastewater management, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6bcf1ed3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1314a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs for nonpoint source management under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1329"},"text":"section 1329 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bcf1ed4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1314a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the permit program for the disposal of sewer sludge under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1345"},"text":"section 1345 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bcf1ed5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1314a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2018-10-23"},"text":"October 23, 2018","children":[],"tail":", and not less frequently than every 3 years thereafter, the Administrator of the Environmental Protection Agency shall submit to Congress a report that describes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bcf1ed6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1314a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type and amount of information provided under subsection (a) to units of local government and nonprofit organizations regarding alternative wastewater treatment and recycling technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bcf1ed7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1314a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the States and regions that have made greatest use of alternative wastewater treatment and recycling technologies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bcf1ed8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1314a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actions taken by the Administrator to assist States in the deployment of alternative wastewater treatment and recycling technologies, including onsite and decentralized systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6bcf1ed9-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/tIV/s4102"},"text":"Pub. L. 115–270, title IV, § 4102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3871"},"text":"132 Stat. 3871","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6bcf1eda-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6bcf1edb-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6bcf1edc-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the America’s Water Infrastructure Act of 2018, and not as part of the Federal Water Pollution Control Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
