{"tag":"section","attrib":{"id":"id6c760e79-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3027"},"text":null,"children":[{"tag":"num","attrib":{"value":"3027"},"text":"§ 3027.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General qualification of officers for promotion to higher permanent grade","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No officer may be promoted to a higher permanent grade on the active list until the officer has passed a satisfactory mental and physical examination in accordance with regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6c760e7a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372/tII/s227"},"text":"Pub. L. 107–372, title II, § 227","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3085"},"text":"116 Stat. 3085","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c760e7b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c760e7c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6c760e7d-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s854"},"text":"section 854 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib