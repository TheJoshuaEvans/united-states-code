{"tag":"section","attrib":{"id":"id6ba68877-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1256"},"text":null,"children":[{"tag":"num","attrib":{"value":"1256"},"text":"§ 1256.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for pollution control programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6ba68878-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1256/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations for State and interstate programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are hereby authorized to be appropriated the following sums, to remain available until expended, to carry out the purpose of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6ba68879-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1256/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $60,000,000 for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1973-06-30"},"text":"June 30, 1973","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6ba6887a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1256/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $75,000,000 for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1974-06-30"},"text":"June 30, 1974","children":[],"tail":", and the fiscal year ending "},{"tag":"date","attrib":{"date":"1975-06-30"},"text":"June 30, 1975","children":[],"tail":", $100,000,000 per fiscal year for the fiscal years 1977, 1978, 1979, and 1980, $75,000,000 per fiscal year for the fiscal years 1981 and 1982, such sums as may be necessary for fiscal years 1983 through 1985, and $75,000,000 per fiscal year for each of the fiscal years 1986 through 1990;"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"for grants to States and to interstate agencies to assist them in administering programs for the prevention, reduction, and elimination of pollution, including enforcement directly or through appropriate State law enforcement officers or agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6ba6887b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1256/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the sums appropriated in any fiscal year, the Administrator shall make allotments to the several States and interstate agencies in accordance with regulations promulgated by him on the basis of the extent of the pollution problem in the respective States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6ba6887c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1256/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum annual payments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator is authorized to pay to each State and interstate agency each fiscal year either—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6ba6887d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1256/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the allotment of such State or agency for such fiscal year under subsection (b), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6ba6887e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1256/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasonable costs as determined by the Administrator of developing and carrying out a pollution program by such State or agency during such fiscal year,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"which ever amount is the lesser.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6ba6887f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1256/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No grant shall be made under this section to any State or interstate agency for any fiscal year when the expenditure of non-Federal funds by such State or interstate agency during such fiscal year for the recurrent expenses of carrying out its pollution control program are less than the expenditure by such State or interstate agency of non-Federal funds for such recurrent program expenses during the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1971-06-30"},"text":"June 30, 1971","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6ba68880-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1256/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants prohibited to States not establishing water quality monitoring procedures or adequate emergency and contingency plans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning in fiscal year 1974 the Administrator shall not make any grant under this section to any State which has not provided or is not carrying out as a part of its program—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6ba68881-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1256/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment and operation of appropriate devices, methods, systems, and procedures necessary to monitor, and to compile and analyze data on (including classification according to eutrophic condition), the quality of navigable waters and to the extent practicable, ground waters including biological monitoring; and provision for annually updating such data and including it in the report required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1315"},"text":"section 1315 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6ba68882-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1256/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authority comparable to that in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1364"},"text":"section 1364 of this title","children":[],"tail":" and adequate contingency plans to implement such authority."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6ba68883-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1256/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants shall be made under this section on condition that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6ba68884-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1256/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such State (or interstate agency) files with the Administrator within one hundred and twenty days after ","children":[{"tag":"date","attrib":{"date":"1972-10-18"},"text":"October 18, 1972","children":[],"tail":":"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6ba68885-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1256/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary report of the current status of the State pollution control program, including the criteria used by the State in determining priority of treatment works; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6ba68886-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1256/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such additional information, data, and reports as the Administrator may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6ba68887-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1256/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No federally assumed enforcement as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1319/a/2"},"text":"section 1319(a)(2) of this title","children":[],"tail":" is in effect with respect to such State or interstate agency."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6ba68888-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1256/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such State (or interstate agency) submits within one hundred and twenty days after ","children":[{"tag":"date","attrib":{"date":"1972-10-18"},"text":"October 18, 1972","children":[],"tail":", and before October 1 of each year thereafter for the Administrator’s approval of its program for the prevention, reduction, and elimination of pollution in accordance with purposes and provisions of this chapter in such form and content as the Administrator may prescribe."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6ba68889-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1256/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallotment of unpaid allotments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any sums allotted under subsection (b) in any fiscal year which are not paid shall be reallotted by the Administrator in accordance with regulations promulgated by him.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6ba6888a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"June 30, 1948, ch. 758","children":[],"tail":", title I, § 106, as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/500/s2"},"text":"Pub. L. 92–500, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-18"},"text":"Oct. 18, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/827"},"text":"86 Stat. 827","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/592/s3"},"text":"Pub. L. 93–592, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-02"},"text":"Jan. 2, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1925"},"text":"88 Stat. 1925","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/273/s3/20"},"text":"Pub. L. 94–273, § 3(20)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-21"},"text":"Apr. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/377"},"text":"90 Stat. 377","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/217/s4/c"},"text":"Pub. L. 95–217, § 4(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-12-27"},"text":"Dec. 27, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1566"},"text":"91 Stat. 1566","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/483/s1/b"},"text":"Pub. L. 96–483, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-21"},"text":"Oct. 21, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2360"},"text":"94 Stat. 2360","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/4/tI/s101/b"},"text":"Pub. L. 100–4, title I, § 101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-02-04"},"text":"Feb. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/9"},"text":"101 Stat. 9","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6ba6888b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6ba6888c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6ba6888d-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1987—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/4"},"text":"Pub. L. 100–4","children":[],"tail":" inserted “, such sums as may be necessary for fiscal years 1983 through 1985, and $75,000,000 per fiscal year for each of the fiscal years 1986 through 1990” after “1982”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/483"},"text":"Pub. L. 96–483","children":[],"tail":" inserted authorization of the sum of $75,000,000 per fiscal year for fiscal years 1981 and 1982."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/217"},"text":"Pub. L. 95–217","children":[],"tail":" substituted “and the fiscal year ending "},{"tag":"date","attrib":{"date":"1975-06-30"},"text":"June 30, 1975","children":[],"tail":", $100,000,000 per fiscal year for the fiscal years 1977, 1978, 1979, and 1980” for “and the fiscal year ending "},{"tag":"date","attrib":{"date":"1975-06-30"},"text":"June 30, 1975","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (f)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/273"},"text":"Pub. L. 94–273","children":[],"tail":" substituted “October” for “July”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/592"},"text":"Pub. L. 93–592","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1974-06-30"},"text":"June 30, 1974","children":[],"tail":", and the fiscal year ending "},{"tag":"date","attrib":{"date":"1975-06-30"},"text":"June 30, 1975","children":[],"tail":";” for “"},{"tag":"date","attrib":{"date":"1974-06-30"},"text":"June 30, 1974","children":[],"tail":";”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
