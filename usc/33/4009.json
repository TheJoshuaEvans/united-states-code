{"tag":"section","attrib":{"id":"id6c950771-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4009"},"text":null,"children":[{"tag":"num","attrib":{"value":"4009"},"text":"§ 4009.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c950772-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4009/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Under Secretary to carry out sections 4002 and 4003 of this title $20,500,000 for each of fiscal years 2014 through 2018, and $20,500,000 for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c950773-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4009/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extramural research activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary shall ensure that a substantial portion of funds appropriated pursuant to subsection (a) that are used for research purposes are allocated to extramural research activities. For each fiscal year, the Under Secretary shall publish a list of all grant recipients and the amounts for all of the funds allocated for research purposes, specifying those allocated for extramural research activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c950774-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/383/tVI/s610"},"text":"Pub. L. 105–383, title VI, § 610","children":[],"tail":", formerly § 609, as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/124/s11"},"text":"Pub. L. 113–124, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-30"},"text":"June 30, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1386"},"text":"128 Stat. 1386","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/423/s9/h"},"text":"Pub. L. 115–423, § 9(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-07"},"text":"Jan. 7, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5464"},"text":"132 Stat. 5464","children":[],"tail":"; renumbered § 610, "},{"tag":"ref","attrib":{"href":"/us/pl/117/144/s2/a/1"},"text":"Pub. L. 117–144, § 2(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-06-16"},"text":"June 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1266"},"text":"136 Stat. 1266","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c950775-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c950776-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c950777-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/423"},"text":"Pub. L. 115–423","children":[],"tail":" inserted “, and $20,500,000 for each of fiscal years 2019 through 2023” before period at end."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
