5/s6/a"},"text":"Pub. L. 119–65, § 6(a)","children":[],"tail":", substituted “Under Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/65/s3/i"},"text":"Pub. L. 119–65, § 3(i)","children":[],"tail":", substituted “for each of fiscal years 2018 through 2029 for carrying out” for “for fiscal year 2023 for carrying out”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2023—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s3514/i"},"text":"Pub. L. 118–31, § 3514(i)","children":[],"tail":", amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/s11328/b"},"text":"Pub. L. 117–263, § 11328(b)","children":[],"tail":". See 2022 Amendment notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s11328/b/1"},"text":"Pub. L. 117–263, § 11328(b)(1)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/s3514/i"},"text":"Pub. L. 118–31, § 3514(i)","children":[],"tail":", substituted “fiscal year 2023” for “each of fiscal years 2018 through 2022”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s11328/b/2"},"text":"Pub. L. 117–263, § 11328(b)(2)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/s3514/i"},"text":"Pub. L. 118–31, § 3514(i)","children":[],"tail":", substituted “4902(1)” for “2702(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/224"},"text":"Pub. L. 116–224","children":[],"tail":" substituted “$15,000,000” for “$10,000,000” and “7 percent” for “5 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/265"},"text":"Pub. L. 115–265","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “There are authorized to be appropriated for each fiscal year 2006 through 2010—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) to the Administrator for carrying out sections 1952 and 1955 of this title, $10,000,000, of which no more than 10 percent may be for administrative costs; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) to the Secretary of the Department in which the Coast Guard is operating, for the use of the Commandant of the Coast Guard in carrying out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1953"},"text":"section 1953 of this title","children":[],"tail":", $2,000,000, of which no more than 10 percent may be used for administrative costs.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
