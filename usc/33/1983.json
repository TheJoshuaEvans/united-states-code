{"tag":"section","attrib":{"id":"id6c2751ca-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1983"},"text":null,"children":[{"tag":"num","attrib":{"value":"1983"},"text":"§ 1983.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c2751cb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1983/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Under Secretary $15,000,000 for each of fiscal years 2018 through 2029 for carrying out sections 1952, 1954, and 1955 of this title, of which not more than 7 percent is authorized for each fiscal year for administrative costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c2751cc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1983/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts authorized for Coast Guard","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts authorized for each fiscal year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s4902/1"},"text":"section 4902(1) of title 14","children":[],"tail":", up to $2,000,000 is authorized for the Secretary of the department in which the Coast Guard is operating for use by the Commandant of the Coast Guard to carry out "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1953"},"text":"section 1953 of this title","children":[],"tail":", of which not more than 5 percent is authorized for each fiscal year for administrative costs."}],"tail":"\n"}],"tail":"\n"}],"tail"