{"tag":"section","attrib":{"id":"id6c419056-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2267b"},"text":"§ 2267b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Post-disaster watershed assessments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c419057-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Watershed assessments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c419058-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In an area that the President has declared a major disaster in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5170"},"text":"section 5170 of title 42","children":[],"tail":", the Secretary may carry out a watershed assessment to identify, to the maximum extent practicable, specific flood risk reduction, hurricane and storm damage reduction, ecosystem restoration, or navigation project recommendations that will help to rehabilitate and improve the resiliency of damaged infrastructure and natural resources to reduce risks to human life and property from future natural disasters."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c419059-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A watershed assessment carried out paragraph ","children":[{"tag":"ref","attrib":{"idref":"fn002107"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002107"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by “under”."}],"tail":" (1) may identify existing projects being carried out under 1 or more of the authorities referred to in subsection (b)(1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c41905a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duplicate watershed assessments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out a watershed assessment under paragraph (1), the Secretary shall use all existing watershed assessments and related information developed by the Secretary or other Federal, State, or local entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c41905b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c41905c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may carry out projects identified under a watershed assessment under subsection (a) in accordance with the criteria for projects carried out under one of the following authorities:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c41905d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 205 of the Flood Control Act of 1948 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s701s"},"text":"33 U.S.C. 701s","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c41905e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 111 of the River and Harbor Act of 1968 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s426i"},"text":"33 U.S.C. 426i","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c41905f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267b/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 206 of the Water Resources Development Act of 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2330"},"text":"33 U.S.C. 2330","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c419060-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267b/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 1135 of the Water Resources Development Act of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2309a"},"text":"33 U.S.C. 2309a","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c419061-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267b/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 107 of the River and Harbor Act of 1960 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s577"},"text":"33 U.S.C. 577","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c419062-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267b/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-13/s3"},"text":"Section 3 of the Act of August 13, 1946","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s426g"},"text":"33 U.S.C. 426g","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c419063-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each project that does not meet the criteria under paragraph (1), the Secretary shall include a recommendation relating to the project in the annual report submitted to Congress by the Secretary in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2282d"},"text":"section 2282d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c419064-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out a project under paragraph (1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c419065-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267b/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, use all existing information and studies available for the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c419066-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267b/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not require any element of a study completed for the project prior to the disaster to be repeated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c419067-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All requirements applicable to a project under the Acts described in subsection (b) shall apply to the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c419068-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on assessments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A watershed assessment under subsection (a) shall be initiated not later than 2 years after the date on which the major disaster declaration is issued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c419069-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessments in territories of the United States","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c41906a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For any major disaster declared in a territory of the United States before ","children":[{"tag":"date","attrib":{"date":"2018-10-23"},"text":"October 23, 2018","children":[],"tail":", all activities in the territory carried out or undertaken pursuant to the authorities described in this section shall be conducted at full Federal expense unless the President determines that the territory has the ability to pay the cost share for an assessment under this section without the use of loans."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c41906b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Territory defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “territory of the United States” means an insular area specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2310/a/1"},"text":"section 2310(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c41906c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/tIII/s3025"},"text":"Pub. L. 113–121, title III, § 3025","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1303"},"text":"128 Stat. 1303","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/270/tI/s1139"},"text":"Pub. L. 115–270, title I, § 1139","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3784"},"text":"132 Stat. 3784","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c41906d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c41906e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c41906f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Flood Control Act of 1948, referred to in subsecs. (b)(1)(A) and (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch771/tII"},"text":"act June 30, 1948, ch. 771, title II","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/1175"},"text":"62 Stat. 1175","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The River and Harbor Act of 1968, referred to in subsecs. (b)(1)(B) and (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/483/tI"},"text":"Pub. L. 90–483, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-13"},"text":"Aug. 13, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/731"},"text":"82 Stat. 731","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Water Resources Development Act of 1996, referred to in subsecs. (b)(1)(C) and (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/303"},"text":"Pub. L. 104–303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3658"},"text":"110 Stat. 3658","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1996 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Water Resources Development Act of 1986, referred to in subsecs. (b)(1)(D) and (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662"},"text":"Pub. L. 99–662","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4082"},"text":"100 Stat. 4082","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The River and Harbor Act of 1960, referred to in subsecs. (b)(1)(E) and (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/645/tI"},"text":"Pub. L. 86–645, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-14"},"text":"July 14, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/480"},"text":"74 Stat. 480","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Act of ","children":[{"tag":"date","attrib":{"date":"1946-08-13"},"text":"August 13, 1946","children":[],"tail":", referred to in subsecs. (b)(1)(F) and (c), is "},{"tag":"ref","attrib":{"href":"/us/act/1946-08-13/ch960"},"text":"act Aug. 13, 1946, ch. 960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/1056"},"text":"60 Stat. 1056","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c419070-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Reform and Development Act of 2014, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c419071-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270"},"text":"Pub. L. 115–270","children":[],"tail":" added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c419072-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c419073-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s2"},"text":"section 2 of Pub. L. 113–121","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
