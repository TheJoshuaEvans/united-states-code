{"tag":"section","attrib":{"id":"id6b2ceb39-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s447"},"text":null,"children":[{"tag":"num","attrib":{"value":"447"},"text":"§ 447.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bribery of inspector; penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Every person who, directly or indirectly, gives any sum of money or other bribe, present, or reward, or makes any offer of the same to any inspector, deputy inspector, or other employee of the office of any supervisor of a harbor with intent to influence such inspector, deputy inspector, or other employee to permit or overlook any violation of the provisions of this subchapter, shall, on conviction thereof, be fined not less than $500 nor more than $1,000, and be imprisoned not less than six months nor more than one year.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b2ceb3a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1888-06-29/ch496/s3"},"text":"June 29, 1888, ch. 496, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/25/209"},"text":"25 Stat. 209","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1894-08-18/ch299/s3"},"text":"Aug. 18, 1894, ch. 299, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/360"},"text":"28 Stat. 360","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1908-05-28/ch212/s8"},"text":"May 28, 1908, ch. 212, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/428"},"text":"35 Stat. 428","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/802/s1/4"},"text":"Pub. L. 85–802, § 1(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-28"},"text":"Aug. 28, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/970"},"text":"72 Stat. 970","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b2ceb3b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b2ceb3c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b2ceb3d-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of section 3 of act ","children":[{"tag":"date","attrib":{"date":"1888-06-29"},"text":"June 29, 1888","children":[],"tail":". Said section 3 of act "},{"tag":"date","attrib":{"date":"1888-06-29"},"text":"June 29, 1888","children":[],"tail":", enacted sections 443 to 448 of this title. See Codification note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s443"},"text":"section 443 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b2ceb3e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1958—","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/802"},"text":"Pub. L. 85–802","children":[],"tail":" substituted “any supervisor of a harbor” for “the supervisor of the harbor”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b2ceb3f-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendme