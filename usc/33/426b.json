{"tag":"section","attrib":{"id":"id6b25bfe5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426b"},"text":null,"children":[{"tag":"num","attrib":{"value":"426b"},"text":"§ 426b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of existing laws; projects referred to Board of Engineers for Rivers and Harbors","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All provisions of existing law relating to examinations and surveys and to works of improvement of rivers and harbors shall apply, insofar as practicable, to examinations and surveys and to works of improvement relating to shore protection; except that all projects having to do with shore protection shall be referred for consideration and recommendation to the Board of Engineers for Rivers and Harbors.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b25bfe6-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch334/s2"},"text":"July 31, 1945, ch. 334, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/59/508"},"text":"59 Stat. 508","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/172/s1"},"text":"Pub. L. 88–172, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-11-07"},"text":"Nov. 7, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/304"},"text":"77 Stat. 304","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b25bfe7-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b25bfe8-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b25bfe9-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provision for the referral of projects having to do with shore protection for consideration and recommendation to the Beach Erosion Board have been omitted as obsolete in view of the abolition of the Beach Erosion Board and the transfer of its review function to the Board of Engineers for Rivers and Harbors by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/172/s1"},"text":"Pub. L. 88–172, § 1","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s426–3"},"text":"section 426–3 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b25bfea-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b25bfeb-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Termination of Board of Engineers for Rivers and Harbors and Reassignment of Duties and Responsibilities","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For termination of Board of Engineers for Rivers and Harbors 180 days after ","children":[{"tag":"date","attrib":{"date":"1992-10-31"},"text":"Oct. 31, 1992","children":[],"tail":", and reassignment of duties and responsibilities by Secretary of Army, see "},{"tag":"ref","attrib":{"href":"/us/pl/102/580/s223"},"text":"section 223 of Pub. L. 102–580","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s541"},"text":"section 541 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
