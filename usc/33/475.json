{"tag":"section","attrib":{"id":"id6b368828-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s475"},"text":null,"children":[{"tag":"num","attrib":{"value":"475"},"text":"§ 475.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations for Pearl Harbor, Hawaii","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the proper control, protection, and defense of the naval station, harbor, and entrance channel at Pearl Harbor, Territory of Hawaii, the Secretary of the Navy is authorized, empowered, and directed to adopt and prescribe suitable rules and regulations governing the navigation, movement, and anchorage of vessels of whatsoever character in the waters of Pearl Harbor, island of Oahu, Hawaiian Islands, and in the entrance channel to said harbor, and to take all necessary measures for the proper enforcement of such rules and regulations.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b368829-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1912-08-22/ch335"},"text":"Aug. 22, 1912, ch. 335","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/341"},"text":"37 Stat. 341","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b36882a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b36882b-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b36882c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Naval Appropriation Act for 1913.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id6b36882d-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b36882e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Admission of Hawaii as State","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Admission of Hawaii into the Union was accomplished ","children":[{"tag":"date","attrib":{"date":"1959-08-21"},"text":"Aug. 21, 1959","children":[],"tail":", on issuance of Proc. No. 3309, "},{"tag":"date","attrib":{"date":"1959-08-21"},"text":"Aug. 21, 1959","children":[],"tail":", 24 F.R. 6868, 73 Stat. c74, as required by sections 1 and 7(c) of "},{"tag":"ref","attrib":{"href":"/us/pl/86/3"},"text":"Pub. L. 86–3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-03-18"},"text":"Mar. 18, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/4"},"text":"73 Stat. 4","children":[],"tail":", set out as notes preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s491"},"text":"section 491 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
