{"tag":"section","attrib":{"id":"id6c7ac895-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203"},"text":null,"children":[{"tag":"num","attrib":{"value":"3203"},"text":"§ 3203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tsunami forecasting and warning program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c7ac896-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator, through the National Weather Service and in consultation with other relevant Administration offices, shall operate a program to provide tsunami detection, forecasting, and warnings for the Pacific and Arctic Ocean regions and for the Atlantic Ocean region, including the Caribbean Sea and the Gulf of Mexico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7ac897-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Components","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7ac898-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include the tsunami warning centers supported or maintained under subsection (d);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac899-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the degree practicable, maintain not less than 80 percent of the Deep-ocean Assessment and Reporting of Tsunamis buoy array at operational capacity to optimize data reliability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac89a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilize and maintain an array of robust tsunami detection technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac89b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain detection equipment in operational condition to fulfill the detection, forecasting, and warning requirements of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac89c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide tsunami forecasting capability based on models and measurements, including tsunami inundation models and maps for use in increasing the preparedness of communities and safeguarding port and harbor operations, that incorporate inputs, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c7ac89d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States and global ocean and coastal observing system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac89e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the global Earth observing system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac89f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the global seismic network;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac8a0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/b/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Advanced National Seismic system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac8a1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/b/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tsunami model validation using historical and paleotsunami data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac8a2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/b/5/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" digital elevation models and bathymetry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac8a3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/b/5/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" newly developing tsunami detection methodologies using satellites and airborne remote sensing;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac8a4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain data quality and management systems to support the requirements of the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac8a5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include a cooperative effort among the Administration, the United States Geological Survey, and the National Science Foundation under which the Director of the United States Geological Survey and the Director of the National Science Foundation shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c7ac8a6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide rapid and reliable seismic information to the Administrator from international and domestic seismic networks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac8a7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support seismic stations installed before ","children":[{"tag":"date","attrib":{"date":"2017-04-18"},"text":"April 18, 2017","children":[],"tail":", to supplement coverage in areas of sparse instrumentation;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac8a8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a capability for the dissemination of warnings, including graphical warning products, to at-risk States, territories, and tsunami communities through rapid and reliable notification to government officials and the public, including utilization of and coordination with existing Federal warning systems, including the National Oceanic and Atmospheric Administration Weather Radio All Hazards Program and Wireless Emergency Alerts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac8a9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide and allow, as practicable, for integration of tsunami detection technologies with other environmental observing technologies and commercial and Federal undersea communications cables; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac8aa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include any technology the Administrator considers appropriate to fulfill the objectives of the program under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7ac8ab-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tsunami warning system","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program under this section shall operate a tsunami warning system that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7ac8ac-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is capable of forecasting tsunami, including forecasting tsunami arrival time and inundation estimates, anywhere in the Pacific and Arctic Ocean regions and providing adequate warnings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac8ad-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is capable of forecasting and providing adequate warnings, including tsunami arrival time and inundation models where applicable, in areas of the Atlantic Ocean, including the Caribbean Sea and Gulf of Mexico, that are determined—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c7ac8ae-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be geologically active, or to have significant potential for geological activity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac8af-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pose significant risks of tsunami for States along the coastal areas of the Atlantic Ocean, Caribbean Sea, or Gulf of Mexico; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac8b0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supports other international tsunami forecasting and warning efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7ac8b1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tsunami warning centers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7ac8b2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall support or maintain centers to support the tsunami warning system required by subsection (c). The Centers ","children":[{"tag":"ref","attrib":{"idref":"fn002136"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002136"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" shall include—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c7ac8b3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Tsunami Warning Center, located in Alaska, which is primarily responsible for Alaska and the continental United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac8b4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Pacific Tsunami Warning Center, located in Hawaii, which is primarily responsible for Hawaii, the Caribbean, and other areas of the Pacific not covered by the National Center; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac8b5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any additional forecast and warning centers determined by the National Weather Service to be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac8b6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The responsibilities of the centers supported or maintained under paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c7ac8b7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Continuously monitoring data from seismological, deep ocean, coastal sea level, and tidal monitoring stations and other data sources as may be developed and deployed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac8b8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Evaluating earthquakes, landslides, and volcanic eruptions that have the potential to generate tsunami.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac8b9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Evaluating deep ocean buoy data and tidal monitoring stations for indications of tsunami resulting from earthquakes and other sources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac8ba-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the extent practicable, utilizing a range of models, including ensemble models, to predict tsunami, including arrival times, flooding estimates, coastal and harbor currents, and duration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac8bb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Using data from the Integrated Ocean Observing System of the Administration in coordination with regional associations to calculate new inundation estimates and periodically update existing inundation estimates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac8bc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Disseminating forecasts and tsunami warning bulletins to Federal, State, tribal, and local government officials and the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac8bd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/d/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coordinating with the tsunami hazard mitigation program conducted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3204"},"text":"section 3204 of this title","children":[],"tail":" to ensure ongoing sharing of information between forecasters and emergency management officials."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac8be-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/d/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In coordination with the Commandant of the Coast Guard and the Administrator of the Federal Emergency Management Agency, evaluating and recommending procedures for ports and harbors at risk of tsunami inundation, including review of readiness, response, and communication strategies, and data sharing policies, to the maximum extent practicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac8bf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/d/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Making data gathered under this chapter and post-warning analyses conducted by the National Weather Service or other relevant Administration offices available to the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac8c0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/d/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Integrating and modernizing the program operated under this section with advances in tsunami science to improve performance without compromising service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac8c1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fail-safe warning capability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tsunami warning centers supported or maintained under paragraph (1) shall maintain a fail-safe warning capability and perform back-up duties for each other.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac8c2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with National Weather Service","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall coordinate with the forecast offices of the National Weather Service, the centers supported or maintained under paragraph (1), and such program offices of the Administration as the Administrator or the coordinating committee, as established in section 3204(d) ","children":[{"tag":"ref","attrib":{"idref":"fn002137"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002137"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “section 3204(b)”."}],"tail":" of this title, consider appropriate to ensure that regional and local forecast offices—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c7ac8c3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the technical knowledge and capability to disseminate tsunami warnings for the communities they serve;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac8c4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leverage connections with local emergency management officials for optimally disseminating tsunami warnings and forecasts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac8c5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement mass communication tools in effect on the day before ","children":[{"tag":"date","attrib":{"date":"2017-04-18"},"text":"April 18, 2017","children":[],"tail":", used by the National Weather Service on such date and newer mass communication technologies as they are developed as a part of the Weather-Ready Nation program of the Administration, or otherwise, for the purpose of timely and effective delivery of tsunami warnings."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac8c6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uniform operating procedures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c7ac8c7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop uniform operational procedures for the centers supported or maintained under paragraph (1), including the use of software applications, checklists, decision support tools, and tsunami warning products that have been standardized across the program supported under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac8c8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure that processes and products of the warning system operated under subsection (c)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c7ac8c9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/d/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reflect industry best practices when practicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c7ac8ca-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/d/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conform to the maximum extent practicable with internationally recognized standards for information technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c7ac8cb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/d/5/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conform to the maximum extent practicable with other warning products and practices of the National Weather Service;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac8cc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/d/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure that future adjustments to operational protocols, processes, and warning products—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c7ac8cd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/d/5/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are made consistently across the warning system operated under subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c7ac8ce-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/d/5/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are applied in a uniform manner across such warning system;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac8cf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/d/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a systematic method for information technology product development to improve long-term technology planning efforts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac8d0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/d/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminate guidelines and metrics for evaluating and improving tsunami forecast models.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac8d1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Available resources","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator, through the National Weather Service, shall ensure that resources are available to fulfill the obligations of this chapter. This includes ensuring supercomputing resources are available to run, as rapidly as possible, such computer models as are needed for purposes of the tsunami warning system operated under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7ac8d2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of technology; maintenance and upgrades","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Administrator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7ac8d3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop requirements for the equipment used to forecast tsunami, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c7ac8d4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provisions for multipurpose detection platforms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac8d5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reliability and performance metrics; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac8d6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, requirements for the integration of equipment with other United States and global ocean and coastal observation systems, the global Earth observing system of systems, the global seismic networks, and the Advanced National Seismic System;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac8d7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and execute a plan for the transfer of technology from ongoing research conducted as part of the program supported or maintained under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3205"},"text":"section 3205 of this title","children":[],"tail":" into the program under this section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac8d8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the Administration’s operational tsunami detection equipment is properly maintained.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7ac8d9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal cooperation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"When deploying and maintaining tsunami detection technologies under the program under this section, the Administrator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7ac8da-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify which assets of other Federal agencies are necessary to support such program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac8db-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" work with each agency identified under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c7ac8dc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to acquire the agency’s assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac8dd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prioritize the necessary assets in support of the tsunami forecast and warning program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7ac8de-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional notifications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7ac8df-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall notify the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Science of the House of Representatives within 30 days of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c7ac8e0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impaired regional forecasting capabilities due to equipment or system failures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac8e1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significant contractor failures or delays in completing work associated with the tsunami forecasting and warning system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac8e2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the occurrence of a significant tsunami warning.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac8e3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In a case in which notice is submitted under paragraph (1) within 30 days of a significant tsunami warning described in subparagraph (C) of such paragraph, such notice shall include, as appropriate, brief information and analysis of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c7ac8e4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the accuracy of the tsunami model used;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac8e5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the specific deep ocean or other monitoring equipment that detected the incident, as well as the deep ocean or other monitoring equipment that did not detect the incident due to malfunction or other reasons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac8e6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of the warning communication, including the dissemination of warnings with State, territory, local, and tribal partners in the affected area under the jurisdiction of the National Weather Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac8e7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3203/g/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other findings as the Administrator considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c7ac8e8-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/424/s4"},"text":"Pub. L. 109–424, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2903"},"text":"120 Stat. 2903","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/479/tVIII/s804"},"text":"Pub. L. 109–479, title VIII, § 804","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-12"},"text":"Jan. 12, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3654"},"text":"120 Stat. 3654","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/25/tV"},"text":"Pub. L. 115–25, title V","children":[],"tail":", §§ 504, 512(a), "},{"tag":"date","attrib":{"date":"2017-04-18"},"text":"Apr. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/116"},"text":"131 Stat. 116","children":[],"tail":", 128.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c7ac8e9-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c7ac8ea-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c7ac8eb-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3205"},"text":"Section 3205 of this title","children":[],"tail":", referred to in subsec. (e)(2), was in the original “section 6”, meaning "},{"tag":"ref","attrib":{"href":"/us/pl/109/424/s6"},"text":"section 6 of Pub. L. 109–424","children":[],"tail":", and was translated as if it referred to "},{"tag":"ref","attrib":{"href":"/us/pl/109/479/s806"},"text":"section 806 of Pub. L. 109–479","children":[],"tail":", which enacted a substantially identical "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s3205"},"text":"section 3205 of this title","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/pl/109/424/s6"},"text":"Section 6 of Pub. L. 109–424","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/115/25/s512/a"},"text":"section 512(a) of Pub. L. 115–25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c7ac8ec-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/424"},"text":"Pub. L. 109–424","children":[],"tail":" and title VIII of "},{"tag":"ref","attrib":{"href":"/us/pl/109/479"},"text":"Pub. L. 109–479","children":[],"tail":" enacted substantially identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/109/424"},"text":"Pub. L. 109–424","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/115/25/s512/a"},"text":"section 512(a) of Pub. L. 115–25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c7ac8ed-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s504/a"},"text":"Pub. L. 115–25, § 504(a)","children":[],"tail":", substituted “Atlantic Ocean region, including the Caribbean Sea and the Gulf of Mexico” for “Atlantic Ocean, Caribbean Sea, and Gulf of Mexico region”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s504/b/1"},"text":"Pub. L. 115–25, § 504(b)(1)","children":[],"tail":", substituted “supported or maintained” for “established”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s504/b/4"},"text":"Pub. L. 115–25, § 504(b)(4)","children":[],"tail":", added par. (2). Former par. (2) redesignated (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s504/b/3"},"text":"Pub. L. 115–25, § 504(b)(3)","children":[],"tail":", redesignated pars. (2) and (3) as (3) and (4), respectively. Former par. (4) redesignated (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s504/b/5"},"text":"Pub. L. 115–25, § 504(b)(5)","children":[],"tail":", amended par. (5) generally. Prior to amendment, par. (5) read as follows: “provide tsunami forecasting capability based on models and measurements, including tsunami inundation models and maps for use in increasing the preparedness of communities, including through the TsunamiReady program;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s504/b/3"},"text":"Pub. L. 115–25, § 504(b)(3)","children":[],"tail":", redesignated par. (4) as (5). Former par. (5) redesignated (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s504/b/3"},"text":"Pub. L. 115–25, § 504(b)(3)","children":[],"tail":", redesignated par. (5) as (6). Former par. (6) redesignated (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s504/b/6"},"text":"Pub. L. 115–25, § 504(b)(6)","children":[],"tail":", amended par. (7) generally. Prior to amendment, par. (7) read as follows: “include a cooperative effort among the Administration, the United States Geological Survey, and the National Science Foundation under which the Geological Survey and the National Science Foundation shall provide rapid and reliable seismic information to the Administration from international and domestic seismic networks;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s504/b/3"},"text":"Pub. L. 115–25, § 504(b)(3)","children":[],"tail":", redesignated par. (6) as (7). Former par. (7) redesignated (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s504/b/2"},"text":"Pub. L. 115–25, § 504(b)(2)","children":[],"tail":", (7), redesignated par. (7) as (8) and inserted “, including graphical warning products,” after “warnings”, “, territories,” after “States” and “and Wireless Emergency Alerts” after “Hazards Program”. Former par. (8) redesignated (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s504/b/2"},"text":"Pub. L. 115–25, § 504(b)(2)","children":[],"tail":", (8), redesignated par. (8) as (9) and inserted “provide and” before “allow” and “and commercial and Federal undersea communications cables” after “observing technologies”. Former par. (9) redesignated (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s504/b/2"},"text":"Pub. L. 115–25, § 504(b)(2)","children":[],"tail":", redesignated par. (9) as (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s504/c"},"text":"Pub. L. 115–25, § 504(c)","children":[],"tail":", amended subsec. (c) generally. Prior to amendment, subsec. (c) related to tsunami warning system areas."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s504/d"},"text":"Pub. L. 115–25, § 504(d)","children":[],"tail":", amended subsec. (d) generally. Prior to amendment, subsec. (d) related to the location of tsunami warning centers and the responsibilities of the centers."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s504/e"},"text":"Pub. L. 115–25, § 504(e)","children":[],"tail":", amended subsec. (e) generally. Prior to amendment, subsec. (e) related to the National Weather Service’s responsibilities regarding tsunami equipment and technology."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s504/f"},"text":"Pub. L. 115–25, § 504(f)","children":[],"tail":", amended subsec. (f) generally. Prior to amendment, text read as follows: “When deploying and maintaining tsunami detection technologies, the Administrator shall seek the assistance and assets of other appropriate Federal agencies.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s504/h"},"text":"Pub. L. 115–25, § 504(h)","children":[],"tail":", designated existing provisions as par. (1) and inserted heading, redesignated former pars. (1) and (2) as subpars. (A) and (B), respectively, of par. (1) and realigned margins, added subpar. (C) of par. (1), and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s504/g/1"},"text":"Pub. L. 115–25, § 504(g)(1)","children":[],"tail":", (3), redesignated subsec. (h) as (g) and struck out former subsec. (g) which related to annual equipment certification."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s504/g/3"},"text":"Pub. L. 115–25, § 504(g)(3)","children":[],"tail":", redesignated subsec. (h) as (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (i) to (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s504/g/2"},"text":"Pub. L. 115–25, § 504(g)(2)","children":[],"tail":", struck out subsecs. (i) to (k) which related to Comptroller General report, external review by the National Academy of Sciences, and establishment of a process for monitoring and certifying contractor performance, respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c7d38ee-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id6c7d38ef-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Science of House of Representatives changed to Committee on Science and Technology of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":". Committee on Science and Technology of House of Representatives changed to Committee on Science, Space, and Technology of House of Representatives by House Resolution No. 5, One Hundred Twelfth Congress, "},{"tag":"date","attrib":{"date":"2011-01-05"},"text":"Jan. 5, 2011","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
