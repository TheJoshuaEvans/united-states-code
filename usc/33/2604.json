{"tag":"section","attrib":{"id":"id6c654449-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2604"},"text":null,"children":[{"tag":"num","attrib":{"value":"2604"},"text":"§ 2604.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension, revocation, and injunctions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c65444a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2604/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension and revocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After notice and opportunity for a hearing, the Secretary of Transportation may, and at the request of the Administrator shall, suspend or revoke a permit issued to a vessel under this chapter for a violation of this chapter or a regulation prescribed under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c65444b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2604/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Injunctions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary or the Administrator may bring a civil action to enjoin any operation in violation of this chapter or a regulation prescribed under this chapter in the district court of the United States for the district in which the violation occurred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c65444c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/688/tIV/s4104"},"text":"Pub. L. 100–688, title IV, § 4104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4157"},"text":"102 Stat. 4157","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
