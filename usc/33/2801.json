{"tag":"section","attrib":{"id":"id6c712b4e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2801"},"text":null,"children":[{"tag":"num","attrib":{"value":"2801"},"text":"§ 2801.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c712b4f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2801/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a comprehensive national program for consistent monitoring of the Nation’s coastal ecosystems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c712b50-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2801/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish long-term water quality assessment and monitoring programs for high priority coastal waters that will enhance the ability of Federal, State, and local authorities to develop and implement effective remedial programs for those waters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c712b51-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2801/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a system for reviewing and evaluating the scientific, analytical, and technological means that are available for monitoring the environmental quality of coastal ecosystems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c712b52-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2801/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish methods for identifying uniform indicators of coastal ecosystem quality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c712b53-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2801/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for periodic, comprehensive reports to Congress concerning the quality of the Nation’s coastal ecosystems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c712b54-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2801/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a coastal environment information program to distribute coastal monitoring information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c712b55-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2801/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide state ","children":[{"tag":"ref","attrib":{"idref":"fn002123"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002123"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" programs authorized under the Coastal Zone Management Act of 1972 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1451"},"text":"16 U.S.C. 1451","children":[],"tail":" et seq.) with information necessary to design land use plans and coastal zone regulations that will contribute to the protection of coastal ecosystems; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c712b56-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2801/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide certain water pollution control programs authorized under the Federal Water Pollution Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251"},"text":"33 U.S.C. 1251","children":[],"tail":" et seq.) with information necessary to design and implement effective coastal water pollution controls."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c712b57-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/532/tV/s501"},"text":"Pub. L. 92–532, title V, § 501","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/567/tV/s501"},"text":"Pub. L. 102–567, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4293"},"text":"106 Stat. 4293","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c712b58-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c712b59-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c712b5a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Coastal Zone Management Act of 1972, referred to in par. (7), is title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/454"},"text":"Pub. L. 89–454","children":[],"tail":" as added by "},{"tag":"ref","attrib":{"href":"/us/pl/92/583"},"text":"Pub. L. 92–583","children":[],"tail":", "},