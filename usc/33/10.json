{"tag":"section","attrib":{"id":"id6b04549f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"§ 10.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waters in Louisiana Purchase as public highways","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All the navigable rivers and waters in the former Territories of Orleans and Louisiana shall be and forever remain public highways.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b0454a0-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(R.S. § 5251.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b0454a1-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b0454a2-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b0454a3-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5251 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1811-03-03/ch46/s12"},"text":"act Mar. 3, 1811, ch. 46, § 12","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/2/606"},"text":"2 Stat. 606","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
