{"tag":"section","attrib":{"id":"id6c86aeed-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3602"},"text":null,"children":[{"tag":"num","attrib":{"value":"3602"},"text":"§ 3602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c86aeee-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3602/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Under Secretary of Commerce for Oceans and Atmosphere in the Under Secretary’s capacity as Administrator of the National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c86aeef-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3602/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Council","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Council” means the National Ocean Research Leadership Council established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8932"},"text":"section 8932 of title 10","children":[],"tail":"."},{"tag":"ref","attrib":{"idref":"fn002153"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002153"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c86aef0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3602/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal assets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal assets” means all relevant non-classified civilian coastal and ocean observations, technologies, and related modeling, research, data management, basic and applied technology research and development, and public education and outreach programs, that are managed by member agencies of the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c86aef1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3602/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency Ocean Observation Committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Interagency Ocean Observation Committee” means the committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3603/c/2"},"text":"section 3603(c)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c86aef2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3602/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal assets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “non-Federal assets” means all relevant coastal and ocean observation technologies, related basic and applied technology research and development, and public education and outreach programs that are managed through States, regional organizations, universities, nongovernmental organizations, or the private sector and integrated into the System by a regional coastal observing system, the National Oceanic and Atmospheric Administration, or the agencies participating in the Interagency Ocean Observation Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c86aef3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3602/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional coastal observing system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “regional coastal observing system” means an organizational body that is certified or established by contract or memorandum by the lead Federal agency designated in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3603/c/3"},"text":"section 3603(c)(3) of this title","children":[],"tail":" and coordinates State, Federal, local, tribal, and private interests at a regional level with the responsibility of engaging the private and public sectors in designing, operating, and improving regional coastal observing systems in order to ensure the provision of data and information that meet the needs of user groups from the respective regions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c86aef4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3602/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Commerce, acting through the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c86aef5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3602/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" System","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “System” means the National Integrated Coastal and Ocean Observation System established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3603"},"text":"section 3603 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c86aef6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3602/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" System Plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “System Plan” means the plan contained in the document entitled “Ocean. US Publication No. 9, The First Integrated Ocean Observing System (IOOS) Development Plan”, as updated by the Council under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c86aef7-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tXII/s12303"},"text":"Pub. L. 111–11, title XII, § 12303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1428"},"text":"123 Stat. 1428","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/271/tI/s102"},"text":"Pub. L. 116–271, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-31"},"text":"Dec. 31, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3333"},"text":"134 Stat. 3333","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c86aef8-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c86aef9-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c86aefa-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The reference to the National Ocean Research Leadership Council established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8932"},"text":"section 8932 of title 10","children":[],"tail":", referred to in par. (2), is no longer accurate insofar as "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8932"},"text":"section 8932 of title 10","children":[],"tail":" was amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" so as to instead refer to the Ocean Policy Committee."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c86aefb-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/271/s102/1"},"text":"Pub. L. 116–271, § 102(1)","children":[],"tail":", substituted “section 8932” for “section 7902”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/271/s102/2"},"text":"Pub. L. 116–271, § 102(2)","children":[],"tail":", substituted “managed through States, regional organizations, universities, nongovernmental organizations, or the private sector and integrated into the System by a regional coastal observing system, the National Oceanic and Atmospheric Administration, or the agencies participating in the Interagency Ocean Observation Committee” for “integrated into the System and are managed through States, regional organizations, universities, nongovernmental organizations, or the private sector”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/271/s102/3"},"text":"Pub. L. 116–271, § 102(3)","children":[],"tail":", amended par. (6) generally. Prior to amendment, par. (6) related to regional information coordination entities."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/271/s102/4"},"text":"Pub. L. 116–271, § 102(4)","children":[],"tail":", substituted “Administrator” for “National Oceanic and Atmospheric Administration”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
