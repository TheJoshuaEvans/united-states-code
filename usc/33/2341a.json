{"tag":"section","attrib":{"id":"id6c5e18a2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2341a"},"text":"§ 2341a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c5e18a3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization of hurricane and storm damage risk reduction efforts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c5e18a4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For authorized projects and ongoing feasibility studies with a primary purpose of hurricane and storm damage risk reduction, the Secretary shall give funding priority to projects and ongoing studies that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c5e18a5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address an imminent threat to life and property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c5e18a6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent storm surge from inundating populated areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c5e18a7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341a/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restore or prevent the loss of coastal wetlands that help reduce the impact of storm surge;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c5e18a8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341a/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect emergency hurricane evacuation routes or shelters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c5e18a9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341a/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent adverse impacts to publicly owned or funded infrastructure and assets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c5e18aa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341a/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize disaster relief costs to the Federal Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c5e18ab-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341a/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address hurricane and storm damage risk reduction in an area for which the President declared a major disaster in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5170"},"text":"section 5170 of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5e18ac-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedited consideration of currently authorized projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c5e18ad-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a list of all—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c5e18ae-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341a/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ongoing hurricane and storm damage reduction feasibility studies that have signed feasibility cost-share agreements and have received Federal funds since 2009; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c5e18af-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341a/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorized hurricane and storm damage reduction projects;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c5e18b0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify those projects on the list required under subparagraph (A) that meet the criteria described in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c5e18b1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341a/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a plan for expeditiously completing the projects identified under subparagraph (B), subject to available funding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5e18b2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization of ecosystem restoration efforts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c5e18b3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For authorized projects with a primary purpose of ecosystem restoration, the Secretary shall give funding priority to projects—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c5e18b4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c5e18b5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341a/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address an identified threat to public health, safety, or welfare;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c5e18b6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341a/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preserve or restore ecosystems of national significance; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c5e18b7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341a/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preserve or restore habitats of importance for federally protected species, including migratory birds; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c5e18b8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which the restoration activities will contribute to other ongoing or planned Federal, State, or local restoration initiatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5e18b9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedited consideration of currently authorized programmatic authorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":", the Secretary shall submit to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a report that contains—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c5e18ba-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a list of all programmatic authorities for aquatic ecosystem restoration or improvement of the environment that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c5e18bb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341a/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" were authorized or modified in the Water Resources Development Act of 2007 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114"},"text":"Public Law 110–114","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/121/1041"},"text":"121 Stat. 1041","children":[],"tail":") or any subsequent Act; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c5e18bc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341a/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that meet the criteria described in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c5e18bd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan for expeditiously completing the projects under the authorities described in subparagraph (A), subject to available funding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c5e18be-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/tI/s1011"},"text":"Pub. L. 113–121, title I, § 1011","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1217"},"text":"128 Stat. 1217","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tI/s1322/a"},"text":"Pub. L. 114–322, title I, § 1322(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1706"},"text":"130 Stat. 1706","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c5e18bf-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c5e18c0-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c5e18c1-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Water Resources Development Act of 2007, referred to in subsec. (b)(2)(A)(i), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114"},"text":"Pub. L. 110–114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-11-08"},"text":"Nov. 8, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1041"},"text":"121 Stat. 1041","children":[],"tail":". For complete classificaton of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c5e18c2-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Reform and Development Act of 2014, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c5e18c3-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1322/a/1/A"},"text":"Pub. L. 114–322, § 1322(a)(1)(A)","children":[],"tail":", inserted “restore or” before “prevent the loss”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1322/a/1/B/i"},"text":"Pub. L. 114–322, § 1322(a)(1)(B)(i)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":"” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1322/a/1/B/ii"},"text":"Pub. L. 114–322, § 1322(a)(1)(B)(ii)","children":[],"tail":", struck out before semicolon at end “that—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(I) have been authorized for more than 20 years but are less than 75 percent complete; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(II) are undergoing a post-authorization change report, general reevaluation report, or limited reevaluation report”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1322/a/2"},"text":"Pub. L. 114–322, § 1322(a)(2)","children":[],"tail":", designated existing provisions as par. (1) and inserted heading, redesignated former pars. (1) and (2) as subpars. (A) and (B), respectively, of par. (1), redesignated former subpars. (A) to (C) of former par. (1) as cls. (i) to (iii), respectively, of subpar. (A) of par. (1), and added par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c5e18c4-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c5e18c5-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s2"},"text":"section 2 of Pub. L. 113–121","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
