{"tag":"section","attrib":{"id":"id6b76c635-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891e"},"text":null,"children":[{"tag":"num","attrib":{"value":"891e"},"text":"§ 891e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction with respect to certain shipyard subsidies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b76c636-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce may not award a contract for the construction, repair (except emergency repairs), or alteration of any vessel of the National Oceanic and Atmospheric Administration in a shipyard, if that vessel benefits or would benefit from significant subsidies for the construction, repair, or alteration of vessels in that shipyard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b76c637-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Significant subsidy” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “significant subsidy” includes, but is not limited to, any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b76c638-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Officially supported export credits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b76c639-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Direct official operating support to the commercial shipbuilding and repair industry, or to a related entity that favors the operation of shipbuilding and repair, including but not limited to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b76c63a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891e/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b76c63b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891e/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" loans and loan guarantees other than those available on the commercial market;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b76c63c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891e/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forgiveness of debt;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b76c63d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891e/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equity infusions on terms inconsistent with commercially reasonable investment practices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b76c63e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891e/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preferential provision of goods and services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b76c63f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891e/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Direct official support for investment in the commercial shipbuilding and repair industry, or to a related entity that favors the operation of shipbuilding and repair, including but not limited to the kinds of support listed in paragraph (2)(A) through (E), and any restructuring support, except public support for social purposes directly and effectively linked to shipyard closures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b76c640-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891e/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assistance in the form of grants, preferential loans, preferential tax treatment, or otherwise, that benefits or is directly related to shipbuilding and repair for purposes of research and development that is not equally open to domestic and foreign enterprises.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b76c641-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891e/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tax policies and practices that favor the shipbuilding and repair industry, directly or indirectly, such as tax credits, deductions, exemptions, and preferences, including accelerated depreciation, if such benefits are not generally available to persons or firms not engaged in shipbuilding or repair.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b76c642-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891e/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any official regulation or practice that authorizes or encourages persons or firms engaged in shipbuilding or repair to enter into anticompetitive arrangements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b76c643-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891e/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any indirect support directly related, in law or in fact, to shipbuilding and repair at national yards, including any public assistance favoring shipowners with an indirect effect on shipbuilding or repair activities, and any assistance provided to suppliers of significant inputs to shipbuilding, which results in benefits to domestic shipbuilders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b76c644-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891e/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any export subsidy identified in the Illustrative List of Export Subsidies in the Annex to the Agreement on Subsidies and Countervailing Measures referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3511/d/12"},"text":"section 3511(d)(12) of title 19","children":[],"tail":", or any other export subsidy prohibited by that agreement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b76c645-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/567/tVI/s607"},"text":"Pub. L. 102–567, title VI, § 607","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4302"},"text":"106 Stat. 4302","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/36/tI/s1002/f"},"text":"Pub. L. 106–36, title I, § 1002(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-06-25"},"text":"June 25, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/133"},"text":"113 Stat. 133","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b76c646-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b76c647-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b76c648-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/36"},"text":"Pub. L. 106–36","children":[],"tail":" substituted “Agreement on Subsidies and Countervailing Measures referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3511/d/12"},"text":"section 3511(d)(12) of title 19","children":[],"tail":", or any other export subsidy prohibited by that agreement” for “Agreement on Interpretation and Application of Articles VI, XVI, and XXIII of the General Agreement on Tariffs and Trade or any other export subsidy that may be prohibited as a result of the Uruguay Round of trade negotiations.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b76c649-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b76c64a-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Fisheries Research Vessel Procurement","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/450/tIV/s401"},"text":"Pub. L. 106–450, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-07"},"text":"Nov. 7, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1945"},"text":"114 Stat. 1945","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/450/tIV/s401"},"text":"“Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s644"},"text":"section 644 of title 15","children":[],"tail":", United States Code, and section 19.502–2 of title 48, Code of Federal Regulations, the Secretary of Commerce shall seek to procure Fisheries Research Vessels through full and open competition from responsible United States shipbuilding companies irrespective of size.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
