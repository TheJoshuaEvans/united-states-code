{"tag":"section","attrib":{"id":"id6c97511e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4251"},"text":null,"children":[{"tag":"num","attrib":{"value":"4251"},"text":"§ 4251.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incentive for fishermen to collect and dispose of plastic found at sea","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c97511f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4251/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Under Secretary shall establish a pilot program to assess the feasibility and advisability of providing incentives, such as grants, to fishermen based in the United States who incidentally capture marine debris while at sea—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c975120-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4251/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to track or keep the debris on board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c975121-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4251/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to dispose of the debris properly on land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c975122-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4251/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support for collection and removal of derelict gear","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Under Secretary shall encourage United States efforts, such as the Fishing for Energy net disposal program, that support—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c975123-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4251/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collection and removal of derelict fishing gear and other fishing waste;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c975124-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4251/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disposal or recycling of such gear and waste; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c975125-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4251/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevention of the loss of such gear.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c975126-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/224/tI/s137"},"text":"Pub. L. 116–224, title I, § 137","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-18"},"text":"Dec. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1086"},"text":"134 Stat. 1086","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
