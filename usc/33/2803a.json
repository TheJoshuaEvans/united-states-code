{"tag":"section","attrib":{"id":"id6c739cb2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2803a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2803a"},"text":"§ 2803a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ocean and coastal resiliency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c739cb3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2803a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct studies to determine the feasibility of carrying out Corps of Engineers projects in coastal zones to enhance ocean and coastal ecosystem resiliency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c739cb4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2803a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the study under subsection (a), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c739cb5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2803a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as appropriate, coordinate with the heads of other appropriate Federal agencies, the Governors and other chief executive officers of the coastal states, nonprofit organizations, Indian tribes, and other interested parties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739cb6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2803a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify Corps of Engineers projects in coastal zones for enhancing ocean and coastal ecosystem resiliency based on an assessment of the need and opportunities for, and feasibility of, the projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739cb7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2803a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give priority to projects in communities the existence of which is threatened by rising sea level, including projects relating to shoreline restoration, tidal marsh restoration, dunal habitats to protect coastal infrastructure, reduction of future and existing emergency repair costs, and the beneficial reuse of dredged materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739cb8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2803a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, use any existing Corps of Engineers plans and data; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739cb9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2803a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 365 days after initial appropriations for this section, and every five years thereafter subject to the availability of appropriations, complete a study authorized under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c739cba-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2803a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c739cbb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2803a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may carry out a project identified in the study pursuant to subsection (a) in accordance with the criteria for projects carried out under one of the following authorities:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c739cbc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2803a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 2330(a)–(d) of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c739cbd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2803a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 2309a(a)–(g) and (i) of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c739cbe-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2803a/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 426g(a)–(b) and (c)(1) of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c739cbf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2803a/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 2326(a)–(f) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739cc0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2803a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each project that does not meet the criteria under paragraph (1), the Secretary shall include a recommendation relating to the project in the annual report submitted to Congress by the Secretary in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2282d"},"text":"section 2282d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c739cc1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2803a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requests for projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may carry out a project for a coastal state under this section only at the request of the Governor or chief executive officer of the coastal state, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c739cc2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2803a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the terms “coastal zone” and “coastal state” have the meanings given such terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1453"},"text":"section 1453 of title 16","children":[],"tail":", as in effect on "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c739cc3-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/tIV/s4014"},"text":"Pub. L. 113–121, title IV, § 4014","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1321"},"text":"128 Stat. 1321","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tI/s1183/a"},"text":"Pub. L. 114–322, title I, § 1183(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1678"},"text":"130 Stat. 1678","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c739cc4-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c739cc5-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c739cc6-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Reform and Development Act of 2014, and not as part of title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/532"},"text":"Pub. L. 92–532","children":[],"tail":", popularly known as the National Coastal Monitoring Act, which comprises this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c739cc7-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1183/a/1"},"text":"Pub. L. 114–322, § 1183(a)(1)","children":[],"tail":", inserted “Indian tribes,” after “nonprofit organizations,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1183/a/2"},"text":"Pub. L. 114–322, § 1183(a)(2)","children":[],"tail":", (3), added par. (3) and redesignated former pars. (3) and (4) as (4) and (5), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c739cc8-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c739cc9-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s2"},"text":"section 2 of Pub. L. 113–121","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
