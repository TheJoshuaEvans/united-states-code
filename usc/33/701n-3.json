{"tag":"section","attrib":{"id":"id6b63b274-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701n–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"701n–3"},"text":"§ 701n–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permanent measures to reduce emergency flood fighting needs for communities subject to repetitive flooding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b63b275-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701n–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b63b276-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701n–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affected community","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “affected community” means a legally constituted public body (as that term is used in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1962d–5b/b"},"text":"section 1962d–5b(b) of title 42","children":[],"tail":")—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b63b277-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701n–3/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with jurisdiction over an area that has been subject to flooding in two or more events in any 10-year period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b63b278-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701n–3/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that has received emergency flood-fighting assistance, including construction of temporary barriers by the Secretary, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s701n"},"text":"section 701n of this title","children":[],"tail":" with respect to such flood events."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b63b279-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701n–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Natural feature; nature-based feature","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “natural feature” and “nature-based feature” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2289a"},"text":"section 2289a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b63b27a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701n–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b63b27b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701n–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to carry out a program to study, design, and construct water resources development projects through measures involving, among other things, strengthening, raising, extending, realigning, or otherwise modifying existing flood control works, designing new works, and incorporating natural features, nature-based features, or nonstructural features, as appropriate to provide flood and coastal storm risk management to affected communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b63b27c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701n–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out paragraph (1), the Secretary shall, to the maximum extent practical, review and, where appropriate, incorporate natural features or nature-based features, or a combination of such features and nonstructural features, that avoid or reduce at least 50 percent of flood or storm damages in one or more of the alternatives included in the final alternatives evaluated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b63b27d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701n–3/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b63b27e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701n–3/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may carry out a project described in paragraph (1) without further congressional authorization if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6b63b27f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701n–3/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary determines that the project—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id6b63b280-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701n–3/b/3/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is advisable to reduce the risk of flooding for an affected community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6b63b281-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701n–3/b/3/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produces benefits that are in excess of the estimated costs; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6b63b282-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701n–3/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal share of the cost of the construction does not exceed $17,500,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b63b283-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701n–3/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Federal share of the cost of a project described in paragraph (1) exceeds $17,500,000, the Secretary shall submit the project recommendation to Congress for authorization prior to construction, and shall include the project recommendation in the next annual report submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2282d"},"text":"section 2282d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b63b284-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701n–3/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financing","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6b63b285-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701n–3/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, based on a study carried out pursuant to paragraph (1), the Secretary determines that a project described in paragraph (1) will not produce benefits greater than cost, the Secretary shall allow the affected community to pay, or provide contributions equal to, an amount sufficient to make the remaining costs of design and construction of the project equal to the estimated value of the benefits of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6b63b286-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701n–3/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on non-Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts provided by an affected community under clause (i) shall be in addition to any payments or contributions the affected community is required to provide toward the remaining costs of design and construction of the project under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2213"},"text":"section 2213 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b63b287-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701n–3/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ability to pay","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b63b288-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701n–3/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any cost-sharing agreement for a project entered into pursuant to this section shall be subject to the ability of the affected community to pay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b63b289-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701n–3/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The ability of any affected community to pay shall be determined by the Secretary in accordance with procedures established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b63b28a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701n–3/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of reduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any reduction in the non-Federal share of the cost of a project described in paragraph (1) as a result of a determination under this paragraph shall not be included in the Federal share for purposes of subparagraphs (A) and (B) of paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b63b28b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/tI/s119"},"text":"Pub. L. 116–260, div. AA, title I, § 119","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2632"},"text":"134 Stat. 2632","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b63b28c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b63b28d-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b63b28e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/s2"},"text":"section 2 of div. AA of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
