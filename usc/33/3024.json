{"tag":"section","attrib":{"id":"id6c760e63-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3024"},"text":null,"children":[{"tag":"num","attrib":{"value":"3024"},"text":"§ 3024.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion by selection to permanent grades above lieutenant (junior grade)","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Promotion to fill vacancies in each permanent grade above the grade of lieutenant (junior grade) shall be made by selection from the next lower grade upon recommendation of the personnel board.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6c760e64-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372/tII/s224"},"text":"Pub. L. 107–372, title II, § 224","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3085"},"text":"116 Stat. 3085","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c760e65-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c760e66-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6c760e67-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s853b"},"text":"section 853b of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/u