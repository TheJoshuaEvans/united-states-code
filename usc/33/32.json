{"tag":"section","attrib":{"id":"id6b06c5f2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s32"},"text":null,"children":[{"tag":"num","attrib":{"value":"32"},"text":"§ 32.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lake George, Mississippi","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Lake George, in Yazoo County, in the State of Mississippi, is declared to be not a navigable water of the United States within the meaning of the laws enacted by the Congress for the preservation and protection of such waters.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The right of Congress to alter, amend, or repeal this section is expressly reserved.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b06c5f3-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-05-24/ch198"},"text":"May 24, 1922, ch. 198","children":[],"tail":", §§ 1, 2, "},{"tag":"ref","attrib":{"href":"/us/stat/42/552"},"text":"42 Stat. 552","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b06c5f4-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b06c5f5-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b06c5f6-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The two sentences comprising this section are respectively sections 1 and 2 of act ","children":[{"tag":"date","attrib":{"date":"1922-05-24"},"text":"May 24, 1922","children":[],"tail":", entitled “An act declaring Lake George, Yazoo County, Mississippi, to be a nonnavigable stream”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
