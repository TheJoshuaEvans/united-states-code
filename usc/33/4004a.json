{"tag":"section","attrib":{"id":"id6c950709-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004a"},"text":null,"children":[{"tag":"num","attrib":{"value":"4004a"},"text":"§ 4004a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" South Florida harmful algal blooms and hypoxia","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c95070a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" South Florida","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “South Florida” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c95070b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all lands and waters within the administrative boundaries of the South Florida Water Management District;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c95070c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regional coastal waters, including Biscayne Bay, the Caloosahatchee Estuary, Florida Bay, Indian River Lagoon, and St. Lucie River Estuary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c95070d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Florida Reef Tract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c95070e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integrated assessment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c95070f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim integrated assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 540 days after ","children":[{"tag":"date","attrib":{"date":"2022-06-16"},"text":"June 16, 2022","children":[],"tail":", the Task Force, in accordance with the authority under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s4001"},"text":"section 4001 of this title","children":[],"tail":", shall complete and submit to Congress and the President an interim integrated assessment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c950710-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finalized integrated assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2022-06-16"},"text":"June 16, 2022","children":[],"tail":", the Task Force shall finalize, and submit to Congress and the President, the interim integrated assessment required by paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c950711-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of integrated assessment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The integrated assessment required by paragraphs (1) and (2) shall examine the causes, consequences, and potential approaches to reduce harmful algal blooms and hypoxia in South Florida, and the status of, and gaps within, current harmful algal bloom and hypoxia research, monitoring, management, prevention, response, and control activities that directly affect the region by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c950712-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004a/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c950713-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004a/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c950714-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004a/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regional research consortia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c950715-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004a/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" academia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c950716-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004a/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c950717-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004a/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nongovernmental organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c950718-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004a/b/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian tribes (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c950719-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c95071a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 years and 180 days after ","children":[{"tag":"date","attrib":{"date":"2022-06-16"},"text":"June 16, 2022","children":[],"tail":", the Task Force shall develop and submit to Congress a plan, based on the integrated assessment under subsection (b), for reducing, mitigating, and controlling harmful algal blooms and hypoxia in South Florida."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c95071b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan submitted under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c95071c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address the monitoring needs identified in the integrated assessment under subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c95071d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a timeline and budgetary requirements for deployment of future assets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c95071e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify requirements for the development and verification of South Florida harmful algal bloom and hypoxia models, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c95071f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004a/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all assumptions built into the models; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c950720-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004a/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data quality methods used to ensure the best available data are utilized; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c950721-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004a/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" propose a plan to implement a remote monitoring network and early warning system for alerting local communities in the region to harmful algal bloom risks that may impact human health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c950722-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the action plan, the Task Force shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c950723-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with the State of Florida, and affected local and tribal governments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c950724-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with representatives from regional academic, agricultural, industry, and other stakeholder groups;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c950725-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004a/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the plan complements and does not duplicate activities conducted by other Federal or State agencies, including the South Florida Ecosystem Restoration Task Force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c950726-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004a/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify critical research for reducing, mitigating, and controlling harmful algal bloom events and their effects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c950727-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004a/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate cost-effective, incentive-based partnership approaches;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c950728-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004a/c/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the plan is technically sound and cost-effective;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c950729-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004a/c/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilize existing research, assessments, reports, and program activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c95072a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004a/c/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish a summary of the proposed plan in the Federal Register at least 180 days prior to submitting the completed plan to Congress; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c95072b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004a/c/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after submitting the completed plan to Congress, provide biennial progress reports on the activities toward achieving the objectives of the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c95072c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/383/tVI/s605"},"text":"Pub. L. 105–383, title VI, § 605","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/144/s2/a/2"},"text":"Pub. L. 117–144, § 2(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-06-16"},"text":"June 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1266"},"text":"136 Stat. 1266","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c95072d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c95072e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6c95072f-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/383/s605"},"text":"section 605 of Pub. L. 105–383","children":[],"tail":" was renumbered section 606 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s4005"},"text":"section 4005 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
