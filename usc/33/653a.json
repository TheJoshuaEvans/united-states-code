{"tag":"section","attrib":{"id":"id6b55823e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s653a"},"text":null,"children":[{"tag":"num","attrib":{"value":"653a"},"text":"§ 653a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of jurisdiction of Mississippi River Commission","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The jurisdiction of the Mississippi River Commission, established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s641"},"text":"section 641 of this title","children":[],"tail":", is extended to include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b55823f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s653a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all of the area between the eastern side of the Bayou Lafourche Ridge from Donaldsonville, Louisiana, to the Gulf of Mexico and the west guide levee of the Mississippi River from Donaldsonville, Louisiana, to the Gulf of Mexico;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b558240-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s653a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Alexander County, Illinois; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b558241-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s653a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the area in the State of Illinois from the confluence of the Mississippi and Ohio Rivers northward to the vicinity of Mississippi River mile 39.5, including the Len Small Drainage and Levee District, insofar as such area is affected by the flood waters of the Mississippi River.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b558242-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/303/tV/s517"},"text":"Pub. L. 104–303, title V, § 517","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3764"},"text":"110 Stat. 3764","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
