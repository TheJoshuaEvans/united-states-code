{"tag":"section","attrib":{"id":"id6b21050a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s408a"},"text":null,"children":[{"tag":"num","attrib":{"value":"408a"},"text":"§ 408a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expediting approval of modifications and alterations of projects by non-Federal interests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b21050b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s408a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Section 14 application defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “section 14 application” means an application submitted by an applicant to the Secretary requesting permission for the temporary occupation or use of a public work, or the alteration or permanent occupation or use of a public work, under ","children":[{"tag":"ref","attrib":{"href":"/us/act/1899-03-03/s14"},"text":"section 14 of the Act of March 3, 1899","children":[],"tail":" (commonly known as the “Rivers and Harbors Appropriation Act of 1899”) ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s408"},"text":"33 U.S.C. 408","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b21050c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s408a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", the Secretary, after providing notice and an opportunity for comment, shall establish a process for the review of section 14 applications in a timely and consistent manner."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b21050d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s408a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benchmark goals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b21050e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s408a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of benchmark goals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (b), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b21050f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s408a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish benchmark goals for determining the amount of time it should take the Secretary to determine whether a section 14 application is complete;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b210510-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s408a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish benchmark goals for determining the amount of time it should take the Secretary to approve or disapprove a section 14 application; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b210511-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s408a/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, use such benchmark goals to make a decision on section 14 applications in a timely and consistent manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b210512-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s408a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benchmark goals","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b210513-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s408a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benchmark goals for determining whether section 14 applications are complete","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent practicable, the benchmark goals established under paragraph (1) shall provide that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6b210514-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s408a/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary reach a decision on whether a section 14 application is complete not later than 15 days after the date of receipt of the application; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6b210515-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s408a/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary determines that a section 14 application is not complete, the Secretary promptly notify the applicant of the specific information that is missing or the analysis that is needed to complete the application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b210516-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s408a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benchmark goals for reviewing completed applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent practicable, the benchmark goals established under paragraph (1) shall provide that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6b210517-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s408a/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary generally approve or disapprove a completed section 14 application not later than 45 days after the date of receipt of the completed application; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6b210518-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s408a/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a case in which the Secretary determines that additional time is needed to review a completed section 14 application due to the type, size, cost, complexity, or impacts of the actions proposed in the application, the Secretary generally approve or disapprove the application not later than 180 days after the date of receipt of the completed application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b210519-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s408a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any case in which the Secretary determines that it will take the Secretary more than 45 days to review a completed section 14 application, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b21051a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s408a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide written notification to the applicant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b21051b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s408a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include in the written notice a best estimate of the Secretary as to the amount of time required for completion of the review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b21051c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s408a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to achieve benchmark goals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any case in which the Secretary fails make ","children":[{"tag":"ref","attrib":{"idref":"fn002008"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002008"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by “to”."}],"tail":" a decision on a section 14 application in accordance with the process established under this section, the Secretary shall provide written notice to the applicant, including a detailed description of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b21051d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s408a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" why the Secretary failed to make a decision in accordance with such process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b21051e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s408a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the additional actions required before the Secretary will issue a decision; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b21051f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s408a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of time the Secretary will require to issue a decision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b210520-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s408a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b210521-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s408a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide a copy of any written notice provided under subsection (d) to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b210522-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s408a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall maintain a publicly available database, including on the Internet, on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b210523-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s408a/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all section 14 applications received by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b210524-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s408a/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current status of such applications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b210525-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s408a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b210526-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s408a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":", the Secretary shall issue guidance on the implementation of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b210527-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s408a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incorporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In issuing guidance under paragraph (1), or any other regulation, guidance, or engineering circular related to activities covered under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s408"},"text":"section 408 of this title","children":[],"tail":", the Secretary shall incorporate the requirements under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b210528-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s408a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prioritize and complete the activities required of the Secretary under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b210529-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/tI/s1007"},"text":"Pub. L. 113–121, title I, § 1007","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1214"},"text":"128 Stat. 1214","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tI/s1156/b"},"text":"Pub. L. 114–322, title I, § 1156(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1665"},"text":"130 Stat. 1665","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b21052a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b21052b-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b21052c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322"},"text":"Pub. L. 114–322","children":[],"tail":" added subsecs. (f) and (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b21052d-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b21052e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s2"},"text":"section 2 of Pub. L. 113–121","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
