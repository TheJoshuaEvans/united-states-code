{"tag":"section","attrib":{"id":"id6b1c4938-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s381"},"text":null,"children":[{"tag":"num","attrib":{"value":"381"},"text":"§ 381.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of public vessels to suppress piracy","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President is authorized to employ so many of the public armed vessels as in his judgment the service may require, with suitable instructions to the commanders thereof, in protecting the merchant vessels of the United States and their crews from piratical aggressions and depredations.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b1c4939-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(R.S. § 4293.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b1c493a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b1c493b-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b1c493c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 4293 derived from acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1819-03-03/ch77/s1"},"text":"Mar. 3, 1819, ch. 77, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/3/510"},"text":"3 Stat. 510","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1823-01-30/ch7"},"text":"Jan. 30, 1823, ch. 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/3/721"},"text":"3 Stat. 721","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],