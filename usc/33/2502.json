{"tag":"section","attrib":{"id":"id6c62faf7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2502"},"text":null,"children":[{"tag":"num","attrib":{"value":"2502"},"text":"§ 2502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c62faf8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2502/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Potentially infectious medical waste","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “potentially infectious medical waste” includes isolation wastes; infectious agents; human blood and blood products; pathological wastes; sharps; body parts; contaminated bedding; surgical wastes; and other disposable medical equipment and material that may pose a risk to the public health, welfare or the marine environment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62faf9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2502/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public vessel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “public vessel” means a vessel of any type whatsoever (including hydrofoils, air-cushion vehicles, submersibles, floating craft whether propelled or not, and fixed or floating platforms) that is owned, or demise chartered, and operated by the United States Government, and is not engaged in commercial service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c62fafa-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/688/tIII/s3103"},"text":"Pub. L. 100–688, title III, § 3103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4152"},"text":"102 Stat. 4152","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
