{"tag":"section","attrib":{"id":"id6c54a2c9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321"},"text":null,"children":[{"tag":"num","attrib":{"value":"2321"},"text":"§ 2321.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation and maintenance of navigation and hydroelectric facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c54a2ca-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Activities currently performed by personnel under the direction of the Secretary in connection with the operation and maintenance of navigation or hydroelectric power generating facilities at Corps of Engineers water resources projects are to be considered as inherently governmental functions and not commercial activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c54a2cb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Major maintenance contracts allowed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section does not prohibit contracting out major maintenance or other functions which are currently contracted out or studying services not directly connected with project maintenance and operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c54a2cc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section does not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c54a2cd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apply to a navigation facility that was under contract on or before ","children":[{"tag":"date","attrib":{"date":"2018-10-23"},"text":"October 23, 2018","children":[],"tail":", with a non-Federal interest to perform operations or maintenance; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c54a2ce-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibit the Secretary from contracting out commercial activities after ","children":[{"tag":"date","attrib":{"date":"2018-10-23"},"text":"October 23, 2018","children":[],"tail":", at a navigation facility."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c54a2cf-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/640/tIII/s314"},"text":"Pub. L. 101–640, title III, § 314","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4641"},"text":"104 Stat. 4641","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/270/tI/s1151/a"},"text":"Pub. L. 115–270, title I, § 1151(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3787"},"text":"132 Stat. 3787","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c54a2d0-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c54a2d1-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c54a2d2-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 1990, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c54a2d3-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270"},"text":"Pub. L. 115–270","children":[],"tail":" inserted “navigation and” before “hydroelectric facilities” in section catchline, designated first sentence as subsec. (a), inserted heading, and inserted “navigation or” before “hydroelectric”, designated second sentence as subsec. (b) and inserted heading, and added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c54a2d4-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c54a2d5-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Remote Operations at Corps Dams","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/dA/tI/s1149"},"text":"Pub. L. 118–272, div. A, title I, § 1149","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3039"},"text":"138 Stat. 3039","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/272/dA/tI/s1149"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“During the 6-year period beginning on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":"], with respect to a water resources development project owned, operated, or managed by the Corps of Engineers, the Secretary [of the Army] is authorized to use remote operation activities at a navigation or hydroelectric power generating facility at such project as a replacement for activities performed, as of the date of enactment of this Act, by personnel under the direction of the Secretary at such project, only after the Secretary provides written notice to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Environment and Public Works of the Senate that—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" use of the remote operation activities—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not affect activities described in section 314 of the Water Resources Development Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2321"},"text":"33 U.S.C. 2321","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will address any cyber and physical security risks to such project in accordance with applicable Federal law and agency guidance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is necessary to increase the availability and capacity, as applicable, of such project, including a project on a lower use waterway; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the remote operation activities were developed under a public process that included engagement with such personnel and other stakeholders who may be affected by the use of such activities.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c54a2d6-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/640/s2"},"text":"section 2 of Pub. L. 101–640","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
