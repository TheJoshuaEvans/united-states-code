{"tag":"section","attrib":{"id":"id6b0b8124-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s52"},"text":null,"children":[{"tag":"num","attrib":{"value":"52"},"text":"§ 52.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Park River, Connecticut","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Park River, a minor tributary of the Connecticut River, located in Hartford County, Connecticut, is declared to be a nonnavigable waterway within the meaning of the Constitution and laws of the United States of America.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The right of Congress to alter, amend, or repeal this section is expressly reserved.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b0b8125-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-05-24/ch246"},"text":"May 24, 1937, ch. 246","children":[],"tail":", §§ 1, 2, "},{"tag":"ref","attrib":{"href":"/us/stat/50/201"},"text":"50 Stat. 201","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
