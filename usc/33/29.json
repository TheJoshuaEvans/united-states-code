{"tag":"section","attrib":{"id":"id6b06c5e1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s29"},"text":null,"children":[{"tag":"num","attrib":{"value":"29"},"text":"§ 29.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cuivre River, Missouri","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Cuivre River, in the counties of Lincoln and Saint Charles, in the State of Missouri, being the dividing line, is declared not to be a navigable stream, and shall be so treated by the Secretary of the Army and all other authorities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b06c5e2-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1900-03-23/ch88"},"text":"Mar. 23, 1900, ch. 88","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/31/50"},"text":"31 Stat. 50","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title II, § 205(a), "},{"tag":"ref","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b06c5e3-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b06c5e4-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id6b06c5e5-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Department of War designated Department of the Army and title of Secretary of War changed to Secretary of the Army by section 205(a) of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343/tII"},"text":"act July 26, 1947, ch. 343, title II","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":". Section 205(a) of act "},{"tag":"date","attrib":{"date":"1947-07-26"},"text":"July 26, 1947","children":[],"tail":", was repealed by section 53 of "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/641"},"text":"70A Stat. 641","children":[],"tail":". Section 1 of act "},{"tag":"date","attrib":{"date":"1956-08-10"},"text":"Aug. 10, 1956","children":[],"tail":", enacted “Title 10, Armed Forces” which in sections 3010 to 3013 continued Department of the Army under administrative supervision of Secretary of the Army."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
