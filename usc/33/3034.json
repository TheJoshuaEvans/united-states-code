{"tag":"section","attrib":{"id":"id6c7856af-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3034"},"text":null,"children":[{"tag":"num","attrib":{"value":"3034"},"text":"§ 3034.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officer candidates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c7856b0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3034/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of number","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall determine the number of appointments of officer candidates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7856b1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3034/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Appointment of officer candidates shall be made under regulations, which the Secretary shall prescribe, including regulations with respect to determining age limits, methods of selection of officer candidates, term of service as an officer candidate before graduation from the basic officer training program of the Administration, and all other matters affecting such appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7856b2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3034/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dismissal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may dismiss from the basic officer training program of the Administration any officer candidate who, during the officer candidate’s term as an officer candidate, the Secretary considers unsatisfactory in either academics or conduct, or not adapted for a career in the commissioned officer corps of the Administration. Officer candidates shall be subject to rules governing discipline prescribed by the Director of the National Oceanic and Atmospheric Administration Commissioned Officer Corps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7856b3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3034/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7856b4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3034/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each officer candidate shall sign an agreement with the Secretary in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3006/a/2"},"text":"section 3006(a)(2) of this title","children":[],"tail":" regarding the officer candidate’s term of service in the commissioned officer corps of the Administration."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7856b5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3034/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An agreement signed by an officer candidate under paragraph (1) shall provide that the officer candidate agrees to the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c7856b6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3034/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That the officer candidate will complete the course of instruction at the basic officer training program of the Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7856b7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3034/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" That upon graduation from such program, the officer candidate—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c7856b8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3034/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will accept an appointment, if tendered, as an officer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c7856b9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3034/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will serve on active duty for at least four years immediately after such appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7856ba-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3034/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prescribe regulations to carry out this section. Such regulations shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7856bb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3034/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standards for determining what constitutes a breach of an agreement signed under subsection (d)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7856bc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3034/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for determining whether such a breach has occurred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7856bd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3034/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An officer candidate or former officer candidate who does not fulfill the terms of the obligation to serve as specified under subsection (d) shall be subject to the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3006/b"},"text":"section 3006(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c7856be-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372/tII/s234"},"text":"Pub. L. 107–372, title II, § 234","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/259/tIII/s305/a"},"text":"Pub. L. 116–259, title III, § 305(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-23"},"text":"Dec. 23, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1172"},"text":"134 Stat. 1172","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
