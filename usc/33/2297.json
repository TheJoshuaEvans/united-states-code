{"tag":"section","attrib":{"id":"id6c4d76f1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2297"},"text":null,"children":[{"tag":"num","attrib":{"value":"2297"},"text":"§ 2297.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation and maintenance on recreation lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall not require, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460d"},"text":"section 460d of title 16","children":[],"tail":", and the Federal Water Project Recreation Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t16/s460"},"text":"16 U.S.C. 460","children":[],"tail":null},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–12 et seq.], non-Federal interests to assume operation and maintenance of any recreational facility operated by the Secretary at any water resources project as a condition to the construction of new recreational facilities at such project or any other water resources project."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6c4d76f2-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662/tIX/s927"},"text":"Pub. L. 99–662, title IX, § 927","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4195"},"text":"100 Stat. 4195","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c4d76f3-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c4d76f4-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c4d76f5-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Water Project Recreation Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/72"},"text":"Pub. L. 89–72","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-09"},"text":"July 9, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/213"},"text":"79 Stat. 213","children":[],"tail":", which is classified principally to part C (§ 460"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–12 et seq.) of subchapter LXIX of chapter 1 of Title 16, Conservation. For complete classification of this Act to the Code, see Short Title note set out under section 460"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–12 of Title 16 and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
