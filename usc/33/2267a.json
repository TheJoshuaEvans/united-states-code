{"tag":"section","attrib":{"id":"id6c419022-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2267a"},"text":"§ 2267a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Watershed and river basin assessments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c419023-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may assess the water resources needs of river basins and watersheds of the United States, including needs relating to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c419024-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ecosystem protection and restoration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c419025-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" flood damage reduction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c419026-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" navigation and ports;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c419027-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" watershed protection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c419028-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water supply;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c419029-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" drought preparedness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c41902a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sea level rise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c41902b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coastal storm damage reduction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c41902c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" streambank and shoreline protection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c41902d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An assessment under subsection (a) shall be carried out in cooperation and coordination with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c41902e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Interior;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c41902f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c419030-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c419031-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Environmental Protection Agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c419032-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the heads of other appropriate agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c419033-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out an assessment under subsection (a), the Secretary shall consult with Federal, tribal, State, interstate, and local governmental entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c419034-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority river basins and watersheds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting river basins and watersheds for assessment under this section, the Secretary shall give priority to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c419035-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Delaware River basin;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c419036-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Kentucky River basin;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c419037-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Potomac River basin;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c419038-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Susquehanna River basin;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c419039-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Willamette River basin;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c41903a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tuscarawas River Basin, Ohio;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c41903b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sauk River Basin, Snohomish and Skagit Counties, Washington;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c41903c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Niagara River Basin, New York;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c41903d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Genesee River Basin, New York;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c41903e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/d/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" White River Basin, Arkansas and Missouri;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c41903f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/d/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" New York-New Jersey Watershed Basin, which encompasses all the watersheds that flow into the New York-New Jersey Harbor and their associated estuaries, including the Hudson, Mohawk, Raritan, Passaic, Hackensack, and Bronx River Watersheds and the Hudson River Estuary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c419040-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/d/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Mississippi River Watershed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c419041-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/d/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chattahoochee River Basin, Alabama, Florida, and Georgia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c419042-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/d/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Walla Walla River Basin;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c419043-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/d/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the San Francisco Bay Basin;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c419044-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/d/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Connecticut River Watershed, Connecticut, Massachusetts, New Hampshire, and Vermont;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c419045-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/d/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Lower Rouge River Watershed, Michigan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c419046-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/d/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Grand River Watershed, Michigan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c419047-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out an assessment under subsection (a), the Secretary may accept contributions, in cash or in kind, from Federal, tribal, State, interstate, and local governmental entities to the extent that the Secretary determines that the contributions will facilitate completion of the assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c419048-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-sharing requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c419049-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal share of the costs of an assessment carried out under this section on or after ","children":[{"tag":"date","attrib":{"date":"2000-12-11"},"text":"December 11, 2000","children":[],"tail":", shall be 25 percent."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c41904a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c41904b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), the Secretary may credit toward the non-Federal share of an assessment under this section the cost of services, materials, supplies, or other in-kind contributions provided by the non-Federal interests for the assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c41904c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount of credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The credit under subparagraph (A) may not exceed an amount equal to 25 percent of the costs of the assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c41904d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Feasibility report on project specific recommendations from assessments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c41904e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the request of a non-Federal interest for an assessment completed under this section, the Secretary is authorized to prepare a feasibility report, in accordance with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2282"},"text":"section 2282 of this title","children":[],"tail":", recommending the construction or modification of a water resources development project to address a water resources need of a river basin or watershed of the United States identified in the assessment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c41904f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority watersheds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this subsection, the Secretary shall give priority to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c419050-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the watersheds of the island of Maui, Hawaii, including the Wahikuli, Honoko̅wai, Kahana, Honokahua, and Honolua watersheds, including the coral reef habitat north of Lahaina off the northwestern coast of the island of Maui; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c419051-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2267a/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the watersheds of the Northern Mariana Islands, American Samoa, and Guam.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c419052-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662/tVII/s729"},"text":"Pub. L. 99–662, title VII, § 729","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4164"},"text":"100 Stat. 4164","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/541/tII/s202"},"text":"Pub. L. 106–541, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-11"},"text":"Dec. 11, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2587"},"text":"114 Stat. 2587","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/114/tII/s2010"},"text":"Pub. L. 110–114, title II, § 2010","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-11-08"},"text":"Nov. 8, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1074"},"text":"121 Stat. 1074","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dH/tLXXXI/s8302"},"text":"Pub. L. 117–263, div. H, title LXXXI, § 8302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3776"},"text":"136 Stat. 3776","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dA/tI/s1143"},"text":"Pub. L. 118–272, div. A, title I, § 1143","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3034"},"text":"138 Stat. 3034","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c419053-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c419054-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c419055-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (d)(14) to (18). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1143/1"},"text":"Pub. L. 118–272, § 1143(1)","children":[],"tail":", added pars. (14) to (18)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1143/2"},"text":"Pub. L. 118–272, § 1143(2)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(7) to (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s8302/1"},"text":"Pub. L. 117–263, § 8302(1)","children":[],"tail":", added pars. (7) to (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(11) to (13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s8302/2"},"text":"Pub. L. 117–263, § 8302(2)","children":[],"tail":", added pars. (11) to (13)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (d)(6) to (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s2010/1"},"text":"Pub. L. 110–114, § 2010(1)","children":[],"tail":", added pars. (6) to (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s2010/2"},"text":"Pub. L. 110–114, § 2010(2)","children":[],"tail":", added par. (1) and struck out heading and text of former par. (1). Text read as follows: “The non-Federal share of the costs of an assessment carried out under this section shall be 50 percent.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s2010/3"},"text":"Pub. L. 110–114, § 2010(3)","children":[],"tail":", struck out heading and text of subsec. (g). Text read as follows: “There is authorized to be appropriated to carry out this section $15,000,000.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/541"},"text":"Pub. L. 106–541","children":[],"tail":" amended section catchline and text generally. Prior to amendment, section read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) The Secretary, in coordination with the Secretary of the Interior and in consultation with appropriate Federal, State, and local agencies, is authorized to study the water resources needs of river basins and regions of the United States. The Secretaries shall report the results of such study to Congress not later than ","children":[{"tag":"date","attrib":{"date":"1988-10-01"},"text":"October 1, 1988","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) In carrying out the studies authorized under subsection (a) of this section, the Secretaries shall consult with State, interstate, and local governmental entities.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(c) There is authorized to be appropriated $5,000,000 for fiscal years beginning after ","children":[{"tag":"date","attrib":{"date":"1986-09-30"},"text":"September 30, 1986","children":[],"tail":", to carry out this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
