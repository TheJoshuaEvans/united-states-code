{"tag":"section","attrib":{"id":"id6b093702-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s37"},"text":null,"children":[{"tag":"num","attrib":{"value":"37"},"text":"§ 37.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nodaway River, Missouri","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nodaway River, in the counties of Andrew, Holt, and Nodaway, in the State of Missouri, is declared to be not a navigable water of the United States within the meaning of the laws enacted by Congress for the preservation and protection of such waters.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The right to alter, amend, or repeal this section is expressly reserved.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b093703-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1910-02-15/ch32"},"text":"Feb. 15, 1910, ch. 32","children":[],"tail":", §§ 1, 2, "},{"tag":"ref","attrib":{"href":"/us/stat/36/194"},"text":"36 Stat. 194","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
