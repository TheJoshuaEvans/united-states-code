{"tag":"section","attrib":{"id":"id6c54a2e9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2321b"},"text":"§ 2321b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expediting hydropower at Corps of Engineers facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c54a2ea-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress declares that it is the policy of the United States that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c54a2eb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of non-Federal hydroelectric power at Corps of Engineers water resources development projects, including locks and dams, shall be given priority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c54a2ec-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Corps of Engineers approval of non-Federal hydroelectric power at Corps of Engineers water resources development projects, including permitting required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s408"},"text":"section 408 of this title","children":[],"tail":", shall be completed by the Corps of Engineers in a timely and consistent manner; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c54a2ed-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approval of hydropower at Corps of Engineers water resources development projects shall in no way diminish the other priorities and missions of the Corps of Engineers, including authorized project purposes and habitat and environmental protection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c54a2ee-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of policy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c54a2ef-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the policy described in subsection (a) is implemented nationwide in an efficient, consistent, and coordinated manner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c54a2f0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assess opportunities—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c54a2f1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the development of hydroelectric power at existing water resources development projects of the Corps of Engineers with hydroelectric facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c54a2f2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop new hydroelectric power at existing nonpowered water resources development projects of the Corps of Engineers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c54a2f3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", and biennially thereafter, the Secretary shall submit to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives and make publicly available a report that, at a minimum, shall include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c54a2f4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of initiatives carried out by the Secretary to encourage the development of hydroelectric power by non-Federal entities at Corps of Engineers water resources development projects and to meet the requirements of subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c54a2f5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of all new hydroelectric power activities by non-Federal entities approved at Corps of Engineers water resources development projects in that fiscal year, including the length of time the Secretary needed to approve those activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c54a2f6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the status of each pending application from non-Federal entities for approval to develop hydroelectric power at Corps of Engineers water resources development projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c54a2f7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321b/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any benefits or impacts to the environment, recreation, or other uses associated with Corps of Engineers water resources development projects at which non-Federal entities have developed hydroelectric power in the previous fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c54a2f8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321b/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total annual amount of payments or other services provided to the Corps of Engineers, the Treasury, and any other Federal agency as a result of approved non-Federal hydropower projects at Corps of Engineers water resources development projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c54a2f9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reviewing hydropower at Corps of Engineers facilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c54a2fa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of eligible non-Federal interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “eligible non-Federal interest” means a non-Federal interest that owns or operates an existing non-Federal hydropower facility at a Corps of Engineers water resources development project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c54a2fb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c54a2fc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321b/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the written request of an eligible non-Federal interest, the Secretary shall conduct an evaluation to consider operational changes at the applicable project to facilitate production of non-Federal hydropower, consistent with authorized project purposes. The Secretary shall solicit input from interested stakeholders as part of the evaluation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c54a2fd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321b/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the date on which the Secretary receives a written request under subparagraph (A), the Secretary shall provide to the non-Federal interest a written response to inform the non-Federal interest—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c54a2fe-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321b/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the Secretary has approved the request to conduct an evaluation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c54a2ff-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321b/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of any additional information necessary for the Secretary to approve the request to conduct an evaluation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c54a300-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operational changes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An operational change referred to in paragraph (2)(A) may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c54a301-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321b/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" changes to seasonal pool levels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c54a302-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321b/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modifying releases from the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c54a303-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321b/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other changes included in the written request submitted under that paragraph that enhance the usage of the project to facilitate production of non-Federal hydropower, consistent with authorized project purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c54a304-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321b/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The eligible non-Federal interest shall pay 100 percent of the costs associated with an evaluation under this subsection, including the costs to prepare the report under paragraph (6).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c54a305-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321b/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall complete an evaluation under this subsection by the date that is not later than 1 year after the date on which the Secretary begins the evaluation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c54a306-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321b/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On completion of an evaluation under this subsection, the Secretary shall submit to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a report on the effects of the operational changes proposed by the non-Federal interest and examined in the evaluation on the authorized purposes of the project, including a description of any negative impacts of the proposed operational changes on the authorized purposes of the project, or on any Federal project located in the same basin.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c54a307-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321b/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings provision","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c54a308-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321b/d/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affects the authorized purposes of a Corps of Engineers water resources development project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c54a309-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321b/d/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affects existing authorities of the Corps of Engineers, including authorities with respect to navigation, flood damage reduction, environmental protection and restoration, water supply and conservation, and other related purposes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c54a30a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321b/d/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorizes the Secretary to make any operational changes to a Corps of Engineers water resources development project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c54a30b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/tI/s1008"},"text":"Pub. L. 113–121, title I, § 1008","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1215"},"text":"128 Stat. 1215","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/tI/s146"},"text":"Pub. L. 116–260, div. AA, title I, § 146","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2655"},"text":"134 Stat. 2655","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dH/tLXXXI/s8123"},"text":"Pub. L. 117–263, div. H, title LXXXI, § 8123","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3714"},"text":"136 Stat. 3714","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c54a30c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c54a30d-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c54a30e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Reform and Development Act of 2014, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c54a30f-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s8123/3"},"text":"Pub. L. 117–263, § 8123(3)","children":[],"tail":", added subsec. (b). Former subsec. (b) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s8123/1"},"text":"Pub. L. 117–263, § 8123(1)","children":[],"tail":", inserted “and to meet the requirements of subsection (b)” after “projects”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s8123/2"},"text":"Pub. L. 117–263, § 8123(2)","children":[],"tail":", redesignated subsecs. (b) and (c) as (c) and (d), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s146/1"},"text":"Pub. L. 116–260, § 146(1)","children":[],"tail":", substituted “water resources development” for “civil works” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s146/2"},"text":"Pub. L. 116–260, § 146(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c54a310-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c54a311-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s2"},"text":"section 2 of Pub. L. 113–121","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
