{"tag":"section","attrib":{"id":"id6b1e93c3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s405"},"text":null,"children":[{"tag":"num","attrib":{"value":"405"},"text":"§ 405.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and modification of harbor lines on Potomac and Anacostia Rivers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s404"},"text":"section 404 of this title","children":[],"tail":" are made applicable to the Potomac and Anacostia Rivers, and after "},{"tag":"date","attrib":{"date":"1912-07-25"},"text":"July 25, 1912","children":[],"tail":", harbor lines in the District of Columbia, or elsewhere on said rivers, shall be established or modified as therein provided."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b1e93c4-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1912-07-25/ch253/s1"},"text":"July 25, 1912, ch. 253, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/206"},"text":"37 Stat. 206","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b1e93c5-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b1e93c6-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b1e93c7-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from part of section 1 of act ","children":[{"tag":"date","attrib":{"date":"1912-07-25"},"text":"July 25, 1912","ch