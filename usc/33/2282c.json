{"tag":"section","attrib":{"id":"id6c464abe-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2282c"},"text":"§ 2282c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vertical integration and acceleration of studies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c464abf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent practicable, a feasibility study initiated by the Secretary, after ","children":[{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2282/a"},"text":"section 2282(a) of this title","children":[],"tail":" shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c464ac0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" result in the completion of a final feasibility report not later than 4 years after the date on which the Secretary determines the Federal interest for purposes of the report pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2282/b"},"text":"section 2282(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c464ac1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a maximum total cost of $5,000,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c464ac2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that personnel from the district, division, and headquarters levels of the Corps of Engineers concurrently conduct the review required under that section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c464ac3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary determines that a feasibility study described in subsection (a) will not be conducted in accordance with subsection (a), the Secretary, not later than 30 days after the date of making the determination, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c464ac4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare an updated feasibility study schedule and cost estimate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c464ac5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the non-Federal feasibility cost-sharing partner that the feasibility study has been delayed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c464ac6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide written notice to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives as to the reasons the requirements of subsection (a) are not attainable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c464ac7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c464ac8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may extend the timeline of a study by a period not to exceed 3 years, if the Secretary determines that the feasibility study is too complex to comply with the requirements of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c464ac9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making a determination that a study is too complex to comply with the requirements of subsection (a), the Secretary shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c464aca-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282c/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type, size, location, scope, and overall cost of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c464acb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282c/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the project will use any innovative design or construction techniques;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c464acc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282c/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the project will require significant action by other Federal, State, or local agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c464acd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282c/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether there is significant public dispute as to the nature or effects of the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c464ace-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282c/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether there is significant public dispute as to the economic or environmental costs or benefits of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c464acf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282c/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each time the Secretary makes a determination under this subsection, the Secretary shall provide written notice to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives as to the results of that determination, including an identification of the specific 1 or more factors used in making the determination that the project is complex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c464ad0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reviews","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the date of the initiation of a study described in subsection (a) for a project, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c464ad1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take all steps necessary to initiate the process for completing federally mandated reviews that the Secretary is required to complete as part of the study, including the environmental review process under section 1005;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c464ad2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" convene a meeting of all Federal, tribal, and State agencies identified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2348/e"},"text":"section 2348(e) of this title","children":[],"tail":" that may be required by law to conduct or issue a review, analysis, or opinion on or to make a determination concerning a permit or license for the study; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c464ad3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282c/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take all steps necessary to provide information that will enable required reviews and analyses related to the project to be conducted by other agencies in a thorough and timely manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c464ad4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", the Secretary shall submit to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives and make publicly available a report that describes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c464ad5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282c/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of the implementation of the planning process under this section, including the number of participating projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c464ad6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282c/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of project delivery schedules, including a description of any delays on those studies participating in the planning process under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c464ad7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282c/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations for additional authority necessary to support efforts to expedite the feasibility study process for water resource projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c464ad8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282c/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 4 years after ","children":[{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", the Secretary shall submit to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives and make publicly available a report that describes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c464ad9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282c/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of the implementation of this section, including a description of each feasibility study subject to the requirements of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c464ada-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282c/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of time taken to complete each feasibility study; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c464adb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282c/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations for additional authority necessary to support efforts to expedite the feasibility study process, including an analysis of whether the limitation established by subsection (a)(2) needs to be adjusted to address the impacts of inflation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c464adc-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/tI/s1001"},"text":"Pub. L. 113–121, title I, § 1001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1196"},"text":"128 Stat. 1196","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/270/tI/s1330/b"},"text":"Pub. L. 115–270, title I, § 1330(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3827"},"text":"132 Stat. 3827","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/tIII/s360/c"},"text":"Pub. L. 116–260, div. AA, title III, § 360(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2733"},"text":"134 Stat. 2733","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dA/tI/s1103/a"},"text":"Pub. L. 118–272, div. A, title I, § 1103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3000"},"text":"138 Stat. 3000","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c464add-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c464ade-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c464adf-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 1005, referred to in subsec. (d)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s1005"},"text":"section 1005 of Pub. L. 113–121","children":[],"tail":", which enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2349"},"text":"section 2349 of this title","children":[],"tail":" and amended generally "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2348"},"text":"section 2348 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c464ae0-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Reform and Development Act of 2014, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c464ae1-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1103/a/1"},"text":"Pub. L. 118–272, § 1103(a)(1)","children":[],"tail":", substituted “4 years after the date on which the Secretary determines the Federal interest for purposes of the report pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2282/b"},"text":"section 2282(b) of this title","children":[],"tail":"” for “3 years after the date of initiation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1103/a/2"},"text":"Pub. L. 118–272, § 1103(a)(2)","children":[],"tail":", added par. (2) and struck out former par. (2) which read as follows: “have a maximum Federal cost of $3,000,000; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s360/c/2"},"text":"Pub. L. 116–260, § 360(c)(2)","children":[],"tail":", redesignated subsec. (d) as (c) and struck out former subsec. (c). Prior to amendment, text of subsec. (c) read as follows: “A feasibility study for which the Secretary has issued a determination under subsection (b) is not authorized after the last day of the 1-year period beginning on the date of the determination if the Secretary has not completed the study on or before such last day.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s360/c/2"},"text":"Pub. L. 116–260, § 360(c)(2)","children":[],"tail":", redesignated subsec. (e) as (d). Former subsec. (d) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s360/c/1/A"},"text":"Pub. L. 116–260, § 360(c)(1)(A)","children":[],"tail":", (B), substituted “The Secretary” for “Notwithstanding the requirements of subsection (c), the Secretary” and “subsection (a)” for “subsections (a) and (c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s360/c/1/B"},"text":"Pub. L. 116–260, § 360(c)(1)(B)","children":[],"tail":", substituted “subsection (a)” for “subsections (a) and (c)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s360/c/1/C"},"text":"Pub. L. 116–260, § 360(c)(1)(C)","children":[],"tail":", struck out par. (4). Text read as follows: “The Secretary shall not extend the timeline for a feasibility study for a period of more than 10 years, and any feasibility study that is not completed before that date shall no longer be authorized.”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e) to (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s360/c/2"},"text":"Pub. L. 116–260, § 360(c)(2)","children":[],"tail":", redesignated subsecs. (f) and (g) as (e) and (f), respectively. Former subsec. (e) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270"},"text":"Pub. L. 115–270","children":[],"tail":" substituted “10 years” for “7 years”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c464ae2-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"id6c464ae3-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Clause","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/dA/tI/s1103/b"},"text":"Pub. L. 118–272, div. A, title I, § 1103(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3000"},"text":"138 Stat. 3000","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/272/dA/tI/s1103/b"},"text":"“Nothing in the amendments made by subsection (a) [amending this section] shall be construed to affect a feasibility study that was initiated prior to the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c464ae4-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s2"},"text":"section 2 of Pub. L. 113–121","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
