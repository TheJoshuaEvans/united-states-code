{"tag":"section","attrib":{"id":"id6b5ef800-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701h–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"701h–4"},"text":"§ 701h–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of funds for harbor dredging","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s701h"},"text":"section 701h of this title","children":[],"tail":", to accept and expend funds contributed by a State or other non-Federal interest—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b5ef801-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701h–4/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to dredge a non-Federal harbor or channel, or a marina or berthing area located adjacent to, or accessible by, such harbor or channel; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b5ef802-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701h–4/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide technical assistance related to the planning and design of dredging activities described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b5ef803-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/tI/s144"},"text":"Pub. L. 116–260, div. AA, title I, § 144","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2653"},"text":"134 Stat. 2653","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b5ef804-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b5ef805-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b5ef806-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/s2"},"text":"section 2 of div. AA of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
