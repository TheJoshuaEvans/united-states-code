{"tag":"section","attrib":{"id":"id6c62fafb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2503"},"text":null,"children":[{"tag":"num","attrib":{"value":"2503"},"text":"§ 2503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"After 6 months after ","children":[{"tag":"date","attrib":{"date":"1988-11-18"},"text":"November 18, 1988","children":[],"tail":", no public vessel shall dispose of potentially infectious medical waste into ocean waters unless—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c62fafc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2503/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c62fafd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2503/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the health or safety of individuals on board the vessel is threatened; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c62fafe-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2503/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during time of war or a declared national emergency;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62faff-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2503/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the waste is disposed of beyond 50 nautical miles from the nearest land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62fb00-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2503/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c62fb01-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2503/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a public vessel which is not a submersible, the waste is sterilized, properly packaged, and sufficiently weighted to prevent the waste from coming ashore after disposal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c62fb02-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2503/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a public vessel which is a submersible, the waste is properly packaged and sufficiently weighted to prevent the waste from coming ashore after disposal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c62fb03-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/688/tIII/s3104"},"text":"Pub. L. 100–688, title III, § 3104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4152"},"text":"102 Stat. 4152","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
