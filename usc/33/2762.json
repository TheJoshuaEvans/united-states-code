{"tag":"section","attrib":{"id":"id6c712b41-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2762"},"text":null,"children":[{"tag":"num","attrib":{"value":"2762"},"text":"§ 2762.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submerged oil program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c712b42-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2762/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c712b43-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2762/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Under Secretary of Commerce for Oceans and Atmosphere, in conjunction with the Commandant of the Coast Guard, shall establish a program to detect, monitor, and evaluate the environmental effects of submerged oil in the Delaware River and Bay region. The program shall include the following elements:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c712b44-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2762/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The development of methods to remove, disperse, or otherwise diminish the persistence of submerged oil.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c712b45-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2762/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The development of improved models and capacities for predicting the environmental fate, transport, and effects of submerged oil.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c712b46-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2762/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The development of techniques to detect and monitor submerged oil.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c712b47-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2762/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":", the Secretary of Commerce shall submit to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a report on the activities carried out under this subsection and activities proposed to be carried out under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c712b48-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2762/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration project","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c712b49-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2762/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal of submerged oil","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commandant of the Coast Guard, in conjunction with the Under Secretary of Commerce for Oceans and Atmosphere, shall conduct a demonstration project for the purpose of developing and demonstrating technologies and management practices to remove submerged oil from the Delaware River and other navigable waters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c712b4a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2762/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Commandant of the Coast Guard $2,000,000 for each of fiscal years 2006 through 2010 to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c712b4b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380/tVII/s7002"},"text":"Pub. L. 101–380, title VII, § 7002","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/241/tVI/s605/a/2"},"text":"Pub. L. 109–241, title VI, § 605(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/555"},"text":"120 Stat. 555","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
