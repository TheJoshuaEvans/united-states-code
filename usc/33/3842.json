{"tag":"section","attrib":{"id":"id6c8ddab0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3842"},"text":null,"children":[{"tag":"num","attrib":{"value":"3842"},"text":"§ 3842.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigations and inspections by Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c8ddab1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3842/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may conduct investigations and inspections regarding a vessel’s compliance with this chapter or the Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c8ddab2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3842/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations; subpoenas","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c8ddab3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3842/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any investigation under this section, the Secretary may issue a subpoena to require the attendance of a witness or the production of documents or other evidence if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c8ddab4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3842/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before the issuance of the subpoena, the Secretary requests a determination by the Attorney General of the United States as to whether the subpoena will interfere with a criminal investigation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c8ddab5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3842/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Attorney General—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c8ddab6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3842/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determines that the subpoena will not interfere with a criminal investigation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c8ddab7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3842/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fails to make a determination under clause (i) before the date that is 30 days after the date on which the Secretary makes a request under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8ddab8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3842/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of refusal to obey a subpoena issued to any person under this subsection, the Secretary may request the Attorney General to invoke the aid of the appropriate district court of the United States to compel compliance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c8ddab9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3842/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Further action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On completion of an investigation, the Secretary may take whatever further action the Secretary considers appropriate under the Convention or this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c8ddaba-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3842/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may cooperate with other parties to the Convention in the detection of violations and in enforcement of the Convention. Nothing in this section affects or alters requirements under any other laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c8ddabb-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/tX/s1032"},"text":"Pub. L. 111–281, title X, § 1032","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3028"},"text":"124 Stat. 3028","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c8ddabc-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c8ddabd-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c8ddabe-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a) and (c), was in the original “this title”, meaning title X of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281"},"text":"Pub. L. 111–281","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3023"},"text":"124 Stat. 3023","children":[],"tail":", which enacted this chapter and repealed chapter 37 (§ 2401 et seq.) of this title. For complete classification of title X to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
