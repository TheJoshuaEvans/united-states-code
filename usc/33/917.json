{"tag":"section","attrib":{"id":"id6b878ec3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s917"},"text":null,"children":[{"tag":"num","attrib":{"value":"917"},"text":"§ 917.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lien against compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Where a trust fund which complies with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s186/c"},"text":"section 186(c) of title 29","children":[],"tail":" established pursuant to a collective-bargaining agreement in effect between an employer and an employee covered under this chapter has paid disability benefits to an employee which the employee is legally obligated to repay by reason of his entitlement to compensation under this chapter or under a settlement, the Secretary shall authorize a lien on such compensation in favor of the trust fund for the amount of such payments."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b878ec4-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-03-04/ch509/s17"},"text":"Mar. 4, 1927, ch. 509, § 17","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1434"},"text":"44 Stat. 1434","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch685/s8"},"text":"June 25, 1938, ch. 685, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1167"},"text":"52 Stat. 1167","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/576/s20/b"},"text":"Pub. L. 92–576, § 20(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1264"},"text":"86 Stat. 1264","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/598/tIII/s324"},"text":"Pub. L. 95–598, title III, § 324","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2679"},"text":"92 Stat. 2679","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/426/s14"},"text":"Pub. L. 98–426, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-09-28"},"text":"Sept. 28, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1649"},"text":"98 Stat. 1649","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b878ec5-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b878ec6-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b878ec7-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/426"},"text":"Pub. L. 98–426","children":[],"tail":" struck out “(b)” before “Where a trust fund which complies”, substituted “covered under this chapter” for “entitled to compensation under this chapter”, and substituted “this chapter or under a settlement, the Secretary shall authorize” for “this chapter, the Secretary may authorize”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":" repealed provision for lien of person entitled to compensation without limit of amount against assets of carrier or employer and for preference and priority in distribution of assets of such carrier or employer, or both upon insolvency, bankruptcy, or reorganization in bankruptcy proceedings of the carrier or employer, or both."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/576"},"text":"Pub. L. 92–576","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1938—Act ","children":[{"tag":"date","attrib":{"date":"1938-06-25"},"text":"June 25, 1938","children":[],"tail":", amended section generally. Prior to amendment, section read as follows: “Compensation shall have the same preference of lien against the assets of the carrier or employer without limit of amount as is now or may hereafter be allowed by law to the claimant for unpaid wages or otherwise”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b878ec8-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6b878ec9-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/426"},"text":"Pub. L. 98–426","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1984-09-28"},"text":"Sept. 28, 1984","children":[],"tail":", and applicable both with respect to claims filed after such date and to claims pending on such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/426/s28/a"},"text":"section 28(a) of Pub. L. 98–426","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s901"},"text":"section 901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6b878eca-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1979-10-01"},"text":"Oct. 1, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/598/s402/a"},"text":"section 402(a) of Pub. L. 95–598","children":[],"tail":", set out as an Effective Date note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of Title 11","children":[],"tail":", Bankruptcy."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6b878ecb-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1972 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/576"},"text":"Pub. L. 92–576","children":[],"tail":" effective 30 days after "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/92/576/s22"},"text":"section 22 of Pub. L. 92–576","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s902"},"text":"section 902 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
