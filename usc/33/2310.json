{"tag":"section","attrib":{"id":"id6c4fe78e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2310"},"text":null,"children":[{"tag":"num","attrib":{"value":"2310"},"text":"§ 2310.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing for Territories and Indian tribes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c4fe78f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2310/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall waive local cost-sharing requirements up to $200,000 for all studies and projects—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c4fe790-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2310/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in American Samoa, Guam, the Northern Mariana Islands, the Virgin Islands, Puerto Rico, and the Trust Territory of the Pacific Islands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c4fe791-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2310/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any Indian tribe or tribal organization (as those terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c4fe792-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2310/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for any organization that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c4fe793-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2310/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is composed primarily of people who are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c4fe794-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2310/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recognized and defined under Federal law as indigenous people of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c4fe795-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2310/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from a specific community; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c4fe796-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2310/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assists in the social, cultural, and educational development of such people in that community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c4fe797-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2310/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inflation adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall adjust the dollar amount specified in subsection (a) on an annual basis for inflation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c4fe798-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2310/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “study” includes a watershed assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c4fe799-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2310/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall apply the waiver amount described in subsection (a) to reduce only the non-Federal share of study and project costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c4fe79a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662/tXI/s1156"},"text":"Pub. L. 99–662, title XI, § 1156","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4256"},"text":"100 Stat. 4256","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/121/tI/s1032"},"text":"Pub. L. 113–121, title I, § 1032","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1233"},"text":"128 Stat. 1233","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tI/s1119"},"text":"Pub. L. 114–322, title I, § 1119","children":[],"tail":", "},{"tag":"date","attrib":{"date":"