{"tag":"section","attrib":{"id":"id6c0f83b0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1478"},"text":null,"children":[{"tag":"num","attrib":{"value":"1478"},"text":"§ 1478.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal, flag state, and foreign state considerations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In the direction and conduct of measures under this chapter the Secretary shall use his best endeavors to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c0f83b1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1478/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assure the avoidance of risk to human life;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0f83b2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1478/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" render all possible aid to distressed persons, including facilitating repatriation of ships’ crews; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0f83b3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1478/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not unnecessarily interfere with rights and interests of others, including the flag state of any ship involved, other foreign states threatened by damage, and persons otherwise concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c0f83b4-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/248/s9"},"text":"Pub. L. 93–248, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-02-05"},"text":"Feb. 5, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/9"},"text":"88 Stat. 9","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
