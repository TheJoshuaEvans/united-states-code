{"tag":"section","attrib":{"id":"id6b5a3d25-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"701b–8"},"text":"§ 701b–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of report by Chief of Engineers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It is declared to be the policy of the Congress that the following provisions shall be observed:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"No project or any modification not authorized, of a project for flood control or rivers and harbors, shall be authorized by the Congress unless a report for such project or modification has been previously submitted by the Chief of Engineers, United States Army, in conformity with existing law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b5a3d26-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-09-03/ch1264"},"text":"Sept. 3, 1954, ch. 1264","children":[],"tail":", title II, § 202, "},{"tag":"ref","attrib":{"href":"/us/stat/68/1256"},"text":"68 Stat. 1256","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b5a3d27-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b5a3d28-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b5a3d29-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section comprises last two paragraphs of section 202 of act ","children":[{"tag":"date","attrib":{"date":"1954-09-03"},"text":"Sept. 3, 1954","children":[],"tail":". First paragraph of section 202 is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s701–1"},"text":"section 701–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6b5a3d2a-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in the following prior acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1950-05-17/ch188"},"text":"May 17, 1950, ch. 188","children":[],"tail":", title II, § 202, "},{"tag":"ref","attrib":{"href":"/us/stat/64/170"},"text":"64 Stat. 170","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch771"},"text":"June 30, 1948, ch. 771","children":[],"tail":", title II, § 202, "},{"tag":"ref","attrib":{"href":"/us/stat/62/1175"},"text":"62 Stat. 1175","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1946-07-24/ch596/s2"},"text":"July 24, 1946, ch. 596, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/641"},"text":"60 Stat. 641","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
