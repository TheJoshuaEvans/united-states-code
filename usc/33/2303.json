{"tag":"section","attrib":{"id":"id6c4d770f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2303"},"text":null,"children":[{"tag":"num","attrib":{"value":"2303"},"text":"§ 2303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Historical properties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to preserve, restore, and maintain those historic properties located on water resource development project lands under the jurisdiction of the Department of the Army if such properties have been entered into the National Register of Historic Places.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6c4d7710-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662/tIX/s943"},"text":"Pub. L. 99–662, title IX, § 943","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4200"},"text":"100 Stat. 4200","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
