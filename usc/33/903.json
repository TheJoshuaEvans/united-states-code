{"tag":"section","attrib":{"id":"id6b7df1c0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s903"},"text":null,"children":[{"tag":"num","attrib":{"value":"903"},"text":"§ 903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coverage","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b7df1c1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disability or death; injuries occurring upon navigable waters of United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this section, compensation shall be payable under this chapter in respect of disability or death of an employee, but only if the disability or death results from an injury occurring upon the navigable waters of the United States (including any adjoining pier, wharf, dry dock, terminal, building way, marine railway, or other adjoining area customarily used by an employer in loading, unloading, repairing, dismantling, or building a vessel).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b7df1c2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Governmental officers and employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No compensation shall be payable in respect of the disability or death of an officer or employee of the United States, or any agency thereof, or of any State or foreign government, or any subdivision thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b7df1c3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s903/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intoxication; willful intention to kill","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No compensation shall be payable if the injury was occasioned solely by the intoxication of the employee or by the willful intention of the employee to injure or kill himself or another.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b7df1c4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s903/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small vessels","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b7df1c5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s903/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No compensation shall be payable to an employee employed at a facility of an employer if, as certified by the Secretary, the facility is engaged in the business of building, repairing, or dismantling exclusively small vessels (as defined in paragraph (3) of this subsection), unless the injury occurs while upon the navigable waters of the United States or while upon any adjoining pier, wharf, dock, facility over land for launching vessels, or facility over land for hauling, lifting, or drydocking vessels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7df1c6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s903/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding paragraph (1), compensation shall be payable to an employee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b7df1c7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s903/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is employed at a facility which is used in the business of building, repairing, or dismantling small vessels if such facility receives Federal maritime subsidies; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b7df1c8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s903/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the employee is not subject to coverage under a State workers’ compensation law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7df1c9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s903/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this subsection, a small vessel means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b7df1ca-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s903/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a commercial barge which is under 900 lightship displacement tons; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b7df1cb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s903/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a commercial tugboat, towboat, crew boat, supply boat, fishing vessel, or other work vessel which is under 1,600 tons gross as measured under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of title 46","children":[],"tail":", or an alternate tonnage measured under section 14302 of that title as prescribed by the Secretary under section 14104 of that title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b7df1cc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s903/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit for benefits paid under other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, any amounts paid to an employee for the same injury, disability, or death for which benefits are claimed under this chapter pursuant to any other workers’ compensation law or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s30104"},"text":"section 30104 of title 46","children":[],"tail":" shall be credited against any liability imposed by this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b7df1cd-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-03-04/ch509/s3"},"text":"Mar. 4, 1927, ch. 509, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1426"},"text":"44 Stat. 1426","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/576"},"text":"Pub. L. 92–576","children":[],"tail":", §§ 2(c), 21, "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1251"},"text":"86 Stat. 1251","children":[],"tail":", 1265; "},{"tag":"ref","attrib":{"href":"/us/pl/98/426/s3"},"text":"Pub. L. 98–426, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-09-28"},"text":"Sept. 28, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1640"},"text":"98 Stat. 1640","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/324/tVII/s703"},"text":"Pub. L. 104–324, title VII, § 703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3933"},"text":"110 Stat. 3933","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b7df1ce-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b7df1cf-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b7df1d0-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (e), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s30104"},"text":"section 30104 of title 46","children":[],"tail":"” substituted for “"},{"tag":"ref","attrib":{"href":"/us/act/1915-03-04/s20"},"text":"section 20 of the Act of March 4, 1915","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/38/1185"},"text":"38 Stat. 1185","children":[],"tail":", chapter 153; "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s688"},"text":"46 U.S.C. 688","children":[],"tail":") (relating to recovery for injury to or death of seamen)” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s18/c"},"text":"Pub. L. 109–304, § 18(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1709"},"text":"120 Stat. 1709","children":[],"tail":", which Act enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s30104"},"text":"section 30104 of Title 46","children":[],"tail":", Shipping."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b7df1d1-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (d)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324"},"text":"Pub. L. 104–324","children":[],"tail":" inserted before period at end “as measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of title 46","children":[],"tail":", or an alternate tonnage measured under section 14302 of that title as prescribed by the Secretary under section 14104 of that title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/426/s3/a"},"text":"Pub. L. 98–426, § 3(a)","children":[],"tail":", inserted introductory language relating to exceptions provided for elsewhere in this section, redesignated existing par. (1) as subsec. (b), and struck out existing par. (2) which had excepted from coverage masters and crew members or persons engaged by such masters or crew members to load, unload, or repair vessels under 18 tons net."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/426/s3/a"},"text":"Pub. L. 98–426, § 3(a)","children":[],"tail":", redesignated as subsec. (b) provisions formerly set out in subsec. (a)(2). Former subsec. (b) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/426/s3/a"},"text":"Pub. L. 98–426, § 3(a)","children":[],"tail":", (b), redesignated former subsec. (b) as (c) and added subsecs. (d) and (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/576/s2/c"},"text":"Pub. L. 92–576, § 2(c)","children":[],"tail":", substituted provisions respecting coverage of injuries occurring upon navigable waters of the United States, including any adjoining pier, wharf, dry dock, terminal, building way, marine railway, or other adjoining area customarily used by an employer in loading, unloading, repairing, or building a vessel, for prior provisions respecting coverage of such injuries upon navigable waters and if recovery for the disability or death through workmen’s compensation proceedings may not validly be provided by State law."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/576/s21"},"text":"Pub. L. 92–576, § 21","children":[],"tail":", substituted “or” for “nor” before “any person engaged by the master”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b7df1d2-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6b7df1d3-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/426/s3/a"},"text":"section 3(a) of Pub. L. 98–426","children":[],"tail":" applicable with respect to any injury after "},{"tag":"date","attrib":{"date":"1984-09-28"},"text":"Sept. 28, 1984","children":[],"tail":", and amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/98/426/s3/b"},"text":"section 3(b) of Pub. L. 98–426","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1984-09-28"},"text":"Sept. 28, 1984","children":[],"tail":", and applicable both with respect to claims filed after "},{"tag":"date","attrib":{"date":"1984-09-28"},"text":"Sept. 28, 1984","children":[],"tail":", and to claims pending on that date, see section 28(a), (c) of "},{"tag":"ref","attrib":{"href":"/us/pl/98/426"},"text":"Pub. L. 98–426","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s901"},"text":"section 901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6b7df1d4-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1972 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/576"},"text":"Pub. L. 92–576","children":[],"tail":" effective 30 days after "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/92/576/s22"},"text":"section 22 of Pub. L. 92–576","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s902"},"text":"section 902 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b7df1d5-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"District of Columbia","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Longshoremen’s and Harbor Workers’ Compensation Act [this chapter] was made applicable in respect to the injury or death of an employee of an employer carrying on any employment in the District of Columbia, by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1928-05-17/ch612"},"text":"act May 17, 1928, ch. 612","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/600"},"text":"45 Stat. 600","children":[],"tail":", as amended."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
