{"tag":"section","attrib":{"id":"id6c4d76f6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2298"},"text":null,"children":[{"tag":"num","attrib":{"value":"2298"},"text":"§ 2298.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Impact of proposed projects on existing recreation facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any report describing a project having recreation benefits that is submitted after ","children":[{"tag":"date","attrib":{"date":"1986-11-17"},"text":"November 17, 1986","children":[],"tail":", to the Committee on Environment and Public Works of the Senate or the Committee on Public Works and Transportation of the House of Representatives by the Secretary, or by the Secretary of Agriculture under authority of the Watershed Protection and Flood Protection Act ("},{"tag":"ref","attrib":{"href":"/us/stat/68/666"},"text":"68 Stat. 666","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1001"},"text":"16 U.S.C. 1001","children":[],"tail":" et seq.), shall describe the usage of other, similar public recreational facilities within the general area of the project, and the anticipated impact of the proposed project on the usage of such existing recreational facilities."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6c4d76f7-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662/tIX/s928"},"text":"Pub. L. 99–662, title IX, § 928","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4195"},"text":"100 Stat. 4195","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c4d76f8-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c4d76f9-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c4d76fa-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Watershed Protection and Flood Prevention Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-04/ch656"},"text":"act Aug. 4, 1954, ch. 656","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/666"},"text":"68 Stat. 666","children":[],"tail":", which is classified principally to chapter 18 (§ 1001 et seq.) of Title 16, Conservation. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1001"},"text":"section 1001 of Title 16","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c4d76fb-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id6c4d76fc-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Public Works and Transportation of House of Representatives treated as referring to Committee on Transportation and Infrastructure of House of Representatives by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/14/s1/a"},"text":"section 1(a) of Pub. L. 104–14","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s21"},"text":"section 21 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
