{"tag":"section","attrib":{"id":"id6c760dfc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3007"},"text":null,"children":[{"tag":"num","attrib":{"value":"3007"},"text":"§ 3007.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training and physical fitness","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c760dfd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3007/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may take such measures as may be necessary to ensure that officers are prepared to carry out their duties in the commissioned officer corps of the Administration and proficient in the skills necessary to carry out such duties. Such measures may include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c760dfe-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3007/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Carrying out training programs and correspondence courses, including establishing and operating a basic officer training program to provide initial indoctrination and maritime vocational training for officer candidates as well as refresher training, mid-career training, aviation training, and such other training as the Secretary considers necessary for officer development and proficiency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760dff-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3007/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing officers and officer candidates with educational materials.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760e00-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3007/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Acquiring such equipment as may be necessary for training and instructional purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c760e01-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3007/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Physical fitness","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that officers maintain a high physical state of readiness by establishing standards of physical fitness for officers that are substantially equivalent to those prescribed for officers in the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c760e02-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372/tII/s217"},"text":"Pub. L. 107–372, title II, § 217","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/259/tI/s104/a"},"text":"Pub. L. 116–259, title I, § 104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-23"},"text":"Dec. 23, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1156"},"text":"134 Stat. 1156","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
