{"tag":"section","attrib":{"id":"id6b426f08-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s553"},"text":null,"children":[{"tag":"num","attrib":{"value":"553"},"text":"§ 553.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Freight statistics","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In the collection of statistics relating to traffic, the Corps of Engineers is directed to adopt a uniform system of classification for freight, and upon rivers or inland waterways to collate ton-mileage statistics as far as practicable.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b426f09-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1912-07-25/ch253/s1"},"text":"July 25, 1912, ch. 253, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/223"},"text":"37 Stat. 223","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b426f0a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b426f0b-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b426f0c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from part of section 1 of act ","children":[{"tag":"date","attrib":{"date":"1912-07-25"},"text":"July 25, 1912","children":[],"tail":", popularly known as the “Rivers and Harbors Appropriation Act of 1912”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
