{"tag":"section","attrib":{"id":"id6c785726-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3045"},"text":null,"children":[{"tag":"num","attrib":{"value":"3045"},"text":"§ 3045.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation of retired pay","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c785727-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3045/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers first becoming members before ","children":[{"tag":"date","attrib":{"date":"1980-09-08"},"text":"September 8, 1980","children":[],"tail":null}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each officer on the retired list who first became a member of a uniformed service before ","children":[{"tag":"date","attrib":{"date":"1980-09-08"},"text":"September 8, 1980","children":[],"tail":", shall receive retired pay at the rate determined by multiplying—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c785728-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3045/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the retired pay base determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1406/g"},"text":"section 1406(g) of title 10","children":[],"tail":"; by"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c785729-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3045/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the retired pay multiplier determined under section 1409 of such title for the number of years of service that may be credited to the officer under section 1405 of such title as if the officer’s service were service as a member of the Armed Forces.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The retired pay so computed may not exceed 75 percent of the retired pay base.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c78572a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3045/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers first becoming members on or after ","children":[{"tag":"date","attrib":{"date":"1980-09-08"},"text":"September 8, 1980","children":[],"tail":null}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each officer on the retired list who first became a member of a uniformed service on or after ","children":[{"tag":"date","attrib":{"date":"1980-09-08"},"text":"September 8, 1980","children":[],"tail":", shall receive retired pay at the rate determined by multiplying—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c78572b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3045/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the retired pay base determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1407"},"text":"section 1407 of title 10","children":[],"tail":"; by"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c78572c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3045/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the retired pay multiplier determined under section 1409 of such title for the number of years of service that may be credited to the officer under section 1405 of such title as if the officer’s service were service as a member of the Armed Forces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c78572d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3045/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of full and fractional parts of months in computing years of service","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c78572e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3045/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In computing the number of years of service of an officer for the purposes of subsection (a)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c78572f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3045/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each full month of service that is in addition to the number of full years of service creditable to the officer shall be credited as ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":"⁄"},{"tag":"sub","attrib":{},"text":"12","children":[],"tail":" of a year; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c785730-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3045/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any remaining fractional part of a month shall be disregarded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c785731-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3045/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rounding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Retired pay computed under this section, if not a multiple of $1, shall be rounded to the next lower multiple of $1.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c785732-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372/tII/s245"},"text":"Pub. L. 107–372, title II, § 245","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3089"},"text":"116 Stat. 3089","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tVI/s631/c/3"},"text":"Pub. L. 114–92, div. A, title VI, § 631(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/844"},"text":"129 Stat. 844","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c785733-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c785734-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6c785735-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in section 853","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/107/372"},"text":"Pub. L. 107–372","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c785736-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Pub. L. 114–92","children":[],"tail":" amended par. (2) generally. Prior to amendment, par. (2) read as follows: “2½ percent of the number of years of service that may be credited to the officer under section 1405 of such title as if the officer’s service were service as a member of the Armed Forces.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c785737-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6c785738-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment; Implementation","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Pub. L. 114–92","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2018-01-01"},"text":"Jan. 1, 2018","children":[],"tail":", with certain implementation requirements, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/s635"},"text":"section 635 of Pub. L. 114–92","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8432"},"text":"section 8432 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
