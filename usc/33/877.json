/pl/92/310"},"text":"Pub. L. 92–310","children":[],"tail":" struck out provisions which required chiefs of parties to give bonds."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b747c44-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id6b747c45-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Government Accountability Office” substituted in text for “General Accounting Office” pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"section 8(b) of Pub. L. 108–271","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s702"},"text":"section 702 of Title 31","children":[],"tail":", Money and Finance, which redesignated the General Accounting Office and any references thereto as the Government Accountability Office. Previously, “General Accounting Office” substituted in text for “Treasury Department” pursuant to act "},{"tag":"date","attrib":{"date":"1921-06-10"},"text":"June 10, 1921","children":[],"tail":", which transferred all powers and duties of Comptroller, six auditors, and certain other employees of Treasury to General Accounting Office. See section 701 et seq. of Title 31."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id6b747c46-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id6b747c47-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Coast and Geodetic Survey consolidated with National Weather Bureau to form Environmental Science Services Administration by Reorg. Plan No. 2 of 1965, eff. ","children":[{"tag":"date","attrib":{"date":"1965-07-13"},"text":"July 13, 1965","children":[],"tail":", 30 F.R. 8819, "},{"tag":"ref","attrib":{"href":"/us/stat/79/1318"},"text":"79 Stat. 1318","children":[],"tail":". Environmental Science Services Administration abolished and its personnel, property, records, etc., transferred to National Oceanic and Atmospheric Administration by Reorg. Plan No. 4 of 1970, eff. "},{"tag":"date","attrib":{"date":"1970-10-03"},"text":"Oct. 3, 1970","children":[],"tail":", 35 F.R. 15627, "},{"tag":"ref","attrib":{"href":"/us/stat/84/2090"},"text":"84 Stat. 2090","children":[],"tail":". By order of Acting Associate Administrator of National Oceanic and Atmospheric Administration, 35 F.R. 19249, "},{"tag":"date","attrib":{"date":"1970-12-19"},"text":"Dec. 19, 1970","children":[],"tail":", Coast and Geodetic Survey redesignated National Ocean Survey. For further details, see note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s851"},"text":"section 851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
