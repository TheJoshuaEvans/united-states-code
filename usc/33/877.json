{"tag":"section","attrib":{"id":"id6b747c3e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s877"},"text":null,"children":[{"tag":"num","attrib":{"value":"877"},"text":"§ 877.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations; advances from","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Advances of money from available appropriations may be made to the National Ocean Survey and by authority of the Director thereof to chiefs of parties and accounts arising under such advances shall be rendered through and by the disbursing officer of the National Ocean Survey to the Government Accountability Office as under advances made to chiefs of parties prior to ","children":[{"tag":"date","attrib":{"date":"1918-07-01"},"text":"July 1, 1918","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b747c3f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1918-07-01/ch113/s1"},"text":"July 1, 1918, ch. 113, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/688"},"text":"40 Stat. 688","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1920-06-05/ch235/s1"},"text":"June 5, 1920, ch. 235, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/929"},"text":"41 Stat. 929","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1921-06-10/ch18"},"text":"June 10, 1921, ch. 18","children":[],"tail":", title III, § 304, "},{"tag":"ref","attrib":{"href":"/us/stat/42/24"},"text":"42 Stat. 24","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/310/tII/s231/z"},"text":"Pub. L. 92–310, title II, § 231(z)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-06"},"text":"June 6, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/212"},"text":"86 Stat. 212","children":[],"tail":"; "},{"tag":"