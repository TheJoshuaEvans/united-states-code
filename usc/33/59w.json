{"tag":"section","attrib":{"id":"id6b103bcd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59w"},"text":null,"children":[{"tag":"num","attrib":{"value":"59w"},"text":"§ 59w.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Norton Basin and Jamaica Bay, New York","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The two portions of Norton Basin and Jamaica Bay, New York, that are particularly described in Committee Print 99–58 of the Committee on Public Works and Transportation of the House of Representatives are hereby declared to be nonnavigable waters of the United States for purposes of the navigation servitude.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b103bce-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662/tXI/s1168"},"text":"Pub. L. 99–662, title XI, § 1168","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4259"},"text":"100 Stat. 4259","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b103bcf-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b103bd0-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id6b103bd1-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Public Works and Transportation of House of Representatives treated as referring to Committee on Transportation and Infrastructure 