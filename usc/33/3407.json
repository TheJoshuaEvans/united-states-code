{"tag":"section","attrib":{"id":"id6c81f510-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3407"},"text":null,"children":[{"tag":"num","attrib":{"value":"3407"},"text":"§ 3407.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c81f511-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3407/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Characterization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “characterization”, “characterize”, and “characterizing” mean activities that provide comprehensive data and interpretations for a specific area of interest of the sea floor, sub-bottom, water column, or hydrologic features, such as water masses and currents, in direct support of specific research, environmental protection, resource management, policymaking, or applied mission objectives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c81f512-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3407/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exploration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ","children":[{"tag":"ref","attrib":{"idref":"fn002145"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002145"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “terms” and “mean”."}],"tail":" “exploration”, “explore”, and “exploring” means "},{"tag":"ref","attrib":{"idref":"fn002145"},"text":"1","children":[],"tail":" activities that provide—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c81f513-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3407/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a multidisciplinary view of an unknown or poorly understood area of the sea floor, sub-bottom, or water column; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c81f514-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3407/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an initial assessment of the physical, chemical, geological, biological, archaeological, or other characteristics of such an area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c81f515-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3407/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mapping","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “map” and “mapping” mean activities that provide comprehensive data and information needed to understand sea floor characteristics, including depth, topography, bottom type, sediment composition and distribution, underlying geologic structure, and benthic flora and fauna.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c81f516-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tXII/s12007"},"text":"Pub. L. 111–11, title XII, § 12007","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tCIII/s10305/h"},"text":"Pub. L. 117–263, div. J, title CIII, § 10305(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3974"},"text":"136 Stat. 3974","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
