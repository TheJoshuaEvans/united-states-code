{"tag":"section","attrib":{"id":"id6c5e18c6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2341b"},"text":"§ 2341b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization of certain projects","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall give priority to a project for flood risk management if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c5e18c7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is an executed project partnership agreement for the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5e18c8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the project is located in an area—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c5e18c9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c5e18ca-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there has been a loss of life due to flood events; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c5e18cb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President has declared that a major disaster or emergency exists under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5170"},"text":"section 5170 of title 42","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c5e18cc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is at significant risk for catastrophic flooding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c5e18cd-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/tI/s1144"},"text":"Pub. L. 114–322, title I, § 1144","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1659"},"text":"130 Stat. 1659","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c5e18ce-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c5e18cf-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c5e18d0-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 2016, and also as part of the Water Infrastructure Improvements for the Nation Act, also known as the WIIN Act, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c5e18d1-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c5e18d2-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1002"},"text":"section 1002 of Pub. L. 114–322","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
