{"tag":"section","attrib":{"id":"id6c950763-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4008"},"text":null,"children":[{"tag":"num","attrib":{"value":"4008"},"text":"§ 4008.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c950764-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4008/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action Strategy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Action Strategy” means the comprehensive research plan and action strategy established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s4003"},"text":"section 4003 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c950765-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4008/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Administrator of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c950766-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4008/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Harmful algal bloom","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “harmful algal bloom” means marine and freshwater phytoplankton that proliferate to high concentrations, resulting in nuisance conditions or harmful impacts on marine and aquatic ecosystems, coastal communities, and human health through the production of toxic compounds or other biological, chemical, and physical impacts of the algae outbreak.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c950767-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4008/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hypoxia","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “hypoxia” means a condition where low dissolved oxygen in aquatic systems causes stress or death to resident organisms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c950768-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4008/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Program” means the national harmful algal bloom and hypoxia program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s4002"},"text":"section 4002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c950769-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4008/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the several States of the United States, the District of Columbia, the Commonwealth of Puerto Rico, the Virgin Islands, Guam, American Samoa, the Commonwealth of the Northern Mariana Islands, any other territory or possession of the United States, and any Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c95076a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4008/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Task Force","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Task Force” means the Inter-Agency Task Force on Harmful Algal Blooms and Hypoxia under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s4001/a"},"text":"section 4001(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c95076b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4008/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Under Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Under Secretary” means the Under Secretary of Commerce for Oceans and Atmosphere.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c95076c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4008/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States coastal waters","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States coastal waters” includes the Great Lakes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c95076d-3a70-11f1-9100-cf79f4fb