{"tag":"section","attrib":{"id":"id6c904c0e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3910"},"text":null,"children":[{"tag":"num","attrib":{"value":"3910"},"text":"§ 3910.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State, tribal, and local permits","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The provision of financial assistance for a project under this chapter shall not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c904c0f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3910/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relieve any recipient of the assistance of any obligation to obtain any required State, local, or tribal permit or approval with respect to the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904c10-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3910/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit the right of any unit of State, local, or tribal government to approve or regulate any rate of return on private equity invested in the project; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904c11-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3910/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise supersede any State, local, or tribal law (including any regulation) applicable to the construction or operation of the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c904c12-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/tV/s5031"},"text":"Pub. L. 113–121, title V, § 5031","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1342"},"text":"128 Stat. 1342","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
