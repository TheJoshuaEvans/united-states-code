{"tag":"section","attrib":{"id":"id6b6fc14a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s853o–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"853o–1"},"text":"§ 853o–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit of service as deck officer or junior engineer and certain other active service for retirement and retirement pay","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Active service in the National Oceanic and Atmospheric Administration as a deck officer or junior engineer and active service counted on ","children":[{"tag":"date","attrib":{"date":"1922-06-30"},"text":"June 30, 1922","children":[],"tail":", for longevity pay, shall be credited to commissioned officers as active commissioned service for purposes of retirement and retirement pay."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b6fc14b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/649/s9/c"},"text":"Pub. L. 87–649, § 9(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/496"},"text":"76 Stat. 496","children":[],"tail":"; 1965 Reorg. Plan No. 2, eff. "},{"tag":"date","attrib":{"date":"1965-07-13"},"text":"July 13, 1965","children":[],"tail":", 30 F.R. 8819, "},{"tag":"ref","attrib":{"href":"/us/stat/79/1318"},"text":"79 Stat. 1318","children":[],"tail":"; 1970 Reorg. Plan No. 4, eff. "},{"tag":"date","attrib":{"date":"1970-10-03"},"text":"Oct. 3, 1970","children":[],"tail":", 35 F.R. 15627, "},{"tag":"ref","attrib":{"href":"/us/stat/84/2090"},"text":"84 Stat. 2090","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b6fc14c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b6fc14d-