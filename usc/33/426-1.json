{"tag":"section","attrib":{"id":"id6b25bfcd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"426–1"},"text":"§ 426–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coastal Engineering Research Center; establishment; powers and functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There shall be established under the Chief of Engineers, United States Army, a Coastal Engineering Research Center which, except as hereinafter provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s426–3"},"text":"section 426–3 of this title","children":[],"tail":", shall be vested with all the functions of the Beach Erosion Board, including the authority to make general investigations as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s426a"},"text":"section 426a of this title","children":[],"tail":", and such additional functions as the Chief of Engineers may assign."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b25bfce-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/172/s1"},"text":"Pub. L. 88–172, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-11-07"},"text":"Nov. 7, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/304"},"text":"77 Stat. 304","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b25bfcf-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b25bfd0-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b25bfd1-3a70-11f1-9100-cf79f4fb4b3e"},"text":nu