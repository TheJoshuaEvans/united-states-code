{"tag":"section","attrib":{"id":"id6c785747-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3049"},"text":null,"children":[{"tag":"num","attrib":{"value":"3049"},"text":"§ 3049.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recall to active duty","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of chapter 39 of title 10 relating to recall of retired officers to active duty, including the limitations on such recalls, shall apply to commissioned officers of the Administration.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6c785748-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372/tII/s249"},"text":"Pub. L. 107–372, title II, § 249","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3090"},"text":"116 Stat. 3090","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
