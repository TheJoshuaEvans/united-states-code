{"tag":"section","attrib":{"id":"id6c785791-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3072"},"text":null,"children":[{"tag":"num","attrib":{"value":"3072"},"text":"§ 3072.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for veterans benefits and other rights, privileges, immunities, and benefits under certain provisions of law","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c785792-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3072/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Active service of officers of the Administration shall be deemed to be active military service for the purposes of all rights, privileges, immunities, and benefits under the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c785793-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3072/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Laws administered by the Secretary of Veterans Affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c785794-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3072/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Servicemembers Civil Relief Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3901"},"text":"50 U.S.C. 3901","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c785795-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3072/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s410"},"text":"Section 410 of title 42","children":[],"tail":", as in effect before "},{"tag":"date","attrib":{"date":"1950-09-01"},"text":"September 1, 1950","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c785796-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3072/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exercise of authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the administration of the laws and regulations referred to in subsection (a), with respect to the Administration, the authority vested in the Secretary of Defense and the Secretaries of the military departments and their respective departments shall be exercised by the Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c785797-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372/tII/s262"},"text":"Pub. L. 107–372, title II, § 262","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3092"},"text":"116 Stat. 3092","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s2/g"},"text":"Pub. L. 108–189, § 2(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2866"},"text":"117 Stat. 2866","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c785798-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c785799-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c78579a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Servicemembers Civil Relief Act, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"act Oct. 17, 1940, ch. 888","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/1178"},"text":"54 Stat. 1178","children":[],"tail":", which is classified principally to chapter 50 (§ 3901 et seq.) of Title 50, War and National Defense. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6c78579b-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in sections 857 and 857–3(a) of this title prior to repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372"},"text":"Pub. L. 107–372","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c78579c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/189"},"text":"Pub. L. 108–189","children":[],"tail":" amended par. (2) generally substituting “The Servicemembers Civil Relief Act” for “The Soldiers’ and Sailors’ Civil Relief Act of 1940 (50 App. U.S.C. 501 et seq.)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
