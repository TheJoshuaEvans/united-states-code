{"tag":"section","attrib":{"id":"id6b499aef-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s579g"},"text":null,"children":[{"tag":"num","attrib":{"value":"579g"},"text":"§ 579g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b499af0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s579g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 10 days after the date on which the budget of the President for each fiscal year is submitted to Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":", the Secretary shall submit to the Committees on Transportation and Infrastructure and Appropriations of the House of Representatives and the Committees on Environment and Public Works and Appropriations of the Senate a report on the status of each covered report."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b499af1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s579g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall include in the report required under paragraph (1) the following information:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b499af2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s579g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A summary of the status of each covered report, including if each such report has been initiated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b499af3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s579g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amount of funds that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6b499af4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s579g/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have been made available to carry out each such report; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6b499af5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s579g/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary requires to complete each such report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b499af6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s579g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A detailed assessment of how the Secretary intends to complete each covered report, including an anticipated timeline for completion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b499af7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s579g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publicly available","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make each report required under paragraph (1) publicly available on the website of the Corps of Engineers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b499af8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s579g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall submit to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on the Environment and Public Works of the Senate on an annual basis a draft of each covered report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b499af9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s579g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of covered report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “covered report”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b499afa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s579g/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means any report or study required to be submitted by the Secretary under this Act or any Act providing authorizations for water resources development projects enacted after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Environment and Public Works of the Senate that has not been so submitted; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b499afb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s579g/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include a feasibility study (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2215/d"},"text":"section 2215(d) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b499afc-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/dA/tI/s1150/b"},"text":"Pub. L. 118–272, div. A, title I, § 1150(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3041"},"text":"138 Stat. 3041","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b499afd-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b499afe-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6b499aff-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in par. (5)(A), probably means div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272"},"text":"Pub. L. 118–272","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2996"},"text":"138 Stat. 2996","children":[],"tail":", known as the Water Resources Development Act of 2024. For complete classification of 