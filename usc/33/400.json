egister and on a publicly available website, the criteria the Secretary uses for prioritizing annual funding for continuing authority program projects."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b1c4997-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s400/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", and each year thereafter, the Secretary shall publish in the Federal Register and on a publicly available website, a report on the status of each continuing authority program, which, at a minimum, shall include—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b1c4998-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s400/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and a short description of each active continuing authority program project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b1c4999-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s400/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost estimate to complete each active project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b1e938a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s400/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the funding available in that fiscal year for each continuing authority program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":