{"tag":"section","attrib":{"id":"id6b7ba73c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894a"},"text":null,"children":[{"tag":"num","attrib":{"value":"894a"},"text":"§ 894a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions to address sexual assault at National Oceanic and Atmospheric Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b7ba73d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive policy on prevention of and response to sexual assaults","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2016-12-23"},"text":"December 23, 2016","children":[],"tail":", the Secretary of Commerce shall, acting through the Under Secretary for Oceans and Atmosphere, develop a comprehensive policy on the prevention of and response to sexual assaults involving employees of the National Oceanic and Atmospheric Administration, members of the commissioned officer corps of the Administration, and individuals who work with or conduct business on behalf of the Administration."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b7ba73e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements of comprehensive policy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The comprehensive policy developed under subsection (a) shall, at minimum, address the following matters:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b7ba73f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prevention measures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7ba740-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Education and training on prevention and response.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7ba741-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A list of support resources an individual may use in the occurrence of sexual assault, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b7ba742-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894a/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" options and contact information for after-hours contact; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b7ba743-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894a/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a procedure for obtaining assistance and reporting sexual assault while working in a remote scientific field camp, at sea, or in another field status.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7ba744-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Easy and ready availability of information described in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7ba745-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Establishing a mechanism by which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b7ba746-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894a/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" questions regarding sexual assault can be confidentially asked and confidentially answered; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b7ba747-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894a/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incidents of sexual assault can be reported on a restricted or unrestricted basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7ba748-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Protocols for the investigation of complaints by command and law enforcement personnel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7ba749-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894a/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prohibiting retaliation and consequences for retaliatory actions against someone who reports a sexual assault.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7ba74a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894a/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Oversight by the Under Secretary of administrative and disciplinary actions in response to substantiated incidents of sexual assault.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7ba74b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894a/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Victim advocacy, including establishment of and the responsibilities and training requirements for victim advocates as described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7ba74c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894a/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Availability of resources for victims of sexual assault within other Federal agencies and State, local, and national organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b7ba74d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Victim advocacy","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b7ba74e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Under Secretary, shall establish victim advocates to advocate for victims of sexual assaults involving employees of the Administration, members of the commissioned officer corps of the Administration, and individuals who work with or conduct business on behalf of the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7ba74f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Victim advocates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, a victim advocate is an existing permanent employee of the Administration who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b7ba750-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is trained in matters relating to sexual assault and the comprehensive policy developed under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b7ba751-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serves as a victim advocate voluntarily and in addition to the employee’s other duties as an employee of the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7ba752-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Primary duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The primary duties of a victim advocate established under paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b7ba753-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Supporting victims of sexual assault and informing them of their rights and the resources available to them as victims.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b7ba754-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Acting as a companion in navigating investigative, medical, mental and emotional health, and recovery processes relating to sexual assault.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b7ba755-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894a/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Helping to identify resources to ensure the safety of victims of sexual assault.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7ba756-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that at least 1 victim advocate established under paragraph (1) is stationed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b7ba757-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894a/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in each region in which the Administration conducts operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b7ba758-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894a/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in each marine and aviation center of the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7ba759-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hotline","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b7ba75a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894a/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this subsection, the Secretary shall provide a telephone number at which a victim of a sexual assault can contact a victim advocate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b7ba75b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894a/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 24-hour access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that the telephone number established under subparagraph (A) is monitored at all times.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b7ba75c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894a/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, where possible, use established hotlines for purposes of this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7ba75d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894a/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Formal relationships with other entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into formal relationships with other entities to make available additional victim advocates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b7ba75e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of policy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that the policy developed under subsection (a) is available to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b7ba75f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all employees of the Administration and members of the commissioned officer corps of the Administration, including those employees and members who conduct field work for the Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7ba760-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b7ba761-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation and assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing the policy required by subsection (a), the Secretary may consult or receive assistance from such State, local, and national organizations and subject matter experts as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b7ba762-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dC/tXXXV/s3542"},"text":"Pub. L. 114–328, div. C, title XXXV, § 3542","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2801"},"text":"130 Stat. 2801","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/259/tV/s504/a/2"},"text":"Pub. L. 116–259, title V, § 504(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-23"},"text":"Dec. 23, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1180"},"text":"134 Stat. 1180","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b7ba763-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b7ba764-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b7ba765-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (b)(5)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/259"},"text":"Pub. L. 116–259","children":[],"tail":" substituted “can be reported on a restricted or unrestricted basis” for “can be confidentially reported”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
