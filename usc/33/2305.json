{"tag":"section","attrib":{"id":"id6c4d7716-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2305"},"text":null,"children":[{"tag":"num","attrib":{"value":"2305"},"text":"§ 2305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of FMHA funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, Federal assistance made available by the Farmers Home Administration may be used to pay the non-Federal share of any other Federal grant-in-aid program for any project for water resources, including water pollution control.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6c4d7717-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662/tIX/s950"},"text":"Pub. L. 99–662, title IX, § 950","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4201"},"text":"100 Stat. 4201","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
