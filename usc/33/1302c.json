{"tag":"section","attrib":{"id":"id6bc7f324-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1302c"},"text":"§ 1302c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small publicly owned treatment works efficiency grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6bc7f325-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations, not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Administrator shall establish an efficiency grant program (referred to in this section as the “efficiency grant program”) under which the Administrator shall award grants to eligible entities for the replacement or repair of equipment that improves water or energy efficiency of small publicly owned treatment works, as identified in an efficiency audit."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bc7f326-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may award a grant under the efficiency grant program to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bc7f327-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an owner or operator of a small publicly owned treatment works that serves—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6bc7f328-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302c/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a population of not more than 10,000 people; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bc7f329-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302c/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a disadvantaged community; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bc7f32a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit organization that seeks to assist a small publicly owned treatment works described in paragraph (1) to carry out the activities described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bc7f32b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after the date on which the Administrator establishes the efficiency grant program, and every 2 years thereafter, the Administrator shall submit to Congress a report describing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bc7f32c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each recipient of a grant under the efficiency grant program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bc7f32d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the activities carried out under the efficiency grant program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bc7f32e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bc7f32f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small systems","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts made available for grants under this section, to the extent that there are sufficient applications, not less than 15 percent shall be used for grants to publicly owned treatment works that serve fewer than 3,300 people.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bc7f330-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts made available for grants under this section, not more than 2 percent may be used to pay the administrative costs of the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6bc7f331-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"June 30, 1948, ch. 758","children":[],"tail":", title II, § 225, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dE/tII/s50207"},"text":"Pub. L. 117–58, div. E, title II, § 50207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1165"},"text":"135 Stat. 1165","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
