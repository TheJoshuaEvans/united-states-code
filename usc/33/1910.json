{"tag":"section","attrib":{"id":"id6c229619-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1910"},"text":null,"children":[{"tag":"num","attrib":{"value":"1910"},"text":"§ 1910.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Legal actions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c22961a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1910/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons with adversely affected interests as plaintiffs; defendants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b) of this section, any person having an interest which is, or can be, adversely affected, may bring an action on his own behalf—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c22961b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1910/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" against any person alleged to be in violation of the provisions of this chapter, or regulations issued hereunder;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c22961c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1910/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" against the Secretary where there is alleged a failure of the Secretary to perform any act or duty under this chapter which is not discretionary with the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c22961d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1910/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" against the Administrator where there is alleged a failure of the Administrator to perform any act or duty under this chapter which is not discretionary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c22961e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1910/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" against the Secretary of the Treasury where there is alleged a failure of the Secretary of the Treasury to take action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1908/e"},"text":"section 1908(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c22961f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1910/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencement conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No action may be commenced under subsection (a) of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c229620-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1910/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prior to 60 days after the plaintiff has given notice, in writing and under oath, to the alleged violator, the Secretary concerned or the Administrator, and the Attorney General; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c229621-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1910/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary or the Administrator has commenced enforcement or penalty action with respect to the alleged violation and is conducting such procedures diligently.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c229622-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1910/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Venue","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any suit brought under this section shall be brought—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c229623-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1910/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a case concerning an onshore facility or port, in the United States district court for the judicial district where the onshore facility or port is located;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c229624-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1910/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a case concerning an offshore facility or offshore structure under the jurisdiction of the United States, in the United States district court for the judicial district nearest the offshore facility or offshore structure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c229625-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1910/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a case concerning a ship, in the United States district court for any judicial district wherein the ship or its owner or operator may be found; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c229626-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1910/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any case, in the District Court for the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c229627-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1910/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs; attorney fees; witness fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The court, in issuing any final order in any action brought pursuant to this section, may award costs of litigation (including reasonable attorney and expert witness fees) to any party including the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c229628-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1910/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal intervention","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any action brought under this section, if the Secretary or Attorney General are not parties of record, the United States, through the Attorney General, shall have the right to intervene.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c229629-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/478/s11"},"text":"Pub. L. 96–478, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-21"},"text":"Oct. 21, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2302"},"text":"94 Stat. 2302","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/280/s12"},"text":"Pub. L. 110–280, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-21"},"text":"July 21, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2615"},"text":"122 Stat. 2615","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c22962a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c22962b-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c22962c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/280/s12/1"},"text":"Pub. L. 110–280, § 12(1)","children":[],"tail":", added par. (3) and redesignated former par. (3) as (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/280/s12/2"},"text":"Pub. L. 110–280, § 12(2)","children":[],"tail":", substituted “concerned or the Administrator,” for “concerned,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/280/s12/3"},"text":"Pub. L. 110–280, § 12(3)","children":[],"tail":", inserted “or the Administrator” after “Secretary”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
