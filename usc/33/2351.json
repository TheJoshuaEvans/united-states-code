{"tag":"section","attrib":{"id":"id6c62fa17-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2351"},"text":null,"children":[{"tag":"num","attrib":{"value":"2351"},"text":"§ 2351.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Durability, sustainability, and resilience","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In carrying out the activities of the Corps of Engineers, the Secretary, to the maximum extent practicable, shall encourage the use of durable and sustainable materials and resilient construction techniques that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c62fa18-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2351/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" allow a water resources infrastructure project—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c62fa19-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2351/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to resist hazards due to a major disaster; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c62fa1a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2351/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to continue to serve the primary function of the water resources infrastructure project following a major disaster;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62fa1b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2351/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce the magnitude or duration of a disruptive event to a water resources infrastructure project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62fa1c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2351/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the absorptive capacity, adaptive capacity, and recoverability to withstand a potentially disruptive event.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c62fa1d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/tIII/s3022"},"text":"Pub. L. 113–121, title III, § 3022","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1301"},"text":"128 Stat. 1301","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c62fa1e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c62fa1f-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c62fa20-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Reform and Development Act of 2014, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c62fa21-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c62fa22-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s2"},"text":"section 2 of Pub. L. 113–121","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
