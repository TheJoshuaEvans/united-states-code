{"tag":"section","attrib":{"id":"id6b0b811d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s50"},"text":null,"children":[{"tag":"num","attrib":{"value":"50"},"text":"§ 50.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Turtle Bay and Turtle Bayou, Texas","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Turtle Bay and Turtle Bayou, in Chambers County, in the State of Texas, are declared to be nonnavigable waterways within the meaning of the Constitution and laws of the United States of America.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The existing project for Turtle Bayou, Texas, authorized by the Rivers and Harbors Act approved ","children":[{"tag":"date","attrib":{"date":"1910-06-25"},"text":"June 25, 1910","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/act/1910-06-25/ch382"},"text":"Act June 25, 1910, ch. 382","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/630"},"text":"36 Stat. 630","children":[],"tail":"), is abandoned."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The right of Congress to alter, amend, or repeal this section is expressly reserved.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b0b811e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-03-10/ch36"},"text":"Mar. 10, 1937, ch. 36","children":[],"tail":", §§ 1–3, "},{"tag":"ref","attrib":{"href":"/us/stat/50/28"},"text":"50 Stat. 28","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b0b811f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b0b8120-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6b0b8121-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Rivers and Harbors Act approved ","children":[{"tag":"date","attrib":{"date":"1910-06-25"},"text":"June 25, 1910","children":[],"tail":", referred to in text, is "},{"tag":"ref","attrib":{"href":"/us/act/1910-06-25/ch382"},"text":"act June 25, 1910, ch. 382","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/630"},"text":"36 Stat. 630","children":[],"tail":", which is classified to sections 546, 564, and 643 of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
