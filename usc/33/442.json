{"tag":"section","attrib":{"id":"id6b2ceb18-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s442"},"text":null,"children":[{"tag":"num","attrib":{"value":"442"},"text":"§ 442.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability of officers of towing vessel","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any and every master and engineer, or person or persons acting in such capacity, respectively, on board of any boat or vessel, who shall knowingly engage in towing any scow, boat, or vessel loaded with any such prohibited matter to any point or place of deposit, or discharge in the waters of any harbor subject to this subchapter, or to any point or place elsewhere than within the limits defined and permitted by the supervisor of the harbor, shall be deemed guilty of a violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s441"},"text":"section 441 of this title","children":[],"tail":", and shall, upon conviction, be punishable as provided for offenses in violation of "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s441"},"text":"section 441 of this title","children":[],"tail":", and shall also have his license revoked or suspended for a term to be fixed by the judge before whom tried and convicted."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b2ceb19-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1888-06-29/ch496/s2"},"text":"June 29, 1888, ch. 496, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/25/209"},"text":"25 Stat. 209","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/802/s1/2"},"text":"Pub. L. 85–802, § 1(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-28"},"text":"Aug. 28, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/970"},"text":"72 Stat. 970","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b2ceb1a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b2ceb1b-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b2ceb1c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1958—","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/802"},"text":"Pub. L. 85–802","children":[],"tail":" substituted “any harbor subject to this subchapter” for “the harbor of New York, or in its adjacent or tributary waters, or in those of Long Island Sound”, and struck out “hereinafter mentioned” after “supervisor of the harbor”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b2ceb1d-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6b2ceb1e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1958 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/802"},"text":"Pub. L. 85–802","children":[],"tail":" effective on sixtieth day after "},{"tag":"date","attrib":{"date":"1958-08-28"},"text":"Aug. 28, 1958","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/85/802/s2"},"text":"section 2 of Pub. L. 85–802","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s441"},"text":"section 441 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
