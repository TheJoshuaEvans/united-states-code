{"tag":"section","attrib":{"id":"id6b3ffecc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s545a"},"text":null,"children":[{"tag":"num","attrib":{"value":"545a"},"text":"§ 545a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discontinuance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For preliminary examinations and surveys authorized in previous river and harbor and flood-control Acts, the Secretary of the Army is directed to cause investigations and reports for navigation and allied purposes to be prepared under the supervision of the Chief of Engineers in the form of survey reports, and that preliminary examination reports shall no longer be required to be prepared.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b3ffecd-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/500/tI/s105"},"text":"Pub. L. 85–500, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-07-03"},"text":"July 3, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/300"},"text":"72 Stat. 300","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b3ffece-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b3ffecf-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6b3ffed0-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Previous river and harbor and flood-control Acts, referred to in text, means those acts prior to the River and Harbor Act of 1958 and the Flood Control Act of 1958, titles I and II, respectively, of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/500"},"text":"Pub. L. 85–500","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
