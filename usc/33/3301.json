{"tag":"section","attrib":{"id":"id6c7d3977-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301"},"text":null,"children":[{"tag":"num","attrib":{"value":"3301"},"text":"§ 3301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7d3978-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Administrator of the Federal Emergency Management Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7d3979-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Canal structure","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c7d397a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “canal structure” means an embankment, wall, or structure along a canal or manmade watercourse that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c7d397b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" constrains water flows;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c7d397c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is subject to frequent water loading; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c7d397d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an integral part of a flood risk reduction system that protects the leveed area from flood waters associated with hurricanes, precipitation events, seasonal high water, and other weather-related events.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7d397e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “canal structure” does not include a barrier across a watercourse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7d397f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “committee” means the Committee on Levee Safety established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3302/a"},"text":"section 3302(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7d3980-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Floodplain management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “floodplain management” means the operation of a community program of corrective and preventative measures for reducing flood damage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7d3981-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian tribe” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7d3982-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “inspection” means an actual inspection of a levee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c7d3983-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish the global information system location of the levee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7d3984-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine the general condition of the levee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7d3985-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to estimate the number of structures and population at risk and protected by the levee that would be adversely impacted if the levee fails or water levels exceed the height of the levee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7d3986-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Levee","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c7d3987-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “levee” means a manmade barrier (such as an embankment, floodwall, or other structure)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c7d3988-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/7/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the primary purpose of which is to provide hurricane, storm, or flood protection relating to seasonal high water, storm surges, precipitation, or other weather events; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c7d3989-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/7/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is normally subject to water loading for only a few days or weeks during a calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7d398a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “levee” includes a levee system, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c7d398b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" levees and canal structures that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id6c7d398c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/7/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" constrain water flows;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6c7d398d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/7/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are subject to more frequent water loading; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6c7d398e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/7/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" do not constitute a barrier across a watercourse; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c7d398f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" roadway and railroad embankments, but only to the extent that the embankments are integral to the performance of a flood damage reduction system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7d3990-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “levee” does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c7d3991-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/7/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a roadway or railroad embankment that is not integral to the performance of a flood damage reduction system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c7d3992-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/7/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a canal constructed completely within natural ground without any manmade structure (such as an embankment or retaining wall to retain water or a case in which water is retained only by natural ground);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c7d3993-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/7/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a canal regulated by a Federal or State agency in a manner that ensures that applicable Federal safety criteria are met;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c7d3994-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/7/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a levee or canal structure—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id6c7d3995-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/7/C/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is not a part of a Federal flood damage reduction system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6c7d3996-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/7/C/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is not recognized under the National Flood Insurance Program as providing protection from the 1-percent-annual-chance or greater flood;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6c7d3997-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/7/C/iv/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is not greater than 3 feet high;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6c7d3998-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/7/C/iv/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the population in the leveed area of which is less than 50 individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6c7d3999-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/7/C/iv/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the leveed area of which is less than 1,000 acres; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c7d399a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/7/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any shoreline protection or river bank protection system (such as revetments or barrier islands).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7d399b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Levee feature","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “levee feature” means a structure that is critical to the functioning of a levee, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c7d399c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an embankment section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7d399d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a floodwall section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7d399e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a closure structure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7d399f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/8/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a pumping station;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7d39a0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/8/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an interior drainage work; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7d39a1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/8/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a flood damage reduction channel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7d39a2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Levee system","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “levee system” means 1 or more levee segments, including all levee features that are interconnected and necessary to ensure protection of the associated leveed areas—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c7d39a3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that collectively provide flood damage reduction to a defined area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7d39a4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the failure of 1 of which may result in the failure of the entire system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7d39a5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National levee database","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “national levee database” means the levee database established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3303"},"text":"section 3303 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7d39a6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participating program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “participating program” means a levee safety program developed by a State, regional district, or Indian tribe that includes the minimum components necessary for recognition by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7d39a7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional district","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “regional district” means a subdivision of a State government, or a subdivision of multiple State governments, that is authorized to acquire, construct, operate, and maintain projects for the purpose of flood damage reduction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7d39a8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rehabilitation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c7d39a9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “rehabilitation” means the repair, replacement, reconstruction, removal of a levee, or reconfiguration of a levee system, including a setback levee, that is carried out to reduce flood risk, increase resiliency to extreme weather events, or meet national levee safety guidelines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7d39aa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “rehabilitation” includes improvements to a levee in conjunction with any repair, replacement, reconstruction, or reconfiguration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7d39ab-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Risk","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “risk” means a measure of the probability and severity of undesirable consequences.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7d39ac-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “State” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c7d39ad-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/15/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7d39ae-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/15/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7d39af-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/15/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commonwealth of Puerto Rico; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7d39b0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/15/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7d39b1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State levee safety agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State levee safety agency” means the agency of a State that has regulatory authority over the safety of any non-Federal levee in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7d39b2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3301/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States”, when used in a geographical sense, means all of the States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c7d39b3-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/tIX/s9002"},"text":"Pub. L. 110–114, title IX, § 9002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-11-08"},"text":"Nov. 8, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1288"},"text":"121 Stat. 1288","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/121/tIII/s3016/b"},"text":"Pub. L. 113–121, title III, § 3016(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1289"},"text":"128 Stat. 1289","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tI/s1130/a"},"text":"Pub. L. 114–322, title I, § 1130(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1650"},"text":"130 Stat. 1650","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dH/tLXXXI/s8387/a"},"text":"Pub. L. 117–263, div. H, title LXXXI, § 8387(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3830"},"text":"136 Stat. 3830","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c7d39b4-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c7d39b5-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c7d39b6-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Par. (13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" designated existing provisions as subpar. (A) and inserted heading, inserted “, increase resiliency to extreme weather events,” after “flood risk”, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Par. (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1130/a/1"},"text":"Pub. L. 114–322, § 1130(a)(1)","children":[],"tail":", substituted “State, regional district, or Indian tribe” for “State or Indian tribe”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (12) to (17). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1130/a/2"},"text":"Pub. L. 114–322, § 1130(a)(2)","children":[],"tail":", (3), added par. (12) and redesignated former pars. (12) to (16) as (13) to (17), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Pars. (1) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s3016/b/1"},"text":"Pub. L. 113–121, § 3016(b)(1)","children":[],"tail":"–(3), added pars. (1), (2), (4), and (5), and redesignated former pars. (1) and (2) as (3) and (6), respectively. Former pars. (3), (4), (5), and (6) redesignated (7), (14), (15), and (16), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s3016/b/4"},"text":"Pub. L. 113–121, § 3016(b)(4)","children":[],"tail":", added par. (7) and struck out former par. (7) which defined “levee”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s3016/b/1"},"text":"Pub. L. 113–121, § 3016(b)(1)","children":[],"tail":", redesignated par. (3) as (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (8) to (16). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s3016/b/1"},"text":"Pub. L. 113–121, § 3016(b)(1)","children":[],"tail":", (4), added pars. (8) to (13) and redesignated pars. (4) to (6) as (14) to (16), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c7d39b7-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id6c7d39b8-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/tIX/s9001/a"},"text":"Pub. L. 110–114, title IX, § 9001(a)","children":[],"tail":", formerly § 9001, "},{"tag":"date","attrib":{"date":"2007-11-08"},"text":"Nov. 8, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1288"},"text":"121 Stat. 1288","children":[],"tail":", renumbered § 9001(a) and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/113/121/tIII/s3016/a/1"},"text":"Pub. L. 113–121, title III, § 3016(a)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1289"},"text":"128 Stat. 1289","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/121/tIII/s3016/a/1"},"text":"“This title [enacting this chapter] may be cited as the ‘National Levee Safety Act of 2007’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c7d39b9-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Purposes of the Safety Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/tIX/s9001/b"},"text":"Pub. L. 110–114, title IX, § 9001(b)","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/121/tIII/s3016/a/3"},"text":"Pub. L. 113–121, title III, § 3016(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1289"},"text":"128 Stat. 1289","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/121/tIII/s3016/a/3"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The purposes of this title [enacting this chapter] are—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that human lives and property that are protected by new and existing levees are safe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage the use of appropriate engineering policies, procedures, and technical practices for levee site investigation, design, construction, operation and maintenance, inspection, assessment, and emergency preparedness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop and support public education and awareness projects to increase public acceptance and support of levee safety programs and provide information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to build public awareness of the residual risks associated with living in levee protected areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop technical assistance materials, seminars, and guidelines to improve the security of levees of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage the establishment of effective State and tribal levee safety programs.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
