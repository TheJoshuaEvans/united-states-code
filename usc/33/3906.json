{"tag":"section","attrib":{"id":"id6c8ddb60-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3906"},"text":null,"children":[{"tag":"num","attrib":{"value":"3906"},"text":"§ 3906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities eligible for assistance","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter, an eligible activity with respect to an eligible project includes the cost of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c8ddb61-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3906/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development-phase activities, including planning, feasibility analysis (including any related analysis necessary to carry out an eligible project), revenue forecasting, environmental review, permitting, preliminary engineering and design work, and other preconstruction activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8ddb62-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3906/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" construction, reconstruction, rehabilitation, and replacement activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8ddb63-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3906/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquisition of real property or an interest in real property (including water rights, land relating to the project, and improvements to land), environmental mitigation (including acquisitions pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3905/8"},"text":"section 3905(8) of this title","children":[],"tail":"), construction contingencies, and acquisition of equipment; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8ddb64-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3906/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capitalized interest necessary to meet market requirements, reasonably required reserve funds, capital issuance expenses, and other carrying costs during construction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c904b65-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/tV/s5027"},"text":"Pub. L. 113–121, title V, § 5027","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1335"},"text":"128 Stat. 1335","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tIV/s5008/b/2/C"},"text":"Pub. L. 114–322, title IV, § 5008(b)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1897"},"text":"130 Stat. 1897","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c904b66-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c904b67-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c904b68-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322"},"text":"Pub. L. 114–322","children":[],"tail":" substituted “section 3905(8)” for “section 3905(7)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
