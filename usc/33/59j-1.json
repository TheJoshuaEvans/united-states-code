{"tag":"section","attrib":{"id":"id6b0df184-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59j–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"59j–1"},"text":"§ 59j–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Declaration of nonnavigability for portions of the Delaware River","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b0df185-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59j–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Area to be declared non-navigable; public interest","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Unless the Secretary finds, after consultation with local and regional public officials (including local and regional public planning organizations), that the proposed projects in Philadelphia, Pennsylvania, to be undertaken within the boundaries described below, are not in the public interest then, subject to subsections (b) and (c) of this section, those portions of the Delaware River, bounded and described as follows, are declared to be non-navigable waters of the United States:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b0df186-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59j–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Liberty Landing","children":[],"tail":"."}],"tail":null},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b0df187-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"p","attrib":{},"text":" [Omitted]","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b0df188-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59j–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Marina Towers and World Trade Center—Pier","children":[],"tail":" 25 "},{"tag":"inline","attrib":{},"text":"North","children":[],"tail":"."}],"tail":null},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b0df189-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"p","attrib":{},"text":" [Omitted]","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b0df18a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59j–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Marine Trade Center—Pier","children":[],"tail":" 24 "},{"tag":"inline","attrib":{},"text":"North","children":[],"tail":"."}],"tail":null},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b0df18b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"p","attrib":{},"text":" [Omitted]","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b0df18c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59j–1/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National Sugar Company “Sugar House”","children":[],"tail":"."}],"tail":null},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b0df18d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"p","attrib":{},"text":" [Omitted]","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b0df18e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59j–1/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rivercenter","children":[],"tail":"."}],"tail":null},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b0df18f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"p","attrib":{},"text":" [Omitted]","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b0df190-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59j–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limits on applicability; regulatory requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The declaration under subsection (a) shall apply only to those parts of the areas described in subsection (a) of this section which are or will be bulkheaded and filled or otherwise occupied by permanent structures, including marina facilities. All such work is subject to all applicable Federal statutes and regulations, including, but not necessarily limited to, sections 401 and 403 of this title, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1344"},"text":"section 1344 of this title","children":[],"tail":", and the National Environmental Policy Act of 1969 ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b0df191-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59j–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expiration date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, 20 years from ","children":[{"tag":"date","attrib":{"date":"1988-11-17"},"text":"November 17, 1988","children":[],"tail":", any area or part thereof described in subsection (a) is not bulkheaded or filled or occupied by permanent structures, including marina facilities, in accordance with the requirements set out in subsection (b) of this section, or if work in connection with any activity permitted in subsection (b) is not commenced within 5 years after issuance of such permits, then the declaration of non-navigability for such area or part thereof shall expire. Notwithstanding the preceding sentence, the declaration of nonnavigability for the area described in subsection (a)(5), or any part thereof, shall not expire."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b0df192-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/676/s38"},"text":"Pub. L. 100–676, § 38","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-17"},"text":"Nov. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4032"},"text":"102 Stat. 4032","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/114/tIII/s3181/g"},"text":"Pub. L. 110–114, title III, § 3181(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-11-08"},"text":"Nov. 8, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1162"},"text":"121 Stat. 1162","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tI/s1310"},"text":"Pub. L. 114–322, title I, § 1310","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1694"},"text":"130 Stat. 1694","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b0df193-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b0df194-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6b0df195-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b0df196-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of the boundary descriptions contained in pars. (1) to (5) of subsec. (a), which is not set out in the Code, appears at ","children":[{"tag":"ref","attrib":{"href":"/us/stat/102/4032"},"text":"102 Stat. 4032","children":[],"tail":" to 4038."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b0df197-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322"},"text":"Pub. L. 114–322","children":[],"tail":" struck out “(except 30 years from "},{"tag":"date","attrib":{"date":"1988-11-17"},"text":"November 17, 1988","children":[],"tail":", in the case of the area or any part thereof described in subsection (a)(5))” after “in subsection (a)” and inserted at end “Notwithstanding the preceding sentence, the declaration of nonnavigability for the area described in subsection (a)(5), or any part thereof, shall not expire.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114"},"text":"Pub. L. 110–114","children":[],"tail":" substituted “subsection (a) (except 30 years from "},{"tag":"date","attrib":{"date":"1988-11-17"},"text":"November 17, 1988","children":[],"tail":", in the case of the area or any part thereof described in subsection (a)(5))” for “subsection (a) of this section”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b0df198-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b0df199-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/676/s2"},"text":"section 2 of Pub. L. 100–676","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
