{"tag":"section","attrib":{"id":"id6b31a5e9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467d"},"text":null,"children":[{"tag":"num","attrib":{"value":"467d"},"text":"§ 467d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National inventory of dams and low-head dams","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b31a5ea-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Army shall maintain and update information on the inventory of dams and low-head dams in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b31a5eb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dams","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The inventory maintained under subsection (a) shall include any available information assessing each dam based on inspections completed by a Federal agency, a State dam safety agency, or a Tribal government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b31a5ec-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-head dams","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The inventory maintained under subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b31a5ed-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the location, ownership, description, current use, condition, height, and length of each low-head dam;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b31a5ee-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any information on public safety conditions at each low-head dam; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b31a5ef-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467d/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other relevant information concerning low-head dams.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b31a5f0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b31a5f1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with Federal and State agencies, Tribal governments, and other relevant entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b31a5f2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use data provided to the Secretary by those agencies and entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b31a5f3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make the inventory maintained under subsection (a) publicly available (including on a publicly available website), including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b31a5f4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467d/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public safety information on the dangers of low-head dams; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b31a5f5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467d/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a directory of financial and technical assistance resources available to reduce safety hazards and fish passage barriers at low-head dams.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b31a5f6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467d/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clarification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section provides authority to the Secretary to carry out an activity, with respect to a low-head dam, that is not explicitly authorized under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b31a5f7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467d/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-head dam defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “low-head dam” means a river-wide artificial barrier that generally spans a stream channel, blocking the waterway and creating a backup of water behind the barrier, with a drop off over the wall of not less than 6 inches and not more than 25 feet.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b31a5f8-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/367/s6"},"text":"Pub. L. 92–367, § 6","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/303/tII/s215/c/8"},"text":"Pub. L. 104–303, title II, § 215(c)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3687"},"text":"110 Stat. 3687","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/460/s1/b"},"text":"Pub. L. 109–460, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3401"},"text":"120 Stat. 3401","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dA/tI/s1132/b"},"text":"Pub. L. 118–272, div. A, title I, § 1132(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3021"},"text":"138 Stat. 3021","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b31a5f9-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b31a5fa-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6b31a5fb-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 467d, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/367/s5"},"text":"Pub. L. 92–367, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-08-08"},"text":"Aug. 8, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/507"},"text":"86 Stat. 507","children":[],"tail":", directed Secretary report to Congress on or before "},{"tag":"date","attrib":{"date":"1974-07-01"},"text":"July 1, 1974","children":[],"tail":", on activities under this subchapter, including in report an inventory of dams in the United States, a review of each inspection made, recommendations to State Governors and implementation of those recommendations, recommendations for comprehensive national program for inspection and safety regulation, and recommendations on responsibilities which should be assumed by Federal, State, and local governments and by public and private interests, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/303/tII/s215/c/2"},"text":"Pub. L. 104–303, title II, § 215(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3685"},"text":"110 Stat. 3685","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/367/s6"},"text":"section 6 of Pub. L. 92–367","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s467e"},"text":"section 467e of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/303"},"text":"Pub. L. 104–303","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b31a5fc-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272"},"text":"Pub. L. 118–272","children":[],"tail":" amended section generally. Prior to amendment, text of section read as follows: “The Secretary of the Army shall maintain and update information on the inventory of dams in the United States. Such inventory of dams shall include any available information assessing each dam based on inspections completed by either a Federal agency or a State dam safety agency.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/460"},"text":"Pub. L. 109–460","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “The Secretary of the Army, acting through the Chief of Engineers, may maintain and periodically publish updated information on the inventory of dams in the United States.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
