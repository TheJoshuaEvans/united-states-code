{"tag":"section","attrib":{"id":"id6c22962d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1911"},"text":null,"children":[{"tag":"num","attrib":{"value":"1911"},"text":"§ 1911.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Authorities, requirements, and remedies of this chapter supplement and neither amend nor repeal any other authorities, requirements, or remedies conferred by any other provision of law. Nothing in this chapter shall limit, deny, amend, modify, or repeal any other authority, requirement, or remedy available to the United States or any other person, except as expressly provided in this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6c22962e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/478/s15"},"text":"Pub. L. 96–478, § 15","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-21"},"text":"Oct. 21, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2303"},"text":"94 Stat. 2303","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/280/s11"},"text":"Pub. L. 110–280, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-21"},"text":"July 21, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2615"},"text":"122 Stat. 2615","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c22962f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c229630-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c229631-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/280"},"text":"Pub. L. 110–280","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “Nothing in this chapter shall be construed as limiting, diminishing, or otherwise restricting any of the authority of the Secretary under the Port and Tanker Safety Act of 1978.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
