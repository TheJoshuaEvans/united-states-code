{"tag":"section","attrib":{"id":"id6b0454c0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s25"},"text":null,"children":[{"tag":"num","attrib":{"value":"25"},"text":"§ 25.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cache River, Arkansas","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Cache River in the State of Arkansas is declared to be a nonnavigable stream within the meaning of the Constitution and laws of the United States. This provision shall become void after one year from ","children":[{"tag":"date","attrib":{"date":"1916-07-27"},"text":"July 27, 1916","children":[],"tail":", unless within said period the Legislature of Arkansas shall pass an act expressly approving this declaration. The right of the Congress to alter, amend, or repeal this section is expressly reserved."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b0454c1-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-07-27/ch260/s1"},"text":"July 27, 1916, ch. 260, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/399"},"text":"39 Stat. 399","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b0454c2-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b0454c3-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b0454c4-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was a provision of section 1 of act ","children":[{"tag":"date","attrib":{"date":"1916-07-27"},"text":"July 27, 1916","children":[],"tail":", popularly known as the “Rivers and Harbors Appropriation Act of 1916”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b0454c5-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Approval of Declaration","children":[],"tail":null},{"tag":"p","attrib":{},"text":"See Arkansas Laws 1917, ch. 2, act 406.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
