{"tag":"section","attrib":{"id":"id6c739d0b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903"},"text":null,"children":[{"tag":"num","attrib":{"value":"2903"},"text":"§ 2903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Estuary habitat restoration program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c739d0c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established an estuary habitat restoration program under which the Secretary may carry out estuary habitat restoration projects and provide technical assistance through the award of contracts and cooperative agreements in accordance with the requirements of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c739d0d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Origin of projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A proposed estuary habitat restoration project shall originate from a non-Federal interest consistent with State or local laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c739d0e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c739d0f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall select estuary habitat restoration projects from a list of project proposals submitted by the Estuary Habitat Restoration Council under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2904/b"},"text":"section 2904(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739d10-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each estuary habitat restoration project selected by the Secretary must—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c739d11-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address restoration needs identified in an estuary habitat restoration plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c739d12-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be consistent with the estuary habitat restoration strategy developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2905"},"text":"section 2905 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c739d13-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a monitoring plan that is consistent with standards for monitoring developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2906"},"text":"section 2906 of this title","children":[],"tail":" to ensure that short-term and long-term restoration goals are achieved; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c739d14-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include satisfactory assurance from the non-Federal interests proposing the project that the non-Federal interests will have adequate personnel, funding, and authority to carry out items of local cooperation and properly maintain the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739d15-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors for selection of projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting an estuary habitat restoration project, the Secretary shall consider the following factors:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c739d16-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether the project is part of an approved Federal or State estuary management or habitat restoration plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c739d17-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The technical feasibility of the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c739d18-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The scientific merit of the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c739d19-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether the project will encourage increased coordination and cooperation among Federal, State, and local government agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c739d1a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether the project fosters public-private partnerships and uses Federal resources to encourage increased private sector involvement, including consideration of the amount of private funds or in-kind contributions for an estuary habitat restoration activity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c739d1b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/c/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether the project is cost-effective.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c739d1c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/c/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether the State in which the non-Federal interest is proposing the project has a dedicated source of funding to acquire or restore estuary habitat, natural areas, and open spaces for the benefit of estuary habitat restoration or protection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c739d1d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/c/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other factors that the Secretary determines to be reasonable and necessary for consideration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739d1e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting estuary habitat restoration projects to be carried out under this chapter, the Secretary shall give priority consideration to a project if, in addition to meriting selection based on the factors under paragraph (3)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c739d1f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project occurs within a watershed in which there is a program being carried out that addresses sources of pollution and other activities that otherwise would re-impair the restored habitat; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c739d20-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project includes pilot testing of or a demonstration of an innovative technology or approach having the potential for improved cost-effectiveness in estuary habitat restoration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c739d21-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c739d22-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c739d23-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2) and subsection (e)(2), the Federal share of the cost of an estuary habitat restoration project (other than the cost of operation and maintenance of the project) carried out under this chapter shall not exceed 65 percent of such cost.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c739d24-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c739d25-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The costs of monitoring an estuary habitat restoration project funded under this chapter may be included in the total cost of the estuary habitat restoration project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c739d26-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The goals of the monitoring shall be—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id6c739d27-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/d/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to measure the effectiveness of the restoration project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6c739d28-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/d/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to allow adaptive management to ensure project success.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739d29-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Innovative technology costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the incremental additional cost of including in a project pilot testing of or a demonstration of an innovative technology or approach described in subsection (c)(4)(B) shall be 85 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739d2a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal share of the cost of an estuary habitat restoration project carried out under this chapter shall include lands, easements, rights-of-way, and relocations and may include services (including monitoring), or any other form of in-kind contribution determined by the Secretary to be an appropriate contribution equivalent to the monetary amount required for the non-Federal share of the activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739d2b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation and maintenance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal interests shall be responsible for all costs associated with operating, maintaining, replacing, repairing, and rehabilitating all projects carried out under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c739d2c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim actions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c739d2d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Pending completion of the estuary habitat restoration strategy to be developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2905"},"text":"section 2905 of this title","children":[],"tail":", the Secretary may take interim actions to carry out an estuary habitat restoration activity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739d2e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of an estuary habitat restoration activity before the completion of the estuary habitat restoration strategy shall not exceed 25 percent of such cost.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c739d2f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation of non-Federal interests","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c739d30-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not carry out an estuary habitat restoration project until a non-Federal interest has entered into a written agreement with the Secretary in which the non-Federal interest agrees to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c739d31-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide all lands, easements, rights-of-way, and relocations and any other elements the Secretary determines appropriate under subsection (d)(3); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c739d32-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for long-term maintenance and monitoring of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739d33-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nongovernmental organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1962d–5b/b"},"text":"section 1962d–5b(b) of title 42","children":[],"tail":", for any project to be undertaken under this chapter, the Secretary, in consultation and coordination with appropriate State and local governmental agencies and Indian tribes, may allow a nongovernmental organization to serve as the non-Federal interest for the project."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739d34-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For a project carried out under this chapter, the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2213/j/1"},"text":"section 2213(j)(1) of this title","children":[],"tail":" may be fulfilled by a nongovernmental organization serving as the non-Federal interest for the project pursuant to paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c739d35-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation of project implementation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c739d36-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this chapter, the Secretary may delegate project implementation to another Federal department or agency on a reimbursable basis if the Secretary, upon the recommendation of the Council, determines such delegation is appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739d37-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small projects","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c739d38-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small project defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this paragraph, the term “small project” means a project carried out under this chapter with an estimated Federal cost of less than $1,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c739d39-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation of project implementation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary, on recommendation of the Council, may delegate implementation of a small project to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c739d3a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/g/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Interior (acting through the Director of the United States Fish and Wildlife Service);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c739d3b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/g/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Under Secretary for Oceans and Atmosphere of the Department of Commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c739d3c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/g/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Environmental Protection Agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c739d3d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/g/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c739d3e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A small project delegated to the head of a Federal department or agency under this paragraph may be carried out using funds appropriated to the department or agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2908/a/1"},"text":"section 2908(a)(1) of this title","children":[],"tail":" or other funds available to the department or agency."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c739d3f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2903/g/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The head of a Federal department or agency to which a small project is delegated under this paragraph shall enter into an agreement with the non-Federal interest for the project generally in conformance with the criteria in subsections (d) and (e). Cooperative agreements may be used for any delegated project to allow the non-Federal interest to carry out the project on behalf of the Federal agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c739d40-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/457/tI/s104"},"text":"Pub. L. 106–457, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-07"},"text":"Nov. 7, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1960"},"text":"114 Stat. 1960","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/114/tV/s5017/c"},"text":"Pub. L. 110–114, title V, § 5017(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-11-08"},"text":"Nov. 8, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1197"},"text":"121 Stat. 1197","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tIV/s5013/a"},"text":"Pub. L. 114–322, title IV, § 5013(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1903"},"text":"130 Stat. 1903","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c739d41-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c739d42-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c739d43-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (f)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322"},"text":"Pub. L. 114–322","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s5017/c/1"},"text":"Pub. L. 110–114, § 5017(c)(1)","children":[],"tail":", inserted “through the award of contracts and cooperative agreements” after “assistance”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s5017/c/2/A"},"text":"Pub. L. 110–114, § 5017(c)(2)(A)","children":[],"tail":", inserted “or State” after “Federal”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s5017/c/2/B"},"text":"Pub. L. 110–114, § 5017(c)(2)(B)","children":[],"tail":", inserted “or approach” after “technology”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s5017/c/3/A"},"text":"Pub. L. 110–114, § 5017(c)(3)(A)","children":[],"tail":", designated existing provisions as subpar. (A), inserted heading, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s5017/c/3/B"},"text":"Pub. L. 110–114, § 5017(c)(3)(B)","children":[],"tail":", inserted “or approach” after “technology”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s5017/c/3/C"},"text":"Pub. L. 110–114, § 5017(c)(3)(C)","children":[],"tail":", inserted “(including monitoring)” after “services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s5017/c/4"},"text":"Pub. L. 110–114, § 5017(c)(4)","children":[],"tail":", inserted “long-term” before “maintenance”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s5017/c/5"},"text":"Pub. L. 110–114, § 5017(c)(5)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, and added par. (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
