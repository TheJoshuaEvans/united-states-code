{"tag":"section","attrib":{"id":"id6b0b8132-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s55"},"text":null,"children":[{"tag":"num","attrib":{"value":"55"},"text":"§ 55.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bayou Savage (or Chantilly) in New Orleans","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Bayou Savage, also styled Bayou Chantilly, in the city of New Orleans, Louisiana, is declared to be a nonnavigable waterway within the meaning of the Constitution and laws of the United States.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The right to alter, amend, or repeal this section is expressly reserved.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b0b8133-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-08-16/ch650"},"text":"Aug. 16, 1937, ch. 650","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/649"},"text":"50 Stat. 649","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
