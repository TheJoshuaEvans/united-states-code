{"tag":"section","attrib":{"id":"id6bc3384a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1290"},"text":null,"children":[{"tag":"num","attrib":{"value":"1290"},"text":"§ 1290.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual survey","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Administrator shall annually make a survey to determine the efficiency of the operation and maintenance of treatment works constructed with grants made under this chapter, as compared to the efficiency planned at the time the grant was made. The results of such annual survey shall be included in the report required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1375/a"},"text":"section 1375(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6bc3384b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"June 30, 1948, ch. 758","children":[],"tail":", title II, § 210, as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/500/s2"},"text":"Pub. L. 92–500, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-18"},"text":"Oct. 18, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/843"},"text":"86 Stat. 843","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/362/tV/s501/d/2/D"},"text":"Pub. L. 105–362, title V, § 501(d)(2)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-10"},"text":"Nov. 10, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3284"},"text":"112 Stat. 3284","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/303/tIII/s302/b/1"},"text":"Pub. L. 107–303, title III, § 302(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-27"},"text":"Nov. 27, 2002","children":[],"tail":", "},{"tag":"ref","