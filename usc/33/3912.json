{"tag":"section","attrib":{"id":"id6c904c18-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3912"},"text":null,"children":[{"tag":"num","attrib":{"value":"3912"},"text":"§ 3912.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c904c19-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3912/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c904c1a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3912/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal years 2015 through 2019","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to each of the Secretary and the Administrator to carry out this chapter, to remain available until expended—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c904c1b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3912/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for fiscal year 2015;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904c1c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3912/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $25,000,000 for fiscal year 2016;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904c1d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3912/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $35,000,000 for fiscal year 2017;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904c1e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3912/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $45,000,000 for fiscal year 2018; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904c1f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3912/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,000,000 for fiscal year 2019.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904c20-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3912/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal years 2020 and 2021","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Administrator to carry out this chapter $50,000,000 for each of fiscal years 2020 and 2021, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904c21-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3912/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal years 2022 through 2026","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Administrator to carry out this chapter $50,000,000 for each of fiscal years 2022 through 2026, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c904c22-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3912/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c904c23-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3912/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal years 2015 through 2019","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds made available to carry out this chapter, the Secretary or the Administrator, as applicable, may use for the administration of this chapter, including for the provision of technical assistance to aid project sponsors in obtaining the necessary approvals for the project, not more than $2,200,000 for each of fiscal years 2015 through 2019.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904c24-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3912/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal years after 2019","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds made available to carry out this chapter, the Administrator may use for the administration of this chapter, including for the provision of technical assistance to aid project sponsors in obtaining the necessary approvals for the project, not more than $5,000,000 for each of fiscal years 2022 through 2026.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c904c25-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3912/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small community water infrastructure projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c904c26-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3912/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each fiscal year, the Secretary or the Administrator, as applicable, shall set aside not less than 15 percent of the amounts made available for that fiscal year under this section for small community water infrastructure projects described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3907/a/2/B"},"text":"section 3907(a)(2)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904c27-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3912/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amounts set aside under paragraph (1) that remain unobligated on June 1 of the fiscal year for which the amounts are set aside shall be available for obligation by the Secretary or the Administrator, as applicable, for projects other than small community water infrastructure projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c904c28-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3912/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3908/b/2"},"text":"section 3908(b)(2) of this title","children":[],"tail":", the Secretary or the Administrator, as applicable, may make available up to 25 percent of the amounts made available for each fiscal year under this section for loans in excess of 49 percent of the total project costs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c904c29-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3912/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance for State infrastructure financing authorities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c904c2a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3912/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to fiscal years 2022 through 2026, if the Administrator has available for obligation in a fiscal year at least $50,000,000, there is authorized to be appropriated to the Administrator $5,000,000 for that fiscal year to provide financial assistance for projects described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3905/9"},"text":"section 3905(9) of this title","children":[],"tail":" to State infrastructure financing authorities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904c2b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3912/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No impact on other Federal funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No funds shall be made available in a fiscal year to the Administrator for purposes of this subsection if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c904c2c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3912/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount appropriated for the fiscal year for State loan funds under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300j–12"},"text":"section 300j–12 of title 42","children":[],"tail":" is less than either the amount made available for such purpose in fiscal year 2018, or 105 percent of the previous fiscal year’s appropriation for such purpose, whichever is greater; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904c2d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3912/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount appropriated for the fiscal year for water pollution control revolving funds under title VI of the Federal Water Pollution Control Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1381"},"text":"33 U.S.C. 1381","children":[],"tail":" et seq.] is less than either the amount made available for such purpose for fiscal year 2018, or 105 percent of the previous fiscal year’s appropriation for such purpose, whichever is greater."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904c2e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3912/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion in agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Administrator provides financial assistance to a State infrastructure financing authority under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3908"},"text":"section 3908 of this title","children":[],"tail":" using funds made available pursuant to this subsection, the Administrator shall specify in the agreement under such section the amount of such assistance that is attributable to such funds."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c904c2f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/tV/s5033"},"text":"Pub. L. 113–121, title V, § 5033","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1342"},"text":"128 Stat. 1342","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/270/tIV/s4201/a/4"},"text":"Pub. L. 115–270, title IV, § 4201(a)(4)","children":[],"tail":", (b)(3), "},{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3878"},"text":"132 Stat. 3878","children":[],"tail":", 3879; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dE/tII/s50215/a"},"text":"Pub. L. 117–58, div. E, title II, § 50215(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1174"},"text":"135 Stat. 1174","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c904c30-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c904c31-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c904c32-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Water Pollution Control Act, referred to in subsec (e)(2)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"act June 30, 1948, ch. 758","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/92/500/s2"},"text":"Pub. L. 92–500, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-18"},"text":"Oct. 18, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/816"},"text":"86 Stat. 816","children":[],"tail":", which is classified generally to chapter 26 (§ 1251 et seq.) of this title. Title VI of the Act is classified generally to subchapter VI (§ 1381 et seq.) of chapter 26 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251"},"text":"section 1251 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c904c33-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s50215/a/1"},"text":"Pub. L. 117–58, § 50215(a)(1)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s50215/a/2"},"text":"Pub. L. 117–58, § 50215(a)(2)","children":[],"tail":", substituted “after 2019” for “2020 and 2021” in heading and “2022 through 2026” for “2020 and 2021” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s50215/a/3"},"text":"Pub. L. 117–58, § 50215(a)(3)","children":[],"tail":", substituted “2022 through 2026” for “2020 and 2021”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/s4201/a/4/A"},"text":"Pub. L. 115–270, § 4201(a)(4)(A)","children":[],"tail":", designated existing provisions as par. (1) and inserted heading, substituted “There are” for “There is”, redesignated former pars. (1) to (5) as subpars. (A) to (E), respectively, of par. (1), realigned margins, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/s4201/a/4/B"},"text":"Pub. L. 115–270, § 4201(a)(4)(B)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/s4201/b/3"},"text":"Pub. L. 115–270, § 4201(b)(3)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c904c34-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c904c35-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s2"},"text":"section 2 of Pub. L. 113–121","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
