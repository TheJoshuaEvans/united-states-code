{"tag":"section","attrib":{"id":"id6c67b50e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703"},"text":null,"children":[{"tag":"num","attrib":{"value":"2703"},"text":"§ 2703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Defenses to liability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c67b50f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Complete defenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A responsible party is not liable for removal costs or damages under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2702"},"text":"section 2702 of this title","children":[],"tail":" if the responsible party establishes, by a preponderance of the evidence, that the discharge or substantial threat of a discharge of oil and the resulting damages or removal costs were caused solely by—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c67b510-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an act of God;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c67b511-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an act of war;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c67b512-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an act or omission of a third party, other than an employee or agent of the responsible party or a third party whose act or omission occurs in connection with any contractual relationship with the responsible party (except where the sole contractual arrangement arises in connection with carriage by a common carrier by rail), if the responsible party establishes, by a preponderance of the evidence, that the responsible party—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c67b513-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exercised due care with respect to the oil concerned, taking into consideration the characteristics of the oil and in light of all relevant facts and circumstances; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c67b514-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" took precautions against foreseeable acts or omissions of any such third party and the foreseeable consequences of those acts or omissions; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c67b515-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any combination of paragraphs (1), (2), and (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c67b516-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Defenses as to particular claimants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A responsible party is not liable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2702"},"text":"section 2702 of this title","children":[],"tail":" to a claimant, to the extent that the incident is caused by the gross negligence or willful misconduct of the claimant."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c67b517-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on complete defense","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) does not apply with respect to a responsible party who fails or refuses—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c67b518-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to report the incident as required by law if the responsible party knows or has reason to know of the incident;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c67b519-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide all reasonable cooperation and assistance requested by a responsible official in connection with removal activities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c67b51a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without sufficient cause, to comply with an order issued under subsection (c) or (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1321"},"text":"section 1321 of this title","children":[],"tail":" or the Intervention on the High Seas Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1471"},"text":"33 U.S.C. 1471","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c67b51b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of contractual relationship","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c67b51c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a)(3) the term “contractual relationship” includes, but is not limited to, land contracts, deeds, easements, leases, or other instruments transferring title or possession, unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c67b51d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the real property on which the facility concerned is located was acquired by the responsible party after the placement of the oil on, in, or at the real property on which the facility concerned is located;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c67b51e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more of the circumstances described in subparagraph (A), (B), or (C) of paragraph (2) is established by the responsible party by a preponderance of the evidence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c67b51f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the responsible party complies with paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c67b520-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required circumstance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The circumstances referred to in paragraph (1)(B) are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c67b521-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At the time the responsible party acquired the real property on which the facility is located the responsible party did not know and had no reason to know that oil that is the subject of the discharge or substantial threat of discharge was located on, in, or at the facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c67b522-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The responsible party is a government entity that acquired the facility—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c67b523-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by escheat;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c67b524-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through any other involuntary transfer or acquisition; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c67b525-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through the exercise of eminent domain authority by purchase or condemnation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c67b526-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The responsible party acquired the facility by inheritance or bequest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c67b527-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1)(C), the responsible party must establish by a preponderance of the evidence that the responsible party—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c67b528-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has satisfied the requirements of subsection (a)(3)(A) and (B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c67b529-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has provided full cooperation, assistance, and facility access to the persons that are authorized to conduct removal actions, including the cooperation and access necessary for the installation, integrity, operation, and maintenance of any complete or partial removal action;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c67b52a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in compliance with any land use restrictions established or relied on in connection with the removal action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c67b52b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not impeded the effectiveness or integrity of any institutional control employed in connection with the removal action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c67b52c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reason to know","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c67b52d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate inquiries","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To establish that the responsible party had no reason to know of the matter described in paragraph (2)(A), the responsible party must demonstrate to a court that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c67b52e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on or before the date on which the responsible party acquired the real property on which the facility is located, the responsible party carried out all appropriate inquiries, as provided in subparagraphs (B) and (D), into the previous ownership and uses of the real property on which the facility is located in accordance with generally accepted good commercial and customary standards and practices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c67b52f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the responsible party took reasonable steps to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id6c67b530-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/4/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stop any continuing discharge;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6c67b531-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/4/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent any substantial threat of discharge; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6c67b532-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/4/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent or limit any human, environmental, or natural resource exposure to any previously discharged oil.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c67b533-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations establishing standards and practices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2004-08-09"},"text":"August 9, 2004","children":[],"tail":", the Secretary, in consultation with the Administrator of the Environmental Protection Agency, shall by regulation establish standards and practices for the purpose of satisfying the requirement to carry out all appropriate inquiries under subparagraph (A)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c67b534-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In promulgating regulations that establish the standards and practices referred to in subparagraph (B), the Secretary shall include in such standards and practices provisions regarding each of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c67b535-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The results of an inquiry by an environmental professional.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c67b536-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Interviews with past and present owners, operators, and occupants of the facility and the real property on which the facility is located for the purpose of gathering information regarding the potential for oil at the facility and on the real property on which the facility is located.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c67b537-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/4/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reviews of historical sources, such as chain of title documents, aerial photographs, building department records, and land use records, to determine previous uses and occupancies of the real property on which the facility is located since the property was first developed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c67b538-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/4/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Searches for recorded environmental cleanup liens against the facility and the real property on which the facility is located that are filed under Federal, State, or local law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c67b539-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/4/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reviews of Federal, State, and local government records, waste disposal records, underground storage tank records, and waste handling, generation, treatment, disposal, and spill records, concerning oil at or near the facility and on the real property on which the facility is located.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c67b53a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/4/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Visual inspections of the facility, the real property on which the facility is located, and adjoining properties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c67b53b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/4/C/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Specialized knowledge or experience on the part of the responsible party.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c67b53c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/4/C/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The relationship of the purchase price to the value of the facility and the real property on which the facility is located, if oil was not at the facility or on the real property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c67b53d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/4/C/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Commonly known or reasonably ascertainable information about the facility and the real property on which the facility is located.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c67b53e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/4/C/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The degree of obviousness of the presence or likely presence of oil at the facility and on the real property on which the facility is located, and the ability to detect the oil by appropriate investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c67b53f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim standards and practices","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c67b540-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/4/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Real property purchased before ","children":[{"tag":"date","attrib":{"date":"1997-05-31"},"text":"May 31, 1997","children":[],"tail":null}],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to real property purchased before ","children":[{"tag":"date","attrib":{"date":"1997-05-31"},"text":"May 31, 1997","children":[],"tail":", in making a determination with respect to a responsible party described in subparagraph (A), a court shall take into account—"}],"tail":null},{"tag":"subclause","attrib":{"id":"id6c67b541-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/4/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any specialized knowledge or experience on the part of the responsible party;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6c67b542-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/4/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relationship of the purchase price to the value of the facility and the real property on which the facility is located, if the oil was not at the facility or on the real property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6c67b543-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/4/D/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commonly known or reasonably ascertainable information about the facility and the real property on which the facility is located;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6c67b544-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/4/D/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the obviousness of the presence or likely presence of oil at the facility and on the real property on which the facility is located; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6c67b545-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/4/D/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of the responsible party to detect oil by appropriate inspection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c67b546-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/4/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Real property purchased on or after ","children":[{"tag":"date","attrib":{"date":"1997-05-31"},"text":"May 31, 1997","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to real property purchased on or after ","children":[{"tag":"date","attrib":{"date":"1997-05-31"},"text":"May 31, 1997","children":[],"tail":", until the Secretary promulgates the regulations described in clause (ii), the procedures of the American Society for Testing and Materials, including the document known as “Standard E1527–97”, entitled “Standard Practice for Environmental Site Assessment: Phase I Environmental Site Assessment Process”, shall satisfy the requirements in subparagraph (A)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c67b547-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Site inspection and title search","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of real property for residential use or other similar use purchased by a nongovernmental or noncommercial entity, inspection and title search of the facility and the real property on which the facility is located that reveal no basis for further investigation shall be considered to satisfy the requirements of this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c67b548-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Previous owner or operator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this paragraph or in subsection (a)(3) shall diminish the liability of any previous owner or operator of such facility who would otherwise be liable under this Act. Notwithstanding this paragraph, if a responsible party obtained actual knowledge of the discharge or substantial threat of discharge of oil at such facility when the responsible party owned the facility and then subsequently transferred ownership of the facility or the real property on which the facility is located to another person without disclosing such knowledge, the responsible party shall be treated as liable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2702/a"},"text":"section 2702(a) of this title","children":[],"tail":" and no defense under subsection (a) shall be available to such responsible party."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c67b549-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2703/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on defense","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall affect the liability under this Act of a responsible party who, by any act or omission, caused or contributed to the discharge or substantial threat of discharge of oil which is the subject of the action relating to the facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c67b54a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380/tI/s1003"},"text":"Pub. L. 101–380, title I, § 1003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/491"},"text":"104 Stat. 491","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/293/tVII/s703/c"},"text":"Pub. L. 108–293, title VII, § 703(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1072"},"text":"118 Stat. 1072","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3547/b"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3547(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2328"},"text":"132 Stat. 2328","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXVII/s7701/g/2"},"text":"Pub. L. 119–60, div. G, title LXXVII, § 7701(g)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1836"},"text":"139 Stat. 1836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c67b54b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c67b54c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c67b54d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Intervention on the High Seas Act, referred to in subsec. (c)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/248"},"text":"Pub. L. 93–248","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-02-05"},"text":"Feb. 5, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/8"},"text":"88 Stat. 8","children":[],"tail":", which is classified generally to chapter 28 (§ 1471 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1471"},"text":"section 1471 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (d)(5), (6), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380"},"text":"Pub. L. 101–380","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/484"},"text":"104 Stat. 484","children":[],"tail":", known as the Oil Pollution Act of 1990, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2701"},"text":"section 2701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c67b54e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (d)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" substituted “this subsection” for “this paragraph”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (d)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" inserted “section” before “2702(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293"},"text":"Pub. L. 108–293","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
