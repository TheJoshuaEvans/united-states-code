{"tag":"section","attrib":{"id":"id6b2f5c67-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s451b"},"text":null,"children":[{"tag":"num","attrib":{"value":"451b"},"text":"§ 451b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waters included within subchapter","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b2f5c68-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s451b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “harbor of New York” means the tidal waters of the harbor of New York, its adjacent and tributary waters, and those of Long Island Sound.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b2f5c69-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s451b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “harbor of Hampton Roads” means the tidal waters of the harbors of Norfolk, Portsmouth, Newport News, Hampton Roads, and their adjacent and tributary waters, so much of the Chesapeake Bay and its tributaries as lies within the State of Virginia, and so much of the Atlantic Ocean and its tributaries as lies within the jurisdiction of the United States within or to the east of the State of Virginia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b2f5c6a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s451b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “harbor of Baltimore” means the tidal waters of the harbor of Baltimore and its adjacent and tributary waters, and so much of Chesapeake Bay and its tributaries as lies within the State of Maryland.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b2f5c6b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1888-06-29/ch496/s7"},"text":"June 29, 1888, ch. 496, § 7","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/85/802/s1/8"},"text":"Pub. L. 85–802, § 1(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-28"},"text":"Aug. 28, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/970"},"text":"72 Stat. 970","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b2f5c6c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b2f5c6d-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id6b2f5c6e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on sixtieth day after ","children":[{"tag":"date","attrib":{"date":"1958-08-28"},"text":"Aug. 28, 1958","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/85/802/s2"},"text":"section 2 of Pub. L. 85–802","children":[],"tail":", set out as an Effective Date of 1958 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s441"},"text":"section 441 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
