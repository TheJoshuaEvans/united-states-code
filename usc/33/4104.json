{"tag":"section","attrib":{"id":"id6c9507da-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4104"},"text":null,"children":[{"tag":"num","attrib":{"value":"4104"},"text":"§ 4104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of unmanned maritime systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c9507db-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall coordinate and centralize the acquisition by the Administration of unmanned maritime systems to meet the prioritized list of data requirements identified by OAR and OMAO in carrying out this chapter in their regular assessments and approved by the USEOB.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c9507dc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Memoranda of understanding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to realize greater savings and efficiency, the Administrator may develop and execute a memorandum of agreement with the Secretary of the Navy to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c9507dd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4104/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participate in procurements conducted by the signatories to the memorandum of understanding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9507de-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4104/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept decommissioned unmanned maritime systems from the Navy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9507df-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4104/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop policies and procedures to share unmanned maritime systems; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9507e0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4104/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for other means of creating efficiency and savings in Federal acquisition of unmanned maritime systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c9507e1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to modify Federal procurement law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c9507e2-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/394/s5"},"text":"Pub. L. 115–394, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5285"},"text":"132 Stat. 5285","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
