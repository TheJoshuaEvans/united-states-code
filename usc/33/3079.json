{"tag":"section","attrib":{"id":"id6c7ac7ed-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079"},"text":null,"children":[{"tag":"num","attrib":{"value":"3079"},"text":"§ 3079.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Student pre-commissioning education assistance program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c7ac7ee-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to provide financial assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of maintaining adequate numbers of officers of the commissioned officer corps of the Administration on active duty, the Secretary may provide financial assistance to a person described in subsection (b) for expenses of the person while the person is pursuing on a full-time basis at an accredited educational institution (as determined by the Secretary of Education) a program of education approved by the Secretary that leads to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7ac7ef-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a baccalaureate degree in not more than five academic years; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac7f0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a postbaccalaureate degree.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7ac7f1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible persons","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7ac7f2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person is eligible to obtain financial assistance under subsection (a) if the person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c7ac7f3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is enrolled on a full-time basis in a program of education referred to in subsection (a) at any educational institution described in such subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac7f4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets all of the requirements for acceptance into the commissioned officer corps of the Administration except for the completion of a baccalaureate degree; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac7f5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enters into a written agreement with the Secretary described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac7f6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A written agreement referred to in paragraph (1)(C) is an agreement between the person and the Secretary in which the person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c7ac7f7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agrees to accept an appointment as an officer, if tendered; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac7f8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" upon completion of the person’s educational program, agrees to serve on active duty, immediately after appointment, for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c7ac7f9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" up to three years if the person received less than three years of assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c7ac7fa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" up to five years if the person received at least three years of assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7ac7fb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying expenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Expenses for which financial assistance may be provided under subsection (a) are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7ac7fc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tuition and fees charged by the educational institution involved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac7fd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The cost of educational materials.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac7fe-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a program of education leading to a baccalaureate degree, laboratory expenses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac7ff-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other expenses as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7ac800-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe the amount of financial assistance provided to a person under subsection (a), which may not exceed the amount specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2173/e/2"},"text":"section 2173(e)(2) of title 10","children":[],"tail":", for each year of obligated service that a person agrees to serve in an agreement described in subsection (b)(2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7ac801-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Financial assistance may be provided to a person under subsection (a) for not more than five consecutive academic years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7ac802-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsistence allowance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7ac803-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person who receives financial assistance under subsection (a) shall be entitled to a monthly subsistence allowance at a rate prescribed under paragraph (2) for the duration of the period for which the person receives such financial assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac804-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe monthly rates for subsistence allowance provided under paragraph (1), which shall be equal to the amount specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2144/a"},"text":"section 2144(a) of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7ac805-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial clothing allowance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7ac806-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may prescribe a sum which shall be credited to each person who receives financial assistance under subsection (a) to cover the cost of the person’s initial clothing and equipment issue.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac807-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon completion of the program of education for which a person receives financial assistance under subsection (a) and acceptance of appointment in the commissioned officer corps of the Administration, the person may be issued a subsequent clothing allowance equivalent to that normally provided to a newly appointed officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7ac808-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of financial assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7ac809-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall terminate the assistance provided to a person under this section if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c7ac80a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary accepts a request by the person to be released from an agreement described in subsection (b)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac80b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the misconduct of the person results in a failure to complete the period of active duty required under the agreement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac80c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/h/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person fails to fulfill any term or condition of the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac80d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may require a person who receives assistance described in subsection (c), (f), or (g) under an agreement entered into under subsection (b)(1)(C) to reimburse the Secretary in an amount that bears the same ratio to the total costs of the assistance provided to that person as the unserved portion of active duty bears to the total period of active duty the officer agreed to serve under the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac80e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may waive the service obligation of a person through an agreement entered into under subsection (b)(1)(C) if the person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c7ac80f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/h/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" becomes unqualified to serve on active duty in the commissioned officer corps of the Administration because of a circumstance not within the control of that person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac810-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/h/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c7ac811-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/h/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not physically qualified for appointment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c7ac812-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/h/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determined to be unqualified for service in the commissioned officer corps of the Administration because of a physical or medical condition that was not the result of the person’s own misconduct or grossly negligent conduct.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac813-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obligation as debt to United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An obligation to reimburse the Secretary imposed under paragraph (2) is, for all purposes, a debt owed to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac814-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/h/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discharge in bankruptcy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A discharge in bankruptcy under title 11 that is entered less than five years after the termination of a written agreement entered into under subsection (b)(1)(C) does not discharge the person signing the agreement from a debt arising under such agreement or under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7ac815-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may prescribe such regulations and orders as the Secretary considers appropriate to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7ac816-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Concurrent completion of service obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A service obligation under this section may be completed concurrently with a service obligation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3006"},"text":"section 3006 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c7ac817-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372/tII/s269"},"text":"Pub. L. 107–372, title II, § 269","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/259/tII/s203/a"},"text":"Pub. L. 116–259, title II, § 203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-23"},"text":"Dec. 23, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1163"},"text":"134 Stat. 1163","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
