{"tag":"section","attrib":{"id":"id6b3417d9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467h"},"text":null,"children":[{"tag":"num","attrib":{"value":"467h"},"text":"§ 467h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the end of each odd-numbered fiscal year, the Administrator shall submit a report to Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b3417da-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the status of the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b3417db-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the progress achieved by Federal agencies during the 2 preceding fiscal years in implementing the Federal Guidelines for Dam Safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b3417dc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the progress achieved in dam safety by States participating in the Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b3417dd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes any recommendations for legislative and other action that the Administrator considers necessary.","children":[],"tail