{"tag":"section","attrib":{"id":"id6c3cd491-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2238c"},"text":"§ 2238c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional measures at donor ports and energy transfer ports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c3cd492-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c3cd493-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cargo container","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “cargo container” means a cargo container that is 1 Twenty-foot Equivalent Unit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3cd494-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretionary cargo","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “discretionary cargo” means maritime cargo for which the United States port of unlading is different than the United States port of entry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3cd495-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Donor port","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c3cd496-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “donor port” means a port—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c3cd497-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is subject to the harbor maintenance fee under section 24.24 of title 19, Code of Federal Regulations (or a successor regulation);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c3cd498-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at which the total amount of harbor maintenance taxes collected (including the estimated taxes related to domestic cargo and cruise passengers) comprise not less than $15,000,000 annually of the total funding of the Harbor Maintenance Trust Fund on an average annual basis for the previous 3 fiscal years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c3cd499-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/a/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that received less than 25 percent of the total amount of harbor maintenance taxes collected (including the estimated taxes related to domestic cargo and cruise passengers) at that port in the previous 3 fiscal years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c3cd49a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/a/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is located in a State in which more than 2,000,000 cargo containers were unloaded from or loaded on to vessels on an average annual basis for the previous 3 fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3cd49b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calculation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of calculating the percentage described in subparagraph (A)(iii), payments described under subsection (c)(1) shall not be included.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3cd49c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy commodity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “energy commodity” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c3cd49d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" petroleum products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3cd49e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" natural gas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3cd49f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3cd4a0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wind and solar energy components; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3cd4a1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/a/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" biofuels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3cd4a2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy transfer port","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “energy transfer port” means a port—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c3cd4a3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is subject to the harbor maintenance fee under section 24.24 of title 19, Code of Federal Regulations (or any successor regulation); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3cd4a4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c3cd4a5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/a/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at which energy commodities comprised greater than 25 percent of all commercial activity by tonnage on an average annual basis for the previous 3 fiscal years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c3cd4a6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/a/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through which more than 40,000,000 tons of cargo were transported on an average annual basis for the previous 3 fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3cd4a7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expanded uses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “expanded uses” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2238/f"},"text":"section 2238(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3cd4a8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Harbor maintenance tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “harbor maintenance tax” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2238/f"},"text":"section 2238(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3cd4a9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Harbor maintenance trust fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Harbor Maintenance Trust Fund” means the Harbor Maintenance Trust Fund established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s9505"},"text":"section 9505 of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3cd4aa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medium-sized donor port","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “medium-sized donor port” means a port—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c3cd4ab-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/a/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is subject to the harbor maintenance fee under section 24.24 of title 19, Code of Federal Regulations (or a successor regulation);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3cd4ac-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/a/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at which the total amount of harbor maintenance taxes collected (including the estimated taxes related to domestic cargo and cruise passengers) comprise annually more than $5,000,000 but less than $15,000,000 of the total funding of the Harbor Maintenance Trust Fund on an average annual basis for the previous 3 fiscal years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3cd4ad-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/a/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that received less than 25 percent of the total amount of harbor maintenance taxes collected (including the estimated taxes related to domestic cargo and cruise passengers) at that port in the previous 3 fiscal years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3cd4ae-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/a/9/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is located in a State in which more than 2,000,000 cargo containers were unloaded from or loaded onto vessels on an average annual basis for the previous 3 fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c3cd4af-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c3cd4b0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations, the Secretary may provide to donor ports, medium-sized donor ports, and energy transfer ports amounts in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3cd4b1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts provided under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c3cd4b2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for energy transfer ports shall be divided equally among all States with an energy transfer port;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3cd4b3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be made available to a port as either a donor port, medium-sized donor port, or an energy transfer port, and no port may receive amounts from more than 1 designation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3cd4b4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for donor ports and medium-sized donor ports—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c3cd4b5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of the funds shall be equally divided between the eligible donor ports as authorized by this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c3cd4b6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of the funds shall be divided between the eligible donor ports and eligible medium-sized donor ports based on the percentage of the total harbor maintenance tax revenues generated at each eligible donor port and medium-sized donor port.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c3cd4b7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts provided under this section may be used by a donor port, a medium-sized donor port, or an energy transfer port—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c3cd4b8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide payments to importers entering cargo through that port, as calculated by the Secretary according to the value of discretionary cargo;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3cd4b9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for expanded uses; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3cd4ba-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for environmental remediation related to dredging berths and Federal navigation channels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c3cd4bb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c3cd4bc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a donor port, a medium-sized donor port, or an energy transfer port elects to provide payments to importers under subsection (c), the Secretary shall transfer to the Commissioner of U.S. Customs and Border Protection an amount equal to those payments that would otherwise be provided to the port under this section to provide the payments to the importers of the discretionary cargo that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c3cd4bd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shipped through the port; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3cd4be-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" most at risk of diversion to seaports outside of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3cd4bf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with a port electing to provide payments under subsection (c), shall determine the top importers at the port, as ranked by the value of discretionary cargo, and payments shall be limited to those top importers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c3cd4c0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c3cd4c1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c3cd4c2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $56,000,000 for fiscal year 2023;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3cd4c3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $58,000,000 for fiscal year 2024;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3cd4c4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $60,000,000 for fiscal year 2025;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3cd4c5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $62,000,000 for fiscal year 2026;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3cd4c6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/e/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $64,000,000 for fiscal year 2027;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3cd4c7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/e/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $66,000,000 for fiscal year 2028;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3cd4c8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/e/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $68,000,000 for fiscal year 2029; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3cd4c9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/e/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $70,000,000 for fiscal year 2030.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3cd4ca-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Division between donor ports, medium-sized donor ports, and energy transfer ports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each fiscal year, amounts made available to carry out this section shall be provided in equal amounts to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c3cd4cb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" donor ports and medium-sized donor ports; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3cd4cc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy transfer ports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c3cd4cd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238c/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings clause","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section waives any statutory requirement related to the transportation of merchandise as authorized under chapter 551 of title 46.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c3cd4ce-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/tII/s2106"},"text":"Pub. L. 113–121, title II, § 2106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1280"},"text":"128 Stat. 1280","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tI/s1110"},"text":"Pub. L. 114–322, title I, § 1110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1634"},"text":"130 Stat. 1634","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/tI/s104/a"},"text":"Pub. L. 116–260, div. AA, title I, § 104(a)","children":[],"tail":"–(b)(2), "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2621"},"text":"134 Stat. 2621","children":[],"tail":", 2622.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c3cd4cf-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c3cd4d0-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c3cd4d1-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Reform and Development Act of 2014, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c3cd4d2-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a)(3)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s104/b/1/A/i"},"text":"Pub. L. 116–260, § 104(b)(1)(A)(i)","children":[],"tail":", amended cl. (ii) generally. Prior to amendment, text read as follows: “at which the total amount of harbor maintenance taxes collected comprise not less than $15,000,000 annually of the total funding of the Harbor Maintenance Trust Fund established under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s9505"},"text":"section 9505 of title 26","children":[],"tail":";”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(A)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s104/b/1/A/ii"},"text":"Pub. L. 116–260, § 104(b)(1)(A)(ii)","children":[],"tail":", inserted “(including the estimated taxes related to domestic cargo and cruise passengers)” after “taxes collected” and substituted “3 fiscal years” for “5 fiscal years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(A)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s104/b/1/A/iii"},"text":"Pub. L. 116–260, § 104(b)(1)(A)(iii)","children":[],"tail":", substituted “on an average annual basis for the previous 3 fiscal years” for “in fiscal year 2012”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s104/b/1/B"},"text":"Pub. L. 116–260, § 104(b)(1)(B)","children":[],"tail":", substituted “on an average annual basis for the previous 3 fiscal years” for “in fiscal year 2012” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(8), (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s104/b/1/C"},"text":"Pub. L. 116–260, § 104(b)(1)(C)","children":[],"tail":", added par. (8) and redesignated former par. (8) as (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(9)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s104/b/1/D/i"},"text":"Pub. L. 116–260, § 104(b)(1)(D)(i)","children":[],"tail":", amended subpar. (B) generally. Prior to amendment, text read as follows: “at which the total amount of harbor maintenance taxes collected comprise annually more than $5,000,000 but less than $15,000,000 of the total funding of the Harbor Maintenance Trust Fund established under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s9505"},"text":"section 9505 of title 26","children":[],"tail":";”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(9)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s104/b/1/D/ii"},"text":"Pub. L. 116–260, § 104(b)(1)(D)(ii)","children":[],"tail":", inserted “(including the estimated taxes related to domestic cargo and cruise passengers)” after “taxes collected” and substituted “3 fiscal years” for “5 fiscal years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(9)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s104/b/1/D/iii"},"text":"Pub. L. 116–260, § 104(b)(1)(D)(iii)","children":[],"tail":", substituted “on an average annual basis for the previous 3 fiscal years” for “in fiscal year 2012”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s104/b/2/A"},"text":"Pub. L. 116–260, § 104(b)(2)(A)","children":[],"tail":", redesignated subsec. (f) as (e) and struck out former subsec. (e) which related to report to Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s104/b/2/B"},"text":"Pub. L. 116–260, § 104(b)(2)(B)","children":[],"tail":", amended par. (1) generally. Prior to amendment, text read as follows: “There is authorized to be appropriated to carry out this section $50,000,000 for each of fiscal years 2015 through 2020.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s104/b/2/A"},"text":"Pub. L. 116–260, § 104(b)(2)(A)","children":[],"tail":", redesignated subsec. (g) as (f). Former subsec. (f) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s104/a/1"},"text":"Pub. L. 116–260, § 104(a)(1)","children":[],"tail":", substituted “2022” for “2020”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s104/a/2"},"text":"Pub. L. 116–260, § 104(a)(2)","children":[],"tail":", struck out par. (3). Prior to amendment, text read as follows: “If the target total budget resources under subparagraphs (A) through (D) of "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2238b/b/1"},"text":"section 2238b(b)(1) of this title","children":[],"tail":" are met for each of fiscal years 2016 through 2020, there is authorized to be appropriated to carry out this section $50,000,000 for each of fiscal years 2021 through 2025.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s104/b/2/A"},"text":"Pub. L. 116–260, § 104(b)(2)(A)","children":[],"tail":", redesignated subsec. (g) as (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1110/1/B"},"text":"Pub. L. 114–322, § 1110(1)(B)","children":[],"tail":", added par. (2). Former par. (2) redesignated (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1110/1/C"},"text":"Pub. L. 114–322, § 1110(1)(C)","children":[],"tail":", designated existing provisions as subpar. (A) and inserted heading, redesignated former subpars. (A) to (D) as cls. (i) to (iv), respectively, of subpar. (A), and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1110/1/A"},"text":"Pub. L. 114–322, § 1110(1)(A)","children":[],"tail":", redesignated par. (2) as (3). Former par. (3) redesignated (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1110/1/A"},"text":"Pub. L. 114–322, § 1110(1)(A)","children":[],"tail":", redesignated par. (3) as (4). Former par. (4) redesignated (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1110/1/A"},"text":"Pub. L. 114–322, § 1110(1)(A)","children":[],"tail":", redesignated par. (4) as (5). Former par. (5) redesignated (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1110/1/D"},"text":"Pub. L. 114–322, § 1110(1)(D)","children":[],"tail":", substituted “Code of Federal Regulations” for “Code of Federal Regulation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1110/1/A"},"text":"Pub. L. 114–322, § 1110(1)(A)","children":[],"tail":", redesignated pars. (5) and (6) as (6) and (7), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1110/1/E"},"text":"Pub. L. 114–322, § 1110(1)(E)","children":[],"tail":", added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1110/2/A"},"text":"Pub. L. 114–322, § 1110(2)(A)","children":[],"tail":", substituted “donor ports, medium-sized donor ports,” for “donor ports”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1110/2/B"},"text":"Pub. L. 114–322, § 1110(2)(B)","children":[],"tail":", added subpars. (B) and (C) and struck out former subpar. (B) which read as follows: “shall be made available to a port as either a donor port or an energy transfer port and no port may receive amounts as both a donor port and an energy transfer port.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1110/3/A"},"text":"Pub. L. 114–322, § 1110(3)(A)","children":[],"tail":", substituted “donor port, a medium-sized donor port,” for “donor port” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1110/3/B"},"text":"Pub. L. 114–322, § 1110(3)(B)","children":[],"tail":", struck out “or shippers transporting cargo” after “entering cargo” and substituted “the Secretary” for “U.S. Customs and Border Protection” and “value of discretionary cargo” for “amount of harbor maintenance taxes collected”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1110/4"},"text":"Pub. L. 114–322, § 1110(4)","children":[],"tail":", added subsec. (d) and struck out former subsec. (d). Prior to amendment, text read as follows: “If a donor port or an energy transfer port elects to provide payments to importers or shippers under subsection (c), the Secretary shall transfer the amount that would otherwise be provided to the port under this section that is equal to those payments to the Commissioner of U.S. Customs and Border Protection to provide the payments to the importers or shippers.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1110/5/A"},"text":"Pub. L. 114–322, § 1110(5)(A)","children":[],"tail":", substituted “2020” for “2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1110/5/B"},"text":"Pub. L. 114–322, § 1110(5)(B)","children":[],"tail":", added par. (2) and struck out former par. (2). Prior to amendment, text read as follows: “For each fiscal year, amounts made available to carry out this section shall be provided in equal amounts to donor ports and energy transfer ports.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1110/5/C"},"text":"Pub. L. 114–322, § 1110(5)(C)","children":[],"tail":", substituted “2016 through 2020” for “2015 through 2018” and “2021 through 2025” for “2019 through 2022”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1110/6"},"text":"Pub. L. 114–322, § 1110(6)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c3cd4d3-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6c3cd4d4-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/tI/s104/b/3"},"text":"Pub. L. 116–260, div. AA, title I, § 104(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2622"},"text":"134 Stat. 2622","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/260/dAA/tI/s104/b/3"},"text":"“The amendments made by this subsection [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2022-10-01"},"text":"October 1, 2022","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c3cd4d5-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s2"},"text":"section 2 of Pub. L. 113–121","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
