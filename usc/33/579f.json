{"tag":"section","attrib":{"id":"id6b499ade-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s579f"},"text":null,"children":[{"tag":"num","attrib":{"value":"579f"},"text":"§ 579f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budgetary evaluation metrics and transparency; public participation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b499adf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s579f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b499ae0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s579f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budgetary evaluation metrics and transparency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning in fiscal year 2020, in the formulation of the annual budget request for the U.S. Army Corps of Engineers (Civil Works) pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":", the President shall ensure that such budget request—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b499ae1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s579f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aligns the assessment of the potential benefit-cost ratio for budgeting water resources development projects with that used by the Corps of Engineers during project plan formulation and evaluation pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1962d–17"},"text":"section 1962d–17 of title 42","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b499ae2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s579f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates the transparent criteria and metrics utilized by the President in the evaluation and selection of water resources development projects included in such budget request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b499ae3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s579f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public participation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the development of, or any proposed major substantive modification to, a proposed budget for water resources development projects, the Secretary, through each District shall, not less frequently than annually—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b499ae4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s579f/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to non-Federal interests and other interested stakeholders information on the proposed budget for projects or substantive modifications to project budgets within each District’s jurisdiction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b499ae5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s579f/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold multiple public meetings to discuss the budget for projects within each District’s jurisdiction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b499ae6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s579f/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide to non-Federal interests the opportunity to collaborate with District personnel for projects within each District’s jurisdiction—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b499ae7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s579f/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support information sharing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b499ae8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s579f/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, to share in concept development and decisionmaking to achieve complementary or integrated solutions to problems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b499ae9-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/tI/s1154"},"text":"Pub. L. 115–270, title I, § 1154","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3791"},"text":"132 Stat. 3791","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b499aea-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b499aeb-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b499aec-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/s1154"},"text":"section 1154 of Pub. L. 115–270","children":[],"tail":". Subsec. (a) of "},{"tag":"ref","attrib":{"href":"/us/pl/115/270/s1154"},"text":"section 1154 of Pub. L. 115–270","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s579a"},"text":"section 579a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b499aed-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b499aee-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/s102"},"text":"section 102 of Pub. L. 115–270","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
