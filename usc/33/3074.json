{"tag":"section","attrib":{"id":"id6c7857a2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3074"},"text":null,"children":[{"tag":"num","attrib":{"value":"3074"},"text":"§ 3074.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commissary privileges","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c7857a3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3074/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of privilege","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Commissioned officers, ships’ officers, and members of crews of vessels of the Administration shall be permitted to purchase commissary and quartermaster supplies as far as available from the Armed Forces at the prices charged officers and enlisted members of the Armed Forces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7857a4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3074/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sales of rations, stores, uniforms, and related equipment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may purchase ration supplies for messes, stores, uniforms, accouterments, and related equipment for sale aboard ship and shore stations of the Administration to members of the uniformed services and to personnel assigned to such ships or shore stations. Sales shall be in accordance with regulations prescribed by the Secretary, and proceeds therefrom shall, as far as is practicable, fully reimburse the appropriations charged without regard to fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7857a5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3074/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surviving spouses’ rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rights extended to members of the uniformed services in this section are extended to their surviving spouses and to such others as are designated by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c7857a6-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372/tII/s264"},"text":"Pub. L. 107–372, title II, § 264","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3093"},"text":"116 Stat. 3093","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c7857a7-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c7857a8-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6c7857a9-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s857–4"},"text":"section 857–4 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/107/372"},"text":"Pub. L. 107–372","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
