{"tag":"section","attrib":{"id":"id6b89d810-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s925"},"text":null,"children":[{"tag":"num","attrib":{"value":"925"},"text":"§ 925.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Witness fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Witnesses summoned in a proceeding before a deputy commissioner or whose depositions are taken shall receive the same fees and mileage as witnesses in courts of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b89d811-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-03-04/ch509/s25"},"text":"Mar. 4, 1927, ch. 509, § 25","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1437"},"text":"44 Stat. 1437","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
