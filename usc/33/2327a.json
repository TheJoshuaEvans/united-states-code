{"tag":"section","attrib":{"id":"id6c595dd5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2327a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2327a"},"text":"§ 2327a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rehabilitation of Corps of Engineers constructed pump stations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c595dd6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2327a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c595dd7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2327a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible pump station","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible pump station” means a pump station—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c595dd8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2327a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that is a feature of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c595dd9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2327a/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a federally authorized flood or coastal storm risk management project; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c595dda-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2327a/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an integrated flood risk reduction system that includes a federally authorized flood or coastal storm risk management project; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c595ddb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2327a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the failure of which the Secretary has determined would demonstrably impact the function of the federally authorized flood or coastal storm risk management project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595ddc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2327a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rehabilitation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c595ddd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2327a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “rehabilitation”, with respect to an eligible pump station, means to address a major deficiency of the eligible pump station caused by long-term degradation of the foundation, construction materials, or engineering systems or components of the eligible pump station.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c595dde-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2327a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “rehabilitation”, with respect to an eligible pump station, includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c595ddf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2327a/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the incorporation into the eligible pump station of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id6c595de0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2327a/a/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" current design standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6c595de1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2327a/a/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efficiency improvements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6c595de2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2327a/a/2/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" associated drainage; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c595de3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2327a/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" increasing the capacity of the eligible pump station, subject to the condition that the increase shall—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id6c595de4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2327a/a/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significantly decrease the risk of loss of life and property damage; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6c595de5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2327a/a/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" decrease total lifecycle rehabilitation costs for the eligible pump station.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c595de6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2327a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may carry out rehabilitation of an eligible pump station, if the Secretary determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c595de7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2327a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible pump station has a major deficiency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595de8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2327a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rehabilitation is feasible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c595de9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2327a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The non-Federal interest for the eligible pump station shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c595dea-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2327a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide 35 percent of the cost of rehabilitation of an eligible pump station carried out under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595deb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2327a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide all land, easements, rights-of-way, and necessary relocations associated with the rehabilitation described in subparagraph (A), at no cost to the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c595dec-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2327a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The rehabilitation of an eligible pump station pursuant to this section shall be initiated only after a non-Federal interest has entered into a binding agreement with the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c595ded-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2327a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pay the non-Federal share of the costs of rehabilitation under subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595dee-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2327a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pay 100 percent of the operation and maintenance costs of the rehabilitated eligible pump station, in accordance with regulations promulgated by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c595def-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2327a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rehabilitation of an eligible pump station pursuant to this section shall not be considered to be a separable element of the associated flood risk management project constructed by the Corps of Engineers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c595df0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2327a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $60,000,000, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c595df1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2327a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent practicable, the Secretary shall prioritize the rehabilitation of eligible pump stations under this section that benefit economically disadvantaged communities, as defined by the Secretary under section 160 of the Water Resources Development Act of 2020 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"33 U.S.C. 2201","children":[],"tail":" note), including economically disadvantaged communities located in urban and rural areas."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c595df2-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/tI/s133"},"text":"Pub. L. 116–260, div. AA, title I, § 133","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2647"},"text":"134 Stat. 2647","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dH/tLXXXI/s8152"},"text":"Pub. L. 117–263, div. H, title LXXXI, § 8152","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3733"},"text":"136 Stat. 3733","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c595df3-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c595df4-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c595df5-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 160 of the Water Resources Development Act of 2020, referred to in subsec. (g), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/s160"},"text":"section 160 of div. AA of Pub. L. 116–260","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c595df6-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 2020, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c595df7-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s8152/1"},"text":"Pub. L. 117–263, § 8152(1)","children":[],"tail":", added par. (1) and struck out former par. (1) which defined eligible pump station."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s8152/2"},"text":"Pub. L. 117–263, § 8152(2)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b). Prior to amendment, text read as follows: “The Secretary may carry out rehabilitation of an eligible pump station, if the Secretary determines that the rehabilitation is feasible.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s8152/3"},"text":"Pub. L. 117–263, § 8152(3)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c595df8-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c595df9-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/s2"},"text":"section 2 of div. AA of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
