{"tag":"section","attrib":{"id":"id6c6ee18e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2736"},"text":null,"children":[{"tag":"num","attrib":{"value":"2736"},"text":"§ 2736.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c6ee18f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2736/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sections 2731, 2733, and 2734","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts in the Fund shall be available, without further appropriations and without fiscal year limitation, to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2731"},"text":"section 2731 of this title","children":[],"tail":" in the amount as determined in subsection (b), and to carry out sections 2733 and 2734 of this title, in an amount not to exceed $5,000,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c6ee190-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2736/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of interest only","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of funding to be made available annually to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2731"},"text":"section 2731 of this title","children":[],"tail":" shall be the interest produced by the Fund’s investment of the $22,500,000 remaining funding authorized for the Prince William Sound Oil Spill Recovery Institute and currently deposited in the Fund and invested by the Secretary of the Treasury in income producing securities along with other funds comprising the Fund. The National Pollution Funds Center shall transfer all such accrued interest, including the interest earned from the date funds in the Trans-Alaska Liability Pipeline Fund were transferred into the Oil Spill Liability Trust Fund pursuant to section 8102(a)(2)(B)(ii), to the Prince William Sound Oil Spill Recovery Institute annually, beginning 60 days after "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"October 19, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c6ee191-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2736/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use for section 2712","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning 1 year after the date on which the Secretary, in consultation with the Secretary of the Interior, determines that oil and gas exploration, development, and production in the State of Alaska have ceased, the funding authorized for the Prince William Sound Oil Spill Recovery Institute and deposited in the Fund shall thereafter be made available for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2712"},"text":"section 2712 of this title","children":[],"tail":" in Alaska."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c6ee192-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2736/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Section 2738","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts in the Fund shall be available, without further appropriation and without fiscal year limitation, to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2738/b"},"text":"section 2738(b) of this title","children":[],"tail":", in an annual amount not to exceed $5,000,000 of which up to $3,000,000 may be used for the lease payment to the Alaska SeaLife Center under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2738/b/2"},"text":"section 2738(b)(2) of this title","children":[],"tail":": "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the entire amount is designated by the Congress as an emergency requirement pursuant to section 251(b)(2)(A) of the Balanced Budget and Emergency Deficit Control Act of 1985, as amended ["},{"tag":"ref","attrib":{"href":"/us/usc/t2/s901/b/2/A"},"text":"2 U.S.C. 901(b)(2)(A)","children":[],"tail":"]: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That the entire amount shall be available only to the extent an official budget request that includes designation of the entire amount of the request as an emergency requirement as defined in the Balanced Budget and Emergency Deficit Control Act of 1985, as amended, is transmitted by the President to the Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c6ee193-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380/tV/s5006"},"text":"Pub. L. 101–380, title V, § 5006","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/554"},"text":"104 Stat. 554","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/324/tXI/s1102/b"},"text":"Pub. L. 104–324, title XI, § 1102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3965"},"text":"110 Stat. 3965","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/246/dB/tII/s2204/2"},"text":"Pub. L. 106–246, div. B, title II, § 2204(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-07-13"},"text":"July 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/547"},"text":"114 Stat. 547","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dB/tI/s144/c/1/C"},"text":"Pub. L. 106–554, § 1(a)(4) [div. B, title I, § 144(c)(1)(C)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–239; "},{"tag":"ref","attrib":{"href":"/us/pl/108/293/tVII/s704"},"text":"Pub. L. 108–293, title VII, § 704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1075"},"text":"118 Stat. 1075","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIII/s389/2"},"text":"Pub. L. 109–58, title III, § 389(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/747"},"text":"119 Stat. 747","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tIV/s4413"},"text":"Pub. L. 109–59, title IV, § 4413","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1779"},"text":"119 Stat. 1779","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/241/tIX/s901/j"},"text":"Pub. L. 109–241, title IX, § 901(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/564"},"text":"120 Stat. 564","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c6ee194-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c6ee195-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c6ee196-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 8102(a)(2)(B)(ii), referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380/s8102/a/2/B/ii"},"text":"section 8102(a)(2)(B)(ii) of Pub. L. 101–380","children":[],"tail":", title VIII, "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/565"},"text":"104 Stat. 565","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1653"},"text":"section 1653 of Title 43","children":[],"tail":", Public Lands."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Balanced Budget and Emergency Deficit Control Act of 1985, referred to in subsec. (d), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/177"},"text":"Pub. L. 99–177","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-12"},"text":"Dec. 12, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1038"},"text":"99 Stat. 1038","children":[],"tail":", which enacted chapter 20 (§ 900 et seq.) and sections 654 to 656 of Title 2, The Congress, amended sections 602, 622, 631 to 642, and 651 to 653 of Title 2, sections 1104 to 1106, and 1109 of Title 31, Money and Finance, and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s911"},"text":"section 911 of Title 42","children":[],"tail":", The Public Health and Welfare, repealed "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s661"},"text":"section 661 of Title 2","children":[],"tail":", enacted provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s900"},"text":"section 900 of Title 2","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s911"},"text":"section 911 of Title 42","children":[],"tail":", and amended provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s621"},"text":"section 621 of Title 2","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s900"},"text":"section 900 of Title 2","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c6ee197-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/241"},"text":"Pub. L. 109–241","children":[],"tail":", which directed the insertion of a comma after “"},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"October 1, 2012","children":[],"tail":"”, could not be executed because “"},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"October 1, 2012","children":[],"tail":"” did not appear subsequent to amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":". See 2005 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":" substituted “1 year after the date on which the Secretary, in consultation with the Secretary of the Interior, determines that oil and gas exploration, development, and production in the State of Alaska have ceased,” for “"},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"October 1, 2012","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":", which directed insertion of “annual” before “amount”, was executed by making the insertion before “amount not to exceed”, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293"},"text":"Pub. L. 108–293","children":[],"tail":" in subsec. (c) relating to section 2712, substituted “"},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"October 1, 2012","children":[],"tail":"” for “with the eleventh year following "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"October 19, 1996","children":[],"tail":",” and redesignated subsec. (c) relating to section 2738 as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":" inserted “of which up to $3,000,000 may be used for the lease payment to the Alaska SeaLife Center under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2738/b/2"},"text":"section 2738(b)(2) of this title","children":[],"tail":"” after “$5,000,000” in subsec. (c) relating to section 2738."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/246"},"text":"Pub. L. 106–246","children":[],"tail":" added subsec. (c) relating to section 2738."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/s1102/b/1"},"text":"Pub. L. 104–324, § 1102(b)(1)","children":[],"tail":"–(3), redesignated subsec. (b) as (a), substituted “2731, 2733,” for “2733” in heading, inserted “to carry out "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2731"},"text":"section 2731 of this title","children":[],"tail":" in the amount as determined in subsection (b), and” after “limitation,”, and struck out heading and text of former subsec. (a). Text read as follows: “Amounts in the Fund shall be available, subject to appropriations, and shall remain available until expended, to carry out "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2731"},"text":"section 2731 of this title","children":[],"tail":" as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) $5,000,000 shall be available for the first fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"1990-08-18"},"text":"August 18, 1990","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) $2,000,000 shall be available for each of the 9 fiscal years following the fiscal year described in paragraph (1).”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/s1102/b/4"},"text":"Pub. L. 104–324, § 1102(b)(4)","children":[],"tail":", added subsecs. (b) and (c). Former subsec. (b) redesignated (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c6ee198-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c6ee199-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Investment Amount","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213/tVII/s710"},"text":"Pub. L. 112–213, title VII, § 710","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-20"},"text":"Dec. 20, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1581"},"text":"126 Stat. 1581","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/213/tVII/s710"},"text":"“Not later than 30 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2012-12-20"},"text":"Dec. 20, 2012","children":[],"tail":"], the Secretary of the Treasury shall increase the $22,500,000 invested in income-producing securities for purposes of section 5006(b) of the Oil Pollution Act of 1990 ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2736/b"},"text":"33 U.S.C. 2736(b)","children":[],"tail":") by $12,851,340.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
