{"tag":"section","attrib":{"id":"id6c739d64-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2905"},"text":null,"children":[{"tag":"num","attrib":{"value":"2905"},"text":"§ 2905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Estuary habitat restoration strategy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c739d65-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2905/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2000-11-07"},"text":"November 7, 2000","children":[],"tail":", the Council, "},{"tag":"ref","attrib":{"idref":"fn002131"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002131"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" shall develop an estuary habitat restoration strategy designed to ensure a comprehensive approach to maximize benefits derived from estuary habitat restoration projects and to foster the coordination of Federal and non-Federal activities related to restoration of estuary habitat."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c739d66-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2905/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The goal of the strategy shall be the restoration of 1,000,000 acres of estuary habitat by the year 2010.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c739d67-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2905/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integration of estuary habitat restoration plans, programs, and partnerships","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the estuary habitat restoration strategy, the Council shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c739d68-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2905/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct a review of estuary management or habitat restoration plans and Federal programs established under other laws that authorize funding for estuary habitat restoration activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739d69-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2905/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the estuary habitat restoration strategy is developed in a manner that is consistent with the estuary management or habitat restoration plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c739d6a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2905/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements of the strategy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The estuary habitat restoration strategy shall include proposals, methods, and guidance on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c739d6b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2905/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maximizing the incentives for the creation of new public-private partnerships to carry out estuary habitat restoration projects and the use of Federal resources to encourage increased private sector involvement in estuary habitat restoration activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739d6c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2905/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring that the estuary habitat restoration strategy will be implemented in a manner that is consistent with the estuary management or habitat restoration plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739d6d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2905/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" promoting estuary habitat restoration projects to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c739d6e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2905/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide healthy ecosystems in order to support—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c739d6f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2905/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wildlife, including endangered and threatened species, migratory birds, and resident species of an estuary watershed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c739d70-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2905/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fish and shellfish, including commercial and recreational fisheries;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c739d71-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2905/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve surface and ground water quality and quantity, and flood control;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c739d72-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2905/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide outdoor recreation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c739d73-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2905/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address other areas of concern that the Council determines to be appropriate for consideration;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739d74-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2905/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" addressing the estimated historic losses, estimated current rate of loss, and extent of the threat of future loss or degradation of each type of estuary habitat;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739d75-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2905/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measuring the rate of change for each type of estuary habitat;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739d76-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2905/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" selecting a balance of smaller and larger estuary habitat restoration projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739d77-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2905/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring equitable geographic distribution of projects funded under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c739d78-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2905/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public review and comment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before the Council adopts a final or revised estuary habitat restoration strategy, the Secretary shall publish in the Federal Register a draft of the estuary habitat restoration strategy and provide an opportunity for public review and comment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c739d79-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2905/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic revision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Using data and information developed through project monitoring and management, and other relevant information, the Council may periodically review and update, as necessary, the estuary habitat restoration strategy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c739d7a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/457/tI/s106"},"text":"Pub. L. 106–457, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-07"},"text":"Nov. 7, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1963"},"text":"114 Stat. 1963","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
