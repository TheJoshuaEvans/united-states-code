{"tag":"section","attrib":{"id":"id6c785739-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3046"},"text":null,"children":[{"tag":"num","attrib":{"value":"3046"},"text":"§ 3046.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retired grade and retired pay","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Each officer retired pursuant to law shall be placed on the retired list with the highest grade satisfactorily held by that officer while on active duty including active duty pursuant to recall, under permanent or temporary appointment, and shall receive retired pay based on such highest grade, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c78573a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3046/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the officer’s performance of duty in such highest grade has been satisfactory, as determined by the Secretary of the department or departments under whose jurisdiction the officer served; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c78573b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3046/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless retired for disability, the officer’s length of service in such highest grade is no less than that required by the Secretary of officers retiring under permanent appointment in that grade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c78573c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372/tII/s246"},"text":"Pub. L. 107–372, title II, § 246","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3090"},"text":"116 Stat. 3090","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c78573d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c78573e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6c78573f-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in sections 853p and 857–2 of this title prior to repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372"},"text":"Pub. L. 107–372","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
