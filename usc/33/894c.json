{"tag":"section","attrib":{"id":"id6b7ba768-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894c"},"text":null,"children":[{"tag":"num","attrib":{"value":"894c"},"text":"§ 894c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Change of station","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b7ba769-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Change of station, unit transfer, or change of work location of victims","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b7ba76a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timely consideration and action upon request","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Commerce, acting through the Under Secretary for Oceans and Atmosphere, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b7ba76b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894c/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a member of the commissioned officer corps of the National Oceanic and Atmospheric Administration who was a victim of a sexual assault, in order to reduce the possibility of retaliation or further sexual assault, provide for timely determination and action on an application submitted by the victim for consideration of a change of station or unit transfer of the victim; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b7ba76c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894c/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an employee of the Administration who was a victim of a sexual assault, to the degree practicable and in order to reduce the possibility of retaliation against the employee for reporting the sexual assault, accommodate a request for a change of work location of the victim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7ba76d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b7ba76e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894c/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period for approval and disapproval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Under Secretary, shall ensure that an application or request submitted under paragraph (1) for a change of station, unit transfer, or change of work location is approved or denied within 72 hours of the submission of the application or request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b7ba76f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894c/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If an application or request submitted under paragraph (1) by a victim of a sexual assault for a change of station, unit transfer, or change of work location of the victim is denied—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6b7ba770-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894c/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the victim may request the Secretary to review the denial; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6b7ba771-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894c/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary, acting through the Under Secretary, shall, not later than 72 hours after receiving such request, affirm or overturn the denial.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b7ba772-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Change of station, unit transfer, and change of work location of alleged perpetrators","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b7ba773-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Under Secretary, shall develop a policy for the protection of victims of sexual assault described in subsection (a)(1) by providing the alleged perpetrator of the sexual assault with a change of station, unit transfer, or change of work location, as the case may be, if the alleged perpetrator is a member of the commissioned officer corps of the Administration or an employee of the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7ba774-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The policy required by paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b7ba775-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894c/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A means to control access to the victim.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b7ba776-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894c/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Due process for the victim and the alleged perpetrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b7ba777-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b7ba778-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall promulgate regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7ba779-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consistency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When practicable, the Secretary shall make regulations promulgated under this section consistent with similar regulations promulgated by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b7ba77a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dC/tXXXV/s3544"},"text":"Pub. L. 114–328, div. C, title XXXV, § 3544","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2803"},"text":"130 Stat. 2803","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
