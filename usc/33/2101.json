{"tag":"section","attrib":{"id":"id6c29c227-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2101"},"text":null,"children":[{"tag":"num","attrib":{"value":"2101"},"text":"§ 2101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional statement of findings and purpose","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c29c228-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c29c229-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2101/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" although fishery products provide an important source of protein and industrial products for United States consumption, United States fishery production annually falls far short of satisfying United States demand;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c29c22a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2101/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" overfishing and the degradation of vital fishery resource habitats have caused a reduction in the abundance and diversity of United States fishery resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c29c22b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2101/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" escalated energy costs have had a negative effect on the economics of United States commercial and recreational fisheries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c29c22c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2101/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commercial and recreational fisheries are a prominent factor in United States coastal economies and the direct and indirect returns to the United States economy from commercial and recreational fishing expenditures are threefold; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c29c22d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2101/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" properly designed, constructed, and located artificial reefs in waters covered under this chapter can enhance the habitat and diversity of fishery resources; enhance United States recreational and commercial fishing opportunities; increase the production of fishery products in the United States; increase the energy efficiency of recreational and commercial fisheries; and contribute to the United States and coastal economies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c29c22e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The purpose of this chapter is to promote and facilitate responsible and effective efforts to establish artificial reefs in waters covered under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c29c22f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/623/tII/s202"},"text":"Pub. L. 98–623, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3394"},"text":"98 Stat. 3394","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c29c230-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c29c231-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c29c232-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/623"},"text":"Pub. L. 98–623","children":[],"tail":", which in addition to enacting this chapter also enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1220d"},"text":"section 1220d of Title 16","children":[],"tail":", Conservation, and amended sections 1220, 1220a, 1220b, and 1220c of Title 16."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c29c233-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id6c29c234-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/623/tII/s201"},"text":"Pub. L. 98–623, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3394"},"text":"98 Stat. 3394","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/623/tII/s201"},"text":"“This title [enacting this chapter and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1220d"},"text":"section 1220d of Title 16","children":[],"tail":", Conservation, and amending sections 1220 to 1220c of Title 16] may be cited as the ‘National Fishing Enhancement Act of 1984’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
