{"tag":"section","attrib":{"id":"id6c4d76fd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2298a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2298a"},"text":"§ 2298a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Databases of Corps recreational sites","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall regularly update publicly available databases maintained, or cooperatively maintained, by the Corps of Engineers with information on sites operated or maintained by the Secretary that are used for recreational purposes, including the operational status of, and the recreational opportunities available at, such sites.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6c4d76fe-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/dA/tI/s1121"},"text":"Pub. L. 118–272, div. A, title I, § 1121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3015"},"text":"138 Stat. 3015","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c4d76ff-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c4d7700-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c4d7701-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 2024, and also as part of the Thomas R. Carper Water Resources Development Act of 2024, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c4d7702-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c4d7703-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/dA/s1002"},"text":"section 1002 of div. A of Pub. L. 118–272","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
