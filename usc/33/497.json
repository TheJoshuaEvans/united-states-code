{"tag":"section","attrib":{"id":"id6b38d25b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s497"},"text":null,"children":[{"tag":"num","attrib":{"value":"497"},"text":"§ 497.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Persons” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The word “persons” as used in sections 491 to 494 and 495 to 498 of this title, shall be construed to import both the singular and the plural, as the case demands, and shall include municipalities, quasi-municipal corporations, corporations, companies, and associations.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b38d25c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1906-03-23/ch1130/s7"},"text":"Mar. 23, 1906, ch. 1130, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/86"},"text":"34 Stat. 86","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
