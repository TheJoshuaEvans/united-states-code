{"tag":"section","attrib":{"id":"id6b5a3d1d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"701b–7"},"text":"§ 701b–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplemental reports to Senate Environment and Public Works Committee and House Public Works Committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"After the Secretary of Agriculture has submitted to Congress a regular or formal report made on any examination or survey, pursuant to the Flood Control Act approved ","children":[{"tag":"date","attrib":{"date":"1936-06-22"},"text":"June 22, 1936","children":[],"tail":", as amended and supplemented, a supplemental, additional, or review report or estimate may be made if authorized by law or by resolution of the Committee on Public Works and Transportation of the House of Representatives or the Committee on Environment and Public Works of the Senate."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b5a3d1e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-01-19/ch2/s2"},"text":"Jan. 19, 1948, ch. 2, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/4"},"text":"62 Stat. 4","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/437/s12/d"},"text":"Pub. L. 103–437, § 12(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4590"},"text":"108 Stat. 4590","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b5a3d1f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b5a3d20-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6b5a3d21-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Flood Control Act approved ","children":[{"tag":"date","attrib":{"date":"1936-06-22"},"text":"June 22, 1936","children":[],"tail":", as amended and supplemented, referred to in text, is "},{"tag":"ref","attrib":{"href":"/us/act/1936-06-22/ch688"},"text":"act June 22, 1936, ch. 688","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1570"},"text":"49 Stat. 1570","children":[],"tail":", which to the extent classified to the Code enacted sections 701a, 701b, 701c, 701d to 701f, and 701h of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b5a3d22-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/437"},"text":"Pub. L. 103–437","children":[],"tail":" substituted “Committee on Public Works and Transportation of the House of Representatives or the Committee on Environment and Public Works of the Senate” for “Committee on Public Works of the House of Representatives or the Committee on Public Works of the Senate”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b5a3d23-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id6b5a3d24-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Public Works and Transportation of House of Representatives treated as referring to Committee on Transportation and Infrastructure of House of Representatives by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/14/s1/a"},"text":"section 1(a) of Pub. L. 104–14","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s21"},"text":"section 21 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
