{"tag":"section","attrib":{"id":"id6c760e19-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3010"},"text":null,"children":[{"tag":"num","attrib":{"value":"3010"},"text":"§ 3010.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awards and decorations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Under Secretary may provide ribbons, medals, badges, trophies, and similar devices to members of the commissioned officer corps of the Administration and to members of other uniformed services for service and achievement in support of the missions of the Administration.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6c760e1a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372/tII/s220"},"text":"Pub. L. 107–372, title II, § 220","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXVII/s11704/a"},"text":"Pub. L. 117–263, div. K, title CXVII, § 11704(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4156"},"text":"136 Stat. 4156","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
