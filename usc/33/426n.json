{"tag":"section","attrib":{"id":"id6b2a7aca-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426n"},"text":null,"children":[{"tag":"num","attrib":{"value":"426n"},"text":"§ 426n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance to States and local governments; cost sharing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b2a7acb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426n/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Upon request of the Governor of a State, or the appropriate official of local government, the Secretary is authorized to provide designs, plans, and specifications, and such other technical assistance as he deems advisable to such State or local government for its use in carrying out—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b2a7acc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426n/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects for removing accumulated snags and other debris, and clearing and straightening channels in navigable streams and tributaries thereof; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b2a7acd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426n/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects for renovating navigable streams and tributaries thereof by means of predominantly nonstructural methods judged by the Secretary to be cost effective, for the purpose of improved drainage, water quality, and habitat diversity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b2a7ace-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426n/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The non-Federal share of the cost of any designs, plans, specifications or technical assistance provided under subsection (a) shall be 50 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b2a7acf-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662/tIX/s942"},"text":"Pub. L. 99–662, title IX, § 942","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4199"},"text":"100 Stat. 4199","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b2a7ad0-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b2a7ad1-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b2a7ad2-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
