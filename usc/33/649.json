{"tag":"section","attrib":{"id":"id6b5310e5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s649"},"text":null,"children":[{"tag":"num","attrib":{"value":"649"},"text":"§ 649.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vicksburg Harbor and Ohio River below Cache River","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The harbor at Vicksburg, Mississippi, and the Ohio River from its mouth to the mouth of the Cache River, are transferred to and placed under the control and jurisdiction of the Mississippi River Commission: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That no part of the improvement of the Ohio River, with a view to the construction of locks and dams, shall be considered as transferred to or placed under the control and jurisdiction of the Mississippi River Commission."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b5310e6-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-07-27/ch260/s1"},"text":"July 27, 1916, ch. 260, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/402"},"text":"39 Stat. 402","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b5310e7-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b5310e8-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b5310e9-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from part of section 1 of the Rivers and Harbors Appropriation Act of 1916.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
