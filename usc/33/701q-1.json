{"tag":"section","attrib":{"id":"id6b63b29a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701q–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"701q–1"},"text":"§ 701q–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repair and restoration of embankments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b63b29b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701q–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the request of a non-Federal interest, the Secretary shall assess the cause of damage to, or the failure of, an embankment that is adjacent to the shoreline of a reservoir project owned and operated by the Secretary for which such damage or failure to the embankment has adversely affected a roadway that the Secretary has relocated for construction of the reservoir.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b63b29c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701q–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repair and restoration activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, based on the assessment carried out under subsection (a), the Secretary determines that the cause of the damage to, or the failure of, the embankment is the direct result of the design or operation of the reservoir by the Secretary, the Secretary is authorized to participate in the repair or restoration of such embankment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b63b29d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701q–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary $10,000,000 to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b63b29e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/tI/s147"},"text":"Pub. L. 116–260, div. AA, title I, § 147","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2656"},"text":"134 Stat. 2656","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b63b29f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b63b2a0-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b63b2a1-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/s2"},"text":"section 2 of div. AA of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
