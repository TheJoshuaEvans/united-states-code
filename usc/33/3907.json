{"tag":"section","attrib":{"id":"id6c904b69-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907"},"text":null,"children":[{"tag":"num","attrib":{"value":"3907"},"text":"§ 3907.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of eligibility and project selection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c904b6a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive financial assistance under this chapter, a project shall meet the following criteria, as determined by the Secretary or Administrator, as applicable:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c904b6b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Creditworthiness","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c904b6c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The project and obligor shall be creditworthy, which shall be determined by the Secretary or the Administrator, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904b6d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining the creditworthiness of a project and obligor, the Secretary or the Administrator, as applicable, shall take into consideration relevant factors, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c904b6e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms, conditions, financial structure, and security features of the proposed financing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c904b6f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the dedicated revenue sources that will secure or fund the project obligations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c904b70-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the financial assumptions upon which the project is based; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c904b71-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the financial soundness and credit history of the obligor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904b72-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security features","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary or the Administrator, as applicable, shall ensure that any financing for the project has appropriate security features, such as a rate covenant, supporting the project obligations to ensure repayment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904b73-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rating opinion letters","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c904b74-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/a/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preliminary rating opinion letter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary or the Administrator, as applicable, shall require each project applicant to provide, at the time of application, a preliminary rating opinion letter from at least 1 rating agency indicating that the senior obligations of the project (which may be the Federal credit instrument) have the potential to achieve an investment-grade rating.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c904b75-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/a/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final rating opinion letters","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary or the Administrator, as applicable, shall require each project applicant to provide, prior to final acceptance and financing of the project, a final rating opinion letter from at least 1 rating agency indicating that the senior obligations of the project have an investment-grade rating.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904b76-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for certain combined projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall develop a credit evaluation process for a Federal credit instrument provided to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c904b77-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/a/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State infrastructure financing authority for a project under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3905/9"},"text":"section 3905(9) of this title","children":[],"tail":", which may include requiring the provision of a final rating opinion letter from at least one rating agency; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c904b78-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/a/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity for a project under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3905/10"},"text":"section 3905(10) of this title","children":[],"tail":", which may include requiring the provision of a final rating opinion letter from at least two rating agencies."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904b79-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible project costs","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c904b7a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), the eligible project costs of a project shall be reasonably anticipated to be not less than $20,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904b7b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small community water infrastructure projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For a project described in paragraph (2) or (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3905"},"text":"section 3905 of this title","children":[],"tail":" that serves a community of not more than 25,000 individuals, the eligible project costs of a project shall be reasonably anticipated to be not less than $5,000,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904b7c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dedicated revenue sources","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal credit instrument for the project shall be repayable, in whole or in part, from dedicated revenue sources that also secure the project obligations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904b7d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public sponsorship of private entities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c904b7e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an eligible project is carried out by an entity that is not a State or local government or an agency or instrumentality of a State or local government or a tribal government or consortium of tribal governments, the project shall be publicly sponsored.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904b7f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public sponsorship","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this chapter, a project shall be considered to be publicly sponsored if the obligor can demonstrate, to the satisfaction of the Secretary or the Administrator, as appropriate, that the project applicant has consulted with the affected State, local, or tribal government in which the project is located, or is otherwise affected by the project, and that such government supports the proposed project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904b80-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of existing financing mechanisms","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c904b81-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each eligible project for which the Administrator has authority under paragraph (2) or (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3902/b"},"text":"section 3902(b) of this title","children":[],"tail":" and for which the Administrator has received an application for financial assistance under this chapter, the Administrator shall notify, not later than 30 days after the date on which the Administrator receives a complete application, the applicable State infrastructure financing authority of the State in which the project is located that such application has been submitted."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904b82-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, not later than 60 days after the date of receipt of a notification under subparagraph (A), a State infrastructure financing authority notifies the Administrator that the State infrastructure financing authority intends to commit funds to the project in an amount that is equal to or greater than the amount requested under the application, the Administrator may not provide any financial assistance for that project under this chapter unless—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c904b83-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/a/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the date that is 180 days after the date of receipt of a notification under subparagraph (A), the State infrastructure financing authority fails to enter into an assistance agreement to provide funds for the project; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c904b84-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/a/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the financial assistance to be provided by the State infrastructure financing authority will be at rates and terms that are less favorable than the rates and terms for financial assistance provided under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904b85-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation and maintenance plan","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c904b86-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary or the Administrator, as applicable, shall determine whether an applicant for assistance under this chapter has developed, and identified adequate revenues to implement, a plan for operating, maintaining, and repairing the project over the useful life of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904b87-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible project described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3905/1"},"text":"section 3905(1) of this title","children":[],"tail":" that has not been specifically authorized by Congress shall not be eligible for Federal assistance for operations and maintenance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c904b88-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c904b89-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary or the Administrator, as applicable, shall establish criteria for the selection of projects that meet the eligibility requirements of subsection (a), in accordance with paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904b8a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The selection criteria shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c904b8b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The extent to which the project is nationally or regionally significant, with respect to the generation of economic and public benefits, such as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c904b8c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reduction of flood risk;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c904b8d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the improvement of water quality and quantity, including aquifer recharge;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c904b8e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the protection of drinking water, including source water protection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c904b8f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the support of international commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904b90-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The extent to which the project financing plan includes public or private financing in addition to assistance under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904b91-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The likelihood that assistance under this chapter would enable the project to proceed at an earlier date than the project would otherwise be able to proceed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904b92-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The extent to which the project uses new or innovative approaches.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904b93-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of budget authority required to fund the Federal credit instrument made available under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904b94-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The extent to which the project—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c904b95-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/b/2/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protects against extreme weather events, such as floods or hurricanes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c904b96-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/b/2/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" helps maintain or protect the environment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904b97-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The extent to which a project serves regions with significant energy exploration, development, or production areas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904b98-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The extent to which a project serves regions with significant water resource challenges, including the need to address—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c904b99-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/b/2/H/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water quality concerns in areas of regional, national, or international significance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c904b9a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/b/2/H/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water quantity concerns related to groundwater, surface water, or other water sources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c904b9b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/b/2/H/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significant flood risk;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c904b9c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/b/2/H/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water resource challenges identified in existing regional, State, or multistate agreements; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c904b9d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/b/2/H/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water resources with exceptional recreational value or ecological importance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904b9e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The extent to which the project addresses identified municipal, State, or regional priorities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904b9f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/b/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The readiness of the project to proceed toward development, including a demonstration by the obligor that there is a reasonable expectation that the contracting process for construction of the project can commence by not later than 90 days after the date on which a Federal credit instrument is obligated for the project under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904ba0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/b/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The extent to which assistance under this chapter reduces the contribution of Federal assistance to the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904ba1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for certain combined projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For a project described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3905/9"},"text":"section 3905(9) of this title","children":[],"tail":", the Administrator shall only consider the criteria described in subparagraphs (B) through (K) of paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c904ba2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3907/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section supersedes the applicability of other requirements of Federal law (including regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c904ba3-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/tV/s5028"},"text":"Pub. L. 113–121, title V, § 5028","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1335"},"text":"128 Stat. 1335","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tI/s1445"},"text":"Pub. L. 114–94, div. A, title I, § 1445","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1437"},"text":"129 Stat. 1437","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tIV/s5008/b/2/D"},"text":"Pub. L. 114–322, title IV, § 5008(b)(2)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1897"},"text":"130 Stat. 1897","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/270/tIV/s4201/a/2"},"text":"Pub. L. 115–270, title IV, § 4201(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3877"},"text":"132 Stat. 3877","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dE/tII/s50214"},"text":"Pub. L. 117–58, div. E, title II, § 50214","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1173"},"text":"135 Stat. 1173","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c904ba4-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c904ba5-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c904ba6-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(1)(D)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" substituted “a final rating opinion letter from at least 1 rating agency” for “final rating opinion letters from at least 2 rating agencies”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270"},"text":"Pub. L. 115–270","children":[],"tail":" amended subpar. (E) generally. Prior to amendment, text read as follows: “The Administrator shall develop a credit evaluation process for a Federal credit instrument provided to a State infrastructure financing authority for a project under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s3905/9"},"text":"section 3905(9) of this title","children":[],"tail":" or an entity for a project under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s3905/10"},"text":"section 3905(10) of this title","children":[],"tail":", which may include requiring the provision of a final rating opinion letter from at least 2 rating agencies.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s5008/b/2/D/i"},"text":"Pub. L. 114–322, § 5008(b)(2)(D)(i)","children":[],"tail":", substituted “section 3905(9)” for “section 3905(8)” and “section 3905(10)” for “section 3905(9)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s5008/b/2/D/ii"},"text":"Pub. L. 114–322, § 5008(b)(2)(D)(ii)","children":[],"tail":", substituted “section 3905(9)” for “section 3905(8)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(5) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" redesignated pars. (6) and (7) as (5) and (6), respectively, and struck out former par. (5). Prior to amendment, text of par. (5) read as follows: “No project receiving Federal credit assistance under this chapter may be financed (directly or indirectly), in whole or in part, with proceeds of any obligation—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the interest on which is exempt from the tax imposed under chapter 1 of title 26; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) with respect to which credit is allowable under subpart I or J of part IV of subchapter A of chapter 1 of title 26.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c904ba7-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6c904ba8-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1003"},"text":"section 1003 of Pub. L. 114–94","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c904ba9-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s2"},"text":"section 2 of Pub. L. 113–121","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
