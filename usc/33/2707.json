{"tag":"section","attrib":{"id":"id6c67b5c1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2707"},"text":null,"children":[{"tag":"num","attrib":{"value":"2707"},"text":"§ 2707.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery by foreign claimants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c67b5c2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2707/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required showing by foreign claimants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c67b5c3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2707/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to satisfying the other requirements of this Act, to recover removal costs or damages resulting from an incident a foreign claimant shall demonstrate that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c67b5c4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2707/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the claimant has not been otherwise compensated for the removal costs or damages; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c67b5c5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2707/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recovery is authorized by a treaty or executive agreement between the United States and the claimant’s country, or the Secretary of State, in consultation with the Attorney General and other appropriate officials, has certified that the claimant’s country provides a comparable remedy for United States claimants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c67b5c6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2707/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1)(B) shall not apply with respect to recovery by a resident of Canada in the case of an incident described in subsection (b)(4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c67b5c7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2707/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discharges in foreign countries","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A foreign claimant may make a claim for removal costs and damages resulting from a discharge, or substantial threat of a discharge, of oil in or on the territorial sea, internal waters, or adjacent shoreline of a foreign country, only if the discharge is from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c67b5c8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2707/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Outer Continental Shelf facility or a deepwater port;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c67b5c9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2707/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel in the navigable waters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c67b5ca-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2707/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel carrying oil as cargo between 2 places in the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c67b5cb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2707/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a tanker that received the oil at the terminal of the pipeline constructed under the Trans-Alaska Pipeline Authorization Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1651"},"text":"43 U.S.C. 1651","children":[],"tail":" et seq.), for transportation to a place in the United States, and the discharge or threat occurs prior to delivery of the oil to that place."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c67b5cc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2707/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Foreign claimant” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “foreign claimant” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c67b5cd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2707/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person residing in a foreign country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c67b5ce-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2707/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the government of a foreign country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c67b5cf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2707/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agency or political subdivision of a foreign country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c67b5d0-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380/tI/s1007"},"text":"Pub. L. 101–380, title I, § 1007","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/496"},"text":"104 Stat. 496","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c67b5d1-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c67b5d2-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c67b5d3-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380"},"text":"Pub. L. 101–380","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/484"},"text":"104 Stat. 484","children":[],"tail":", known as the Oil Pollution Act of 1990, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2701"},"text":"section 2701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Trans-Alaska Pipeline Authorization Act, referred to in subsec. (b)(4), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/153"},"text":"Pub. L. 93–153","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-11-16"},"text":"Nov. 16, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/584"},"text":"87 Stat. 584","children":[],"tail":", which is classified generally to chapter 34 (§ 1651 et seq.) of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1651"},"text":"section 1651 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
