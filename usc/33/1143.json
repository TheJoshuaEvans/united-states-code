{"tag":"section","attrib":{"id":"id6b983014-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1143"},"text":null,"children":[{"tag":"num","attrib":{"value":"1143"},"text":"§ 1143.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b983015-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1143/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the Program, the Secretary shall make competitive grants to support new and established local and regional training, education, outreach, and technical assistance initiatives for young fishermen, including programs, workshops, and services relating to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b983016-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1143/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seamanship, navigation, electronics, and safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b983017-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1143/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vessel and engine care, maintenance, and repair;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b983018-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1143/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" innovative conservation fishing gear engineering and technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b983019-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1143/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sustainable fishing practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b98301a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1143/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entrepreneurship and good business practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b98301b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1143/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct marketing, supply chain, and traceability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b98301c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1143/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial and risk management, including vessel, permit, and quota purchasing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b98301d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1143/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and Federal legal requirements for specific fisheries, including reporting, monitoring, licenses, and regulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b98301e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1143/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and Federal fisheries policy and management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b98301f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1143/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mentoring, apprenticeships, or internships; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b983020-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1143/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other activities, opportunities, or programs, as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b983021-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1143/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b983022-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1143/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under the Program, a recipient shall be a collaborative State, Tribal, local, or regionally based network or partnership of public or private entities, which may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b983023-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1143/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Sea Grant Institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b983024-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1143/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal or State agency or a Tribal organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b983025-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1143/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a community-based nongovernmental organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b983026-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1143/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fishermen’s cooperatives or associations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b983027-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1143/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education (including an institution awarding an associate’s degree), or a foundation maintained by an institution of higher education; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b983028-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1143/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other appropriate entity, as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b983029-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1143/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All young fishermen seeking to participate in the commercial fisheries of the United States and the Great Lakes are eligible to participate in the activities funded through grants provided for in this section, except that participants in such activities shall be selected by each grant recipient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b98302a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1143/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum term and amount of grant","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b98302b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1143/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant under this section shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b98302c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1143/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a term of no more than 3 fiscal years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b98302d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1143/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be in an amount that is not more than $200,000 for each fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b98302e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1143/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consecutive grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible recipient may receive consecutive grants under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b98302f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1143/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under this section, a recipient shall provide a match in the form of cash or in-kind contributions from the recipient in the amount equal to or greater than 25 percent of the funds provided by the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b983030-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1143/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional balance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making grants under this section, the Secretary shall, to the maximum extent practicable, ensure geographic diversity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b983031-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1143/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation and evaluation criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section and in developing criteria for evaluating grant applications, the Secretary shall consult, to the maximum extent practicable, with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b983032-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1143/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sea Grant Institutions and extension agents of such institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b983033-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1143/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community-based nongovernmental fishing organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b983034-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1143/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal and State agencies, including Regional Fishery Management Councils established under the Magnuson-Stevens Fishery Conservation and Management Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1851"},"text":"16 U.S.C. 1851","children":[],"tail":" et seq.); "},{"tag":"ref","attrib":{"idref":"fn002049"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002049"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b983035-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1143/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions of higher education with fisheries expertise and programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b983036-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1143/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" partners, as the Secretary determines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b983037-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1143/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant under this section may not be used to purchase any fishing license, permit, quota, or other harvesting right.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b983038-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/289/s4"},"text":"Pub. L. 116–289, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4886"},"text":"134 Stat. 4886","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b983039-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b98303a-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6b98303b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Magnuson-Stevens Fishery Conservation and Management Act, referred to in subsec. (f)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/265"},"text":"Pub. L. 94–265","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-13"},"text":"Apr. 13, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/331"},"text":"90 Stat. 331","children":[],"tail":", which is classified principally to chapter 38 (§ 1801 et seq.) of Title 16, Conservation. Title III of the Act is classified generally to subchapter IV (§ 1851 et seq.) of chapter 38 of Title 16. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1801"},"text":"section 1801 of Title 16","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b98303c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Young Fishermen’s Development Act, and not as part of titles I and II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/454"},"text":"Pub. L. 89–454","children":[],"tail":" which comprise this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
