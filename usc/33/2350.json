{"tag":"section","attrib":{"id":"id6c62f9f7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2350"},"text":null,"children":[{"tag":"num","attrib":{"value":"2350"},"text":"§ 2350.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corrosion prevention","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c62f9f8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2350/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the greatest extent practicable, the Secretary shall encourage and incorporate corrosion prevention activities at water resources development projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c62f9f9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2350/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (a), the Secretary, to the greatest extent practicable, shall ensure that contractors performing work for water resources development projects—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c62f9fa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2350/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use best practices to carry out corrosion prevention activities in the field;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62f9fb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2350/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" use industry-recognized standards and corrosion mitigation and prevention methods when—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c62f9fc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2350/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determining protective coatings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c62f9fd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2350/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" selecting materials; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c62f9fe-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2350/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determining methods of cathodic protection, design, and engineering for corrosion prevention;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62f9ff-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2350/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use certified coating application specialists and cathodic protection technicians and engineers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62fa00-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2350/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use best practices in environmental protection to prevent environmental degradation and to ensure careful handling of all hazardous materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62fa01-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2350/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate a history of employing industry-certified inspectors to ensure adherence to best practices and standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62fa02-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2350/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate a history of compliance with applicable requirements of the Occupational Safety and Health Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c62fa03-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2350/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corrosion prevention activities defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “corrosion prevention activities” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c62fa04-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2350/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application and inspection of protective coatings for complex work involving steel and cementitious structures, including structures that will be exposed in immersion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62fa05-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2350/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the installation, testing, and inspection of cathodic protection systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62fa06-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2350/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the carrying out of an activity described in paragraph (1) or (2) through a program in corrosion prevention that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c62fa07-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2350/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offered or accredited by an organization that sets industry standards for corrosion mitigation and prevention; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c62fa08-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2350/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an industrial coatings applicator program that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c62fa09-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2350/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employment and training activity (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3102"},"text":"section 3102 of title 29","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c62fa0a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2350/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" registered under the Act of ","children":[{"tag":"date","attrib":{"date":"1937-08-16"},"text":"August 16, 1937","children":[],"tail":" (commonly known as the “National Apprenticeship Act”; "},{"tag":"ref","attrib":{"href":"/us/stat/50/664"},"text":"50 Stat. 664","children":[],"tail":", chapter 663; "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s50"},"text":"29 U.S.C. 50","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62fa0b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2350/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other activities related to corrosion prevention the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c62fa0c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2350/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the first annual report submitted to Congress after ","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":", in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s556"},"text":"section 556 of this title","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2295/b"},"text":"section 2295(b) of this title","children":[],"tail":", the Secretary shall report on the corrosion prevention activities encouraged under this section, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c62fa0d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2350/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the actions the Secretary has taken to implement this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62fa0e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2350/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the projects utilizing corrosion prevention activities, including which activities were undertaken.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c62fa0f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/tI/s1033"},"text":"Pub. L. 113–121, title I, § 1033","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1233"},"text":"128 Stat. 1233","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tI/s1142"},"text":"Pub. L. 114–322, title I, § 1142","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1658"},"text":"130 Stat. 1658","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dA/tI/s1135"},"text":"Pub. L. 118–272, div. A, title I, § 1135","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3025"},"text":"138 Stat. 3025","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c62fa10-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c62fa11-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c62fa12-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Apprenticeship Act, referred to in subsec. (c)(3)(B)(ii), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-08-16/ch663"},"text":"act Aug. 16, 1937, ch. 663","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/664"},"text":"50 Stat. 664","children":[],"tail":", which is classified generally to chapter 4C (§ 50 et seq.) of Title 29, Labor. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s50"},"text":"section 50 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c62fa13-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Reform and Development Act of 2014, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c62fa14-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272"},"text":"Pub. L. 118–272","children":[],"tail":" added par. (3) and redesignated former par. (3) as (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322"},"text":"Pub. L. 114–322","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c62fa15-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c62fa16-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s2"},"text":"section 2 of Pub. L. 113–121","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
