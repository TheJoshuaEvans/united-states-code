{"tag":"section","attrib":{"id":"id6c0aa103-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1414a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1414a"},"text":"§ 1414a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special provisions regarding certain dumping sites","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c0aa104-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1414a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New York Bight Apex","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c0aa105-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1414a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c0aa106-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1414a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Apex” means the New York Bight Apex consisting of the ocean waters of the Atlantic Ocean westward of 73 degrees 30 minutes west longitude and northward of 40 degrees 10 minutes north latitude.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c0aa107-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1414a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Apex site” means that site within the Apex at which the dumping of municipal sludge occurred before ","children":[{"tag":"date","attrib":{"date":"1983-10-01"},"text":"October 1, 1983","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c0aa108-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1414a/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “eligible authority” means any sewerage authority or other unit of State or local government that on November 2, 1983, was authorized under court order to dump municipal sludge at the Apex site.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0aa109-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1414a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No person may apply for a permit under this subchapter in relation to the dumping of, or the transportation for purposes of dumping, municipal sludge within the Apex unless that person is an eligible authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0aa10a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1414a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Administrator may not issue, or renew, any permit under this subchapter that authorizes the dumping of, or the transportation for purposes of dumping, municipal sludge within the Apex after the earlier of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c0aa10b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1414a/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"1987-12-15"},"text":"December 15, 1987","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c0aa10c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1414a/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the day determined by the Administrator to be the first day on which municipal sludge generated by eligible authorities can reasonably be dumped at a site designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1412"},"text":"section 1412 of this title","children":[],"tail":" other than a site within the Apex."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c0aa10d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1414a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction on use of 106-mile site","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may not issue or renew any permit under this subchapter which authorizes any person, other than a person that is an eligible authority within the meaning of subsection (a)(1)(C), to dump, or to transport for the purposes of dumping, municipal sludge within the site designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1412/c"},"text":"section 1412(c) of this title","children":[],"tail":" by the Administrator and known as the “106-Mile Ocean Waste Dump Site” (as described in 49 F.R. 19005)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c0aa10e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/532/tI/s104A"},"text":"Pub. L. 92–532, title I, § 104A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/662/tXI/s1172/b"},"text":"Pub. L. 99–662, title XI, § 1172(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4259"},"text":"100 Stat. 4259","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/4/tV/s508/b"},"text":"Pub. L. 100–4, title V, § 508(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-02-04"},"text":"Feb. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/79"},"text":"101 Stat. 79","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/688/tI/s1002"},"text":"Pub. L. 100–688, title I, § 1002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4139"},"text":"102 Stat. 4139","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c0aa10f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c0aa110-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c0aa111-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/688"},"text":"Pub. L. 100–688","children":[],"tail":" repealed the second of two identical sections 104A of "},{"tag":"ref","attrib":{"href":"/us/pl/92/532"},"text":"Pub. L. 92–532","children":[],"tail":", both classified to this section and enacted by "},{"tag":"ref","attrib":{"href":"/us/pl/99/662"},"text":"Pub. L. 99–662","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/100/4"},"text":"Pub. L. 100–4","children":[],"tail":", thereby involving no change in text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c0aa112-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c0aa113-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"New York Bight Apex Not Suitable for Dumping","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662/tXI/s1172/a"},"text":"Pub. L. 99–662, title XI, § 1172(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4259"},"text":"100 Stat. 4259","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/662/tXI/s1172/a"},"text":"“The Congress finds that the New York Bight Apex is no longer a suitable location for the ocean dumping of municipal sludge.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"An identical provision was enacted by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/4/tV/s508/a"},"text":"Pub. L. 100–4, title V, § 508(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-02-04"},"text":"Feb. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/79"},"text":"101 Stat. 79","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
