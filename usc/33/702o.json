{"tag":"section","attrib":{"id":"id6b689591-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s702o"},"text":null,"children":[{"tag":"num","attrib":{"value":"702o"},"text":"§ 702o.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mississippi River and Tributaries Project","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b689592-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s702o/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After any flood event requiring operation or activation of any floodway or backwater feature within the Mississippi River and Tributaries Project through natural overtopping of a Federal levee or artificial crevassing of a Federal levee to relieve pressure on the levees elsewhere in the system, the Secretary shall expeditiously reset and restore the damaged floodway’s levees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b689593-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s702o/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out subsection (a), the Secretary shall provide an opportunity for consultation with affected communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b689594-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s702o/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mississippi River and Tributaries Project","children":[],"tail":null},