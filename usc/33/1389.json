{"tag":"section","attrib":{"id":"id6c05e661-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1389"},"text":null,"children":[{"tag":"num","attrib":{"value":"1389"},"text":"§ 1389.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clean watersheds needs survey","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c05e662-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1389/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", and not less frequently than once every 4 years thereafter, the Administrator shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c05e663-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1389/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct and complete an assessment of capital improvement needs for all projects that are eligible under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1383/c"},"text":"section 1383(c) of this title","children":[],"tail":" for assistance from State water pollution control revolving funds; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c05e664-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1389/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to Congress a report describing the results of the assessment completed under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c05e665-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1389/b"},"text":null,"child