{"tag":"section","attrib":{"id":"id6c86af7d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3605"},"text":null,"children":[{"tag":"num","attrib":{"value":"3605"},"text":"§ 3605.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application with other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter supersedes or limits the authority of any agency to carry out its responsibilities and missions under other laws.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6c86af7e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tXII/s12306"},"text":"Pub. L. 111–11, title XII, § 12306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1435"},"text":"123 Stat. 1435","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
