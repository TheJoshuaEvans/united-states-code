{"tag":"section","attrib":{"id":"id6c43d9d0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281"},"text":null,"children":[{"tag":"num","attrib":{"value":"2281"},"text":"§ 2281.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matters to be addressed in planning","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c43d9d1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Enhancing national economic development (including benefits to particular regions of the Nation not involving the transfer of economic activity to such regions from other regions), the quality of the total environment (including preservation and enhancement of the environment), the well-being of the people of the United States, the prevention of loss of life, and the preservation of cultural and historical values shall be addressed in the formulation and evaluation of water resources projects to be carried out by the Secretary, and the associated benefits and costs, both quantifiable and unquantifiable, and information regarding potential loss of human life that may be associated with flooding and coastal storm events, shall be displayed in the benefits and costs of such projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c43d9d2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For all feasibility reports for water resources projects completed after ","children":[{"tag":"date","attrib":{"date":"2007-12-31"},"text":"December 31, 2007","children":[],"tail":", the Secretary shall assess whether—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c43d9d3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the water resources project and each separable element is cost-effective; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c43d9d4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the water resources project complies with Federal, State, and local laws (including regulations) and public policies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c43d9d5-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662/tIX/s904"},"text":"Pub. L. 99–662, title IX, § 904","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4185"},"text":"100 Stat. 4185","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/640/tIII/s315"},"text":"Pub. L. 101–640, title III, § 315","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4641"},"text":"104 Stat. 4641","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/303/tII/s231"},"text":"Pub. L. 104–303, title II, § 231","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3704"},"text":"110 Stat. 3704","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us