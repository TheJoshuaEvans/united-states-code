l":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/303"},"text":"Pub. L. 104–303","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b368800-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1132/d/1/A"},"text":"Pub. L. 118–272, § 1132(d)(1)(A)","children":[],"tail":", substituted “2028” for “2023”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A)(ii)(I), (II). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1132/d/1/B/i"},"text":"Pub. L. 118–272, § 1132(d)(1)(B)(i)","children":[],"tail":", inserted “and low-head dams” after “inventory of dams”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1132/d/1/B/ii"},"text":"Pub. L. 118–272, § 1132(d)(1)(B)(ii)","children":[],"tail":", amended subpar. (B) generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—The amount of funds allocated to a State under this paragraph may not exceed 50 percent of the reasonable cost of implementing the State dam safety program."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) ","children":[{"tag":"inline","attrib":{},"text":"Fiscal year 2015 and subsequent fiscal years","children":[],"tail":".—For fiscal year 2015 and each subsequent fiscal year, the amount of funds allocated to a State under this paragraph may not exceed the amount of funds committed by the State to implement dam safety activities.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1132/d/2"},"text":"Pub. L. 118–272, § 1132(d)(2)","children":[],"