{"tag":"section","attrib":{"id":"id6b3417eb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467j"},"text":null,"children":[{"tag":"num","attrib":{"value":"467j"},"text":"§ 467j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b3417ec-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National dam safety program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b3417ed-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467j/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to FEMA to carry out sections 467e, 467f, and 467h of this title (in addition to any amounts made available for similar purposes included in any other Act and amounts made available under subsections (b) through (e)), $9,200,000 for each of fiscal years 2019 through 2028, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b3687ee-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467j/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b3687ef-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467j/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subparagraphs (B) and (C), for each fiscal year, amounts made available under this subsection to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s467f"},"text":"section 467f of this title","children":[],"tail":" shall be allocated among the States as follows:"}],"tail":null},{"tag":"clause","attrib":{"id":"id6b3687f0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467j/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One-third among States that qualify for assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s467f/e"},"text":"section 467f(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6b3687f1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467j/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Two-thirds among States that qualify for assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s467f/e"},"text":"section 467f(e) of this title","children":[],"tail":", to each such State in proportion to—"}],"tail":null},{"tag":"subclause","attrib":{"id":"id6b3687f2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467j/a/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of dams in the State that are listed as State-regulated dams on the inventory of dams and low-head dams maintained under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s467d"},"text":"section 467d of this title","children":[],"tail":"; as compared to"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6b3687f3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467j/a/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of dams in all States that are listed as State-regulated dams on the inventory of dams and low-head dams maintained under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s467d"},"text":"section 467d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b3687f4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467j/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount of allocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of funds allocated to a State under this paragraph for a fiscal year may not exceed the amount that is equal to 4 times the amount of funds committed by the State to implement dam safety activities for that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b3687f5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467j/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator and the Board shall determine the amount allocated to States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b3687f6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National inventory of dams and low-head dams","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s467d"},"text":"section 467d of this title","children":[],"tail":" $500,000 for each of fiscal years 2019 through 2028."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b3687f7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467j/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public awareness","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s467g–2"},"text":"section 467g–2 of this title","children":[],"tail":" $1,000,000 for each of fiscal years 2019 through 2028."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b3687f8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467j/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s467g"},"text":"section 467g of this title","children":[],"tail":" $1,450,000 for each of fiscal years 2019 through 2028, to remain until expended."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b3687f9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467j/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dam safety training","children":[],"tail":null},{"tag":"content","attrib":{},"t