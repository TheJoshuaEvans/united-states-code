{"tag":"section","attrib":{"id":"id6c3cd500-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2240"},"text":null,"children":[{"tag":"num","attrib":{"value":"2240"},"text":"§ 2240.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency response services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c3cd501-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2240/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to make grants to any non-Federal interest operating a project for a harbor for provision of emergency response services in such harbor (including contingency planning, necessary personnel training, and the procurement of equipment and facilities either by the non-Federal interest, by a local agency or municipality, or by a combination of local agencies or municipalities on a cost-reimbursable basis, either by a cooperative agreement, mutual aid plan, or mutual assistance plan entered into between one or more non-Federal interests, public agencies, or local municipalities).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c3cd502-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2240/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated for fiscal years beginning after ","children":[{"tag":"date","attrib":{"date":"1986-09-30"},"text":"September 30, 1986","children":[],"tail":", and ending before "},{"tag":"date","attrib":{"date":"1992-10-01"},"text":"October 1, 1992","children":[],"tail":", $5,000,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c3cd503-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662/tII/s212"},"text":"Pub. L. 99–662, title II, § 212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4107"},"text":"100 Stat. 4107","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
