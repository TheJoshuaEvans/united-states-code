{"tag":"section","attrib":{"id":"id6c7ac827-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079c"},"text":null,"children":[{"tag":"num","attrib":{"value":"3079c"},"text":"§ 3079c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility of former officers to compete for certain positions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c7ac828-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual who was separated from the commissioned officer corps of the Administration under honorable conditions after not fewer than 3 years of active service may not be denied the opportunity to compete for a vacant position with respect to which the agency in which the position is located will accept applications from individuals outside the workforce of that agency under merit promotion procedures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7ac829-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Type of appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If selected for a position pursuant to subsection (a), an individual described in that subsection shall receive a career or career-conditional appointment, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7ac82a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Announcements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The area of consideration for a merit promotion announcement with respect to a position that includes consideration of individuals within the Federal service for that position shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7ac82b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indicate that individuals described in subsection (a) are eligible to apply for the position; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac82c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be publicized in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3327"},"text":"section 3327 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7ac82d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section may be construed to confer an entitlement to veterans’ preference that is not otherwise required by any statute or regulation relating to veterans’ preference.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7ac82e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Office of Personnel Management shall prescribe regulations necessary for the administration of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7ac82f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079c/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2025-12-18"},"text":"December 18, 2025","children":[],"tail":", the Administrator shall submit to the Committees on Commerce, Science, and Transportation and Homeland Security and Governmental Affairs of the Senate and the Committee on Natural Resources, the Committee on Science, Space, and Technology, and the Committee on Oversight and Government Reform of the House of Representatives a report which includes the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7ac830-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079c/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of how the Administrator has utilized the authority granted under this section, including the number and locations of individuals hired utilizing the authority granted under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac831-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079c/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An overview of the impact to Federal employment for former members of the commissioned officer corps of the Administration as a result of the authority granted under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7ac832-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079c/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall be repealed on the date that is 5 years after ","children":[{"tag":"date","attrib":{"date":"2025-12-18"},"text":"December 18, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c7ac833-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372/tII/s269C"},"text":"Pub. L. 107–372, title II, § 269C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dH/tLXXXIV/s8404/a"},"text":"Pub. L. 119–60, div. H, title LXXXIV, § 8404(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1912"},"text":"139 Stat. 1912","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
