{"tag":"section","attrib":{"id":"id6b5a3d16-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"701b–6"},"text":"§ 701b–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examinations and surveys by Secretary of Agriculture","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"That, in order to further the declaration of policy and principles declared in sections 701a and 701b of this title, and to supplement the preliminary examinations and surveys which the Secretary of the Army has heretofore been, or is hereafter, authorized and directed to make of waterways with a view to the control of their floods, the Secretary of Agriculture be, and he is, authorized and directed to cause preliminary examinations and surveys to be made for run-off and water-flow retardation and soil-erosion prevention on the watersheds of said waterways, the costs thereof to be paid from appropriations heretofore or hereafter made for such purposes.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b5a3d17-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-08-28/ch877/s3"},"text":"Aug. 28, 1937, ch. 877, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/877"},"text":"50 Stat. 877","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1948-01-19/ch2/s1"},"text":"Jan. 19, 1948, ch. 2, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/4"},"text":"62 Stat. 4","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title II, § 205(a), "},{"tag":"ref","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b5a3d18-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b5a3d19-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b5a3d1a-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1948—Act ","children":[{"tag":"date","attrib":{"date":"1948-01-19"},"text":"Jan. 19, 1948","children":[],"tail":", inserted “or is hereafter” after “heretofore been” to make section applicable to future preliminary surveys and examinations."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b5a3d1b-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id6b5a3d1c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Department of War designated Department of the Army and title of Secretary of War changed to Secretary of the Army by section 205(a) of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343/tII"},"text":"act July 26, 1947, ch. 343, title II","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":". Section 205(a) of act "},{"tag":"date","attrib":{"date":"1947-07-26"},"text":"July 26, 1947","children":[],"tail":", was repealed by section 53 of "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/641"},"text":"70A Stat. 641","children":[],"tail":". Section 1 of act "},{"tag":"date","attrib":{"date":"1956-08-10"},"text":"Aug. 10, 1956","children":[],"tail":", enacted “Title 10, Armed Forces” which in sections 3010 to 3013 continued Department of the Army under administrative supervision of Secretary of the Army."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
