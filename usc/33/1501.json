{"tag":"section","attrib":{"id":"id6c0f83f6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1501"},"text":null,"children":[{"tag":"num","attrib":{"value":"1501"},"text":"§ 1501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional declaration of policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c0f83f7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c0f83f8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1501/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to authorize and regulate the location, ownership, construction, and operation of deepwater ports in waters beyond the territorial limits of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0f83f9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1501/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide for the protection of the marine and coastal environment to prevent or minimize any adverse impact which might occur as a consequence of the development of deepwater ports;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0f83fa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1501/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to protect the interests of the United States and those of adjacent coastal States in the location, construction, and operation of deepwater ports;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0f83fb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1501/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to protect the rights and responsibilities of States and communities to regulate growth, determine land use, and otherwise protect the environment in accordance with law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0f83fc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1501/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote the construction and operation of deepwater ports as a safe and effective means of importing oil or natural gas into the United States and transporting oil or natural gas from the outer Continental Shelf while minimizing tanker traffic and the risks associated with that traffic; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0f83fd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1501/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote oil or natural gas production on the outer Continental Shelf by affording an economic and safe means of transportation of outer Continental Shelf oil or natural gas to the United States mainland.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c0f83fe-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of chapter","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this chapter affects the legal status of the high seas, the superjacent airspace, or the seabed and subsoil, including the Continental Shelf.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c0f83ff-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/627/s2"},"text":"Pub. L. 93–627, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2126"},"text":"88 Stat. 2126","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/324/tV/s502/b"},"text":"Pub. L. 104–324, title V, § 502(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3925"},"text":"110 Stat. 3925","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/295/tI/s106/a/1"},"text":"Pub. L. 107–295, title I, § 106(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2086"},"text":"116 Stat. 2086","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dC/tXXXV/s3514/k/1"},"text":"Pub. L. 118–31, div. C, title XXXV, § 3514(k)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/812"},"text":"137 Stat. 812","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c0f8400-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c0f8401-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c0f8402-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s3514/k/1/A/i"},"text":"Pub. L. 118–31, § 3514(k)(1)(A)(i)","children":[],"tail":", inserted heading and substituted “The purposes of this chapter are—” for “It is declared to be the purposes of the Congress in this chapter to—” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s3514/k/1/A/ii"},"text":"Pub. L. 118–31, § 3514(k)(1)(A)(ii)","children":[],"tail":", inserted “to” after par. designation and realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s3514/k/1/A/ii"},"text":"Pub. L. 118–31, § 3514(k)(1)(A)(ii)","children":[],"tail":", (iii), inserted “to” after par. designation, substituted “deepwater ports” for “such ports”, and realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s3514/k/1/A/ii"},"text":"Pub. L. 118–31, § 3514(k)(1)(A)(ii)","children":[],"tail":", inserted “to” after par. designation and realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s3514/k/1/A/ii"},"text":"Pub. L. 118–31, § 3514(k)(1)(A)(ii)","children":[],"tail":", (iv), inserted “to” after par. designation, substituted “Continental Shelf” for “continental shelf” and “associated with that traffic” for “attendant thereto”, and realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s3514/k/1/A/ii"},"text":"Pub. L. 118–31, § 3514(k)(1)(A)(ii)","children":[],"tail":", (v), inserted “to” after par. designation, substituted “Continental Shelf” for “continental shelf” in two places, and realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s3514/k/1/B"},"text":"Pub. L. 118–31, § 3514(k)(1)(B)","children":[],"tail":", inserted heading and substituted “Nothing in this chapter affects” for “The Congress declares that nothing in this chapter shall be construed to affect” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295"},"text":"Pub. L. 107–295","children":[],"tail":" inserted “or natural gas” after “oil” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324"},"text":"Pub. L. 104–324","children":[],"tail":" added pars. (5) and (6)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c11ccf3-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id6c11ccf4-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/tV/s501"},"text":"Pub. L. 104–324, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3925"},"text":"110 Stat. 3925","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/324/tV/s501"},"text":"“This title [amending this section and sections 1502 to 1504, 1507, and 1509 of this title, repealing ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1506"},"text":"section 1506 of this title","children":[],"tail":", and enacting provisions set out as a note under this section] may be cited as the ‘Deepwater Port Modernization Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id6c11ccf5-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/419/s1"},"text":"Pub. L. 98–419, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-09-25"},"text":"Sept. 25, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1607"},"text":"98 Stat. 1607","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/419/s1"},"text":"“That this Act [amending sections 1502, 1503, 1504, 1506, 1507, 1517, and 1518 of this title and enacting provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1518"},"text":"section 1518 of this title","children":[],"tail":"] may be cited as the ‘Deepwater Port Act Amendments of 1984’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id6c11ccf6-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/627/s1"},"text":"Pub. L. 93–627, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2126"},"text":"88 Stat. 2126","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/93/627/s1"},"text":"“That this Act [enacting this chapter and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1333"},"text":"section 1333 of Title 43","children":[],"tail":", Public Lands] may be cited as the ‘Deepwater Port Act of 1974’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c11ccf7-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Purposes for 1996 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/tV/s502/a"},"text":"Pub. L. 104–324, title V, § 502(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3925"},"text":"110 Stat. 3925","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/324/tV/s502/a"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The purposes of this title [see Short Title of 1996 Amendment note above] are to—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" update and improve the Deepwater Port Act of 1974 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1501"},"text":"33 U.S.C. 1501","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assure that the regulation of deepwater ports is not more burdensome or stringent than necessary in comparison to the regulation of other modes of importing or transporting oil;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recognize that deepwater ports are generally subject to effective competition from alternative transportation modes and eliminate, for as long as a port remains subject to effective competition, unnecessary Federal regulatory oversight or involvement in the ports’ business and economic decisions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote innovation, flexibility, and efficiency in the management and operation of deepwater ports by removing or reducing any duplicative, unnecessary, or overly burdensome Federal regulations or license provisions.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c11ccf8-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deposit of Certain Penalties Into Oil Spill Liability Trust Fund","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Penalties paid pursuant to this chapter and sections 1319(c) and 1321 of this title to be deposited in the Oil Spill Liability Trust Fund created under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s9509"},"text":"section 9509 of Title 26","children":[],"tail":", Internal Revenue Code, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/380/s4304"},"text":"section 4304 of Pub. L. 101–380","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s9509"},"text":"section 9509 of Title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id6c11ccf9-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c11ccfa-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Environmental Effects Abroad of Major Federal Actions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to environmental effects abroad of major Federal actions, see Ex. Ord. No. 12114, ","children":[{"tag":"date","attrib":{"date":"1979-01-04"},"text":"Jan. 4, 1979","children":[],"tail":", 44 F.R. 1957, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
