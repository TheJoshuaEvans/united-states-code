{"tag":"section","attrib":{"id":"id6b7936a9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892c"},"text":null,"children":[{"tag":"num","attrib":{"value":"892c"},"text":"§ 892c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hydrographic Services Review Panel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b7936aa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2002-12-19"},"text":"December 19, 2002","children":[],"tail":", the Secretary shall establish the Hydrographic Services Review Panel."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b7936ab-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b7936ac-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The panel shall advise the Administrator on matters related to the responsibilities and authorities set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s892a"},"text":"section 892a of this title","children":[],"tail":" and such other appropriate matters as the Administrator refers to the panel for review and advice."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7936ad-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative resources","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall make available to the panel such information, personnel, and administrative services and assistance as it may reasonably require to carry out its duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b7936ae-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b7936af-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b7936b0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892c/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The panel shall consist of 15 voting members who shall be appointed by the Administrator. The Co-directors of the Center for Coastal and Ocean Mapping/Joint Hydrographic Center and no more than 2 employees of the National Oceanic and Atmospheric Administration appointed by the Administrator shall serve as nonvoting members of the panel. The voting members of the panel shall be individuals who, by reason of knowledge, experience, or training, are especially qualified in 1 or more of the disciplines and fields relating to hydrographic data and hydrographic services, marine transportation, port administration, vessel pilotage, coastal and fishery management, and other disciplines as determined appropriate by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b7936b1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892c/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual may not be appointed as a voting member of the panel if the individual is a full-time officer or employee of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b7936b2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892c/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any voting member of the panel who is an applicant for, or beneficiary (as determined by the Secretary) of, any assistance under this subchapter shall disclose to the panel that relationship, and may not vote on any matter pertaining to that assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7936b3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b7936b4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892c/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term of office of a voting member of the panel shall be 4 years, except that of the original appointees, five shall be appointed for a term of 2 years, five shall be appointed for a term of 3 years, and five shall be appointed for a term of 4 years, as specified by the Administrator at the time of appointment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b7936b5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892c/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any individual appointed to a partial or full term may be reappointed for one additional full term. A voting member may serve after the date of the expiration of the term of office for which appointed until his or her successor has taken office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7936b6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892c/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nominations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At least once each year, the Secretary shall publish a notice in the Federal Register soliciting nominations for membership on the panel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7936b7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892c/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairman and Vice Chairman","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b7936b8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892c/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The panel shall select one voting member to serve as the Chairman and another voting member to serve as the Vice Chairman.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b7936b9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892c/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Vice Chairman shall act as Chairman in the absence or incapacity of the Chairman.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b7936ba-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Voting members of the panel shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b7936bb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive compensation at a rate established by the Secretary, not to exceed the maximum daily rate payable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of title 5","children":[],"tail":" when actually engaged in the performance of duties for such panel; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7936bc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be reimbursed for actual and reasonable expenses incurred in the performance of such duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b7936bd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The panel shall meet on a biannual basis and, at any other time, at the call of the Chairman or upon the request of a majority of the voting members or of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b7936be-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892c/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The panel may exercise such powers as are reasonably necessary in order to carry out its duties under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b7936bf-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/384/tIII/s305"},"text":"Pub. L. 105–384, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3456"},"text":"112 Stat. 3456","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/383/tIV/s432/c"},"text":"Pub. L. 105–383, title IV, § 432(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3445"},"text":"112 Stat. 3445","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/372/tI/s105"},"text":"Pub. L. 107–372, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3080"},"text":"116 Stat. 3080","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/386/s4"},"text":"Pub. L. 110–386, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4107"},"text":"122 Stat. 4107","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b7936c0-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b7936c1-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6b7936c2-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsec. (c)(1)(C), was in the original “this Act”, and was translated, to reflect the probable intent of Congress, as reading “this title”, meaning title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/384"},"text":"Pub. L. 105–384","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3454"},"text":"112 Stat. 3454","children":[],"tail":", known as the Hydrographic Services Improvement Act of 1998, which is classified principally to this subchapter. For complete classification of title III to the Code, see Short Title of 1998 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s851"},"text":"section 851 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b7936c3-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/386"},"text":"Pub. L. 110–386","children":[],"tail":" amended subpar. (A) generally. Prior to amendment, subpar. (A) read as follows: “The panel shall consist of 15 voting members who shall be appointed by the Administrator. The Director of the Joint Hydrographic Institute and no more than 2 employees of the National Oceanic and Atmospheric Administration appointed by the Administrator shall serve as nonvoting members of the panel. The voting members of the panel shall be individuals who, by reason of knowledge, experience, or training, are especially qualified in one or more of the disciplines and fields relating to hydrographic surveying, tide, current geodetic and geospatial measurement, marine transportation, port administration, vessel pilotage, and coastal and fishery management.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372"},"text":"Pub. L. 107–372","children":[],"tail":" amended section generally, substituting provisions establishing Hydrographic Services Review Panel for provisions requiring report, not later than 6 months after "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"November 13, 1998","children":[],"tail":", on a plan to ensure maintenance of Federal competence and expertise in hydrographic surveying."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/383"},"text":"Pub. L. 105–383","children":[],"tail":", which directed the amendment of this section by striking out subsecs. (a) and (d), was executed by striking out subsec. (a), because no subsec. (d) has been enacted. Prior to amendment, subsec. (a) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) ","children":[{"tag":"inline","attrib":{},"text":"Ports","children":[],"tail":".—Not later than 6 months after "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"November 13, 1998","children":[],"tail":", the Administrator and the Commandant of the Coast Guard shall report to the Congress on—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) the status of implementation of real-time tide and current data systems in United States ports;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) existing safety and efficiency needs in United States ports that could be met by increased use of those systems; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) a plan for expanding those systems to meet those needs, including an estimate of the cost of implementing those systems in priority locations.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b7936c4-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6b7936c5-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/383/tIV/s432/a"},"text":"Pub. L. 105–383, title IV, § 432(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3444"},"text":"112 Stat. 3444","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/383/tIV/s432/a"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Subsections (b) and (c) [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s892d"},"text":"section 892d of this title","children":[],"tail":"] shall take effect immediately after the later of—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the enactment of the Hydrographic Services Improvement Act of 1998 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/384/tIII"},"text":"Pub. L. 105–384, title III","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":"]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
