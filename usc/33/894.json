{"tag":"section","attrib":{"id":"id6b7ba71f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894"},"text":null,"children":[{"tag":"num","attrib":{"value":"894"},"text":"§ 894.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions to address sexual harassment at National Oceanic and Atmospheric Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b7ba720-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2016-12-23"},"text":"December 23, 2016","children":[],"tail":", the Secretary of Commerce shall, acting through the Under Secretary for Oceans and Atmosphere, develop a policy on the prevention of and response to sexual harassment involving employees of the National Oceanic and Atmospheric Administration, members of the commissioned officer corps of the Administration, and individuals who work with or conduct business on behalf of the Administration."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b7ba721-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matters to be specified in policy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The policy developed under subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b7ba722-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishment of a program to promote awareness of the incidence of sexual harassment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7ba723-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" clear procedures an individual should follow in the case of an occurrence of sexual harassment, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b7ba724-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a specification of the person or persons to whom an alleged occurrence of sexual harassment should be reported by an individual and options for confidential reporting, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6b7ba725-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" options and contact information for after-hours contact; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6b7ba726-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a procedure for obtaining assistance and reporting sexual harassment while working in a remote scientific field camp, at sea, or in another field status; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b7ba727-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a specification of any other person whom the victim should contact;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7ba728-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establishment of a mechanism by which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b7ba729-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" questions regarding sexual harassment can be confidentially asked and confidentially answered; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b7ba72a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incidents of sexual harassment can be reported on a restricted or unrestricted basis; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7ba72b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a prohibition on retaliation and consequences for retaliatory actions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b7ba72c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation and assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing the policy required by subsection (a), the Secretary may consult or receive assistance from such State, local, and national organizations and subject matter experts as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b7ba72d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of policy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that the policy developed under subsection (a) is available to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b7ba72e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all employees of the Administration and members of the commissioned officer corps of the Administration, including those employees and members who conduct field work for the Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7ba72f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b7ba730-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographic distribution of equal employment opportunity personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall designate out of existing staff at least 1 employee of the Administration who is tasked with handling matters relating to equal employment opportunity or sexual harassment at each marine and aviation center of the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b7ba731-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quarterly reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b7ba732-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less frequently than 4 times each year, the Director of the Civil Rights Office of the Administration shall submit to the Under Secretary a report on sexual harassment in the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7ba733-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report submitted under paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b7ba734-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of sexual harassment cases, both actionable and non-actionable, involving individuals covered by the policy developed under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b7ba735-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of open actionable sexual harassment cases and how long the cases have been open.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b7ba736-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such trends or region-specific issues as the Director may have discovered with respect to sexual harassment in the Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b7ba737-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such recommendations as the Director may have with respect to sexual harassment in the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b7ba738-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dC/tXXXV/s3541"},"text":"Pub. L. 114–328, div. C, title XXXV, § 3541","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2800"},"text":"130 Stat. 2800","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/259/tV/s504/a/1"},"text":"Pub. L. 116–259, title V, § 504(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-23"},"text":"Dec. 23, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1180"},"text":"134 Stat. 1180","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b7ba739-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b7ba73a-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b7ba73b-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (b)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/259"},"text":"Pub. L. 116–259","children":[],"tail":" substituted “can be reported on a restricted or unrestricted basis” for “can be confidentially reported”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
