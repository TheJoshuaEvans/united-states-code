{"tag":"section","attrib":{"id":"id6c18f957-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1601"},"text":null,"children":[{"tag":"num","attrib":{"value":"1601"},"text":"§ 1601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c18f958-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1601/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “vessel” means every description of watercraft, including nondisplacement craft and seaplanes, used or capable of being used as a means of transportation on water; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c18f959-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1601/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “high seas” means all parts of the sea that are not included in the territorial sea or in the internal waters of any nation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c18f95a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/75/s2"},"text":"Pub. L. 95–75, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-07-27"},"text":"July 27, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/308"},"text":"91 Stat. 308","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c18f95b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c18f95c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","a