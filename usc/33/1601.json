n":[],"tail":", provided in part that "},{"tag":"ref","attrib":{"href":"/us/pl/88/131"},"text":"Pub. L. 88–131","children":[],"tail":", enacting sections 1051 to 1094 of this title and a provision set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1051"},"text":"section 1051 of this title","children":[],"tail":" which sections included the former International Regulations for Preventing Collisions at Sea, was repealed effective on the date on which the International Regulations [promulgated pursuant to this chapter] entered into force for the United States ["},{"tag":"date","attrib":{"date":"1977-07-15"},"text":"July 15, 1977","children":[],"tail":"]. See Proclamation dated "},{"tag":"date","attrib":{"date":"1977-01-19"},"text":"Jan. 19, 1977","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1602"},"text":"section 1602 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c18f960-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References to Former Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/75/s10"},"text":"Pub. L. 95–75, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-07-27"},"text":"July 27, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/311"},"text":"91 Stat. 311","children":[],"tail":", provided in part that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/75/s10"},"text":"“The reference in any other law to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/131"},"text":"Public Law 88–131","children":[],"tail":" [enacting sections 1051 to 1094 of this title and enacting a provision set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1051"},"text":"section 1051 of this title","children":[],"tail":"], or to the regulations set forth in section 4 of that Act [sections 1061 to 1094 of this title], shall be considered a reference, respectively, to this Act [this chapter], or to the International Regulations proclaimed hereunder [set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1602"},"text":"section 1602 of this title","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id6c18f961-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/75/s1"},"text":"Pub. L. 95–75, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-07-27"},"text":"July 27, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/308"},"text":"91 Stat. 308","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/75/s1"},"text":"“That this Act [enacting this chapter, repealing sections 1051 to 1094 of this title, enacting provisions set out as notes under this section, and repealing provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1051"},"text":"section 1051 of this title","children":[],"tail":"] may be cited as the ‘International Navigational Rules Act of 1977’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
