{"tag":"section","attrib":{"id":"id6b3ffed9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s547"},"text":null,"children":[{"tag":"num","attrib":{"value":"547"},"text":"§ 547.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports as to local benefits of improvement and recommendations as to local cooperation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Every report submitted to Congress in pursuance of any provision of law for a survey, in addition to other information which the Congress has directed shall be given, shall contain a statement of special or local benefit which will accrue to localities affected by such improvement and a statement of general or national benefits, with recommendations as to what local cooperation should be required, if any, on account of such special or local benefit.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b3ffeda-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-06-05/ch252/s2"},"text":"June 5, 1920, ch. 252, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/1010"},"text":"41 Stat. 1010","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b3ffedb-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b3ffedc-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b3ffedd-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from act ","children":[{"tag":"date","attrib":{"date":"1920-06-05"},"text":"June 5, 1920","children":[],"tail":", popularly known as the “Rivers and Harbors Appropriation Act of 1921”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
