{"tag":"section","attrib":{"id":"id6b9f5c6b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1206"},"text":null,"children":[{"tag":"num","attrib":{"value":"1206"},"text":"§ 1206.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemptions; terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may, if he considers that marine navigational safety will not be adversely affected or where a local communication system fully complies with the intent of this concept but does not conform in detail, issue exemptions from any provisions of this chapter, on such terms and conditions as he considers appropriate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b9f5c6c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/63/s7"},"text":"Pub. L. 92–63, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-08-04"},"text":"Aug. 4, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/165"},"text":"85 Stat. 165","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b9f5c6d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b9f5c6e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id6b9f5c6f-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1971-05-01"},"text":"May 1, 1971","children":[],"tail":", or six months after the promulgation of regulations which would implement its provisions, whichever is later, see "},{"tag":"ref","attrib":{"href":"/us/pl/92/63/s10"},"text":"section 10 of Pub. L. 92–63","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1201"},"text":"section 1201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
