{"tag":"section","attrib":{"id":"id6b103bc2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59u"},"text":null,"children":[{"tag":"num","attrib":{"value":"59u"},"text":"§ 59u.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lawyer’s Ditch, Essex County, New Jersey","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The body of water known as Lawyer’s Ditch located at block 5,000 in the city of Newark, county of Essex, New Jersey, is declared to be a nonnavigable waterway of the United States within the meaning of the General Bridge Act of 1946 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s525"},"text":"33 U.S.C. 525","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b103bc3-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/307/s3"},"text":"Pub. L. 99–307, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-05-19"},"text":"May 19, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/446"},"text":"100 Stat. 446","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b103bc4-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b103bc5-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6b103bc6-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The General Bridge Act of 1946, referred to in text, is title V of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-02/ch753"},"text":"act Aug. 2, 1946, ch. 753","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/847"},"text":"60 Stat. 847","children":[],"tail":", which is classified generally to subchapter III (§ 525 et seq.) of chapter 11 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s525"},"text":"section 525 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
