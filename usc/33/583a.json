{"tag":"section","attrib":{"id":"id6b499b10-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s583a"},"text":null,"children":[{"tag":"num","attrib":{"value":"583a"},"text":"§ 583a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of pay and allowances of officers of Corps of Engineers from appropriation for improvements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b499b11-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s583a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The personnel described in subsection (b) who are employed primarily on duty connected with non-military public works prosecuted under the direction of the Chief of Engineers, including river and harbor improvements, flood control, and other such works, shall, while so employed, be paid their pay and allowances from the appropriation for the works upon which they are employed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b499b12-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s583a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The personnel referred to in subsection (a) are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b499b13-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s583a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Regular officers of the Corps of Engineers of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b499b14-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s583a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The following members of the Army who are assigned to the Corps of Engineers:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b499b15-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s583a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reserve component officers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b499b16-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s583a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Warrant officers (whether regular or reserve component).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b499b17-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s583a/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Enlisted members (whether regular or reserve component).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b499b18-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041/s36"},"text":"Aug. 10, 1956, ch. 1041, § 36","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/634"},"text":"70A Stat. 634","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dH/tLXXXI/s8125"},"text":"Pub. L. 117–263, div. H, title LXXXI, § 8125","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3715"},"text":"136 Stat. 3715","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b499b19-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b499b1a-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b499b1b-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is derived from the third proviso of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-06-26/ch839"},"text":"Act June 26, 1936, ch. 839","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1974"},"text":"49 Stat. 1974","children":[],"tail":", which was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s181a"},"text":"section 181a of Title 10","children":[],"tail":" prior to the general revision and enactment of Title 10, Armed Forces, by "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041/s1"},"text":"act Aug. 10, 1956, ch. 1041, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/1"},"text":"70A Stat. 1","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b499b1c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, substituted “The personnel described in subsection (b)” for “Regular officers of the Corps of Engineers of the Army, and reserve officers of the Army who are assigned to the Corps of Engineers,”, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
