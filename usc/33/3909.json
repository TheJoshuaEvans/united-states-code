{"tag":"section","attrib":{"id":"id6c904bea-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3909"},"text":null,"children":[{"tag":"num","attrib":{"value":"3909"},"text":"§ 3909.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c904beb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3909/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary or the Administrator, as applicable, shall establish a uniform system to service the Federal credit instruments made available under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c904bec-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3909/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c904bed-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3909/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary or the Administrator, as applicable, may collect and spend fees, contingent on authority being provided in appropriations Acts, at a level that is sufficient to cover—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c904bee-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3909/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of services of expert firms retained pursuant to subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904bef-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3909/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all or a portion of the costs to the Federal Government of servicing the Federal credit instruments provided under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904bf0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3909/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on pass through fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator, in the case where a State infrastructure financing authority obtains financial assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3912/e"},"text":"section 3912(e) of this title","children":[],"tail":", shall require as a condition of obtaining such assistance, that the State infrastructure financing authority is prohibited from passing any portion of the fees required under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s3908/b/7"},"text":"section 3908(b)(7) of this title","children":[],"tail":" to any party that utilizes any portion of such assistance for a project funded by such authority."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c904bf1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3909/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Servicer","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c904bf2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3909/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary or the Administrator, as applicable, may appoint a financial entity to assist the Secretary or the Administrator in servicing the Federal credit instruments provided under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904bf3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3909/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A servicer appointed under paragraph (1) shall act as the agent for the Secretary or the Administrator, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904bf4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3909/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A servicer appointed under paragraph (1) shall receive a servicing fee, subject to approval by the Secretary or the Administrator, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c904bf5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3909/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance from experts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary or the Administrator, as applicable, may retain the services, including counsel, of organizations and entities with expertise in the field of municipal and project finance to assist in the underwriting and servicing of Federal credit instruments provided under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c904bf6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3909/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for State reviews of projects for State infrastructure financing authorities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c904bf7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3909/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A project described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3905/9"},"text":"section 3905(9) of this title","children":[],"tail":" for which funding is provided under this title shall comply with any applicable State environmental or engineering review requirements pursuant to, as applicable—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c904bf8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3909/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" title VI of the Federal Water Pollution Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1381"},"text":"33 U.S.C. 1381","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904bf9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3909/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300j–12"},"text":"section 300j–12 of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904bfa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3909/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No new reviews required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this title requires any additional or new environmental or engineering review for a project described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3905/9"},"text":"section 3905(9) of this title","children":[],"tail":" for which funding is provided, other than any requirement otherwise applicable to the project."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c904bfb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3909/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for expedited review of applications from State infrastructure financing authorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the date on which the Administrator receives a complete application from a State infrastructure financing authority for a project under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3905/9"},"text":"section 3905(9) of this title","children":[],"tail":", the Administrator shall, through a written notice to the State infrastructure financing authority—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c904bfc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3909/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approve the application; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904bfd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3909/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide detailed guidance and an explanation of any changes to the application necessary for approval of the application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c904bfe-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3909/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c904bff-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3909/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraphs (3) and (4), the Administrator may enter into an agreement with another relevant Federal agency to provide assistance in administering and servicing Federal credit instruments that such agency is authorized to make available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904c00-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3909/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may act as an agent for the head of another Federal agency under paragraph (1), subject to the terms of any agreement entered into by the Administrator and the head of such other agency under such clause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904c01-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3909/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The authority of the Administrator to provide assistance under paragraph (1) is subject to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c904c02-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3909/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of funds appropriated to the other Federal agency that may be transferred to the Administrator to carry out an agreement entered into under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904c03-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3909/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transfer of such funds to the Administrator to carry out such an agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904c04-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3909/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection affects the authority of the Administrator with respect to the selection of projects described in paragraphs (1), (8), or (10) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3905"},"text":"section 3905 of this title","children":[],"tail":" to receive financial assistance under this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c904c05-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3909/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Section 513 of the Federal Water Pollution Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1372"},"text":"33 U.S.C. 1372","children":[],"tail":") applies to the construction of a project carried out, in whole or in part, with assistance made available through a Federal credit instrument under this chapter in the same manner that section applies to a treatment works for which a grant is made available under that Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251"},"text":"33 U.S.C. 1251","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c904c06-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/tV/s5030"},"text":"Pub. L. 113–121, title V, § 5030","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1341"},"text":"128 Stat. 1341","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/270/tIV/s4201/b/2"},"text":"Pub. L. 115–270, title IV, § 4201(b)(2)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3878"},"text":"132 Stat. 3878","children":[],"tail":", 3880.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c904c07-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c904c08-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c904c09-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Water Pollution Control Act, referred to in subsecs. (e)(1)(A) and (h), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"act June 30, 1948, ch. 758","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/92/500/s2"},"text":"Pub. L. 92–500, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-18"},"text":"Oct. 18, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/816"},"text":"86 Stat. 816","children":[],"tail":", which is classified generally to chapter 26 (§ 1251 et seq.) of this title. Title VI of the Act is classified generally to subchapter VI (§ 1381 et seq.) of chapter 26 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251"},"text":"section 1251 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Under this title and nothing in this title, referred to in subsec. (e), mean title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121"},"text":"Pub. L. 113–121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1322"},"text":"128 Stat. 1322","children":[],"tail":". Subtitle C (§§ 5021–5035) of title V of "},{"tag":"ref","attrib":{"href":"/us/pl/113/121"},"text":"Pub. L. 113–121","children":[],"tail":" enacted this chapter. For complete classification of title V to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c904c0a-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/s4201/b/2/A"},"text":"Pub. L. 115–270, § 4201(b)(2)(A)","children":[],"tail":", added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/s4201/b/2/B"},"text":"Pub. L. 115–270, § 4201(b)(2)(B)","children":[],"tail":", added subsecs. (e) and (f). Former subsec. (e) designated (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/s4201/c"},"text":"Pub. L. 115–270, § 4201(c)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/s4201/b/2/B"},"text":"Pub. L. 115–270, § 4201(b)(2)(B)","children":[],"tail":", redesignated subsec. (e) as (h)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c904c0b-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c904c0c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Agreement With Commissioner of Reclamation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/tIV/s4301"},"text":"Pub. L. 115–270, title IV, § 4301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3880"},"text":"132 Stat. 3880","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/270/tIV/s4301"},"text":"“Not later than 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":"], the Administrator of the Environmental Protection Agency and the Commissioner of Reclamation shall enter into an agreement under section 5030(g) of the Water Infrastructure Finance and Innovation Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t33/s3909/g"},"text":"33 U.S.C. 3909(g)","children":[],"tail":"] (as added by this Act).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c904c0d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s2"},"text":"section 2 of Pub. L. 113–121","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
