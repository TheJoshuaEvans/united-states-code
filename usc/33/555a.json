{"tag":"section","attrib":{"id":"id6b426f17-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s555a"},"text":null,"children":[{"tag":"num","attrib":{"value":"555a"},"text":"§ 555a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petroleum product information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b426f18-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s555a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure to States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall disclose petroleum product information to any State taxing agency making a request under subsection (b). Such information shall be disclosed for the purpose of, and only to the extent necessary in, the administration of State tax laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b426f19-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s555a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requests for disclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Disclosure of information under this section shall be permitted only upon written request by the head of the State taxing agency and only to the representatives of such agency designated in such written request as the individuals who are to inspect or to receive the information on behalf of such agency. Any such representative shall be an employee or legal representative of such agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b426f1a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s555a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modes of disclosure","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b426f1b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s555a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Requests for the disclosure of information under this section, and such disclosure, shall be made in such manner and at such time and place as shall be prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b426f1c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s555a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information disclosed to any person under this section may be provided in the form of written documents or reproductions of such documents, or by any other mode or means which the Secretary determines necessary or appropriate. A reasonable fee may be prescribed for furnishing such information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b426f1d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s555a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any reproduction of any document or other matter made in accordance with this subsection shall have the same legal status as the original, and any such reproduction shall, if properly authenticated, be admissible in evidence in any judicial or administrative proceeding as if it were the original, whether or not the original is in existence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b426f1e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s555a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality of disclosed information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall not disclose information to a State taxing agency of a State under this section unless such State has in effect provisions of law which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b426f1f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s555a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exempt such information from disclosure under a State law requiring agencies of the State to make information available to the public, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b426f20-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s555a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise protect the confidentiality of the information.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Nothing in the preceding sentence shall be construed to prohibit the disclosure by an officer or employee of a State of information to another officer or employer of such State (or political subdivision of such State) to the extent necessary in the administration of State tax laws.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b426f21-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s555a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b426f22-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s555a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “petroleum product information” means information relating to petroleum products transported by vessel which is received by the Secretary (A) under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s555"},"text":"section 555 of this title","children":[],"tail":", or (B) under any other legal authority; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b426f23-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s555a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State taxing agency” means any State agency, body, or commission, or its legal representative, which is charged under the laws of such State with responsibility for the administration of State tax laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b426f24-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s555a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b426f25-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662/tIX/s919"},"text":"Pub. L. 99–662, title IX, § 919","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4192"},"text":"100 Stat. 4192","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b426f26-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b426f27-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b426f28-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f) of this section amended ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s555"},"text":"section 555 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b426f29-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b426f2a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
