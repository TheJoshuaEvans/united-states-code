{"tag":"section","attrib":{"id":"id6b1767aa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59mm"},"text":null,"children":[{"tag":"num","attrib":{"value":"59mm"},"text":"§ 59mm.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coalbank Slough deemed not navigable waters of the United States for certain purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Coalbank Slough in Coos Bay, Oregon, is deemed to not be navigable waters of the United States for all purposes of subchapter J of Chapter I of title 33, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b1767ab-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXIV"},"text":"Pub. L. 116–283, div. G, title LVXXXIV","children":[],"tail":" [LXXXIV], § 8436, "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4736"},"text":"134 Stat. 4736","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
