{"tag":"section","attrib":{"id":"id6b368846-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s493"},"text":null,"children":[{"tag":"num","attrib":{"value":"493"},"text":"§ 493.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of railroad bridges by other railroad companies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All railroad companies desiring the use of any railroad bridge built in accordance with the provisions of sections 491 to 494 and 495 to 498 of this title, shall be entitled to equal rights and privileges relative to the passage of railway trains or cars over the same and over the approaches thereto upon payment of a reasonable compensation for such use; and in case of any disagreement between the parties in regard to the terms of such use or the sums to be paid all matters at issue shall be determined by the Secretary of Transportation upon hearing the allegations and proofs submitted to him.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b368847-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1906-03-23/ch1130/s3"},"text":"Mar. 23, 1906, ch. 1130, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/85"},"text":"34 Stat. 85","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/449/s2/d/1"},"text":"Pub. L. 97–449, § 2(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2440"},"text":"96 Stat. 2440","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b368848-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b368849-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b36884a-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/449"},"text":"Pub. L. 97–449","children":[],"tail":" substituted “Secretary of Transportation” for “Secretary of War”. See Transfer of Functions note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b36884b-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id6b36884c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions, powers, and duties of Secretary of the Army [formerly War] and other offices and officers of Department of the Army [formerly War] under this section to extent that they relate generally to location and clearances of bridges and causeways in navigable waters of United States transferred to and vested in Secretary of Transportation by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/670/s6/g/6/B"},"text":"Pub. L. 89–670, § 6(g)(6)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-15"},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/941"},"text":"80 Stat. 941","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/pl/97/449"},"text":"Pub. L. 97–449","children":[],"tail":" amended this section to reflect transfer made by "},{"tag":"ref","attrib":{"href":"/us/pl/89/670/s6/g/6/B"},"text":"section 6(g)(6)(B) of Pub. L. 89–670","children":[],"tail":", and repealed section 6(g)(6)(B)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
