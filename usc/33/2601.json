{"tag":"section","attrib":{"id":"id6c62fb09-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2601"},"text":null,"children":[{"tag":"num","attrib":{"value":"2601"},"text":"§ 2601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c62fb0a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2601/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Administrator” means the Administrator of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62fb0b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2601/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “coastal waters” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c62fb0c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2601/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the territorial sea of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c62fb0d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2601/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Great Lakes and their connecting waters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c62fb0e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2601/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the marine and estuarine waters of the United States up to the head of tidal influence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c6543ff-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2601/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Exclusive Economic Zone as established by Presidential Proclamation Number 5030, dated ","children":[{"tag":"date","attrib":{"date":"1983-03-10"},"text":"March 10, 1983","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c654400-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2601/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “municipal or commercial waste” means solid waste (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6903"},"text":"section 6903 of title 42","children":[],"tail":") except—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c654401-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2601/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solid waste identified and listed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6921"},"text":"section 6921 of title 42","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c654402-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2601/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" waste generated by the vessel during normal operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c654403-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2601/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" debris solely from construction activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c654404-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2601/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sewage sludge subject to regulation under title I of the Marine Protection, Research, and Sanctuaries Act of 1972 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1411"},"text":"33 U.S.C. 1411","children":[],"tail":" et seq.]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c654405-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2601/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dredged or fill material subject to regulation under title I of the Marine Protection, Research, and Sanctuaries Act of 1972 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1411"},"text":"33 U.S.C. 1411","children":[],"tail":" et seq.], the Federal Water Pollution Control Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251"},"text":"33 U.S.C. 1251","children":[],"tail":" et seq.), or the Rivers and Harbors Appropriation Act of 1899 ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s401"},"text":"33 U.S.C. 401","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c654406-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2601/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “person” means an individual, trust, firm, joint stock company, corporation (including a government corporation), partnership, association, State, municipality, commission, political subdivision of a State, or any interstate body.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c654407-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2601/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “receiving facility” means a facility or operation where municipal or commercial waste is unloaded from a vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c654408-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2601/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “United States”, when used in a geographic sense, means the States of the United States, Puerto Rico, the District of Columbia, the Virgin Islands, American Samoa, Guam, the Northern Mariana Islands, and any other territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c654409-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2601/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “waste source” means a facility or vessel from which municipal or commercial waste is loaded onto a vessel, including any rolling stock or motor vehicles from which that waste is directly loaded.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c65440a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/688/tIV/s4101"},"text":"Pub. L. 100–688, title IV, § 4101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4154"},"text":"102 Stat. 4154","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c65440b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c65440c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c65440d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Presidential Proclamation Number 5030, referred to in par. (2)(D), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1453"},"text":"section 1453 of Title 16","children":[],"tail":", Conservation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Marine Protection, Research, and Sanctuaries Act of 1972, referred to in par. (3)(D) and (E), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/532"},"text":"Pub. L. 92–532","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-23"},"text":"Oct. 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1052"},"text":"86 Stat. 1052","children":[],"tail":". Title I of that Act is classified generally to subchapter I (§ 1411 et seq.) of chapter 27 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1401"},"text":"section 1401 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Water Pollution Control Act, referred to in par. (3)(E), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"act June 30, 1948, ch. 758","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/92/500/s2"},"text":"Pub. L. 92–500, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-18"},"text":"Oct. 18, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/816"},"text":"86 Stat. 816","children":[],"tail":", which is classified generally to chapter 26 (§ 1251 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251"},"text":"section 1251 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Rivers and Harbors Appropriation Act of 1899, referred to in par. (3)(E), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1899-03-03/ch425"},"text":"act Mar. 3, 1899, ch. 425","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/30/1151"},"text":"30 Stat. 1151","children":[],"tail":", which enacted sections 401, 403, 404, 406 to 409, 411 to 416, 418, 502, 549, 686, and 687 of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c65440e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id6c65440f-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/688/tIV/s4001"},"text":"Pub. L. 100–688, title IV, § 4001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4154"},"text":"102 Stat. 4154","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/688/tIV/s4001"},"text":"“This title [enacting this chapter] may be cited as the ‘Shore Protection Act of 1988’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id6c654410-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c654411-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Territorial Sea of United States","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For extension of territorial sea of United States, see Proc. No. 5928, set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1331"},"text":"section 1331 of Title 43","children":[],"tail":", Public Lands."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
