{"tag":"section","attrib":{"id":"id6c0f8394-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1473"},"text":null,"children":[{"tag":"num","attrib":{"value":"1473"},"text":"§ 1473.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultations and determinations respecting creation of hazards to human health, etc.; criteria for determinations respecting grave and imminent dangers of major harmful consequences to United States coastline or related interests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c0f8395-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1473/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary, after consultation with the Administrator of the Environmental Protection Agency and the Secretary of Commerce, shall determine when a substance other than those enumerated in the protocol is liable to create a hazard to human health, to harm living resources, to damage amenities, or to interfere with other legitimate uses of the sea.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c0f8396-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1473/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In determining whether there is grave and imminent danger of major harmful consequences to the coastline or related interests of the United States, the Secretary shall consider the interests of the United States directly threatened or affected including but not limited to, human health, fish, shellfish, and other living marine resources, wildlife, coastal zone and estuarine activities, and public and private shorelines and beaches.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c0f8397-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/248/s4"},"text":"Pub. L. 93–248, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-02-05"},"text":"Feb. 5, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/9"},"text":"88 Stat. 9","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/302/s1/3"},"text":"Pub. L. 95–302, § 1(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-06-26"},"text":"June 26, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/344"},"text":"92 Stat. 344","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c0f8398-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c0f8399-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c0f839a-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/302"},"text":"Pub. L. 95–302","children":[],"tail":" added subsec. (a), designated existing provisions as subsec. (b), and inserted “human health,” before “fish”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c0f839b-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6c0f839c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/302"},"text":"Pub. L. 95–302","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/302/s2"},"text":"section 2 of Pub. L. 95–302","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1487"},"text":"section 1487 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
