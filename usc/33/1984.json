{"tag":"section","attrib":{"id":"id6c2751d2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1984"},"text":null,"children":[{"tag":"num","attrib":{"value":"1984"},"text":"§ 1984.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization of marine debris in existing innovation and entrepreneurship programs","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In carrying out any relevant innovation and entrepreneurship programs that improve the innovation, effectiveness, and efficiency of the Marine Debris Program established under section 1952 ","children":[{"tag":"ref","attrib":{"idref":"fn002095"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002095"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title without undermining the purpose for which such program was established, the Secretary of Commerce, the Secretary of Energy, the EPA Administrator, and the heads of other relevant Federal agencies, shall prioritize efforts to combat marine debris, including by—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c2751d3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1984/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing innovation in methods and the effectiveness of efforts to identify, determine sources of, assess, prevent, reduce, and remove marine debris; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c2751d4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1984/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" addressing the impacts of marine debris on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c2751d5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1984/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the economy of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c2751d6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1984/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the marine environment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c2751d7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1984/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" navigation safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c2751d8-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/449/s134"},"text":"Pub. L. 109–449, § 134","children":[],"tail":", formerly § 10, as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/224/tI/s101/3"},"text":"Pub. L. 116–224, title I, § 101(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-18"},"text":"Dec. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1075"},"text":"134 Stat. 1075","children":[],"tail":"; renumbered § 134 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/65"},"text":"Pub. L. 119–65","children":[],"tail":", §§ 4(b)(1), 6(e), "},{"tag":"date","attrib":{"date":"2025-12-26"},"text":"Dec. 26, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1989"},"text":"139 Stat. 1989","children":[],"tail":", 1990.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c2751d9-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c2751da-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c2751db-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1952"},"text":"Section 1952 of this title","children":[],"tail":", referred to in text, was in the original “section 3”, and was translated as reading “section 101” of "},{"tag":"ref","attrib":{"href":"/us/pl/109/449"},"text":"Pub. L. 109–449","children":[],"tail":" to reflect the probable intent of Congress and the renumbering of section 3 as 101 by "},{"tag":"ref","attrib":{"href":"/us/pl/119/65/s2/a/2"},"text":"Pub. L. 119–65, § 2(a)(2)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c2751dc-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1959"},"text":"section 1959 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/119/65"},"text":"Pub. L. 119–65","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c2751dd-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/65/s6/e"},"text":"Pub. L. 119–65, § 6(e)","children":[],"tail":", substituted “EPA Administrator” for “Administrator of the Envi