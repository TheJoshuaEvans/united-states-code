{"tag":"section","attrib":{"id":"id6b9d1262-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1203"},"text":null,"children":[{"tag":"num","attrib":{"value":"1203"},"text":"§ 1203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Radiotelephone requirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b9d1263-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1203/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vessel coverage; exchange of navigational information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1206"},"text":"section 1206 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b9d1264-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1203/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" every power-driven vessel of twenty meters or over in length while navigating;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b9d1265-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1203/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" every vessel of one hundred gross tons as measured under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of title 46","children":[],"tail":", or an alternate tonnage measured under section 14302 of that title as prescribed by the Secretary under section 14104 of that title, and upward carrying one or more passengers for hire while navigating;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b9d1266-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1203/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" every towing vessel of twenty-six feet or over in length while navigating; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b9d1267-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1203/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" every dredge and floating plant engaged in or near a channel or fairway in operations likely to restrict or affect navigation of other vessels—","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall have a radiotelephone capable of operation from its navigational bridge or, in the case of a dredge, from its main control station and capable of transmitting and receiving on the frequency or frequencies within the 156–162 Mega-Hertz band using the classes of emissions designated by the Federal Communications Commission, after consultation with other cognizant agencies, for the exchange of navigational information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b9f5c58-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1203/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vessels upon navigable waters of United States inside high seas lines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The radiotelephone required by subsection (a) shall be carried on board the described vessels, dredges, and floating plants upon the navigable waters of the United States, which includes all waters of the territorial sea of the United States as described in Presidential Proclamation 5928 of ","children":[{"tag":"date","attrib":{"date":"1988-12-27"},"text":"December 27, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b9f5c59-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/63/s4"},"text":"Pub. L. 92–63, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-08-04"},"text":"Aug. 4, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/164"},"text":"85 Stat. 164","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/241/s16"},"text":"Pub. L. 102–241, § 16","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2213"},"text":"105 Stat. 2213","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/324/tVII/s704"},"text":"Pub. L. 104–324, title VII, § 704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3933"},"text":"110 Stat. 3933","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/295/tIII/s321"},"text":"Pub. L. 107–295, title III, § 321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2103"},"text":"116 Stat. 2103","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b9f5c5a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b9f5c5b-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6b9f5c5c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Presidential Proclamation 5928 of ","children":[{"tag":"date","attrib":{"date":"1988-12-27"},"text":"December 27, 1988","children":[],"tail":", referred to in subsec. (b), is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1331"},"text":"section 1331 of Title 43","children":[],"tail":", Public Lands."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b9f5c5d-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295"},"text":"Pub. L. 107–295","children":[],"tail":" substituted “United States, which includes all waters of the territorial sea of the United States as described in Presidential Proclamation 5928 of "},{"tag":"date","attrib":{"date":"1988-12-27"},"text":"December 27, 1988","children":[],"tail":"” for “United States inside the lines established pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s151"},"text":"section 151 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324"},"text":"Pub. L. 104–324","children":[],"tail":" inserted “as measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of title 46","children":[],"tail":", or an alternate tonnage measured under section 14302 of that title as prescribed by the Secretary under section 14104 of that title,” after “one hundred gross tons”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/241"},"text":"Pub. L. 102–241","children":[],"tail":" amended par. (1) generally, substituting “twenty meters or over in length” for “three hundred gross tons and upward”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b9f5c5e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id6b9f5c5f-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1971-05-01"},"text":"May 1, 1971","children":[],"tail":", or six months after the promulgation of regulations which would implement its provisions, whichever is later, see "},{"tag":"ref","attrib":{"href":"/us/pl/92/63/s10"},"text":"section 10 of Pub. L. 92–63","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1201"},"text":"section 1201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b9f5c60-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Vessel Communication Equipment Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380/tIV/s4118"},"text":"Pub. L. 101–380, title IV, § 4118","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/523"},"text":"104 Stat. 523","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/380/tIV/s4118"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Secretary shall, not later than one year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":"], issue regulations necessary to ensure that vessels subject to the Vessel Bridge-to-Bridge Radiotelephone Act of 1971 ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1203"},"text":"33 U.S.C. 1203","children":[],"tail":") are also equipped as necessary to—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive radio marine navigation safety warnings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage in radio communications on designated frequencies with the Coast Guard, and such other vessels and stations as may be specified by the Secretary.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
