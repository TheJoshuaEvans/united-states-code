{"tag":"section","attrib":{"id":"id6c24e09b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1955"},"text":null,"children":[{"tag":"num","attrib":{"value":"1955"},"text":"§ 1955.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal information clearinghouse","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Under Secretary, in coordination with the Interagency Committee, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c24e09c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1955/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain a Federal information clearinghouse on marine debris that will be available to researchers and other interested persons to improve marine debris source identification, data sharing, and monitoring efforts through collaborative research and open sharing of data; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c24e09d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1955/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take the necessary steps to ensure the confidentiality of such information (especially proprietary information), for any information required by the Under Secretary to be submitted under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c24e09e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/449/s104"},"text":"Pub. L. 109–449, § 104","children":[],"tail":", formerly § 6, "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3338"},"text":"120 Stat. 3338","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/213/tVI/s607"},"text":"Pub. L. 112–213, title VI, § 607","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-20"},"text":"Dec. 20, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1578"},"text":"126 Stat. 1578","children":[],"tail":"; renumbered § 104 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/65"},"text":"Pub. L. 119–65","children":[],"tail":", §§ 2(a)(2), 6(a), "},{"tag":"date","attrib":{"date":"2025-12-26"},"text":"Dec. 26, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1986"},"text":"139 Stat. 1986","children":[],"tail":", 1990.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c24e09f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c24e0a0-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c24e0a1-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/65/s6/a"},"text":"Pub. L. 119–65, § 6(a)","children":[],"tail":", which directed substitution of “Under Secretary” for “Administrator”, was executed by making the substitution in both introductory provisions and par. (2), to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213"},"text":"Pub. L. 112–213","children":[],"tail":" struck out “by the fishing industry” after “to be submitted”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
