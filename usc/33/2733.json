{"tag":"section","attrib":{"id":"id6c6ee172-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2733"},"text":null,"children":[{"tag":"num","attrib":{"value":"2733"},"text":"§ 2733.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bligh Reef light","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Transportation shall within one year after ","children":[{"tag":"date","attrib":{"date":"1990-08-18"},"text":"August 18, 1990","children":[],"tail":", install and ensure operation of an automated navigation light on or adjacent to Bligh Reef in Prince William Sound, Alaska, of sufficient power and height to provide long-range warning of the location of Bligh Reef."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6c6ee173-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380/tV/s5003"},"text":"Pub. L. 101–380, title V, § 5003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/553"},"text":"104 Stat. 553","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
