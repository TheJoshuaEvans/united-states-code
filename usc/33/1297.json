{"tag":"section","attrib":{"id":"id6bc58184-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1297"},"text":null,"children":[{"tag":"num","attrib":{"value":"1297"},"text":"§ 1297.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines for cost-effectiveness analysis","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any guidelines for cost-effectiveness analysis published by the Administrator under this subchapter shall provide for the identification and selection of cost effective alternatives to comply with the objectives and goals of this chapter and sections 1281(b), 1281(d), 1281(g)(2)(A), and 1311(b)(2)(B) of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6bc58185-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"June 30, 1948, ch. 758","children":[],"tail":", title II, § 217, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/217/s41"},"text":"Pub. L. 95–217, § 41","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-12-27"},"text":"Dec. 27, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1582"},"text":"91 Stat. 1582","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
