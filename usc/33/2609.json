{"tag":"section","attrib":{"id":"id6c65446d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2609"},"text":null,"children":[{"tag":"num","attrib":{"value":"2609"},"text":"§ 2609.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c65446e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2609/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b) of this section, a person violating this chapter is liable to the United States Government for a civil penalty of not more than $25,000. Each day of a continuing violation is a separate violation. A vessel involved in the violation also is liable in rem for the penalty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c65446f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2609/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operating without a permit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person violating ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2602"},"text":"section 2602 of this title","children":[],"tail":" is liable to the United States Government for a civil penalty of not more than $10,000. Each day of a continuing violation is a separate violation. A vessel involved in the violation also is liable in rem for the penalty."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c654470-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2609/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person that knowingly violates, or that knowingly aids, abets, authorizes, or instigates a violation of this chapter, shall be fined under title 18, imprisoned for not more than 3 years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c654471-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2609/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments for information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The court, the Secretary of Transportation, or the Administrator, as the case may be, may pay up to one-half of a fine or penalty to any person giving information leading to the assessment of the fine or penalty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c654472-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/688/tIV/s4109"},"text":"Pub. L. 100–688, title IV, § 4109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4158"},"text":"102 Stat. 4158","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
