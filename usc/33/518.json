{"tag":"section","attrib":{"id":"id6b3b43e6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s518"},"text":null,"children":[{"tag":"num","attrib":{"value":"518"},"text":"§ 518.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b3b43e7-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-06-21/ch409/s8"},"text":"June 21, 1940, ch. 409, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/500"},"text":"54 Stat. 500","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b3b43e8-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b3b43e9-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b3b43ea-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Alteration of Bridges","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/90/tII"},"text":"Pub. L. 108–90, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-10-01"},"text":"Oct. 1, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1144"},"text":"117 Stat. 1144","children":[],"tail":", provided in part: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/90/tII"},"text":"“That in fiscal year 2004 and thereafter, funds for bridge alteration projects conducted pursuant to the Act of ","children":[{"tag":"date","attrib":{"date":"1940-06-21"},"text":"June 21, 1940","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s511"},"text":"33 U.S.C. 511","children":[],"tail":" et seq.) shall be available for such projects only to the extent that the steel, iron, and manufactured products used in such projects are produced in the United States, unless contrary to law or international agreement, or unless the Commandant of the Coast Guard determines such action to be inconsistent with the public interest or the cost unreasonable.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation act:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dI/tI"},"text":"Pub. L. 108–7, div. I, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/389"},"text":"117 Stat. 389","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
