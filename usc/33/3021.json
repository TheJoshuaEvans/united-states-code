{"tag":"section","attrib":{"id":"id6c760e1c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3021"},"text":null,"children":[{"tag":"num","attrib":{"value":"3021"},"text":"§ 3021.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Original appointments and reappointments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c760e1d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3021/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Original appointments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c760e1e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3021/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grades","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c760e1f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3021/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subparagraph (B), an original appointment of an officer may be made in such grades as may be appropriate for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c760e20-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3021/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the qualification, experience, and length of service of the appointee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c760e21-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3021/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the commissioned officer corps of the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c760e22-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3021/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of officer candidates","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c760e23-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3021/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on grade","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An original appointment of an officer candidate, upon graduation from the basic officer training program of the commissioned officer corps of the Administration, may not be made in any other grade than ensign.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c760e24-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3021/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rank","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Officer candidates receiving appointments as ensigns upon graduation from the basic officer training program shall take rank according to their proficiency as shown by the order of their merit at date of graduation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760e25-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3021/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Source of appointments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An original appointment may be made from among the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c760e26-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3021/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Graduates of the basic officer training program of the commissioned officer corps of the Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c760e27-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3021/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to the approval of the Secretary of Defense, graduates of the military service academies of the United States who otherwise meet the academic standards for enrollment in the training program described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c760e28-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3021/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Graduates of the State maritime academies who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c760e29-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3021/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise meet the academic standards for enrollment in the training program described in subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c760e2a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3021/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" completed at least three years of regimented training while at a State maritime academy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c760e2b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3021/a/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtained an unlimited tonnage or unlimited horsepower Merchant Mariner Credential from the United States Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c760e2c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3021/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Licensed officers of the United States merchant marine who have served two or more years aboard a vessel of the United States in the capacity of a licensed officer, who otherwise meet the academic standards for enrollment in the training program described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760e2d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3021/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c760e2e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3021/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military service academies of the United States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “military service academies of the United States” means the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c760e2f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3021/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Military Academy, West Point, New York.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c760e30-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3021/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Naval Academy, Annapolis, Maryland.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c760e31-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3021/a/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Air Force Academy, Colorado Springs, Colorado.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c760e32-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3021/a/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Coast Guard Academy, New London, Connecticut.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c760e33-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3021/a/3/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Merchant Marine Academy, Kings Point, New York.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c760e34-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3021/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State maritime academy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State maritime academy” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s51102"},"text":"section 51102 of title 46","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c760e35-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3021/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reappointment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c760e36-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3021/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), an individual who previously served in the commissioned officer corps of the Administration may be appointed by the Secretary to the grade the individual held prior to separation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760e37-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3021/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reappointments to higher grades","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An appointment under paragraph (1) to a position of importance and responsibility designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3028"},"text":"section 3028 of this title","children":[],"tail":" may only be made by the President."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c760e38-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3021/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An appointment under subsection (a) or (b) may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c760e39-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3021/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be given only to an individual who is a citizen of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760e3a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3021/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not be given.","children":[{"tag":"ref","attrib":{"idref":"fn002132"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002132"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The period probably should not appear."}],"tail":" to an individual until the individual’s mental, moral, physical, and professional fitness to perform the duties of an officer has been established under such regulations as the Secretary shall prescribe."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c760e3b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3021/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Order of precedence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Appointees under this section shall take precedence in the grade to which appointed in accordance with the dates of their commissions as commissioned officers in such grade. The order of precedence of appointees whose dates of commission are the same shall be determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c760e3c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3021/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inter-service transfers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For inter-service transfers (as described in Department of Defense Directive 1300.4 (dated ","children":[{"tag":"date","attrib":{"date":"2006-12-27"},"text":"December 27, 2006","children":[],"tail":")) the Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c760e3d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3021/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with the Secretary of Defense and the Secretary of the Department in which the Coast Guard is operating to promote and streamline inter-service transfers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760e3e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3021/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give preference to such inter-service transfers for recruitment purposes as determined appropriate by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760e3f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3021/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reappoint such inter-service transfers to the equivalent grade in the commissioned officer corps of the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c760e40-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372/tII/s221"},"text":"Pub. L. 107–372, title II, § 221","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3084"},"text":"116 Stat. 3084","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/259/tIII/s301/a"},"text":"Pub. L. 116–259, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-23"},"text":"Dec. 23, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1169"},"text":"134 Stat. 1169","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXVII/s11702"},"text":"Pub. L. 117–263, div. K, title CXVII, § 11702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4156"},"text":"136 Stat. 4156","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c760e41-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c760e42-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6c760e43-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s853t"},"text":"section 853t of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/107/372"},"text":"Pub. L. 107–372","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c760e44-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “may—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) be given only to an individual who is a citizen of the United States; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) not be given.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"for “may not be given”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/259"},"text":"Pub. L. 116–259","children":[],"tail":" substituted “Original appointments and reappointments” for “Original appointments” in section catchline and amended text generally. Prior to amendment, text related to original appointments in the grades of ensign, lieutenant (junior grade), and lieutenant."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
