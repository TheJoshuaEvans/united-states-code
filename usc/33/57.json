{"tag":"section","attrib":{"id":"id6b0b8136-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s57"},"text":null,"children":[{"tag":"num","attrib":{"value":"57"},"text":"§ 57.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pike Creek, Wisconsin","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Pike Creek, in the State of Wisconsin, above the easterly side of the highway bridge at Sixth Avenue in the city of Kenosha is declared to be a nonnavigable stream within the meaning of the Constitution and laws of the United States.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The right to alter, amend, or repeal this section is expressly reserved.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b0b8137-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-26/ch377"},"text":"July 26, 1955, ch. 377","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/373"},"text":"69 Stat. 373","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
