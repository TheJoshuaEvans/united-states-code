{"tag":"section","attrib":{"id":"id6c275183-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1974"},"text":null,"children":[{"tag":"num","attrib":{"value":"1974"},"text":"§ 1974.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judges","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c275184-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1974/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall appoint not fewer than 3 judges who shall, except as provided in subsection (b), select the 1 or more annual winners of the prize competition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c275185-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1974/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination by the Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The judges appointed under subsection (a) shall not select any annual winner of the prize competition if the Secretary makes a determination that, in any fiscal year, none of the technological advancements entered into the prize competition merits an award.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c275186-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/449/s124"},"text":"Pub. L. 109–449, § 124","children":[],"tail":", formerly "},{"tag":"ref","attrib":{"href":"/us/pl/116/224/tI/s124"},"text":"Pub. L. 116–224, title I, § 124","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-18"},"text":"Dec. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1083"},"text":"134 Stat. 1083","children":[],"tail":"; renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/109/449/s124"},"text":"Pub. L. 109–449, § 124","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/119/65/s4/a"},"text":"Pub. L. 119–65, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-26"},"text":"Dec. 26, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1989"},"text":"139 Stat. 1989","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c275187-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c275188-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c275189-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s4234"},"text":"section 4234 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/119/65"},"text":"Pub. L. 119–65","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
