{"tag":"section","attrib":{"id":"id6c54a2b8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2320"},"text":null,"children":[{"tag":"num","attrib":{"value":"2320"},"text":"§ 2320.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of recreational and commercial uses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c54a2b9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2320/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In planning any water resources project, the Secretary shall consider the impact of the project on existing and future recreational and commercial uses in the area surrounding the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c54a2ba-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2320/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever the Secretary maintains, repairs, rehabilitates, or reconstructs a water resources project which will result in a change in the configuration of a structure which is a part of such project, the Secretary, to the maximum extent practicable, shall carry out such maintenance, repair, rehabilitation, or reconstruction in a manner which will not adversely affect any recreational use established with respect to such project before the date of such maintenance, repair, rehabilitation, or reconstruction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c54a2bb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2320/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mitigation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c54a2bc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2320/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If maintenance, repair, rehabilitation, or reconstruction of a water resources project by the Secretary results in a change in the configuration of any structure which is a part of such project and has an adverse effect on a recreational use established with respect to such project before the date of such maintenance, repair, rehabilitation, or reconstruction, the Secretary, to the maximum extent practicable, shall take such actions as may be necessary to restore such recreational use or provide alternative opportunities for comparable recreational use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c54a2bd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2320/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not expend more than $2,000,000 in a fiscal year to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c54a2be-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2320/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall not be effective after the last day of the 5-year period beginning on ","children":[{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":"; except that the Secretary may complete any restoration commenced under this subsection on or before such last day."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c54a2bf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2320/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c54a2c0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2320/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsections (b) and (c) shall apply to maintenance, repair, rehabilitation, or reconstruction for which physical construction is initiated after ","children":[{"tag":"date","attrib":{"date":"1988-05-01"},"text":"May 1, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c54a2c1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2320/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsections (b) and (c) shall not apply to any action of the Secretary which is necessary to discontinue the operation of a water resources project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c54a2c2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2320/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Costs incurred by the Secretary to carry out the objectives of this section shall be allocated to recreation and shall be payable by the beneficiaries of the recreation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c54a2c3-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/640/tIII/s313"},"text":"Pub. L. 101–640, title III, § 313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4640"},"text":"104 Stat. 4640","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c54a2c4-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c54a2c5-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c54a2c6-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 1990, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c54a2c7-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c54a2c8-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/640/s2"},"text":"section 2 of Pub. L. 101–640","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
