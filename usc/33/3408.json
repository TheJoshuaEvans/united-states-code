{"tag":"section","attrib":{"id":"id6c81f517-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408"},"text":null,"children":[{"tag":"num","attrib":{"value":"3408"},"text":"§ 3408.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Ocean Mapping, Exploration, and Characterization Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c81f518-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall establish a council, to be known as the “National Ocean Mapping, Exploration, and Characterization Council” (in this section referred to as the “Council”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c81f519-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c81f51a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" update national priorities for ocean mapping, exploration, and characterization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c81f51b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate and facilitate activities to advance those priorities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c81f51c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall report to the Ocean Science and Technology Subcommittee of the Ocean Policy Committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8932/c"},"text":"section 8932(c) of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c81f51d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall be composed of senior-level representatives from the appropriate Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c81f51e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Co-Chairs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall be co-chaired by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c81f51f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two senior-level representatives from the National Oceanic and Atmospheric Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c81f520-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one senior-level representative from the Department of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c81f521-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c81f522-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set national ocean mapping, exploration, and characterization priorities and strategies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c81f523-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cultivate and facilitate transparent and sustained partnerships among Federal and State agencies, Indian Tribes, private industry, academia, and nongovernmental organizations to conduct ocean mapping, exploration, and characterization activities and related technology development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c81f524-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate improved processes for data compilation, management, access, synthesis, and visualization with respect to ocean mapping, exploration, and characterization, with a focus on building on existing ocean data management systems and with appropriate safeguards on the public accessibility of data to protect national security equities, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c81f525-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" encourage education, workforce training, and public engagement activities that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c81f526-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advance interdisciplinary principles that contribute to ocean mapping, exploration, research, and characterization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c81f527-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve public engagement with and understanding of ocean science; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c81f528-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/f/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide opportunities for underserved populations;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c81f529-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate activities as appropriate with domestic and international ocean mapping, exploration, and characterization initiatives or programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c81f52a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and monitor metrics to track progress in achieving the priorities set under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c81f52b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency Working Group on Ocean Exploration and Characterization","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c81f52c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall establish a new interagency working group to be known as the “Interagency Working Group on Ocean Exploration and Characterization”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c81f52d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Interagency Working Group on Ocean Exploration and Characterization shall be comprised of senior representatives from Federal agencies with ocean exploration and characterization responsibilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c81f52e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Interagency Working Group on Ocean Exploration and Characterization shall support the Council and the Ocean Science and Technology Subcommittee of the Ocean Policy Committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8932/c"},"text":"section 8932(c) of title 10","children":[],"tail":" on ocean exploration and characterization activities and associated technology development across the Federal Government, State governments, Indian Tribes, private industry, nongovernmental organizations, and academia."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c843e1f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oversight","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall oversee—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c843e20-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Interagency Working Group on Ocean Exploration and Characterization established under subsection (g)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c843e21-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Interagency Working Group on Ocean and Coastal Mapping under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3502"},"text":"section 3502 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c843e22-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c843e23-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", the Council shall develop or update and submit to the appropriate committees of Congress a plan for an integrated cross-sectoral ocean mapping, exploration, and characterization initiative."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c843e24-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan required by paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c843e25-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discuss the utility and benefits of ocean exploration and characterization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c843e26-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and describe national ocean mapping, exploration, and characterization priorities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c843e27-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/i/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and describe Federal and federally funded ocean mapping, exploration, and characterization programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c843e28-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/i/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate and incorporate non-Federal input into national ocean mapping, exploration, and characterization priorities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c843e29-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/i/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure effective coordination of ocean mapping, exploration, and characterization activities among programs described in subparagraph (C);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c843e2a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/i/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify opportunities for combining overlapping or complementary needs, activities, and resources of Federal agencies and non-Federal organizations relating to ocean mapping, exploration, and characterization while not reducing benefits from existing mapping, explorations, and characterization activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c843e2b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/i/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote new and existing partnerships among Federal and State agencies, Indian Tribes, private industry, academia, and nongovernmental organizations to conduct or support ocean mapping, exploration, and characterization activities and technology development needs, including through coordination under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s4102"},"text":"section 4102 of this title","children":[],"tail":" and the National Oceanographic Partnership Program under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8931"},"text":"section 8931 of title 10","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c843e2c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/i/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop a transparent and sustained mechanism for non-Federal partnerships and stakeholder engagement in strategic planning and mission execution to be implemented not later than ","children":[{"tag":"date","attrib":{"date":"2023-12-31"},"text":"December 31, 2023","children":[],"tail":", for coordinating such activities with—"}],"tail":null},{"tag":"clause","attrib":{"id":"id6c843e2d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/i/2/H/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions of higher education (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001/a"},"text":"section 1001(a) of title 20","children":[],"tail":", the private sector, philanthropic organizations, and nonprofits; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c843e2e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/i/2/H/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" international partners for activities relating to maritime areas (including the sea floor) beyond the jurisdiction of the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c843e2f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/i/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish standardized collection and data management protocols, including with respect to metadata, for ocean mapping, exploration, and characterization which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c843e30-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/i/2/I/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are publicly accessible and locatable via appropriate Federal repositories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c843e31-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/i/2/I/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" can facilitate the integration of ocean data into products and use innovations from non-Federal partners; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c843e32-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/i/2/I/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have appropriate safeguards on the public accessibility of data to protect national security;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c843e33-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/i/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage the development, testing, demonstration, and adoption of innovative ocean mapping, exploration, and characterization technologies and applications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c843e34-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/i/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote protocols for accepting data, equipment, approaches, or other resources that support national ocean mapping, exploration, and characterization priorities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c843e35-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/i/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify best practices for the protection of marine life during mapping, exploration, and characterization activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c843e36-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/i/2/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify training, technology, and other resource requirements for enabling the National Oceanic and Atmospheric Administration and other appropriate Federal agencies to support a coordinated national ocean mapping, exploration, and characterization effort;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c843e37-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/i/2/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and facilitate a centralized mechanism or office for coordinating data collection, compilation, processing, archiving, and dissemination activities relating to ocean mapping, exploration, and characterization that meets Federal mandates for data accuracy and accessibility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c843e38-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/i/2/O"},"text":null,"children":[{"tag":"num","attrib":{"value":"O"},"text":"(O)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate repositories responsible for archiving and managing ocean mapping, exploration, and characterization data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c843e39-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/i/2/P"},"text":null,"children":[{"tag":"num","attrib":{"value":"P"},"text":"(P)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth a timetable and estimated costs for implementation and completion of the plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c843e3a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/i/2/Q"},"text":null,"children":[{"tag":"num","attrib":{"value":"Q"},"text":"(Q)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, align ocean exploration and characterization efforts with existing programs and identify key gaps; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c843e3b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/i/2/R"},"text":null,"children":[{"tag":"num","attrib":{"value":"R"},"text":"(R)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify criteria for determining the optimal frequency of observations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c843e3c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/i/2/S"},"text":null,"children":[{"tag":"num","attrib":{"value":"S"},"text":"(S)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide recommendations, developed in coordination with the private sector, to improve incentives, access, and processes for the private sector to share ocean-related data with the public and Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c843e3d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Briefings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", and not less frequently than once every 2 years thereafter, the Council shall brief the appropriate committees of Congress on—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c843e3e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" progress made toward meeting the national priorities described in subsection (i)(2)(B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c843e3f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for meeting such priorities, such as additional authorities that may be needed to develop a mechanism for non-Federal partnerships and stakeholder engagement described in subsection (i)(2)(H).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c843e40-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate committees of Congress defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “appropriate committees of Congress” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c843e41-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Commerce, Science, and Transportation and the Committee on Armed Services of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c843e42-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3408/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Natural Resources, the Committee on Science, Space, and Technology, and the Committee on Armed Services of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c843e43-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tCIII/s10304"},"text":"Pub. L. 117–263, div. J, title CIII, § 10304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3968"},"text":"136 Stat. 3968","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c843e44-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c843e45-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c843e46-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of James M. Inhofe National Defense Authorization Act for Fiscal Year 2023, and not as part of the Omnibus Public Land Management Act of 2009 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c843e47-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c843e48-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tCIII/s10301"},"text":"Pub. L. 117–263, div. J, title CIII, § 10301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3966"},"text":"136 Stat. 3966","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dJ/tCIII/s10301"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress makes the following findings:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The health and resilience of the ocean are vital to the security and economy of the United States and to the lives of the people of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States depends on the ocean to regulate weather and climate, to sustain and protect the diversity of life, for maritime shipping, for national defense, and for food, energy, medicine, recreation, and other services essential to the people of the United States and all humankind.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The prosperity, security, and well-being of the United States depend on successful understanding and stewardship of the ocean.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Interdisciplinary cooperation and engagement among government agencies, research institutions, nongovernmental organizations, States, Indian Tribes, and the private sector are essential for successful stewardship of ocean and coastal environments, national economic growth, national security, and development of agile strategies that develop, promote, and use new technologies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ocean exploration can help the people of the United States understand how to be effective stewards of the ocean and serve as catalysts and enablers for other sectors of the economy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Mapping, exploration, and characterization of the ocean provides basic, essential information to protect and restore the marine environment, stimulate economic activity, and provide security for the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A robust national ocean exploration program engaging multiple Federal agencies, Indian Tribes, the private sector, nongovernmental organizations, and academia is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" essential to the interests of the United States and vital to its security and economy and the health and well-being of all people of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" critical to reestablish the United States at the forefront of global ocean exploration and stewardship.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id6c843e49-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tCIII/s10302"},"text":"Pub. L. 117–263, div. J, title CIII, § 10302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3966"},"text":"136 Stat. 3966","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dJ/tCIII/s10302"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this title [see Tables for classification]:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Characterization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘characterization’ means activities that provide comprehensive data and interpretations for a specific area of interest of the sea floor, sub-bottom, water column, or hydrologic features, including water masses and currents, in direct support of specific research, environmental protection, resource management, policymaking, or applied mission objectives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exploration","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘exploration’ means activities that provide—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a multidisciplinary view of an unknown or poorly understood area of the seafloor, sub-bottom, or water column; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an initial assessment of the physical, chemical, geological, biological, archeological, or other characteristics of such an area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Indian tribe","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Indian Tribe’ has the meaning given that term in section 4 of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"25 U.S.C. 5304","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Mapping","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘mapping’ means activities that provide comprehensive data and information needed to understand seafloor characteristics, such as depth, topography, bottom type, sediment composition and distribution, underlying geologic structure, and benthic flora and fauna.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
