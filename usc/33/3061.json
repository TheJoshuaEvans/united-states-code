{"tag":"section","attrib":{"id":"id6c78574a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3061"},"text":null,"children":[{"tag":"num","attrib":{"value":"3061"},"text":"§ 3061.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation with and transfer to military departments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c78574b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3061/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers of resources and officers during national emergency","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c78574c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3061/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may, whenever in the judgment of the President a sufficient national emergency exists, transfer to the service and jurisdiction of a military department such vessels, equipment, stations, and officers of the Administration as the President considers to be in the best interest of the country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c78574d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3061/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibility for funding of transferred resources and officers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After any such transfer all expenses connected therewith shall be defrayed out of the appropriations for the department to which the transfer is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c78574e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3061/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return of transferred resources and officers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such transferred vessels, equipment, stations, and officers shall be returned to the Administration when the national emergency ceases, in the opinion of the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c78574f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3061/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed as transferring the Administration or any of its functions from the Department of Commerce except in time of national emergency and to the extent provided in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c785750-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3061/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on transfer of officers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section does not authorize the transfer of an officer of the Administration to a military department if the accession or retention of that officer in that military department is otherwise not authorized by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c785751-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3061/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status of transferred officers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An officer of the Administration transferred under this section, shall, while under the jurisdiction of a military department, have proper military status and shall be subject to the laws, regulations, and orders for the government of the Army, Navy, or Air Force, as the case may be, insofar as the same may be applicable to persons whose retention permanently in the military service of the United States is not contemplated by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c785752-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372/tII/s251"},"text":"Pub. L. 107–372, title II, § 251","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3090"},"text":"116 Stat. 3090","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c785753-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c785754-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6c785755-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s855"},"text":"section 855 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/107/372"},"text":"Pub. L. 107–372","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id6c785756-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id6c785757-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of President under this section delegated to Secretary of Commerce by section 1(k) of Ex. Ord. No. 11023, ","children":[{"tag":"date","attrib":{"date":"1962-05-28"},"text":"May 28, 1962","children":[],"tail":", 27 F.R. 5131, as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of Title 3","children":[],"tail":", The President."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
