{"tag":"section","attrib":{"id":"id6c81f4ee-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3404"},"text":null,"children":[{"tag":"num","attrib":{"value":"3404"},"text":"§ 3404.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education, workforce training, and outreach","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c81f4ef-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3404/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator of the National Oceanic and Atmospheric Administration shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c81f4f0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3404/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct education and outreach efforts in order to broadly disseminate information to the public on the discoveries made by the program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3402"},"text":"section 3402 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c81f4f1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3404/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent possible, coordinate the efforts described in paragraph (1) with the outreach strategies of other domestic or international ocean mapping, exploration, and characterization initiatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c81f4f2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3404/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a fellowship program at the National Oceanic and Atmospheric Administration to provide year-long fellowships to undergraduate students from institutions described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1067q/a"},"text":"section 1067q(a) of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c81f4f3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3404/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education and outreach efforts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Efforts described in subsection (a)(1) may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c81f4f4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3404/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" education of the general public, teachers, students, and ocean and coastal resource managers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c81f4f5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3404/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" workforce training, reskilling, and opportunities to encourage development of ocean-related science, technology, engineering, and mathematics technical training programs involving secondary schools, community colleges, and universities, including institutions described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1067q/a"},"text":"section 1067q(a) of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c81f4f6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3404/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach strategy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after the date of the enactment of the National Ocean Exploration Act,","children":[{"tag":"ref","attrib":{"idref":"fn002142"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002142"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" the Administrator of the National Oceanic and Atmospheric Administration shall develop an outreach strategy to broadly disseminate information on the discoveries made by the program under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s3402"},"text":"section 3402 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c81f4f7-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tXII/s12004"},"text":"Pub. L. 111–11, title XII, § 12004","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tCIII/s10305/e/1"},"text":"Pub. L. 117–263, div. J, title CIII, § 10305(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3973"},"text":"136 Stat. 3973","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c81f4f8-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c81f4f9-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c81f4fa-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the National Ocean Exploration Act, referred to in subsec. (c), probably means the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":". Prior versions of the bill that was enacted into law as title CIII of div. J of "},{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" included such Short Title, but it was not enacted as part of "},{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6c81f4fb-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3404, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tXII"},"text":"Pub. L. 111–11, title XII","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1418"},"text":"123 Stat. 1418","children":[],"tail":", related to an ocean exploration and undersea research technology and infrastructure task force, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tCIII/s10305/d"},"text":"Pub. L. 117–263, div. J, title CIII, § 10305(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3972"},"text":"136 Stat. 3972","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
