{"tag":"section","attrib":{"id":"id6c595d70-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326h"},"text":null,"children":[{"tag":"num","attrib":{"value":"2326h"},"text":"§ 2326h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Five-year regional dredged material management plans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c595d71-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", and annually thereafter, the District Commander of each district of the Corps of Engineers that obtains dredged material through the construction or operation and maintenance of a water resources development project shall, at Federal expense, develop and submit to the Secretary a 5-year dredged material management plan in coordination with relevant State agencies and stakeholders."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595d72-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each plan developed under this subsection shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c595d73-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a dredged material budget for each watershed or littoral system within the district;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c595d74-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the amount of dredged material likely to be obtained through the construction or operation and maintenance of all water resources development projects projected to be carried out within the district during the 5-year period following submission of the plan, and the estimated timing for obtaining such dredged material;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c595d75-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of potential water resources development projects projected to be carried out within the district during such 5-year period that are suitable for, or that require, the placement of dredged material, and an estimate of the amount of dredged material placement capacity of such projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c595d76-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326h/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an evaluation of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c595d77-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326h/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the suitability of the dredged material for a full range of beneficial uses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c595d78-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326h/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the economic and environmental benefits, efficiencies, and impacts (including the effects on living coral) of using the dredged material for beneficial uses, including, in the case of beneficial use activities that involve more than one water resources development project, the benefits, efficiencies, and impacts that result from the combined activities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c595d79-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326h/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the district-wide goals for beneficial use of the dredged material, including any expected cost savings from aligning and coordinating multiple projects (including projects across Corps districts) in the use of the dredged material; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c595d7a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326h/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of potential beneficial use projects identified through stakeholder solicitation and coordination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595d7b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public comment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing each plan under this subsection, each District Commander shall provide notice and an opportunity for public comment, including a solicitation for stakeholders to identify beneficial use projects, in order to ensure, to the extent practicable, that beneficial use of dredged material is not foregone in a particular fiscal year or dredging cycle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595d7c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon submission of each plan to the Secretary under this subsection, each District Commander shall make the plan publicly available, including on a publicly available website.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595d7d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326h/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmission to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after receiving a plan under subsection (a), the Secretary shall transmit the plan to Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595d7e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326h/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional sediment management plans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A plan developed under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c595d7f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326h/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be in addition to regional sediment management plans prepared under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2326/a"},"text":"section 2326(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c595d80-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326h/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be subject to the limitations in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2326/g"},"text":"section 2326(g) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c595d81-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/tI/s125/c"},"text":"Pub. L. 116–260, div. AA, title I, § 125(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2638"},"text":"134 Stat. 2638","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c595d82-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c595d83-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c595d84-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 2020, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c595d85-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c595d86-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/s2"},"text":"section 2 of div. AA of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
