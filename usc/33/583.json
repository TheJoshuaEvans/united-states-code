{"tag":"section","attrib":{"id":"id6b499b0b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s583"},"text":null,"children":[{"tag":"num","attrib":{"value":"583"},"text":"§ 583.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of allowances, etc., incident to change of station of Engineer officers from appropriation for improvements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When in the opinion of the Secretary of the Army the changes of a station of an officer of the Corps of Engineers is primarily in the interest of river and harbor improvement, the mileage and other allowances to which he may be entitled incident to such change of station may be paid from appropriations for such improvements.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b499b0c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1925-03-03/ch467/s5"},"text":"Mar. 3, 1925, ch. 467, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/1191"},"text":"43 Stat. 1191","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title II, § 205(a), "},{"tag":"ref","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b499b0d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b499b0e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id6b499b0f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Department of War designated Department of the Army and title of Secretary of War changed to Secretary of the Army by section 205(a) of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343/tII"},"text":"act July 26, 1947, ch. 343, title II","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":". Section 205(a) of act "},{"tag":"date","attrib":{"date":"1947-07-26"},"text":"July 26, 1947","children":[],"tail":", was repealed by section 53 of "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/641"},"text":"70A Stat. 641","children":[],"tail":". Section 1 of act "},{"tag":"date","attrib":{"date":"1956-08-10"},"text":"Aug. 10, 1956","children":[],"tail":", enacted “Title 10, Armed Forces” which in sections 3010 to 3013 continued Department of the Army under administrative supervision of Secretary of the Army."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
