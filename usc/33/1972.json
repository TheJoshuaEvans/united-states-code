{"tag":"section","attrib":{"id":"id6c275148-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1972"},"text":null,"children":[{"tag":"num","attrib":{"value":"1972"},"text":"§ 1972.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Genius Prize for Save Our Seas Innovations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c275149-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1972/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c27514a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1972/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2020-12-18"},"text":"December 18, 2020","children":[],"tail":", the Secretary shall establish under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3719"},"text":"section 3719 of title 15","children":[],"tail":" a prize competition—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c27514b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1972/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage technological innovation with the potential to reduce plastic waste, and associated and potential pollution, and thereby prevent marine debris; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c27514c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1972/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to award 1 or more prizes biennially for projects that advance human understanding and innovation in removing and preventing plastic waste, in one of the categories described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c27514d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1972/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Categories for projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The categories for projects are:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c27514e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1972/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advancements in materials used in packaging and other products that, if such products enter the coastal or ocean environment, will fully degrade without harming the environment, wildlife, or human health.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c27514f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1972/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Innovations in production and packaging design that reduce the use of raw materials, increase recycled content, encourage reusability and recyclability, and promote a circular economy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c275150-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1972/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Improvements in marine debris detection, monitoring, and cleanup technologies and processes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c275151-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1972/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Improvements or improved strategies to increase solid waste collection, processing, sorting, recycling, or reuse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c275152-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1972/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" New designs or strategies to reduce overall packaging needs and promote reuse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c275153-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1972/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The prize competition established under subsection (a) shall be known as the “Genius Prize for Save Our Seas Innovations”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c275154-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1972/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting awards for the prize competition, priority shall be given to projects that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c275155-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1972/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a strategy, submitted with the application or proposal, to move the new technology, process, design, material, or other product supported by the prize to market-scale deployment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c275156-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1972/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the concept of a circular economy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c275157-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1972/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" promote development of materials that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c275158-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1972/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" can fully degrade in the ocean without harming the environment, wildlife, or human health; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c275159-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1972/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are to be used in fishing gear or other maritime products that have an increased likelihood of entering the coastal or ocean environment as unintentional waste.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c27515a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/449/s122"},"text":"Pub. L. 109–449, § 122","children":[],"tail":", formerly "},{"tag":"ref","attrib":{"href":"/us/pl/116/224/tI/s122"},"text":"Pub. L. 116–224, title I, § 122","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-18"},"text":"Dec. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1081"},"text":"134 Stat. 1081","children":[],"tail":"; renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/109/449/s122"},"text":"Pub. L. 109–449, § 122","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/119/65/s4/a"},"text":"Pub. L. 119–65, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-26"},"text":"Dec. 26, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1989"},"text":"139 Stat. 1989","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c27515b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c27515c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c27515d-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s4232"},"text":"section 4232 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/119/65"},"text":"Pub. L. 119–65","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
