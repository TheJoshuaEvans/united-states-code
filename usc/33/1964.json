{"tag":"section","attrib":{"id":"id6c275107-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1964"},"text":null,"children":[{"tag":"num","attrib":{"value":"1964"},"text":"§ 1964.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative services and support","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c275108-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1964/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary may provide personnel, facilities, and other administrative services to the Foundation, including reimbursement of expenses, not to exceed the current Federal Government per diem rates, for a period of up to 5 years beginning on ","children":[{"tag":"date","attrib":{"date":"2020-12-18"},"text":"December 18, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c275109-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1964/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary shall require reimbursement from the Foundation for any administrative service provided under subsection (a). The Under Secretary shall deposit any reimbursement received under this subsection into the Treasury to the credit of the appropriations then current and chargeable for the cost of providing such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c27510a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"hre