{"tag":"section","attrib":{"id":"id6b283034-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426f"},"text":null,"children":[{"tag":"num","attrib":{"value":"426f"},"text":"§ 426f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b283035-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to reimburse non-Federal interests for work done by them, after initiation of the survey studies which form the basis for the project or separable element of the project, on authorized projects or separable elements which individually do not exceed $1,000,000 in total cost: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the work which may have been done on the projects or separable elements is approved by the Chief of Engineers as being in accordance with the authorized projects or separable elements: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That such reimbursement shall be subject to appropriations applicable thereto or funds available therefor and shall not take precedence over other pending projects or separable elements of higher priority for improvements."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b283036-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b283037-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After authorization of reimbursement by the Secretary under this section, and before commencement of construction, of a shore protection project, the Secretary shall enter into a written agreement with the non-Federal interest with respect to the project or separable element.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b283038-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The agreement shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b283039-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426f/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify the life of the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b28303a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426f/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the Federal Government and the non-Federal interest will cooperate in carrying out the project or separable element.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b28303b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-13/ch960/s2"},"text":"Aug. 13, 1946, ch. 960, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/1056"},"text":"60 Stat. 1056","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title II, § 205(a), "},{"tag":"ref","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-07-28/ch768"},"text":"July 28, 1956, ch. 768","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/703"},"text":"70 Stat. 703","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/874/tI/s103/a/4"},"text":"Pub. L. 87–874, title I, § 103(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-23"},"text":"Oct. 23, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1178"},"text":"76 Stat. 1178","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/303/tII/s227/c/1"},"text":"Pub. L. 104–303, title II, § 227(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3699"},"text":"110 Stat. 3699","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b28303c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b28303d-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b28303e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/303"},"text":"Pub. L. 104–303","children":[],"tail":" inserted section catchline, designated existing provisions as subsec. (a), inserted heading, substituted “Secretary” for “Secretary of the Army” and “non-Federal interests” for “local interests”, inserted “or separable element of the project” after “project”, inserted “or separable elements” after “projects” wherever appearing, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/874"},"text":"Pub. L. 87–874","children":[],"tail":" substituted provisions which authorize the Secretary of the Army to reimburse local interests for work done on authorized projects which individually do not exceed $1,000,000 in cost, and provide that such reimbursement shall be subject to applicable appropriations or available funds and not take priority over pending projects of higher priority, for provisions which authorized the Chief of Engineers to cause to be paid to the political subdivision involved the amount authorized by Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1956—Act ","children":[{"tag":"date","attrib":{"date":"1956-07-28"},"text":"July 28, 1956","children":[],"tail":", substituted “or other political subdivision involved” for “or political subdivision”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b28303f-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id6b283040-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Department of War designated Department of the Army and title of Secretary of War changed to Secretary of the Army by section 205(a) of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343/tII"},"text":"act July 26, 1947, ch. 343, title II","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":". Section 205(a) of act "},{"tag":"date","attrib":{"date":"1947-07-26"},"text":"July 26, 1947","children":[],"tail":", was repealed by section 53 of "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/641"},"text":"70A Stat. 641","children":[],"tail":". Section 1 of act "},{"tag":"date","attrib":{"date":"1956-08-10"},"text":"Aug. 10, 1956","children":[],"tail":", enacted “Title 10, Armed Forces” which in sections 3010 to 3013 continued Department of the Army under administrative supervision of Secretary of the Army."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id6b283041-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions, powers, and duties of Secretary of the Army and other offices and officers of Department of the Army under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s401"},"text":"section 401 of this title","children":[],"tail":" to extent that they relate generally to location and clearances of bridges and causeways in navigable waters of United States transferred to and vested in Secretary of Transportation by "},{"tag":"ref","attrib":{"href":"/us/pl/89/670/s6/g/6/A"},"text":"Pub. L. 89–670, § 6(g)(6)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-15"},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/941"},"text":"80 Stat. 941","children":[],"tail":", which created Department of Transportation. "},{"tag":"ref","attrib":{"href":"/us/pl/97/449"},"text":"Pub. L. 97–449","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s401"},"text":"section 401 of this title","children":[],"tail":" to reflect transfer made by "},{"tag":"ref","attrib":{"href":"/us/pl/89/670/s6/g/6/A"},"text":"section 6(g)(6)(A) of Pub. L. 89–670","children":[],"tail":", and repealed section 6(g)(6)(A)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
