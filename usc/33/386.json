{"tag":"section","attrib":{"id":"id6b1c4954-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s386"},"text":null,"children":[{"tag":"num","attrib":{"value":"386"},"text":"§ 386.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commissioning private vessels for seizure of piratical vessels","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President is authorized to instruct the commanders of the public-armed vessels of the United States, and to authorize the commanders of any other armed vessels sailing under the authority of any letters of marque and reprisal granted by Congress, or the commanders of any other suitable vessels, to subdue, seize, take, and, if on the high seas, to send into any port of the United States, any vessel or boat built, purchased, fitted out, or held as mentioned in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s385"},"text":"section 385 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b1c4955-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(R.S. § 4298.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b1c4956-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b1c4957-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b1c4958-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 4298 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1861-08-05/ch48/s2"},"text":"act Aug. 5, 1861, ch. 48, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/12/315"},"text":"12 Stat. 315","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
