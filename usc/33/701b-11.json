{"tag":"section","attrib":{"id":"id6b5a3d39-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–11"},"text":null,"children":[{"tag":"num","attrib":{"value":"701b–11"},"text":"§ 701b–11.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Flood protection projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b5a3d3a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–11/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General considerations; nonstructural alternatives","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the survey, planning, or design by any Federal agency of any project involving flood protection, consideration shall be given to nonstructural alternatives to prevent or reduce flood damages, with a view toward formulating the most economically, socially, and environmentally acceptable means of reducing or preventing flood damage, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b5a3d3b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–11/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" floodproofing of structures, including through elevation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b5a3d3c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–11/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" floodplain regulation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b5a3d3d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–11/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquisition of floodplain land for recreational, fish and wildlife, and other public purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b5a3d3e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–11/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relocation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b5a3d3f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–11/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of a feature described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2289a/a"},"text":"section 2289a(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b5a3d40-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–11/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal participation through nonstructural alternatives; limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Where a nonstructural alternative is recommended, non-Federal participation shall be comparable to the value of lands, easements, and rights-of-way which would have been required of non-Federal interests under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s701c"},"text":"section 701c of this title","children":[],"tail":", for structural protection measures, but in no event shall exceed 20 per centum of the project costs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b5a3d41-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/251/tI/s73"},"text":"Pub. L. 93–251, title I, § 73","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-03-07"},"text":"Mar. 7, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/32"},"text":"88 Stat. 32","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/tI/s115/a"},"text":"Pub. L. 116–260, div. AA, title I, § 115(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2627"},"text":"134 Stat. 2627","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b5a3d42-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b5a3d43-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b5a3d44-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" substituted “, with a view toward formulating the most economically, socially, and environmentally acceptable means of reducing or preventing flood damage, including—” and pars. (1) to (5) for “including, but not limited to, floodproofing of structures; flood plain regulation; acquisition of flood plain lands for recreational, fish and wildlife, and other public purposes; and relocation with a view toward formulating the most economically, socially, and environmentally acceptable means of reducing or preventing flood damages.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b5a3d45-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b5a3d46-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Nonstructural Flood Control Policy","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/303/tII/s202/d"},"text":"Pub. L. 104–303, title II, § 202(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3675"},"text":"110 Stat. 3675","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/303/tII/s202/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall conduct a review of policies, procedures, and techniques relating to the evaluation and development of flood control measures with a view toward identifying impediments that may exist to justifying nonstructural flood control measures as alternatives to structural measures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":"], the Secretary shall transmit to Congress a report on the findings of the review conducted under this subsection, together with any recommendations for modifying existing law to remove any impediments identified under such review.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
