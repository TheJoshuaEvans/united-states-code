{"tag":"section","attrib":{"id":"id6b25bfda-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"426–3"},"text":"§ 426–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of functions of Beach Erosion Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All functions of the Beach Erosion Board pertaining to review of reports of investigations made concerning erosion of the shores of coastal and lake waters, and the protection of such shores, are hereby transferred to the Board established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s541"},"text":"section 541 of this title","children":[],"tail":", referred to as the Board of Engineers for Rivers and Harbors."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b25bfdb-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/172/s3"},"text":"Pub. L. 88–172, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-11-07"},"text":"Nov. 7, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/305"},"text":"77 Stat. 305","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b25bfdc-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b25bfdd-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b25bfde-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Termination of Board of Engineers for Rivers and Harbors and Reassignment of Duties and Responsibilities","children":[],"tai