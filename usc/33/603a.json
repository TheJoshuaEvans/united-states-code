{"tag":"section","attrib":{"id":"id6b4be5a8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s603a"},"text":null,"children":[{"tag":"num","attrib":{"value":"603a"},"text":"§ 603a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal of snags and debris, and straightening, clearing, and protecting channels in navigable waters","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Army is authorized to allot not to exceed $5,000,000 from any appropriations made prior to or after ","children":[{"tag":"date","attrib":{"date":"1945-03-02"},"text":"March 2, 1945","children":[],"tail":", for any one fiscal year for improvement of rivers and harbors, for removing accumulated snags, obstructions, and other debris located in or adjacent to a Federal channel, and for protecting, clearing, and straightening channels in navigable harbors and navigable streams and tributaries thereof, when in the opinion of the Chief of Engineers such work is advisable in the interest of navigation, flood control, ecosystem restoration, or recreation."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b4be5a9-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-03-02/ch19/s3"},"text":"Mar. 2, 1945, ch. 19, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/59/23"},"text":"59 Stat. 23","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title II, § 205(a), "},{"tag":"ref","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/662/tIX/s915/g"},"text":"Pub. L. 99–662, title IX, § 915(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4191"},"text":"100 Stat. 4191","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tI/s1164"},"text":"Pub. L. 114–322, title I, § 1164","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1670"},"text":"130 Stat. 1670","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dH/tLXXXI/s8381"},"text":"Pub. L. 117–263, div. H, title LXXXI, § 8381","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3828"},"text":"136 Stat. 3828","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b4be5aa-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b4be5ab-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b4be5ac-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “ecosystem restoration, or recreation” for “or recreation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322"},"text":"Pub. L. 114–322","children":[],"tail":" substituted “$5,000,000” for “$1,000,000”, “accumulated snags, obstructions, and other debris located in or adjacent to a Federal channel” for “accumulated snags and other debris”, and “, flood control, or recreation” for “or flood control”."}],"tail":"\n"},{"tag":"p","attrib":{},"tex