{"tag":"section","attrib":{"id":"id6b50a0be-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s642a"},"text":null,"children":[{"tag":"num","attrib":{"value":"642a"},"text":"§ 642a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rank, pay, and allowances of Corps of Engineers officers serving as President of Mississippi River Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any officer of the Corps of Engineers who has served or shall serve four years as President of the Mississippi River Commission and who has been or shall subsequently be retired, shall, from the date of such retirement, receive the rank, pay, and allowances of a retired major general.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b50a0bf-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-06-15/ch548"},"text":"June 15, 1936, ch. 548","children":[],"tail":" (pt.), as added "},{"tag":"ref","attrib":{"href":"/us/act/1941-08-18/ch377/s3"},"text":"Aug. 18, 1941, ch. 377, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/55/644"},"text":"55 Stat. 644","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b50a0c0-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b50a0c1-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b50a0c2-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t