{"tag":"section","attrib":{"id":"id6c419074-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2268"},"text":null,"children":[{"tag":"num","attrib":{"value":"2268"},"text":"§ 2268.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marine technology review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c419075-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2268/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dredging needs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to conduct such studies as are necessary to provide a report to Congress on the dredging needs of the national ports and harbors of the United States. The report shall include existing and projected future project depths, types and sizes of ships in use, and world trade patterns, an assessment of the future national waterside infrastructure needs, and a comparison of drafts of United States and selected world ports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c419076-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2268/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated $2,500,000 to carry out this section for fiscal years beginning after ","children":[{"tag":"date","attrib":{"date":"1992-09-30"},"text":"September 30, 1992","children":[],"tail":". Such sums shall remain available until expended."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c419077-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/580/tIV/s402"},"text":"Pub. L. 102–580, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-31"},"text":"Oct. 31, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4862"},"text":"106 Stat. 4862","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c419078-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c419079-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c41907a-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 1992, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c41907b-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c41907c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/580/s3"},"text":"section 3 of Pub. L. 102–580","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
