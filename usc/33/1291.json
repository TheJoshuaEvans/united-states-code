{"tag":"section","attrib":{"id":"id6bc33851-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1291"},"text":null,"children":[{"tag":"num","attrib":{"value":"1291"},"text":"§ 1291.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sewage collection systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6bc33852-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1291/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing and new systems","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No grant shall be made for a sewage collection system under this subchapter unless such grant (1) is for replacement or major rehabilitation of an existing collection system and is necessary to the total integrity and performance of the waste treatment works servicing such community, or (2) is for a new collection system in an existing community with sufficient existing or planned capacity adequately to treat such collected sewage and is consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1281"},"text":"section 1281 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bc33853-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1291/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of population density as test","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Administrator uses population density as a test for determining the eligibility of a collector sewer for assistance it shall be only for the purpose of evaluating alternatives and determining the needs for such system in relation to ground or surface water quality impact.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bc33854-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1291/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pollutant discharges from separate storm sewer systems","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No grant shall be made under this subchapter from funds authorized for any fiscal year during the period beginning ","children":[{"tag":"date","attrib":{"date":"1977-10-01"},"text":"October 1, 1977","children":[],"tail":", and ending "},{"tag":"date","attrib":{"date":"1990-09-30"},"text":"September 30, 1990","children":[],"tail":", for treatment works for control of pollutant discharges from separate storm sewer systems."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6bc33855-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"June 30, 1948, ch. 758","children":[],"tail":", title II, § 211, as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/500/s2"},"text":"Pub. L. 92–500, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-18"},"text":"Oct. 18, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/843"},"text":"86 Stat. 843","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/217/s36"},"text":"Pub. L. 95–217, § 36","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-12-27"},"text":"Dec. 27, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1581"},"text":"91 Stat. 1581","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/117/s2/b"},"text":"Pub. L. 97–117, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1623"},"text":"95 Stat. 1623","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/4/tII/s206/d"},"text":"Pub. L. 100–4, title II, § 206(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-02-04"},"text":"Feb. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/20"},"text":"101 Stat. 20","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6bc33856-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6bc33857-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6bc33858-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1987—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/4"},"text":"Pub. L. 100–4","children":[],"tail":" substituted “1990” for “1985”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/117"},"text":"Pub. L. 97–117","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1985-09-30"},"text":"September 30, 1985","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1982-09-30"},"text":"September 30, 1982","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/217"},"text":"Pub. L. 95–217","children":[],"tail":" designated existing provisions as subsec. (a) and added subsecs. (b) and (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
