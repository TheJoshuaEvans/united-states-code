{"tag":"section","attrib":{"id":"id6b5a3d2b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–8a"},"text":null,"children":[{"tag":"num","attrib":{"value":"701b–8a"},"text":"§ 701b–8a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discontinuance of preliminary examination reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For preliminary examinations and surveys authorized in previous river and harbor and flood control Acts, the Secretary of the Army is directed to cause investigations and reports for flood control and allied purposes, to be prepared under the supervision of the Chief of Engineers in the form of survey reports, and that preliminary examination reports shall no longer be required to be prepared.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b5a3d2c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/500/tII/s208"},"text":"Pub. L. 85–500, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-07-03"},"text":"July 3, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/319"},"text":"72 Stat. 319","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b5a3d2d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b5a3d2e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6b5a3d2f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Previous river and harbor and flood-control Acts, referred to in text, means those acts prior to the River and Harbor Act of 1958 and the Flood Control Act of 1958, titles I and II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/500"},"text":"Pub. L. 85–500","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
