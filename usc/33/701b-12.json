{"tag":"section","attrib":{"id":"id6b5a3d47-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–12"},"text":null,"children":[{"tag":"num","attrib":{"value":"701b–12"},"text":"§ 701b–12.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Floodplain management requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b5a3d48-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–12/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with floodplain management and insurance programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before construction of any project for local flood protection, or any project for hurricane or storm damage reduction, that involves Federal assistance from the Secretary, the non-Federal interest shall agree to participate in and comply with applicable Federal floodplain management and flood insurance programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b5a3d49-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–12/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Floodplain management plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 1 year after the date of signing a project cooperation agreement for construction of a project to which subsection (a) applies, the non-Federal interest shall prepare a floodplain management plan designed to reduce the impacts of future flood events in the project area. Such plan shall be implemented by the non-Federal interest not later than 1 year after completion of construction of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b5a3d4a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–12/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b5a3d4b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–12/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop guidelines for preparation of floodplain management plans by non-Federal interests under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b5a3d4c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–12/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The guidelines developed under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b5a3d4d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–12/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address potential measures, practices, and policies to be undertaken by non-Federal interests to to ","children":[{"tag":"ref","attrib":{"idref":"fn002025"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002025"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" reduce loss of life, injuries, damages to property and facilities, public expenditures, and other adverse impacts associated with flooding and to preserve and enhance natural floodplain values; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b5a3d4e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–12/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address those measures to be undertaken by non-Federal interests to preserve the level of flood protection provided by a project to which subsection (a) applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b5a3d4f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–12/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on statutory construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall be construed to confer any regulatory authority upon the Secretary or the Administrator of the Federal Emergency Management Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b5a3d50-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–12/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide technical support to a non-Federal interest for a project to which subsection (a) applies for the development and implementation of plans prepared under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b5a3d51-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662/tIV/s402"},"text":"Pub. L. 99–662, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4133"},"text":"100 Stat. 4133","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/676/s14"},"text":"Pub. L. 100–676, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-17"},"text":"Nov. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4026"},"text":"102 Stat. 4026","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/303/tII/s202/c/1"},"text":"Pub. L. 104–303, title II, § 202(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3674"},"text":"110 Stat. 3674","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/541/tII/s209/a"},"text":"Pub. L. 106–541, title II, § 209(a)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2000-12-11"},"text":"Dec. 11, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2591"},"text":"114 Stat. 2591","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s612/c"},"text":"Pub. L. 109–295, title VI, § 612(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1410"},"text":"120 Stat. 1410","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b5a3d52-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b5a3d53-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b5a3d54-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/541/s209/c"},"text":"Pub. L. 106–541, § 209(c)","children":[],"tail":", substituted “Floodplain” for “Flood plain” in heading and “floodplain” for “flood plain” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/541/s209/a"},"text":"Pub. L. 106–541, § 209(a)","children":[],"tail":", in first sentence substituted “The” for “Within 6 months after "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"October 12, 1996","children":[],"tail":", the”, designated second sentence as par. (2), inserted heading, substituted “The guidelines developed under paragraph (1) shall—” for “Such guidelines shall”, designated remainder of sentence as subpar. (A), inserted “to be undertaken by non-Federal interests to” after “policies”, added subpar. (B), and redesignated former par. (2) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/303"},"text":"Pub. L. 104–303","children":[],"tail":" substituted “Floodplain management requirements” for “Compliance with flood plain management and insurance programs” in section catchline and amended text generally. Prior to amendment, text read as follows: “Before construction of any project for local flood protection or any project for hurricane or storm damage reduction, the non-Federal interests shall agree to participate in and comply with applicable Federal flood plain management and flood insurance programs.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/676"},"text":"Pub. L. 100–676","children":[],"tail":" inserted “or any project for hurricane or storm damage reduction” after “local flood protection”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b5a3d55-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id6b5a3d56-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Administrator of the Federal Emergency Management Agency” substituted for “Director of the Federal Emergency Management Agency” in subsec. (c)(3) on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/s612/c"},"text":"section 612(c) of Pub. L. 109–295","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s313"},"text":"section 313 of Title 6","children":[],"tail":", Domestic Security. Any reference to the Administrator of the Federal Emergency Management Agency in title VI of "},{"tag":"ref","attrib":{"href":"/us/pl/109/295"},"text":"Pub. L. 109–295","children":[],"tail":" or an amendment by title VI to be considered to refer and apply to the Director of the Federal Emergency Management Agency until "},{"tag":"date","attrib":{"date":"2007-03-31"},"text":"Mar. 31, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/s612/f/2"},"text":"section 612(f)(2) of Pub. L. 109–295","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s313"},"text":"section 313 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6b5a3d57-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/541/tII/s209/b"},"text":"Pub. L. 106–541, title II, § 209(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-11"},"text":"Dec. 11, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2591"},"text":"114 Stat. 2591","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/541/tII/s209/b"},"text":"“The amendments made by subsection (a) [amending this section] shall apply to any project or separable element of a project with respect to which the Secretary [of the Army] and the non-Federal interest have not entered a project cooperation agreement on or before the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2000-12-11"},"text":"Dec. 11, 2000","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6b5a3d58-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/303/tII/s202/c/2"},"text":"Pub. L. 104–303, title II, § 202(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3675"},"text":"110 Stat. 3675","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/303/tII/s202/c/2"},"text":"“The amendment made by paragraph (1) [amending this section] shall apply to any project or separable element thereof with respect to which the Secretary and the non-Federal interest have not entered into a project cooperation agreement on or before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b5a3d59-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Reference to Project Cooperation Agreement Deemed Reference to Project Partnership Agreement","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to “project cooperation agreement” deemed to be reference to “project partnership agreement”, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s2003/f/2"},"text":"section 2003(f)(2) of Pub. L. 110–114","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1962d–5b"},"text":"section 1962d–5b of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
