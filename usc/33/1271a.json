{"tag":"section","attrib":{"id":"id6bb26fbd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1271a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1271a"},"text":"§ 1271a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and development program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6bb26fbe-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1271a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In coordination with other Federal, State, and local officials, the Administrator of the Environmental Protection Agency may conduct research on the development and use of innovative approaches, technologies, and techniques for the remediation of sediment contamination in areas of concern that are located wholly or partially in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bb26fbf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1271a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bb26fc0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1271a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to any amounts authorized under other provisions of law, there is authorized to be appropriated to carry out this section $3,000,000 for each of fiscal years 2004 through 2010.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb26fc1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1271a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds appropriated under paragraph (1) shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6bb26fc2-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/303/tI/s106"},"text":"Pub. L. 107–303, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-27"},"text":"Nov. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2358"},"text":"116 Stat. 2358","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/365/s4"},"text":"Pub. L. 110–365, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-08"},"text":"Oct. 8, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4023"},"text":"122 Stat. 4023","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6bb26fc3-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6bb26fc4-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6bb26fc5-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Great Lakes Legacy Act of 2002, and also as part of the Great Lakes and Lake Champlain Act of 2002, and not as part of the Federal Water Pollution Control Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6bb26fc6-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/365"},"text":"Pub. L. 110–365","children":[],"tail":" added par. (1) and struck out former par. (1). Prior to amendment, text read as follows: “In addition to amounts authorized under other laws, there is authorized to be appropriated to carry out this section $3,000,000 for each of fiscal years 2004 through 2008.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
