{"tag":"section","attrib":{"id":"id6b63b266-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701n–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"701n–1"},"text":"§ 701n–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biennial report to Congress","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b63b267-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701n–1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", and every 2 years thereafter, the Secretary shall submit to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a report detailing the amounts expended in the previous 5 fiscal years to carry out Corps of Engineers projects under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s701n"},"text":"section 701n of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b63b268-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701n–1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A report under subparagraph (A) shall, at a minimum, include a description of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6b63b269-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701n–1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each structure, feature, or project for which amounts are expended, including the type of structure, feature, or project and cost of the work; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6b63b26a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701n–1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the Secretary has repaired, restored, replaced, or modified each structure, feature, or project or intends to restore the structure, feature, or project to the design level of protection for the structure, feature, or project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b63b26b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/tIII/s3029/c/1"},"text":"Pub. L. 113–121, title III, § 3029(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1307"},"text":"128 Stat. 1307","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b63b26c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b63b26d-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b63b26e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s2"},"text":"section 2 of Pub. L. 113–121","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
