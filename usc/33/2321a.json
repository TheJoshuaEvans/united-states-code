{"tag":"section","attrib":{"id":"id6c54a2d7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2321a"},"text":"§ 2321a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hydroelectric power project uprating","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c54a2d8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the operation, maintenance, rehabilitation, and modernization of a hydroelectric power generating facility at a water resources project under the jurisdiction of the Department of the Army, the Secretary may, to the extent funds are made available in appropriations Acts or in accordance with subsection (c), take such actions as are necessary to optimize the efficiency of energy production or increase the capacity of the facility, or both, if, after consulting with the heads of other appropriate Federal and State agencies, the Secretary determines that such actions—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c54a2d9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are economically justified and financially feasible;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c54a2da-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will not result in any significant adverse effect on the other purposes for which the project is authorized;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c54a2db-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will not result in significant adverse environmental impacts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c54a2dc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will not involve major structural or operational changes in the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c54a2dd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will not adversely affect the use, management, or protection of existing Federal, State, or tribal water rights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c54a2de-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before proceeding with any proposed uprating under subsection (a), the Secretary shall provide affected State, tribal, and Federal agencies with a copy of the proposed determinations under subsection (a). If the agencies submit comments, the Secretary shall accept those comments or respond in writing to any objections those agencies raise to the proposed determinations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c54a2df-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds provided by preference customers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Secretary may accept and expend funds provided by preference customers under Federal law relating to the marketing of power.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c54a2e0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section does not apply to any facility of the Department of the Army that is authorized to be funded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s839d–1"},"text":"section 839d–1 of title 16","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c54a2e1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2321a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not affect the authority of the Secretary and the Administrator of the Bonneville Power Administration under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s839d–1"},"text":"section 839d–1 of title 16","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c54a2e2-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/303/tII/s216"},"text":"Pub. L. 104–303, title II, § 216","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3694"},"text":"110 Stat. 3694","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/541/tII/s212"},"text":"Pub. L. 106–541, title II, § 212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-11"},"text":"Dec. 11, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2593"},"text":"114 Stat. 2593","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c54a2e3-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c54a2e4-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c54a2e5-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 1996, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c54a2e6-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/541/s212/1"},"text":"Pub. L. 106–541, § 212(1)","children":[],"tail":", inserted introductory provisions and struck out former introductory provisions which read as follows: “In carrying out the maintenance, rehabilitation, and modernization of a hydroelectric power generating facility at a water resources project under the jurisdiction of the Department of the Army, the Secretary may take, to the extent funds are made available in appropriations Acts, such actions as are necessary to increase the efficiency of energy production or the capacity of the facility, or both, if, after consulting with the heads of other appropriate Federal and State agencies, the Secretary determines that the increase—”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/541/s212/1"},"text":"Pub. L. 106–541, § 212(1)","children":[],"tail":", substituted “are” for “is” before “economically justified”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/541/s212/2"},"text":"Pub. L. 106–541, § 212(2)","children":[],"tail":", substituted “any proposed uprating” for “the proposed uprating” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/541/s212/3"},"text":"Pub. L. 106–541, § 212(3)","children":[],"tail":", (4), added subsecs. (c) and (d) and redesignated former subsec. (c) as (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c54a2e7-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c54a2e8-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/303/s2"},"text":"section 2 of Pub. L. 104–303","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
