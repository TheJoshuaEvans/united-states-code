{"tag":"section","attrib":{"id":"id6c54a319-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2323"},"text":null,"children":[{"tag":"num","attrib":{"value":"2323"},"text":"§ 2323.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance to private entities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c54a31a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2323/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of Corps research and development labs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized to use Corps of Engineers research and development laboratories to provide research and development assistance to corporations, partnerships, limited partnerships, consortia, public and private foundations, universities, and nonprofit organizations operating within the United States, territories or possessions of the United States, and the Commonwealths of Puerto Rico and the Northern Mariana Islands—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c54a31b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2323/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the entity furnishes in advance of fiscal obligation by the United States such funds as are necessary to cover any and all costs of such research and development assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c54a31c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2323/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary determines that the research and development assistance to be provided is within the mission of the Corps of Engineers and is in the public interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c54a31d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2323/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the entity has certified to the Secretary that provision of such research and development assistance is not otherwise reasonably and expeditiously obtainable from the private sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c54a31e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2323/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the entity has agreed to hold and save the United States free from any damages due to any such research and development assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c54a31f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2323/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide research and development assistance under subsection (a), or any part thereof, by contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c54a320-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2323/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c54a321-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/640/tIII/s318"},"text":"Pub. L. 101–640, title III, § 318","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4641"},"text":"104 Stat. 4641","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c54a322-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c54a323-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c54a324-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/640/s318"},"text":"section 318 of Pub. L. 101–640","children":[],"tail":". Subsec. (c) of "},{"tag":"ref","attrib":{"href":"/us/pl/101/640/s318"},"text":"section 318 of Pub. L. 101–640","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2314a"},"text":"section 2314a of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 1990, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c54a325-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c54a326-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/640/s2"},"text":"section 2 of Pub. L. 101–640","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
