:"Pub. L. 118–272, § 1130(a)(3)","children":[],"tail":", substituted “The” for “In carrying out the pilot program, the” and “under this section” for “under the pilot program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1130/a/4"},"text":"Pub. L. 118–272, § 1130(a)(4)","children":[],"tail":", substituted “this section” for “the pilot program” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1130/a/5/A"},"text":"Pub. L. 118–272, § 1130(a)(5)(A)","children":[],"tail":", substituted “this section” for “the pilot program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1130/a/5/B"},"text":"Pub. L. 118–272, § 1130(a)(5)(B)","children":[],"tail":", substituted “the implementation of this section” for “the pilot program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (g), (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1130/a/6"},"text":"Pub. L. 118–272, § 1130(a)(6)","children":[],"tail":", redesignated subsec. (h) as (g) and struck out former subsec. (g) which provided that the pilot program would terminate after completion of the 35 projects carried out pursuant to subsec. (b)(1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s125/b/1/A"},"text":"Pub. L. 116–260, § 125(b)(1)(A)","children":[],"tail":", added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b)(1), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s125/b/1/B"},"text":"Pub. L. 116–260, § 125(b)(1)(B)","children":[],"tail":", (C), substituted “35” for “20”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsecs. (b)(1), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270"},"text":"Pub. L. 115–270"