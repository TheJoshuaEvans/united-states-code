{"tag":"section","attrib":{"id":"id6c595d87-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i"},"text":null,"children":[{"tag":"num","attrib":{"value":"2326i"},"text":"§ 2326i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Beneficial use of dredged material","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c595d88-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized to carry out projects for the beneficial use of dredged material, including projects for the purposes of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c595d89-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting resiliency and reducing the risk to property and infrastructure of flooding and storm damage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595d8a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting public safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595d8b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protecting, restoring, and creating aquatic ecosystem habitats;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595d8c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stabilizing stream systems and enhancing shorelines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595d8d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting recreation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595d8e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting risk management adaptation strategies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595d8f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" reducing the costs of dredging and dredged material placement or disposal, such as projects that use dredged material for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c595d90-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" construction or fill material;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c595d91-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" civic improvement objectives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c595d92-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/a/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other innovative uses and placement alternatives that produce public economic or environmental benefits; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595d93-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recovering lost storage capacity in reservoirs due to sediment accumulation, if the project also has a purpose described in any of paragraphs (1) through (7).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c595d94-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project selection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c595d95-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and carry out projects for the beneficial use of dredged material;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595d96-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with relevant State agencies in selecting projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595d97-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" select projects solely on the basis of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c595d98-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the environmental, economic, and social benefits of the projects, including monetary and nonmonetary benefits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c595d99-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need for a diversity of project types and geographical project locations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c595d9a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional beneficial use teams","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c595d9b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish regional beneficial use teams to identify and assist in the implementation of projects under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595d9c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c595d9d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leadership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each regional beneficial use team established under paragraph (1), the Secretary shall appoint the Commander of the relevant division of the Corps of Engineers to serve as the head of the team.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c595d9e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The membership of each regional beneficial use team shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c595d9f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of relevant Corps of Engineers districts and divisions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c595da0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of relevant State and local agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c595da1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of Federal agencies and such other entities as the Secretary determines appropriate, consistent with the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c595da2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out this section in a manner that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c595da3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maximizes the beneficial placement of dredged material from Federal and non-Federal navigation channels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595da4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporates, to the maximum extent practicable, 2 or more Federal navigation, flood control, storm damage reduction, or environmental restoration projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595da5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinates the mobilization of dredges and related equipment, including through the use of such efficiencies in contracting and environmental permitting as can be implemented under existing laws and regulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595da6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fosters Federal, State, and local collaboration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595da7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implements best practices to maximize the beneficial use of dredged sand and other sediments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595da8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensures that the use of dredged material is consistent with all applicable environmental laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c595da9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c595daa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Projects carried out under this section shall be subject to the cost-sharing requirements applicable to projects carried out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2326"},"text":"section 2326 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595dab-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (1), if the cost of transporting and depositing dredged material for a project carried out under this section exceeds the cost of carrying out those activities pursuant to any other water resources project in accordance, if applicable, with the Federal standard (as defined in section 335.7 of title 33, Code of Federal Regulations), the Secretary may not require the non-Federal interest to bear the additional cost of such activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c595dac-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":", and annually thereafter, the Secretary shall submit to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a report that includes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c595dad-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the projects selected to be carried out under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595dae-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" documentation supporting each of the projects selected;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595daf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the findings of regional beneficial use teams regarding project selection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595db0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations of the Secretary or regional beneficial use teams with respect to the implementation of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c595db1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from other standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The projects carried out under this section shall be carried out notwithstanding the definition of the term “Federal standard” in section 335.7 of title 33, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c595db2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redesignated (g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c595db3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326i/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":", (j) Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c595db4-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/tI/s1122"},"text":"Pub. L. 114–322, title I, § 1122","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1645"},"text":"130 Stat. 1645","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/270/tI/s1130"},"text":"Pub. L. 115–270, title I, § 1130","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3780"},"text":"132 Stat. 3780","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/tI/s125/b/1"},"text":"Pub. L. 116–260, div. AA, title I, § 125(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2638"},"text":"134 Stat. 2638","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dA/tI/s1130/a"},"text":"Pub. L. 118–272, div. A, title I, § 1130(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3018"},"text":"138 Stat. 3018","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c595db5-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c595db6-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c595db7-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2326"},"text":"section 2326 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 2016, and also as part of the Water Infrastructure Improvements for the Nation Act, also known as the WIIN Act, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1122"},"text":"section 1122 of Pub. L. 114–322","children":[],"tail":". Subsecs. (i) and (j) of "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1122"},"text":"section 1122 of Pub. L. 114–322","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2326"},"text":"section 2326 of thi