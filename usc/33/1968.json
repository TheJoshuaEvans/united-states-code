{"tag":"section","attrib":{"id":"id6c275125-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1968"},"text":null,"children":[{"tag":"num","attrib":{"value":"1968"},"text":"§ 1968.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c275126-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1968/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c275127-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1968/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Department of Commerce to carry out this title ","children":[{"tag":"ref","attrib":{"idref":"fn002092"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002092"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" $10,000,000 for each of fiscal years 2021 through 2024 and $2,000,000 for fiscal year 2025."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c275128-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1968/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of appropriated funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (3), amounts made available under paragraph (1) shall be provided to the Foundation to match contributions (whether in currency, services, or property) made to the Foundation, or to a recipient of a grant provided by the Foundation, by private persons, State and local government agencies, regional organizations, Indian Tribes, Tribal organizations, and foreign governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c275129-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1968/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on use for administrative expenses","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c27512a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1968/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), no Federal funds made available under paragraph (1) may be used by the Foundation for administrative expenses of the Foundation, including for salaries, travel and transportation expenses, and other overhead expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c27512b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1968/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may allow the use of Federal funds made available under paragraph (1) to pay for salaries during the 18-month period beginning on ","children":[{"tag":"date","attrib":{"date":"2020-12-18"},"text":"December 18, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c27512c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1968/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional authorization","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c27512d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1968/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the amounts made available under subsection (a), the Foundation may accept Federal funds from a Federal agency under any other Federal law for use by the Foundation to further the assessment, prevention, reduction, and removal of marine debris in accordance with the requirements of this title.","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c27512e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1968/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds accepted from Federal agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Federal funds provided to the Foundation under paragraph (1) shall be used by the Foundation for matching, in whole or in part, contributions (whether in currency, services, or property) made to the Foundation by private persons and State and local government agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c27512f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1968/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on use of grant amounts for litigation and lobbying expenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts provided as a grant by the Foundation shall not be used for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c275130-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1968/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any expense related to litigation consistent with Federal-wide cost principles; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c275131-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1968/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any activity the purpose of which is to influence legislation pending before Congress consistent with Federal-wide cost principles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c275132-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/449/s118"},"text":"Pub. L. 109–449, § 118","children":[],"tail":", formerly "},{"tag":"ref","attrib":{"href":"/us/pl/116/224/tI/s118"},"text":"Pub. L. 116–224, title I, § 118","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-18"},"text":"Dec. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1080"},"text":"134 Stat. 1080","children":[],"tail":"; renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/109/449/s118"},"text":"Pub. L. 109–449, § 118","children":[],"tail":", and amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/65/s3/a"},"text":"Pub. L. 119–65, § 3(a)","children":[],"tail":", (h), "},{"tag":"date","attrib":{"date":"2025-12-26"},"text":"Dec. 26, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1987"},"text":"139 Stat. 1987","children":[],"tail":", 1988.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c275133-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c275134-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c275135-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in subsecs. (a)(1) and (b)(1), means title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/224"},"text":"Pub. L. 116–224","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-18"},"text":"Dec. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1074"},"text":"134 Stat. 1074","children":[],"tail":", which was classified principally to subchapter I (§ 4211 et seq.) of chapter 55 of this title. Subtitles B and C of title I of "},{"tag":"ref","attrib":{"href":"/us/pl/116/224"},"text":"Pub. L. 116–224","children":[],"tail":" were transferred to subtitles B and C of "},{"tag":"ref","attrib":{"href":"/us/pl/109/449"},"text":"Pub. L. 109–449","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/119/65"},"text":"Pub. L. 119–65","children":[],"tail":", §§ 3(a), 4(a), "},{"tag":"date","attrib":{"date":"2025-12-26"},"text":"Dec. 26, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1987"},"text":"139 Stat. 1987","children":[],"tail":", 1989, and are classified to this subchapter and subchapter III of this chapter, respectively. Subtitle A of title I of "},{"tag":"ref","attrib":{"href":"/us/pl/116/224"},"text":"Pub. L. 116–224","children":[],"tail":" amended sections 1951, 1958, and 1959 of this title, and subtitle D of title I of "},{"tag":"ref","attrib":{"href":"/us/pl/116/224"},"text":"Pub. L. 116–224","children":[],"tail":" is classified to part C (§ 4251) of subchapter I of chapter 55 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c275136-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s4218"},"text":"section 4218 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/119/65"},"text":"Pub. L. 119–65","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c275137-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/65/s3/h/1"},"text":"Pub. L. 119–65, § 3(h)(1)","children":[],"tail":", inserted “and $2,000,000 for fiscal year 2025” after “through 2024”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/65/s3/h/2"},"text":"Pub. L. 119–65, § 3(h)(2)","children":[],"tail":", substituted “, State and local government agencies, regional organizations, Indian Tribes, Tribal organizations, and foreign governments” for “and State and local government agencies”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
