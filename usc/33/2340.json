{"tag":"section","attrib":{"id":"id6c5e188f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2340"},"text":null,"children":[{"tag":"num","attrib":{"value":"2340"},"text":"§ 2340.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revision of project partnership agreement; cost sharing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c5e1890-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2340/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal allocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon authorization by law of an increase in the maximum amount of Federal funds that may be allocated for a water resources project or an increase in the total cost of a water resources project authorized to be carried out by the Secretary, the Secretary shall enter into a revised partnership agreement for the project to take into account the change in Federal participation in the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5e1891-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2340/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An increase in the maximum amount of Federal funds that may be allocated for a water resources project, or an increase in the total cost of a water resources project, authorized to be carried out by the Secretary shall not affect any cost-sharing requirement applicable to the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5e1892-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2340/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost estimates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The estimated Federal and non-Federal costs of water resources projects authorized to be carried out by the Secretary before, on, or after ","children":[{"tag":"date","attrib":{"date":"2007-11-08"},"text":"November 8, 2007","children":[],"tail":", are for informational purposes only and shall not be interpreted as affecting the cost-sharing responsibilities established by law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c5e1893-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/tII/s2008"},"text":"Pub. L. 110–114, title II, § 2008","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-11-08"},"text":"Nov. 8, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1073"},"text":"121 Stat. 1073","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c5e1894-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c5e1895-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c5e1896-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 2007, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c5e1897-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c5e1898-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Reference to Partnership Agreement Deemed Reference to Cooperation Agreement","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to partnership agreement deemed to be reference to cooperation agreement, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s2003/f/3"},"text":"section 2003(f)(3) of Pub. L. 110–114","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1962d–5b"},"text":"section 1962d–5b of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c5e1899-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s2"},"text":"section 2 of Pub. L. 110–114","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
