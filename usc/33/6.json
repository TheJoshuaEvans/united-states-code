{"tag":"section","attrib":{"id":"id6b045489-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"§ 6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Free passage to harbor of Michigan City, Indiana","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The passage of vessels to and from the harbor of Michigan City, in Indiana, shall be free and not subject to toll or charge.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b04548a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(R.S. § 5247.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b04548b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b04548c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b04548d-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5247 derived from acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1866-06-23/ch138/s1"},"text":"June 23, 1866, ch. 138, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/14/73"},"text":"14 Stat. 73","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1867-03-02/ch144/s2"},"text":"Mar. 2, 1867, ch. 144, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/14/421"},"text":"14 Stat. 421","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
