{"tag":"section","attrib":{"id":"id6c27515e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1973"},"text":null,"children":[{"tag":"num","attrib":{"value":"1973"},"text":"§ 1973.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement with the Marine Debris Foundation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c27515f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1973/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may offer to enter into an agreement, which may include a grant or cooperative agreement, under which the Marine Debris Foundation established under subchapter II may administer the prize competition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c275160-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1973/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An agreement entered into under subsection (a) shall comply with the following requirements:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c275161-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1973/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Marine Debris Foundation shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c275162-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1973/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advertise the prize competition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c275163-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1973/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solicit prize competition participants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c275164-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1973/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer funds relating to the prize competition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c275165-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1973/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" receive Federal and non-Federal funds—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c275166-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1973/b/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to administer the prize competition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c275167-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1973/b/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to award a cash prize;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c275168-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1973/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" carry out activities to generate contributions of non-Federal funds to offset, in whole or in part—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c275169-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1973/b/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the administrative costs of the prize competition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c27516a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1973/b/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of a cash prize;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c27516b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1973/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the design and award of the prize, consult, as appropriate with experts from—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c27516c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1973/b/1/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal agencies with jurisdiction over the prevention of marine debris or the promotion of innovative materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c27516d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1973/b/1/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State agencies with jurisdiction over the prevention of marine debris or the promotion of innovative materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c27516e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1973/b/1/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State, regional, or local conservation or post-consumer materials management organizations, the mission of which relates to the prevention of marine debris or the promotion of innovative materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c27516f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1973/b/1/F/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conservation groups, technology companies, research institutions, scientists (including those with expertise in marine environments) institutions of higher education, industry, or individual stakeholders with an interest in the prevention of marine debris or the promotion of innovative materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c275170-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1973/b/1/F/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" experts in the area of standards development regarding the degradation, breakdown, or recycling of polymers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c275171-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1973/b/1/F/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other relevant experts of the Board’s choosing;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c275172-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1973/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with, and subject to final approval by, the Secretary, develop criteria for the selection of prize competition winners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c275173-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1973/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide advice and consultation to the Secretary on the selection of judges under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1974"},"text":"section 1974 of this title","children":[],"tail":" based on criteria developed in consultation with, and subject to the final approval of, the Secretary;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c275174-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1973/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" announce 1 or more annual winners of the prize competition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c275175-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1973/b/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to paragraph (2), award 1 or more cash prizes biennially of not less than $100,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c275176-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1973/b/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect against unauthorized use or disclosure by the Marine Debris Foundation of any trade secret or confidential business information of a prize competition participant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c275177-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1973/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional cash prizes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Marine Debris Foundation may award more than 1 cash prize in a year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c275178-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1973/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the initial cash prize referred to in paragraph (1)(J) and any additional cash prizes are awarded using only non-Federal funds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c275179-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1973/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consisting of an amount determined by the Under Secretary after the Secretary is notified by the Marine Debris Foundation that non-Federal funds are available for an additional cash prize.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c27517a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1973/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solicitation of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Marine Debris Foundation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c27517b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1973/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may request and accept Federal funds and non-Federal funds for a cash prize or administration of the prize competition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c27517c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1973/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may accept a contribution for a cash prize in exchange for the right to name the prize; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c27517d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1973/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not give special consideration to any Federal agency or non-Federal entity in exchange for a donation for a cash prize awarded under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c27517e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/449/s123"},"text":"Pub. L. 109–449, § 123","children":[],"tail":", formerly "},{"tag":"ref","attrib":{"href":"/us/pl/116/224/tI/s123"},"text":"Pub. L. 116–224, title I, § 123","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-18"},"text":"Dec. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1082"},"text":"134 Stat. 1082","children":[],"tail":"; renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/109/449/s123"},"text":"Pub. L. 109–449, § 123","children":[],"tail":", and amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/65"},"text":"Pub. L. 119–65","children":[],"tail":", §§ 4(a), 6(c), "},{"tag":"date","attrib":{"date":"2025-12-26"},"text":"Dec. 26, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1989"},"text":"139 Stat. 1989","children":[],"tail":", 1990.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c27517f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c275180-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c275181-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s4233"},"text":"section 4233 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/119/65"},"text":"Pub. L. 119–65","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c275182-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/65/s6/c"},"text":"Pub. L. 119–65, § 6(c)","children":[],"tail":", substituted “subchapter II” for “title I”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
