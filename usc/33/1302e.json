{"tag":"section","attrib":{"id":"id6bc7f347-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1302e"},"text":"§ 1302e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Connection to publicly owned treatment works","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6bc7f348-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bc7f349-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6bc7f34a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302e/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an owner or operator of a publicly owned treatment works that assists or is seeking to assist low-income or moderate-income individuals with connecting the household of the individual to the publicly owned treatment works; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bc7f34b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302e/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit entity that assists low-income or moderate-income individuals with the costs associated with connecting the household of the individual to a publicly owned treatment works.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bc7f34c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “program” means the competitive grant program established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bc7f34d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified individual","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified individual” has the meaning given the term “eligible individual” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1383/j"},"text":"section 1383(j) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bc7f34e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations, the Administrator shall establish a competitive grant program with the purpose of improving general welfare, under which the Administrator awards grants to eligible entities to provide funds to assist qualified individuals in covering the costs incurred by the qualified individual in connecting the household of the qualified individual to a publicly owned treatment works.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bc7f34f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bc7f350-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity seeking a grant under the program shall submit to the Administrator an application at such time, in such manner, and containing such information as the Administrator may by regulation require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bc7f351-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after the date on which the Administrator receives an application from an eligible entity under paragraph (1), the Administrator shall notify the eligible entity of whether the Administrator will award a grant to the eligible entity under the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bc7f352-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting recipients of grants under the program, the Administrator shall use the following criteria:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bc7f353-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302e/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether the eligible entity seeking a grant provides services to, or works directly with, qualified individuals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bc7f354-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302e/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whether the eligible entity seeking a grant—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6bc7f355-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302e/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has an existing program to assist in covering the costs incurred in connecting a household to a publicly owned treatment works; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bc7f356-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302e/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seeks to create a program described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bc7f357-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bc7f358-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302e/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary connection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before providing funds to a qualified individual for the costs described in subsection (b), an eligible entity shall ensure that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6bc7f359-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302e/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the qualified individual has connected to the publicly owned treatment works voluntarily; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bc7f35a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302e/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the eligible entity is not the owner or operator of the publicly owned treatment works to which the qualified individual has connected, the publicly owned treatment works to which the qualified individual has connected has agreed to the connection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bc7f35b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302e/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursements from publicly owned treatment works","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity that is an owner or operator of a publicly owned treatment works may reimburse a qualified individual that has already incurred the costs described in subsection (b) by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6bc7f35c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302e/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing the amount otherwise owed by the qualified individual to the owner or operator for wastewater or other services provided by the owner or operator; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bc7f35d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302e/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing a direct payment to the qualified individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bc7f35e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302e/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bc7f35f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302e/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out the program $40,000,000 for each of fiscal years 2022 through 2026.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bc7f360-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302e/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on use of funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6bc7f361-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302e/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small systems","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amounts made available for grants under paragraph (1), to the extent that there are sufficient applications, not less than 15 percent shall be used to make grants to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6bc7f362-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302e/f/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible entities described in subsection (a)(1)(A) that are owners and operators of publicly owned treatment works that serve fewer than 3,300 people; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6bc7f363-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302e/f/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible entities described in subsection (a)(1)(B) that provide the assistance described in that subsection in areas that are served by publicly owned treatment works that serve fewer than 3,300 people.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bc7f364-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302e/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts made available for grants under paragraph (1), not more than 2 percent may be used to pay the administrative costs of the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6bc7f365-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"June 30, 1948, ch. 758","children":[],"tail":", title II, § 227, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dE/tII/s50209"},"text":"Pub. L. 117–58, div. E, title II, § 50209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1167"},"text":"135 Stat. 1167","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
