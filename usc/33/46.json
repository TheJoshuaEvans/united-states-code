{"tag":"section","attrib":{"id":"id6b0b8112-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s46"},"text":null,"children":[{"tag":"num","attrib":{"value":"46"},"text":"§ 46.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tchula Lake, Mississippi","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Tchula Lake, in Holmes County, in the State of Mississippi, is declared to be a nonnavigable stream within the meaning of the Constitution and laws of the United States.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The right of Congress to alter, amend, or repeal this section is expressly reserved.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b0b8113-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-07-01/ch266"},"text":"July 1, 1922, ch. 266","children":[],"tail":", §§ 1, 2, "},{"tag":"ref","attrib":{"href":"/us/stat/42/816"},"text":"42 Stat. 816","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b0b8114-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b0b8115-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b0b8116-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The two sentences comprising this section are, respectively, sections 1 and 2 of act ","children":[{"tag":"date","attrib":{"date":"1922-07-01"},"text":"July 1, 1922","children":[],"tail":", entitled “An act declaring Tchula Lake, Holmes County, Mississippi, to be a nonnavigable stream”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
