{"tag":"section","attrib":{"id":"id6b1c4942-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s383"},"text":null,"children":[{"tag":"num","attrib":{"value":"383"},"text":"§ 383.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resistance of pirates by merchant vessels","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The commander and crew of any merchant vessel of the United States, owned wholly, or in part, by a citizen thereof, may oppose and defend against any aggression, search, restraint, depredation, or seizure, which shall be attempted upon such vessel, or upon any other vessel so owned, by the commander or crew of any armed vessel whatsoever, not being a public armed vessel of some nation in amity with the United States, and may subdue and capture the same; and may also retake any vessel so owned which may have been captured by the commander or crew of any such armed vessel, and send the same into any port of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b1c4943-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(R.S. § 4295.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b1c4944-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b1c4945-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b1c4946-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 4295 derived from acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1819-03-03/ch77/s3"},"text":"Mar. 3, 1819, ch. 77, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/3/513"},"text":"3 Stat. 513","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1823-01-30/ch7"},"text":"Jan. 30, 1823, ch. 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/3/721"},"text":"3 Stat. 721","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
