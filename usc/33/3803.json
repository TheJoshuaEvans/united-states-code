{"tag":"section","attrib":{"id":"id6c8dda64-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3803"},"text":null,"children":[{"tag":"num","attrib":{"value":"3803"},"text":"§ 3803.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration and enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c8dda65-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3803/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Unless otherwise specified in this chapter, with respect to a vessel, the Secretary shall administer and enforce the Convention and this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c8dda66-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3803/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except with respect to section 3841(b) and (c) of this title, the Administrator shall administer and enforce subchapter III.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c8dda67-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3803/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator and the Secretary may each prescribe and enforce regulations as may be necessary to carry out their respective responsibilities under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c8dda68-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/tX/s1013"},"text":"Pub. L. 111–281, title X, § 1013","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3025"},"text":"124 Stat. 3025","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c8dda69-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c8dda6a-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c8dda6b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a) and (c), was in the original “this title”, meaning title X of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281"},"text":"Pub. L. 111–281","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3023"},"text":"124 Stat. 3023","children":[],"tail":", which enacted this chapter and repealed chapter 37 (§ 2401 et seq.) of this title. For complete classification of title X to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
