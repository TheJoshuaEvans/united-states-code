{"tag":"section","attrib":{"id":"id6c2025a0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1904"},"text":null,"children":[{"tag":"num","attrib":{"value":"1904"},"text":"§ 1904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certificates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c2025a1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance by authorized designees; restriction on issuance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1903/b/1"},"text":"section 1903(b)(1) of this title","children":[],"tail":", the Secretary shall designate those persons authorized to issue on behalf of the United States the certificates required by the MARPOL Protocol. A certificate required by the MARPOL Protocol shall not be issued to a ship which is registered in or of the nationality of a country which is not a party to the MARPOL Protocol."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c2025a2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Validity of foreign certificates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A certificate issued by a country which is a party to the MARPOL Protocol has the same validity as a certificate issued by the Secretary or the Administrator under the authority of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c2025a3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1904/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location onboard vessel; inspection of vessels subject to jurisdiction of the United States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A ship required by the MARPOL Protocol to have a certificate—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c2025a4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1904/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall carry a valid certificate onboard in the manner prescribed by the authority issuing the certificate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c2025a5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1904/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is subject to inspection while in a port or terminal under the jurisdiction of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c2025a6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1904/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Onboard inspections; other Federal inspection authority unaffected","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An inspection conducted under subsection (c)(2) of this section is limited to verifying whether or not a valid certificate is onboard, unless clear grounds exist which reasonably indicate that the condition of the ship or its equipment does not substantially agree with the particulars of its certificate. This section shall not limit the authority of any official or employee of the United States under any other treaty, law, or regulation to board and inspect a ship or its equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c2025a7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1904/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detention orders; duration of detention; shipyard option","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the penalties prescribed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1908"},"text":"section 1908 of this title","children":[],"tail":", a ship required by the MARPOL Protocol to have a certificate—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c2025a8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1904/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which does not have a valid certificate onboard; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c2025a9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1904/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose condition or whose equipment’s condition does not substantially agree with the particulars of the certificate onboard;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be detained by order of the Secretary at the port or terminal where the violation is discovered until, in the opinion of the Secretary, the ship can proceed to sea without presenting an unreasonable threat of harm to the marine environment or the public health and welfare. The detention order may authorize the ship to proceed to the nearest appropriate available shipyard rather than remaining at the place where the violation was discovered.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c2025aa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1904/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ship clearance; refusal or revocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a ship is under a detention order under this section, the Secretary may refuse or revoke the clearance required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s60105"},"text":"section 60105 of title 46","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c2025ab-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1904/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of detention orders; petition; determination by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person whose ship is subject to a detention order under this section may petition the Secretary, in the manner prescribed by regulation, to review the detention order. Upon receipt of a petition under this subsection, the Secretary shall affirm, modify, or withdraw the detention order within the time prescribed by regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c2025ac-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1904/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation for loss or damage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A ship unreasonably detained or delayed by the Secretary acting under the authority of this chapter is entitled to compensation for any loss or damage suffered thereby.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c2025ad-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/478/s5"},"text":"Pub. L. 96–478, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-21"},"text":"Oct. 21, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2298"},"text":"94 Stat. 2298","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/280/s6"},"text":"Pub. L. 110–280, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-21"},"text":"July 21, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2614"},"text":"122 Stat. 2614","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3548/c"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3548(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2328"},"text":"132 Stat. 2328","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c2025ae-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c2025af-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c2025b0-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" amended subsec. (f) generally. Prior to amendment, subsec. (f) related to refusal or revocation of ship clearance or permits."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/280/s6/1"},"text":"Pub. L. 110–280, § 6(1)","children":[],"tail":", substituted “Except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1903/b/1"},"text":"section 1903(b)(1) of this title","children":[],"tail":", the Secretary” for “The Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/280/s6/2"},"text":"Pub. L. 110–280, § 6(2)","children":[],"tail":", substituted “Secretary or the Administrator under the authority of this chapter.” for “Secretary under the authority of the MARPOL Protocol.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/280/s6/3"},"text":"Pub. L. 110–280, § 6(3)","children":[],"tail":", substituted “environment or the public health and welfare.” for “environment.” in concluding provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c2025b1-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id6c2025b2-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsec. (a) of this section effective ","children":[{"tag":"date","attrib":{"date":"1980-10-21"},"text":"Oct. 21, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/478/s14/b"},"text":"section 14(b) of Pub. L. 96–478","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1901"},"text":"section 1901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
