{"tag":"section","attrib":{"id":"id6bb4e062-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1276a"},"text":"§ 1276a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" San Francisco Bay restoration grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6bb4e063-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bb4e064-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Estuary Partnership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Estuary Partnership” means the San Francisco Estuary Partnership, designated as the management conference for the San Francisco Bay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1330"},"text":"section 1330 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4e065-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" San Francisco Bay Plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “San Francisco Bay Plan” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6bb4e066-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" until the date of the completion of the plan developed by the Director under subsection (d), the comprehensive conservation and management plan approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1330"},"text":"section 1330 of this title","children":[],"tail":" for the San Francisco Bay estuary; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bb4e067-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on and after the date of the completion of the plan developed by the Director under subsection (d), the plan developed by the Director under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bb4e068-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program Office","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bb4e069-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall establish in the Environmental Protection Agency a San Francisco Bay Program Office. The Office shall be located at the headquarters of Region 9 of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4e06a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall appoint a Director of the Office, who shall have management experience and technical expertise relating to the San Francisco Bay and be highly qualified to direct the development and implementation of projects, activities, and studies necessary to implement the San Francisco Bay Plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4e06b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation of authority; staffing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall delegate to the Director such authority and provide such staff as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bb4e06c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual priority list","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bb4e06d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After providing public notice, the Director shall annually compile a priority list, consistent with the San Francisco Bay Plan, identifying and prioritizing the projects, activities, and studies to be carried out with amounts made available under subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4e06e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The annual priority list compiled under paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6bb4e06f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Projects, activities, and studies, including restoration projects and habitat improvement for fish, waterfowl, and wildlife, that advance the goals and objectives of the San Francisco Bay Plan, for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6bb4e070-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water quality improvement, including the reduction of marine litter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6bb4e071-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wetland, riverine, and estuary restoration and protection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6bb4e072-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nearshore and endangered species recovery; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6bb4e073-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a/c/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adaptation to climate change.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bb4e074-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Information on the projects, activities, and studies specified under subparagraph (A), including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6bb4e075-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identity of each entity receiving assistance pursuant to subsection (e); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6bb4e076-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the communities to be served.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bb4e077-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The criteria and methods established by the Director for identification of projects, activities, and studies to be included on the annual priority list.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4e078-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In compiling the annual priority list under paragraph (1), the Director shall consult with, and consider the recommendations of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6bb4e079-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Estuary Partnership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bb4e07a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State of California and affected local governments in the San Francisco Bay estuary watershed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bb4e07b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the San Francisco Bay Restoration Authority; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bb4e07c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other relevant stakeholder involved with the protection and restoration of the San Francisco Bay estuary that the Director determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bb4e07d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" San Francisco Bay Plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bb4e07e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 5 years after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", the Director, in conjunction with the Estuary Partnership, shall review and revise the comprehensive conservation and management plan approved under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1330"},"text":"section 1330 of this title","children":[],"tail":" for the San Francisco Bay estuary to develop a plan to guide the projects, activities, and studies of the Office to address the restoration and protection of the San Francisco Bay."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4e07f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revision of San Francisco Bay Plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less often than once every 5 years after the date of the completion of the plan described in paragraph (1), the Director shall review, and revise as appropriate, the San Francisco Bay Plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4e080-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this subsection, the Director shall consult with the Estuary Partnership and Indian tribes and solicit input from other non-Federal stakeholders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bb4e081-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bb4e082-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may provide funding through cooperative agreements, grants, or other means to State and local agencies, special districts, and public or nonprofit agencies, institutions, and organizations, including the Estuary Partnership, for projects, activities, and studies identified on the annual priority list compiled under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4e083-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount of grants; non-Federal share","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6bb4e084-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount of grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts provided to any entity under this section for a fiscal year shall not exceed an amount equal to 75 percent of the total cost of any projects, activities, and studies that are to be carried out using those amounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bb4e085-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 25 percent of the cost of any project, activity, or study carried out using amounts provided under this section shall be provided from non-Federal sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bb4e086-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bb4e087-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amount made available to carry out this section for a fiscal year, the Director may not use more than 5 percent to pay administrative expenses incurred in carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4e088-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No amounts made available under this section may be used for the administration of a management conference under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1330"},"text":"section 1330 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6bb4e089-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"June 30, 1948, ch. 758","children":[],"tail":", title I, § 125, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dH/tLXXXV/s8501/a"},"text":"Pub. L. 117–263, div. H, title LXXXV, § 8501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3845"},"text":"136 Stat. 3845","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
