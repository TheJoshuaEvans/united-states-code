{"tag":"section","attrib":{"id":"id6c54a336-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2324"},"text":null,"children":[{"tag":"num","attrib":{"value":"2324"},"text":"§ 2324.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduced pricing for certain water supply storage","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c54a337-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2324/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of storage space","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a low income community requests the Secretary to provide water supply storage space in a water resources development project operated by the Secretary and if the amount of space requested is available or could be made available through reallocation of water supply storage space in the project or through modifications to operation of the project, the Secretary may provide such space to the community at a price determined under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c54a338-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2324/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount of storage space","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The maximum amount of water supply storage space which may be provided to a community under this section may not exceed an amount of water supply storage space sufficient to yield 3,000,000 gallons of water per day.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c54a339-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2324/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Price","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide water supply storage space under this section at a price which is the greater of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c54a33a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2324/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the updated construction cost of the project allocated to provide such amount of water supply storage space or $100 per acre foot of storage space, whichever is less; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c54a33b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2324/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of the benefits which are lost as a result of providing such water supply storage space.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c54a33c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2324/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (c), the determinations of updated construction costs and value of benefits lost shall be made by the Secretary on the basis of the most recent information available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c54a33d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2324/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inflation adjustment of dollar amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The $100 amount set forth in subsection (c) shall be adjusted annually by the Secretary for changes in the Consumer Price Index of All Urban Consumers published by the Bureau of Labor Statistics.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c54a33e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2324/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal responsibilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed as affecting the responsibility of non-Federal interests to provide operation and maintenance costs assigned to water supply storage provided under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c54a33f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2324/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Low income community” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “low income community” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c54a340-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2324/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a community with a population of less than 20,000 which is located in a county with a per capita income less than the per capita income of two-thirds of the counties in the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c54a341-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2324/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a regional water system that serves a population of less than 100,000, for which the per capita income is less than the per capita income of not less than 50 percent of the counties in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c54a342-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/640/tIII/s322"},"text":"Pub. L. 101–640, title III, § 322","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4643"},"text":"104 Stat. 4643","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/tIII/s350"},"text":"Pub. L. 116–260, div. AA, title III, § 350","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2716"},"text":"134 Stat. 2716","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c54a343-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c54a344-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c54a345-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 1990, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c54a346-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s350/1"},"text":"Pub. L. 116–260, § 350(1)","children":[],"tail":", substituted “3,000,000” for “2,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s350/2"},"text":"Pub. L. 116–260, § 350(2)","children":[],"tail":", substituted “means—” for “means”, inserted par. (1) designation before “a community”, substituted “; or” for period at end, and added par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c54a347-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c54a348-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/640/s2"},"text":"section 2 of Pub. L. 101–640","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
