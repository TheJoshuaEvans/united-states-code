{"tag":"section","attrib":{"id":"id6b499ace-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s579e"},"text":null,"children":[{"tag":"num","attrib":{"value":"579e"},"text":"§ 579e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to real estate data","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b499acf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s579e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Using available funds, the Secretary shall make publicly available, including on a publicly accessible website, information on all Federal real estate assets in the United States that are owned, operated, or managed by, or in the custody of, the Corps of Engineers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b499ad0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s579e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b499ad1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s579e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The real estate information made available under subsection (a) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b499ad2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s579e/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing standardized real estate plat descriptions of assets described in subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b499ad3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s579e/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing geographic information systems and geospatial information associated with such assets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b499ad4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s579e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaboration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making information available under subsection (a), the Secretary shall consult with the Administrator of General Services. Such information may be made available, in whole or in part, in the Federal real property database published under section 21 of the Federal Assets Sale and Transfer Act of 2016 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/287"},"text":"Public Law 114–287","children":[],"tail":"), as determined appropriate by the Administrator of General Services. Nothing in this paragraph shall be construed as requiring the Administrator of General Services to add additional data elements or features to such Federal real property database if such additions are impractical or would add additional costs to such database."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b499ad5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s579e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall compel or authorize the disclosure of data or other information determined by the Secretary to be confidential, privileged, national security information, personal information, or information the disclosure of which is otherwise prohibited by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b499ad6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s579e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that the implementation of subsection (a) occurs as soon as practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b499ad7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s579e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed as modifying, or exempting the Corps of Engineers from, the requirements of the Federal real property database published under section 21 of the Federal Assets Sale and Transfer Act of 2016 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/287"},"text":"Public Law 114–287","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b499ad8-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/tI/s1107"},"text":"Pub. L. 115–270, title I, § 1107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3773"},"text":"132 Stat. 3773","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b499ad9-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b499ada-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6b499adb-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 21 of the Federal Assets Sale and Transfer Act of 2016, referred to in subsecs. (b)(2) and (e), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/287/s21"},"text":"section 21 of Pub. L. 114–287","children":[],"tail":", which is set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s1303"},"text":"section 1303 of Title 40","children":[],"tail":", Public Buildings, Property, and Works."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b499adc-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b499add-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/s102"},"text":"section 102 of Pub. L. 115–270","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
