{"tag":"section","attrib":{"id":"id6bb99b55-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1281b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1281b"},"text":"§ 1281b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of Farmers Home Administration funds for non-Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, Federal assistance made available by the Farmers Home Administration to any political subdivision of a State may be used to provide the non-Federal share of the cost of any construction project carried out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1281"},"text":"section 1281 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6bb99b56-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/4/tII/s202/f"},"text":"Pub. L. 100–4, title II, § 202(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-02-04"},"text":"Feb. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/16"},"text":"101 Stat. 16","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6bb99b57-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6bb99b58-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6bb99b59-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Quality Act of 1987, and not as part of the Federal Water Pollution Control Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
