{"tag":"section","attrib":{"id":"id6c0f83d1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1482"},"text":null,"children":[{"tag":"num","attrib":{"value":"1482"},"text":"§ 1482.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation for nomination and nomination of experts, negotiators, etc.; proposal of amendments to list of substances other than convention oil; Presidential acceptance of amendments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c0f83d2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1482/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nomination of experts and proposal of amendments to list of substances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Secretary of State and the Administrator of the Environmental Protection Agency, may nominate individuals to the list of experts provided for in article III of the convention and article II of the protocol and may propose amendments to the list of substances other than convention oil in accordance with article III of the protocol.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c0f83d3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1482/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultations for designation or nomination of negotiators, etc., provided for by convention and protocol","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State, in consultation with the Secretary, shall designate or nominate, as appropriate and necessary, the negotiators, conciliators, or arbitrators provided for by the convention and the protocol.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c0f83d4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1482/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presidential acceptance of amendments to list of substances other than convention oil in accordance with protocol","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may accept amendments to the list of substances other than convention oil in accordance with article III of the protocol.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c0f83d5-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/248/s13"},"text":"Pub. L. 93–248, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-02-05"},"text":"Feb. 5, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/10"},"text":"88 Stat. 10","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/302/s1/5"},"text":"Pub. L. 95–302, § 1(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-06-26"},"text":"June 26, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/345"},"text":"92 Stat. 345","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c0f83d6-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c0f83d7-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c0f83d8-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/302/s1/5/A"},"text":"Pub. L. 95–302, § 1(5)(A)","children":[],"tail":", inserted provisions relating to applicability of article II of the protocol and provisions for proposal of amendments to the list of substances other than convention oil."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/302/s1/5/B"},"text":"Pub. L. 95–302, § 1(5)(B)","children":[],"tail":", substituted “protocol” for “annexes thereto”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/302/s1/5/C"},"text":"Pub. L. 95–302, § 1(5)(C)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c0f83d9-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6c0f83da-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/302"},"text":"Pub. L. 95–302","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/302/s2"},"text":"section 2 of Pub. L. 95–302","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1487"},"text":"section 1487 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
