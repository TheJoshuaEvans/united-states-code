{"tag":"section","attrib":{"id":"id6b44b9bb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s569e"},"text":null,"children":[{"tag":"num","attrib":{"value":"569e"},"text":"§ 569e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of private sector resources in surveying and mapping","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"To the maximum extent practicable, the Secretary shall make use of private sector resources in carrying out surveying and mapping activities in the Civil Works Program of the Corps of Engineers.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b44b9bc-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/580/tII/s212"},"text":"Pub. L. 102–580, title II, § 212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-31"},"text":"Oct. 31, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4831"},"text":"106 Stat. 4831","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b44b9bd-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b44b9be-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b44b9bf-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/580/s3"},"text":"section 3 of Pub. L. 102–580","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"