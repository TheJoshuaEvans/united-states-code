{"tag":"section","attrib":{"id":"id6bb4dffb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1274"},"text":null,"children":[{"tag":"num","attrib":{"value":"1274"},"text":"§ 1274.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Watershed pilot projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6bb4dffc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1274/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator, in coordination with the States, may provide technical assistance and grants to a municipality or municipal entity to carry out pilot projects relating to the following areas:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bb4dffd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1274/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Watershed management of wet weather discharges","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The management of municipal combined sewer overflows, sanitary sewer overflows, and stormwater discharges, on an integrated watershed or subwatershed basis for the purpose of demonstrating the effectiveness of a unified wet weather approach.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4dffe-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1274/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stormwater best management practices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The control of pollutants from municipal separate storm sewer systems for the purpose of demonstrating and determining controls that are cost-effective and that use innovative technologies to manage, reduce, treat, recapture, or reuse municipal stormwater, including techniques that utilize infiltration, evapotranspiration, and reuse of stormwater onsite.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4dfff-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1274/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Watershed partnerships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Efforts of municipalities and property owners to demonstrate cooperative ways to address nonpoint sources of pollution to reduce adverse impacts on water quality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4e000-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1274/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integrated water resource plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The development of an integrated water resource plan for the coordinated management and protection of surface water, ground water, and stormwater resources on a watershed or subwatershed basis to meet the objectives, goals, and policies of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4e001-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1274/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Municipality-wide stormwater management planning","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The development of a municipality-wide plan that identifies the most effective placement of stormwater technologies and management approaches, to reduce water quality impairments from stormwater on a municipality-wide basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4e002-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1274/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increased resilience of treatment works","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Efforts to assess future risks and vulnerabilities of publicly owned treatment works to manmade or natural disasters, including extreme weather events and sea-level rise, and to carry out measures, on a systemwide or area-wide basis, to increase the resiliency of publicly owned treatment works.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bb4e003-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1274/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator, in coordination with the States, shall provide municipalities participating in a pilot project under this section the ability to engage in innovative practices, including the ability to unify separate wet weather control efforts under a single permit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bb4e004-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1274/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2015-10-01"},"text":"October 1, 2015","children":[],"tail":", the Administrator shall transmit to Congress a report on the results of the pilot projects conducted under this section and their possible application nationwide."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6bb4e005-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"June 30, 1948, ch. 758","children":[],"tail":", title I, § 122, formerly § 121, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dB/tI/s112/b"},"text":"Pub. L. 106–554, § 1(a)(4) [div. B, title I, § 112(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–225; renumbered § 122, "},{"tag":"ref","attrib":{"href":"/us/pl/109/392/s2"},"text":"Pub. L. 109–392, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-12"},"text":"Dec. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2703"},"text":"120 Stat. 2703","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/121/tV/s5011"},"text":"Pub. L. 113–121, title V, § 5011","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1327"},"text":"128 Stat. 1327","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6bb4e006-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6bb4e007-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6bb4e008-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s5011/1"},"text":"Pub. L. 113–121, § 5011(1)","children":[],"tail":", struck out “Wet weather” before “Watershed” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s5011/2/A"},"text":"Pub. L. 113–121, § 5011(2)(A)","children":[],"tail":", in introductory provisions, substituted “to a municipality or municipal entity” for “for treatment works” and struck out “of wet weather discharge control” after “the following areas”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s5011/2/B"},"text":"Pub. L. 113–121, § 5011(2)(B)","children":[],"tail":", substituted “to manage, reduce, treat, recapture, or reuse municipal stormwater, including techniques that utilize infiltration, evapotranspiration, and reuse of stormwater onsite” for “in reducing such pollutants from stormwater discharges”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s5011/2/C"},"text":"Pub. L. 113–121, § 5011(2)(C)","children":[],"tail":", added pars. (3) to (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s5011/3"},"text":"Pub. L. 113–121, § 5011(3)","children":[],"tail":"–(5), redesignated subsec. (d) as (c), substituted “"},{"tag":"date","attrib":{"date":"2015-10-01"},"text":"October 1, 2015","children":[],"tail":",” for “5 years after "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"December 21, 2000","children":[],"tail":",”, and struck out former subsec. (c) which authorized appropriations to carry out this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
