{"tag":"section","attrib":{"id":"id6c86af76-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3604"},"text":null,"children":[{"tag":"num","attrib":{"value":"3604"},"text":"§ 3604.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency financing and agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c86af77-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3604/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce may execute an agreement, on a reimbursable or nonreimbursable basis, with any State or subdivision thereof, any Federal agency, any public or private organization, or any individual to carry out activities under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c86af78-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3604/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reciprocity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Member Departments and agencies of the Council shall have the authority to create, support, and maintain joint centers, and to enter into and perform such contracts, leases, grants, and cooperative agreements as may be necessary to carry out the purposes of this chapter and fulfillment of the System Plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c86af79-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tXII/s12305"},"text":"Pub. L. 111–11, title XII, § 12305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1434"},"text":"123 Stat. 1434","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/271/tI/s104"},"text":"Pub. L. 116–271, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-31"},"text":"Dec. 31, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3339"},"text":"134 Stat. 3339","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c86af7a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c86af7b-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c86af7c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/271"},"text":"Pub. L. 116–271","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, text read as follows: “To carry out interagency activities under this chapter, the Secretary of Commerce may execute cooperative agreements, or any other agreements, with, and receive and expend funds made available by, any State or subdivision thereof, any Federal agency, or any public or private organization, or individual.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
