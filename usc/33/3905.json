{"tag":"section","attrib":{"id":"id6c8ddb49-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3905"},"text":null,"children":[{"tag":"num","attrib":{"value":"3905"},"text":"§ 3905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects eligible for assistance","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The following projects may be carried out with amounts made available under this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c8ddb4a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3905/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any project for flood damage reduction, hurricane and storm damage reduction, environmental restoration, coastal or inland harbor navigation improvement, or inland and intracoastal waterways navigation improvement that the Secretary determines is technically sound, economically justified, and environmentally acceptable, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c8ddb4b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3905/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a project to reduce flood damage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c8ddb4c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3905/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a project to restore aquatic ecosystems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c8ddb4d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3905/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a project to improve the inland and intracoastal waterways navigation system of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c8ddb4e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3905/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a project to improve navigation of a coastal or inland harbor of the United States, including channel deepening and construction of associated general navigation features.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8ddb4f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3905/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more activities that are eligible for assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1383/c"},"text":"section 1383(c) of this title","children":[],"tail":", notwithstanding the public ownership requirement under paragraph (1) of that subsection."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8ddb50-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3905/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300j–12/a/2"},"text":"section 300j–12(a)(2) of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8ddb51-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3905/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A project for enhanced energy efficiency in the operation of a public water system or a publicly owned treatment works.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8ddb52-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3905/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A project for repair, rehabilitation, or replacement of a treatment works, community water system, or aging water distribution or waste collection facility (including a facility that serves a population or community of an Indian reservation).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8ddb53-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3905/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A brackish or sea water desalination project, including chloride control, a managed aquifer recharge project, a water recycling project, or a project to provide alternative water supplies to reduce aquifer depletion.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8ddb54-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3905/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A project to prevent, reduce, or mitigate the effects of drought, including projects that enhance the resilience of drought-stricken watersheds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8ddb55-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3905/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Acquisition of real property or an interest in real property—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c8ddb56-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3905/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the acquisition is integral to a project described in paragraphs (1) through (6); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c8ddb57-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3905/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to an existing plan that, in the judgment of the Administrator or the Secretary, as applicable, would mitigate the environmental impacts of water resources infrastructure projects otherwise eligible for assistance under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8ddb58-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3905/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A combination of projects, each of which is eligible under paragraph (2) or (3), for which a State infrastructure financing authority submits to the Administrator a single application.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8ddb59-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3905/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A combination of projects secured by a common security pledge, each of which is eligible under paragraph (1), (2), (3), (4), (5), (6), (7), or (8), for which an eligible entity, or a combination of eligible entities, submits a single application.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c8ddb5a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/tV/s5026"},"text":"Pub. L. 113–121, title V, § 5026","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1334"},"text":"128 Stat. 1334","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tIV/s5008/b/1"},"text":"Pub. L. 114–322, title IV, § 5008(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1896"},"text":"130 Stat. 1896","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c8ddb5b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c8ddb5c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c8ddb5d-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s5008/b/1/A"},"text":"Pub. L. 114–322, § 5008(b)(1)(A)","children":[],"tail":", substituted “desalination project, including chloride control” for “desalination project” and “a water recycling project, or a project to provide alternative water supplies to reduce aquifer depletion” for “or a water recycling project”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (7) to (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s5008/b/1/B"},"text":"Pub. L. 114–322, § 5008(b)(1)(B)","children":[],"tail":", (C), added par. (7) and redesignated former pars. (7) and (8) as (8) and (9), respectively. Former par. (9) redesignated (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s5008/b/1/B"},"text":"Pub. L. 114–322, § 5008(b)(1)(B)","children":[],"tail":", (D), redesignated par. (9) as (10) and substituted “(7), or (8)” for “or (7)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c8ddb5e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c8ddb5f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s2"},"text":"section 2 of Pub. L. 113–121","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
