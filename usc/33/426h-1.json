{"tag":"section","attrib":{"id":"id6b2a7a88-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426h–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"426h–1"},"text":"§ 426h–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In sections 426e and 426f to 426h–1 of this title, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b2a7a89-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426h–1/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Erosion control program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “erosion control program” means the national shoreline erosion control development and demonstration program established under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b2a7a8a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426h–1/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Army.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b2a7a8b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426h–1/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separable element","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “separable element” has the meaning provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2213/f"},"text":"section 2213(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b2a7a8c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426h–1/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Shore","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “shore” includes each shoreline of the Atlantic and Pacific Oceans, the Gulf of Mexico, the Great Lakes, and lakes, estuaries, and bays directly connected therewith.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b2a7a8d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426h–1/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Shore protection project","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “shore protection project” includes a project for beach nourishment, including the replacement of sand.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b2a7a8e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-13/ch960/s6"},"text":"Aug. 13, 1946, ch. 960, § 6","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/303/tII/s227/e/1"},"text":"Pub. L. 104–303, title II, § 227(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3702"},"text":"110 Stat. 3702","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
