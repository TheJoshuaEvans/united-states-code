{"tag":"section","attrib":{"id":"id6c712b5d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2802"},"text":null,"children":[{"tag":"num","attrib":{"value":"2802"},"text":"§ 2802.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this chapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c712b5e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2802/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Administrator” means the Administrator of the Environmental Protection Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c712b5f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2802/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “coastal ecosystem” means a system of interacting biological, chemical, and physical components throughout the water column, water surface, and benthic environment of coastal waters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c712b60-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2802/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “coastal water quality” means the physical, chemical and biological parameters that relate to the health and integrity of coastal ecosystems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c712b61-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2802/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “coastal water quality monitoring” means a continuing program of measurement, analysis, and synthesis to identify and quantify coastal water quality conditions and trends to provide a technical basis for decisionmaking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c712b62-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2802/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “coastal waters” means waters of the Great Lakes, including their connecting waters and those portions of rivers, streams, and other bodies of water having unimpaired connection with the open sea up to the head of tidal influence, including wetlands, intertidal areas, bays, harbors, and lagoons, including waters of the territorial sea of the United States and the contiguous zone”; ","children":[{"tag":"ref","attrib":{"idref":"fn002124"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002124"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The closing quotation marks preceding the semicolon probably should not appear."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c712b63-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2802/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Under Secretary” means Under Secretary of Commerce for Oceans and Atmosphere.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c712b64-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/532/tV/s502"},"text":"Pub. L. 92–532, title V, § 502","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/567/tV/s501"},"text":"Pub. L. 102–567, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4294"},"text":"106 Stat. 4294","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c712b65-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id6c712b66-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c712b67-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Territorial Sea and Contiguous Zone of United States","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For extension of territorial sea and contiguous zone of United States, see Proc. No. 5928 and Proc. No. 7219, respectively, set out as notes under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1331"},"text":"section 1331 of Title 43","children":[],"tail":", Public Lands."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
