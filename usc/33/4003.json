{"tag":"section","attrib":{"id":"id6c9506dd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4003"},"text":null,"children":[{"tag":"num","attrib":{"value":"4003"},"text":"§ 4003.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive research plan and action strategy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c9506de-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4003/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2014-06-30"},"text":"June 30, 2014","children":[],"tail":", the Under Secretary, through the Task Force, shall develop and submit to Congress a comprehensive research plan and action strategy to address marine and freshwater harmful algal blooms and hypoxia. The Action Strategy shall identify—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c9506df-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4003/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the specific activities to be carried out by the Program and the timeline for carrying out those activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9506e0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4003/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the roles and responsibilities of each Federal agency in the Task Force in carrying out the activities under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9506e1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4003/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate regions and subregions requiring specific research and activities to address harmful algal blooms and hypoxia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c9506e2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4003/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional focus","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regional and subregional parts of the Action Strategy shall identify—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c9506e3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4003/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regional priorities for ecological, economic, and social research on issues related to the impacts of harmful algal blooms and hypoxia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9506e4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4003/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research, development, and demonstration activities needed to develop and advance technologies and techniques for minimizing the occurrence of harmful algal blooms and hypoxia and improving capabilities to detect, predict, monitor, control, mitigate, respond to, and remediate harmful algal blooms and hypoxia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9506e5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4003/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ways to reduce the duration and intensity of harmful algal blooms and hypoxia, including deployment of response technologies in a timely manner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9506e6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4003/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research and methods to address human health dimensions of harmful algal blooms and hypoxia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9506e7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4003/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mechanisms, including the potential costs and benefits of those mechanisms, to protect ecosystems that may be or have been affected by harmful algal bloom and hypoxia events;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9506e8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4003/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mechanisms by which data, information, and products may be transferred between the Program and the State, tribal, and local governments and research entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9506e9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4003/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" communication and information dissemination methods that State, tribal, and local governments may undertake to educate and inform the public concerning harmful algal blooms and hypoxia; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9506ea-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4003/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" roles that Federal agencies may have to assist in the implementation of the Action Strategy, including efforts to support local and regional scientific assessments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s4001/e"},"text":"section 4001(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c9506eb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4003/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilizing available studies and information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the Action Strategy, the Under Secretary shall utilize existing research, assessments, reports, and program activities, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c9506ec-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4003/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" those carried out under existing law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9506ed-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4003/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other relevant peer-reviewed and published sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c9506ee-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4003/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of the Action Strategy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the Action Strategy, the Under Secretary shall, as appropriate—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c9506ef-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4003/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" coordinate with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c9506f0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4003/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State coastal management and planning officials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9506f1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4003/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tribal resource management officials; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9506f2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4003/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water management and watershed officials from both coastal States and noncoastal States with water sources that drain into water bodies affected by harmful algal blooms and hypoxia; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9506f3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4003/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consult with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c9506f4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4003/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public health officials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9506f5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4003/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emergency management officials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9506f6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4003/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" science and technology development institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9506f7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4003/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" economists;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9506f8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4003/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" industries and businesses affected by marine and freshwater harmful algal blooms and hypoxia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9506f9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4003/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scientists with expertise concerning harmful algal blooms or hypoxia from academic or research institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9506fa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4003/d/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other stakeholders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c9506fb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4003/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Register","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary shall publish the Action Strategy in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c9506fc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4003/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic revision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary, in coordination and consultation with the individuals and entities under subsection (d), shall periodically review and revise the Action Strategy prepared under this section, as necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c9506fd-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/383/tVI/s603B"},"text":"Pub. L. 105–383, title VI, § 603B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/124/s5"},"text":"Pub. L. 113–124, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-30"},"text":"June 30, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1382"},"text":"128 Stat. 1382","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
